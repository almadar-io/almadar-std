{
  "name": "std-pagination",
  "version": "1.0.0",
  "description": "std-pagination as a Function — single primitive: pagination + infinite-scroll-sentinel",
  "orbitals": [
    {
      "name": "PagedItemOrbital",
      "entity": {
        "name": "PagedItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PagedItemPagination",
          "category": "interaction",
          "linkedEntity": "PagedItem",
          "emits": [
            {
              "event": "PagedItemLoaded",
              "description": "Fired when PagedItem finishes loading; payload.data holds the page",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PagedItem]"
                }
              ]
            },
            {
              "event": "PagedItemLoadFailed",
              "description": "Fired when PagedItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PagedItemLoaded",
                "name": "PagedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PagedItem]"
                  }
                ]
              },
              {
                "key": "PagedItemLoadFailed",
                "name": "PagedItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAGE",
                "name": "Page",
                "payloadSchema": [
                  {
                    "name": "page",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "pageSize",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "failure": "PagedItemLoadFailed",
                        "success": "PagedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "PagedItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "onPageChange": "@config.event",
                      "totalPages": "@config.totalPages",
                      "type": "pagination",
                      "showPageSize": false,
                      "currentPage": 1.0
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PagedItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "showPageSize": false,
                          "currentPage": 1.0,
                          "type": "pagination",
                          "onPageChange": "@config.event",
                          "totalPages": "@config.totalPages"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "caption",
                          "color": "error"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "xs"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "PAGE",
                "effects": [
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "failure": "PagedItemLoadFailed",
                        "success": "PagedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center",
                      "children": [
                        {
                          "currentPage": 1.0,
                          "onPageChange": "@config.event",
                          "totalPages": "@config.totalPages",
                          "type": "pagination",
                          "showPageSize": false
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "success": "PagedItemLoaded",
                        "failure": "PagedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "totalPages": {
              "type": "number",
              "default": 10.0
            },
            "event": {
              "type": "string",
              "default": "PAGE"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PagedItemPaginationPage",
          "path": "/pageditems/paginated",
          "traits": [
            {
              "ref": "PagedItemPagination"
            }
          ]
        }
      ]
    }
  ]
}
