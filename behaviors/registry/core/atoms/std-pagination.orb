{
  "name": "std-pagination",
  "version": "1.0.0",
  "description": "std-pagination as a Function — single primitive: pagination control.\nThe atom's own PagedItem entity is the UI-state container — every PAGE\ntransition persists currentPage / pageSize. Visual reflection of\n@entity.currentPage on the pagination control needs pattern-registry +\nUI component support for a `currentPage` binding-prop (gap #21.G.3 +\n#21.H follow-ups).",
  "orbitals": [
    {
      "name": "PagedItemOrbital",
      "entity": {
        "name": "PagedItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "currentPage",
            "type": "number"
          },
          {
            "name": "pageSize",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "PagedItemPagination",
          "category": "interaction",
          "linkedEntity": "PagedItem",
          "emits": [
            {
              "event": "PAGE",
              "payloadSchema": [
                {
                  "name": "page",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "pageSize",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PAGE",
                "name": "Page",
                "payloadSchema": [
                  {
                    "name": "page",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "pageSize",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "currentPage": 1.0,
                      "onPageChange": "@config.event",
                      "totalPages": "@config.totalPages",
                      "showPageSize": false
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    "@payload.page"
                  ],
                  [
                    "set",
                    "@entity.pageSize",
                    "@payload.pageSize"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "totalPages": "@config.totalPages",
                      "onPageChange": "@config.event",
                      "currentPage": 1.0,
                      "showPageSize": false
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "PAGE"
            },
            "pageSize": {
              "type": "number",
              "default": 10.0
            },
            "totalPages": {
              "type": "number",
              "default": 1.0
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PagedItemPaginationPage",
          "path": "/pageditems/paginated",
          "traits": [
            {
              "ref": "PagedItemPagination"
            }
          ]
        }
      ]
    }
  ]
}
