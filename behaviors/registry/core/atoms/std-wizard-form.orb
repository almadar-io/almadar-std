{
  "description": "std-wizard-form — canonical molecule-level wizard example (3-step sign-up flow). Wizards own their state machine at molecule tier.",
  "name": "std-wizard-form",
  "orbitals": [
    {
      "entity": {
        "collection": "wizardformentries",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "User-provided text identifying the entry.",
            "name": "name",
            "synonyms": "label, title, identifier",
            "type": "string"
          },
          {
            "description": "User-provided email address.",
            "name": "email",
            "synonyms": "email address, email, user email",
            "type": "string"
          },
          {
            "description": "Visual style or appearance applied to the entry.",
            "name": "theme",
            "synonyms": "style, appearance, look, design",
            "type": "string"
          }
        ],
        "name": "WizardFormEntry",
        "persistence": "persistent"
      },
      "name": "WizardFormOrbital",
      "pages": [
        {
          "name": "WizardForm",
          "path": "/wizard-form",
          "traits": [
            {
              "ref": "WizardFormFlow"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Indicates progression to the next step in a sequence.",
              "event": "NEXT",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                },
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ],
              "synonyms": "advance, proceed, continue",
              "tier": "domain"
            },
            {
              "description": "Indicates the user navigated to the previous step.",
              "event": "PREV",
              "payloadSchema": [
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ],
              "synonyms": "back, previous, undo",
              "tier": "domain"
            },
            {
              "description": "Indicates the wizard form has been successfully completed.",
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                },
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ],
              "synonyms": "finished, done, submitted",
              "tier": "domain"
            },
            {
              "description": "Indicates the form data has been successfully saved.",
              "event": "WizardFormSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "saved, submitted, finalized",
              "tier": "domain"
            },
            {
              "description": "Indicates a failure during the save operation.",
              "event": "WizardFormSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "error, failed, problem, unsuccessful",
              "tier": "internal"
            },
            {
              "description": "Signals that a form entry has been successfully loaded.",
              "event": "WizardFormEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[WizardFormEntry]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, initialized, ready",
              "tier": "internal"
            },
            {
              "description": "Indicates failure to load a form entry.",
              "event": "WizardFormEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "error, failure, problem, load error",
              "tier": "internal"
            }
          ],
          "linkedEntity": "WizardFormEntry",
          "name": "WizardFormFlow",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates progression to the next step in a sequence.",
                "key": "NEXT",
                "name": "Next",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  },
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ],
                "synonyms": "advance, proceed, continue",
                "tier": "domain"
              },
              {
                "description": "Indicates the user navigated to the previous step.",
                "key": "PREV",
                "name": "Prev",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ],
                "synonyms": "back, previous, undo",
                "tier": "domain"
              },
              {
                "description": "Indicates the wizard form has been successfully completed.",
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  },
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ],
                "synonyms": "finished, done, submitted",
                "tier": "domain"
              },
              {
                "description": "Indicates the form data has been successfully saved.",
                "key": "WizardFormSaved",
                "name": "Wizard form saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ],
                "synonyms": "saved, submitted, finalized",
                "tier": "domain"
              },
              {
                "description": "Indicates a failure during the save operation.",
                "key": "WizardFormSaveFailed",
                "name": "Wizard form save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failed, problem, unsuccessful",
                "tier": "internal"
              },
              {
                "description": "Resets the wizard to its initial state.",
                "key": "RESTART",
                "name": "Restart",
                "synonyms": "reset, clear, begin, start",
                "tier": "presentation"
              },
              {
                "description": "Signals that a form entry has been successfully loaded.",
                "key": "WizardFormEntryLoaded",
                "name": "WizardFormEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WizardFormEntry]"
                  }
                ],
                "synonyms": "loaded, initialized, ready",
                "tier": "internal"
              },
              {
                "description": "Indicates failure to load a form entry.",
                "key": "WizardFormEntryLoadFailed",
                "name": "WizardFormEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failure, problem, load error",
                "tier": "internal"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "personal"
              },
              {
                "name": "preferences"
              },
              {
                "name": "review"
              },
              {
                "name": "persisting"
              },
              {
                "name": "complete"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "WizardFormEntry",
                    {
                      "emit": {
                        "failure": "WizardFormEntryLoadFailed",
                        "success": "WizardFormEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "user-plus",
                              "type": "icon"
                            },
                            {
                              "content": "Sign-up",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 0.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Personal Info",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "cancelEvent": "INIT",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "mode": "create",
                          "submitEvent": "NEXT",
                          "type": "form-section"
                        },
                        {
                          "currentStep": 0.0,
                          "onNext": "NEXT",
                          "showBack": false,
                          "showComplete": false,
                          "showNext": true,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "personal",
                "to": "personal"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.name",
                    "@payload.data.name"
                  ],
                  [
                    "set",
                    "@entity.email",
                    "@payload.data.email"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "user-plus",
                              "type": "icon"
                            },
                            {
                              "content": "Sign-up",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 1.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Preferences",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "cancelEvent": "PREV",
                          "entity": "@entity",
                          "fields": [
                            "theme"
                          ],
                          "mode": "edit",
                          "submitEvent": "NEXT",
                          "type": "form-section"
                        },
                        {
                          "currentStep": 1.0,
                          "onBack": "PREV",
                          "onNext": "NEXT",
                          "showBack": true,
                          "showComplete": false,
                          "showNext": true,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "NEXT",
                "from": "personal",
                "to": "preferences"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.theme",
                    "@payload.data.theme"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "user-plus",
                              "type": "icon"
                            },
                            {
                              "content": "Sign-up",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 2.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Review",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Name",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.name",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Email",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.email",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Theme",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.theme",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "between",
                              "type": "stack"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 2.0,
                          "onBack": "PREV",
                          "onComplete": "COMPLETE",
                          "showBack": true,
                          "showComplete": true,
                          "showNext": false,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "NEXT",
                "from": "preferences",
                "to": "review"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "user-plus",
                              "type": "icon"
                            },
                            {
                              "content": "Sign-up",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 0.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Personal Info",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "cancelEvent": "INIT",
                          "entity": "@entity",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "mode": "edit",
                          "submitEvent": "NEXT",
                          "type": "form-section"
                        },
                        {
                          "currentStep": 0.0,
                          "onNext": "NEXT",
                          "showBack": false,
                          "showComplete": false,
                          "showNext": true,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PREV",
                "from": "preferences",
                "to": "personal"
              },
              {
                "effects": [
                  [
                    "persist",
                    "create",
                    "WizardFormEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "WizardFormSaveFailed",
                        "success": "WizardFormSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Completing sign-up…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full py-12",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "COMPLETE",
                "from": "review",
                "to": "persisting"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "user-plus",
                              "type": "icon"
                            },
                            {
                              "content": "Sign-up",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 1.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Preferences",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "cancelEvent": "PREV",
                          "entity": "@entity",
                          "fields": [
                            "theme"
                          ],
                          "mode": "edit",
                          "submitEvent": "NEXT",
                          "type": "form-section"
                        },
                        {
                          "currentStep": 1.0,
                          "onBack": "PREV",
                          "onNext": "NEXT",
                          "showBack": true,
                          "showComplete": false,
                          "showNext": true,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "PREV",
                "from": "review",
                "to": "preferences"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Welcome!",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "Your account has been created.",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "RESTART",
                          "icon": "rotate-ccw",
                          "label": "Start Over",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full py-12",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "WizardFormSaved",
                "from": "persisting",
                "to": "complete"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Sign-up Failed",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "message": "@payload.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "action": "COMPLETE",
                          "icon": "refresh-cw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full py-12",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "WizardFormSaveFailed",
                "from": "persisting",
                "to": "review"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "user-plus",
                              "type": "icon"
                            },
                            {
                              "content": "Sign-up",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": 0.0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Personal Info",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "cancelEvent": "INIT",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "mode": "create",
                          "submitEvent": "NEXT",
                          "type": "form-section"
                        },
                        {
                          "currentStep": 0.0,
                          "onNext": "NEXT",
                          "showBack": false,
                          "showComplete": false,
                          "showNext": true,
                          "totalSteps": 3.0,
                          "type": "wizard-navigation"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RESTART",
                "from": "complete",
                "to": "personal"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}