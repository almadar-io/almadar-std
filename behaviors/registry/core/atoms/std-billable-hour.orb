{
  "name": "std-billable-hour",
  "version": "1.0.0",
  "description": "std-billable-hour — generic billable-hour timesheet primitive for legal, agency, and consulting domains. Lists entries in `browsing`; opens entry detail in `viewing_single` with Invoice / Write Off actions.",
  "orbitals": [
    {
      "name": "BillableHourOrbital",
      "entity": {
        "name": "BillableHour",
        "collection": "billablehours",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "workerId",
            "type": "string",
            "required": true
          },
          {
            "name": "workerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "matterId",
            "type": "string",
            "default": ""
          },
          {
            "name": "projectId",
            "type": "string",
            "default": ""
          },
          {
            "name": "workDate",
            "type": "string",
            "required": true
          },
          {
            "name": "hours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "rate",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "isBillable",
            "type": "boolean",
            "default": true
          },
          {
            "name": "invoiceStatus",
            "type": "string",
            "default": "unbilled",
            "values": [
              "unbilled",
              "invoiced",
              "paid",
              "written_off"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "BillableHourTimesheet",
          "category": "interaction",
          "linkedEntity": "BillableHour",
          "emits": [
            {
              "event": "OPEN_HOURS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.workerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.workerName",
                  "type": "string"
                },
                {
                  "name": "row.matterId",
                  "type": "string"
                },
                {
                  "name": "row.projectId",
                  "type": "string"
                },
                {
                  "name": "row.workDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.hours",
                  "type": "number"
                },
                {
                  "name": "row.rate",
                  "type": "number"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.isBillable",
                  "type": "boolean"
                },
                {
                  "name": "row.invoiceStatus",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "INVOICE_HOURS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WRITE_OFF_HOURS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BillableHourLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BillableHour]"
                }
              ]
            },
            {
              "event": "BillableHourLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BillableHourLoaded",
                "name": "BillableHour loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BillableHour]"
                  }
                ]
              },
              {
                "key": "BillableHourLoadFailed",
                "name": "BillableHour load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_HOURS",
                "name": "Open Hours",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BillableHour"
                  }
                ]
              },
              {
                "key": "WRITE_OFF_HOURS",
                "name": "Write Off Hours",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "INVOICE_HOURS",
                "name": "Invoice Hours",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading time entries…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BillableHourLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total entries",
                              "icon": "clock"
                            },
                            {
                              "value": "248",
                              "icon": "hourglass",
                              "label": "Unbilled hours",
                              "type": "stat-display"
                            },
                            {
                              "value": "32",
                              "label": "Invoiced this month",
                              "icon": "file-text",
                              "type": "stat-display"
                            },
                            {
                              "value": "4",
                              "label": "Written off",
                              "type": "stat-display",
                              "icon": "x-circle"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "workerName",
                              "label": "Worker"
                            },
                            {
                              "name": "matterId",
                              "variant": "caption",
                              "label": "Matter"
                            },
                            {
                              "name": "workDate",
                              "label": "Date",
                              "variant": "caption"
                            },
                            {
                              "label": "Hours",
                              "variant": "caption",
                              "name": "hours"
                            },
                            {
                              "label": "Rate",
                              "variant": "caption",
                              "name": "rate"
                            },
                            {
                              "name": "invoiceStatus",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ],
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Open",
                              "variant": "primary",
                              "icon": "arrow-right",
                              "event": "OPEN_HOURS"
                            },
                            {
                              "label": "Write Off",
                              "event": "WRITE_OFF_HOURS",
                              "variant": "danger"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BillableHourLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.workerId",
                    "@payload.row.workerId"
                  ],
                  [
                    "set",
                    "@entity.workerName",
                    "@payload.row.workerName"
                  ],
                  [
                    "set",
                    "@entity.matterId",
                    "@payload.row.matterId"
                  ],
                  [
                    "set",
                    "@entity.projectId",
                    "@payload.row.projectId"
                  ],
                  [
                    "set",
                    "@entity.workDate",
                    "@payload.row.workDate"
                  ],
                  [
                    "set",
                    "@entity.hours",
                    "@payload.row.hours"
                  ],
                  [
                    "set",
                    "@entity.rate",
                    "@payload.row.rate"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.isBillable",
                    "@payload.row.isBillable"
                  ],
                  [
                    "set",
                    "@entity.invoiceStatus",
                    "@payload.row.invoiceStatus"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.workerName",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.invoiceStatus",
                              "type": "badge",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Matter",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.matterId"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Project"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.projectId"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Description",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.description",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.hours",
                              "icon": "clock",
                              "type": "stat-display",
                              "label": "Hours"
                            },
                            {
                              "value": "@entity.rate",
                              "type": "stat-display",
                              "label": "Rate",
                              "icon": "dollar-sign"
                            },
                            {
                              "value": "@entity.workDate",
                              "type": "stat-display",
                              "label": "Date",
                              "icon": "calendar"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "action": "INVOICE_HOURS",
                              "type": "button",
                              "label": "Invoice",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Write Off",
                              "type": "button",
                              "variant": "danger",
                              "action": "WRITE_OFF_HOURS"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WRITE_OFF_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "success": "BillableHourLoaded",
                        "failure": "BillableHourLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Writing off hours…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading time entries…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "INVOICE_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Invoicing hours…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "WRITE_OFF_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Writing off hours…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "success": "BillableHourLoaded",
                        "failure": "BillableHourLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Time Entries",
              "label": "Section title",
              "description": "Heading shown above the time-entries list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BillableHourPage",
          "path": "/timesheet",
          "traits": [
            {
              "ref": "BillableHourTimesheet"
            }
          ]
        }
      ]
    }
  ]
}