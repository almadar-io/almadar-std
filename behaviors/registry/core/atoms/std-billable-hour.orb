{
  "name": "std-billable-hour",
  "version": "1.0.0",
  "description": "std-billable-hour — generic billable-hour timesheet primitive for legal, agency, and consulting domains. Lists entries in `browsing`; opens entry detail in `viewing_single` with Invoice / Write Off actions.",
  "orbitals": [
    {
      "name": "BillableHourOrbital",
      "entity": {
        "name": "BillableHour",
        "collection": "billablehours",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "workerId",
            "type": "string",
            "required": true,
            "description": "Unique identifier for the worker.",
            "synonyms": "employeeId, staffId, userId"
          },
          {
            "name": "workerName",
            "type": "string",
            "default": "",
            "description": "The name of the worker associated with the time entry.",
            "synonyms": "employee, staff, personnel"
          },
          {
            "name": "matterId",
            "type": "string",
            "default": "",
            "description": "Unique identifier for the associated case or project.",
            "synonyms": "caseId, projectID, reference"
          },
          {
            "name": "projectId",
            "type": "string",
            "default": "",
            "description": "Identifier for the project associated with the time entry.",
            "synonyms": "project, task, reference"
          },
          {
            "name": "workDate",
            "type": "string",
            "required": true,
            "description": "The date on which the work was performed.",
            "synonyms": "date, transaction date, service date"
          },
          {
            "name": "hours",
            "type": "number",
            "default": 0.0,
            "description": "The quantity of time recorded.",
            "synonyms": "duration, time, amount"
          },
          {
            "name": "rate",
            "type": "number",
            "default": 0.0,
            "description": "The hourly charge for the work performed.",
            "synonyms": "price, cost, amount"
          },
          {
            "name": "description",
            "type": "string",
            "default": "",
            "description": "A textual explanation of the hour entry.",
            "synonyms": "explanation, notes, details, comment"
          },
          {
            "name": "isBillable",
            "type": "boolean",
            "default": true,
            "description": "Indicates whether the hour is eligible for billing.",
            "synonyms": "billable flag, billing status, billable indicator"
          },
          {
            "name": "invoiceStatus",
            "type": "string",
            "default": "unbilled",
            "values": [
              "unbilled",
              "invoiced",
              "paid",
              "written_off"
            ],
            "description": "The current billing status of the hour entry.",
            "synonyms": "status, billing status, payment status"
          }
        ]
      },
      "traits": [
        {
          "name": "BillableHourTimesheet",
          "category": "interaction",
          "linkedEntity": "BillableHour",
          "emits": [
            {
              "event": "OPEN_HOURS",
              "description": "Signals the display of the hours list.",
              "synonyms": "show, display, list",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row",
                  "type": "object",
                  "properties": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "workerId",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "workerName",
                      "type": "string"
                    },
                    {
                      "name": "matterId",
                      "type": "string"
                    },
                    {
                      "name": "projectId",
                      "type": "string"
                    },
                    {
                      "name": "workDate",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "hours",
                      "type": "number"
                    },
                    {
                      "name": "rate",
                      "type": "number"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    },
                    {
                      "name": "isBillable",
                      "type": "boolean"
                    },
                    {
                      "name": "invoiceStatus",
                      "type": "string"
                    }
                  ]
                }
              ]
            },
            {
              "event": "CLOSE_VIEW",
              "description": "Indicates the detail view has been dismissed.",
              "synonyms": "dismiss, close, hide",
              "tier": "essential"
            },
            {
              "event": "INVOICE_HOURS",
              "description": "Signals that billable hours have been invoiced.",
              "synonyms": "invoice, charge, bill",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WRITE_OFF_HOURS",
              "description": "Indicates billable hours have been written off.",
              "synonyms": "deduct, remove, cancel",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BillableHourLoaded",
              "description": "Signals that a billable hour data set has been successfully retrieved.",
              "synonyms": "loaded, fetched, retrieved, populated",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BillableHour]"
                }
              ]
            },
            {
              "event": "BillableHourLoadFailed",
              "description": "Indicates a failure to load billable hour data.",
              "synonyms": "error, failed, problem, unsuccessful",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BillableHourLoaded",
                "name": "BillableHour loaded",
                "description": "Signals that a billable hour data set has been successfully retrieved.",
                "synonyms": "loaded, fetched, retrieved, populated",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BillableHour]"
                  }
                ]
              },
              {
                "key": "BillableHourLoadFailed",
                "name": "BillableHour load failed",
                "description": "Indicates a failure to load billable hour data.",
                "synonyms": "error, failed, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_HOURS",
                "name": "Open Hours",
                "description": "Signals the display of the hours list.",
                "synonyms": "show, display, list",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BillableHour"
                  }
                ]
              },
              {
                "key": "WRITE_OFF_HOURS",
                "name": "Write Off Hours",
                "description": "Indicates billable hours have been written off.",
                "synonyms": "deduct, remove, cancel",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View",
                "description": "Indicates the detail view has been dismissed.",
                "synonyms": "dismiss, close, hide",
                "tier": "essential"
              },
              {
                "key": "INVOICE_HOURS",
                "name": "Invoice Hours",
                "description": "Signals that billable hours have been invoiced.",
                "synonyms": "invoice, charge, bill",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading time entries…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BillableHourLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "icon": "clock",
                              "look": "@config.statLook",
                              "label": "Total entries",
                              "value": "@payload.data.length",
                              "type": "stat-display"
                            },
                            {
                              "label": "Unbilled hours",
                              "type": "stat-display",
                              "value": "248",
                              "look": "@config.statLook",
                              "icon": "hourglass"
                            },
                            {
                              "icon": "file-text",
                              "label": "Invoiced this month",
                              "type": "stat-display",
                              "value": "32",
                              "look": "@config.statLook"
                            },
                            {
                              "icon": "x-circle",
                              "type": "stat-display",
                              "value": "4",
                              "look": "@config.statLook",
                              "label": "Written off"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "name": "workerName",
                              "label": "Worker",
                              "variant": "caption"
                            },
                            {
                              "label": "Matter",
                              "name": "matterId",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "label": "Date",
                              "name": "workDate"
                            },
                            {
                              "variant": "caption",
                              "name": "hours",
                              "label": "Hours"
                            },
                            {
                              "label": "Rate",
                              "name": "rate",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "invoiceStatus"
                            }
                          ],
                          "gap": "sm",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "OPEN_HOURS",
                              "icon": "arrow-right",
                              "label": "Open",
                              "variant": "primary"
                            },
                            {
                              "event": "WRITE_OFF_HOURS",
                              "label": "Write Off",
                              "variant": "danger"
                            }
                          ],
                          "look": "@config.tableLook",
                          "type": "data-grid",
                          "cols": 1.0
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BillableHourLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.workerId",
                    "@payload.row.workerId"
                  ],
                  [
                    "set",
                    "@entity.workerName",
                    "@payload.row.workerName"
                  ],
                  [
                    "set",
                    "@entity.matterId",
                    "@payload.row.matterId"
                  ],
                  [
                    "set",
                    "@entity.projectId",
                    "@payload.row.projectId"
                  ],
                  [
                    "set",
                    "@entity.workDate",
                    "@payload.row.workDate"
                  ],
                  [
                    "set",
                    "@entity.hours",
                    "@payload.row.hours"
                  ],
                  [
                    "set",
                    "@entity.rate",
                    "@payload.row.rate"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.isBillable",
                    "@payload.row.isBillable"
                  ],
                  [
                    "set",
                    "@entity.invoiceStatus",
                    "@payload.row.invoiceStatus"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.workerName"
                            },
                            {
                              "label": "@entity.invoiceStatus",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Matter",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.matterId"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Project",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.projectId",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Description"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.description",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.hours",
                              "icon": "clock",
                              "label": "Hours",
                              "look": "@config.statLook"
                            },
                            {
                              "value": "@entity.rate",
                              "look": "@config.statLook",
                              "icon": "dollar-sign",
                              "label": "Rate",
                              "type": "stat-display"
                            },
                            {
                              "label": "Date",
                              "type": "stat-display",
                              "value": "@entity.workDate",
                              "look": "@config.statLook",
                              "icon": "calendar"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Invoice",
                              "type": "button",
                              "variant": "primary",
                              "action": "INVOICE_HOURS"
                            },
                            {
                              "type": "button",
                              "action": "WRITE_OFF_HOURS",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Write Off",
                              "variant": "danger"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WRITE_OFF_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Writing off hours…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading time entries…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "INVOICE_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "success": "BillableHourLoaded",
                        "failure": "BillableHourLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Invoicing hours…"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "WRITE_OFF_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Writing off hours…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "success": "BillableHourLoaded",
                        "failure": "BillableHourLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "statLook": {
              "type": "string",
              "default": "elevated",
              "label": "Stat display look",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            },
            "title": {
              "type": "string",
              "default": "Time Entries",
              "label": "Section title",
              "description": "Heading shown above the time-entries list",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BillableHourPage",
          "path": "/timesheet",
          "traits": [
            {
              "ref": "BillableHourTimesheet"
            }
          ]
        }
      ]
    }
  ]
}
