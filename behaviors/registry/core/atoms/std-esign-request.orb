{
  "name": "std-esign-request",
  "version": "1.0.0",
  "description": "Generic e-signature request primitive: send a document for signing and track status.",
  "orbitals": [
    {
      "name": "ESignRequestOrbital",
      "entity": {
        "name": "ESignRequest",
        "collection": "esignrequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "documentId",
            "type": "string",
            "required": true
          },
          {
            "name": "documentName",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientName",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientEmail",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "viewed",
              "signed",
              "declined",
              "expired"
            ]
          },
          {
            "name": "sentAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "signedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "expiresAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ESignRequestSigning",
          "category": "interaction",
          "linkedEntity": "ESignRequest",
          "emits": [
            {
              "event": "SEND_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVOKE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ESignRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ESignRequest]"
                }
              ]
            },
            {
              "event": "ESignRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ESignRequestLoaded",
                "name": "ESignRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ESignRequest]"
                  }
                ]
              },
              {
                "key": "ESignRequestLoadFailed",
                "name": "ESignRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEND_REQUEST",
                "name": "Send Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVOKE_REQUEST",
                "name": "Revoke Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ESignRequest",
                    {
                      "emit": {
                        "success": "ESignRequestLoaded",
                        "failure": "ESignRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ESignRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "variant": "h3",
                          "content": "@config.title",
                          "type": "typography"
                        },
                        {
                          "type": "signature-pad",
                          "height": 160.0,
                          "readOnly": true,
                          "helperText": "Read-only preview of the captured signature",
                          "label": "Recipient signature preview"
                        },
                        {
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Send",
                              "event": "SEND_REQUEST",
                              "variant": "primary"
                            },
                            {
                              "event": "REVOKE_REQUEST",
                              "variant": "danger",
                              "label": "Revoke"
                            }
                          ],
                          "fields": [
                            {
                              "label": "Document",
                              "variant": "h4",
                              "name": "documentName"
                            },
                            {
                              "variant": "body",
                              "name": "recipientName",
                              "label": "Recipient"
                            },
                            {
                              "variant": "caption",
                              "name": "recipientEmail",
                              "label": "Email"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "name": "sentAt",
                              "variant": "caption",
                              "label": "Sent"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ESignRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Failed to load signature requests",
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEND_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Signature request sent",
                    "success"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REVOKE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Signature request revoked",
                    "info"
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ESignRequest",
                    {
                      "emit": {
                        "failure": "ESignRequestLoadFailed",
                        "success": "ESignRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Signature Requests",
              "label": "Section title",
              "description": "Heading shown above the signature-request list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ESignRequestPage",
          "path": "/esign",
          "traits": [
            {
              "ref": "ESignRequestSigning"
            }
          ]
        }
      ]
    }
  ]
}