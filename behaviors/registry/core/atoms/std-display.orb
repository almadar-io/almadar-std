{
  "name": "std-display",
  "version": "1.1.0",
  "description": "std-display — DEPRECATED. Use std-stats (stat-cards) + std-graphs (charts) composed in a molecule (see std-dashboard); the original violated the explicit-binding rule. Preserved so existing imports keep loading.",
  "orbitals": [
    {
      "name": "DisplayItemOrbital",
      "entity": {
        "name": "DisplayItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DisplayItemDisplay",
          "category": "interaction",
          "linkedEntity": "DisplayItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "warning",
                      "title": "std-display is deprecated",
                      "message": "@config.message"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "message": {
              "type": "string",
              "default": "std-display is deprecated — use std-stats and std-graphs instead. See docs/Almadar_Std_Verification.md gap #25.",
              "label": "Deprecation message",
              "description": "Warning text shown in the deprecated std-display alert banner",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DisplayItemDisplayPage",
          "path": "/displayitems",
          "traits": [
            {
              "ref": "DisplayItemDisplay"
            }
          ]
        }
      ]
    }
  ]
}