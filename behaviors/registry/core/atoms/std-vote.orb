{
  "name": "std-vote",
  "version": "1.0.0",
  "description": "std-vote — forum-style up/down vote tally with single-vote-per-user constraint. Owns a Vote entity; VOTE persists the new direction (toggling to none when re-clicking the active arrow) and emits VoteCasted so cross-trait listeners can recompute aggregates.",
  "orbitals": [
    {
      "name": "VoteOrbital",
      "entity": {
        "name": "Vote",
        "collection": "votes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "voterId",
            "type": "string",
            "required": true
          },
          {
            "name": "direction",
            "type": "string",
            "default": "none",
            "values": [
              "up",
              "down",
              "none"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "VoteCast",
          "category": "interaction",
          "linkedEntity": "Vote",
          "emits": [
            {
              "event": "VOTE",
              "payloadSchema": [
                {
                  "name": "next",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "VoteLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Vote]"
                }
              ]
            },
            {
              "event": "VoteLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VoteCasted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.voterId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.direction",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VoteCastFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "voting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VoteLoaded",
                "name": "Vote loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Vote]"
                  }
                ]
              },
              {
                "key": "VoteLoadFailed",
                "name": "Vote load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VOTE",
                "name": "Vote",
                "payloadSchema": [
                  {
                    "name": "next",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "VoteCasted",
                "name": "Vote casted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Vote"
                  }
                ]
              },
              {
                "key": "VoteCastFailed",
                "name": "Vote cast failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vote",
                    {
                      "emit": {
                        "failure": "VoteLoadFailed",
                        "success": "VoteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading votes…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "VoteLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "label": "Vote",
                      "userVote": "@entity.direction",
                      "variant": "vertical",
                      "type": "vote-stack",
                      "count": 0.0,
                      "onVote": "VOTE"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "VoteLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "voting",
                "event": "VOTE",
                "guard": [
                  "not",
                  [
                    "=",
                    "@payload.next",
                    "@entity.direction"
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.direction",
                    "@payload.next"
                  ],
                  [
                    "persist",
                    "update",
                    "Vote",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "VoteCastFailed",
                        "success": "VoteCasted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Recording your vote…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "voting",
                "event": "VOTE",
                "guard": [
                  "=",
                  "@payload.next",
                  "@entity.direction"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.direction",
                    "none"
                  ],
                  [
                    "persist",
                    "update",
                    "Vote",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "VoteCasted",
                        "failure": "VoteCastFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Clearing your vote…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "voting",
                "to": "idle",
                "event": "VoteCasted",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "count": 0.0,
                      "userVote": "@entity.direction",
                      "onVote": "VOTE",
                      "variant": "vertical",
                      "type": "vote-stack",
                      "label": "Vote"
                    }
                  ]
                ]
              },
              {
                "from": "voting",
                "to": "error",
                "event": "VoteCastFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vote",
                    {
                      "emit": {
                        "failure": "VoteLoadFailed",
                        "success": "VoteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading votes…"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "allowDown": {
              "type": "boolean",
              "default": true,
              "label": "Allow downvotes",
              "description": "Show the downvote arrow alongside the upvote"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "VoteCastPage",
          "path": "/votes/cast",
          "traits": [
            {
              "ref": "VoteCast"
            }
          ]
        }
      ]
    }
  ]
}