{
  "name": "std-tag-taxonomy",
  "version": "1.1.0",
  "description": "std-tag-taxonomy — hierarchical category tag tree (parent/child). TagBrowse fetches Tag rows on INIT, renders the active level via data-grid, and on SELECT_TAG drills into a tag's children by binding @entity.id to the chosen parent.",
  "orbitals": [
    {
      "name": "TagTaxonomyOrbital",
      "entity": {
        "name": "Tag",
        "collection": "tags",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "The descriptive label for this item.",
            "synonyms": "label, title, description"
          },
          {
            "name": "parentId",
            "type": "string",
            "description": "Reference to the parent tag in the hierarchy.",
            "synonyms": "parent, superior, ancestor"
          },
          {
            "name": "slug",
            "type": "string",
            "description": "A unique, URL-friendly identifier.",
            "synonyms": "identifier, key, code"
          },
          {
            "name": "color",
            "type": "string",
            "description": "A visual identifier, often used for categorization.",
            "synonyms": "hue, shade, tint, category color"
          },
          {
            "name": "count",
            "type": "number",
            "default": 0.0,
            "description": "The number of items associated with this entry.",
            "synonyms": "quantity, total, size, amount"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TagBrowse",
          "category": "interaction",
          "linkedEntity": "Tag",
          "emits": [
            {
              "event": "SELECT_TAG",
              "payloadSchema": [
                {
                  "name": "tagId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TagLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Tag]"
                }
              ]
            },
            {
              "event": "TagLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TagSelected",
              "payloadSchema": [
                {
                  "name": "tagId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TagLoaded",
                "name": "Tag loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Tag]"
                  }
                ]
              },
              {
                "key": "TagLoadFailed",
                "name": "Tag load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TAG",
                "name": "Select Tag",
                "payloadSchema": [
                  {
                    "name": "tagId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TagSelected",
                "name": "Tag selected",
                "payloadSchema": [
                  {
                    "name": "tagId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "failure": "TagLoadFailed",
                        "success": "TagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading categories…"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "type": "data-grid",
                          "minCardWidth": 180.0,
                          "fields": [],
                          "entity": "@payload.data",
                          "gap": "sm",
                          "renderItem": [
                            "fn",
                            "tag",
                            {
                              "look": "flat-bordered",
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "xs",
                                  "direction": "vertical",
                                  "children": [
                                    {
                                      "children": [
                                        {
                                          "align": "center",
                                          "direction": "horizontal",
                                          "className": "min-w-0",
                                          "type": "stack",
                                          "children": [
                                            {
                                              "size": "sm",
                                              "type": "icon",
                                              "name": "tag"
                                            },
                                            {
                                              "type": "typography",
                                              "variant": "body",
                                              "content": "@tag.name",
                                              "weight": "medium",
                                              "className": "truncate"
                                            }
                                          ],
                                          "gap": "sm"
                                        },
                                        {
                                          "label": "@tag.count",
                                          "variant": "neutral",
                                          "type": "badge",
                                          "size": "sm"
                                        }
                                      ],
                                      "justify": "between",
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "align": "center",
                                      "gap": "sm"
                                    },
                                    {
                                      "variant": "ghost",
                                      "action": "SELECT_TAG",
                                      "actionPayload": {
                                        "tagId": "@tag.id"
                                      },
                                      "icon": "chevron-right",
                                      "size": "sm",
                                      "type": "button",
                                      "className": "w-full justify-center",
                                      "label": "Open"
                                    }
                                  ]
                                }
                              ],
                              "padding": "sm",
                              "className": "cursor-pointer hover:shadow-md transition-shadow"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "SELECT_TAG",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tagId"
                  ],
                  [
                    "emit",
                    "TagSelected",
                    {
                      "tagId": "@payload.tagId"
                    }
                  ],
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "failure": "TagLoadFailed",
                        "success": "TagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading children…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@config.title"
                        },
                        {
                          "gap": "sm",
                          "renderItem": [
                            "fn",
                            "tag",
                            {
                              "className": "cursor-pointer hover:shadow-md transition-shadow",
                              "type": "card",
                              "padding": "sm",
                              "look": "flat-bordered",
                              "children": [
                                {
                                  "gap": "xs",
                                  "direction": "vertical",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "direction": "horizontal",
                                          "className": "min-w-0",
                                          "type": "stack",
                                          "children": [
                                            {
                                              "name": "tag",
                                              "type": "icon",
                                              "size": "sm"
                                            },
                                            {
                                              "type": "typography",
                                              "content": "@tag.name",
                                              "weight": "medium",
                                              "variant": "body",
                                              "className": "truncate"
                                            }
                                          ],
                                          "gap": "sm",
                                          "align": "center"
                                        },
                                        {
                                          "variant": "neutral",
                                          "size": "sm",
                                          "type": "badge",
                                          "label": "@tag.count"
                                        }
                                      ],
                                      "type": "stack",
                                      "direction": "horizontal",
                                      "justify": "between",
                                      "align": "center"
                                    },
                                    {
                                      "label": "Open",
                                      "variant": "ghost",
                                      "className": "w-full justify-center",
                                      "icon": "chevron-right",
                                      "actionPayload": {
                                        "tagId": "@tag.id"
                                      },
                                      "action": "SELECT_TAG",
                                      "size": "sm",
                                      "type": "button"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "minCardWidth": 180.0,
                          "fields": [],
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "TagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "failure": "TagLoadFailed",
                        "success": "TagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading categories…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "SELECT_TAG",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tagId"
                  ],
                  [
                    "emit",
                    "TagSelected",
                    {
                      "tagId": "@payload.tagId"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "TagSelected",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tagId"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "TagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@config.title"
                        },
                        {
                          "entity": "@payload.data",
                          "renderItem": [
                            "fn",
                            "tag",
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "vertical",
                                  "gap": "xs",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "gap": "sm",
                                      "align": "center",
                                      "justify": "between",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "className": "min-w-0",
                                          "gap": "sm",
                                          "direction": "horizontal",
                                          "type": "stack",
                                          "align": "center",
                                          "children": [
                                            {
                                              "size": "sm",
                                              "type": "icon",
                                              "name": "tag"
                                            },
                                            {
                                              "weight": "medium",
                                              "content": "@tag.name",
                                              "className": "truncate",
                                              "variant": "body",
                                              "type": "typography"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "badge",
                                          "size": "sm",
                                          "variant": "neutral",
                                          "label": "@tag.count"
                                        }
                                      ]
                                    },
                                    {
                                      "variant": "ghost",
                                      "size": "sm",
                                      "icon": "chevron-right",
                                      "actionPayload": {
                                        "tagId": "@tag.id"
                                      },
                                      "label": "Open",
                                      "className": "w-full justify-center",
                                      "type": "button",
                                      "action": "SELECT_TAG"
                                    }
                                  ]
                                }
                              ],
                              "className": "cursor-pointer hover:shadow-md transition-shadow",
                              "look": "flat-bordered",
                              "padding": "sm"
                            }
                          ],
                          "type": "data-grid",
                          "gap": "sm",
                          "fields": [],
                          "minCardWidth": 180.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "TagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "failure": "TagLoadFailed",
                        "success": "TagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading categories…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "allowEdit": {
              "type": "boolean",
              "default": false,
              "label": "Allow editing",
              "description": "Show inline controls to create or rename tags",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Categories",
              "label": "Section title",
              "description": "Heading shown above the tag tree",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TagBrowsePage",
          "path": "/tags/browse",
          "traits": [
            {
              "ref": "TagBrowse"
            }
          ]
        }
      ]
    }
  ]
}
