{
  "name": "std-tag-taxonomy",
  "version": "1.0.0",
  "description": "std-tag-taxonomy — hierarchical category tag tree (parent/child). TagBrowse fetches Tag rows on INIT, renders the active level via data-grid, and on SELECT_TAG drills into a tag's children by binding @entity.id to the chosen parent.",
  "orbitals": [
    {
      "name": "TagTaxonomyOrbital",
      "entity": {
        "name": "Tag",
        "collection": "tags",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "slug",
            "type": "string"
          },
          {
            "name": "color",
            "type": "string"
          },
          {
            "name": "count",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TagBrowse",
          "category": "interaction",
          "linkedEntity": "Tag",
          "emits": [
            {
              "event": "SELECT_TAG",
              "payloadSchema": [
                {
                  "name": "tagId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TagLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Tag]"
                }
              ]
            },
            {
              "event": "TagLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TagSelected",
              "payloadSchema": [
                {
                  "name": "tagId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TagLoaded",
                "name": "Tag loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Tag]"
                  }
                ]
              },
              {
                "key": "TagLoadFailed",
                "name": "Tag load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TAG",
                "name": "Select Tag",
                "payloadSchema": [
                  {
                    "name": "tagId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TagSelected",
                "name": "Tag selected",
                "payloadSchema": [
                  {
                    "name": "tagId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "failure": "TagLoadFailed",
                        "success": "TagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading categories…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "content": "@config.title",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Open",
                              "icon": "chevron-right",
                              "event": "SELECT_TAG"
                            }
                          ],
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "label": "Items",
                              "name": "count"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "SELECT_TAG",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tagId"
                  ],
                  [
                    "emit",
                    "TagSelected",
                    {
                      "tagId": "@payload.tagId"
                    }
                  ],
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "success": "TagLoaded",
                        "failure": "TagLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading children…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "fields": [
                            {
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Items",
                              "name": "count"
                            }
                          ],
                          "itemActions": [
                            {
                              "icon": "chevron-right",
                              "label": "Open",
                              "event": "SELECT_TAG"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "TagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "success": "TagLoaded",
                        "failure": "TagLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading categories…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "SELECT_TAG",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tagId"
                  ],
                  [
                    "emit",
                    "TagSelected",
                    {
                      "tagId": "@payload.tagId"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "TagSelected",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tagId"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "TagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "@config.title"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "name": "count",
                              "label": "Items"
                            }
                          ],
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Open",
                              "icon": "chevron-right",
                              "event": "SELECT_TAG"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "TagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tag",
                    {
                      "emit": {
                        "success": "TagLoaded",
                        "failure": "TagLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading categories…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "allowEdit": {
              "type": "boolean",
              "default": false,
              "label": "Allow editing",
              "description": "Show inline controls to create or rename tags"
            },
            "title": {
              "type": "string",
              "default": "Categories",
              "label": "Section title",
              "description": "Heading shown above the tag tree"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TagBrowsePage",
          "path": "/tags/browse",
          "traits": [
            {
              "ref": "TagBrowse"
            }
          ]
        }
      ]
    }
  ]
}