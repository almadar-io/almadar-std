{
  "description": "Hero marquee — eyebrow + headline + lead + primary CTA, centered in an elevated card. Above-the-fold landing surface. Standalone atom; fetches one HeroPromo record and renders inline.",
  "name": "std-hero-banner",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "default": "Announcing",
            "description": "A short introductory text or tagline.",
            "name": "eyebrow",
            "synonyms": "subtitle, teaser, prefix",
            "type": "string"
          },
          {
            "default": "Headline",
            "description": "The main title or heading for a promotional message.",
            "name": "headline",
            "required": true,
            "synonyms": "title, heading, main text",
            "type": "string"
          },
          {
            "default": "",
            "description": "The main descriptive text for the component.",
            "name": "lead",
            "synonyms": "body, content, text",
            "type": "string"
          },
          {
            "default": "Get started",
            "description": "Text for the call to action button.",
            "name": "ctaLabel",
            "synonyms": "button text, action label, call to action",
            "type": "string"
          },
          {
            "default": "PRIMARY_CTA",
            "description": "The event triggered when the call to action is activated.",
            "name": "ctaEvent",
            "synonyms": "event, action, trigger",
            "type": "string"
          },
          {
            "default": "",
            "description": "Error message to display if data retrieval fails.",
            "name": "errorMessage",
            "synonyms": "error, alert, message",
            "type": "string"
          }
        ],
        "name": "HeroPromo",
        "persistence": "runtime"
      },
      "name": "HeroBannerOrbital",
      "pages": [
        {
          "name": "HeroBannerPage",
          "path": "/hero-banner",
          "traits": [
            {
              "ref": "HeroBanner"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Signals that the primary call to action has been triggered.",
              "event": "PRIMARY_CTA",
              "synonyms": "click, activate, submit, trigger",
              "tier": "essential"
            },
            {
              "description": "Signals successful loading of the hero promotion data.",
              "event": "HeroPromoLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ],
              "synonyms": "loaded, fetched, received, ready",
              "tier": "essential"
            },
            {
              "description": "Indicates failure to load the hero promotion data.",
              "event": "HeroPromoLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "synonyms": "error, failed, load error",
              "tier": "internal"
            }
          ],
          "linkedEntity": "HeroPromo",
          "name": "HeroBanner",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals successful loading of the hero promotion data.",
                "key": "HeroPromoLoaded",
                "name": "HeroPromo loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ],
                "synonyms": "loaded, fetched, received, ready",
                "tier": "essential"
              },
              {
                "description": "Indicates failure to load the hero promotion data.",
                "key": "HeroPromoLoadFailed",
                "name": "HeroPromo load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failed, load error",
                "tier": "internal"
              },
              {
                "description": "Signals that the primary call to action has been triggered.",
                "key": "PRIMARY_CTA",
                "name": "Primary Cta",
                "synonyms": "click, activate, submit, trigger",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "ready"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "HeroPromo",
                    {
                      "emit": {
                        "failure": "HeroPromoLoadFailed",
                        "success": "HeroPromoLoaded"
                      },
                      "limit": 1.0
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading…",
                      "type": "loading-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.eyebrow",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "eyebrow"
                    ]
                  ],
                  [
                    "set",
                    "@entity.headline",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "headline"
                    ]
                  ],
                  [
                    "set",
                    "@entity.lead",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "lead"
                    ]
                  ],
                  [
                    "set",
                    "@entity.ctaLabel",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "ctaLabel"
                    ]
                  ],
                  [
                    "set",
                    "@entity.ctaEvent",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "ctaEvent"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "label": "@entity.eyebrow",
                              "size": "sm",
                              "type": "badge",
                              "variant": "neutral"
                            },
                            {
                              "content": "@entity.headline",
                              "type": "typography",
                              "variant": "h1",
                              "weight": "bold"
                            },
                            {
                              "color": "muted",
                              "content": "@entity.lead",
                              "type": "typography",
                              "variant": "body"
                            },
                            {
                              "action": "@entity.ctaEvent",
                              "label": "@entity.ctaLabel",
                              "size": "lg",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "lg",
                          "type": "stack"
                        }
                      ],
                      "look": "elevated",
                      "padding": "lg",
                      "type": "card"
                    }
                  ]
                ],
                "event": "HeroPromoLoaded",
                "from": "loading",
                "to": "ready"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Failed to load hero",
                      "type": "error-state"
                    }
                  ]
                ],
                "event": "HeroPromoLoadFailed",
                "from": "loading",
                "to": "error"
              },
              {
                "event": "PRIMARY_CTA",
                "from": "ready",
                "to": "ready"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}