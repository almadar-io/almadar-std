                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "max": 100.0,
                          "min": 0.0,
                          "type": "meter",
                          "value": "@entity.count"
                        },
                        {
                          "max": 100.0,
                          "showPercentage": true,
                          "type": "progress-bar",
                          "value": "@entity.count"
                        },
                        {
                          "children": [
                            {
                              "action": "REQUEST",
                              "icon": "send",
                              "label": "Request",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "action": "RESET",
                              "icon": "rotate-ccw",
                              "label": "Reset",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "REQUEST",
                "from": "open",
                "guard": "@config.enabled",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.limiterStatus",
                    "throttled"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "shield",
                                  "type": "icon"
                                },
                                {
                                  "content": "RateBucket Rate Limiter",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "label": "Throttled",
                              "pulse": true,
                              "status": "critical",
                              "type": "status-dot"
