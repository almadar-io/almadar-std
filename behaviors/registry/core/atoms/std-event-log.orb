{
  "name": "std-event-log",
  "version": "2.1.0",
  "description": "std-event-log — generic chronological event feed (Stripe activity log / GitHub PR timeline / Linear event feed style). Renders a vertical `timeline` with type-coded dots, a single horizontal chip-bar of kind filters (All + per-kind), reverse-chronological sort, and an inline form for logging events that weren't auto-captured. `config.kindOptions` maps each kind → status/icon/label so consuming molecules/organisms get type-coded visuals without re-implementing topology. Topology = loading / viewing / backfilling / error.",
  "orbitals": [
    {
      "name": "EventLogOrbital",
      "entity": {
        "name": "EventLogView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "default": "",
            "description": "The descriptive name or heading for the event log.",
            "synonyms": "heading, label, name"
          },
          {
            "name": "description",
            "type": "string",
            "default": "",
            "description": "A human-readable explanation of the event.",
            "synonyms": "text, details, explanation, summary"
          },
          {
            "name": "kind",
            "type": "string",
            "default": "created",
            "values": [
              "created",
              "updated",
              "approved",
              "rejected"
            ],
            "description": "The type of event being logged.",
            "synonyms": "event type, event category, kind, status"
          },
          {
            "name": "date",
            "type": "string",
            "default": "",
            "description": "The timestamp associated with the event.",
            "synonyms": "timestamp, time, occurred"
          },
          {
            "name": "allEntries",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "name": "status",
                  "type": "string",
                  "required": false,
                  "values": [
                    "complete",
                    "active",
                    "pending",
                    "error"
                  ]
                },
                "date": {
                  "name": "date",
                  "type": "string",
                  "required": false
                },
                "kind": {
                  "name": "kind",
                  "type": "string",
                  "required": false,
                  "values": [
                    "created",
                    "updated",
                    "approved",
                    "rejected"
                  ]
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                }
              }
            },
            "description": "An array of log entry objects.",
            "synonyms": "entries, records, items, data"
          },
          {
            "name": "entries",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "status": {
                  "name": "status",
                  "type": "string",
                  "required": false,
                  "values": [
                    "complete",
                    "active",
                    "pending",
                    "error"
                  ]
                },
                "kind": {
                  "name": "kind",
                  "type": "string",
                  "required": false,
                  "values": [
                    "created",
                    "updated",
                    "approved",
                    "rejected"
                  ]
                },
                "date": {
                  "name": "date",
                  "type": "string",
                  "required": false
                }
              }
            },
            "description": "A list of log entries, each with associated data.",
            "synonyms": "records, items, data, events"
          },
          {
            "name": "filterChips",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                }
              }
            },
            "description": "Represents selectable filter options for event categories.",
            "synonyms": "filters, categories, types, selections"
          },
          {
            "name": "filterKind",
            "type": "string",
            "default": "",
            "description": "The type of filter currently applied to the event log.",
            "synonyms": "filter, category, type"
          },
          {
            "name": "backfillTitle",
            "type": "string",
            "default": "",
            "description": "A descriptive title for a manually added event.",
            "synonyms": "manual title, user-provided title, custom title"
          },
          {
            "name": "backfillDescription",
            "type": "string",
            "default": "",
            "description": "A textual explanation for the event backfill process.",
            "synonyms": "explanation, details, notes, information"
          },
          {
            "name": "backfillDate",
            "type": "string",
            "default": "",
            "description": "The date and time when the event was manually added.",
            "synonyms": "timestamp, entered date, manual date"
          },
          {
            "name": "backfillKind",
            "type": "string",
            "default": "",
            "description": "Specifies the category or type of the manually added event.",
            "synonyms": "event type, category, kind"
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": "",
            "description": "A human-readable message indicating an error condition.",
            "synonyms": "error, error message, problem, issue"
          }
        ]
      },
      "traits": [
        {
          "name": "EventLogTimeline",
          "category": "interaction",
          "linkedEntity": "EventLogView",
          "emits": [
            {
              "event": "APPLY_FILTER",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OPEN_BACKFILL"
            },
            {
              "event": "SAVE_BACKFILL",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CANCEL_BACKFILL"
            },
            {
              "event": "EventLogLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "EventLogLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EventLogSaved",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "EventLogSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "backfilling"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EventLogLoaded",
                "name": "Event log loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "EventLogLoadFailed",
                "name": "Event log load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EventLogSaved",
                "name": "Event log saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "EventLogSaveFailed",
                "name": "Event log save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "APPLY_FILTER",
                "name": "Apply Filter",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_BACKFILL",
                "name": "Open Backfill"
              },
              {
                "key": "SAVE_BACKFILL",
                "name": "Save Backfill",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL_BACKFILL",
                "name": "Cancel Backfill"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EventLogView",
                    {
                      "emit": {
                        "failure": "EventLogLoadFailed",
                        "success": "EventLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading activity…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "EventLogLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.filterChips",
                    [
                      "array/prepend",
                      [
                        "array/map",
                        "@config.kindOptions",
                        [
                          "fn",
                          "k",
                          {
                            "id": [
                              "object/get",
                              "@k",
                              "key"
                            ],
                            "icon": [
                              "object/get",
                              "@k",
                              "icon",
                              "circle"
                            ],
                            "label": [
                              "object/get",
                              "@k",
                              "label"
                            ]
                          }
                        ]
                      ],
                      {
                        "label": "All",
                        "icon": "list",
                        "id": ""
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.allEntries",
                    [
                      "array/sort",
                      [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "row",
                          {
                            "status": [
                              "object/get",
                              [
                                "or",
                                [
                                  "array/find",
                                  "@config.kindOptions",
                                  [
                                    "fn",
                                    "k",
                                    [
                                      "=",
                                      [
                                        "object/get",
                                        "@k",
                                        "key"
                                      ],
                                      [
                                        "object/get",
                                        "@row",
                                        "kind",
                                        ""
                                      ]
                                    ]
                                  ]
                                ],
                                {}
                              ],
                              "status",
                              "pending"
                            ],
                            "title": [
                              "object/get",
                              "@row",
                              "title",
                              ""
                            ],
                            "id": [
                              "object/get",
                              "@row",
                              "id",
                              ""
                            ],
                            "date": [
                              "object/get",
                              "@row",
                              "createdAt",
                              [
                                "object/get",
                                "@row",
                                "date",
                                ""
                              ]
                            ],
                            "kind": [
                              "object/get",
                              "@row",
                              "kind",
                              ""
                            ],
                            "description": [
                              "object/get",
                              "@row",
                              "description",
                              ""
                            ]
                          }
                        ]
                      ],
                      "date",
                      "desc"
                    ]
                  ],
                  [
                    "set",
                    "@entity.entries",
                    [
                      "array/sort",
                      [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "row",
                          {
                            "kind": [
                              "object/get",
                              "@row",
                              "kind",
                              ""
                            ],
                            "description": [
                              "object/get",
                              "@row",
                              "description",
                              ""
                            ],
                            "date": [
                              "object/get",
                              "@row",
                              "createdAt",
                              [
                                "object/get",
                                "@row",
                                "date",
                                ""
                              ]
                            ],
                            "status": [
                              "object/get",
                              [
                                "or",
                                [
                                  "array/find",
                                  "@config.kindOptions",
                                  [
                                    "fn",
                                    "k",
                                    [
                                      "=",
                                      [
                                        "object/get",
                                        "@k",
                                        "key"
                                      ],
                                      [
                                        "object/get",
                                        "@row",
                                        "kind",
                                        ""
                                      ]
                                    ]
                                  ]
                                ],
                                {}
                              ],
                              "status",
                              "pending"
                            ],
                            "id": [
                              "object/get",
                              "@row",
                              "id",
                              ""
                            ],
                            "title": [
                              "object/get",
                              "@row",
                              "title",
                              ""
                            ]
                          }
                        ]
                      ],
                      "date",
                      "desc"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "history"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "action": "OPEN_BACKFILL",
                              "label": "Log event",
                              "variant": "primary",
                              "type": "button",
                              "icon": "plus"
                            }
                          ]
                        },
                        {
                          "tabChangeEvent": "APPLY_FILTER",
                          "type": "tabs",
                          "tabs": "@entity.filterChips",
                          "activeTab": "@entity.filterKind"
                        },
                        {
                          "type": "timeline",
                          "fields": [
                            "title",
                            "description",
                            "date",
                            "status"
                          ],
                          "look": "@config.timelineLook",
                          "entity": "@entity.entries"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "EventLogLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Failed to load",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "EventLogSaved",
                "effects": [
                  [
                    "fetch",
                    "EventLogView",
                    {
                      "emit": {
                        "success": "EventLogLoaded",
                        "failure": "EventLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "EventLogSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Save failed",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "APPLY_FILTER",
                "effects": [
                  [
                    "set",
                    "@entity.filterKind",
                    "@payload.tabId"
                  ],
                  [
                    "set",
                    "@entity.entries",
                    [
                      "array/filter",
                      "@entity.allEntries",
                      [
                        "fn",
                        "e",
                        [
                          "or",
                          [
                            "=",
                            "@payload.tabId",
                            ""
                          ],
                          [
                            "=",
                            [
                              "object/get",
                              "@e",
                              "kind"
                            ],
                            "@payload.tabId"
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "history",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            },
                            {
                              "label": "Log event",
                              "type": "button",
                              "icon": "plus",
                              "action": "OPEN_BACKFILL",
                              "variant": "primary"
                            }
                          ]
                        },
                        {
                          "tabChangeEvent": "APPLY_FILTER",
                          "activeTab": "@entity.filterKind",
                          "tabs": "@entity.filterChips",
                          "type": "tabs"
                        },
                        {
                          "type": "timeline",
                          "look": "@config.timelineLook",
                          "fields": [
                            "title",
                            "description",
                            "date",
                            "status"
                          ],
                          "entity": "@entity.entries"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "backfilling",
                "event": "OPEN_BACKFILL",
                "effects": [
                  [
                    "set",
                    "@entity.backfillTitle",
                    ""
                  ],
                  [
                    "set",
                    "@entity.backfillDescription",
                    ""
                  ],
                  [
                    "set",
                    "@entity.backfillDate",
                    ""
                  ],
                  [
                    "set",
                    "@entity.backfillKind",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CANCEL_BACKFILL",
                              "icon": "arrow-left",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "variant": "h3",
                              "content": "Log event",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "submitEvent": "SAVE_BACKFILL",
                              "type": "form-section",
                              "cancelEvent": "CANCEL_BACKFILL",
                              "fields": "@config.formFields",
                              "mode": "create",
                              "entity": "@entity"
                            }
                          ],
                          "type": "card",
                          "look": "@config.cardLook"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "backfilling",
                "to": "loading",
                "event": "SAVE_BACKFILL",
                "effects": [
                  [
                    "persist",
                    "create",
                    "EventLogView",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "EventLogSaveFailed",
                        "success": "EventLogSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Saving entry…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "backfilling",
                "to": "viewing",
                "event": "CANCEL_BACKFILL",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "history"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "OPEN_BACKFILL",
                              "label": "Log event",
                              "icon": "plus"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "tabs": "@entity.filterChips",
                          "tabChangeEvent": "APPLY_FILTER",
                          "activeTab": "@entity.filterKind",
                          "type": "tabs"
                        },
                        {
                          "fields": [
                            "title",
                            "description",
                            "date",
                            "status"
                          ],
                          "entity": "@entity.entries",
                          "type": "timeline",
                          "look": "@config.timelineLook"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "formFields": {
              "type": "[string]",
              "default": [
                "backfillTitle",
                "backfillDescription",
                "backfillKind",
                "backfillDate"
              ],
              "label": "Backfill fields",
              "description": "Inputs shown in the form for manually logging missed events",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "kindOptions": {
              "type": "[KindOption]",
              "default": [
                {
                  "status": "active",
                  "label": "Created",
                  "key": "created",
                  "icon": "plus-circle"
                },
                {
                  "status": "pending",
                  "label": "Updated",
                  "icon": "edit-3",
                  "key": "updated"
                },
                {
                  "status": "complete",
                  "key": "approved",
                  "label": "Approved",
                  "icon": "check-circle"
                },
                {
                  "icon": "x-circle",
                  "label": "Rejected",
                  "key": "rejected",
                  "status": "error"
                }
              ],
              "label": "Event kinds",
              "description": "Maps each event kind to its label, icon, and status color",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "status": {
                    "name": "status",
                    "type": "string",
                    "required": false,
                    "values": [
                      "complete",
                      "active",
                      "pending",
                      "error"
                    ]
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
