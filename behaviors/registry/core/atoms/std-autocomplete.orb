{
  "description": "std-autocomplete — reusable inline typeahead: as the user types (AUTO_QUERY), fetches the linked entity filtered by @config.searchField and shows a compact suggestions list; picking one emits AUTO_SELECTED { id } for the consumer to open the record or fill a field. Rebind to any entity; configure searchField + the label field shown per suggestion.",
  "name": "std-autocomplete",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The primary label matched + shown per suggestion.",
            "name": "name",
            "synonyms": "title, label, productName",
            "type": "string"
          },
          {
            "default": "",
            "description": "The current typed query.",
            "intrinsic": true,
            "name": "searchTerm",
            "synonyms": "query, term, q",
            "type": "string"
          }
        ],
        "name": "AutoTarget",
        "persistence": "runtime"
      },
      "name": "AutocompleteOrbital",
      "pages": [
        {
          "name": "AutocompletePage",
          "path": "/autocomplete",
          "traits": [
            {
              "ref": "Autocomplete"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "placeholder": {
              "default": "Search…",
              "description": "Hint text in the empty typeahead input.",
              "label": "Placeholder",
              "tier": "presentation",
              "type": "string"
            },
            "searchField": {
              "default": "name",
              "description": "Entity field matched against the typed query (case-insensitive substring).",
              "label": "Search field",
              "tier": "presentation",
              "type": "string"
            },
            "suggestionFields": {
              "default": [
                {
                  "label": "Name",
                  "name": "name",
                  "variant": "body"
                }
              ],
              "description": "Fields shown per suggestion row.",
              "items": {
                "properties": {
                  "icon": {
                    "name": "icon",
                    "required": false,
                    "type": "string"
                  },
                  "label": {
                    "name": "label",
                    "required": false,
                    "type": "string"
                  },
                  "name": {
                    "name": "name",
                    "required": true,
                    "type": "string"
                  },
                  "variant": {
                    "name": "variant",
                    "required": false,
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "label": "Suggestion fields",
              "tier": "presentation",
              "type": "[AutoSuggestSpec]"
            }
          },
          "emits": [
            {
              "description": "Suggestion matches loaded",
              "event": "AutoLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AutoTarget]"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "Suggestion fetch failed",
              "event": "AutoFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                }
              ],
              "scope": "internal"
            },
            {
              "description": "A suggestion was picked; carries the chosen record id for the consumer to open or bind.",
              "event": "AUTO_SELECTED",
              "payloadSchema": [
                {
                  "name": "id",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "select, choose, pick",
              "tier": "essential"
            }
          ],
          "entityContract": {
            "provides": [
              "searchTerm"
            ],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "AutoTarget",
          "name": "Autocomplete",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "The user typed/submitted a query in the typeahead input.",
                "key": "AUTO_QUERY",
                "name": "Auto Query",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ],
                "synonyms": "type, query, search",
                "tier": "essential"
              },
              {
                "key": "AutoLoaded",
                "name": "Auto loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AutoTarget]"
                  }
                ]
              },
              {
                "description": "The user clicked a suggestion.",
                "key": "AUTO_SELECT",
                "name": "Auto Select",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "pick, choose, open",
                "tier": "essential"
              },
              {
                "key": "AutoFailed",
                "name": "Auto failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "description": "A suggestion was picked; carries the chosen record id for the consumer to open or bind.",
                "key": "AUTO_SELECTED",
                "name": "Auto Selected",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "select, choose, pick",
                "tier": "essential"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "AutoTarget",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "event": "AUTO_QUERY",
                      "placeholder": "@config.placeholder",
                      "query": "@entity.searchTerm",
                      "type": "search-input"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.value"
                  ],
                  [
                    "fetch",
                    "AutoTarget",
                    {
                      "emit": {
                        "failure": "AutoFailed",
                        "success": "AutoLoaded"
                      },
                      "filter": [
                        "or",
                        [
                          "=",
                          "@payload.value",
                          ""
                        ],
                        [
                          "str/includes",
                          [
                            "object/get",
                            "@entity",
                            "@config.searchField"
                          ],
                          "@payload.value"
                        ]
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "AUTO_QUERY",
                          "placeholder": "@config.placeholder",
                          "query": "@entity.searchTerm",
                          "type": "search-input"
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "xs",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AUTO_QUERY",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "AUTO_QUERY",
                          "placeholder": "@config.placeholder",
                          "query": "@entity.searchTerm",
                          "type": "search-input"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": "@config.suggestionFields",
                          "itemActions": [
                            {
                              "event": "AUTO_SELECT",
                              "label": "Open",
                              "variant": "ghost"
                            }
                          ],
                          "type": "data-list"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "xs",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "AutoLoaded",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "emit",
                    "AUTO_SELECTED",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "event": "AUTO_QUERY",
                      "placeholder": "@config.placeholder",
                      "query": "@entity.searchTerm",
                      "type": "search-input"
                    }
                  ]
                ],
                "event": "AUTO_SELECT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "event": "AUTO_QUERY",
                      "placeholder": "@config.placeholder",
                      "query": "@entity.searchTerm",
                      "type": "search-input"
                    }
                  ]
                ],
                "event": "AutoFailed",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}