{
  "name": "std-board",
  "version": "1.1.0",
  "description": "std-board — generic N-column board primitive. `config.columns` is an array of column definitions ({ key, label, icon, variant }); the trait `array/map`s them on `BoardItemsLoaded` into `@entity.boards` where each board carries its filtered items + a count. The render is a `data-grid` over `@entity.boards` (one card per column) whose `renderItem` lambda nests a `data-list` over `@col.items` (the cards in that stage). N is config-driven — pass any number of columns; the outer `data-grid`'s `cols` is bound to `@config.gridCols` so the grid wraps if you exceed it. Topology = loading / viewing_board / viewing_card / adding / error — distinct from the cookie-cutter `loading/browsing/viewing_single/error` CRUD shape. App-level atoms (e.g. std-pipeline) compose std-board via `uses` and add a sibling persistor + extended source entity.",
  "orbitals": [
    {
      "name": "BoardOrbital",
      "entity": {
        "name": "BoardView",
        "collection": "board_items",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "stage",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "doing",
              "done"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "position",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "boards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "count": {
                  "name": "count",
                  "type": "number",
                  "required": false
                },
                "items": {
                  "name": "items",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "object",
                    "properties": {
                      "notes": {
                        "name": "notes",
                        "type": "string",
                        "required": false
                      },
                      "position": {
                        "name": "position",
                        "type": "number",
                        "required": false
                      },
                      "description": {
                        "name": "description",
                        "type": "string",
                        "required": false
                      },
                      "id": {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      "stage": {
                        "name": "stage",
                        "type": "string",
                        "required": false
                      },
                      "title": {
                        "name": "title",
                        "type": "string",
                        "required": false
                      }
                    }
                  }
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "key": {
                  "name": "key",
                  "type": "string",
                  "required": true
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                }
              }
            }
          },
          {
            "name": "currentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStage",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentNotes",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "BoardItemBoard",
          "category": "interaction",
          "linkedEntity": "BoardView",
          "emits": [
            {
              "event": "OPEN_CARD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE_CARD"
            },
            {
              "event": "ADD_CARD"
            },
            {
              "event": "CANCEL_ADD"
            },
            {
              "event": "SAVE_CARD",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "MOVE_CARD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "sourceGroup",
                  "type": "string"
                },
                {
                  "name": "targetGroup",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "newIndex",
                  "type": "number"
                }
              ]
            },
            {
              "event": "REORDER_CARD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "oldIndex",
                  "type": "number"
                },
                {
                  "name": "newIndex",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DELETE_CARD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BoardItemsLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "BoardItemsLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BoardItemsSaved",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "BoardItemsSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing_board"
              },
              {
                "name": "viewing_card"
              },
              {
                "name": "adding"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BoardItemsLoaded",
                "name": "Board items loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "BoardItemsLoadFailed",
                "name": "Board items load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BoardItemsSaveFailed",
                "name": "Board items save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CARD",
                "name": "Open Card",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ADD_CARD",
                "name": "Add Card"
              },
              {
                "key": "MOVE_CARD",
                "name": "Move Card",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "sourceGroup",
                    "type": "string"
                  },
                  {
                    "name": "targetGroup",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newIndex",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "REORDER_CARD",
                "name": "Reorder Card",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "oldIndex",
                    "type": "number"
                  },
                  {
                    "name": "newIndex",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "REORDER_POSITION",
                "name": "Reorder Position",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "position",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "BoardItemsSaved",
                "name": "Board items saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CLOSE_CARD",
                "name": "Close Card"
              },
              {
                "key": "DELETE_CARD",
                "name": "Delete Card",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_CARD",
                "name": "Save Card",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_ADD",
                "name": "Cancel Add"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "success": "BoardItemsLoaded",
                        "failure": "BoardItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading board…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing_board",
                "event": "BoardItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.boards",
                    [
                      "array/map",
                      "@config.columns",
                      [
                        "fn",
                        "col",
                        {
                          "items": [
                            "array/sort",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "stage"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "variant": [
                            "object/get",
                            "@col",
                            "variant",
                            "default"
                          ],
                          "label": [
                            "object/get",
                            "@col",
                            "label"
                          ],
                          "icon": [
                            "object/get",
                            "@col",
                            "icon",
                            "circle"
                          ],
                          "key": [
                            "object/get",
                            "@col",
                            "key"
                          ],
                          "count": [
                            "array/len",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "stage"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BoardItemsLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "message": "@entity.errorMessage",
                      "title": "Failed to load board"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BoardItemsSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "type": "error-state",
                      "title": "Save failed"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_card",
                "event": "OPEN_CARD",
                "effects": [
                  [
                    "set",
                    "@entity.currentId",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.currentTitle",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.currentDescription",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.currentStage",
                    "@payload.row.stage"
                  ],
                  [
                    "set",
                    "@entity.currentNotes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "action": "CLOSE_CARD",
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "icon": "arrow-left"
                            },
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.currentTitle",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.currentStage",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "look": "@config.cardLook",
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Description"
                                },
                                {
                                  "content": "@entity.currentDescription",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Notes",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.currentNotes"
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Move to stage:",
                          "type": "typography"
                        },
                        {
                          "renderItem": [
                            "fn",
                            "col",
                            {
                              "action": "MOVE_CARD",
                              "actionPayload": {
                                "targetGroup": "@col.key",
                                "id": "@entity.currentId"
                              },
                              "icon": "@col.icon",
                              "label": "@col.label",
                              "variant": "secondary",
                              "type": "button"
                            }
                          ],
                          "entity": "@entity.boards",
                          "type": "data-list",
                          "gap": "sm",
                          "variant": "default",
                          "fields": []
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Delete",
                              "actionPayload": {
                                "id": "@entity.currentId"
                              },
                              "icon": "trash-2",
                              "type": "button",
                              "variant": "danger",
                              "action": "DELETE_CARD"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "adding",
                "event": "ADD_CARD",
                "effects": [
                  [
                    "set",
                    "@entity.currentId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentTitle",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentDescription",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentNotes",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "action": "CANCEL_ADD",
                              "variant": "ghost",
                              "type": "button",
                              "icon": "x",
                              "label": "Cancel"
                            },
                            {
                              "type": "icon",
                              "name": "plus"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "New board item"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@entity",
                          "cancelEvent": "CANCEL_ADD",
                          "fields": "@config.formFields",
                          "mode": "create",
                          "submitEvent": "SAVE_CARD",
                          "type": "form-section"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "MOVE_CARD",
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "stage": "@payload.targetGroup",
                      "id": "@payload.id"
                    },
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "REORDER_CARD"
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "REORDER_POSITION",
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "position": "@payload.position"
                    },
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "BoardItemsSaved",
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "success": "BoardItemsLoaded",
                        "failure": "BoardItemsLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "BoardItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.boards",
                    [
                      "array/map",
                      "@config.columns",
                      [
                        "fn",
                        "col",
                        {
                          "icon": [
                            "object/get",
                            "@col",
                            "icon",
                            "circle"
                          ],
                          "key": [
                            "object/get",
                            "@col",
                            "key"
                          ],
                          "variant": [
                            "object/get",
                            "@col",
                            "variant",
                            "default"
                          ],
                          "count": [
                            "array/len",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "stage"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ]
                          ],
                          "items": [
                            "array/sort",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "stage"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "label": [
                            "object/get",
                            "@col",
                            "label"
                          ]
                        }
                      ]
                    ]
                  ]
                ]
              },
              {
                "from": "viewing_card",
                "to": "loading",
                "event": "CLOSE_CARD",
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "failure": "BoardItemsLoadFailed",
                        "success": "BoardItemsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing board…"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_card",
                "to": "loading",
                "event": "MOVE_CARD",
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "stage": "@payload.targetGroup"
                    },
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Moving item…"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_card",
                "to": "loading",
                "event": "DELETE_CARD",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "BoardView",
                    "@payload.id",
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Deleting item…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "adding",
                "to": "loading",
                "event": "SAVE_CARD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "BoardView",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Saving…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "adding",
                "to": "viewing_board",
                "event": "CANCEL_ADD",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Cancelling…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "cardLook": {
              "type": "string",
              "default": "elevated",
              "label": "Card look",
              "description": "Layer 2 visual treatment for cards rendered by this board.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat-bordered",
                "borderless-divider",
                "ticket",
                "invoice",
                "chip",
                "tile-image-first"
              ]
            },
            "columns": {
              "type": "[ColumnSpec]",
              "default": [
                {
                  "label": "To Do",
                  "variant": "default",
                  "key": "todo",
                  "icon": "circle"
                },
                {
                  "icon": "circle-dot",
                  "label": "In Progress",
                  "key": "doing",
                  "variant": "primary"
                },
                {
                  "variant": "success",
                  "key": "done",
                  "label": "Done",
                  "icon": "check-circle"
                }
              ],
              "label": "Columns",
              "description": "Board columns; each row's stage maps to a column key",
              "tier": "domain",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "formFields": {
              "type": "[string]",
              "default": [
                "title",
                "description",
                "stage",
                "notes"
              ],
              "label": "New-card fields",
              "description": "Fields shown in the add-card form",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "bodyContent": {
              "type": "render-ui",
              "default": {
                "children": [
                  {
                    "align": "center",
                    "direction": "horizontal",
                    "type": "stack",
                    "gap": "sm",
                    "children": [
                      {
                        "type": "icon",
                        "name": "kanban-square"
                      },
                      {
                        "variant": "h3",
                        "type": "typography",
                        "content": "@config.title"
                      }
                    ]
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "entity": "@entity.boards",
                    "gap": "md",
                    "dndRoot": true,
                    "cols": "@config.gridCols",
                    "fields": [],
                    "type": "data-grid",
                    "renderItem": [
                      "fn",
                      "col",
                      {
                        "children": [
                          {
                            "children": [
                              {
                                "align": "center",
                                "children": [
                                  {
                                    "type": "icon",
                                    "name": "@col.icon"
                                  },
                                  {
                                    "variant": "h4",
                                    "type": "typography",
                                    "content": "@col.label"
                                  },
                                  {
                                    "variant": "@col.variant",
                                    "type": "badge",
                                    "label": "@col.count"
                                  }
                                ],
                                "gap": "xs",
                                "direction": "horizontal",
                                "type": "stack"
                              },
                              {
                                "fields": [],
                                "dragGroup": "@col.key",
                                "sortable": true,
                                "type": "data-list",
                                "reorderEvent": "REORDER_CARD",
                                "accepts": "*",
                                "dropEvent": "MOVE_CARD",
                                "entity": "@col.items",
                                "gap": "sm",
                                "renderItem": [
                                  "fn",
                                  "item",
                                  {
                                    "type": "card",
                                    "look": "@config.cardLook",
                                    "children": [
                                      {
                                        "children": [
                                          {
                                            "content": "@item.title",
                                            "variant": "h4",
                                            "type": "typography"
                                          },
                                          {
                                            "color": "muted",
                                            "type": "typography",
                                            "content": "@item.description",
                                            "variant": "caption"
                                          },
                                          {
                                            "align": "center",
                                            "gap": "xs",
                                            "direction": "horizontal",
                                            "type": "stack",
                                            "children": [
                                              {
                                                "action": "OPEN_CARD",
                                                "variant": "ghost",
                                                "label": "Open",
                                                "actionPayload": {
                                                  "row": "@item",
                                                  "id": "@item.id"
                                                },
                                                "icon": "arrow-right",
                                                "type": "button"
                                              }
                                            ]
                                          }
                                        ],
                                        "type": "stack",
                                        "gap": "xs",
                                        "direction": "vertical"
                                      }
                                    ]
                                  }
                                ],
                                "positionEvent": "REORDER_POSITION"
                              }
                            ],
                            "type": "stack",
                            "gap": "sm",
                            "direction": "vertical"
                          }
                        ],
                        "type": "card",
                        "look": "@config.cardLook"
                      }
                    ]
                  },
                  {
                    "label": "Add item",
                    "action": "ADD_CARD",
                    "type": "floating-action-button",
                    "icon": "plus",
                    "variant": "primary"
                  }
                ],
                "gap": "md",
                "type": "stack",
                "direction": "vertical"
              },
              "label": "Body content tree",
              "description": "Render-ui SExpr rendered after the board loads. Default is the canonical column data-grid with nested per-column data-lists. Layer 3 variants override this with their own tree (swim-lanes, timeline-roadmap, etc.) while inheriting the same trait, state machine, emits, and listens.",
              "tier": "internal"
            },
            "gridCols": {
              "type": "number",
              "default": 3.0,
              "label": "Grid columns",
              "description": "Outer grid column count before the board wraps",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Board",
              "label": "Board title",
              "description": "Heading shown above the column board",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BoardPage",
          "path": "/board",
          "traits": [
            {
              "ref": "BoardItemBoard"
            }
          ]
        }
      ]
    }
  ]
}