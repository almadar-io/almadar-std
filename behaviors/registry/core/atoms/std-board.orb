{
  "name": "std-board",
  "version": "1.1.0",
  "description": "std-board — generic N-column board primitive. `config.columns` is an array of column definitions ({ key, label, icon, variant }); the trait `array/map`s them on `BoardItemsLoaded` into `@entity.boards` where each board carries its filtered items + a count. The render is a `data-grid` over `@entity.boards` (one card per column) whose `renderItem` lambda nests a `data-list` over `@col.items` (the cards in that stage). N is config-driven — pass any number of columns; the outer `data-grid`'s `cols` is bound to `@config.gridCols` so the grid wraps if you exceed it. Topology = loading / viewing_board / viewing_card / adding / error — distinct from the cookie-cutter `loading/browsing/viewing_single/error` CRUD shape. App-level atoms (e.g. std-pipeline) compose std-board via `uses` and add a sibling persistor + extended source entity.",
  "orbitals": [
    {
      "name": "BoardOrbital",
      "entity": {
        "name": "BoardView",
        "collection": "board_items",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true,
            "description": "The descriptive name of the board.",
            "synonyms": "name, heading, label"
          },
          {
            "name": "description",
            "type": "string",
            "default": "",
            "description": "A textual explanation or summary of the board.",
            "synonyms": "summary, details, notes, explanation"
          },
          {
            "name": "stage",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "doing",
              "done"
            ],
            "description": "The current status or lifecycle phase of the board.",
            "synonyms": "status, lifecycle, progress, state"
          },
          {
            "name": "notes",
            "type": "string",
            "default": "",
            "description": "Free-form text providing additional information.",
            "synonyms": "comments, remarks, details, annotations"
          },
          {
            "name": "position",
            "type": "number",
            "default": 0.0,
            "description": "The sequential order of this item within a collection.",
            "synonyms": "order, sequence, index, rank"
          },
          {
            "name": "boards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "key": {
                  "name": "key",
                  "type": "string",
                  "required": true
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "required": false,
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "count": {
                  "name": "count",
                  "type": "number",
                  "required": false
                },
                "items": {
                  "name": "items",
                  "type": "array",
                  "required": false,
                  "items": {
                    "type": "object",
                    "properties": {
                      "stage": {
                        "name": "stage",
                        "type": "string",
                        "required": false
                      },
                      "title": {
                        "name": "title",
                        "type": "string",
                        "required": false
                      },
                      "id": {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      "notes": {
                        "name": "notes",
                        "type": "string",
                        "required": false
                      },
                      "position": {
                        "name": "position",
                        "type": "number",
                        "required": false
                      },
                      "description": {
                        "name": "description",
                        "type": "string",
                        "required": false
                      }
                    }
                  }
                }
              }
            },
            "intrinsic": true
          },
          {
            "name": "currentId",
            "type": "string",
            "default": "",
            "intrinsic": true
          },
          {
            "name": "currentTitle",
            "type": "string",
            "default": "",
            "intrinsic": true
          },
          {
            "name": "currentDescription",
            "type": "string",
            "default": "",
            "intrinsic": true
          },
          {
            "name": "currentStage",
            "type": "string",
            "default": "",
            "intrinsic": true
          },
          {
            "name": "currentNotes",
            "type": "string",
            "default": "",
            "intrinsic": true
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": "",
            "intrinsic": true
          }
        ]
      },
      "traits": [
        {
          "name": "BoardItemBoard",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "boards",
              "currentDescription",
              "currentId",
              "currentNotes",
              "currentStage",
              "currentTitle",
              "errorMessage"
            ]
          },
          "category": "interaction",
          "linkedEntity": "BoardView",
          "emits": [
            {
              "event": "OPEN_CARD",
              "description": "Indicates a card within the board has been selected.",
              "synonyms": "select, choose, activate, display",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE_CARD",
              "description": "Signals a card is being dismissed or closed.",
              "synonyms": "dismiss, hide, close, remove",
              "tier": "essential"
            },
            {
              "event": "ADD_CARD",
              "description": "Signals a new card is being added to the board.",
              "synonyms": "create, new, append",
              "tier": "essential"
            },
            {
              "event": "CANCEL_ADD",
              "description": "Aborts an in-progress addition operation.",
              "synonyms": "discard, undo, reset",
              "tier": "customization"
            },
            {
              "event": "SAVE_CARD",
              "description": "Signals that a card's data has been successfully saved.",
              "synonyms": "persist, update, store",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "MOVE_CARD",
              "description": "Signals a card has been repositioned within a column.",
              "synonyms": "reorder, drag, reposition",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "sourceGroup",
                  "type": "string"
                },
                {
                  "name": "targetGroup",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "newIndex",
                  "type": "number"
                }
              ]
            },
            {
              "event": "REORDER_CARD",
              "description": "Signals a change in the order of cards within a column.",
              "synonyms": "rearrange, sort, shuffle, reposition",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "oldIndex",
                  "type": "number"
                },
                {
                  "name": "newIndex",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DELETE_CARD",
              "description": "Signals removal of a card from the board.",
              "synonyms": "remove, delete, discard",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BoardItemsLoaded",
              "description": "Signals that board items have been successfully loaded.",
              "synonyms": "loaded, fetched, retrieved, populated",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "BoardItemsLoadFailed",
              "description": "Indicates a failure to load board items.",
              "synonyms": "error, failed, problem, loading failure",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BoardItemsSaved",
              "description": "Signals that board items have been successfully saved.",
              "synonyms": "saved, persisted, updated",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "BoardItemsSaveFailed",
              "description": "Indicates a failure to save board items.",
              "synonyms": "error, failed, save error",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing_board"
              },
              {
                "name": "viewing_card"
              },
              {
                "name": "adding"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BoardItemsLoaded",
                "name": "Board items loaded",
                "description": "Signals that board items have been successfully loaded.",
                "synonyms": "loaded, fetched, retrieved, populated",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "BoardItemsLoadFailed",
                "name": "Board items load failed",
                "description": "Indicates a failure to load board items.",
                "synonyms": "error, failed, problem, loading failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BoardItemsSaveFailed",
                "name": "Board items save failed",
                "description": "Indicates a failure to save board items.",
                "synonyms": "error, failed, save error",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CARD",
                "name": "Open Card",
                "description": "Indicates a card within the board has been selected.",
                "synonyms": "select, choose, activate, display",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ADD_CARD",
                "name": "Add Card",
                "description": "Signals a new card is being added to the board.",
                "synonyms": "create, new, append",
                "tier": "essential"
              },
              {
                "key": "MOVE_CARD",
                "name": "Move Card",
                "description": "Signals a card has been repositioned within a column.",
                "synonyms": "reorder, drag, reposition",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "sourceGroup",
                    "type": "string"
                  },
                  {
                    "name": "targetGroup",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newIndex",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "REORDER_CARD",
                "name": "Reorder Card",
                "description": "Signals a change in the order of cards within a column.",
                "synonyms": "rearrange, sort, shuffle, reposition",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "oldIndex",
                    "type": "number"
                  },
                  {
                    "name": "newIndex",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "REORDER_POSITION",
                "name": "Reorder Position",
                "description": "Indicates a change in the order of items within a column.",
                "synonyms": "sort, rearrange, reposition",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "position",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "BoardItemsSaved",
                "name": "Board items saved",
                "description": "Signals that board items have been successfully saved.",
                "synonyms": "saved, persisted, updated",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CLOSE_CARD",
                "name": "Close Card",
                "description": "Signals a card is being dismissed or closed.",
                "synonyms": "dismiss, hide, close, remove",
                "tier": "essential"
              },
              {
                "key": "DELETE_CARD",
                "name": "Delete Card",
                "description": "Signals removal of a card from the board.",
                "synonyms": "remove, delete, discard",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_CARD",
                "name": "Save Card",
                "description": "Signals that a card's data has been successfully saved.",
                "synonyms": "persist, update, store",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_ADD",
                "name": "Cancel Add",
                "description": "Aborts an in-progress addition operation.",
                "synonyms": "discard, undo, reset",
                "tier": "customization"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "success": "BoardItemsLoaded",
                        "failure": "BoardItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading board…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing_board",
                "event": "BoardItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.boards",
                    [
                      "array/map",
                      "@config.columns",
                      [
                        "fn",
                        "col",
                        {
                          "icon": [
                            "object/get",
                            "@col",
                            "icon",
                            "circle"
                          ],
                          "items": [
                            "array/sort",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "label": [
                            "object/get",
                            "@col",
                            "label"
                          ],
                          "key": [
                            "object/get",
                            "@col",
                            "key"
                          ],
                          "variant": [
                            "object/get",
                            "@col",
                            "variant",
                            "default"
                          ],
                          "count": [
                            "array/len",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BoardItemsLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Failed to load board",
                      "message": "@entity.errorMessage",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BoardItemsSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "type": "error-state",
                      "title": "Save failed"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_card",
                "event": "OPEN_CARD",
                "effects": [
                  [
                    "set",
                    "@entity.currentId",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.currentTitle",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.currentDescription",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.currentStage",
                    "@payload.row.stage"
                  ],
                  [
                    "set",
                    "@entity.currentNotes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_CARD",
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost",
                              "icon": "arrow-left"
                            },
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.currentTitle"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.currentStage",
                              "variant": "primary"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "look": "@config.cardLook",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Description",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.currentDescription",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Notes",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.currentNotes",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Move to stage:"
                        },
                        {
                          "type": "data-list",
                          "entity": "@entity.boards",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "col",
                            {
                              "action": "MOVE_CARD",
                              "actionPayload": {
                                "id": "@entity.currentId",
                                "targetGroup": "@col.key"
                              },
                              "icon": "@col.icon",
                              "label": "@col.label",
                              "type": "button",
                              "variant": "secondary"
                            }
                          ],
                          "gap": "sm",
                          "variant": "default"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "icon": "trash-2",
                              "label": "Delete",
                              "type": "button",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.currentId"
                              },
                              "action": "DELETE_CARD"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "adding",
                "event": "ADD_CARD",
                "effects": [
                  [
                    "set",
                    "@entity.currentId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentTitle",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentDescription",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStage",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentNotes",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "CANCEL_ADD",
                              "icon": "x",
                              "label": "Cancel",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "plus"
                            },
                            {
                              "content": "New board item",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CANCEL_ADD",
                          "mode": "create",
                          "submitEvent": "SAVE_CARD",
                          "fields": "@config.formFields",
                          "type": "form-section",
                          "entity": "@entity"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "MOVE_CARD",
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "stage": "@payload.targetGroup"
                    },
                    {
                      "emit": {
                        "success": "BoardItemsSaved",
                        "failure": "BoardItemsSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "REORDER_CARD"
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "REORDER_POSITION",
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "position": "@payload.position"
                    },
                    {
                      "emit": {
                        "success": "BoardItemsSaved",
                        "failure": "BoardItemsSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "BoardItemsSaved",
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "success": "BoardItemsLoaded",
                        "failure": "BoardItemsLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing_board",
                "to": "viewing_board",
                "event": "BoardItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.boards",
                    [
                      "array/map",
                      "@config.columns",
                      [
                        "fn",
                        "col",
                        {
                          "items": [
                            "array/sort",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ],
                            "position"
                          ],
                          "label": [
                            "object/get",
                            "@col",
                            "label"
                          ],
                          "icon": [
                            "object/get",
                            "@col",
                            "icon",
                            "circle"
                          ],
                          "variant": [
                            "object/get",
                            "@col",
                            "variant",
                            "default"
                          ],
                          "key": [
                            "object/get",
                            "@col",
                            "key"
                          ],
                          "count": [
                            "array/len",
                            [
                              "array/filter",
                              "@payload.data",
                              [
                                "fn",
                                "item",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@item",
                                    "@config.groupByField"
                                  ],
                                  [
                                    "object/get",
                                    "@col",
                                    "key"
                                  ]
                                ]
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ]
                ]
              },
              {
                "from": "viewing_card",
                "to": "loading",
                "event": "CLOSE_CARD",
                "effects": [
                  [
                    "fetch",
                    "BoardView",
                    {
                      "emit": {
                        "success": "BoardItemsLoaded",
                        "failure": "BoardItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Refreshing board…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_card",
                "to": "loading",
                "event": "MOVE_CARD",
                "effects": [
                  [
                    "persist",
                    "update",
                    "BoardView",
                    {
                      "id": "@payload.id",
                      "stage": "@payload.targetGroup"
                    },
                    {
                      "emit": {
                        "success": "BoardItemsSaved",
                        "failure": "BoardItemsSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Moving item…"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_card",
                "to": "loading",
                "event": "DELETE_CARD",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "BoardView",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "BoardItemsSaved",
                        "failure": "BoardItemsSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Deleting item…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "adding",
                "to": "loading",
                "event": "SAVE_CARD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "BoardView",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "BoardItemsSaveFailed",
                        "success": "BoardItemsSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Saving…"
                    }
                  ]
                ]
              },
              {
                "from": "adding",
                "to": "viewing_board",
                "event": "CANCEL_ADD",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Cancelling…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "gridCols": {
              "type": "number",
              "default": 3.0,
              "label": "Grid columns",
              "description": "Outer grid column count before the board wraps",
              "tier": "presentation"
            },
            "groupByField": {
              "type": "string",
              "default": "stage",
              "label": "Group-by field",
              "description": "Entity field whose value matches a column key — items are filtered into columns by it. Default 'stage'; set to 'status' (or any field) for entities that track state under a different name.",
              "tier": "presentation"
            },
            "cardDescriptionBinding": {
              "type": "string",
              "default": "@item.description",
              "label": "Card description binding",
              "description": "Per-card binding for the description slot.",
              "tier": "presentation"
            },
            "bodyContent": {
              "type": "render-ui",
              "default": {
                "direction": "vertical",
                "children": [
                  {
                    "direction": "horizontal",
                    "align": "center",
                    "children": [
                      {
                        "type": "icon",
                        "name": "kanban-square"
                      },
                      {
                        "variant": "h3",
                        "type": "typography",
                        "content": "@config.title"
                      }
                    ],
                    "gap": "sm",
                    "type": "stack"
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "entity": "@entity.boards",
                    "fields": [],
                    "cols": "@config.gridCols",
                    "renderItem": [
                      "fn",
                      "col",
                      {
                        "look": "@config.cardLook",
                        "children": [
                          {
                            "direction": "vertical",
                            "type": "stack",
                            "children": [
                              {
                                "children": [
                                  {
                                    "name": "@col.icon",
                                    "type": "icon"
                                  },
                                  {
                                    "content": "@col.label",
                                    "variant": "h4",
                                    "type": "typography"
                                  },
                                  {
                                    "label": "@col.count",
                                    "type": "badge",
                                    "variant": "@col.variant"
                                  }
                                ],
                                "direction": "horizontal",
                                "type": "stack",
                                "align": "center",
                                "gap": "xs"
                              },
                              {
                                "sortable": true,
                                "gap": "sm",
                                "accepts": "*",
                                "positionEvent": "REORDER_POSITION",
                                "renderItem": [
                                  "fn",
                                  "item",
                                  {
                                    "children": [
                                      {
                                        "children": [
                                          {
                                            "type": "typography",
                                            "content": "@config.cardTitleBinding",
                                            "variant": "h4"
                                          },
                                          {
                                            "content": "@config.cardDescriptionBinding",
                                            "color": "muted",
                                            "type": "typography",
                                            "variant": "caption"
                                          },
                                          {
                                            "direction": "horizontal",
                                            "gap": "xs",
                                            "align": "center",
                                            "children": [
                                              {
                                                "action": "OPEN_CARD",
                                                "actionPayload": {
                                                  "row": "@item",
                                                  "id": "@config.cardIdBinding"
                                                },
                                                "icon": "arrow-right",
                                                "type": "button",
                                                "label": "Open",
                                                "variant": "ghost"
                                              }
                                            ],
                                            "type": "stack"
                                          }
                                        ],
                                        "type": "stack",
                                        "gap": "xs",
                                        "direction": "vertical"
                                      }
                                    ],
                                    "look": "@config.cardLook",
                                    "type": "card"
                                  }
                                ],
                                "type": "data-list",
                                "dragGroup": "@col.key",
                                "fields": [],
                                "entity": "@col.items",
                                "reorderEvent": "REORDER_CARD",
                                "dropEvent": "MOVE_CARD"
                              }
                            ],
                            "gap": "sm"
                          }
                        ],
                        "type": "card"
                      }
                    ],
                    "gap": "md",
                    "dndRoot": true,
                    "type": "data-grid"
                  },
                  {
                    "type": "floating-action-button",
                    "icon": "plus",
                    "action": "ADD_CARD",
                    "label": "Add item",
                    "variant": "primary"
                  }
                ],
                "type": "stack",
                "gap": "md"
              },
              "label": "Body content tree",
              "description": "Render-ui SExpr rendered after the board loads. Default is the canonical column data-grid with nested per-column data-lists. Layer 3 variants override this with their own tree (swim-lanes, timeline-roadmap, etc.) while inheriting the same trait, state machine, emits, and listens.",
              "tier": "internal"
            },
            "cardStageBinding": {
              "type": "string",
              "default": "@item.stage",
              "label": "Card stage binding",
              "description": "Per-card binding for the stage/status slot.",
              "tier": "presentation"
            },
            "cardTitleBinding": {
              "type": "string",
              "default": "@item.title",
              "label": "Card title binding",
              "description": "Per-card binding for the title slot.",
              "tier": "presentation"
            },
            "columns": {
              "type": "[ColumnSpec]",
              "default": [
                {
                  "variant": "default",
                  "key": "todo",
                  "label": "To Do",
                  "icon": "circle"
                },
                {
                  "label": "In Progress",
                  "icon": "circle-dot",
                  "key": "doing",
                  "variant": "primary"
                },
                {
                  "label": "Done",
                  "icon": "check-circle",
                  "key": "done",
                  "variant": "success"
                }
              ],
              "label": "Columns",
              "description": "Board columns; each row's stage maps to a column key",
              "tier": "domain",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "cardIdBinding": {
              "type": "string",
              "default": "@item.id",
              "label": "Card id binding",
              "description": "Per-card binding for the id used in action payloads.",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Board",
              "label": "Board title",
              "description": "Heading shown above the column board",
              "tier": "presentation"
            },
            "cardLook": {
              "type": "string",
              "default": "elevated",
              "label": "Card look",
              "description": "Layer 2 visual treatment for cards rendered by this board.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat-bordered",
                "borderless-divider",
                "ticket",
                "invoice",
                "chip",
                "tile-image-first"
              ]
            },
            "formFields": {
              "type": "[string]",
              "default": [
                "title",
                "description",
                "stage",
                "notes"
              ],
              "label": "New-card fields",
              "description": "Fields shown in the add-card form",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BoardPage",
          "path": "/board",
          "traits": [
            {
              "ref": "BoardItemBoard"
            }
          ]
        }
      ]
    }
  ]
}
