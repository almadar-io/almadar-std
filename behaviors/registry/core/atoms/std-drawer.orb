{
  "description": "std-drawer — drawer-slot atom. Renders ONLY to its `drawer` slot. The runtime's slot wrapper provides the backdrop + right-anchored panel + close-X chrome; the atom emits ONLY the panel body content. Host emits OPEN with payload {id, name, description} → renders body; CLOSE clears the slot. Stateless: state lives in the OPEN payload, not the entity, so the trait stays safe under consumer entity rebinds.",
  "name": "std-drawer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DrawerContent",
        "persistence": "runtime"
      },
      "name": "DrawerContentOrbital",
      "pages": [
        {
          "name": "DrawerContentDrawerPage",
          "path": "/drawercontents/drawer",
          "traits": [
            {
              "ref": "DrawerContentDrawer"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DrawerContent",
          "name": "DrawerContentDrawer",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Drawer content is requested and should be rendered.",
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  }
                ],
                "synonyms": "show, display, load, reveal",
                "tier": "domain"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "children": [
                        {
                          "content": "@payload.name",
                          "type": "typography",
                          "variant": "h4"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.description",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "children": [
                            {
                              "action": "CLOSE",
                              "label": "Close",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "OPEN",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ],
                "event": "CLOSE",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "2.2.0"
}