{
  "name": "std-drawer",
  "version": "1.0.0",
  "description": "std-drawer as a Function",
  "orbitals": [
    {
      "name": "DrawerContentOrbital",
      "entity": {
        "name": "DrawerContent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DrawerContentDrawer",
          "category": "interaction",
          "linkedEntity": "DrawerContent",
          "emits": [
            {
              "event": "DrawerContentLoaded",
              "description": "Fired when DrawerContent finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DrawerContent]"
                }
              ]
            },
            {
              "event": "DrawerContentLoadFailed",
              "description": "Fired when DrawerContent fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "closed"
              },
              {
                "name": "open"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DrawerContentLoaded",
                "name": "DrawerContent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DrawerContent]"
                  }
                ]
              },
              {
                "key": "DrawerContentLoadFailed",
                "name": "DrawerContent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN",
                "name": "Open"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DrawerContent",
                    {
                      "emit": {
                        "success": "DrawerContentLoaded",
                        "failure": "DrawerContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading…",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "closed",
                "event": "DrawerContentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "panel-right",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Details"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "icon": "panel-right",
                              "action": "OPEN",
                              "label": "Open"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "@item.name",
                                  "type": "typography",
                                  "variant": "h4"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "entity": "@payload.data",
                          "fields": []
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DrawerContentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error"
                        },
                        {
                          "variant": "primary",
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "OPEN",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "position": "right",
                      "isOpen": true,
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "body",
                              "content": "Drawer content",
                              "type": "typography"
                            },
                            {
                              "justify": "end",
                              "type": "stack",
                              "children": [
                                {
                                  "action": "CLOSE",
                                  "type": "button",
                                  "label": "Close",
                                  "variant": "ghost"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ],
                      "type": "side-panel",
                      "title": "Details",
                      "onClose": "CLOSE"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "fetch",
                    "DrawerContent",
                    {
                      "emit": {
                        "success": "DrawerContentLoaded",
                        "failure": "DrawerContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DrawerContent",
                    {
                      "emit": {
                        "failure": "DrawerContentLoadFailed",
                        "success": "DrawerContentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DrawerContentDrawerPage",
          "path": "/drawercontents/drawer",
          "traits": [
            {
              "ref": "DrawerContentDrawer"
            }
          ]
        }
      ]
    }
  ]
}
