{
  "description": "std-drawer — drawer-slot atom. Renders ONLY to its `drawer` slot. The runtime's slot wrapper provides the backdrop + right-anchored panel + close-X chrome; the atom emits ONLY the panel body content. Host emits OPEN with payload {id, name, description} → renders body; CLOSE clears the slot. Stateless: state lives in the OPEN payload, not the entity, so the trait stays safe under consumer entity rebinds.",
  "name": "std-drawer",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "DrawerContent",
        "persistence": "runtime"
      },
      "name": "DrawerContentOrbital",
      "pages": [
        {
          "name": "DrawerContentDrawerPage",
          "path": "/drawercontents/drawer",
          "traits": [
            {
              "ref": "DrawerContentDrawer"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "content": {
              "default": "@payload.name",
              "type": "unknown"
            },
            "variant": {
              "default": "h4",
              "type": "unknown"
            }
          },
          "linkedEntity": "DrawerContent",
          "name": "Typography1",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "config": {
            "color": {
              "default": "muted",
              "type": "unknown"
            },
            "content": {
              "default": "@payload.description",
              "type": "unknown"
            },
            "variant": {
              "default": "body",
              "type": "unknown"
            }
          },
          "linkedEntity": "DrawerContent",
          "name": "Typography2",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "config": {
            "action": {
              "default": "CLOSE",
              "type": "unknown"
            },
            "label": {
              "default": "Close",
              "type": "unknown"
            },
            "variant": {
              "default": "ghost",
              "type": "unknown"
            }
          },
          "linkedEntity": "DrawerContent",
          "name": "Button1",
          "ref": "Button.traits.ButtonRender"
        },
        {
          "category": "interaction",
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "DrawerContent",
          "name": "DrawerContentDrawer",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Drawer content is requested and should be rendered.",
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  }
                ],
                "synonyms": "show, display, load, reveal",
                "tier": "domain"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "closed"
              },
              {
                "name": "open"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "closed",
                "to": "closed"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "children": [
                        "@trait.Typography1",
                        "@trait.Typography2",
                        {
                          "children": [
                            "@trait.Button1"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "OPEN",
                "from": "closed",
                "to": "open"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ],
                "event": "CLOSE",
                "from": "open",
                "to": "closed"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "Button",
          "from": "std/behaviors/ui-button"
        }
      ]
    }
  ],
  "version": "2.2.0"
}