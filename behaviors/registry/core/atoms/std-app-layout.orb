{
  "name": "std-app-layout",
  "version": "1.4.0",
  "description": "std-app-layout — dashboard-layout chrome (sidebar nav + top bar with search + topBarActions + notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data, and the consumer can add domain icons (cart / profile / help) via topBarActions. Bind once per orbital — the consumer rebinds linkedEntity via `XAppLayout = AppShell.traits.AppLayout -> XEntity` so multiple orbitals in one file each get their own chrome without colliding on a shared atom entity.",
  "orbitals": [
    {
      "name": "AppLayoutOrbital",
      "entity": {
        "name": "AppLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "AppLayout",
          "category": "interaction",
          "linkedEntity": "AppLayoutState",
          "emits": [
            {
              "event": "SEARCH",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            },
            {
              "event": "NOTIFY_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AppLayoutStateLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AppLayoutState]"
                }
              ]
            },
            {
              "event": "AppLayoutStateLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AppLayoutStateLoaded",
                "name": "AppLayoutState loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AppLayoutState]"
                  }
                ]
              },
              {
                "key": "AppLayoutStateLoadFailed",
                "name": "AppLayoutState load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "NOTIFY_CLICK",
                "name": "Notify Click"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AppLayoutState",
                    {
                      "emit": {
                        "failure": "AppLayoutStateLoadFailed",
                        "success": "AppLayoutStateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "notificationClickEvent": "@config.notificationClickEvent",
                      "appName": "@config.appName",
                      "type": "@config.layoutPattern",
                      "notifications": "@config.notifications",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            "@config.contentTrait"
                          ],
                          "className": "max-w-5xl mx-auto w-full",
                          "gap": "lg",
                          "direction": "vertical"
                        }
                      ],
                      "searchEvent": "@config.searchEvent",
                      "layoutMode": "@config.layoutMode",
                      "topBarActions": "@config.topBarActions",
                      "navItems": "@config.navItems"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "AppLayoutStateLoaded"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "AppLayoutStateLoadFailed"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "NOTIFY_CLICK"
              }
            ]
          },
          "config": {
            "contentTrait": {
              "type": "trait",
              "label": "Content trait",
              "description": "Trait rendered inside the app layout content area"
            },
            "appName": {
              "type": "string",
              "default": "App",
              "label": "App name",
              "description": "Product name shown in the chrome header"
            },
            "notificationClickEvent": {
              "type": "string",
              "default": "NOTIFY_CLICK",
              "label": "Notification click event",
              "description": "Event emitted when the user picks a notification"
            },
            "topBarActions": {
              "type": "[object]",
              "default": [],
              "label": "Top-bar actions",
              "description": "Icon buttons shown on the right side of the top bar",
              "items": {
                "type": "object"
              }
            },
            "layoutPattern": {
              "type": "pattern",
              "default": "dashboard-layout",
              "label": "Layout pattern",
              "description": "UI pattern used to render the application chrome"
            },
            "layoutMode": {
              "type": "string",
              "default": "sidebar",
              "label": "Layout mode",
              "description": "Where the primary navigation lives in the chrome",
              "values": [
                "sidebar",
                "topnav",
                "bottomnav",
                "minimal"
              ]
            },
            "notifications": {
              "type": "[object]",
              "default": [],
              "label": "Notifications",
              "description": "Items shown in the notifications dropdown",
              "items": {
                "type": "object"
              }
            },
            "navItems": {
              "type": "[object]",
              "default": [],
              "label": "Sidebar links",
              "description": "Top-level nav entries on the left rail",
              "items": {
                "type": "object"
              }
            },
            "searchEvent": {
              "type": "string",
              "default": "SEARCH",
              "label": "Search event",
              "description": "Event emitted when the user runs a global search"
            },
            "detailSlot": {
              "type": "slot",
              "default": "modal",
              "label": "Detail slot",
              "description": "Slot where detail/edit views render"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AppLayoutPage",
          "path": "/app-layout",
          "traits": [
            {
              "ref": "AppLayout"
            }
          ]
        }
      ]
    }
  ]
}