{
  "name": "std-calendar",
  "version": "1.1.0",
  "description": "std-calendar as a Function — owns the fetch + SELECT_DAY state machine; default bodyContent renders the month-grid + upcoming-events tree. Layer 3 variants override bodyContent to deliver agenda, week-timeline, etc. while inheriting the same trait, state machine, emits, and listens.",
  "orbitals": [
    {
      "name": "CalendarEventOrbital",
      "entity": {
        "name": "CalendarEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "string",
            "default": ""
          },
          {
            "name": "time",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60.0
          }
        ]
      },
      "traits": [
        {
          "name": "CalendarEventCalendar",
          "category": "interaction",
          "linkedEntity": "CalendarEvent",
          "emits": [
            {
              "event": "CalendarEventLoaded",
              "description": "Fired when CalendarEvent finishes loading; payload.data holds the events",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CalendarEvent]"
                }
              ]
            },
            {
              "event": "CalendarEventLoadFailed",
              "description": "Fired when CalendarEvent fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "month-view"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CalendarEventLoaded",
                "name": "CalendarEvent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CalendarEvent]"
                  }
                ]
              },
              {
                "key": "CalendarEventLoadFailed",
                "name": "CalendarEvent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_DAY",
                "name": "Select Day",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_SLOT",
                "name": "Select Slot",
                "payloadSchema": [
                  {
                    "name": "time",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "failure": "CalendarEventLoadFailed",
                        "success": "CalendarEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading calendar…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "month-view",
                "event": "CalendarEventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CalendarEventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "label": "Retry",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "type": "button"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "month-view",
                "to": "loading",
                "event": "SELECT_DAY",
                "effects": [
                  [
                    "set",
                    "@entity.date",
                    "@payload.value"
                  ],
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "filter": [
                        "=",
                        "@entity.date",
                        "@payload.value"
                      ],
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "bodyContent": {
              "type": "render-ui",
              "default": {
                "children": [
                  {
                    "align": "center",
                    "type": "stack",
                    "direction": "horizontal",
                    "children": [
                      {
                        "direction": "horizontal",
                        "gap": "sm",
                        "align": "center",
                        "children": [
                          {
                            "name": "calendar",
                            "type": "icon"
                          },
                          {
                            "type": "typography",
                            "variant": "h2",
                            "content": "CalendarEvents Calendar"
                          }
                        ],
                        "type": "stack"
                      },
                      {
                        "onSelect": "SELECT_DAY",
                        "type": "date-range-selector"
                      }
                    ],
                    "gap": "md",
                    "justify": "between"
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "type": "calendar-grid"
                  },
                  {
                    "type": "divider"
                  },
                  {
                    "variant": "h4",
                    "type": "typography",
                    "content": "Upcoming Events"
                  },
                  {
                    "entity": "@payload.data",
                    "type": "data-list",
                    "look": "@config.tableLook",
                    "fields": [
                      {
                        "variant": "h4",
                        "icon": "calendar",
                        "name": "name",
                        "label": "Event"
                      },
                      {
                        "variant": "badge",
                        "name": "time",
                        "label": "Time"
                      },
                      {
                        "variant": "caption",
                        "label": "Date",
                        "format": "date",
                        "name": "date"
                      },
                      {
                        "label": "Status",
                        "variant": "badge",
                        "name": "status"
                      }
                    ],
                    "itemActions": [
                      {
                        "label": "View",
                        "icon": "eye",
                        "event": "SELECT_DAY"
                      }
                    ]
                  }
                ],
                "type": "stack",
                "direction": "vertical",
                "gap": "lg"
              },
              "label": "Body content tree",
              "description": "Render-ui SExpr rendered after events load. Default is the month-grid + upcoming-events list. Layer 3 variants override this with their own tree (agenda list, week timeline, etc.) to deliver entirely different calendar UX while inheriting the same trait, state machine, emits, and listens.",
              "tier": "internal"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CalendarEventCalendarPage",
          "path": "/calendarevents/calendar",
          "traits": [
            {
              "ref": "CalendarEventCalendar"
            }
          ]
        }
      ]
    }
  ]
}