{
  "name": "std-calendar",
  "version": "1.0.0",
  "description": "std-calendar as a Function",
  "orbitals": [
    {
      "name": "CalendarEventOrbital",
      "entity": {
        "name": "CalendarEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "string",
            "default": ""
          },
          {
            "name": "time",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60.0
          }
        ]
      },
      "traits": [
        {
          "name": "CalendarEventCalendar",
          "category": "interaction",
          "linkedEntity": "CalendarEvent",
          "emits": [
            {
              "event": "CalendarEventLoaded",
              "description": "Fired when CalendarEvent finishes loading; payload.data holds the events",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CalendarEvent]"
                }
              ]
            },
            {
              "event": "CalendarEventLoadFailed",
              "description": "Fired when CalendarEvent fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "month-view"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CalendarEventLoaded",
                "name": "CalendarEvent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CalendarEvent]"
                  }
                ]
              },
              {
                "key": "CalendarEventLoadFailed",
                "name": "CalendarEvent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_DAY",
                "name": "Select Day",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_SLOT",
                "name": "Select Slot",
                "payloadSchema": [
                  {
                    "name": "time",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading calendar…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "month-view",
                "event": "CalendarEventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "calendar"
                                },
                                {
                                  "content": "CalendarEvents Calendar",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "date-range-selector",
                              "onSelect": "SELECT_DAY"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "calendar-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h4",
                          "content": "Upcoming Events"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "icon": "calendar",
                              "variant": "h4",
                              "label": "Event",
                              "name": "name"
                            },
                            {
                              "label": "Time",
                              "name": "time",
                              "variant": "badge"
                            },
                            {
                              "label": "Date",
                              "format": "date",
                              "name": "date",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ],
                          "type": "data-list",
                          "itemActions": [
                            {
                              "icon": "eye",
                              "event": "SELECT_DAY",
                              "label": "View"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CalendarEventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load"
                        },
                        {
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "label": "Retry",
                          "action": "INIT",
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "month-view",
                "to": "loading",
                "event": "SELECT_DAY",
                "effects": [
                  [
                    "set",
                    "@entity.date",
                    "@payload.value"
                  ],
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      },
                      "filter": [
                        "=",
                        "@entity.date",
                        "@payload.value"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "failure": "CalendarEventLoadFailed",
                        "success": "CalendarEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CalendarEventCalendarPage",
          "path": "/calendarevents/calendar",
          "traits": [
            {
              "ref": "CalendarEventCalendar"
            }
          ]
        }
      ]
    }
  ]
}