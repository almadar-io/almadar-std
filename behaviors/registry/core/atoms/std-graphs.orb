{
  "name": "std-graphs",
  "version": "2.0.0",
  "description": "std-graphs — embeddable chart atom. ITEMS_LOADED groups @payload.data by @config.categoryField (or @config.timeField when timeAxis=true) and aggregates per bucket. Multi-series rendering via @config.series (preformatted ChartSeries shape). Histograms via chartType=histogram pass pre-binned @payload.data through unchanged. Stacked / 100% stacked bars via @config.stack. Post-process sort + limit. Clicking a data point emits UI:@config.drillEvent with { label, value, seriesLabel? }. Drop into a dashboard alongside std-stats / std-browse.",
  "orbitals": [
    {
      "name": "GraphItemOrbital",
      "entity": {
        "name": "GraphItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "value": {
                  "name": "value",
                  "type": "number"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "GraphItemGraph",
          "category": "interaction",
          "linkedEntity": "GraphItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      {
                        "value": 6.0,
                        "label": "Active"
                      },
                      {
                        "label": "Pending",
                        "value": 3.0
                      },
                      {
                        "label": "Inactive",
                        "value": 1.0
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "chartType": "@config.chartType",
                      "timeAxis": "@config.timeAxis",
                      "drillEvent": "@config.drillEvent",
                      "title": "@config.title",
                      "series": "@config.series",
                      "data": "@entity.chartData",
                      "showValues": "@config.showValues",
                      "showLegend": "@config.showLegend",
                      "type": "@config.viewPattern",
                      "stack": "@config.stack",
                      "subtitle": "@config.subtitle",
                      "height": "@config.height"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "if",
                      [
                        "=",
                        "@config.chartType",
                        "histogram"
                      ],
                      [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "p",
                          {
                            "label": [
                              "object/get",
                              "@p",
                              "label"
                            ],
                            "value": [
                              "object/get",
                              "@p",
                              "value"
                            ]
                          }
                        ]
                      ],
                      [
                        "array/map",
                        [
                          "object/entries",
                          [
                            "array/groupBy",
                            "@payload.data",
                            [
                              "if",
                              "@config.timeAxis",
                              "@config.timeField",
                              "@config.categoryField"
                            ]
                          ]
                        ],
                        [
                          "fn",
                          "entry",
                          {
                            "value": [
                              "if",
                              [
                                "=",
                                "@config.aggregation",
                                "sum"
                              ],
                              [
                                "array/sum",
                                [
                                  "object/get",
                                  "@entry",
                                  "1"
                                ],
                                "@config.valueField"
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  "@config.aggregation",
                                  "avg"
                                ],
                                [
                                  "array/avg",
                                  [
                                    "object/get",
                                    "@entry",
                                    "1"
                                  ],
                                  "@config.valueField"
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    "@config.aggregation",
                                    "min"
                                  ],
                                  [
                                    "array/min",
                                    [
                                      "object/get",
                                      "@entry",
                                      "1"
                                    ],
                                    "@config.valueField"
                                  ],
                                  [
                                    "if",
                                    [
                                      "=",
                                      "@config.aggregation",
                                      "max"
                                    ],
                                    [
                                      "array/max",
                                      [
                                        "object/get",
                                        "@entry",
                                        "1"
                                      ],
                                      "@config.valueField"
                                    ],
                                    [
                                      "array/len",
                                      [
                                        "object/get",
                                        "@entry",
                                        "1"
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ],
                            "label": [
                              "object/get",
                              "@entry",
                              "0"
                            ]
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "if",
                      [
                        "!=",
                        "@config.sortField",
                        "none"
                      ],
                      [
                        "array/sort",
                        "@entity.chartData",
                        "@config.sortField",
                        "@config.sortDir"
                      ],
                      "@entity.chartData"
                    ]
                  ],
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "if",
                      [
                        ">",
                        "@config.limit",
                        0.0
                      ],
                      [
                        "array/take",
                        "@entity.chartData",
                        "@config.limit"
                      ],
                      "@entity.chartData"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "@config.title",
                      "subtitle": "@config.subtitle",
                      "showValues": "@config.showValues",
                      "type": "@config.viewPattern",
                      "showLegend": "@config.showLegend",
                      "stack": "@config.stack",
                      "timeAxis": "@config.timeAxis",
                      "data": "@entity.chartData",
                      "height": "@config.height",
                      "drillEvent": "@config.drillEvent",
                      "chartType": "@config.chartType",
                      "series": "@config.series"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "showValues": {
              "type": "boolean",
              "default": false,
              "label": "Show values",
              "description": "Render the numeric value on top of each data point"
            },
            "limit": {
              "type": "number",
              "default": 0.0,
              "label": "Top N",
              "description": "Keep only the first N points after sorting (0 = all)"
            },
            "title": {
              "type": "string",
              "default": "Distribution",
              "label": "Title",
              "description": "Heading shown above the chart"
            },
            "chartType": {
              "type": "string",
              "default": "bar",
              "label": "Chart type",
              "description": "Visual format for the rendered chart",
              "values": [
                "bar",
                "line",
                "pie",
                "area",
                "donut",
                "histogram",
                "scatter"
              ]
            },
            "sortDir": {
              "type": "string",
              "default": "desc",
              "label": "Sort direction",
              "description": "Ascending or descending order for the sort field",
              "values": [
                "asc",
                "desc"
              ]
            },
            "height": {
              "type": "number",
              "default": 280.0,
              "label": "Chart height",
              "description": "Pixel height of the rendered chart"
            },
            "viewPattern": {
              "type": "pattern",
              "default": "chart",
              "label": "Render pattern",
              "description": "UI pattern used to draw the chart"
            },
            "aggregation": {
              "type": "string",
              "default": "count",
              "label": "Aggregation",
              "description": "How values within a bucket combine into one number",
              "values": [
                "count",
                "sum",
                "avg",
                "min",
                "max"
              ]
            },
            "timeField": {
              "type": "string",
              "default": "date",
              "label": "Date field",
              "description": "Entity field used as the time axis when timeAxis is on"
            },
            "valueField": {
              "type": "string",
              "default": "",
              "label": "Value field",
              "description": "Numeric field aggregated per bucket (blank = row count)"
            },
            "timeAxis": {
              "type": "boolean",
              "default": false,
              "label": "Time axis",
              "description": "Group by timeField bucketed by period instead of categoryField"
            },
            "stack": {
              "type": "string",
              "default": "none",
              "label": "Stacking",
              "description": "Stack bars, normalize to 100%, or render side-by-side",
              "values": [
                "none",
                "stack",
                "normalize"
              ]
            },
            "period": {
              "type": "string",
              "default": "month",
              "label": "Bucket period",
              "description": "Calendar bucket size when grouping by time",
              "values": [
                "day",
                "week",
                "month",
                "quarter",
                "year"
              ]
            },
            "categoryField": {
              "type": "string",
              "default": "status",
              "label": "Group-by field",
              "description": "Entity field whose values become the chart's categories"
            },
            "sortField": {
              "type": "string",
              "default": "none",
              "label": "Sort by",
              "description": "Order points by value, label, or leave unsorted",
              "values": [
                "value",
                "label",
                "none"
              ]
            },
            "subtitle": {
              "type": "string",
              "default": "Counts per category",
              "label": "Subtitle",
              "description": "Secondary line below the title"
            },
            "series": {
              "type": "[SeriesSpec]",
              "default": [],
              "label": "Series",
              "description": "Pre-formatted multi-series spec for stacked or layered charts"
            },
            "showLegend": {
              "type": "boolean",
              "default": true,
              "label": "Show legend",
              "description": "Display the series legend"
            },
            "drillEvent": {
              "type": "string",
              "default": "",
              "label": "Drill event",
              "description": "Event emitted when a user clicks a chart point"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GraphItemGraphPage",
          "path": "/graphitems",
          "traits": [
            {
              "ref": "GraphItemGraph"
            }
          ]
        }
      ]
    }
  ]
}
