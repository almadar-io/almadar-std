{
  "name": "std-graphs",
  "version": "1.0.0",
  "description": "std-graphs — embeddable chart atom. ITEMS_LOADED groups @payload.data by @config.categoryField and applies the configured aggregation (count|sum|avg|min|max) per bucket, emitting {label,value} points into the chart pattern. Drop into a dashboard alongside std-stats / std-browse.",
  "orbitals": [
    {
      "name": "GraphItemOrbital",
      "entity": {
        "name": "GraphItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "name": "value",
                  "type": "number"
                },
                "label": {
                  "name": "label",
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "GraphItemGraph",
          "category": "interaction",
          "linkedEntity": "GraphItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      {
                        "value": 6.0,
                        "label": "Active"
                      },
                      {
                        "label": "Pending",
                        "value": 3.0
                      },
                      {
                        "label": "Inactive",
                        "value": 1.0
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showLegend": "@config.showLegend",
                      "subtitle": "@config.subtitle",
                      "data": "@entity.chartData",
                      "height": "@config.height",
                      "type": "chart",
                      "showValues": "@config.showValues",
                      "title": "@config.title",
                      "chartType": "@config.chartType"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "array/map",
                      [
                        "object/entries",
                        [
                          "array/groupBy",
                          "@payload.data",
                          "@config.categoryField"
                        ]
                      ],
                      [
                        "fn",
                        "entry",
                        {
                          "value": [
                            "if",
                            [
                              "=",
                              "@config.aggregation",
                              "sum"
                            ],
                            [
                              "array/sum",
                              [
                                "object/get",
                                "@entry",
                                "1"
                              ],
                              "@config.valueField"
                            ],
                            [
                              "if",
                              [
                                "=",
                                "@config.aggregation",
                                "avg"
                              ],
                              [
                                "array/avg",
                                [
                                  "object/get",
                                  "@entry",
                                  "1"
                                ],
                                "@config.valueField"
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  "@config.aggregation",
                                  "min"
                                ],
                                [
                                  "array/min",
                                  [
                                    "object/get",
                                    "@entry",
                                    "1"
                                  ],
                                  "@config.valueField"
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    "@config.aggregation",
                                    "max"
                                  ],
                                  [
                                    "array/max",
                                    [
                                      "object/get",
                                      "@entry",
                                      "1"
                                    ],
                                    "@config.valueField"
                                  ],
                                  [
                                    "array/len",
                                    [
                                      "object/get",
                                      "@entry",
                                      "1"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          "label": [
                            "object/get",
                            "@entry",
                            "0"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "data": "@entity.chartData",
                      "showLegend": "@config.showLegend",
                      "title": "@config.title",
                      "type": "chart",
                      "subtitle": "@config.subtitle",
                      "height": "@config.height",
                      "showValues": "@config.showValues",
                      "chartType": "@config.chartType"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "height": {
              "type": "number",
              "default": 280.0
            },
            "showValues": {
              "type": "boolean",
              "default": false
            },
            "showLegend": {
              "type": "boolean",
              "default": true
            },
            "title": {
              "type": "string",
              "default": "Distribution"
            },
            "aggregation": {
              "type": "string",
              "default": "count",
              "values": [
                "count",
                "sum",
                "avg",
                "min",
                "max"
              ]
            },
            "valueField": {
              "type": "string",
              "default": ""
            },
            "chartType": {
              "type": "string",
              "default": "bar",
              "values": [
                "bar",
                "line",
                "pie",
                "area"
              ]
            },
            "categoryField": {
              "type": "string",
              "default": "status"
            },
            "subtitle": {
              "type": "string",
              "default": "Counts per category"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GraphItemGraphPage",
          "path": "/graphitems",
          "traits": [
            {
              "ref": "GraphItemGraph"
            }
          ]
        }
      ]
    }
  ]
}
