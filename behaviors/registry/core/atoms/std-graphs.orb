{
  "name": "std-graphs",
  "version": "2.0.0",
  "description": "std-graphs — embeddable chart atom. ITEMS_LOADED groups @payload.data by @config.categoryField (or @config.timeField when timeAxis=true) and aggregates per bucket. Multi-series rendering via @config.series (preformatted ChartSeries shape). Histograms via chartType=histogram pass pre-binned @payload.data through unchanged. Stacked / 100% stacked bars via @config.stack. Post-process sort + limit. Clicking a data point emits UI:@config.drillEvent with { label, value, seriesLabel? }. Drop into a dashboard alongside std-stats / std-browse.",
  "orbitals": [
    {
      "name": "GraphItemOrbital",
      "entity": {
        "name": "GraphItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "value": {
                  "name": "value",
                  "type": "number",
                  "required": true
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "GraphItemGraph",
          "category": "interaction",
          "linkedEntity": "GraphItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      {
                        "value": 6.0,
                        "label": "Active"
                      },
                      {
                        "value": 3.0,
                        "label": "Pending"
                      },
                      {
                        "value": 1.0,
                        "label": "Inactive"
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "@config.subtitle",
                      "stack": "@config.stack",
                      "series": "@config.series",
                      "showLegend": "@config.showLegend",
                      "timeAxis": "@config.timeAxis",
                      "drillEvent": "@config.drillEvent",
                      "type": "@config.viewPattern",
                      "showValues": "@config.showValues",
                      "title": "@config.title",
                      "chartType": "@config.chartType",
                      "height": "@config.height",
                      "data": "@entity.chartData"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "if",
                      [
                        "=",
                        "@config.chartType",
                        "histogram"
                      ],
                      [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "p",
                          {
                            "label": [
                              "object/get",
                              "@p",
                              "label"
                            ],
                            "value": [
                              "object/get",
                              "@p",
                              "value"
                            ]
                          }
                        ]
                      ],
                      [
                        "array/map",
                        [
                          "object/entries",
                          [
                            "array/groupBy",
                            "@payload.data",
                            [
                              "if",
                              "@config.timeAxis",
                              "@config.timeField",
                              "@config.categoryField"
                            ]
                          ]
                        ],
                        [
                          "fn",
                          "entry",
                          {
                            "label": [
                              "object/get",
                              "@entry",
                              "0"
                            ],
                            "value": [
                              "if",
                              [
                                "=",
                                "@config.aggregation",
                                "sum"
                              ],
                              [
                                "array/sum",
                                [
                                  "object/get",
                                  "@entry",
                                  "1"
                                ],
                                "@config.valueField"
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  "@config.aggregation",
                                  "avg"
                                ],
                                [
                                  "array/avg",
                                  [
                                    "object/get",
                                    "@entry",
                                    "1"
                                  ],
                                  "@config.valueField"
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    "@config.aggregation",
                                    "min"
                                  ],
                                  [
                                    "array/min",
                                    [
                                      "object/get",
                                      "@entry",
                                      "1"
                                    ],
                                    "@config.valueField"
                                  ],
                                  [
                                    "if",
                                    [
                                      "=",
                                      "@config.aggregation",
                                      "max"
                                    ],
                                    [
                                      "array/max",
                                      [
                                        "object/get",
                                        "@entry",
                                        "1"
                                      ],
                                      "@config.valueField"
                                    ],
                                    [
                                      "array/len",
                                      [
                                        "object/get",
                                        "@entry",
                                        "1"
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "if",
                      [
                        "!=",
                        "@config.sortField",
                        "none"
                      ],
                      [
                        "array/sort",
                        "@entity.chartData",
                        "@config.sortField",
                        "@config.sortDir"
                      ],
                      "@entity.chartData"
                    ]
                  ],
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "if",
                      [
                        ">",
                        "@config.limit",
                        0.0
                      ],
                      [
                        "array/take",
                        "@entity.chartData",
                        "@config.limit"
                      ],
                      "@entity.chartData"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "stack": "@config.stack",
                      "subtitle": "@config.subtitle",
                      "drillEvent": "@config.drillEvent",
                      "chartType": "@config.chartType",
                      "height": "@config.height",
                      "timeAxis": "@config.timeAxis",
                      "showLegend": "@config.showLegend",
                      "series": "@config.series",
                      "data": "@entity.chartData",
                      "type": "@config.viewPattern",
                      "title": "@config.title",
                      "showValues": "@config.showValues"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "sortDir": {
              "type": "string",
              "default": "desc",
              "label": "Sort direction",
              "description": "Ascending or descending order for the sort field",
              "synonyms": "asc = ascending = lowest-to-highest = low-to-high = smallest-first. desc = descending = highest-to-lowest = high-to-low = largest-first. user phrases: 'highest to lowest' / 'largest first' / 'descending' -> desc; 'lowest to highest' / 'smallest first' / 'ascending' -> asc",
              "tier": "advanced",
              "values": [
                "asc",
                "desc"
              ]
            },
            "title": {
              "type": "string",
              "default": "Distribution",
              "label": "Title",
              "description": "Heading shown above the chart",
              "synonyms": "the chart's header text. user phrases: 'rename to X' / 'title it X' / 'change the title to X' / 'call it X' -> X",
              "tier": "customization"
            },
            "chartType": {
              "type": "string",
              "default": "bar",
              "label": "Chart type",
              "description": "Visual format for the rendered chart",
              "synonyms": "bar = vertical bars, line = connected line, pie = pie chart, donut = pie with hole, area = filled area chart, histogram = frequency distribution, scatter = XY scatter. user phrases: 'switch to donut' / 'make it a donut' / 'as a donut chart' -> donut; 'use a pie chart' -> pie; 'show as line' / 'line chart' -> line; 'as bars' / 'bar chart' -> bar",
              "tier": "essential",
              "values": [
                "bar",
                "line",
                "pie",
                "area",
                "donut",
                "histogram",
                "scatter"
              ]
            },
            "series": {
              "type": "[SeriesSpec]",
              "default": [],
              "label": "Series",
              "description": "Pre-formatted multi-series spec for stacked or layered charts",
              "synonyms": "multiple lines / bars per category. user phrases: 'compare X and Y' -> add two series entries",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "data": {
                    "name": "data",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "name": "label",
                          "type": "string",
                          "required": true
                        },
                        "value": {
                          "name": "value",
                          "type": "number",
                          "required": true
                        }
                      }
                    }
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "dashed": {
                    "name": "dashed",
                    "type": "boolean",
                    "required": false
                  }
                }
              }
            },
            "valueField": {
              "type": "string",
              "default": "",
              "label": "Value field",
              "description": "Numeric field aggregated per bucket (blank = row count)",
              "synonyms": "the numeric column to aggregate. empty string counts rows. user phrases: 'sum revenue' -> valueField=revenue + aggregation=sum",
              "tier": "customization"
            },
            "aggregation": {
              "type": "string",
              "default": "count",
              "label": "Aggregation",
              "description": "How values within a bucket combine into one number",
              "synonyms": "user phrases: 'count' / 'how many' -> count; 'total' / 'sum of' -> sum; 'average' / 'mean' -> avg; 'minimum' / 'lowest' -> min; 'maximum' / 'highest' -> max",
              "tier": "customization",
              "values": [
                "count",
                "sum",
                "avg",
                "min",
                "max"
              ]
            },
            "showValues": {
              "type": "boolean",
              "default": false,
              "label": "Show values",
              "description": "Render the numeric value on top of each data point",
              "synonyms": "user phrases: 'show values' / 'show numbers on bars' / 'with data labels' / 'label the bars' -> true; 'hide values' / 'no labels' -> false",
              "tier": "advanced"
            },
            "categoryField": {
              "type": "string",
              "default": "status",
              "label": "Group-by field",
              "description": "Entity field whose values become the chart's categories",
              "synonyms": "user phrases: 'group by status' -> categoryField=status; 'by region' -> categoryField=region; 'split by X' -> categoryField=X",
              "tier": "essential"
            },
            "stack": {
              "type": "string",
              "default": "none",
              "label": "Stacking",
              "description": "Stack bars, normalize to 100%, or render side-by-side",
              "synonyms": "user phrases: 'side by side' / 'grouped' -> none; 'stacked' / 'stack the bars' -> stack; 'percent stacked' / '100% stacked' / 'normalized' -> normalize",
              "tier": "customization",
              "values": [
                "none",
                "stack",
                "normalize"
              ]
            },
            "subtitle": {
              "type": "string",
              "default": "Counts per category",
              "label": "Subtitle",
              "description": "Secondary line below the title",
              "synonyms": "secondary header below the title. user phrases: 'with subtitle X' / 'set subtitle to X' -> X",
              "tier": "customization"
            },
            "period": {
              "type": "string",
              "default": "month",
              "label": "Bucket period",
              "description": "Calendar bucket size when grouping by time",
              "synonyms": "user phrases: 'daily' / 'by day' -> day; 'weekly' / 'by week' -> week; 'monthly' / 'by month' -> month; 'quarterly' / 'by quarter' -> quarter; 'yearly' / 'annually' / 'by year' -> year",
              "tier": "customization",
              "values": [
                "day",
                "week",
                "month",
                "quarter",
                "year"
              ]
            },
            "timeField": {
              "type": "string",
              "default": "date",
              "label": "Date field",
              "description": "Entity field used as the time axis when timeAxis is on",
              "synonyms": "the date / timestamp / created-at column. set when timeAxis=true",
              "tier": "customization"
            },
            "sortField": {
              "type": "string",
              "default": "none",
              "label": "Sort by",
              "description": "Order points by value, label, or leave unsorted",
              "synonyms": "user phrases: 'sort by value' / 'order by amount' -> value; 'sort alphabetically' / 'sort by name' -> label; 'no sort' / 'leave order' -> none",
              "tier": "customization",
              "values": [
                "value",
                "label",
                "none"
              ]
            },
            "height": {
              "type": "number",
              "default": 280.0,
              "label": "Chart height",
              "description": "Pixel height of the rendered chart",
              "synonyms": "vertical size in pixels. user phrases: 'taller' / 'make it taller' / 'increase height' / 'bigger vertically' -> larger number (e.g. 300, 400); 'shorter' / 'smaller' -> smaller; 'set height to 300' / '300px tall' -> 300",
              "tier": "advanced"
            },
            "timeAxis": {
              "type": "boolean",
              "default": false,
              "label": "Time axis",
              "description": "Group by timeField bucketed by period instead of categoryField",
              "synonyms": "true means group by date / month / time. user phrases: 'group by month / week / year / date' -> set timeAxis=true; 'group by status / category' -> timeAxis=false",
              "tier": "customization"
            },
            "limit": {
              "type": "number",
              "default": 0.0,
              "label": "Top N",
              "description": "Keep only the first N points after sorting (0 = all)",
              "synonyms": "user phrases: 'top 5' -> 5; 'top 10' -> 10; 'first 3' -> 3; 'all' / 'no limit' -> 0; 'show all' -> 0",
              "tier": "customization"
            },
            "showLegend": {
              "type": "boolean",
              "default": true,
              "label": "Show legend",
              "description": "Display the series legend",
              "synonyms": "true shows the color key. user phrases: 'show legend' / 'show the legend' / 'show key' / 'with legend' / 'with a legend' -> true; 'hide legend' / 'no legend' / 'without legend' / 'remove legend' -> false",
              "tier": "advanced"
            },
            "drillEvent": {
              "type": "string",
              "default": "",
              "label": "Drill event",
              "description": "Event emitted when a user clicks a chart point",
              "synonyms": "click-through navigation event. user phrases: 'on click navigate to X' / 'drill into X' / 'when clicked open X' -> X event name",
              "tier": "advanced"
            },
            "viewPattern": {
              "type": "pattern",
              "default": "chart",
              "label": "Render pattern",
              "description": "UI pattern used to draw the chart",
              "synonyms": "internal pattern selector. user prompts rarely target this directly — pattern selection is upstream",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GraphItemGraphPage",
          "path": "/graphitems",
          "traits": [
            {
              "ref": "GraphItemGraph"
            }
          ]
        }
      ]
    }
  ]
}
