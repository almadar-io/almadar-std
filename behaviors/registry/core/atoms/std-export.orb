{
  "name": "std-export",
  "version": "3.0.0",
  "description": "std-export — a row of export-format buttons. Predefined CSV/XLSX/PDF defaults; caller can override via config.formats. Emits EXPORT_REQUESTED { format, tileId } on the bus; host or sibling orbital generates the file.",
  "orbitals": [
    {
      "name": "ExportOrbital",
      "entity": {
        "name": "ExportPanel",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "options",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "traits": [
        {
          "name": "ExportMenu",
          "category": "interaction",
          "linkedEntity": "ExportPanel",
          "emits": [
            {
              "event": "EXPORT_REQUESTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "format",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "tileId",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXPORT_REQUESTED",
                "name": "Export Requested",
                "payloadSchema": [
                  {
                    "name": "format",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.options",
                    "@config.formats"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "card",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "download",
                                  "type": "icon"
                                },
                                {
                                  "content": "Export",
                                  "variant": "h4",
                                  "type": "typography"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "content": "Choose a format to download this view",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "fields": [],
                              "type": "data-list",
                              "entity": "@entity.options",
                              "renderItem": [
                                "fn",
                                "fmt",
                                {
                                  "action": "@config.event",
                                  "variant": "outline",
                                  "size": "sm",
                                  "actionPayload": {
                                    "format": "@fmt.format",
                                    "tileId": "@config.tileId"
                                  },
                                  "label": "@fmt.label",
                                  "type": "button",
                                  "icon": "file-down"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EXPORT_REQUESTED",
                "effects": [
                  [
                    "set",
                    "@entity.options",
                    "@entity.options"
                  ]
                ]
              }
            ]
          },
          "config": {
            "tileId": {
              "type": "string",
              "default": ""
            },
            "event": {
              "type": "string",
              "default": "EXPORT_REQUESTED"
            },
            "formats": {
              "type": "[FormatOption]",
              "default": [
                {
                  "id": "csv",
                  "format": "csv",
                  "label": "CSV"
                },
                {
                  "id": "xlsx",
                  "format": "xlsx",
                  "label": "XLSX"
                },
                {
                  "label": "PDF",
                  "format": "pdf",
                  "id": "pdf"
                }
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ExportMenuPage",
          "path": "/exports/menu",
          "traits": [
            {
              "ref": "ExportMenu"
            }
          ]
        }
      ]
    }
  ]
}
