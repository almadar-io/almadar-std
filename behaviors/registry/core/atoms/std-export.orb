{
  "name": "std-export",
  "version": "3.0.0",
  "description": "std-export — a row of export-format buttons. Predefined CSV/XLSX/PDF defaults; caller can override via config.formats. Emits EXPORT_REQUESTED { format, tileId } on the bus; host or sibling orbital generates the file.",
  "orbitals": [
    {
      "name": "ExportOrbital",
      "entity": {
        "name": "ExportPanel",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "options",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "name": "id",
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "ExportMenu",
          "category": "interaction",
          "linkedEntity": "ExportPanel",
          "emits": [
            {
              "event": "EXPORT_REQUESTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "format",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "tileId",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OPEN_EXPORT",
                "name": "Open Export"
              },
              {
                "key": "EXPORT_REQUESTED",
                "name": "Export Requested",
                "payloadSchema": [
                  {
                    "name": "format",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "tileId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.options",
                    "@config.formats"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "content": {
                        "fields": [],
                        "type": "data-list",
                        "renderItem": [
                          "fn",
                          "fmt",
                          {
                            "type": "button",
                            "label": "@fmt.label",
                            "variant": "ghost",
                            "size": "sm",
                            "actionPayload": {
                              "tileId": "@config.tileId",
                              "format": "@fmt.format"
                            },
                            "action": "@config.event",
                            "icon": "file-down"
                          }
                        ],
                        "entity": "@entity.options"
                      },
                      "children": {
                        "action": "OPEN_EXPORT",
                        "icon": "download",
                        "variant": "ghost",
                        "type": "button",
                        "size": "sm",
                        "label": "Export"
                      },
                      "position": "bottom",
                      "type": "popover"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "OPEN_EXPORT",
                "effects": [
                  [
                    "set",
                    "@entity.options",
                    "@entity.options"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EXPORT_REQUESTED",
                "effects": [
                  [
                    "set",
                    "@entity.options",
                    "@entity.options"
                  ]
                ]
              }
            ]
          },
          "config": {
            "tileId": {
              "type": "string",
              "default": ""
            },
            "event": {
              "type": "string",
              "default": "EXPORT_REQUESTED"
            },
            "formats": {
              "type": "[object]",
              "default": [
                {
                  "id": "csv",
                  "format": "csv",
                  "label": "CSV"
                },
                {
                  "label": "XLSX",
                  "format": "xlsx",
                  "id": "xlsx"
                },
                {
                  "label": "PDF",
                  "id": "pdf",
                  "format": "pdf"
                }
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ExportMenuPage",
          "path": "/exports/menu",
          "traits": [
            {
              "ref": "ExportMenu"
            }
          ]
        }
      ]
    }
  ]
}
