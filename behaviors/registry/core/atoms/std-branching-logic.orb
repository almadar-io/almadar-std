{
  "name": "std-branching-logic",
  "version": "1.0.0",
  "description": "std-branching-logic — survey skip-logic rules. Owns a BranchingRule entity and a manage trait that fetches rules on INIT, lists them via the branching-logic-builder pattern, and persists ADD_RULE / UPDATE_RULE / DELETE_RULE.",
  "orbitals": [
    {
      "name": "BranchingLogicOrbital",
      "entity": {
        "name": "BranchingRule",
        "collection": "branchingrules",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "surveyId",
            "type": "string",
            "required": true
          },
          {
            "name": "sourceQuestionId",
            "type": "string",
            "required": true
          },
          {
            "name": "operator",
            "type": "string",
            "default": "equals",
            "values": [
              "equals",
              "not-equals",
              "contains",
              "in"
            ]
          },
          {
            "name": "value",
            "type": "string"
          },
          {
            "name": "targetQuestionId",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "BranchingRuleManage",
          "category": "interaction",
          "linkedEntity": "BranchingRule",
          "emits": [
            {
              "event": "ADD_RULE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE_RULE",
              "payloadSchema": [
                {
                  "name": "ruleId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sourceQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.operator",
                  "type": "string"
                },
                {
                  "name": "row.value",
                  "type": "string"
                },
                {
                  "name": "row.targetQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "number"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE_RULE",
              "payloadSchema": [
                {
                  "name": "ruleId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sourceQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.operator",
                  "type": "string"
                },
                {
                  "name": "row.value",
                  "type": "string"
                },
                {
                  "name": "row.targetQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "number"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_SOURCE",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_OPERATOR",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_VALUE",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_TARGET",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL"
            },
            {
              "event": "BranchingRuleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BranchingRule]"
                }
              ]
            },
            {
              "event": "BranchingRuleLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BranchingRuleAdded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sourceQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.operator",
                  "type": "string"
                },
                {
                  "name": "row.value",
                  "type": "string"
                },
                {
                  "name": "row.targetQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "number"
                }
              ]
            },
            {
              "event": "BranchingRuleUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sourceQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.operator",
                  "type": "string"
                },
                {
                  "name": "row.value",
                  "type": "string"
                },
                {
                  "name": "row.targetQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "number"
                }
              ]
            },
            {
              "event": "BranchingRuleDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BranchingRuleLoaded",
                "name": "BranchingRule loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BranchingRule]"
                  }
                ]
              },
              {
                "key": "BranchingRuleLoadFailed",
                "name": "BranchingRule load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADD_RULE",
                "name": "Add Rule",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE_RULE",
                "name": "Delete Rule",
                "payloadSchema": [
                  {
                    "name": "ruleId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BranchingRule"
                  }
                ]
              },
              {
                "key": "BranchingRuleAdded",
                "name": "BranchingRule added",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "BranchingRule"
                  }
                ]
              },
              {
                "key": "BranchingRuleUpdated",
                "name": "BranchingRule updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "BranchingRule"
                  }
                ]
              },
              {
                "key": "BranchingRuleDeleted",
                "name": "BranchingRule deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_SOURCE",
                "name": "Edit Source",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_OPERATOR",
                "name": "Edit Operator",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_VALUE",
                "name": "Edit Value",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_TARGET",
                "name": "Edit Target",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE_RULE",
                "name": "Update Rule",
                "payloadSchema": [
                  {
                    "name": "ruleId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BranchingRule"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading branching rules…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BranchingRuleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "git-branch",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "rules": "@payload.data",
                          "type": "branching-logic-builder",
                          "questions": []
                        },
                        {
                          "entity": "@payload.data",
                          "gap": "sm",
                          "fields": [
                            {
                              "name": "sourceQuestionId",
                              "label": "If question"
                            },
                            {
                              "label": "Op",
                              "variant": "badge",
                              "name": "operator"
                            },
                            {
                              "label": "Value",
                              "name": "value"
                            },
                            {
                              "name": "targetQuestionId",
                              "label": "Jump to"
                            },
                            {
                              "label": "Priority",
                              "variant": "badge",
                              "name": "priority"
                            }
                          ],
                          "cols": 1.0,
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "secondary",
                              "icon": "pencil"
                            },
                            {
                              "label": "Delete",
                              "event": "DELETE_RULE",
                              "variant": "danger",
                              "icon": "trash-2"
                            }
                          ]
                        },
                        {
                          "icon": "plus",
                          "label": "Add rule",
                          "variant": "primary",
                          "action": "ADD_RULE",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BranchingRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ADD_RULE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "BranchingRule",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "BranchingRuleAdded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "pencil"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Edit branching rule"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "Source question id",
                          "value": "@entity.sourceQuestionId",
                          "action": "EDIT_SOURCE"
                        },
                        {
                          "type": "select",
                          "placeholder": "Operator",
                          "action": "EDIT_OPERATOR",
                          "options": [
                            {
                              "value": "equals",
                              "label": "Equals"
                            },
                            {
                              "label": "Not equals",
                              "value": "not-equals"
                            },
                            {
                              "label": "Contains",
                              "value": "contains"
                            },
                            {
                              "label": "In",
                              "value": "in"
                            }
                          ],
                          "value": "@entity.operator"
                        },
                        {
                          "action": "EDIT_VALUE",
                          "value": "@entity.value",
                          "type": "input",
                          "placeholder": "Value"
                        },
                        {
                          "action": "EDIT_TARGET",
                          "placeholder": "Target question id",
                          "value": "@entity.targetQuestionId",
                          "type": "input"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "UPDATE_RULE",
                              "icon": "check",
                              "type": "button",
                              "variant": "primary",
                              "label": "Save"
                            },
                            {
                              "label": "Cancel",
                              "variant": "secondary",
                              "type": "button",
                              "action": "CANCEL",
                              "icon": "x"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DELETE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.ruleId"
                  ],
                  [
                    "persist",
                    "delete",
                    "BranchingRule",
                    "@payload.row",
                    {
                      "emit": {
                        "success": "BranchingRuleDeleted",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "BranchingRuleAdded",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "success": "BranchingRuleLoaded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "BranchingRuleUpdated",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "BranchingRuleDeleted",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "success": "BranchingRuleLoaded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "BranchingRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "EDIT_SOURCE",
                "effects": [
                  [
                    "set",
                    "@entity.sourceQuestionId",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "EDIT_OPERATOR",
                "effects": [
                  [
                    "set",
                    "@entity.operator",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "EDIT_VALUE",
                "effects": [
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "EDIT_TARGET",
                "effects": [
                  [
                    "set",
                    "@entity.targetQuestionId",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "UPDATE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.ruleId"
                  ],
                  [
                    "set",
                    "@entity.sourceQuestionId",
                    "@payload.row.sourceQuestionId"
                  ],
                  [
                    "set",
                    "@entity.operator",
                    "@payload.row.operator"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.row.value"
                  ],
                  [
                    "set",
                    "@entity.targetQuestionId",
                    "@payload.row.targetQuestionId"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.row.priority"
                  ],
                  [
                    "persist",
                    "update",
                    "BranchingRule",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "success": "BranchingRuleLoaded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "BranchingRuleUpdated",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "success": "BranchingRuleLoaded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "BranchingRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Branching Rules"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BranchingRuleManagePage",
          "path": "/branching-rules",
          "traits": [
            {
              "ref": "BranchingRuleManage"
            }
          ]
        }
      ]
    }
  ]
}