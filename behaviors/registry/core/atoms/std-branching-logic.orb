{
  "name": "std-branching-logic",
  "version": "1.0.0",
  "description": "std-branching-logic — survey skip-logic rules. Lists rules in `browsing`; opens rule detail in `viewing_single` with Edit / Delete actions.",
  "orbitals": [
    {
      "name": "BranchingLogicOrbital",
      "entity": {
        "name": "BranchingRule",
        "collection": "branchingrules",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "surveyId",
            "type": "string",
            "required": true,
            "description": "Unique identifier for the survey this rule applies to.",
            "synonyms": "survey, questionnaire, form"
          },
          {
            "name": "sourceQuestionId",
            "type": "string",
            "required": true,
            "description": "The ID of the question triggering the branching logic.",
            "synonyms": "trigger, source, question_id"
          },
          {
            "name": "operator",
            "type": "string",
            "default": "equals",
            "values": [
              "equals",
              "not-equals",
              "contains",
              "in"
            ],
            "description": "Specifies the comparison method used in the rule.",
            "synonyms": "comparison, method, type"
          },
          {
            "name": "value",
            "type": "string",
            "description": "The data being compared against a condition.",
            "synonyms": "data, content, expression"
          },
          {
            "name": "targetQuestionId",
            "type": "string",
            "required": true,
            "description": "The ID of the question to navigate to based on the rule.",
            "synonyms": "destination, nextQuestion, target"
          },
          {
            "name": "priority",
            "type": "number",
            "default": 0.0,
            "description": "Specifies the order in which rules are evaluated.",
            "synonyms": "order, sequence, precedence"
          }
        ]
      },
      "traits": [
        {
          "name": "BranchingRuleManage",
          "category": "interaction",
          "linkedEntity": "BranchingRule",
          "emits": [
            {
              "event": "OPEN_RULE",
              "description": "Signals a rule detail view should be opened.",
              "synonyms": "show, display, reveal, open",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sourceQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.operator",
                  "type": "string"
                },
                {
                  "name": "row.value",
                  "type": "string"
                },
                {
                  "name": "row.targetQuestionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW",
              "description": "Indicates the detail view has been closed.",
              "synonyms": "dismiss, hide, close",
              "tier": "customization"
            },
            {
              "event": "DELETE_RULE",
              "description": "Signals a branching rule has been removed.",
              "synonyms": "remove, discard, delete",
              "tier": "customization",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BranchingRuleLoaded",
              "description": "Indicates a branching rule has been successfully retrieved.",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BranchingRule]"
                }
              ]
            },
            {
              "event": "BranchingRuleLoadFailed",
              "description": "Indicates a failure to load a branching rule.",
              "synonyms": "error, failure, problem, unsuccessful",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BranchingRuleLoaded",
                "name": "BranchingRule loaded",
                "description": "Indicates a branching rule has been successfully retrieved.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BranchingRule]"
                  }
                ]
              },
              {
                "key": "BranchingRuleLoadFailed",
                "name": "BranchingRule load failed",
                "description": "Indicates a failure to load a branching rule.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RULE",
                "name": "Open Rule",
                "description": "Signals a rule detail view should be opened.",
                "synonyms": "show, display, reveal, open",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "BranchingRule"
                  }
                ]
              },
              {
                "key": "DELETE_RULE",
                "name": "Delete Rule",
                "description": "Signals a branching rule has been removed.",
                "synonyms": "remove, discard, delete",
                "tier": "customization",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View",
                "description": "Indicates the detail view has been closed.",
                "synonyms": "dismiss, hide, close",
                "tier": "customization"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "success": "BranchingRuleLoaded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading branching rules…"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BranchingRuleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-branch"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Total rules",
                              "value": "@payload.data.length",
                              "icon": "git-branch"
                            },
                            {
                              "value": "8",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Active surveys",
                              "icon": "clipboard-list"
                            },
                            {
                              "label": "Skip jumps",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "value": "42",
                              "icon": "skip-forward"
                            },
                            {
                              "icon": "trending-up",
                              "value": "3",
                              "label": "Priority avg",
                              "type": "stat-display",
                              "look": "@config.statLook"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "look": "@config.tableLook",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "sourceQuestionId",
                              "label": "If question"
                            },
                            {
                              "label": "Op",
                              "name": "operator",
                              "variant": "badge"
                            },
                            {
                              "name": "value",
                              "label": "Value",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "label": "Jump to",
                              "name": "targetQuestionId"
                            },
                            {
                              "label": "Priority",
                              "variant": "badge",
                              "name": "priority"
                            }
                          ],
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Open",
                              "variant": "primary",
                              "event": "OPEN_RULE",
                              "icon": "arrow-right"
                            },
                            {
                              "icon": "trash-2",
                              "event": "DELETE_RULE",
                              "variant": "danger",
                              "label": "Delete"
                            }
                          ],
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BranchingRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.surveyId",
                    "@payload.row.surveyId"
                  ],
                  [
                    "set",
                    "@entity.sourceQuestionId",
                    "@payload.row.sourceQuestionId"
                  ],
                  [
                    "set",
                    "@entity.operator",
                    "@payload.row.operator"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.row.value"
                  ],
                  [
                    "set",
                    "@entity.targetQuestionId",
                    "@payload.row.targetQuestionId"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.row.priority"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "git-branch",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.sourceQuestionId",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.operator",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Survey",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.surveyId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Value"
                                },
                                {
                                  "content": "@entity.value",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.sourceQuestionId",
                              "label": "Source",
                              "icon": "help-circle",
                              "look": "@config.statLook"
                            },
                            {
                              "value": "@entity.targetQuestionId",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "icon": "arrow-right-circle",
                              "label": "Target"
                            },
                            {
                              "label": "Priority",
                              "value": "@entity.priority",
                              "icon": "trending-up",
                              "look": "@config.statLook",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "type": "button",
                              "action": "DELETE_RULE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Deleting rule…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading branching rules…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DELETE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "success": "BranchingRuleLoaded",
                        "failure": "BranchingRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Deleting rule…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BranchingRule",
                    {
                      "emit": {
                        "failure": "BranchingRuleLoadFailed",
                        "success": "BranchingRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Branching Rules",
              "label": "Section title",
              "description": "Heading shown above the branching-rule list",
              "tier": "presentation"
            },
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "statLook": {
              "type": "string",
              "default": "elevated",
              "label": "Stat display look",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BranchingRuleManagePage",
          "path": "/branching-rules",
          "traits": [
            {
              "ref": "BranchingRuleManage"
            }
          ]
        }
      ]
    }
  ]
}
