{
  "name": "std-step-flow",
  "version": "3.4.0",
  "description": "std-step-flow — generic N-step sequential decision chain (Stripe Connect / TurboTax / Vercel deploy style). `config.steps` is an array of step definitions `{ key, label, description, icon, allowedRoles?: [string] }`; the trait projects the current step into a prominent body card and a `wizard-progress` stepper bar at the top. When a step declares `allowedRoles`, only users whose `@user.role` is in that list can advance through it. One primary button ADVANCEs along the chain; at the last step the same button finalizes (label/icon/variant swap via entity binding, state routed via guard). REJECT/ESCALATE terminate. Topology = loading / running / approved / rejected / escalated / error.",
  "orbitals": [
    {
      "name": "StepFlowOrbital",
      "entity": {
        "name": "StepFlowView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "wizardSteps",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "badgeVariant": {
                  "name": "badgeVariant",
                  "type": "string",
                  "required": false
                },
                "key": {
                  "name": "key",
                  "type": "string",
                  "required": false
                },
                "indexLabel": {
                  "name": "indexLabel",
                  "type": "string",
                  "required": false
                },
                "labelColor": {
                  "name": "labelColor",
                  "type": "string",
                  "required": false
                },
                "isPending": {
                  "name": "isPending",
                  "type": "boolean",
                  "required": false
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": false
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          {
            "name": "currentStepIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "currentStepLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepIcon",
            "type": "string",
            "default": "user"
          },
          {
            "name": "isFirstStep",
            "type": "boolean",
            "default": true
          },
          {
            "name": "isLastStep",
            "type": "boolean",
            "default": false
          },
          {
            "name": "primaryActionLabel",
            "type": "string",
            "default": "Approve & Continue"
          },
          {
            "name": "primaryActionVariant",
            "type": "string",
            "default": "primary",
            "values": [
              "primary",
              "success"
            ]
          },
          {
            "name": "primaryActionIcon",
            "type": "string",
            "default": "chevron-right"
          },
          {
            "name": "finalStatus",
            "type": "string",
            "default": "",
            "values": [
              "approved",
              "rejected",
              "escalated",
              ""
            ]
          },
          {
            "name": "rejectionReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "StepFlowReview",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "currentStepDescription",
              "currentStepIcon",
              "currentStepIndex",
              "currentStepLabel",
              "errorMessage",
              "finalStatus",
              "isFirstStep",
              "isLastStep",
              "primaryActionIcon",
              "primaryActionLabel",
              "primaryActionVariant",
              "rejectionReason",
              "totalSteps",
              "wizardSteps"
            ]
          },
          "category": "interaction",
          "linkedEntity": "StepFlowView",
          "emits": [
            {
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "stepKey",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BACK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESTART",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StepItemsLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "StepItemsLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "approved"
              },
              {
                "name": "rejected"
              },
              {
                "name": "escalated"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StepItemsLoaded",
                "name": "Step items loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "StepItemsLoadFailed",
                "name": "Step items load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StepItemsSaved",
                "name": "Step items saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "StepItemsSaveFailed",
                "name": "Step items save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "stepKey",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BACK",
                "name": "Back",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "failure": "StepItemsLoadFailed",
                        "success": "StepItemsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading review…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "StepItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@payload.data",
                        0.0
                      ],
                      "id"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    [
                      "array/len",
                      "@config.steps"
                    ]
                  ],
                  [
                    "set",
                    "@entity.wizardSteps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "badgeVariant": [
                            "if",
                            [
                              "<",
                              "@index",
                              "@entity.currentStepIndex"
                            ],
                            "success",
                            [
                              "if",
                              [
                                "=",
                                "@index",
                                "@entity.currentStepIndex"
                              ],
                              "primary",
                              "neutral"
                            ]
                          ],
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "labelColor": [
                            "if",
                            [
                              "=",
                              "@index",
                              "@entity.currentStepIndex"
                            ],
                            "default",
                            "muted"
                          ],
                          "indexLabel": [
                            "str/concat",
                            "",
                            [
                              "+",
                              "@index",
                              1.0
                            ]
                          ],
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "title": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "isPending": [
                            ">",
                            "@index",
                            "@entity.currentStepIndex"
                          ],
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "circle"
                          ],
                          "id": [
                            "object/get",
                            "@step",
                            "key"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    true
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      [
                        "array/len",
                        "@config.steps"
                      ],
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "Finalize Approval",
                      "Approve & Continue"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionVariant",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "success",
                      "primary"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StepItemsLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Failed to load",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "StepItemsSaved"
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StepItemsSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Save failed",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "ADVANCE",
                "guard": [
                  "and",
                  [
                    "not",
                    "@entity.isLastStep"
                  ],
                  [
                    "or",
                    [
                      "=",
                      [
                        "object/get",
                        [
                          "array/nth",
                          "@config.steps",
                          "@entity.currentStepIndex"
                        ],
                        "allowedRoles",
                        "ANY"
                      ],
                      "ANY"
                    ],
                    [
                      "array/includes",
                      [
                        "object/get",
                        [
                          "array/nth",
                          "@config.steps",
                          "@entity.currentStepIndex"
                        ],
                        "allowedRoles"
                      ],
                      "@user.role"
                    ]
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "+",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      [
                        "-",
                        "@entity.totalSteps",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "Finalize Approval",
                      "Approve & Continue"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionVariant",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "success",
                      "primary"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "set",
                    "@entity.wizardSteps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "circle"
                          ],
                          "title": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "indexLabel": [
                            "str/concat",
                            "",
                            [
                              "+",
                              "@index",
                              1.0
                            ]
                          ],
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "id": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "badgeVariant": [
                            "if",
                            [
                              "<",
                              "@index",
                              "@entity.currentStepIndex"
                            ],
                            "success",
                            [
                              "if",
                              [
                                "=",
                                "@index",
                                "@entity.currentStepIndex"
                              ],
                              "primary",
                              "neutral"
                            ]
                          ],
                          "labelColor": [
                            "if",
                            [
                              "=",
                              "@index",
                              "@entity.currentStepIndex"
                            ],
                            "default",
                            "muted"
                          ],
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "isPending": [
                            ">",
                            "@index",
                            "@entity.currentStepIndex"
                          ],
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "running",
                "to": "approved",
                "event": "ADVANCE",
                "guard": [
                  "and",
                  "@entity.isLastStep",
                  [
                    "or",
                    [
                      "=",
                      [
                        "object/get",
                        [
                          "array/nth",
                          "@config.steps",
                          "@entity.currentStepIndex"
                        ],
                        "allowedRoles",
                        "ANY"
                      ],
                      "ANY"
                    ],
                    [
                      "array/includes",
                      [
                        "object/get",
                        [
                          "array/nth",
                          "@config.steps",
                          "@entity.currentStepIndex"
                        ],
                        "allowedRoles"
                      ],
                      "@user.role"
                    ]
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "approved"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon",
                          "size": "lg"
                        },
                        {
                          "content": "Approved",
                          "type": "typography",
                          "align": "center",
                          "variant": "h2"
                        },
                        {
                          "content": "All review steps completed successfully.",
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "align": "center"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.totalSteps",
                          "steps": "@entity.wizardSteps",
                          "allowNavigation": false
                        },
                        {
                          "type": "button",
                          "action": "RESTART",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "variant": "secondary",
                          "icon": "rotate-ccw",
                          "label": "Start a new review"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "BACK",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "-",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      [
                        "-",
                        "@entity.totalSteps",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "Finalize Approval",
                      "Approve & Continue"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionVariant",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "success",
                      "primary"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "set",
                    "@entity.wizardSteps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "id": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "labelColor": [
                            "if",
                            [
                              "=",
                              "@index",
                              "@entity.currentStepIndex"
                            ],
                            "default",
                            "muted"
                          ],
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "isPending": [
                            ">",
                            "@index",
                            "@entity.currentStepIndex"
                          ],
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "circle"
                          ],
                          "badgeVariant": [
                            "if",
                            [
                              "<",
                              "@index",
                              "@entity.currentStepIndex"
                            ],
                            "success",
                            [
                              "if",
                              [
                                "=",
                                "@index",
                                "@entity.currentStepIndex"
                              ],
                              "primary",
                              "neutral"
                            ]
                          ],
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "title": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "indexLabel": [
                            "str/concat",
                            "",
                            [
                              "+",
                              "@index",
                              1.0
                            ]
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "running",
                "to": "rejected",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "rejected"
                  ],
                  [
                    "set",
                    "@entity.rejectionReason",
                    "@payload.reason"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "align": "center",
                          "content": "Rejected"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Reason",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.rejectionReason"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "look": "@config.cardLook",
                          "type": "card"
                        },
                        {
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "label": "Start a new review",
                          "variant": "secondary",
                          "icon": "rotate-ccw",
                          "action": "RESTART",
                          "type": "button"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "escalated",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "escalated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "size": "lg",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "content": "Escalated",
                          "align": "center",
                          "type": "typography"
                        },
                        {
                          "content": "This item has been escalated for further review.",
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "align": "center"
                        },
                        {
                          "action": "RESTART",
                          "type": "button",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "label": "Start a new review",
                          "variant": "secondary",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "approved",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "success": "StepItemsLoaded",
                        "failure": "StepItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "rejected",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.rejectionReason",
                    ""
                  ],
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "failure": "StepItemsLoadFailed",
                        "success": "StepItemsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "escalated",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "success": "StepItemsLoaded",
                        "failure": "StepItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Review",
              "label": "Flow title",
              "description": "Heading shown above the step progress bar",
              "tier": "presentation"
            },
            "steps": {
              "type": "[StepSpec]",
              "default": [
                {
                  "key": "manager",
                  "label": "Manager Review",
                  "description": "Initial review by direct manager",
                  "icon": "user"
                },
                {
                  "key": "director",
                  "description": "Department director sign-off",
                  "icon": "users",
                  "label": "Director Approval"
                },
                {
                  "key": "executive",
                  "label": "Executive Sign-off",
                  "description": "Final executive approval",
                  "icon": "shield"
                }
              ],
              "label": "Steps",
              "description": "Ordered decision steps with label, icon, and optional role gates",
              "tier": "domain",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "allowedRoles": {
                    "name": "allowedRoles",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "description": {
                    "name": "description",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "cardLook": {
              "type": "string",
              "default": "elevated",
              "label": "Card look",
              "description": "Layer 2 visual treatment for cards rendered by this atom.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat-bordered",
                "borderless-divider",
                "ticket",
                "invoice",
                "chip",
                "tile-image-first"
              ]
            },
            "bodyContent": {
              "type": "render-ui",
              "default": {
                "type": "stack",
                "direction": "vertical",
                "children": [
                  {
                    "gap": "sm",
                    "children": [
                      {
                        "type": "icon",
                        "name": "shield-check"
                      },
                      {
                        "variant": "h3",
                        "content": "@config.title",
                        "type": "typography"
                      }
                    ],
                    "align": "center",
                    "type": "stack",
                    "direction": "horizontal"
                  },
                  {
                    "allowNavigation": false,
                    "steps": "@entity.wizardSteps",
                    "type": "wizard-progress",
                    "currentStep": "@entity.currentStepIndex"
                  },
                  {
                    "children": [
                      {
                        "gap": "md",
                        "type": "stack",
                        "children": [
                          {
                            "gap": "sm",
                            "children": [
                              {
                                "size": "lg",
                                "name": "@entity.currentStepIcon",
                                "type": "icon"
                              },
                              {
                                "gap": "xs",
                                "children": [
                                  {
                                    "content": "@entity.currentStepLabel",
                                    "type": "typography",
                                    "variant": "h2"
                                  },
                                  {
                                    "type": "typography",
                                    "variant": "body",
                                    "color": "muted",
                                    "content": "@entity.currentStepDescription"
                                  }
                                ],
                                "type": "stack",
                                "direction": "vertical"
                              }
                            ],
                            "type": "stack",
                            "align": "center",
                            "direction": "horizontal"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ],
                    "type": "card",
                    "look": "@config.cardLook"
                  },
                  {
                    "type": "stack",
                    "children": [
                      {
                        "label": "Back",
                        "disabled": "@entity.isFirstStep",
                        "actionPayload": {
                          "id": "@entity.id"
                        },
                        "variant": "ghost",
                        "action": "BACK",
                        "type": "button",
                        "icon": "chevron-left"
                      },
                      {
                        "label": "Reject",
                        "action": "REJECT",
                        "type": "button",
                        "variant": "ghost",
                        "icon": "x",
                        "actionPayload": {
                          "id": "@entity.id"
                        }
                      },
                      {
                        "action": "ESCALATE",
                        "icon": "alert-triangle",
                        "actionPayload": {
                          "id": "@entity.id"
                        },
                        "label": "Escalate",
                        "variant": "ghost",
                        "type": "button"
                      },
                      {
                        "type": "button",
                        "actionPayload": {
                          "id": "@entity.id"
                        },
                        "variant": "primary",
                        "action": "ADVANCE",
                        "label": "@entity.primaryActionLabel",
                        "icon": "@entity.primaryActionIcon"
                      }
                    ],
                    "direction": "horizontal",
                    "gap": "sm",
                    "align": "center"
                  }
                ],
                "gap": "lg"
              },
              "label": "Body content tree",
              "description": "Render-ui SExpr rendered while the step chain is active (loading-success, running, BACK). Default is the canonical wizard-progress + step-card + action-row tree. Layer 3 variants override this with their own tree (horizontal stepper, sidebar progress, card carousel, etc.) to deliver entirely different step UX while inheriting the same trait, state machine, emits, and listens.",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StepFlowPage",
          "path": "/step-flow",
          "traits": [
            {
              "ref": "StepFlowReview"
            }
          ]
        }
      ]
    }
  ]
}