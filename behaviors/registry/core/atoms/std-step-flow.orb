{
  "name": "std-step-flow",
  "version": "2.0.0",
  "description": "std-step-flow — generic N-step sequential decision chain (approval/review/sign-off). `config.steps` is an array of step definitions; @entity.currentStepIndex walks through them; ADVANCE self-loops to the next step, COMPLETE/REJECT/ESCALATE terminate. Topology = loading / running / approved / rejected / escalated / error — the running state owns N via data, not states.",
  "orbitals": [
    {
      "name": "StepFlowOrbital",
      "entity": {
        "name": "StepFlowView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "steps",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "name": "description",
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "type": "string"
                },
                "number": {
                  "name": "number",
                  "type": "number"
                },
                "status": {
                  "name": "status",
                  "type": "string",
                  "values": [
                    "pending",
                    "current",
                    "approved"
                  ]
                }
              }
            }
          },
          {
            "name": "currentStepIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "finalStatus",
            "type": "string",
            "default": "",
            "values": [
              "approved",
              "rejected",
              "escalated",
              ""
            ]
          },
          {
            "name": "rejectionReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "StepFlowReview",
          "category": "interaction",
          "linkedEntity": "StepFlowView",
          "emits": [
            {
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "stepKey",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESTART",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StepItemsLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "StepItemsLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "approved"
              },
              {
                "name": "rejected"
              },
              {
                "name": "escalated"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StepItemsLoaded",
                "name": "Step items loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "StepItemsLoadFailed",
                "name": "Step items load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StepItemsSaved",
                "name": "Step items saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "StepItemsSaveFailed",
                "name": "Step items save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "stepKey",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "failure": "StepItemsLoadFailed",
                        "success": "StepItemsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading review…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "StepItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    [
                      "array/len",
                      "@config.steps"
                    ]
                  ],
                  [
                    "set",
                    "@entity.steps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "user"
                          ],
                          "number": 1.0,
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "status": "current"
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "shield-check",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": [],
                          "entity": "@entity.steps",
                          "type": "data-list",
                          "renderItem": [
                            "fn",
                            "step",
                            {
                              "type": "card",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@step.icon"
                                    },
                                    {
                                      "gap": "xs",
                                      "type": "stack",
                                      "direction": "vertical",
                                      "children": [
                                        {
                                          "content": "@step.label",
                                          "type": "typography",
                                          "variant": "h4"
                                        },
                                        {
                                          "variant": "caption",
                                          "content": "@step.description",
                                          "type": "typography",
                                          "color": "muted"
                                        }
                                      ]
                                    },
                                    {
                                      "variant": "primary",
                                      "type": "badge",
                                      "label": "@step.status"
                                    }
                                  ],
                                  "align": "center",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "action": "ADVANCE",
                              "variant": "primary",
                              "type": "button",
                              "label": "Approve Step",
                              "icon": "check"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Finalize Approval",
                              "action": "COMPLETE",
                              "type": "button",
                              "variant": "success"
                            },
                            {
                              "label": "Reject",
                              "variant": "danger",
                              "type": "button",
                              "action": "REJECT",
                              "icon": "x"
                            },
                            {
                              "variant": "secondary",
                              "type": "button",
                              "action": "ESCALATE",
                              "icon": "alert-triangle",
                              "label": "Escalate"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StepItemsLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Failed to load",
                      "type": "error-state",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "StepItemsSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Refreshing…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StepItemsSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Save failed",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "ADVANCE",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "+",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.steps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "user"
                          ],
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "number": 1.0,
                          "status": "current",
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "shield-check",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-list",
                          "gap": "sm",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "step",
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "@step.icon",
                                      "type": "icon"
                                    },
                                    {
                                      "gap": "xs",
                                      "direction": "vertical",
                                      "children": [
                                        {
                                          "variant": "h4",
                                          "type": "typography",
                                          "content": "@step.label"
                                        },
                                        {
                                          "type": "typography",
                                          "color": "muted",
                                          "content": "@step.description",
                                          "variant": "caption"
                                        }
                                      ],
                                      "type": "stack"
                                    },
                                    {
                                      "variant": "primary",
                                      "label": "@step.status",
                                      "type": "badge"
                                    }
                                  ],
                                  "gap": "sm"
                                }
                              ]
                            }
                          ],
                          "entity": "@entity.steps"
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "icon": "check",
                              "label": "Approve Step",
                              "action": "ADVANCE"
                            },
                            {
                              "label": "Finalize Approval",
                              "icon": "check-circle",
                              "action": "COMPLETE",
                              "type": "button",
                              "variant": "success"
                            },
                            {
                              "icon": "x",
                              "variant": "danger",
                              "type": "button",
                              "action": "REJECT",
                              "label": "Reject"
                            },
                            {
                              "icon": "alert-triangle",
                              "variant": "secondary",
                              "label": "Escalate",
                              "action": "ESCALATE",
                              "type": "button"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "approved",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "approved"
                  ],
                  [
                    "set",
                    "@entity.steps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "user"
                          ],
                          "status": "approved",
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "number": 1.0
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Approved"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-list",
                          "entity": "@entity.steps",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "step",
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "name": "@step.icon",
                                      "type": "icon"
                                    },
                                    {
                                      "direction": "vertical",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "content": "@step.label",
                                          "variant": "h4",
                                          "type": "typography"
                                        },
                                        {
                                          "color": "muted",
                                          "content": "@step.description",
                                          "type": "typography",
                                          "variant": "caption"
                                        }
                                      ],
                                      "gap": "xs"
                                    },
                                    {
                                      "type": "badge",
                                      "variant": "success",
                                      "label": "@step.status"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center"
                                }
                              ],
                              "type": "card"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "variant": "secondary",
                          "action": "RESTART",
                          "type": "button",
                          "label": "Restart",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "rejected",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "rejected"
                  ],
                  [
                    "set",
                    "@entity.rejectionReason",
                    "@payload.reason"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "x-circle",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Rejected"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Reason"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.rejectionReason",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "action": "RESTART",
                          "type": "button",
                          "label": "Restart",
                          "variant": "secondary",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "escalated",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "escalated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "Escalated",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "content": "This item has been escalated for further review.",
                          "type": "typography"
                        },
                        {
                          "variant": "secondary",
                          "label": "Restart",
                          "action": "RESTART",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "approved",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "rejected",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.rejectionReason",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "escalated",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "steps": {
              "type": "[object]",
              "default": [
                {
                  "label": "Manager Review",
                  "description": "Initial review by direct manager",
                  "key": "manager",
                  "icon": "user"
                },
                {
                  "label": "Director Approval",
                  "description": "Department director sign-off",
                  "icon": "users",
                  "key": "director"
                },
                {
                  "key": "executive",
                  "label": "Executive Sign-off",
                  "description": "Final executive approval",
                  "icon": "shield"
