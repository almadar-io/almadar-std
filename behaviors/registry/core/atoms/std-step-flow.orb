{
  "name": "std-step-flow",
  "version": "3.1.0",
  "description": "std-step-flow — generic N-step sequential decision chain (Stripe Connect / TurboTax / Vercel deploy style). `config.steps` is an array of step definitions; the trait projects the current step into a prominent body card and a `wizard-progress` stepper bar at the top. One primary button ADVANCEs along the chain; at the last step the same button finalizes (label/icon/variant swap via entity binding, state routed via guard). REJECT/ESCALATE terminate. Topology = loading / running / approved / rejected / escalated / error.",
  "orbitals": [
    {
      "name": "StepFlowOrbital",
      "entity": {
        "name": "StepFlowView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "wizardSteps",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "name": "id",
                  "type": "string"
                },
                "title": {
                  "name": "title",
                  "type": "string"
                },
                "description": {
                  "name": "description",
                  "type": "string"
                }
              }
            }
          },
          {
            "name": "currentStepIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "currentStepLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepIcon",
            "type": "string",
            "default": "user"
          },
          {
            "name": "isFirstStep",
            "type": "boolean",
            "default": true
          },
          {
            "name": "isLastStep",
            "type": "boolean",
            "default": false
          },
          {
            "name": "primaryActionLabel",
            "type": "string",
            "default": "Approve & Continue"
          },
          {
            "name": "primaryActionVariant",
            "type": "string",
            "default": "primary"
          },
          {
            "name": "primaryActionIcon",
            "type": "string",
            "default": "chevron-right"
          },
          {
            "name": "finalStatus",
            "type": "string",
            "default": "",
            "values": [
              "approved",
              "rejected",
              "escalated",
              ""
            ]
          },
          {
            "name": "rejectionReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "StepFlowReview",
          "category": "interaction",
          "linkedEntity": "StepFlowView",
          "emits": [
            {
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "stepKey",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BACK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESTART",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StepItemsLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "StepItemsLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "approved"
              },
              {
                "name": "rejected"
              },
              {
                "name": "escalated"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StepItemsLoaded",
                "name": "Step items loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "StepItemsLoadFailed",
                "name": "Step items load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StepItemsSaved",
                "name": "Step items saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "StepItemsSaveFailed",
                "name": "Step items save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "stepKey",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BACK",
                "name": "Back",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "failure": "StepItemsLoadFailed",
                        "success": "StepItemsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading review…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "StepItemsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    [
                      "array/len",
                      "@config.steps"
                    ]
                  ],
                  [
                    "set",
                    "@entity.wizardSteps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "id": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "title": [
                            "object/get",
                            "@step",
                            "label"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    true
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      [
                        "array/len",
                        "@config.steps"
                      ],
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "Finalize Approval",
                      "Approve & Continue"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionVariant",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "success",
                      "primary"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "shield-check"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStepIndex",
                          "steps": "@entity.wizardSteps",
                          "allowNavigation": false
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@entity.currentStepIcon",
                                      "size": "lg"
                                    },
                                    {
                                      "children": [
                                        {
                                          "type": "typography",
                                          "content": "@entity.currentStepLabel",
                                          "variant": "h2"
                                        },
                                        {
                                          "type": "typography",
                                          "color": "muted",
                                          "content": "@entity.currentStepDescription",
                                          "variant": "body"
                                        }
                                      ],
                                      "type": "stack",
                                      "direction": "vertical",
                                      "gap": "xs"
                                    }
                                  ]
                                }
                              ],
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "action": "BACK",
                              "icon": "chevron-left",
                              "disabled": "@entity.isFirstStep",
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "action": "REJECT",
                              "variant": "ghost",
                              "label": "Reject",
                              "icon": "x"
                            },
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Escalate",
                              "action": "ESCALATE",
                              "icon": "alert-triangle"
                            },
                            {
                              "type": "button",
                              "label": "@entity.primaryActionLabel",
                              "variant": "@entity.primaryActionVariant",
                              "action": "ADVANCE",
                              "icon": "@entity.primaryActionIcon"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StepItemsLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Failed to load",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "StepItemsSaved"
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StepItemsSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Save failed",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "ADVANCE",
                "guard": [
                  "not",
                  "@entity.isLastStep"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "+",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      [
                        "-",
                        "@entity.totalSteps",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "Finalize Approval",
                      "Approve & Continue"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionVariant",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "success",
                      "primary"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "shield-check",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStepIndex",
                          "allowNavigation": false,
                          "steps": "@entity.wizardSteps"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@entity.currentStepIcon",
                                      "size": "lg"
                                    },
                                    {
                                      "gap": "xs",
                                      "children": [
                                        {
                                          "content": "@entity.currentStepLabel",
                                          "variant": "h2",
                                          "type": "typography"
                                        },
                                        {
                                          "content": "@entity.currentStepDescription",
                                          "variant": "body",
                                          "color": "muted",
                                          "type": "typography"
                                        }
                                      ],
                                      "direction": "vertical",
                                      "type": "stack"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center"
                                }
                              ],
                              "gap": "md",
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "icon": "chevron-left",
                              "disabled": "@entity.isFirstStep",
                              "variant": "ghost",
                              "type": "button",
                              "action": "BACK"
                            },
                            {
                              "action": "REJECT",
                              "type": "button",
                              "icon": "x",
                              "label": "Reject",
                              "variant": "ghost"
                            },
                            {
                              "icon": "alert-triangle",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Escalate",
                              "action": "ESCALATE"
                            },
                            {
                              "type": "button",
                              "variant": "@entity.primaryActionVariant",
                              "label": "@entity.primaryActionLabel",
                              "icon": "@entity.primaryActionIcon",
                              "action": "ADVANCE"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "approved",
                "event": "ADVANCE",
                "guard": "@entity.isLastStep",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "approved"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "align": "center",
                          "variant": "h2",
                          "type": "typography",
                          "content": "Approved"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "All review steps completed successfully.",
                          "align": "center"
                        },
                        {
                          "type": "wizard-progress",
                          "allowNavigation": false,
                          "steps": "@entity.wizardSteps",
                          "currentStep": "@entity.totalSteps"
                        },
                        {
                          "action": "RESTART",
                          "label": "Start a new review",
                          "icon": "rotate-ccw",
                          "variant": "secondary",
                          "type": "button"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "BACK",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "-",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "icon",
                      "user"
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      [
                        "-",
                        "@entity.totalSteps",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "Finalize Approval",
                      "Approve & Continue"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionVariant",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "success",
                      "primary"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "shield-check"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "steps": "@entity.wizardSteps",
                          "currentStep": "@entity.currentStepIndex",
                          "allowNavigation": false,
                          "type": "wizard-progress"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@entity.currentStepIcon",
                                      "size": "lg"
                                    },
                                    {
                                      "direction": "vertical",
                                      "type": "stack",
                                      "gap": "xs",
                                      "children": [
                                        {
                                          "variant": "h2",
                                          "type": "typography",
                                          "content": "@entity.currentStepLabel"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "@entity.currentStepDescription",
                                          "color": "muted",
                                          "variant": "body"
                                        }
                                      ]
                                    }
                                  ],
                                  "align": "center",
                                  "direction": "horizontal",
                                  "gap": "sm"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "variant": "ghost",
                              "label": "Back",
                              "type": "button",
                              "action": "BACK",
                              "icon": "chevron-left",
                              "disabled": "@entity.isFirstStep"
                            },
                            {
                              "action": "REJECT",
                              "icon": "x",
                              "type": "button",
                              "label": "Reject",
                              "variant": "ghost"
                            },
                            {
                              "action": "ESCALATE",
                              "icon": "alert-triangle",
                              "type": "button",
                              "label": "Escalate",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "label": "@entity.primaryActionLabel",
                              "variant": "@entity.primaryActionVariant",
                              "action": "ADVANCE",
                              "icon": "@entity.primaryActionIcon"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "rejected",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "rejected"
                  ],
                  [
                    "set",
                    "@entity.rejectionReason",
                    "@payload.reason"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon",
                          "size": "lg"
                        },
                        {
                          "variant": "h2",
                          "content": "Rejected",
                          "type": "typography",
                          "align": "center"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Reason",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.rejectionReason",
                                  "variant": "body"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "variant": "secondary",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Start a new review",
                          "action": "RESTART"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "escalated",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    "escalated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "align": "center",
                          "type": "typography",
                          "content": "Escalated"
                        },
                        {
                          "variant": "body",
                          "content": "This item has been escalated for further review.",
                          "type": "typography",
                          "color": "muted",
                          "align": "center"
                        },
                        {
                          "action": "RESTART",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "secondary",
                          "label": "Start a new review"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "approved",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "success": "StepItemsLoaded",
                        "failure": "StepItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "rejected",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.rejectionReason",
                    ""
                  ],
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "success": "StepItemsLoaded",
                        "failure": "StepItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "escalated",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.finalStatus",
                    ""
                  ],
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "fetch",
                    "StepFlowView",
                    {
                      "emit": {
                        "success": "StepItemsLoaded",
                        "failure": "StepItemsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Review"
            },
            "steps": {
              "type": "[object]",
              "default": [
                {
                  "label": "Manager Review",
                  "icon": "user",
                  "key": "manager",
                  "description": "Initial review by direct manager"
                },
                {
                  "icon": "users",
                  "label": "Director Approval",
                  "key": "director",
                  "description": "Department director sign-off"
                },
                {
                  "icon": "shield",
                  "key": "executive",
                  "label": "Executive Sign-off",
                  "description": "Final executive approval"
                }
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StepFlowPage",
          "path": "/step-flow",
          "traits": [
            {
              "ref": "StepFlowReview"
            }
          ]
        }
      ]
    }
  ]
}
