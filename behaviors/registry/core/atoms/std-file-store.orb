{
  "name": "std-file-store",
  "version": "1.0.0",
  "description": "std-file-store — generic file + folder + metadata primitive consumed by document-mgmt, legal-case, and any organism that needs a file store. Fetches StoredFile rows on INIT and renders them in a data-grid with per-row Download/Archive actions.",
  "orbitals": [
    {
      "name": "StoredFileOrbital",
      "entity": {
        "name": "StoredFile",
        "collection": "storedfiles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "path",
            "type": "string",
            "default": ""
          },
          {
            "name": "mimeType",
            "type": "string",
            "default": ""
          },
          {
            "name": "sizeBytes",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "uploaderId",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploaderName",
            "type": "string",
            "default": ""
          },
          {
            "name": "folder",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploadedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isArchived",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "StoredFileStore",
          "category": "interaction",
          "linkedEntity": "StoredFile",
          "emits": [
            {
              "event": "DOWNLOAD_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ARCHIVE_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "StoredFileLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StoredFile]"
                }
              ]
            },
            {
              "event": "StoredFileLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StoredFileLoaded",
                "name": "StoredFile loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StoredFile]"
                  }
                ]
              },
              {
                "key": "StoredFileLoadFailed",
                "name": "StoredFile load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DOWNLOAD_FILE",
                "name": "Download File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARCHIVE_FILE",
                "name": "Archive File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading files…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StoredFileLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "content": "@config.title",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "items": [
                            {
                              "href": "/",
                              "label": "Workspace"
                            },
                            {
                              "href": "/files",
                              "label": "Files"
                            },
                            {
                              "label": "All Documents"
                            }
                          ],
                          "type": "doc-breadcrumb"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "file-tree",
                              "tree": [
                                {
                                  "path": "Contracts",
                                  "name": "Contracts",
                                  "type": "dir",
                                  "children": [
                                    {
                                      "name": "Active.pdf",
                                      "path": "Active.pdf",
                                      "type": "file"
                                    },
                                    {
                                      "path": "Archived.pdf",
                                      "name": "Archived.pdf",
                                      "type": "file"
                                    }
                                  ]
                                },
                                {
                                  "type": "dir",
                                  "name": "Policies",
                                  "children": [
                                    {
                                      "type": "file",
                                      "name": "HR.docx",
                                      "path": "Policies/HR.docx"
                                    },
                                    {
                                      "name": "Security.md",
                                      "type": "file",
                                      "path": "Policies/Security.md"
                                    }
                                  ],
                                  "path": "Policies"
                                },
                                {
                                  "type": "dir",
                                  "path": "Templates",
                                  "name": "Templates",
                                  "children": [
                                    {
                                      "name": "Invoice.docx",
                                      "type": "file",
                                      "path": "Templates/Invoice.docx"
                                    },
                                    {
                                      "path": "Templates/NDA.pdf",
                                      "name": "NDA.pdf",
                                      "type": "file"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "description": "or click to browse",
                                  "label": "Drop files here",
                                  "icon": "upload",
                                  "type": "upload-drop-zone",
                                  "maxSize": 10485760.0,
                                  "maxFiles": 5.0,
                                  "accept": "*/*"
                                },
                                {
                                  "type": "accordion",
                                  "items": [
                                    {
                                      "id": "recent",
                                      "content": "Files uploaded in the last 7 days.",
                                      "title": "Recent Uploads"
                                    },
                                    {
                                      "content": "Files shared by collaborators.",
                                      "id": "shared",
                                      "title": "Shared With Me"
                                    },
                                    {
                                      "title": "Starred",
                                      "content": "Files you have flagged for quick access.",
                                      "id": "starred"
                                    }
                                  ]
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "type": "tag-cloud",
                          "tags": [
                            {
                              "label": "Contracts"
                            },
                            {
                              "label": "Policies"
                            },
                            {
                              "label": "Templates"
                            },
                            {
                              "label": "Archive"
                            },
                            {
                              "label": "Drafts"
                            },
                            {
                              "label": "Public"
                            }
                          ],
                          "variant": "primary"
                        },
                        {
                          "fields": [
                            {
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "name": "folder",
                              "label": "Folder"
                            },
                            {
                              "name": "mimeType",
                              "label": "Type"
                            },
                            {
                              "name": "sizeBytes",
                              "label": "Size"
                            },
                            {
                              "name": "uploadedAt",
                              "label": "Uploaded"
                            }
                          ],
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "event": "DOWNLOAD_FILE",
                              "label": "Download",
                              "variant": "primary"
                            },
                            {
                              "label": "Archive",
                              "event": "ARCHIVE_FILE",
                              "variant": "danger"
                            }
                          ],
                          "entity": "@payload.data"
                        },
                        {
                          "showPageSize": false,
                          "currentPage": 1.0,
                          "showTotal": true,
                          "totalPages": 8.0,
                          "totalItems": 80.0,
                          "type": "pagination"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StoredFileLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DOWNLOAD_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Download requested"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ARCHIVE_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Archive requested"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading files…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Files"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "StoredFilePage",
          "path": "/files",
          "traits": [
            {
              "ref": "StoredFileStore"
            }
          ]
        }
      ]
    }
  ]
}
