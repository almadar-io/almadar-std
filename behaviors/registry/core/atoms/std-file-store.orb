{
  "name": "std-file-store",
  "version": "1.0.0",
  "description": "std-file-store — generic file + folder + metadata primitive consumed by document-mgmt, legal-case, and any organism that needs a file store. Fetches StoredFile rows on INIT and renders them in a data-grid with per-row Download/Archive actions.",
  "orbitals": [
    {
      "name": "StoredFileOrbital",
      "entity": {
        "name": "StoredFile",
        "collection": "storedfiles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "path",
            "type": "string",
            "default": ""
          },
          {
            "name": "mimeType",
            "type": "string",
            "default": ""
          },
          {
            "name": "sizeBytes",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "uploaderId",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploaderName",
            "type": "string",
            "default": ""
          },
          {
            "name": "folder",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploadedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isArchived",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "StoredFileStore",
          "category": "interaction",
          "linkedEntity": "StoredFile",
          "emits": [
            {
              "event": "DOWNLOAD_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ARCHIVE_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "StoredFileLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StoredFile]"
                }
              ]
            },
            {
              "event": "StoredFileLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StoredFileLoaded",
                "name": "StoredFile loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StoredFile]"
                  }
                ]
              },
              {
                "key": "StoredFileLoadFailed",
                "name": "StoredFile load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DOWNLOAD_FILE",
                "name": "Download File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARCHIVE_FILE",
                "name": "Archive File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading files…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StoredFileLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "name": "folder",
                              "label": "Folder"
                            },
                            {
                              "name": "mimeType",
                              "label": "Type"
                            },
                            {
                              "name": "sizeBytes",
                              "label": "Size"
                            },
                            {
                              "name": "uploadedAt",
                              "label": "Uploaded"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Download",
                              "event": "DOWNLOAD_FILE"
                            },
                            {
                              "event": "ARCHIVE_FILE",
                              "variant": "danger",
                              "label": "Archive"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StoredFileLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DOWNLOAD_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Download requested"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ARCHIVE_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Archive requested",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "success": "StoredFileLoaded",
                        "failure": "StoredFileLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading files…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Files"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "StoredFilePage",
          "path": "/files",
          "traits": [
            {
              "ref": "StoredFileStore"
            }
          ]
        }
      ]
    }
  ]
}
