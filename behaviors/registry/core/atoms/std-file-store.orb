{
  "name": "std-file-store",
  "version": "1.0.0",
  "description": "std-file-store — generic file + folder + metadata primitive. Browses files via file-tree + data-grid; opens file detail in `viewing_single` with Download / Archive actions.",
  "orbitals": [
    {
      "name": "StoredFileOrbital",
      "entity": {
        "name": "StoredFile",
        "collection": "storedfiles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "path",
            "type": "string",
            "default": ""
          },
          {
            "name": "mimeType",
            "type": "string",
            "default": ""
          },
          {
            "name": "sizeBytes",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "uploaderId",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploaderName",
            "type": "string",
            "default": ""
          },
          {
            "name": "folder",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploadedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isArchived",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "StoredFileStore",
          "category": "interaction",
          "linkedEntity": "StoredFile",
          "emits": [
            {
              "event": "OPEN_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.path",
                  "type": "string"
                },
                {
                  "name": "row.mimeType",
                  "type": "string"
                },
                {
                  "name": "row.sizeBytes",
                  "type": "number"
                },
                {
                  "name": "row.uploaderId",
                  "type": "string"
                },
                {
                  "name": "row.uploaderName",
                  "type": "string"
                },
                {
                  "name": "row.folder",
                  "type": "string"
                },
                {
                  "name": "row.uploadedAt",
                  "type": "string"
                },
                {
                  "name": "row.isArchived",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "DOWNLOAD_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ARCHIVE_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "StoredFileLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StoredFile]"
                }
              ]
            },
            {
              "event": "StoredFileLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StoredFileLoaded",
                "name": "StoredFile loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StoredFile]"
                  }
                ]
              },
              {
                "key": "StoredFileLoadFailed",
                "name": "StoredFile load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_FILE",
                "name": "Open File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "StoredFile"
                  }
                ]
              },
              {
                "key": "ARCHIVE_FILE",
                "name": "Archive File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "DOWNLOAD_FILE",
                "name": "Download File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "success": "StoredFileLoaded",
                        "failure": "StoredFileLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading files…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StoredFileLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "folder"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total files",
                              "value": "@payload.data.length",
                              "icon": "file"
                            },
                            {
                              "label": "Folders",
                              "type": "stat-display",
                              "value": "12",
                              "icon": "folder"
                            },
                            {
                              "label": "Uploaded this week",
                              "icon": "upload",
                              "value": "18",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "archive",
                              "label": "Archived",
                              "value": "4"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "tree": [
                            {
                              "name": "Contracts",
                              "type": "dir",
                              "children": [
                                {
                                  "path": "Active.pdf",
                                  "type": "file",
                                  "name": "Active.pdf"
                                },
                                {
                                  "path": "Archived.pdf",
                                  "name": "Archived.pdf",
                                  "type": "file"
                                }
                              ],
                              "path": "Contracts"
                            },
                            {
                              "name": "Policies",
                              "children": [
                                {
                                  "name": "HR.docx",
                                  "type": "file",
                                  "path": "Policies/HR.docx"
                                },
                                {
                                  "type": "file",
                                  "name": "Security.md",
                                  "path": "Policies/Security.md"
                                }
                              ],
                              "path": "Policies",
                              "type": "dir"
                            },
                            {
                              "path": "Templates",
                              "children": [
                                {
                                  "path": "Templates/Invoice.docx",
                                  "name": "Invoice.docx",
                                  "type": "file"
                                },
                                {
                                  "path": "Templates/NDA.pdf",
                                  "type": "file",
                                  "name": "NDA.pdf"
                                }
                              ],
                              "name": "Templates",
                              "type": "dir"
                            }
                          ],
                          "type": "file-tree"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "OPEN_FILE",
                              "variant": "primary",
                              "icon": "arrow-right",
                              "label": "Open"
                            },
                            {
                              "label": "Archive",
                              "event": "ARCHIVE_FILE",
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "name",
                              "variant": "caption",
                              "label": "Name"
                            },
                            {
                              "name": "folder",
                              "label": "Folder",
                              "variant": "caption"
                            },
                            {
                              "name": "mimeType",
                              "variant": "badge",
                              "label": "Type"
                            },
                            {
                              "variant": "caption",
                              "label": "Size",
                              "name": "sizeBytes"
                            },
                            {
                              "name": "uploadedAt",
                              "variant": "caption",
                              "label": "Uploaded"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StoredFileLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.path",
                    "@payload.row.path"
                  ],
                  [
                    "set",
                    "@entity.mimeType",
                    "@payload.row.mimeType"
                  ],
                  [
                    "set",
                    "@entity.sizeBytes",
                    "@payload.row.sizeBytes"
                  ],
                  [
                    "set",
                    "@entity.uploaderId",
                    "@payload.row.uploaderId"
                  ],
                  [
                    "set",
                    "@entity.uploaderName",
                    "@payload.row.uploaderName"
                  ],
                  [
                    "set",
                    "@entity.folder",
                    "@payload.row.folder"
                  ],
                  [
                    "set",
                    "@entity.uploadedAt",
                    "@payload.row.uploadedAt"
                  ],
                  [
                    "set",
                    "@entity.isArchived",
                    "@payload.row.isArchived"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "name": "file",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.mimeType",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Folder",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.folder",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Path",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.path"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Uploader"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.uploaderName"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "label": "Size",
                              "value": "@entity.sizeBytes",
                              "icon": "hard-drive",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.mimeType",
                              "type": "stat-display",
                              "icon": "file",
                              "label": "Type"
                            },
                            {
                              "label": "Uploaded",
                              "value": "@entity.uploadedAt",
                              "type": "stat-display",
                              "icon": "calendar"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Download",
                              "action": "DOWNLOAD_FILE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "action": "ARCHIVE_FILE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Archive",
                              "variant": "danger"
                            }
                          ],
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ARCHIVE_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "success": "StoredFileLoaded",
                        "failure": "StoredFileLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Archiving file…"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading files…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DOWNLOAD_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Preparing download…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "success": "StoredFileLoaded",
                        "failure": "StoredFileLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Archiving file…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Files",
              "label": "Section title",
              "description": "Heading shown above the file browser"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "StoredFilePage",
          "path": "/files",
          "traits": [
            {
              "ref": "StoredFileStore"
            }
          ]
        }
      ]
    }
  ]
}