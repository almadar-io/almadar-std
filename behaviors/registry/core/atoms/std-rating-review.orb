                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "MARK_HELPFUL",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Recording…"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "RATE_DRAFT",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    "@payload.rating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CANCEL_REVIEW",
                              "icon": "arrow-left"
                            },
                            {
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Write a review"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "look": "@config.cardLook",
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "@config.subjectTitle",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "How would you rate it?",
                                  "variant": "h4"
                                },
                                {
                                  "value": "@entity.draftRating",
                                  "max": 5.0,
                                  "action": "RATE_DRAFT",
                                  "type": "star-rating"
                                },
                                {
                                  "type": "typography",
                                  "content": "Share more details (optional)",
                                  "variant": "h4"
                                },
                                {
                                  "fields": "@config.reviewFields",
                                  "entity": "@entity",
                                  "mode": "edit",
                                  "submitEvent": "SUBMIT_REVIEW",
                                  "type": "form-section",
                                  "submitLabel": "@config.submitLabel",
                                  "cancelEvent": "CANCEL_REVIEW"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "submitting",
                "event": "SUBMIT_REVIEW",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ReviewView",
                    {
                      "rating": "@entity.draftRating",
                      "comment": "@entity.draftComment"
                    },
                    {
                      "emit": {
                        "success": "ReviewSaved",
                        "failure": "ReviewSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "send"
                        },
                        {
                          "content": "Submitting your review…",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "viewing",
                "event": "CANCEL_REVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.draftComment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Returning…"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "ReviewSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "check-circle",
                          "size": "lg",
                          "type": "icon"
                        },
                        {
                          "align": "center",
                          "type": "typography",
                          "variant": "h2",
                          "content": "Thanks for your review!"
                        },
                        {
                          "type": "typography",
                          "content": "It will appear on the page shortly.",
                          "align": "center",
                          "color": "muted",
                          "variant": "body"
                        },
                        {
                          "variant": "primary",
                          "label": "Back to reviews",
                          "action": "RESTART",
                          "icon": "arrow-left",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "error",
                "event": "ReviewSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "message": "@entity.errorMessage",
                      "title": "Submit failed"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "fetch",
                    "ReviewView",
                    {
                      "emit": {
                        "success": "ReviewsLoaded",
                        "failure": "ReviewsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing reviews…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReviewView",
                    {
                      "emit": {
                        "failure": "ReviewsLoadFailed",
                        "success": "ReviewsLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "writeLabel": {
              "type": "string",
              "default": "Write a review",
              "label": "Write CTA",
              "description": "Label on the call-to-action that opens the compose form",
              "tier": "presentation"
            },
            "submitLabel": {
              "type": "string",
              "default": "Submit review",
              "label": "Submit button",
              "description": "Label on the primary submit-review button",
              "tier": "presentation"
            },
            "sortOptions": {
              "type": "[SortOption]",
              "default": [
                {
                  "label": "Most recent",
                  "icon": "clock",
                  "id": "recent"
                },
                {
                  "label": "Top rated",
                  "icon": "star",
                  "id": "highest"
                },
                {
                  "label": "Lowest",
                  "id": "lowest",
                  "icon": "trending-down"
                }
              ],
              "label": "Sort tabs",
              "description": "Sort modes shown as tabs above the reviews list",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "starDistribution": {
              "type": "[StarBucket]",
              "default": [
                {
                  "percentage": 74.0,
                  "label": "5 stars"
                },
                {
                  "label": "4 stars",
                  "percentage": 18.0
                },
                {
                  "label": "3 stars",
                  "percentage": 5.0
                },
                {
                  "percentage": 2.0,
                  "label": "2 stars"
                },
                {
                  "percentage": 1.0,
                  "label": "1 star"
                }
              ],
              "label": "Star bars",
              "description": "Per-star distribution displayed as horizontal progress bars",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "percentage": {
                    "name": "percentage",
                    "type": "number",
                    "required": true
                  }
                }
              }
            },
            "subjectTitle": {
              "type": "string",
              "default": "Bali Sunset Villa · 3 nights",
              "label": "Subject title",
              "description": "Name of the item being reviewed (shown in the header)",
              "tier": "presentation"
            },
            "reviewFields": {
              "type": "[string]",
              "default": [
                "draftComment"
              ],
              "label": "Review form fields",
              "description": "Inputs shown in the review compose form",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "cancelLabel": {
              "type": "string",
              "default": "Cancel",
              "label": "Cancel button",
              "description": "Label on the cancel button inside the compose form",
              "tier": "presentation"
            },
            "cardLook": {
              "type": "string",
              "default": "elevated",
              "label": "Card look",
              "description": "Layer 2 visual treatment for cards rendered by this atom.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat-bordered",
                "borderless-divider",
                "ticket",
                "invoice",
                "chip",
                "tile-image-first"
              ]
            }
          },
          "scope": "instance"
        },
        {
          "name": "RatingReviewSubmit",
          "category": "interaction",
          "linkedEntity": "ReviewView",
          "emits": [
            {
              "event": "RATE_DRAFT",
              "payloadSchema": [
                {
                  "name": "rating",
                  "type": "number"
                }
              ]
            },
            {
              "event": "SUBMIT_REVIEW",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CANCEL_REVIEW"
            },
            {
              "event": "RESTART"
            },
            {
              "event": "ReviewSaved",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ReviewSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RATE_DRAFT",
                "name": "Rate Draft",
                "payloadSchema": [
                  {
                    "name": "rating",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "SUBMIT_REVIEW",
                "name": "Submit Review",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL_REVIEW",
                "name": "Cancel Review"
              },
              {
                "key": "ReviewSaved",
                "name": "Review saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ReviewSaveFailed",
                "name": "Review save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.draftComment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            },
                            {
                              "max": "@config.maxStars",
                              "value": "@entity.draftRating",
                              "type": "star-rating",
                              "action": "RATE_DRAFT"
                            },
                            {
                              "fields": [
                                "draftComment"
                              ],
                              "mode": "edit",
                              "cancelEvent": "CANCEL_REVIEW",
                              "submitLabel": "@config.submitLabel",
                              "type": "form-section",
                              "submitEvent": "SUBMIT_REVIEW",
                              "entity": "@entity"
                            }
                          ]
                        }
                      ],
                      "type": "card",
                      "look": "@config.cardLook"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "RATE_DRAFT",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    "@payload.rating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "look": "@config.cardLook",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            },
                            {
                              "value": "@entity.draftRating",
                              "type": "star-rating",
                              "action": "RATE_DRAFT",
                              "max": "@config.maxStars"
                            },
                            {
                              "type": "form-section",
                              "entity": "@entity",
                              "mode": "edit",
                              "cancelEvent": "CANCEL_REVIEW",
                              "submitEvent": "SUBMIT_REVIEW",
                              "submitLabel": "@config.submitLabel",
                              "fields": [
                                "draftComment"
                              ]
                            }
                          ]
                        }
                      ],
                      "type": "card"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "submitting",
                "event": "SUBMIT_REVIEW",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ReviewView",
                    {
                      "comment": "@entity.draftComment",
                      "rating": "@entity.draftRating"
                    },
                    {
                      "emit": {
                        "failure": "ReviewSaveFailed",
                        "success": "ReviewSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "send",
                          "size": "lg"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Submitting…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CANCEL_REVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.draftComment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "look": "@config.cardLook",
                      "type": "card",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            },
                            {
                              "value": 0.0,
                              "type": "star-rating",
                              "max": "@config.maxStars",
                              "action": "RATE_DRAFT"
                            },
                            {
                              "fields": [
                                "draftComment"
                              ],
                              "mode": "edit",
                              "entity": "@entity",
                              "type": "form-section",
                              "submitEvent": "SUBMIT_REVIEW",
                              "cancelEvent": "CANCEL_REVIEW",
                              "submitLabel": "@config.submitLabel"
                            }
                          ],
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "ReviewSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "content": "Thanks for your review!",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "error",
                "event": "ReviewSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Submit failed",
                      "type": "error-state",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "composing",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.draftComment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "look": "@config.cardLook",
                      "type": "card",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "value": 0.0,
                              "action": "RATE_DRAFT",
                              "max": "@config.maxStars",
                              "type": "star-rating"
                            },
                            {
                              "type": "form-section",
                              "submitEvent": "SUBMIT_REVIEW",
                              "cancelEvent": "CANCEL_REVIEW",
                              "entity": "@entity",
                              "mode": "edit",
                              "submitLabel": "@config.submitLabel",
                              "fields": [
                                "draftComment"
                              ]
                            }
                          ],
                          "direction": "vertical"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "composing",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            },
                            {
                              "action": "RATE_DRAFT",
                              "value": 0.0,
                              "max": "@config.maxStars",
                              "type": "star-rating"
                            },
                            {
                              "submitLabel": "@config.submitLabel",
                              "fields": [
                                "draftComment"
                              ],
                              "cancelEvent": "CANCEL_REVIEW",
                              "type": "form-section",
                              "entity": "@entity",
                              "submitEvent": "SUBMIT_REVIEW",
                              "mode": "edit"
                            }
                          ]
                        }
                      ],
                      "type": "card",
                      "look": "@config.cardLook"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "submitEvent": {
              "type": "string",
              "default": "SUBMIT_REVIEW",
              "label": "Submit event",
              "description": "Event emitted when the user submits the form",
              "tier": "internal"
            },
            "maxStars": {
              "type": "number",
              "default": 5.0,
              "label": "Max stars",
              "description": "Top of the rating scale (typically 5)",
              "tier": "domain"
            },
            "allowPhotos": {
              "type": "boolean",
              "default": false,
              "label": "Allow photos",
              "description": "Let the user attach photos to the review",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Write a review",
              "label": "Form title",
              "description": "Heading shown above the review compose form",
              "tier": "presentation"
            },
            "allowComment": {
              "type": "boolean",
              "default": true,
              "label": "Allow comment",
              "description": "Show a free-text comment field below the stars",
              "tier": "presentation"
            },
            "cancelLabel": {
              "type": "string",
              "default": "Cancel",
              "label": "Cancel button",
              "description": "Label on the cancel button",
              "tier": "presentation"
            },
            "submitLabel": {
              "type": "string",
              "default": "Submit review",
              "label": "Submit button",
              "description": "Label on the primary submit button",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RatingReviewPage",
          "path": "/reviews",
          "traits": [
            {
              "ref": "RatingReviewBoard"
            }
          ]
        },
        {
          "name": "RatingReviewSubmitPage",
          "path": "/reviews/new",
          "traits": [
            {
              "ref": "RatingReviewSubmit"
            }
          ]
        }
      ]
    }
  ]
}