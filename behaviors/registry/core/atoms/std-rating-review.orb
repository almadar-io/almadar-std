{
  "name": "std-rating-review",
  "version": "1.0.0",
  "description": "std-rating-review — capture a 1..N star rating with optional comment + photos. Owns a RatingReview entity; SUBMIT persists @payload.data (rating, comment, photos, targetId) and emits RatingReviewSubmitted so cross-trait listeners can react (e.g. recompute aggregate).",
  "orbitals": [
    {
      "name": "RatingReviewOrbital",
      "entity": {
        "name": "RatingReview",
        "collection": "ratingreviews",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "rating",
            "type": "number",
            "required": true
          },
          {
            "name": "comment",
            "type": "string"
          },
          {
            "name": "photos",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "authorId",
            "type": "string"
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RatingReviewSubmit",
          "category": "interaction",
          "linkedEntity": "RatingReview",
          "emits": [
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "RATE",
              "payloadSchema": [
                {
                  "name": "rating",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_COMMENT",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RatingReviewLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RatingReview]"
                }
              ]
            },
            {
              "event": "RatingReviewLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RatingReviewSubmitted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.rating",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.photos",
                  "type": "[string]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RatingReviewSubmitFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RATE",
                "name": "Rate",
                "payloadSchema": [
                  {
                    "name": "rating",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_COMMENT",
                "name": "Edit Comment",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RatingReviewLoaded",
                "name": "RatingReview loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RatingReview]"
                  }
                ]
              },
              {
                "key": "RatingReviewLoadFailed",
                "name": "RatingReview load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RatingReviewSubmitted",
                "name": "RatingReview submitted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "RatingReview"
                  }
                ]
              },
              {
                "key": "RatingReviewSubmitFailed",
                "name": "RatingReview submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RatingReview",
                    {
                      "emit": {
                        "success": "RatingReviewLoaded",
                        "failure": "RatingReviewLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "@config.title",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "max": "@config.maxStars",
                          "action": "RATE",
                          "type": "star-rating",
                          "value": "@entity.rating"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Tell us more (optional)",
                          "action": "EDIT_COMMENT"
                        },
                        {
                          "type": "button",
                          "icon": "send",
                          "action": "SUBMIT",
                          "label": "Submit",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RATE",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    "@payload.rating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "@config.title"
                        },
                        {
                          "type": "star-rating",
                          "max": "@config.maxStars",
                          "value": "@entity.rating",
                          "action": "RATE"
                        },
                        {
                          "type": "textarea",
                          "action": "EDIT_COMMENT",
                          "placeholder": "Tell us more (optional)"
                        },
                        {
                          "variant": "primary",
                          "label": "Submit",
                          "action": "SUBMIT",
                          "icon": "send",
                          "type": "button"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_COMMENT",
                "effects": [
                  [
                    "set",
                    "@entity.comment",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RatingReviewLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "@config.title"
                        },
                        {
                          "value": "@entity.rating",
                          "max": "@config.maxStars",
                          "type": "star-rating",
                          "action": "RATE"
                        },
                        {
                          "placeholder": "Tell us more (optional)",
                          "type": "textarea",
                          "action": "EDIT_COMMENT"
                        },
                        {
                          "icon": "send",
                          "type": "button",
                          "label": "Submit",
                          "action": "SUBMIT",
                          "variant": "primary"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RatingReviewLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
                    "RatingReview",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "RatingReviewSubmitFailed",
                        "success": "RatingReviewSubmitted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Submitting your review…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "RatingReviewSubmitted",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "success",
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h3",
                          "content": "Thanks for your review!",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "idle",
                "event": "RatingReviewSubmitFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.comment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "type": "star-rating",
                          "max": "@config.maxStars",
                          "action": "RATE",
                          "value": "@entity.rating"
                        },
                        {
                          "type": "textarea",
                          "action": "EDIT_COMMENT",
                          "placeholder": "Tell us more (optional)"
                        },
                        {
                          "type": "button",
                          "label": "Submit",
                          "action": "SUBMIT",
                          "variant": "primary",
                          "icon": "send"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "allowPhotos": {
              "type": "boolean",
              "default": false
            },
            "maxStars": {
              "type": "number",
              "default": 5.0
            },
            "allowComment": {
              "type": "boolean",
              "default": true
            },
            "title": {
              "type": "string",
              "default": "Rate this"
            },
            "submitEvent": {
              "type": "string",
              "default": "SUBMIT_REVIEW"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RatingReviewSubmitPage",
          "path": "/ratingreviews/submit",
          "traits": [
            {
              "ref": "RatingReviewSubmit"
            }
          ]
        }
      ]
    }
  ]
}
