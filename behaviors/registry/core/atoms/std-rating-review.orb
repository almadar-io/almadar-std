                                          "type": "typography"
                                        },
                                        {
                                          "type": "typography",
                                          "color": "muted",
                                          "variant": "caption",
                                          "content": "@review.createdAt"
                                        }
                                      ],
                                      "direction": "horizontal"
                                    },
                                    {
                                      "variant": "body",
                                      "type": "typography",
                                      "content": "@review.comment"
                                    },
