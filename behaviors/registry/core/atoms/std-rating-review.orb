{
  "name": "std-rating-review",
  "version": "2.1.1",
  "description": "std-rating-review — Airbnb / Amazon / Google Maps style review surface. Header with aggregate score + Write CTA, per-star distribution bars, working sort chips (recent / top rated / lowest), scrollable reviews list with author + stars + comment + helpful action. Topology = loading / viewing / composing / submitting / submitted / error.",
  "orbitals": [
    {
      "name": "RatingReviewOrbital",
      "entity": {
        "name": "ReviewView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "reviews",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "rating": {
                  "name": "rating",
                  "type": "number",
                  "required": false
                },
                "comment": {
                  "name": "comment",
                  "type": "string",
                  "required": false
                },
                "createdAt": {
                  "name": "createdAt",
                  "type": "string",
                  "required": false
                },
                "helpful": {
                  "name": "helpful",
                  "type": "number",
                  "required": false
                },
                "avatarIcon": {
                  "name": "avatarIcon",
                  "type": "string",
                  "required": false
                },
                "authorName": {
                  "name": "authorName",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          {
            "name": "reviewsSource",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "helpful": {
                  "name": "helpful",
                  "type": "number",
                  "required": false
                },
                "rating": {
                  "name": "rating",
                  "type": "number",
                  "required": false
                },
                "authorName": {
                  "name": "authorName",
                  "type": "string",
                  "required": false
                },
                "createdAt": {
                  "name": "createdAt",
                  "type": "string",
                  "required": false
                },
                "comment": {
                  "name": "comment",
                  "type": "string",
                  "required": false
                },
                "avatarIcon": {
                  "name": "avatarIcon",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          {
            "name": "totalReviews",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "averageRating",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "starDistribution",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "percentage": {
                  "name": "percentage",
                  "type": "number",
                  "required": false
                }
              }
            }
          },
          {
            "name": "currentSort",
            "type": "string",
            "default": "recent",
            "values": [
              "recent",
              "highest",
              "lowest"
            ]
          },
          {
            "name": "draftRating",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "draftComment",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RatingReviewBoard",
          "category": "interaction",
          "linkedEntity": "ReviewView",
          "emits": [
            {
              "event": "WRITE_REVIEW"
            },
            {
              "event": "RATE_DRAFT",
              "payloadSchema": [
                {
                  "name": "rating",
                  "type": "number"
                }
              ]
            },
            {
              "event": "SUBMIT_REVIEW",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CANCEL_REVIEW"
            },
            {
              "event": "CHANGE_SORT",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_HELPFUL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESTART"
            },
            {
              "event": "ReviewsLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "ReviewsLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ReviewSaved",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ReviewSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "composing"
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReviewsLoaded",
                "name": "Reviews loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "ReviewsLoadFailed",
                "name": "Reviews load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ReviewSaved",
                "name": "Review saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ReviewSaveFailed",
                "name": "Review save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "WRITE_REVIEW",
                "name": "Write Review"
              },
              {
                "key": "CHANGE_SORT",
                "name": "Change Sort",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MARK_HELPFUL",
                "name": "Mark Helpful",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RATE_DRAFT",
                "name": "Rate Draft",
                "payloadSchema": [
                  {
                    "name": "rating",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "SUBMIT_REVIEW",
                "name": "Submit Review",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL_REVIEW",
                "name": "Cancel Review"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReviewView",
                    {
                      "emit": {
                        "success": "ReviewsLoaded",
                        "failure": "ReviewsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading reviews…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "ReviewsLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.reviewsSource",
                    [
                      "array/map",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        {
                          "avatarIcon": [
                            "object/get",
                            "@row",
                            "avatarIcon",
                            "user"
                          ],
                          "id": [
                            "object/get",
                            "@row",
                            "id",
                            ""
                          ],
                          "rating": [
                            "object/get",
                            "@row",
                            "rating",
                            5.0
                          ],
                          "authorName": [
                            "object/get",
                            "@row",
                            "authorName",
                            "Guest"
                          ],
                          "comment": [
                            "object/get",
                            "@row",
                            "comment",
                            ""
                          ],
                          "createdAt": [
                            "object/get",
                            "@row",
                            "createdAt",
                            ""
                          ],
                          "helpful": [
                            "object/get",
                            "@row",
                            "helpful",
                            0.0
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.reviews",
                    "@entity.reviewsSource"
                  ],
                  [
                    "set",
                    "@entity.totalReviews",
                    [
                      "array/len",
                      "@payload.data"
                    ]
                  ],
                  [
                    "set",
                    "@entity.averageRating",
                    [
                      "array/avg",
                      [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "row",
                          [
                            "object/get",
                            "@row",
                            "rating",
                            5.0
                          ]
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.starDistribution",
                    [
                      "array/map",
                      "@config.starDistribution",
                      [
                        "fn",
                        "bar",
                        {
                          "percentage": [
                            "object/get",
                            "@bar",
                            "percentage",
                            0.0
                          ],
                          "label": [
                            "object/get",
                            "@bar",
                            "label",
                            ""
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "xs",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "star"
                                    },
                                    {
                                      "content": "Reviews",
                                      "variant": "h3",
                                      "type": "typography"
                                    },
                                    {
                                      "type": "typography",
                                      "color": "muted",
                                      "content": "·"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h3",
                                      "content": "@entity.averageRating"
                                    },
                                    {
                                      "name": "star",
                                      "color": "warning",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "·",
                                      "color": "muted",
                                      "type": "typography"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h4",
                                      "color": "muted",
                                      "content": "@entity.totalReviews"
                                    },
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "color": "muted",
                                      "content": "reviews"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "align": "center"
                                },
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "@config.subjectTitle",
                                  "variant": "caption"
                                }
                              ],
                              "direction": "vertical"
                            },
                            {
                              "variant": "primary",
                              "action": "WRITE_REVIEW",
                              "label": "@config.writeLabel",
                              "type": "button",
                              "icon": "edit"
                            }
                          ]
                        },
                        {
                          "type": "card",
                          "look": "@config.cardLook",
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Rating distribution",
                                  "variant": "h4",
                                  "type": "typography"
                                },
                                {
                                  "type": "data-list",
                                  "gap": "sm",
                                  "fields": [],
                                  "renderItem": [
                                    "fn",
                                    "bar",
                                    {
                                      "align": "center",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "content": "@bar.label",
                                          "variant": "caption"
                                        },
                                        {
                                          "max": 100.0,
                                          "value": "@bar.percentage",
                                          "type": "progress-bar",
                                          "variant": "primary"
                                        },
                                        {
                                          "color": "muted",
                                          "variant": "caption",
                                          "type": "typography",
                                          "content": "@bar.percentage"
                                        },
                                        {
                                          "variant": "caption",
                                          "color": "muted",
                                          "type": "typography",
                                          "content": "%"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "gap": "md"
                                    }
                                  ],
                                  "entity": "@entity.starDistribution"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "tabChangeEvent": "CHANGE_SORT",
                          "type": "tabs",
                          "tabs": "@config.sortOptions",
                          "activeTab": "@entity.currentSort"
                        },
                        {
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "review",
                            {
                              "type": "card",
                              "look": "@config.cardLook",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "align": "center",
                                      "type": "stack",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "name": "@review.avatarIcon",
                                          "type": "icon"
                                        },
                                        {
                                          "weight": "bold",
                                          "type": "typography",
                                          "content": "@review.authorName"
                                        },
                                        {
                                          "color": "muted",
                                          "type": "typography",
                                          "content": "·"
                                        },
                                        {
                                          "type": "icon",
                                          "name": "star",
                                          "color": "warning"
                                        },
                                        {
                                          "content": "@review.rating",
                                          "weight": "bold",
                                          "type": "typography"
                                        },
                                        {
                                          "content": "·",
                                          "color": "muted",
                                          "type": "typography"
                                        },
                                        {
                                          "type": "typography",
                                          "color": "muted",
                                          "variant": "caption",
                                          "content": "@review.createdAt"
                                        }
                                      ]
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@review.comment",
                                      "type": "typography"
                                    },
                                    {
                                      "align": "center",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "actionPayload": {
                                            "id": "@review.id"
                                          },
                                          "type": "button",
                                          "label": "Helpful",
                                          "variant": "ghost",
                                          "action": "MARK_HELPFUL",
                                          "icon": "thumbs-up"
                                        },
                                        {
                                          "content": "@review.helpful",
                                          "type": "typography",
                                          "variant": "caption",
                                          "color": "muted"
                                        }
                                      ],
                                      "direction": "horizontal",
                                      "type": "stack"
                                    }
                                  ],
                                  "direction": "vertical",
                                  "type": "stack",
                                  "gap": "sm"
                                }
                              ]
                            }
                          ],
                          "type": "data-list",
                          "entity": "@entity.reviews",
                          "gap": "md"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReviewsLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "message": "@entity.errorMessage",
                      "title": "Failed to load reviews"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "ReviewSaved",
                "effects": [
                  [
                    "fetch",
                    "ReviewView",
                    {
                      "emit": {
                        "success": "ReviewsLoaded",
                        "failure": "ReviewsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing reviews…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReviewSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Failed to submit",
                      "type": "error-state",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "composing",
                "event": "WRITE_REVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.draftRating",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.draftComment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "action": "CANCEL_REVIEW",
                              "icon": "arrow-left",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "edit",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Write a review"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "look": "@config.cardLook",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "@config.subjectTitle",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "How would you rate it?"
                                },
                                {
                                  "value": "@entity.draftRating",
                                  "max": 5.0,
                                  "type": "star-rating",
                                  "action": "RATE_DRAFT"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "Share more details (optional)"
                                },
                                {
                                  "mode": "edit",
                                  "cancelEvent": "CANCEL_REVIEW",
                                  "submitLabel": "@config.submitLabel",
                                  "fields": "@config.reviewFields",
                                  "submitEvent": "SUBMIT_REVIEW",
                                  "entity": "@entity",
                                  "type": "form-section"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "md"
                            }
                          ],
                          "type": "card"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CHANGE_SORT",
                "guard": [
                  "=",
                  "@payload.tabId",
                  "highest"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.currentSort",
                    "highest"
                  ],
                  [
                    "set",
                    "@entity.reviews",
                    [
                      "array/sort",
                      "@entity.reviewsSource",
                      "rating",
                      "desc"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "xs",
                              "children": [
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "star"
                                    },
                                    {
                                      "variant": "h3",
                                      "type": "typography",
                                      "content": "Reviews"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "·",
                                      "color": "muted"
                                    },
                                    {
                                      "variant": "h3",
                                      "content": "@entity.averageRating",
                                      "type": "typography"
                                    },
                                    {
                                      "color": "warning",
                                      "type": "icon",
                                      "name": "star"
                                    },
                                    {
                                      "color": "muted",
                                      "type": "typography",
                                      "content": "·"
                                    },
                                    {
                                      "content": "@entity.totalReviews",
                                      "variant": "h4",
                                      "type": "typography",
                                      "color": "muted"
                                    },
                                    {
                                      "variant": "h4",
                                      "content": "reviews",
                                      "type": "typography",
                                      "color": "muted"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "align": "center"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "@config.subjectTitle",
                                  "color": "muted"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "@config.writeLabel",
                              "action": "WRITE_REVIEW",
                              "variant": "primary",
                              "icon": "edit"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Rating distribution",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "fields": [],
                                  "type": "data-list",
                                  "renderItem": [
                                    "fn",
                                    "bar",
                                    {
                                      "children": [
                                        {
                                          "type": "typography",
                                          "content": "@bar.label",
                                          "variant": "caption"
                                        },
                                        {
                                          "type": "progress-bar",
                                          "variant": "primary",
                                          "value": "@bar.percentage",
                                          "max": 100.0
                                        },
                                        {
