{
  "description": "std-related as a Function",
  "name": "std-related",
  "orbitals": [
    {
      "entity": {
        "collection": "relateditems",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The identifier or designation for the related item.",
            "name": "name",
            "synonyms": "title, label, identifier",
            "type": "string"
          }
        ],
        "name": "RelatedItem",
        "persistence": "persistent"
      },
      "name": "RelatedItemOrbital",
      "pages": [
        {
          "name": "Related",
          "path": "/related",
          "traits": [
            {
              "ref": "RelatedItemList"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "tableLook": {
              "default": "dense",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "label": "Table look",
              "tier": "presentation",
              "type": "string",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            }
          },
          "emits": [
            {
              "description": "Signals that related items have been successfully loaded.",
              "event": "RelatedItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RelatedItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "essential"
            },
            {
              "description": "Indicates failure to load related items.",
              "event": "RelatedItemLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "error, failure, problem, unsuccessful",
              "tier": "internal"
            }
          ],
          "entityContract": {
            "provides": [],
            "requires": []
          },
          "entityRebindable": true,
          "linkedEntity": "RelatedItem",
          "name": "RelatedItemList",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals that related items have been successfully loaded.",
                "key": "RelatedItemLoaded",
                "name": "RelatedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RelatedItem]"
                  }
                ],
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential"
              },
              {
                "description": "Indicates failure to load related items.",
                "key": "RelatedItemLoadFailed",
                "name": "RelatedItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "loading"
              },
              {
                "name": "loaded"
              },
              {
                "name": "error"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "failure": "RelatedItemLoadFailed",
                        "success": "RelatedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading related…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-8",
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "loading",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "link",
                              "type": "icon"
                            },
                            {
                              "content": "Related",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [],
                          "look": "@config.tableLook",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "content": "@item.name",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs",
                              "type": "stack"
                            }
                          ],
                          "type": "data-list"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RelatedItemLoaded",
                "from": "loading",
                "to": "loaded"
              },
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "error",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load related",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "className": "py-8",
                      "direction": "vertical",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "RelatedItemLoadFailed",
                "from": "loading",
                "to": "error"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "failure": "RelatedItemLoadFailed",
                        "success": "RelatedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "loaded",
                "to": "loading"
              },
              {
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "failure": "RelatedItemLoadFailed",
                        "success": "RelatedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "error",
                "to": "loading"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}