{
  "name": "std-related",
  "version": "1.0.0",
  "description": "std-related as a Function",
  "orbitals": [
    {
      "name": "RelatedItemOrbital",
      "entity": {
        "name": "RelatedItem",
        "collection": "relateditems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RelatedItemList",
          "category": "interaction",
          "linkedEntity": "RelatedItem",
          "emits": [
            {
              "event": "RelatedItemLoaded",
              "description": "Fired when RelatedItem finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RelatedItem]"
                }
              ]
            },
            {
              "event": "RelatedItemLoadFailed",
              "description": "Fired when RelatedItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "loaded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RelatedItemLoaded",
                "name": "RelatedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RelatedItem]"
                  }
                ]
              },
              {
                "key": "RelatedItemLoadFailed",
                "name": "RelatedItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "failure": "RelatedItemLoadFailed",
                        "success": "RelatedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading related…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-8",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "sm",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loaded",
                "event": "RelatedItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "link"
                            },
                            {
                              "type": "typography",
                              "content": "Related",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-list",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@item.name"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical"
                            }
                          ],
                          "fields": []
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RelatedItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "variant": "body",
                          "content": "Failed to load related",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "@payload.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "action": "INIT",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "className": "py-8",
                      "type": "stack",
                      "gap": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "loaded",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "success": "RelatedItemLoaded",
                        "failure": "RelatedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "success": "RelatedItemLoaded",
                        "failure": "RelatedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Related",
          "path": "/related",
          "traits": [
            {
              "ref": "RelatedItemList"
            }
          ]
        }
      ]
    }
  ]
}
