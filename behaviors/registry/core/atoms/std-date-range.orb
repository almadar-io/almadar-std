{
  "name": "std-date-range",
  "version": "2.0.0",
  "description": "std-date-range — compact calendar button (Looker / Tableau shape) that opens a popover containing the date-range-picker. Owns a DateRange runtime entity; DATE_RANGE_CHANGED persists @payload.from + @payload.to so cross-trait listeners can route the range into data atoms (Browse REFETCH_FILTER, Stats / Graphs requery).",
  "orbitals": [
    {
      "name": "DateRangeOrbital",
      "entity": {
        "name": "DateRange",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "from",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DateRangeFilter",
          "category": "interaction",
          "linkedEntity": "DateRange",
          "emits": [
            {
              "event": "DATE_RANGE_CHANGED",
              "payloadSchema": [
                {
                  "name": "from",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "to",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OPEN_DATE_RANGE",
                "name": "Open Date Range"
              },
              {
                "key": "DATE_RANGE_CHANGED",
                "name": "Date Range Changed",
                "payloadSchema": [
                  {
                    "name": "from",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "to",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "popover",
                      "content": {
                        "event": "@config.event",
                        "type": "date-range-picker",
                        "fromLabel": "@config.fromLabel",
                        "toLabel": "@config.toLabel"
                      },
                      "position": "bottom",
                      "children": {
                        "variant": "secondary",
                        "icon": "calendar",
                        "type": "button",
                        "size": "sm",
                        "label": "@config.buttonLabel",
                        "action": "OPEN_DATE_RANGE"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "OPEN_DATE_RANGE",
                "effects": [
                  [
                    "set",
                    "@entity.from",
                    "@entity.from"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DATE_RANGE_CHANGED",
                "effects": [
                  [
                    "set",
                    "@entity.from",
                    "@payload.from"
                  ],
                  [
                    "set",
                    "@entity.to",
                    "@payload.to"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "popover",
                      "position": "bottom",
                      "children": {
                        "icon": "calendar",
                        "variant": "secondary",
                        "type": "button",
                        "size": "sm",
                        "action": "OPEN_DATE_RANGE",
                        "label": "@config.buttonLabel"
                      },
                      "content": {
                        "toLabel": "@config.toLabel",
                        "fromLabel": "@config.fromLabel",
                        "event": "@config.event",
                        "to": "@entity.to",
                        "type": "date-range-picker",
                        "from": "@entity.from"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "DATE_RANGE_CHANGED",
              "label": "Change event",
              "description": "Event name emitted when the user picks a new range"
            },
            "toLabel": {
              "type": "string",
              "default": "To",
              "label": "End-date label",
              "description": "Caption shown above the end-date input"
            },
            "buttonLabel": {
              "type": "string",
              "default": "Date range",
              "label": "Trigger button",
              "description": "Text on the toolbar button that opens the popover"
            },
            "fromLabel": {
              "type": "string",
              "default": "From",
              "label": "Start-date label",
              "description": "Caption shown above the start-date input"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DateRangeFilterPage",
          "path": "/dateranges/filter",
          "traits": [
            {
              "ref": "DateRangeFilter"
            }
          ]
        }
      ]
    }
  ]
}
