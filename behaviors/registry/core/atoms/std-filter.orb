{
  "name": "std-filter",
  "version": "1.0.0",
  "description": "std-filter — single primitive: filter-group. Owns a FilterTarget runtime entity; every FILTER transition persists field/value so cross-trait listeners can route the latest selection into data atoms.",
  "orbitals": [
    {
      "name": "FilterTargetOrbital",
      "entity": {
        "name": "FilterTarget",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "field",
            "type": "string",
            "description": "The name of the data field being filtered.",
            "synonyms": "attribute, property, key"
          },
          {
            "name": "value",
            "type": "string",
            "description": "The data associated with the filter criterion.",
            "synonyms": "data, criterion, content"
          }
        ]
      },
      "traits": [
        {
          "name": "FilterTargetFilter",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "field",
              "value"
            ]
          },
          "category": "interaction",
          "linkedEntity": "FilterTarget",
          "emits": [
            {
              "event": "FILTER",
              "description": "Signals a filter has been applied or changed.",
              "synonyms": "apply, update, change, refine",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "field",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILTER",
                "name": "Filter",
                "description": "Signals a filter has been applied or changed.",
                "synonyms": "apply, update, change, refine",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters",
                "description": "Resets the filter selection to its initial state.",
                "synonyms": "reset, clear, remove, undo",
                "tier": "essential"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "look": "@config.filterBarLook",
                      "type": "filter-group"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FILTER",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    "@payload.field"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "look": "@config.filterBarLook",
                      "type": "filter-group"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    ""
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "emit",
                    "FILTER",
                    {
                      "field": "",
                      "value": ""
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "look": "@config.filterBarLook",
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "type": "filter-group"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "filters": {
              "type": "[FilterSpec]",
              "default": [
                {
                  "field": "status",
                  "options": [
                    "active",
                    "inactive",
                    "pending"
                  ],
                  "label": "Status",
                  "filterType": "select"
                }
              ],
              "label": "Filter controls",
              "description": "Field, label, control type, and options for each filter input",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "options": {
                    "name": "options",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "filterType": {
                    "name": "filterType",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "filterBarLook": {
              "type": "string",
              "default": "toolbar",
              "label": "Filter bar look",
              "description": "Layer 2 visual treatment for the filter bar.",
              "tier": "presentation",
              "values": [
                "toolbar",
                "chips",
                "pills",
                "popover-trigger",
                "inline-column-header"
              ]
            },
            "event": {
              "type": "string",
              "default": "FILTER",
              "label": "Filter event",
              "description": "Event emitted when the user changes a filter selection",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ]
    }
  ]
}
