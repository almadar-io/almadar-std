{
  "name": "std-filter",
  "version": "1.0.0",
  "description": "std-filter — single primitive: filter-group. Owns a FilterTarget runtime entity; every FILTER transition persists field/value so cross-trait listeners can route the latest selection into data atoms.",
  "orbitals": [
    {
      "name": "FilterTargetOrbital",
      "entity": {
        "name": "FilterTarget",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "field",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FilterTargetFilter",
          "category": "interaction",
          "linkedEntity": "FilterTarget",
          "emits": [
            {
              "event": "FILTER",
              "payloadSchema": [
                {
                  "name": "field",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILTER",
                "name": "Filter",
                "payloadSchema": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "type": "filter-group"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FILTER",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    "@payload.field"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "filters": "@config.filters",
                      "type": "filter-group",
                      "entity": "FilterTarget"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    ""
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "emit",
                    "FILTER",
                    {
                      "value": "",
                      "field": ""
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "filter-group",
                      "filters": "@config.filters",
                      "entity": "FilterTarget"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "filters": {
              "type": "[FilterSpec]",
              "default": [
                {
                  "field": "status",
                  "label": "Status",
                  "options": [
                    "active",
                    "inactive",
                    "pending"
                  ],
                  "filterType": "select"
                }
              ],
              "label": "Filter controls",
              "description": "Field, label, control type, and options for each filter input",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "field": {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  "options": {
                    "name": "options",
                    "type": "array",
                    "required": false,
                    "items": {
                      "type": "string"
                    }
                  },
                  "filterType": {
                    "name": "filterType",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "event": {
              "type": "string",
              "default": "FILTER",
              "label": "Filter event",
              "description": "Event emitted when the user changes a filter selection",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ]
    }
  ]
}