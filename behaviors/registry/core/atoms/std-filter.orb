{
  "name": "std-filter",
  "version": "1.0.0",
  "description": "std-filter as a Function — single primitive: filter-group",
  "orbitals": [
    {
      "name": "FilterTargetOrbital",
      "entity": {
        "name": "FilterTarget",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FilterTargetFilter",
          "category": "interaction",
          "linkedEntity": "FilterTarget",
          "emits": [
            {
              "event": "FilterTargetLoaded",
              "description": "Fired when FilterTarget finishes loading; payload.data holds the filtered list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[FilterTarget]"
                }
              ]
            },
            {
              "event": "FilterTargetLoadFailed",
              "description": "Fired when FilterTarget fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FilterTargetLoaded",
                "name": "FilterTarget loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[FilterTarget]"
                  }
                ]
              },
              {
                "key": "FilterTargetLoadFailed",
                "name": "FilterTarget load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER",
                "name": "Filter",
                "payloadSchema": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "success": "FilterTargetLoaded",
                        "failure": "FilterTargetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "FilterTargetLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "filter-group",
                      "filters": "@config.filters",
                      "entity": "FilterTarget"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FilterTargetLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "xs",
                      "direction": "vertical",
                      "children": [
                        {
                          "entity": "FilterTarget",
                          "type": "filter-group",
                          "filters": "@config.filters"
                        },
                        {
                          "color": "error",
                          "variant": "caption",
                          "content": "@payload.error",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "FILTER",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "failure": "FilterTargetLoadFailed",
                        "success": "FilterTargetLoaded"
                      },
                      "filter": [
                        "=",
                        [
                          "object/get",
                          "@entity",
                          "@payload.field"
                        ],
                        "@payload.value"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "sm",
                      "type": "stack",
                      "direction": "horizontal",
                      "children": [
                        {
                          "entity": "FilterTarget",
                          "type": "filter-group",
                          "filters": "@config.filters"
                        },
                        {
                          "type": "spinner",
                          "size": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "failure": "FilterTargetLoadFailed",
                        "success": "FilterTargetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "filters": "@config.filters",
                          "type": "filter-group",
                          "entity": "FilterTarget"
                        },
                        {
                          "type": "spinner",
                          "size": "sm"
                        }
                      ],
                      "direction": "horizontal",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {
                      "emit": {
                        "success": "FilterTargetLoaded",
                        "failure": "FilterTargetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "FILTER"
            },
            "filters": {
              "type": "object",
              "default": []
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ]
    }
  ]
}
