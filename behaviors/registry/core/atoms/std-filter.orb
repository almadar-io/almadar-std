{
  "name": "std-filter",
  "version": "1.0.0",
  "description": "std-filter as a Function — single primitive: filter-group. The atom's\nown FilterTarget entity is the UI-state container — every FILTER\ntransition persists field/value into the entity. Visual reflection of\nthe persisted value (filter-group `value` prop) is a follow-up that\nneeds the pattern registry + UI component to accept a `value` prop;\nthe persistence side is done.",
  "orbitals": [
    {
      "name": "FilterTargetOrbital",
      "entity": {
        "name": "FilterTarget",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "field",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FilterTargetFilter",
          "category": "interaction",
          "linkedEntity": "FilterTarget",
          "emits": [
            {
              "event": "FILTER",
              "payloadSchema": [
                {
                  "name": "field",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILTER",
                "name": "Filter",
                "payloadSchema": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "filters": "@config.filters",
                      "entity": "FilterTarget",
                      "type": "filter-group"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FILTER",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    "@payload.field"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "filter-group",
                      "entity": "FilterTarget",
                      "filters": "@config.filters"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    ""
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "emit",
                    "FILTER",
                    {
                      "field": "",
                      "value": ""
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": "@config.filters",
                      "type": "filter-group"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "filters": {
              "type": "[object]",
              "default": []
            },
            "event": {
              "type": "string",
              "default": "FILTER"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ]
    }
  ]
}
