{
  "name": "std-form-advanced",
  "version": "1.2.0",
  "description": "std-form-advanced — full-typed form-section primitive. Hosts the `editing` state with a configurable `fields` array (each entry mirrors @almadar/ui's `form-section` field schema: `{ name, label, type?, values?, relation?, required? }`). Field-level constraints live in `config.fieldValidation` as `[{ field, format?: 'email'|'url'|'phone', regex?, minLength?, maxLength?, message? }]` — form-section surfaces inline errors when a submit violates a declared constraint. Agents drive shape by overriding `config.fields` + `config.fieldValidation` per-call-site.",
  "orbitals": [
    {
      "name": "FormEntryOrbital",
      "entity": {
        "name": "FormEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "age",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": false
          },
          {
            "name": "birthDate",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "categoryId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "FormEntryFormAdvanced",
          "category": "interaction",
          "linkedEntity": "FormEntry",
          "emits": [
            {
              "event": "FormEntryLoaded",
              "description": "Fired when FormEntry finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "age",
                  "type": "number"
                },
                {
                  "name": "isActive",
                  "type": "boolean"
                },
                {
                  "name": "birthDate",
                  "type": "datetime"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "categoryId",
                  "type": "relation"
                }
              ]
            },
            {
              "event": "FormEntryLoadFailed",
              "description": "Fired when FormEntry fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FormEntrySaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FormEntrySaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "editing",
                "isInitial": true
              },
              {
                "name": "submitted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "FormEntryLoaded",
                "name": "FormEntry loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "age",
                    "type": "number"
                  },
                  {
                    "name": "isActive",
                    "type": "boolean"
                  },
                  {
                    "name": "birthDate",
                    "type": "datetime"
                  },
                  {
                    "name": "priority",
                    "type": "string"
                  },
                  {
                    "name": "categoryId",
                    "type": "relation"
                  }
                ]
              },
              {
                "key": "FormEntryLoadFailed",
                "name": "FormEntry load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FormEntrySaved",
                "name": "FormEntry saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FormEntrySaveFailed",
                "name": "FormEntry save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "editing",
                "to": "editing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "failure": "FormEntryLoadFailed",
                        "success": "FormEntryLoaded"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "success": "FormEntryLoaded",
                        "failure": "FormEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "FormEntry Form"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "mode": "create",
                          "submitEvent": "SUBMIT",
                          "cancelEvent": "INIT",
                          "fields": "@config.fields"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "submitted",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.name",
                    "@payload.data.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.data.description"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.data.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.data.notes"
                  ],
                  [
                    "set",
                    "@entity.age",
                    "@payload.data.age"
                  ],
                  [
                    "set",
                    "@entity.isActive",
                    "@payload.data.isActive"
                  ],
                  [
                    "set",
                    "@entity.birthDate",
                    "@payload.data.birthDate"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.data.priority"
                  ],
                  [
                    "set",
                    "@entity.categoryId",
                    "@payload.data.categoryId"
                  ],
                  [
                    "persist",
                    "create",
                    "FormEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "FormEntrySaved",
                        "failure": "FormEntrySaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "content": "Form Submitted",
                          "type": "typography"
                        },
                        {
                          "message": "Your form has been submitted successfully.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "icon": "plus",
                          "type": "button",
                          "label": "New Entry",
                          "action": "RESET",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "editing",
                "event": "RESET",
                "effects": [
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "success": "FormEntryLoaded",
                        "failure": "FormEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "success": "FormEntryLoaded",
                        "failure": "FormEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "content": "FormEntry Form",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "INIT",
                          "submitEvent": "SUBMIT",
                          "type": "form-section",
                          "mode": "create",
                          "fields": "@config.fields"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "name",
                  "label": "Name"
                },
                {
                  "label": "Description",
                  "name": "description"
                },
                {
                  "label": "Status",
                  "values": [
                    "active",
                    "inactive",
                    "pending"
                  ],
                  "type": "enum",
                  "name": "status"
                },
                {
                  "label": "Notes",
                  "name": "notes",
                  "type": "textarea"
                },
                {
                  "name": "age",
                  "label": "Age",
                  "type": "number"
                },
                {
                  "label": "Is Active",
                  "name": "isActive",
                  "type": "boolean"
                },
                {
                  "name": "birthDate",
                  "label": "Birth Date",
                  "type": "date"
                },
                {
                  "name": "priority",
                  "type": "enum",
                  "values": [
                    "low",
                    "medium",
                    "high",
                    "critical"
                  ],
                  "label": "Priority"
                },
                {
                  "name": "categoryId",
                  "type": "relation",
                  "relation": {
                    "cardinality": "one",
                    "entity": "FormEntry"
                  },
                  "label": "Category ID"
                }
              ],
              "label": "Form fields",
              "description": "Inputs to render; each entry follows the form-section field schema"
            },
            "fieldValidation": {
              "type": "[object]",
              "default": [],
              "label": "Field validation",
              "description": "Per-field rules (format, regex, length) shown inline on submit"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FormEntryFormPage",
          "path": "/formentrys/form",
          "traits": [
            {
              "ref": "FormEntryFormAdvanced"
            }
          ]
        }
      ]
    }
  ]
}
