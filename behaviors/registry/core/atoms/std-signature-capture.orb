{
  "name": "std-signature-capture",
  "version": "1.0.0",
  "description": "std-signature-capture — hand-drawn signature primitive. Use when the user voices ANY scenario where a person must attest to or sign off on something via a captured signature — proof of completion, consent acknowledgement, delivery confirmation, agreement assent, attestation on a form. Covers field-service sign-off, consent capture, delivery proof, in-person agreement assent. Owns a Signature entity; CHANGE binds @entity.signatureDataUrl; SUBMIT persists @payload.data and emits SignatureSubmitted.",
  "orbitals": [
    {
      "name": "SignatureCaptureOrbital",
      "entity": {
        "name": "Signature",
        "collection": "signatures",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "signerName",
            "type": "string",
            "required": true
          },
          {
            "name": "signatureDataUrl",
            "type": "string",
            "required": true
          },
          {
            "name": "signedAt",
            "type": "string"
          },
          {
            "name": "ipAddress",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SignatureCapture",
          "category": "interaction",
          "linkedEntity": "Signature",
          "emits": [
            {
              "event": "CHANGE",
              "payloadSchema": [
                {
                  "name": "dataUrl",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLEAR"
            },
            {
              "event": "SignatureLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Signature]"
                }
              ]
            },
            {
              "event": "SignatureLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SignatureSubmitted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.signerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.signatureDataUrl",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.signedAt",
                  "type": "string"
                },
                {
                  "name": "row.ipAddress",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SignatureSubmitFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SignatureLoaded",
                "name": "Signature loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Signature]"
                  }
                ]
              },
              {
                "key": "SignatureLoadFailed",
                "name": "Signature load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHANGE",
                "name": "Change",
                "payloadSchema": [
                  {
                    "name": "dataUrl",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SignatureSubmitted",
                "name": "Signature submitted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Signature"
                  }
                ]
              },
              {
                "key": "SignatureSubmitFailed",
                "name": "Signature submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Signature",
                    {
                      "emit": {
                        "failure": "SignatureLoadFailed",
                        "success": "SignatureLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "SignatureLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "content": "@config.title",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "content": "@config.instructions",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "onChange": "CHANGE",
                          "type": "signature-pad",
                          "value": "@entity.signatureDataUrl"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Clear",
                              "action": "CLEAR",
                              "type": "button",
                              "variant": "secondary",
                              "icon": "trash"
                            },
                            {
                              "action": "SUBMIT",
                              "variant": "primary",
                              "label": "Submit",
                              "icon": "send",
                              "type": "button"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SignatureLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.signatureDataUrl",
                    "@payload.dataUrl"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.signatureDataUrl",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "@config.instructions"
                        },
                        {
                          "value": "@entity.signatureDataUrl",
                          "onChange": "CHANGE",
                          "type": "signature-pad"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "trash",
                              "action": "CLEAR",
                              "type": "button",
                              "label": "Clear",
                              "variant": "secondary"
                            },
                            {
                              "variant": "primary",
                              "action": "SUBMIT",
                              "label": "Submit",
                              "icon": "send",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Signature",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SignatureSubmitted",
                        "failure": "SignatureSubmitFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Submitting your signature…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "SignatureSubmitted",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "color": "success",
                          "name": "check-circle"
                        },
                        {
                          "content": "Signature recorded. Thank you.",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ],
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "idle",
                "event": "SignatureSubmitFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.signatureDataUrl",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@config.title"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "@config.instructions",
                          "color": "muted"
                        },
                        {
                          "onChange": "CHANGE",
                          "value": "@entity.signatureDataUrl",
                          "type": "signature-pad"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "secondary",
                              "action": "CLEAR",
                              "type": "button",
                              "label": "Clear",
                              "icon": "trash"
                            },
                            {
                              "type": "button",
                              "action": "SUBMIT",
                              "variant": "primary",
                              "icon": "send",
                              "label": "Submit"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "@config.title"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "@config.instructions"
                        },
                        {
                          "onChange": "CHANGE",
                          "type": "signature-pad",
                          "value": "@entity.signatureDataUrl"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Clear",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "trash",
                              "action": "CLEAR"
                            },
                            {
                              "label": "Submit",
                              "variant": "primary",
                              "action": "SUBMIT",
                              "icon": "send",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "instructions": {
              "type": "string",
              "default": "Use your finger or stylus to sign below",
              "label": "Instructions",
              "description": "Helper text shown to the signer above the pad",
              "tier": "presentation"
            },
            "title": {
              "type": "string",
              "default": "Sign here",
              "label": "Pad title",
              "description": "Heading shown above the signature pad",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SignatureCapturePage",
          "path": "/signatures/capture",
          "traits": [
            {
              "ref": "SignatureCapture"
            }
          ]
        }
      ]
    }
  ]
}