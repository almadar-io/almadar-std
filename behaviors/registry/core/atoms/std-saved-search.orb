{
  "name": "std-saved-search",
  "version": "1.0.0",
  "description": "std-saved-search — persisted query + alert subscription. Owns a SavedSearch entity (one row per saved query) and a single manage trait that lists saved searches in a data-grid, lets users toggle their alert subscription / rename the search / delete it, and persists each change.",
  "orbitals": [
    {
      "name": "SavedSearchOrbital",
      "entity": {
        "name": "SavedSearch",
        "collection": "savedsearches",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "query",
            "type": "string"
          },
          {
            "name": "filters",
            "type": "object"
          },
          {
            "name": "alertEnabled",
            "type": "boolean",
            "default": false
          },
          {
            "name": "alertFrequency",
            "type": "string",
            "default": "daily",
            "values": [
              "instant",
              "daily",
              "weekly"
            ]
          },
          {
            "name": "userId",
            "type": "string"
          },
          {
            "name": "lastNotifiedAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SavedSearchManage",
          "category": "interaction",
          "linkedEntity": "SavedSearch",
          "emits": [
            {
              "event": "TOGGLE_ALERT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "enabled",
                  "type": "boolean",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RENAME",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CHANGE_FREQUENCY",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SAVE"
            },
            {
              "event": "CANCEL"
            },
            {
              "event": "SavedSearchLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[SavedSearch]"
                }
              ]
            },
            {
              "event": "SavedSearchLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SavedSearchUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.query",
                  "type": "string"
                },
                {
                  "name": "row.filters",
                  "type": "object"
                },
                {
                  "name": "row.alertEnabled",
                  "type": "boolean"
                },
                {
                  "name": "row.alertFrequency",
                  "type": "string"
                },
                {
                  "name": "row.userId",
                  "type": "string"
                },
                {
                  "name": "row.lastNotifiedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SavedSearchDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SavedSearchLoaded",
                "name": "SavedSearch loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SavedSearch]"
                  }
                ]
              },
              {
                "key": "SavedSearchLoadFailed",
                "name": "SavedSearch load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TOGGLE_ALERT",
                "name": "Toggle Alert",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "enabled",
                    "type": "boolean",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SavedSearchUpdated",
                "name": "SavedSearch updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "SavedSearch"
                  }
                ]
              },
              {
                "key": "SavedSearchDeleted",
                "name": "SavedSearch deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RENAME",
                "name": "Rename",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CHANGE_FREQUENCY",
                "name": "Change Frequency",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SavedSearch",
                    {
                      "emit": {
                        "success": "SavedSearchLoaded",
                        "failure": "SavedSearchLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading saved searches…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SavedSearchLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "name": "bookmark",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name",
                              "variant": "h4"
                            },
                            {
                              "name": "query",
                              "variant": "caption",
                              "label": "Query"
                            },
                            {
                              "variant": "badge",
                              "label": "Frequency",
                              "name": "alertFrequency"
                            },
                            {
                              "variant": "badge",
                              "name": "alertEnabled",
                              "label": "Alerts"
                            }
                          ],
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "event": "TOGGLE_ALERT",
                              "label": "Toggle alert",
                              "variant": "secondary",
                              "icon": "bell"
                            },
                            {
                              "event": "EDIT",
                              "label": "Edit",
                              "icon": "pencil",
                              "variant": "secondary"
                            },
                            {
                              "event": "DELETE",
                              "label": "Delete",
                              "variant": "danger",
                              "icon": "trash-2"
                            }
                          ],
                          "type": "data-grid",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SavedSearchLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TOGGLE_ALERT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.alertEnabled",
                    "@payload.enabled"
                  ],
                  [
                    "persist",
                    "update",
                    "SavedSearch",
                    "@entity",
                    {
                      "emit": {
                        "success": "SavedSearchUpdated",
                        "failure": "SavedSearchLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "persist",
                    "delete",
                    "SavedSearch",
                    "@entity",
                    {
                      "emit": {
                        "failure": "SavedSearchLoadFailed",
                        "success": "SavedSearchDeleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "pencil"
                            },
                            {
                              "type": "typography",
                              "content": "Edit saved search",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "value": "@entity.name",
                          "placeholder": "Name",
                          "type": "input",
                          "action": "RENAME"
                        },
                        {
                          "placeholder": "Alert frequency",
                          "type": "select",
                          "options": [
                            {
                              "label": "Instant",
                              "value": "instant"
                            },
                            {
                              "value": "daily",
                              "label": "Daily"
                            },
                            {
                              "label": "Weekly",
                              "value": "weekly"
                            }
                          ],
                          "value": "@entity.alertFrequency",
                          "action": "CHANGE_FREQUENCY"
                        },
                        {
                          "checked": "@entity.alertEnabled",
                          "label": "Alerts enabled",
                          "type": "switch"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "Save",
                              "variant": "primary",
                              "icon": "check",
                              "action": "SAVE"
                            },
                            {
                              "label": "Cancel",
                              "type": "button",
                              "action": "CANCEL",
                              "variant": "secondary",
                              "icon": "x"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SavedSearchUpdated",
                "effects": [
                  [
                    "fetch",
                    "SavedSearch",
                    {
                      "emit": {
                        "success": "SavedSearchLoaded",
                        "failure": "SavedSearchLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SavedSearchDeleted",
                "effects": [
                  [
                    "fetch",
                    "SavedSearch",
                    {
                      "emit": {
                        "success": "SavedSearchLoaded",
                        "failure": "SavedSearchLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "RENAME",
                "effects": [
                  [
                    "set",
                    "@entity.name",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "CHANGE_FREQUENCY",
                "effects": [
                  [
                    "set",
                    "@entity.alertFrequency",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "SavedSearch",
                    "@entity",
                    {
                      "emit": {
                        "success": "SavedSearchUpdated",
                        "failure": "SavedSearchLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "fetch",
                    "SavedSearch",
                    {
                      "emit": {
                        "success": "SavedSearchLoaded",
                        "failure": "SavedSearchLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SavedSearch",
                    {
                      "emit": {
                        "failure": "SavedSearchLoadFailed",
                        "success": "SavedSearchLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Saved Searches",
              "label": "Section title",
              "description": "Heading shown above the saved-search list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SavedSearchManagePage",
          "path": "/savedsearches",
          "traits": [
            {
              "ref": "SavedSearchManage"
            }
          ]
        }
      ]
    }
  ]
}
