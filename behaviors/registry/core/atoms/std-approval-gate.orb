{
  "name": "std-approval-gate",
  "version": "1.0.1",
  "description": "std-approval-gate — generic approval gate / approver workflow. Use when a user voices that an action must be reviewed, approved, signed off, or authorized by a privileged role before it proceeds (admin approval, supervisor sign-off, manager approval, gatekeeper review, editor approval, senior editor approval, reviewer approval, publishing approval, draft approval, content review, submit drafts then editors review and approve or reject, needs approval before going live, requires sign-off before publish). Persists ApprovalRequest rows + surfaces them in a review queue with Approve / Deny / Reject actions, optionally requiring a written rejection reason or feedback comment. On approval emits ApprovalGranted; on denial emits ApprovalDenied. Compose onto any orbital whose action you want to gate: the target orbital emits an external event, an ApprovalRequest row is created, and downstream effects wait on ApprovalGranted. Differs from std-mod-queue, which is content-moderation-specific.",
  "orbitals": [
    {
      "name": "ApprovalGateOrbital",
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approval_requests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "gatedEvent",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "approved",
              "denied",
              "escalated"
            ]
          },
          {
            "name": "reviewer",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestedAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "decidedAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "escalatedAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApprovalGateReview",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "reviewer",
              "status"
            ]
          },
          "category": "interaction",
          "capabilities": [
            "approval"
          ],
          "linkedEntity": "ApprovalRequest",
          "emits": [
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.gatedEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.decidedAt",
                  "type": "number"
                },
                {
                  "name": "row.escalatedAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DENY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.gatedEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.decidedAt",
                  "type": "number"
                },
                {
                  "name": "row.escalatedAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalGranted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "requestId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalDenied",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "requestId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApprovalRequest]"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestReviewed",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.gatedEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.decidedAt",
                  "type": "number"
                },
                {
                  "name": "row.escalatedAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestReviewFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "reviewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "DENY",
                "name": "Deny",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "ApprovalRequestReviewed",
                "name": "ApprovalRequest reviewed",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "ApprovalRequestReviewFailed",
                "name": "ApprovalRequest review failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApprovalGranted",
                "name": "Approval granted",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApprovalDenied",
                "name": "Approval denied",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "guard": "@config.enabled",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading approval queue…"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "reviewing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "shield-check"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Approval queue"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Approve",
                              "icon": "check",
                              "event": "APPROVE",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "icon": "x",
                              "label": "Deny",
                              "event": "DENY"
                            }
                          ],
                          "entity": "@payload.data",
                          "look": "@config.tableLook",
                          "type": "data-grid",
                          "cols": 1.0,
                          "fields": [
                            {
                              "variant": "badge",
                              "name": "gatedEvent",
                              "label": "Action"
                            },
                            {
                              "label": "Requested",
                              "name": "requestedAt",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "approved"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "ApprovalRequestReviewed",
                        "failure": "ApprovalRequestReviewFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalGranted",
                    {
                      "requestId": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "DENY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "denied"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestReviewFailed",
                        "success": "ApprovalRequestReviewed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalDenied",
                    {
                      "requestId": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "loading",
                "event": "ApprovalRequestReviewed",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "ApprovalRequestReviewFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "escalationRoles": {
              "type": "[string]",
              "default": [],
              "label": "Escalation roles",
              "description": "Roles notified when a request escalates (compose sibling std-notify-on-event).",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "approverRoles": {
              "type": "[string]",
              "default": [],
              "label": "Approver roles",
              "description": "Roles eligible to approve. The host application enforces role-gating on the page.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "threshold": {
              "type": "number",
              "default": 0.0,
              "label": "Auto-approve threshold",
              "description": "Below this value, requests should be auto-approved. v1.0 declarative only; wiring lands in v1.1 (gap).",
              "tier": "domain"
            },
            "enabled": {
              "type": "boolean",
              "default": false,
              "label": "Enabled",
              "description": "Whether the approval gate is active for the host orbital. Off by default; turn on to require sign-off.",
              "synonyms": "enable, turn on, enforce, require, activate, apply, switch on, approval, needs approval, sign-off, signed off, review before, gatekeeper, editor approval, publishing approval, draft approval, content review, requires approval, manager approval, supervisor approval, admin approval, before going live",
              "tier": "domain"
            },
            "autoApproveBelowThreshold": {
              "type": "boolean",
              "default": true,
              "label": "Auto-approve below threshold",
              "description": "Skip the review queue when the gated event's value is below the threshold. v1.0 declarative only.",
              "tier": "domain"
            },
            "valueField": {
              "type": "string",
              "default": "",
              "label": "Value field",
              "description": "Payload field name to compare against threshold (e.g. 'amount' on a RefundRequested event). v1.0 declarative only.",
              "tier": "domain"
            },
            "escalationHours": {
              "type": "number",
              "default": 0.0,
              "label": "Escalation hours",
              "description": "Hours a request can sit pending before escalating. v1.0 declarative only; per-row escalation needs loop-with-emit primitive (gap).",
              "tier": "domain"
            },
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApprovalGateReviewPage",
          "path": "/approvals/queue",
          "traits": [
            {
              "ref": "ApprovalGateReview"
            }
          ]
        }
      ]
    }
  ]
}