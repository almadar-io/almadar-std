{
  "name": "std-approval-gate",
  "version": "1.0.1",
  "description": "std-approval-gate — generic approval gate / approver workflow. Use when a user voices that an action must be reviewed, approved, signed off, or authorized by a privileged role before it proceeds (admin approval, supervisor sign-off, manager approval, gatekeeper review, editor approval, senior editor approval, reviewer approval, publishing approval, draft approval, content review, submit drafts then editors review and approve or reject, needs approval before going live, requires sign-off before publish). Persists ApprovalRequest rows + surfaces them in a review queue with Approve / Deny / Reject actions, optionally requiring a written rejection reason or feedback comment. On approval emits ApprovalGranted; on denial emits ApprovalDenied. Compose onto any orbital whose action you want to gate: the target orbital emits an external event, an ApprovalRequest row is created, and downstream effects wait on ApprovalGranted. Differs from std-mod-queue, which is content-moderation-specific.",
  "orbitals": [
    {
      "name": "ApprovalGateOrbital",
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approval_requests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "gatedEvent",
            "type": "string",
            "default": "",
            "description": "The event that triggered the approval request.",
            "synonyms": "trigger, event, source"
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "approved",
              "denied",
              "escalated"
            ],
            "description": "Current state of the approval process.",
            "synonyms": "approval status, state, condition"
          },
          {
            "name": "reviewer",
            "type": "string",
            "default": "",
            "description": "The user or system responsible for reviewing the request.",
            "synonyms": "assignee, owner, approver, responsible party"
          },
          {
            "name": "requestedAt",
            "type": "number",
            "default": 0.0,
            "description": "Timestamp indicating when the approval request was initiated.",
            "synonyms": "creation time, request date, submission time"
          },
          {
            "name": "decidedAt",
            "type": "number",
            "default": 0.0,
            "description": "Timestamp indicating when a decision was made on the request.",
            "synonyms": "decision time, resolved at, completed at"
          },
          {
            "name": "escalatedAt",
            "type": "number",
            "default": 0.0,
            "description": "Timestamp indicating when the request was escalated.",
            "synonyms": "escalation time, escalation timestamp, escalated time"
          },
          {
            "name": "notes",
            "type": "string",
            "default": "",
            "description": "Free-form text providing additional context or details.",
            "synonyms": "comments, remarks, explanation, details"
          }
        ]
      },
      "traits": [
        {
          "name": "ApprovalGateReview",
          "entityRebindable": true,
          "entityContract": {
            "requires": [],
            "provides": [
              "reviewer",
              "status"
            ]
          },
          "category": "interaction",
          "capabilities": [
            "approval"
          ],
          "linkedEntity": "ApprovalRequest",
          "emits": [
            {
              "event": "APPROVE",
              "description": "Signals that an approval request has been approved.",
              "synonyms": "accept, authorize, confirm, pass",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.gatedEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.decidedAt",
                  "type": "number"
                },
                {
                  "name": "row.escalatedAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DENY",
              "description": "Signals that an approval request has been denied.",
              "synonyms": "reject, decline",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.gatedEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.decidedAt",
                  "type": "number"
                },
                {
                  "name": "row.escalatedAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalGranted",
              "description": "Signals that an approval process has been successfully completed.",
              "synonyms": "approved, authorized, confirmed, validated",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "requestId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalDenied",
              "description": "Indicates an approval request has been denied.",
              "synonyms": "rejected, declined",
              "tier": "essential",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "requestId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoaded",
              "description": "Indicates an approval request has been successfully loaded.",
              "synonyms": "loaded, fetched, retrieved",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApprovalRequest]"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoadFailed",
              "description": "Indicates failure to load an approval request.",
              "synonyms": "load error, failed load, request failure",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestReviewed",
              "description": "Signals that an approval request has been reviewed.",
              "synonyms": "reviewed, processed, examined",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.gatedEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.decidedAt",
                  "type": "number"
                },
                {
                  "name": "row.escalatedAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestReviewFailed",
              "description": "Indicates a failure to load or process an approval request for review.",
              "synonyms": "load error, failed review, processing failure",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "reviewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "description": "Indicates an approval request has been successfully loaded.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "description": "Indicates failure to load an approval request.",
                "synonyms": "load error, failed load, request failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "description": "Signals that an approval request has been approved.",
                "synonyms": "accept, authorize, confirm, pass",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "DENY",
                "name": "Deny",
                "description": "Signals that an approval request has been denied.",
                "synonyms": "reject, decline",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "ApprovalRequestReviewed",
                "name": "ApprovalRequest reviewed",
                "description": "Signals that an approval request has been reviewed.",
                "synonyms": "reviewed, processed, examined",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "ApprovalRequestReviewFailed",
                "name": "ApprovalRequest review failed",
                "description": "Indicates a failure to load or process an approval request for review.",
                "synonyms": "load error, failed review, processing failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApprovalGranted",
                "name": "Approval granted",
                "description": "Signals that an approval process has been successfully completed.",
                "synonyms": "approved, authorized, confirmed, validated",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApprovalDenied",
                "name": "Approval denied",
                "description": "Indicates an approval request has been denied.",
                "synonyms": "rejected, declined",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "requestId",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "guard": "@config.enabled",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading approval queue…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "reviewing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "shield-check",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Approval queue"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Approve",
                              "event": "APPROVE",
                              "icon": "check",
                              "variant": "primary"
                            },
                            {
                              "label": "Deny",
                              "event": "DENY",
                              "variant": "danger",
                              "icon": "x"
                            }
                          ],
                          "look": "@config.tableLook",
                          "fields": [
                            {
                              "name": "gatedEvent",
                              "variant": "badge",
                              "label": "Action"
                            },
                            {
                              "label": "Requested",
                              "variant": "caption",
                              "name": "requestedAt"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "cols": 1.0
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "approved"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "ApprovalRequestReviewed",
                        "failure": "ApprovalRequestReviewFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalGranted",
                    {
                      "requestId": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "DENY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "denied"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@user.id"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestReviewFailed",
                        "success": "ApprovalRequestReviewed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ApprovalDenied",
                    {
                      "requestId": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "loading",
                "event": "ApprovalRequestReviewed",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "reviewing",
                "to": "reviewing",
                "event": "ApprovalRequestReviewFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "valueField": {
              "type": "string",
              "default": "",
              "label": "Value field",
              "description": "Payload field name to compare against threshold (e.g. 'amount' on a RefundRequested event). v1.0 declarative only.",
              "tier": "internal"
            },
            "enabled": {
              "type": "boolean",
              "default": false,
              "label": "Require approval",
              "description": "Require sign-off before a record is finalized. Off by default.",
              "synonyms": "enable, turn on, enforce, require, activate, apply, switch on, approval, needs approval, sign-off, signed off, review before, gatekeeper, editor approval, publishing approval, draft approval, content review, requires approval, manager approval, supervisor approval, admin approval, before going live",
              "tier": "policy"
            },
            "escalationHours": {
              "type": "number",
              "default": 0.0,
              "label": "Escalation hours",
              "description": "Hours a request can sit pending before escalating. v1.0 declarative only; per-row escalation needs loop-with-emit primitive (gap).",
              "tier": "policy"
            },
            "approverRoles": {
              "type": "[string]",
              "default": [],
              "label": "Approver roles",
              "description": "Roles eligible to approve. The host application enforces role-gating on the page.",
              "tier": "policy",
              "items": {
                "type": "string"
              }
            },
            "autoApproveBelowThreshold": {
              "type": "boolean",
              "default": true,
              "label": "Auto-approve below threshold",
              "description": "Skip the review queue when the gated event's value is below the threshold. v1.0 declarative only.",
              "tier": "policy"
            },
            "escalationRoles": {
              "type": "[string]",
              "default": [],
              "label": "Escalation roles",
              "description": "Roles notified when a request escalates (compose sibling std-notify-on-event).",
              "tier": "policy",
              "items": {
                "type": "string"
              }
            },
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            },
            "threshold": {
              "type": "number",
              "default": 0.0,
              "label": "Auto-approve threshold",
              "description": "Below this value, requests should be auto-approved. v1.0 declarative only; wiring lands in v1.1 (gap).",
              "tier": "policy"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApprovalGateReviewPage",
          "path": "/approvals/queue",
          "traits": [
            {
              "ref": "ApprovalGateReview"
            }
          ]
        }
      ]
    }
  ]
}