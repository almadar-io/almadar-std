{
  "name": "std-flag",
  "version": "1.0.0",
  "description": "std-flag — user-initiated content flagging. Owns a Flag entity; SUBMIT persists @payload.data (targetId, targetType, reason, notes) and emits FlagSubmitted so cross-trait listeners (e.g. std-mod-queue) can react.",
  "orbitals": [
    {
      "name": "FlagOrbital",
      "entity": {
        "name": "Flag",
        "collection": "flags",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "reportedBy",
            "type": "string"
          },
          {
            "name": "reason",
            "type": "string",
            "default": "spam",
            "values": [
              "spam",
              "abuse",
              "off-topic",
              "misinformation",
              "nsfw",
              "other"
            ]
          },
          {
            "name": "notes",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FlagReport",
          "category": "interaction",
          "linkedEntity": "Flag",
          "emits": [
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "SELECT_REASON",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_NOTES",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FlagLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Flag]"
                }
              ]
            },
            {
              "event": "FlagLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FlagSubmitted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reportedBy",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FlagSubmitFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_REASON",
                "name": "Select Reason",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_NOTES",
                "name": "Edit Notes",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FlagLoaded",
                "name": "Flag loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Flag]"
                  }
                ]
              },
              {
                "key": "FlagLoadFailed",
                "name": "Flag load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "FlagSubmitted",
                "name": "Flag submitted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Flag"
                  }
                ]
              },
              {
                "key": "FlagSubmitFailed",
                "name": "Flag submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Flag",
                    {
                      "emit": {
                        "success": "FlagLoaded",
                        "failure": "FlagLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "content": "@config.title",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "type": "select",
                          "action": "SELECT_REASON",
                          "placeholder": "Select a reason",
                          "options": [
                            {
                              "value": "spam",
                              "label": "Spam"
                            },
                            {
                              "label": "Abuse",
                              "value": "abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "value": "misinformation",
                              "label": "Misinformation"
                            },
                            {
                              "value": "nsfw",
                              "label": "NSFW"
                            },
                            {
                              "value": "other",
                              "label": "Other"
                            }
                          ]
                        },
                        {
                          "placeholder": "Add details (optional)",
                          "type": "textarea",
                          "action": "EDIT_NOTES"
                        },
                        {
                          "type": "button",
                          "action": "SUBMIT",
                          "variant": "primary",
                          "label": "Submit report",
                          "icon": "flag"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT_REASON",
                "effects": [
                  [
                    "set",
                    "@entity.reason",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_NOTES",
                "effects": [
                  [
                    "set",
                    "@entity.notes",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FlagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@config.title"
                        },
                        {
                          "action": "SELECT_REASON",
                          "placeholder": "Select a reason",
                          "type": "select",
                          "options": [
                            {
                              "value": "spam",
                              "label": "Spam"
                            },
                            {
                              "label": "Abuse",
                              "value": "abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "value": "misinformation",
                              "label": "Misinformation"
                            },
                            {
                              "label": "NSFW",
                              "value": "nsfw"
                            },
                            {
                              "label": "Other",
                              "value": "other"
                            }
                          ]
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Add details (optional)",
                          "action": "EDIT_NOTES"
                        },
                        {
                          "icon": "flag",
                          "action": "SUBMIT",
                          "variant": "primary",
                          "label": "Submit report",
                          "type": "button"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FlagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Flag",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "FlagSubmitted",
                        "failure": "FlagSubmitFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Submitting your report…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "FlagSubmitted",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "color": "success"
                        },
                        {
                          "content": "Thanks. Our team will review this report.",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "error",
                "event": "FlagSubmitFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.reason",
                    "spam"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "@config.title"
                        },
                        {
                          "options": [
                            {
                              "value": "spam",
                              "label": "Spam"
                            },
                            {
                              "value": "abuse",
                              "label": "Abuse"
                            },
                            {
                              "value": "off-topic",
                              "label": "Off-topic"
                            },
                            {
                              "label": "Misinformation",
                              "value": "misinformation"
                            },
                            {
                              "value": "nsfw",
                              "label": "NSFW"
                            },
                            {
                              "value": "other",
                              "label": "Other"
                            }
                          ],
                          "type": "select",
                          "placeholder": "Select a reason",
                          "action": "SELECT_REASON"
                        },
                        {
                          "action": "EDIT_NOTES",
                          "placeholder": "Add details (optional)",
                          "type": "textarea"
                        },
                        {
                          "type": "button",
                          "label": "Submit report",
                          "variant": "primary",
                          "action": "SUBMIT",
                          "icon": "flag"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "@config.title"
                        },
                        {
                          "options": [
                            {
                              "label": "Spam",
                              "value": "spam"
                            },
                            {
                              "value": "abuse",
                              "label": "Abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "label": "Misinformation",
                              "value": "misinformation"
                            },
                            {
                              "label": "NSFW",
                              "value": "nsfw"
                            },
                            {
                              "value": "other",
                              "label": "Other"
                            }
                          ],
                          "action": "SELECT_REASON",
                          "type": "select",
                          "placeholder": "Select a reason"
                        },
                        {
                          "action": "EDIT_NOTES",
                          "placeholder": "Add details (optional)",
                          "type": "textarea"
                        },
                        {
                          "variant": "primary",
                          "action": "SUBMIT",
                          "label": "Submit report",
                          "type": "button",
                          "icon": "flag"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "reasons": {
              "type": "[string]",
              "default": [
                "spam",
                "abuse",
                "off-topic",
                "misinformation",
                "nsfw",
                "other"
              ],
              "label": "Reason options",
              "description": "Selectable reason codes shown to the reporter",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "default": "Report content",
              "label": "Form title",
              "description": "Heading shown above the flag-submission form"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FlagReportPage",
          "path": "/flags/report",
          "traits": [
            {
              "ref": "FlagReport"
            }
          ]
        }
      ]
    }
  ]
}