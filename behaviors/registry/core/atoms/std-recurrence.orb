{
  "name": "std-recurrence",
  "version": "2.1.0",
  "description": "std-recurrence — recurring-rule definition + upcoming runs (Stripe Subscriptions / Cron Hub style). The viewing state shows a plain-English rule sentence and the next N dated runs as an agenda timeline. Per-run exception modal supports skip / reschedule. Topology = loading / defining_rule / viewing / awaiting_exception_decision / cancelled / error.",
  "orbitals": [
    {
      "name": "RecurrenceOrbital",
      "entity": {
        "name": "RecurrenceView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "date",
            "type": "string",
            "default": ""
          },
          {
            "name": "occurrences",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "status": {
                  "name": "status",
                  "type": "string",
                  "required": false,
                  "values": [
                    "complete",
                    "active",
                    "pending",
                    "error"
                  ]
                },
                "date": {
                  "name": "date",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "rawStatus": {
                  "name": "rawStatus",
                  "type": "string",
                  "required": false,
                  "values": [
                    "scheduled",
                    "skipped",
                    "completed",
                    "rescheduled"
                  ]
                }
              }
            }
          },
          {
            "name": "frequency",
            "type": "string",
            "default": "weekly",
            "values": [
              "daily",
              "weekly",
              "monthly",
              "yearly"
            ]
          },
          {
            "name": "interval",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "startDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "endDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "endAfterCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "summaryText",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentOccurrenceId",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentOccurrenceDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentOccurrenceLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "rescheduleDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "skipReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RecurrenceEditor",
          "category": "interaction",
          "linkedEntity": "RecurrenceView",
          "emits": [
            {
              "event": "EDIT_RULE"
            },
            {
              "event": "SAVE_RULE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CANCEL_RULE"
            },
            {
              "event": "OPEN_EXCEPTION",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE_EXCEPTION"
            },
            {
              "event": "SKIP_OCCURRENCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESCHEDULE_OCCURRENCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "newDate",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_SCHEDULE"
            },
            {
              "event": "RESTART"
            },
            {
              "event": "RecurrenceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "RecurrenceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RecurrenceSaved",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "RecurrenceSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "defining_rule"
              },
              {
                "name": "awaiting_exception_decision"
              },
              {
                "name": "cancelled"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RecurrenceLoaded",
                "name": "Recurrence loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "RecurrenceLoadFailed",
                "name": "Recurrence load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RecurrenceSaved",
                "name": "Recurrence saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "RecurrenceSaveFailed",
                "name": "Recurrence save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EDIT_RULE",
                "name": "Edit Rule"
              },
              {
                "key": "OPEN_EXCEPTION",
                "name": "Open Exception",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_SCHEDULE",
                "name": "Cancel Schedule"
              },
              {
                "key": "SAVE_RULE",
                "name": "Save Rule",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL_RULE",
                "name": "Cancel Rule"
              },
              {
                "key": "SKIP_OCCURRENCE",
                "name": "Skip Occurrence",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESCHEDULE_OCCURRENCE",
                "name": "Reschedule Occurrence",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "newDate",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_EXCEPTION",
                "name": "Close Exception"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RecurrenceView",
                    {
                      "emit": {
                        "success": "RecurrenceLoaded",
                        "failure": "RecurrenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading schedule…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "RecurrenceLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.frequency",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "frequency",
                      "weekly"
                    ]
                  ],
                  [
                    "set",
                    "@entity.interval",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "interval",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.startDate",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "startDate",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.endDate",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "endDate",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.endAfterCount",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "endAfterCount",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.occurrences",
                    [
                      "array/map",
                      "@payload.data",
                      [
                        "fn",
                        "row",
                        {
                          "description": [
                            "object/get",
                            "@row",
                            "notes",
                            ""
                          ],
                          "status": "active",
                          "id": [
                            "object/get",
                            "@row",
                            "id",
                            ""
                          ],
                          "date": [
                            "object/get",
                            "@row",
                            "date",
                            ""
                          ],
                          "title": [
                            "object/get",
                            "@row",
                            "title",
                            "Occurrence"
                          ],
                          "rawStatus": "scheduled"
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "repeat"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            },
                            {
                              "variant": "success",
                              "type": "badge",
                              "label": "Active"
                            },
                            {
                              "icon": "settings",
                              "variant": "primary",
                              "label": "Edit rule",
                              "action": "EDIT_RULE",
                              "type": "button"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "look": "@config.cardLook",
                          "type": "card",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "gap": "xs",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "Repeats every",
                                      "color": "muted"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "@entity.interval",
                                      "weight": "bold"
                                    },
                                    {
                                      "type": "typography",
                                      "weight": "bold",
                                      "content": "@entity.frequency"
                                    }
                                  ]
                                },
                                {
                                  "children": [
                                    {
                                      "content": "Starts",
                                      "color": "muted",
                                      "type": "typography"
                                    },
                                    {
                                      "content": "@entity.startDate",
                                      "type": "typography",
                                      "weight": "bold"
                                    },
                                    {
                                      "content": "·",
                                      "color": "muted",
                                      "type": "typography"
                                    },
                                    {
                                      "color": "muted",
                                      "type": "typography",
                                      "content": "Ends"
                                    },
                                    {
                                      "type": "typography",
                                      "weight": "bold",
                                      "content": "@entity.endDate"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center",
                                  "gap": "xs"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs"
                            }
                          ]
                        },
                        {
                          "variant": "h4",
                          "type": "typography",
                          "content": "Next runs"
                        },
                        {
                          "type": "timeline",
                          "fields": [
                            "title",
                            "description",
                            "date",
                            "status"
                          ],
                          "entity": "@entity.occurrences",
                          "itemActions": [
                            {
                              "event": "OPEN_EXCEPTION",
                              "label": "Manage"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "End schedule",
                              "action": "CANCEL_SCHEDULE",
                              "icon": "x-circle",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RecurrenceLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Failed to load",
                      "message": "@entity.errorMessage",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "RecurrenceSaved",
                "effects": [
                  [
                    "fetch",
                    "RecurrenceView",
                    {
                      "emit": {
                        "success": "RecurrenceLoaded",
                        "failure": "RecurrenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RecurrenceSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Save failed",
                      "message": "@entity.errorMessage",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "defining_rule",
                "event": "EDIT_RULE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "icon": "arrow-left",
                              "type": "button",
                              "action": "CANCEL_RULE"
                            },
                            {
                              "type": "icon",
                              "name": "settings"
                            },
                            {
                              "content": "Edit recurrence rule",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "cancelEvent": "CANCEL_RULE",
                              "fields": "@config.formFields",
                              "submitEvent": "SAVE_RULE",
                              "entity": "@entity",
                              "type": "form-section",
                              "mode": "edit"
                            }
                          ],
                          "look": "@config.cardLook",
                          "type": "card"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "awaiting_exception_decision",
                "event": "OPEN_EXCEPTION",
                "effects": [
                  [
                    "set",
                    "@entity.currentOccurrenceId",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.currentOccurrenceDate",
                    "@payload.row.date"
                  ],
                  [
                    "set",
                    "@entity.currentOccurrenceLabel",
                    "@payload.row.title"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_EXCEPTION",
                              "icon": "arrow-left",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "calendar-clock"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.currentOccurrenceLabel",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.currentOccurrenceDate",
                              "type": "badge",
                              "variant": "primary"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "What would you like to do with this occurrence?"
                                },
                                {
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "actionPayload": {
                                        "id": "@entity.currentOccurrenceId"
                                      },
                                      "label": "Skip",
                                      "variant": "secondary",
                                      "type": "button",
                                      "action": "SKIP_OCCURRENCE",
                                      "icon": "skip-forward"
                                    },
                                    {
                                      "label": "Reschedule",
                                      "variant": "primary",
                                      "actionPayload": {
                                        "id": "@entity.currentOccurrenceId"
                                      },
                                      "icon": "calendar-clock",
                                      "type": "button",
                                      "action": "RESCHEDULE_OCCURRENCE"
                                    }
                                  ],
                                  "type": "stack",
                                  "align": "center",
                                  "direction": "horizontal"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "look": "@config.cardLook",
                          "type": "card"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "cancelled",
                "event": "CANCEL_SCHEDULE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "Schedule ended",
                          "variant": "h2",
                          "align": "center"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "type": "typography",
                          "align": "center",
                          "content": "This recurring schedule has been cancelled. No further occurrences will fire."
                        },
                        {
                          "type": "button",
                          "label": "Start a new schedule",
                          "action": "RESTART",
                          "icon": "rotate-ccw",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "defining_rule",
                "to": "loading",
                "event": "SAVE_RULE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "RecurrenceView",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "RecurrenceSaveFailed",
                        "success": "RecurrenceSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Saving rule…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "defining_rule",
                "to": "loading",
                "event": "CANCEL_RULE",
                "effects": [
                  [
                    "fetch",
                    "RecurrenceView",
                    {
                      "emit": {
                        "success": "RecurrenceLoaded",
                        "failure": "RecurrenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Cancelling…"
                    }
                  ]
                ]
              },
              {
                "from": "awaiting_exception_decision",
                "to": "loading",
                "event": "SKIP_OCCURRENCE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "RecurrenceView",
                    {
                      "id": "@payload.id",
                      "status": "skipped"
                    },
                    {
                      "emit": {
                        "failure": "RecurrenceSaveFailed",
                        "success": "RecurrenceSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Skipping…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "awaiting_exception_decision",
                "to": "loading",
                "event": "RESCHEDULE_OCCURRENCE",
                "effects": [
                  [
                    "set",
                    "@entity.rescheduleDate",
                    "@payload.newDate"
                  ],
                  [
                    "persist",
                    "update",
                    "RecurrenceView",
                    {
                      "date": "@payload.newDate",
                      "status": "rescheduled",
                      "id": "@payload.id"
                    },
                    {
                      "emit": {
                        "failure": "RecurrenceSaveFailed",
                        "success": "RecurrenceSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Rescheduling…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "awaiting_exception_decision",
                "to": "loading",
                "event": "CLOSE_EXCEPTION",
                "effects": [
                  [
                    "fetch",
                    "RecurrenceView",
                    {
                      "emit": {
                        "failure": "RecurrenceLoadFailed",
                        "success": "RecurrenceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Closing…"
                    }
                  ]
                ]
              },
              {
                "from": "cancelled",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "fetch",
                    "RecurrenceView",
                    {
                      "emit": {
                        "success": "RecurrenceLoaded",
                        "failure": "RecurrenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Schedule",
              "label": "Section title",
              "description": "Heading shown above the recurrence editor",
              "tier": "presentation"
            },
            "formFields": {
              "type": "[string]",
              "default": [
                "frequency",
                "interval",
                "startDate",
                "endDate",
                "endAfterCount"
              ],
              "label": "Rule fields",
              "description": "Inputs shown in the recurrence-rule definition form",
              "tier": "presentation",
              "items": {
                "type": "string"
              }
            },
            "cardLook": {
              "type": "string",
              "default": "elevated",
              "label": "Card look",
              "description": "Layer 2 visual treatment for cards rendered by this atom.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat-bordered",
                "borderless-divider",
                "ticket",
                "invoice",
                "chip",
                "tile-image-first"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RecurrencePage",
          "path": "/recurrence",
          "traits": [
            {
              "ref": "RecurrenceEditor"
            }
          ]
        }
      ]
    }
  ]
}