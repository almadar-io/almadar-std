{
  "name": "std-sidebar-meta",
  "version": "1.0.0",
  "description": "Right-rail meta panel — Linear/Jira/GitHub-style issue sidebar. Stacked label/value rows grouped with dividers. Standalone atom; fetches one SidebarRecord and renders inline.",
  "orbitals": [
    {
      "name": "SidebarMetaOrbital",
      "entity": {
        "name": "SidebarRecord",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true,
            "default": "Untitled"
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "in_progress",
              "closed"
            ]
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high"
            ]
          },
          {
            "name": "assignee",
            "type": "string",
            "default": ""
          },
          {
            "name": "reporter",
            "type": "string",
            "default": ""
          },
          {
            "name": "milestone",
            "type": "string",
            "default": ""
          },
          {
            "name": "labels",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SidebarMeta",
          "category": "interaction",
          "linkedEntity": "SidebarRecord",
          "emits": [
            {
              "event": "SidebarRecordLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "SidebarRecordLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SidebarRecordLoaded",
                "name": "SidebarRecord loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "SidebarRecordLoadFailed",
                "name": "SidebarRecord load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SidebarRecord",
                    {
                      "limit": 1.0,
                      "emit": {
                        "failure": "SidebarRecordLoadFailed",
                        "success": "SidebarRecordLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "SidebarRecordLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "id"
                    ]
                  ],
                  [
                    "set",
                    "@entity.title",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "title"
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "status"
                    ]
                  ],
                  [
                    "set",
                    "@entity.priority",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "priority"
                    ]
                  ],
                  [
                    "set",
                    "@entity.assignee",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "assignee"
                    ]
                  ],
                  [
                    "set",
                    "@entity.reporter",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "reporter"
                    ]
                  ],
                  [
                    "set",
                    "@entity.milestone",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "milestone"
                    ]
                  ],
                  [
                    "set",
                    "@entity.labels",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "labels"
                    ]
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "createdAt"
                    ]
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "updatedAt"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "padding": "md",
                      "type": "card",
                      "look": "flat-bordered",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "gap": "xs",
                              "children": [
                                {
                                  "content": "@entity.id",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.title",
                                  "type": "typography",
                                  "variant": "h4",
                                  "weight": "semibold"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "justify": "between",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Status",
                                  "type": "typography",
                                  "variant": "overline"
                                },
                                {
                                  "variant": "default",
                                  "label": "@entity.status",
                                  "type": "badge",
                                  "size": "sm"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "align": "center",
                              "justify": "between",
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Priority",
                                  "variant": "overline"
                                },
                                {
                                  "variant": "neutral",
                                  "type": "badge",
                                  "label": "@entity.priority",
                                  "size": "sm"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Assignee",
                                  "variant": "overline"
                                },
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "size": "xs",
                                      "type": "avatar",
                                      "name": "@entity.assignee"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": "@entity.assignee"
                                    }
                                  ],
                                  "direction": "horizontal"
                                }
                              ],
                              "type": "stack",
                              "gap": "xs",
                              "direction": "vertical"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "overline",
                                  "type": "typography",
                                  "content": "Reporter"
                                },
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "size": "xs",
                                      "type": "avatar",
                                      "name": "@entity.reporter"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "body",
                                      "content": "@entity.reporter"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "align": "center"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "justify": "between",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "content": "Milestone",
                                  "color": "muted",
                                  "variant": "overline",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.milestone",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "xs",
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Labels",
                                  "variant": "overline",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "label": "@entity.labels",
                                  "type": "badge",
                                  "variant": "neutral",
                                  "size": "sm"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "overline",
                                  "content": "Created",
                                  "color": "muted"
                                },
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "@entity.createdAt",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "justify": "between"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "overline",
                                  "content": "Updated",
                                  "color": "muted"
                                },
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "@entity.updatedAt",
                                  "variant": "caption"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "justify": "between"
                            }
                          ],
                          "gap": "md",
                          "direction": "vertical",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SidebarRecordLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Failed to load sidebar",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SidebarMetaPage",
          "path": "/sidebar-meta",
          "traits": [
            {
              "ref": "SidebarMeta"
            }
          ]
        }
      ]
    }
  ]
}