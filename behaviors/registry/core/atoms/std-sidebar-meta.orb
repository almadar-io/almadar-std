{
  "name": "std-sidebar-meta",
  "version": "1.0.0",
  "description": "Right-rail meta panel — Linear/Jira/GitHub-style issue sidebar. Stacked label/value rows grouped with dividers. Standalone atom; fetches one SidebarRecord and renders inline.",
  "orbitals": [
    {
      "name": "SidebarMetaOrbital",
      "entity": {
        "name": "SidebarRecord",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true,
            "default": "Untitled",
            "description": "The descriptive name of the record.",
            "synonyms": "name, heading, subject"
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "in_progress",
              "closed"
            ],
            "description": "Current state of the record.",
            "synonyms": "state, condition, phase"
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high"
            ],
            "description": "Indicates the level of importance or urgency.",
            "synonyms": "severity, importance, urgency"
          },
          {
            "name": "assignee",
            "type": "string",
            "default": "",
            "description": "The user currently responsible for the item.",
            "synonyms": "owner, responsible, assignedTo"
          },
          {
            "name": "reporter",
            "type": "string",
            "default": "",
            "description": "The user who initially reported the item.",
            "synonyms": "owner, submitter, creator"
          },
          {
            "name": "milestone",
            "type": "string",
            "default": "",
            "description": "The target date for completing related work.",
            "synonyms": "due date, target date, completion date"
          },
          {
            "name": "labels",
            "type": "string",
            "default": "",
            "description": "A collection of descriptive tags or categories.",
            "synonyms": "tags, categories, keywords, markers"
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": "",
            "description": "Error message associated with the record.",
            "synonyms": "error, fault, issue"
          }
        ]
      },
      "traits": [
        {
          "name": "SidebarMeta",
          "category": "interaction",
          "linkedEntity": "SidebarRecord",
          "emits": [
            {
              "event": "SidebarRecordLoaded",
              "description": "Signals successful retrieval of data for the sidebar.",
              "synonyms": "loaded, fetched, received, updated",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "SidebarRecordLoadFailed",
              "description": "Indicates failure to load the sidebar record.",
              "synonyms": "error, failed, problem, unsuccessful",
              "tier": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SidebarRecordLoaded",
                "name": "SidebarRecord loaded",
                "description": "Signals successful retrieval of data for the sidebar.",
                "synonyms": "loaded, fetched, received, updated",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "SidebarRecordLoadFailed",
                "name": "SidebarRecord load failed",
                "description": "Indicates failure to load the sidebar record.",
                "synonyms": "error, failed, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SidebarRecord",
                    {
                      "emit": {
                        "success": "SidebarRecordLoaded",
                        "failure": "SidebarRecordLoadFailed"
                      },
                      "limit": 1.0
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Loading…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "SidebarRecordLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "id"
                    ]
                  ],
                  [
                    "set",
                    "@entity.title",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "title"
                    ]
                  ],
                  [
                    "set",
                    "@entity.status",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "status"
                    ]
                  ],
                  [
                    "set",
                    "@entity.priority",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "priority"
                    ]
                  ],
                  [
                    "set",
                    "@entity.assignee",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "assignee"
                    ]
                  ],
                  [
                    "set",
                    "@entity.reporter",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "reporter"
                    ]
                  ],
                  [
                    "set",
                    "@entity.milestone",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "milestone"
                    ]
                  ],
                  [
                    "set",
                    "@entity.labels",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "labels"
                    ]
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "createdAt"
                    ]
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    [
                      "object/get",
                      [
                        "array/first",
                        "@payload.data"
                      ],
                      "updatedAt"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "padding": "md",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "@entity.id",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "weight": "semibold",
                                  "content": "@entity.title",
                                  "variant": "h4",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "xs"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "justify": "between",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Status",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "overline"
                                },
                                {
                                  "size": "sm",
                                  "variant": "default",
                                  "type": "badge",
                                  "label": "@entity.status"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "justify": "between",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "overline",
                                  "content": "Priority",
                                  "color": "muted"
                                },
                                {
                                  "size": "sm",
                                  "label": "@entity.priority",
                                  "type": "badge",
                                  "variant": "neutral"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "overline",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Assignee"
                                },
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "@entity.assignee",
                                      "size": "xs",
                                      "type": "avatar"
                                    },
                                    {
                                      "content": "@entity.assignee",
                                      "variant": "body",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm"
                                }
                              ],
                              "gap": "xs"
                            },
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "overline",
                                  "content": "Reporter",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "gap": "sm",
                                  "children": [
                                    {
                                      "type": "avatar",
                                      "size": "xs",
                                      "name": "@entity.reporter"
                                    },
                                    {
                                      "variant": "body",
                                      "content": "@entity.reporter",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "align": "center",
                                  "type": "stack"
                                }
                              ],
                              "gap": "xs"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "direction": "horizontal",
                              "justify": "between",
                              "children": [
                                {
                                  "content": "Milestone",
                                  "type": "typography",
                                  "variant": "overline",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.milestone"
                                }
                              ],
                              "align": "center",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "variant": "overline",
                                  "color": "muted",
                                  "content": "Labels",
                                  "type": "typography"
                                },
                                {
                                  "size": "sm",
                                  "label": "@entity.labels",
                                  "type": "badge",
                                  "variant": "neutral"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "justify": "between",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Created",
                                  "variant": "overline"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "@entity.createdAt"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "overline",
                                  "color": "muted",
                                  "content": "Updated"
                                },
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "@entity.updatedAt"
                                }
                              ],
                              "justify": "between",
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "look": "flat-bordered",
                      "type": "card"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SidebarRecordLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "title": "Failed to load sidebar",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SidebarMetaPage",
          "path": "/sidebar-meta",
          "traits": [
            {
              "ref": "SidebarMeta"
            }
          ]
        }
      ]
    }
  ]
}
