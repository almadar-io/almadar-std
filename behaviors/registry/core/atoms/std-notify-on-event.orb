{
  "name": "std-notify-on-event",
  "version": "1.1.0",
  "description": "std-notify-on-event — event-driven notification dispatcher. Listens for the generic `EventOccurred` sentinel (rename via traitOverrides.events to the real event, e.g. ContactSaved). Resolves recipient from `recipients` (first entry; fan-out is a future extension) or falls back to `@user.id`. Skips dispatch when the recipient is in `suppressionList`. Emits in-app `notify` when `notifyChannel` is `\"in-app\"`, or persists a `NotificationRecord` row for out-of-band delivery when channel is `\"email\"` or `\"sms\"`.",
  "orbitals": [
    {
      "name": "NotifyOnEventOrbital",
      "entity": {
        "name": "NotificationRecord",
        "collection": "notifications",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "recipient",
            "type": "string",
            "default": ""
          },
          {
            "name": "channel",
            "type": "string",
            "default": "in-app"
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "severity",
            "type": "string",
            "default": "info"
          },
          {
            "name": "dispatched",
            "type": "boolean",
            "default": false
          },
          {
            "name": "recordedAt",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "NotifyOnEventListener",
          "category": "lifecycle",
          "linkedEntity": "NotificationRecord",
          "emits": [
            {
              "event": "NotificationDispatched",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "recipient",
                  "type": "string"
                },
                {
                  "name": "channel",
                  "type": "string"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "severity",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "EventOccurred",
                "name": "Event occurred",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "NotificationDispatched",
                "name": "Notification dispatched",
                "payloadSchema": [
                  {
                    "name": "recipient",
                    "type": "string"
                  },
                  {
                    "name": "channel",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "severity",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "EventOccurred",
                "effects": [
                  [
                    "set",
                    "@entity.recipient",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.recipients"
                        ],
                        0.0
                      ],
                      "@user.id",
                      [
                        "array/first",
                        "@config.recipients"
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.channel",
                    "@config.notifyChannel"
                  ],
                  [
                    "set",
                    "@entity.message",
                    "@config.template"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    "@config.severity"
                  ],
                  [
                    "set",
                    "@entity.dispatched",
                    [
                      "and",
                      [
                        "=",
                        "@config.notifyChannel",
                        "in-app"
                      ],
                      [
                        "not",
                        [
                          "array/includes",
                          "@config.suppressionList",
                          "@entity.recipient"
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.recordedAt",
                    0.0
                  ],
                  [
                    "when",
                    [
                      "not",
                      [
                        "array/includes",
                        "@config.suppressionList",
                        "@entity.recipient"
                      ]
                    ],
                    [
                      "if",
                      [
                        "=",
                        "@config.notifyChannel",
                        "in-app"
                      ],
                      [
                        "notify",
                        "@config.severity",
                        "@config.template"
                      ],
                      [
                        "persist",
                        "create",
                        "NotificationRecord",
                        {
                          "recipient": "@entity.recipient",
                          "message": "@config.template",
                          "channel": "@config.notifyChannel",
                          "severity": "@config.severity",
                          "dispatched": false,
                          "recordedAt": 0.0
                        }
                      ]
                    ]
                  ],
                  [
                    "emit",
                    "NotificationDispatched",
                    {
                      "severity": "@config.severity",
                      "message": "@config.template",
                      "recipient": "@entity.recipient",
                      "channel": "@config.notifyChannel"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "notifyChannel": {
              "type": "string",
              "default": "in-app",
              "label": "Channel",
              "description": "Delivery channel: in-app, email, or sms",
              "tier": "domain"
            },
            "suppressionList": {
              "type": "[string]",
              "default": [],
              "label": "Suppression list",
              "description": "Recipient ids/addresses to skip (e.g. unsubscribed users). Suppression check runs before dispatch.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "frequencyCapPerWeek": {
              "type": "number",
              "default": 0.0,
              "label": "Frequency cap (per week)",
              "description": "Max sends per (channel, recipient) per rolling 7-day window. 0 = uncapped. WIRING DEFERRED: needs stateful history query (gap — docs/Almadar_Std_Factories.md).",
              "tier": "domain"
            },
            "severity": {
              "type": "string",
              "default": "info",
              "label": "Severity",
              "description": "info, success, warning, or error — controls styling",
              "tier": "domain"
            },
            "template": {
              "type": "string",
              "default": "",
              "label": "Message template",
              "description": "Text shown to the recipient; supports payload interpolation",
              "tier": "presentation"
            },
            "listensFor": {
              "type": "[string]",
              "default": [],
              "label": "Trigger events",
              "description": "Event names that should fire a notification",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "quietHours": {
              "type": "QuietHoursSpec",
              "default": {
                "end": "",
                "start": ""
              },
              "label": "Quiet hours",
              "description": "Local-time window during which dispatch is suppressed. Both start and end required to activate. WIRING DEFERRED: needs @now-aware time comparison primitive (gap — docs/Almadar_Std_Factories.md).",
              "tier": "domain",
              "properties": {
                "start": {
                  "name": "start",
                  "type": "string",
                  "required": false
                },
                "end": {
                  "name": "end",
                  "type": "string",
                  "required": false
                }
              }
            },
            "recipients": {
              "type": "[string]",
              "default": [],
              "label": "Recipients",
              "description": "Recipient ids/addresses. v1.1 uses the first entry; multi-recipient fan-out lands in v1.2 (gap). When empty, falls back to the authenticated user.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "NotifyOnEventPage",
          "path": "/notify-on-event",
          "traits": [
            {
              "ref": "NotifyOnEventListener"
            }
          ]
        }
      ]
    }
  ]
}