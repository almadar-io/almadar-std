{
  "name": "std-tabs",
  "version": "2.1.0",
  "description": "std-tabs — embeddable tab-navigation atom. Renders a tabs strip from @config.tabs ([{id, label, icon?, badge?, content?}]); clicking a tab updates @entity.activeTab so only the matching @trait.X content shows. Events remap at the call site for routing, persistence, analytics.",
  "orbitals": [
    {
      "name": "TabsItemOrbital",
      "entity": {
        "name": "TabsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "activeTab",
            "type": "string",
            "default": ""
          },
          {
            "name": "items",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string",
                  "required": true
                },
                "badge": {
                  "name": "badge",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                "icon": {
                  "name": "icon",
                  "type": "string",
                  "required": false
                },
                "content": {
                  "name": "content",
                  "type": "trait",
                  "required": false
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "TabsItemTabs",
          "category": "interaction",
          "linkedEntity": "TabsItem",
          "emits": [
            {
              "event": "TAB_CHANGED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TAB_CHANGED",
                "name": "Tab Changed",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.tabs"
                  ],
                  [
                    "set",
                    "@entity.activeTab",
                    "@config.defaultTab"
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TAB_CHANGED",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    "@config.tabs"
                  ],
                  [
                    "set",
                    "@entity.activeTab",
                    "@payload.tabId"
                  ],
                  [
                    "render-ui",
                    "main",
                    "@config.bodyContent"
                  ]
                ]
              }
            ]
          },
          "config": {
            "bodyContent": {
              "type": "render-ui",
              "default": {
                "orientation": "@config.orientation",
                "tabChangeEvent": "TAB_CHANGED",
                "activeTab": "@entity.activeTab",
                "items": "@entity.items",
                "variant": "@config.variant",
                "type": "tabs"
              },
              "label": "Body content tree",
              "description": "Render-ui SExpr rendered for the tabs surface. Default is the canonical tabs pattern bound to @entity.items / @entity.activeTab. Layer 3 variants override this with their own tree (segmented-pill bar, vertical sidebar rail, etc.) while inheriting the same trait, state machine, emits, and listens.",
              "tier": "internal"
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "label": "Orientation",
              "description": "Horizontal strip or vertical rail layout",
              "tier": "presentation",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "variant": {
              "type": "string",
              "default": "default",
              "label": "Tab style",
              "description": "Visual style of the tab strip",
              "tier": "presentation",
              "values": [
                "default",
                "pills",
                "underline"
              ]
            },
            "defaultTab": {
              "type": "string",
              "default": "overview",
              "label": "Default tab",
              "description": "Tab id selected on first render",
              "tier": "presentation"
            },
            "tabs": {
              "type": "[TabSpec]",
              "default": [
                {
                  "icon": "info",
                  "label": "Overview",
                  "id": "overview"
                },
                {
                  "icon": "list",
                  "id": "details",
                  "label": "Details"
                },
                {
                  "id": "settings",
                  "icon": "settings",
                  "label": "Settings"
                }
              ],
              "label": "Tabs",
              "description": "Tab entries with id, label, icon, badge, and optional content trait",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "content": {
                    "name": "content",
                    "type": "trait",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TabsItemTabsPage",
          "path": "/tabsitems",
          "traits": [
            {
              "ref": "TabsItemTabs"
            }
          ]
        }
      ]
    }
  ]
}