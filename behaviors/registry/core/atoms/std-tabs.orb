{
  "name": "std-tabs",
  "version": "1.0.0",
  "description": "std-tabs as a Function",
  "orbitals": [
    {
      "name": "TabContentOrbital",
      "entity": {
        "name": "TabContent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TabContentTabs",
          "category": "interaction",
          "linkedEntity": "TabContent",
          "emits": [
            {
              "event": "TabContentLoaded",
              "description": "Fired when TabContent finishes loading; payload.data holds the list",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[TabContent]"
                }
              ]
            },
            {
              "event": "TabContentLoadFailed",
              "description": "Fired when TabContent fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TabContentLoaded",
                "name": "TabContent loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[TabContent]"
                  }
                ]
              },
              {
                "key": "TabContentLoadFailed",
                "name": "TabContent load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TAB",
                "name": "Select Tab",
                "payload": [
                  {
                    "name": "tab",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TabContent",
                    {
                      "emit": {
                        "failure": "TabContentLoadFailed",
                        "success": "TabContentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "TabContentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "layout-grid"
                            },
                            {
                              "content": "TabContents",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "tabs": [
                            {
                              "id": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "id": "description"
                            },
                            {
                              "label": "Status",
                              "id": "status"
                            },
                            {
                              "label": "CreatedAt",
                              "id": "createdAt"
                            }
                          ],
                          "type": "tabs",
                          "defaultActiveTab": "name",
                          "onTabChange": "SELECT_TAB"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "h4",
                                  "content": "@item.name",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "@item.description"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "className": "transition-shadow hover:shadow-md cursor-pointer"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TabContentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "label": "Retry",
                          "action": "INIT",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "SELECT_TAB",
                "effects": [
                  [
                    "fetch",
                    "TabContent",
                    {
                      "emit": {
                        "success": "TabContentLoaded",
                        "failure": "TabContentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TabContent",
                    {
                      "emit": {
                        "failure": "TabContentLoadFailed",
                        "success": "TabContentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TabContentTabsPage",
          "path": "/tabcontents",
          "traits": [
            {
              "ref": "TabContentTabs"
            }
          ]
        }
      ]
    }
  ]
}