{
  "name": "std-cache-aside",
  "version": "1.0.0",
  "description": "std-cache-aside as a Function",
  "orbitals": [
    {
      "name": "CacheEntryOrbital",
      "entity": {
        "name": "CacheEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "hitCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "cacheAge",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "CacheEntryCacheManager",
          "category": "interaction",
          "linkedEntity": "CacheEntry",
          "emits": [
            {
              "event": "CacheEntryLoaded",
              "description": "Fired when CacheEntry finishes loading; payload.data holds the entries",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CacheEntry]"
                }
              ]
            },
            {
              "event": "CacheEntryLoadFailed",
              "description": "Fired when CacheEntry fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CacheEntryUpdated",
              "description": "Fired when persist update succeeds",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CacheEntryUpdateFailed",
              "description": "Fired when persist update fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "empty",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "cached"
              },
              {
                "name": "stale"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FETCH",
                "name": "Fetch"
              },
              {
                "key": "CacheEntryLoaded",
                "name": "CacheEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CacheEntry]"
                  }
                ]
              },
              {
                "key": "CacheEntryLoadFailed",
                "name": "CacheEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INVALIDATE",
                "name": "Invalidate"
              },
              {
                "key": "CACHED",
                "name": "Cached",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "CacheEntry"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "CacheEntryUpdated",
                "name": "CacheEntry updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CacheEntryUpdateFailed",
                "name": "CacheEntry update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "empty",
                "to": "empty",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "database",
                                  "type": "icon"
                                },
                                {
                                  "content": "Cache (empty)",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "icon": "download",
                              "type": "button",
                              "label": "Fetch",
                              "action": "FETCH",
                              "variant": "primary"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "title": "Cache is empty",
                          "description": "Fetch data to populate the cache.",
                          "type": "empty-state",
                          "icon": "inbox"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "empty",
                "to": "loading",
                "event": "FETCH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "success": "CacheEntryLoaded",
                        "failure": "CacheEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Fetching cache…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "cached",
                "event": "CacheEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "database"
                                },
                                {
                                  "content": "Cache (hot)",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "label": "Cached",
                                  "pulse": false,
                                  "type": "status-dot",
                                  "status": "online"
                                },
                                {
                                  "action": "INVALIDATE",
                                  "type": "button",
                                  "variant": "ghost",
                                  "icon": "trash",
                                  "label": "Invalidate"
                                }
                              ]
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "align": "center",
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "type": "icon",
                                          "name": "database"
                                        },
                                        {
                                          "variant": "h4",
                                          "type": "typography",
                                          "content": "@item.name"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "badge",
                                      "label": "@item.description"
                                    }
                                  ],
                                  "justify": "between",
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "typography",
                                  "content": "@item.status",
                                  "variant": "caption"
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CacheEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to load",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "variant": "primary",
                          "action": "FETCH"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "cached",
                "to": "stale",
                "event": "INVALIDATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "database",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Cache (stale)",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "gap": "sm",
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "label": "Stale",
                                  "pulse": true,
                                  "type": "status-dot",
                                  "status": "warning"
                                },
                                {
                                  "label": "Refresh",
                                  "variant": "primary",
                                  "icon": "refresh-cw",
                                  "action": "REFRESH",
                                  "type": "button"
                                }
                              ]
                            }
                          ],
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "warning",
                          "message": "Cache data is stale. Refresh to get the latest data."
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "cached",
                "to": "loading",
                "event": "CACHED",
                "effects": [
                  [
                    "persist",
                    "update",
                    "CacheEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CacheEntryUpdated",
                        "failure": "CacheEntryUpdateFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "failure": "CacheEntryLoadFailed",
                        "success": "CacheEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "stale",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "success": "CacheEntryLoaded",
                        "failure": "CacheEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "stale",
                "to": "loading",
                "event": "FETCH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "success": "CacheEntryLoaded",
                        "failure": "CacheEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "empty",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "inbox",
                      "type": "empty-state",
                      "description": "Fetch data to populate the cache.",
                      "title": "Cache is empty"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "FETCH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "success": "CacheEntryLoaded",
                        "failure": "CacheEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "ttlSeconds": {
              "type": "number",
              "default": 300.0,
              "label": "TTL (seconds)",
              "description": "Cache entry time-to-live before it goes stale. Default 5 minutes.",
              "synonyms": "expiration, time to live, cache duration",
              "tier": "domain"
            },
            "evictionPolicy": {
              "type": "string",
              "default": "lru",
              "label": "Eviction policy",
              "description": "How entries are evicted when the cache fills: least-recently-used, least-frequently-used, first-in-first-out, or TTL-only (never evict early).",
              "synonyms": "cache replacement, eviction strategy",
              "tier": "domain",
              "values": [
                "lru",
                "lfu",
                "fifo",
                "ttl-only"
              ]
            },
            "staleWhileRevalidate": {
              "type": "boolean",
              "default": true,
              "label": "Serve stale while revalidating",
              "description": "When true, serve stale entries to consumers while a background refresh fetches fresh data. Reduces latency at the cost of brief staleness.",
              "synonyms": "SWR, stale serving",
              "tier": "domain"
            },
            "maxCacheSize": {
              "type": "number",
              "default": 1000.0,
              "label": "Max cache entries",
              "description": "Hard cap on cached entries before eviction. 0 = unlimited.",
              "synonyms": "cache capacity, max entries",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CacheEntryPage",
          "path": "/cacheentrys",
          "traits": [
            {
              "ref": "CacheEntryCacheManager"
            }
          ]
        }
      ]
    }
  ]
}