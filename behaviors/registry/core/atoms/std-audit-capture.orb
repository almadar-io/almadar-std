{
  "name": "std-audit-capture",
  "version": "1.1.0",
  "description": "std-audit-capture — event-interceptor audit log. Listens for the generic `EntityMutated` sentinel (rename via traitOverrides.events to the real mutation event, e.g. ContactSaved) and persists an AuditEntry row capturing actor, action, entity type/id, before/after snapshots, and timestamp. `captureEventTypes` filters on @payload.data.kind (empty = capture all). Compose with `std-lifecycle` to apply retention. Composable via `extraTraits` to interpose audit logging behind any mutating trait.",
  "orbitals": [
    {
      "name": "AuditCaptureOrbital",
      "entity": {
        "name": "AuditEntry",
        "collection": "audit_entries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "actor",
            "type": "string",
            "default": ""
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "entityType",
            "type": "string",
            "default": ""
          },
          {
            "name": "entityId",
            "type": "string",
            "default": ""
          },
          {
            "name": "before",
            "type": "object",
            "default": {}
          },
          {
            "name": "after",
            "type": "object",
            "default": {}
          },
          {
            "name": "recordedAt",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AuditCaptureListener",
          "entityRebindable": true,
          "entityContract": {
            "provides": [
              "action",
              "actor",
              "after",
              "before",
              "entityId",
              "entityType",
              "recordedAt"
            ]
          },
          "category": "lifecycle",
          "capabilities": [
            "audit",
            "compliance"
          ],
          "linkedEntity": "AuditEntry",
          "emits": [
            {
              "event": "AuditRecorded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "actor",
                  "type": "string"
                },
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "entityType",
                  "type": "string"
                },
                {
                  "name": "entityId",
                  "type": "string"
                },
                {
                  "name": "recordedAt",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "EntityMutated",
                "name": "Entity mutated",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "AuditRecorded",
                "name": "Audit recorded",
                "payloadSchema": [
                  {
                    "name": "actor",
                    "type": "string"
                  },
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "entityType",
                    "type": "string"
                  },
                  {
                    "name": "entityId",
                    "type": "string"
                  },
                  {
                    "name": "recordedAt",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "EntityMutated",
                "effects": [
                  [
                    "when",
                    [
                      "or",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.captureEventTypes"
                        ],
                        0.0
                      ],
                      [
                        "array/includes",
                        "@config.captureEventTypes",
                        [
                          "object/get",
                          "@payload.data",
                          "kind",
                          ""
                        ]
                      ]
                    ],
                    [
                      "do",
                      [
                        "set",
                        "@entity.actor",
                        "@user.id"
                      ],
                      [
                        "set",
                        "@entity.action",
                        [
                          "object/get",
                          "@payload.data",
                          "kind",
                          "EntityMutated"
                        ]
                      ],
                      [
                        "set",
                        "@entity.entityType",
                        "@config.captureEntity"
                      ],
                      [
                        "set",
                        "@entity.entityId",
                        [
                          "object/get",
                          "@payload.data",
                          "id",
                          ""
                        ]
                      ],
                      [
                        "set",
                        "@entity.before",
                        [
                          "if",
                          "@config.captureBeforeAfter",
                          [
                            "object/get",
                            "@payload.data",
                            "before",
                            {}
                          ],
                          {}
                        ]
                      ],
                      [
                        "set",
                        "@entity.after",
                        [
                          "if",
                          "@config.captureBeforeAfter",
                          [
                            "object/get",
                            "@payload.data",
                            "after",
                            {}
                          ],
                          {}
                        ]
                      ],
                      [
                        "set",
                        "@entity.recordedAt",
                        0.0
                      ],
                      [
                        "persist",
                        "create",
                        "AuditEntry",
                        {
                          "recordedAt": 0.0,
                          "entityType": "@config.captureEntity",
                          "entityId": "@entity.entityId",
                          "action": "@entity.action",
                          "before": "@entity.before",
                          "after": "@entity.after",
                          "actor": "@user.id"
                        }
                      ],
                      [
                        "emit",
                        "AuditRecorded",
                        {
                          "entityId": "@entity.entityId",
                          "recordedAt": 0.0,
                          "entityType": "@config.captureEntity",
                          "actor": "@user.id",
                          "action": "@entity.action"
                        }
                      ]
                    ]
                  ]
                ]
              }
            ]
          },
          "config": {
            "captureEventTypes": {
              "type": "[string]",
              "default": [],
              "label": "Event-kind filter",
              "description": "When set, only @payload.data.kind values in this list are audited. Empty list = capture every event. Requires the upstream event to include a `kind` field on its payload.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "captureBeforeAfter": {
              "type": "boolean",
              "default": false,
              "label": "Capture before/after snapshots",
              "description": "When true, persist `before` and `after` object snapshots from @payload.data on each audit row. Default off to keep audit rows small.",
              "tier": "domain"
            },
            "excludeFields": {
              "type": "[string]",
              "default": [],
              "label": "Skip fields",
              "description": "Entity fields to omit from the audit payload (declarative; before/after still capture all fields in v1.1 — field exclusion lands when captureBeforeAfter wiring filters per-field).",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "retentionDays": {
              "type": "number",
              "default": 2555.0,
              "label": "Retention (days)",
              "description": "Days to keep audit rows. Default 2555 (7 years) for typical compliance regimes. WIRING DEFERRED: retention enforcement requires composing `std-lifecycle` against AuditEntry with a delete rule (gap — docs/Almadar_Std_Factories.md).",
              "tier": "domain"
            },
            "captureEntity": {
              "type": "string",
              "default": "",
              "label": "Entity to audit",
              "description": "Type name of the entity whose mutations get logged",
              "tier": "domain"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AuditCapturePage",
          "path": "/audit-capture",
          "traits": [
            {
              "ref": "AuditCaptureListener"
            }
          ]
        }
      ]
    }
  ]
}