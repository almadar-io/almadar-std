                "priority"
              ]
            },
            "step2Label": {
              "type": "string",
              "default": "Options"
            },
            "step1Fields": {
              "type": "[string]",
              "default": [
                "title",
                "description"
              ]
            },
            "step2Key": {
              "type": "string",
              "default": "options"
            },
            "step3Desc": {
              "type": "string",
              "default": "Confirm and submit"
            },
            "step1Key": {
              "type": "string",
              "default": "details"
            },
            "step2Icon": {
              "type": "string",
              "default": "settings"
            },
            "step2Desc": {
              "type": "string",
              "default": "Configure preferences"
            },
            "step3Label": {
              "type": "string",
              "default": "Review"
            },
            "step3Key": {
              "type": "string",
              "default": "review"
            },
            "step1Icon": {
              "type": "string",
              "default": "file-text"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WizardPage",
          "path": "/wizard",
          "traits": [
            {
              "ref": "WizardForm"
            }
          ]
        }
      ]
    }
  ]
