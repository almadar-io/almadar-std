{
  "name": "std-wizard",
  "version": "3.0.0",
  "description": "std-wizard — generic N-step data-collection wizard (Vercel deploy / GitHub repo create / Stripe Connect onboarding style). Each step has its own form fields. Topology = loading / running / completed / cancelled / error. ADVANCE is guard-routed: not-last-step advances; last-step transitions to completed. Distinct from std-step-flow (approval-decision) — wizard collects data via form-section per step, step-flow collects yes/no decisions.",
  "orbitals": [
    {
      "name": "WizardOrbital",
      "entity": {
        "name": "WizardView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": "",
            "values": [
              "marketing",
              "engineering",
              "design",
              "operations",
              ""
            ]
          },
          {
            "name": "priority",
            "type": "string",
            "default": "",
            "values": [
              "low",
              "medium",
              "high",
              "urgent",
              ""
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "wizardSteps",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "name": "title",
                  "type": "string",
                  "required": true
                },
                "description": {
                  "name": "description",
                  "type": "string",
                  "required": false
                },
                "id": {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              }
            }
          },
          {
            "name": "currentStepIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "currentStepLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "currentStepIcon",
            "type": "string",
            "default": "circle"
          },
          {
            "name": "currentFields",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "isFirstStep",
            "type": "boolean",
            "default": true
          },
          {
            "name": "isLastStep",
            "type": "boolean",
            "default": false
          },
          {
            "name": "primaryActionLabel",
            "type": "string",
            "default": "Next"
          },
          {
            "name": "primaryActionIcon",
            "type": "string",
            "default": "chevron-right"
          },
          {
            "name": "completionMessage",
            "type": "string",
            "default": ""
          },
          {
            "name": "cancelReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "WizardForm",
          "category": "interaction",
          "linkedEntity": "WizardView",
          "emits": [
            {
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "RETREAT"
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESTART"
            },
            {
              "event": "WizardLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ObjectSpec]"
                }
              ]
            },
            {
              "event": "WizardLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WizardSaved",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "object"
                }
              ]
            },
            {
              "event": "WizardSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "completed"
              },
              {
                "name": "cancelled"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WizardLoaded",
                "name": "Wizard loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "key": "WizardLoadFailed",
                "name": "Wizard load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "WizardSaved",
                "name": "Wizard saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "WizardSaveFailed",
                "name": "Wizard save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "RETREAT",
                "name": "Retreat"
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardView",
                    {
                      "emit": {
                        "success": "WizardLoaded",
                        "failure": "WizardLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading wizard…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "WizardLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    [
                      "array/len",
                      "@config.steps"
                    ]
                  ],
                  [
                    "set",
                    "@entity.wizardSteps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "title": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "id": [
                            "object/get",
                            "@step",
                            "key"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "icon",
                      "circle"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentFields",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        0.0
                      ],
                      "fields",
                      []
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    true
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      [
                        "array/len",
                        "@config.steps"
                      ],
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "Submit",
                      "Next"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        [
                          "array/len",
                          "@config.steps"
                        ],
                        1.0
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "list-checks",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "currentStep": "@entity.currentStepIndex",
                          "allowNavigation": false,
                          "type": "wizard-progress",
                          "steps": "@entity.wizardSteps"
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "@entity.currentStepIcon",
                                      "type": "icon",
                                      "size": "lg"
                                    },
                                    {
                                      "direction": "vertical",
                                      "type": "stack",
                                      "gap": "xs",
                                      "children": [
                                        {
                                          "variant": "h2",
                                          "type": "typography",
                                          "content": "@entity.currentStepLabel"
                                        },
                                        {
                                          "content": "@entity.currentStepDescription",
                                          "variant": "body",
                                          "type": "typography",
                                          "color": "muted"
                                        }
                                      ]
                                    }
                                  ],
                                  "direction": "horizontal"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "showCancel": false,
                                  "showSubmit": false,
                                  "submitEvent": "ADVANCE",
                                  "cancelEvent": "CANCEL",
                                  "fields": "@entity.currentFields",
                                  "entity": "@entity",
                                  "type": "form-section",
                                  "mode": "edit"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "icon": "chevron-left",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "RETREAT",
                              "disabled": "@entity.isFirstStep",
                              "type": "button"
                            },
                            {
                              "label": "Cancel wizard",
                              "variant": "ghost",
                              "action": "CANCEL",
                              "type": "button",
                              "icon": "x"
                            },
                            {
                              "action": "ADVANCE",
                              "label": "@entity.primaryActionLabel",
                              "type": "button",
                              "icon": "@entity.primaryActionIcon",
                              "variant": "primary"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WizardLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Failed to load",
                      "type": "error-state",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "WizardSaved",
                "effects": [
                  [
                    "fetch",
                    "WizardView",
                    {
                      "emit": {
                        "success": "WizardLoaded",
                        "failure": "WizardLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Refreshing…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WizardSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Save failed",
                      "message": "@entity.errorMessage",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "ADVANCE",
                "guard": [
                  "not",
                  "@entity.isLastStep"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "+",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "icon",
                      "circle"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentFields",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "fields",
                      []
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      [
                        "-",
                        "@entity.totalSteps",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "Submit",
                      "Next"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "currentStep": "@entity.currentStepIndex",
                          "steps": "@entity.wizardSteps",
                          "type": "wizard-progress",
                          "allowNavigation": false
                        },
                        {
                          "type": "card",
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "@entity.currentStepIcon",
                                      "size": "lg",
                                      "type": "icon"
                                    },
                                    {
                                      "gap": "xs",
                                      "type": "stack",
                                      "direction": "vertical",
                                      "children": [
                                        {
                                          "content": "@entity.currentStepLabel",
                                          "variant": "h2",
                                          "type": "typography"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "@entity.currentStepDescription",
                                          "variant": "body",
                                          "color": "muted"
                                        }
                                      ]
                                    }
                                  ],
                                  "gap": "sm"
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "submitEvent": "ADVANCE",
                                  "showSubmit": false,
                                  "type": "form-section",
                                  "entity": "@entity",
                                  "mode": "edit",
                                  "fields": "@entity.currentFields",
                                  "cancelEvent": "CANCEL",
                                  "showCancel": false
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "action": "RETREAT",
                              "variant": "ghost",
                              "disabled": "@entity.isFirstStep",
                              "icon": "chevron-left",
                              "label": "Back"
                            },
                            {
                              "type": "button",
                              "action": "CANCEL",
                              "label": "Cancel wizard",
                              "variant": "ghost",
                              "icon": "x"
                            },
                            {
                              "icon": "@entity.primaryActionIcon",
                              "label": "@entity.primaryActionLabel",
                              "variant": "primary",
                              "type": "button",
                              "action": "ADVANCE"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "completed",
                "event": "ADVANCE",
                "guard": "@entity.isLastStep",
                "effects": [
                  [
                    "set",
                    "@entity.completionMessage",
                    "All steps completed. Your submission has been recorded."
                  ],
                  [
                    "persist",
                    "update",
                    "WizardView",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "WizardSaved",
                        "failure": "WizardSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "align": "center",
                          "content": "Complete",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "@entity.completionMessage",
                          "align": "center",
                          "type": "typography"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.totalSteps",
                          "allowNavigation": false,
                          "steps": "@entity.wizardSteps"
                        },
                        {
                          "variant": "secondary",
                          "action": "RESTART",
                          "icon": "rotate-ccw",
                          "label": "Start a new wizard",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "RETREAT",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "-",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepLabel",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "label"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepDescription",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "description",
                      ""
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentStepIcon",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "icon",
                      "circle"
                    ]
                  ],
                  [
                    "set",
                    "@entity.currentFields",
                    [
                      "object/get",
                      [
                        "array/nth",
                        "@config.steps",
                        "@entity.currentStepIndex"
                      ],
                      "fields",
                      []
                    ]
                  ],
                  [
                    "set",
                    "@entity.isFirstStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      0.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.isLastStep",
                    [
                      "=",
                      "@entity.currentStepIndex",
                      [
                        "-",
                        "@entity.totalSteps",
                        1.0
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionLabel",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "Submit",
                      "Next"
                    ]
                  ],
                  [
                    "set",
                    "@entity.primaryActionIcon",
                    [
                      "if",
                      [
                        "=",
                        "@entity.currentStepIndex",
                        [
                          "-",
                          "@entity.totalSteps",
                          1.0
                        ]
                      ],
                      "check-circle",
                      "chevron-right"
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": "@entity.currentStepIndex",
                          "steps": "@entity.wizardSteps",
                          "allowNavigation": false
                        },
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "gap": "sm",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "size": "lg",
                                      "name": "@entity.currentStepIcon"
                                    },
                                    {
                                      "gap": "xs",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "content": "@entity.currentStepLabel",
                                          "type": "typography",
                                          "variant": "h2"
                                        },
                                        {
                                          "variant": "body",
                                          "content": "@entity.currentStepDescription",
                                          "type": "typography",
                                          "color": "muted"
                                        }
                                      ],
                                      "direction": "vertical"
                                    }
                                  ]
                                },
                                {
                                  "type": "divider"
                                },
                                {
                                  "entity": "@entity",
                                  "type": "form-section",
                                  "mode": "edit",
                                  "fields": "@entity.currentFields",
                                  "showCancel": false,
                                  "cancelEvent": "CANCEL",
                                  "submitEvent": "ADVANCE",
                                  "showSubmit": false
                                }
                              ]
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "disabled": "@entity.isFirstStep",
                              "icon": "chevron-left",
                              "label": "Back",
                              "action": "RETREAT"
                            },
                            {
                              "icon": "x",
                              "type": "button",
                              "label": "Cancel wizard",
                              "action": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "variant": "primary",
                              "action": "ADVANCE",
                              "icon": "@entity.primaryActionIcon",
                              "label": "@entity.primaryActionLabel",
                              "type": "button"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "cancelled",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.cancelReason",
                    "@payload.reason"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "size": "lg",
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "align": "center",
                          "variant": "h2",
                          "content": "Cancelled",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "The wizard was cancelled. No data was submitted.",
                          "type": "typography",
                          "align": "center"
                        },
                        {
                          "action": "RESTART",
                          "icon": "rotate-ccw",
                          "variant": "secondary",
                          "type": "button",
                          "label": "Start a new wizard"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.completionMessage",
                    ""
                  ],
                  [
                    "fetch",
                    "WizardView",
                    {
                      "emit": {
                        "success": "WizardLoaded",
                        "failure": "WizardLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "cancelled",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.cancelReason",
                    ""
                  ],
                  [
                    "fetch",
                    "WizardView",
                    {
                      "emit": {
                        "success": "WizardLoaded",
                        "failure": "WizardLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Retrying…",
                      "type": "loading-state"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "steps": {
              "type": "[StepSpec]",
              "default": [
                {
                  "key": "details",
                  "fields": [
                    "title",
                    "description"
                  ],
                  "label": "Details",
                  "description": "Basic information",
                  "icon": "file-text"
                },
                {
                  "key": "options",
                  "fields": [
                    "category",
                    "priority"
                  ],
                  "icon": "settings",
                  "description": "Configure preferences",
                  "label": "Options"
                },
                {
                  "label": "Review",
                  "key": "review",
                  "description": "Confirm and submit",
                  "icon": "check-circle",
                  "fields": [
                    "notes"
                  ]
                }
              ],
              "label": "Steps",
              "description": "Ordered steps with their label, icon, and form fields",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Wizard",
              "label": "Wizard title",
              "description": "Heading shown across all wizard steps"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WizardPage",
          "path": "/wizard",
          "traits": [
            {
              "ref": "WizardForm"
            }
          ]
        }
      ]
    }
  ]
}