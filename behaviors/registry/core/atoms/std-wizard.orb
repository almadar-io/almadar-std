{
  "name": "std-wizard",
  "version": "2.0.0",
  "description": "std-wizard — generic N-step branching wizard. `config.steps` is an array of step definitions (each with its own `fields` list); @entity.currentStepIndex walks through them; ADVANCE/RETREAT self-loop, COMPLETE/CANCEL terminate. Topology = loading / running / completed / cancelled / error — running state owns N via data, not states.",
  "orbitals": [
    {
      "name": "WizardOrbital",
      "entity": {
        "name": "WizardView",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "steps",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "status": {
                  "name": "status",
                  "type": "string",
                  "values": [
                    "pending",
                    "current",
                    "completed"
                  ]
                },
                "number": {
                  "name": "number",
                  "type": "number"
                },
                "key": {
                  "name": "key",
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "type": "string"
                },
                "description": {
                  "name": "description",
                  "type": "string"
                }
              }
            }
          },
          {
            "name": "currentStepIndex",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSteps",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "completionMessage",
            "type": "string",
            "default": ""
          },
          {
            "name": "cancelReason",
            "type": "string",
            "default": ""
          },
          {
            "name": "errorMessage",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "WizardForm",
          "category": "interaction",
          "linkedEntity": "WizardView",
          "emits": [
            {
              "event": "ADVANCE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "RETREAT"
            },
            {
              "event": "SKIP"
            },
            {
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESTART"
            },
            {
              "event": "WizardLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "WizardLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "completed"
              },
              {
                "name": "cancelled"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WizardLoaded",
                "name": "Wizard loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "WizardLoadFailed",
                "name": "Wizard load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "WizardSaved",
                "name": "Wizard saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "WizardSaveFailed",
                "name": "Wizard save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE",
                "name": "Advance",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "RETREAT",
                "name": "Retreat"
              },
              {
                "key": "SKIP",
                "name": "Skip"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardView",
                    {
                      "emit": {
                        "failure": "WizardLoadFailed",
                        "success": "WizardLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Loading wizard…"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "WizardLoaded",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.totalSteps",
                    [
                      "array/len",
                      "@config.steps"
                    ]
                  ],
                  [
                    "set",
                    "@entity.steps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "circle"
                          ],
                          "status": "current",
                          "number": 1.0,
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-list",
                          "renderItem": [
                            "fn",
                            "step",
                            {
                              "type": "card",
                              "children": [
                                {
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@step.icon"
                                    },
                                    {
                                      "type": "stack",
                                      "direction": "vertical",
                                      "gap": "xs",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "variant": "h4",
                                          "content": "@step.label"
                                        },
                                        {
                                          "variant": "caption",
                                          "color": "muted",
                                          "type": "typography",
                                          "content": "@step.description"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "badge",
                                      "variant": "primary",
                                      "label": "@step.status"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "gap": "sm"
                                }
                              ]
                            }
                          ],
                          "entity": "@entity.steps",
                          "fields": []
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "ADVANCE",
                          "cancelEvent": "CANCEL",
                          "entity": "@entity",
                          "fields": "@config.currentFields",
                          "type": "form-section",
                          "mode": "edit"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "icon": "arrow-left",
                              "variant": "ghost",
                              "action": "RETREAT",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "action": "SKIP",
                              "variant": "secondary",
                              "icon": "skip-forward",
                              "type": "button",
                              "label": "Skip"
                            },
                            {
                              "label": "Submit",
                              "type": "button",
                              "action": "COMPLETE",
                              "variant": "success",
                              "icon": "check-circle"
                            },
                            {
                              "icon": "x",
                              "label": "Cancel",
                              "type": "button",
                              "action": "CANCEL",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WizardLoadFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Failed to load",
                      "message": "@entity.errorMessage"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "running",
                "event": "WizardSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Refreshing…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WizardSaveFailed",
                "effects": [
                  [
                    "set",
                    "@entity.errorMessage",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.errorMessage",
                      "type": "error-state",
                      "title": "Save failed"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "ADVANCE",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "+",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.steps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "circle"
                          ],
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "number": 1.0,
                          "status": "current"
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "gap": "sm",
                          "entity": "@entity.steps",
                          "renderItem": [
                            "fn",
                            "step",
                            {
                              "type": "card",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@step.icon"
                                    },
                                    {
                                      "children": [
                                        {
                                          "content": "@step.label",
                                          "variant": "h4",
                                          "type": "typography"
                                        },
                                        {
                                          "type": "typography",
                                          "variant": "caption",
                                          "color": "muted",
                                          "content": "@step.description"
                                        }
                                      ],
                                      "direction": "vertical",
                                      "gap": "xs",
                                      "type": "stack"
                                    },
                                    {
                                      "variant": "primary",
                                      "type": "badge",
                                      "label": "@step.status"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack"
                                }
                              ]
                            }
                          ],
                          "type": "data-list"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@entity",
                          "type": "form-section",
                          "fields": "@config.currentFields",
                          "submitEvent": "ADVANCE",
                          "mode": "edit",
                          "cancelEvent": "CANCEL"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "action": "RETREAT",
                              "icon": "arrow-left",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "label": "Skip",
                              "variant": "secondary",
                              "action": "SKIP",
                              "icon": "skip-forward"
                            },
                            {
                              "variant": "success",
                              "action": "COMPLETE",
                              "type": "button",
                              "icon": "check-circle",
                              "label": "Submit"
                            },
                            {
                              "variant": "ghost",
                              "type": "button",
                              "action": "CANCEL",
                              "icon": "x",
                              "label": "Cancel"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "RETREAT",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "-",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Going back…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "running",
                "event": "SKIP",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    [
                      "+",
                      "@entity.currentStepIndex",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Skipping…"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "completed",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.completionMessage",
                    "All steps completed"
                  ],
                  [
                    "set",
                    "@entity.steps",
                    [
                      "array/map",
                      "@config.steps",
                      [
                        "fn",
                        "step",
                        {
                          "key": [
                            "object/get",
                            "@step",
                            "key"
                          ],
                          "description": [
                            "object/get",
                            "@step",
                            "description",
                            ""
                          ],
                          "number": 1.0,
                          "status": "completed",
                          "label": [
                            "object/get",
                            "@step",
                            "label"
                          ],
                          "icon": [
                            "object/get",
                            "@step",
                            "icon",
                            "circle"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "check-circle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Complete"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "renderItem": [
                            "fn",
                            "step",
                            {
                              "type": "card",
                              "children": [
                                {
                                  "align": "center",
                                  "gap": "sm",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "@step.icon"
                                    },
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "variant": "h4",
                                          "content": "@step.label",
                                          "type": "typography"
                                        },
                                        {
                                          "color": "muted",
                                          "type": "typography",
                                          "variant": "caption",
                                          "content": "@step.description"
                                        }
                                      ],
                                      "direction": "vertical",
                                      "gap": "xs"
                                    },
                                    {
                                      "variant": "success",
                                      "type": "badge",
                                      "label": "@step.status"
                                    }
                                  ],
                                  "direction": "horizontal"
                                }
                              ]
                            }
                          ],
                          "fields": [],
                          "gap": "sm",
                          "type": "data-list",
                          "entity": "@entity.steps"
                        },
                        {
                          "children": [
                            {
                              "content": "@entity.completionMessage",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "type": "card"
                        },
                        {
                          "type": "button",
                          "label": "Restart",
                          "icon": "rotate-ccw",
                          "action": "RESTART",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "cancelled",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.cancelReason",
                    "@payload.reason"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "x-circle"
                            },
                            {
                              "content": "Cancelled",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "Wizard cancelled."
                        },
                        {
                          "icon": "rotate-ccw",
                          "label": "Restart",
                          "type": "button",
                          "variant": "secondary",
                          "action": "RESTART"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Restarting…",
                      "type": "loading-state"
                    }
                  ]
                ]
              },
              {
                "from": "cancelled",
                "to": "loading",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.currentStepIndex",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Restarting…"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Retrying…"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "steps": {
              "type": "[object]",
              "default": [
                {
                  "description": "Basic information",
                  "key": "details",
                  "fields": [
                    "title",
                    "description"
                  ],
                  "icon": "file-text",
                  "label": "Details"
                },
                {
                  "icon": "settings",
                  "description": "Configure preferences",
                  "fields": [
                    "category",
                    "priority"
                  ],
                  "label": "Options",
                  "key": "options"
                },
                {
                  "key": "review",
                  "label": "Review",
                  "icon": "check-circle",
                  "description": "Confirm and submit",
                  "fields": [
                    "notes"
                  ]
                }
              ]
            },
            "currentFields": {
              "type": "[string]",
              "default": [
                "title",
                "description"
              ]
            },
            "title": {
              "type": "string",
              "default": "Wizard"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WizardPage",
          "path": "/wizard",
          "traits": [
            {
              "ref": "WizardForm"
            }
          ]
        }
      ]
    }
  ]
}
