{
  "name": "std-geosearch",
  "version": "1.0.0",
  "description": "std-geosearch — location-aware search variant: search-input + map-view + range-slider for radius. Owns a GeoSearchResult runtime entity; GEO_SEARCH persists @payload.searchTerm/lat/lng/radiusKm so cross-trait listeners can route them into geo-aware data atoms.",
  "orbitals": [
    {
      "name": "GeoSearchResultOrbital",
      "entity": {
        "name": "GeoSearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "searchTerm",
            "type": "string",
            "description": "The user's search query string.",
            "synonyms": "query, text, input"
          },
          {
            "name": "centerLat",
            "type": "number",
            "description": "Latitude coordinate of the search center.",
            "synonyms": "lat, y, north"
          },
          {
            "name": "centerLng",
            "type": "number",
            "description": "The longitude coordinate of the search center.",
            "synonyms": "longitude, lng"
          },
          {
            "name": "radiusKm",
            "type": "number",
            "default": 10.0,
            "description": "The search radius in kilometers.",
            "synonyms": "range, distance, extent"
          },
          {
            "name": "boundsNorth",
            "type": "number",
            "description": "Northern boundary coordinate of the search area.",
            "synonyms": "north, upper, top"
          },
          {
            "name": "boundsSouth",
            "type": "number",
            "description": "Southern boundary coordinate of the search area.",
            "synonyms": "south, bottom, lowerBoundary"
          },
          {
            "name": "boundsEast",
            "type": "number",
            "description": "The eastern boundary coordinate of the search area.",
            "synonyms": "east, right, longitude"
          },
          {
            "name": "boundsWest",
            "type": "number",
            "description": "Western boundary coordinate of the search area.",
            "synonyms": "west, longitude, x"
          }
        ]
      },
      "traits": [
        {
          "name": "GeoSearchResultSearch",
          "category": "interaction",
          "linkedEntity": "GeoSearchResult",
          "emits": [
            {
              "event": "GEO_SEARCH",
              "description": "Indicates a search request with location parameters.",
              "synonyms": "search, locate, find, query",
              "tier": "essential",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "lat",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "lng",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "radiusKm",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GEO_SEARCH",
                "name": "Geo Search",
                "description": "Indicates a search request with location parameters.",
                "synonyms": "search, locate, find, query",
                "tier": "essential",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "lat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "lng",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "radiusKm",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "placeholder": "@config.placeholder",
                          "type": "search-input",
                          "event": "@config.event"
                        },
                        {
                          "centerLat": "@entity.centerLat",
                          "markers": [],
                          "height": "240px",
                          "zoom": 12.0,
                          "centerLng": "@entity.centerLng",
                          "type": "map-view"
                        },
                        {
                          "action": "GEO_SEARCH",
                          "max": 100.0,
                          "min": 1.0,
                          "showTooltip": true,
                          "type": "range-slider",
                          "value": "@entity.radiusKm",
                          "step": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "GEO_SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ],
                  [
                    "set",
                    "@entity.centerLat",
                    "@payload.lat"
                  ],
                  [
                    "set",
                    "@entity.centerLng",
                    "@payload.lng"
                  ],
                  [
                    "set",
                    "@entity.radiusKm",
                    "@payload.radiusKm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "placeholder": "@config.placeholder",
                          "event": "@config.event",
                          "type": "search-input"
                        },
                        {
                          "markers": [],
                          "zoom": 12.0,
                          "centerLng": "@entity.centerLng",
                          "height": "240px",
                          "type": "map-view",
                          "centerLat": "@entity.centerLat"
                        },
                        {
                          "step": 1.0,
                          "showTooltip": true,
                          "max": 100.0,
                          "type": "range-slider",
                          "action": "GEO_SEARCH",
                          "value": "@entity.radiusKm",
                          "min": 1.0
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "GEO_SEARCH",
              "label": "Search event",
              "description": "Event emitted when the user runs a geo search",
              "tier": "internal"
            },
            "placeholder": {
              "type": "string",
              "default": "Search nearby…",
              "label": "Search placeholder",
              "description": "Hint text in the location search input",
              "tier": "presentation"
            },
            "defaultRadiusKm": {
              "type": "number",
              "default": 10.0,
              "label": "Default radius (km)",
              "description": "Initial search radius around the chosen center",
              "tier": "presentation"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GeoSearchResultSearchPage",
          "path": "/geosearchresults/search",
          "traits": [
            {
              "ref": "GeoSearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}
