{
  "description": "std-geosearch — location-aware search variant: search-input + map-view + range-slider for radius. Owns a GeoSearchResult runtime entity; GEO_SEARCH persists @payload.searchTerm/lat/lng/radiusKm so cross-trait listeners can route them into geo-aware data atoms.",
  "name": "std-geosearch",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The user's search query string.",
            "name": "searchTerm",
            "synonyms": "query, text, input",
            "type": "string"
          },
          {
            "description": "Latitude coordinate of the search center.",
            "name": "centerLat",
            "synonyms": "lat, y, north",
            "type": "number"
          },
          {
            "description": "The longitude coordinate of the search center.",
            "name": "centerLng",
            "synonyms": "longitude, lng",
            "type": "number"
          },
          {
            "default": 10.0,
            "description": "The search radius in kilometers.",
            "name": "radiusKm",
            "synonyms": "range, distance, extent",
            "type": "number"
          },
          {
            "description": "Northern boundary coordinate of the search area.",
            "name": "boundsNorth",
            "synonyms": "north, upper, top",
            "type": "number"
          },
          {
            "description": "Southern boundary coordinate of the search area.",
            "name": "boundsSouth",
            "synonyms": "south, bottom, lowerBoundary",
            "type": "number"
          },
          {
            "description": "The eastern boundary coordinate of the search area.",
            "name": "boundsEast",
            "synonyms": "east, right, longitude",
            "type": "number"
          },
          {
            "description": "Western boundary coordinate of the search area.",
            "name": "boundsWest",
            "synonyms": "west, longitude, x",
            "type": "number"
          }
        ],
        "name": "GeoSearchResult",
        "persistence": "runtime"
      },
      "name": "GeoSearchResultOrbital",
      "pages": [
        {
          "name": "GeoSearchResultSearchPage",
          "path": "/geosearchresults/search",
          "traits": [
            {
              "ref": "GeoSearchResultSearch"
            }
          ]
        }
      ],
      "traits": [
        {
          "category": "interaction",
          "config": {
            "defaultRadiusKm": {
              "default": 10.0,
              "description": "Initial search radius around the chosen center",
              "label": "Default radius (km)",
              "tier": "presentation",
              "type": "number"
            },
            "event": {
              "default": "GEO_SEARCH",
              "description": "Event emitted when the user runs a geo search",
              "label": "Search event",
              "tier": "internal",
              "type": "string"
            },
            "placeholder": {
              "default": "Search nearby…",
              "description": "Hint text in the location search input",
              "label": "Search placeholder",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Indicates a search request with location parameters.",
              "event": "GEO_SEARCH",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "required": true,
                  "type": "string"
                },
                {
                  "name": "lat",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "lng",
                  "required": true,
                  "type": "number"
                },
                {
                  "name": "radiusKm",
                  "required": true,
                  "type": "number"
                }
              ],
              "synonyms": "search, locate, find, query",
              "tier": "domain"
            }
          ],
          "linkedEntity": "GeoSearchResult",
          "name": "GeoSearchResultSearch",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates a search request with location parameters.",
                "key": "GEO_SEARCH",
                "name": "Geo Search",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "required": true,
                    "type": "string"
                  },
                  {
                    "name": "lat",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "lng",
                    "required": true,
                    "type": "number"
                  },
                  {
                    "name": "radiusKm",
                    "required": true,
                    "type": "number"
                  }
                ],
                "synonyms": "search, locate, find, query",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "@config.event",
                          "placeholder": "@config.placeholder",
                          "type": "search-input"
                        },
                        {
                          "centerLat": "@entity.centerLat",
                          "centerLng": "@entity.centerLng",
                          "height": "240px",
                          "markers": [],
                          "type": "map-view",
                          "zoom": 12.0
                        },
                        {
                          "action": "GEO_SEARCH",
                          "max": 100.0,
                          "min": 1.0,
                          "showTooltip": true,
                          "step": 1.0,
                          "type": "range-slider",
                          "value": "@entity.radiusKm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ],
                  [
                    "set",
                    "@entity.centerLat",
                    "@payload.lat"
                  ],
                  [
                    "set",
                    "@entity.centerLng",
                    "@payload.lng"
                  ],
                  [
                    "set",
                    "@entity.radiusKm",
                    "@payload.radiusKm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "@config.event",
                          "placeholder": "@config.placeholder",
                          "type": "search-input"
                        },
                        {
                          "centerLat": "@entity.centerLat",
                          "centerLng": "@entity.centerLng",
                          "height": "240px",
                          "markers": [],
                          "type": "map-view",
                          "zoom": 12.0
                        },
                        {
                          "action": "GEO_SEARCH",
                          "max": 100.0,
                          "min": 1.0,
                          "showTooltip": true,
                          "step": 1.0,
                          "type": "range-slider",
                          "value": "@entity.radiusKm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "GEO_SEARCH",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ]
    }
  ],
  "version": "1.0.0"
}