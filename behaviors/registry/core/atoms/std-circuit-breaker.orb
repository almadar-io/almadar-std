{
  "name": "std-circuit-breaker",
  "version": "1.0.0",
  "description": "std-circuit-breaker as a Function",
  "orbitals": [
    {
      "name": "ServiceNodeOrbital",
      "entity": {
        "name": "ServiceNode",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "failureCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "successCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 5.0
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceNodeCircuitBreaker",
          "category": "interaction",
          "linkedEntity": "ServiceNode",
          "emits": [
            {
              "event": "ServiceNodeLoaded",
              "description": "Fired when ServiceNode finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "failureCount",
                  "type": "number"
                },
                {
                  "name": "successCount",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ServiceNodeLoadFailed",
              "description": "Fired when ServiceNode fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              },
              {
                "name": "halfOpen"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FAILURE",
                "name": "Failure"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "TIMEOUT",
                "name": "Timeout"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceNodeLoaded",
                "name": "ServiceNode loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "failureCount",
                    "type": "number"
                  },
                  {
                    "name": "successCount",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ServiceNodeLoadFailed",
                "name": "ServiceNode load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.failureCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.successCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.threshold",
                    5.0
                  ],
                  [
                    "fetch",
                    "ServiceNode",
                    {
                      "emit": {
                        "success": "ServiceNodeLoaded",
                        "failure": "ServiceNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "shield",
                                  "type": "icon"
                                },
                                {
                                  "content": "ServiceNode",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "status-dot",
                              "label": "Circuit Closed",
                              "pulse": false,
                              "status": "online"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.failureCount",
                              "type": "stat-display",
                              "label": "Failures"
                            },
                            {
                              "value": "@entity.successCount",
                              "label": "Successes",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0.0
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "content": "ServiceNode",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "md"
                            },
                            {
                              "label": "Circuit Open",
                              "status": "critical",
                              "type": "status-dot",
                              "pulse": true
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "error",
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.successCount",
                              "type": "stat-display",
                              "label": "Successes"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "type": "meter",
                          "min": 0.0
                        },
                        {
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "type": "button",
                          "label": "Reset"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "content": "ServiceNode",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "pulse": false,
                              "label": "Circuit Closed",
                              "status": "online"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "message": "Service is healthy. All requests are being processed.",
                          "type": "alert"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.failureCount",
                              "label": "Failures"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "max": "@entity.threshold",
                          "type": "meter",
                          "value": "@entity.failureCount",
                          "min": 0.0
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "halfOpen",
                "event": "TIMEOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "ServiceNode"
                                }
                              ]
                            },
                            {
                              "pulse": true,
                              "status": "warning",
                              "type": "status-dot",
                              "label": "Circuit Half-Open"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "warning",
                          "type": "alert",
                          "message": "Testing recovery. Limited requests are being allowed through."
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.failureCount",
                              "type": "stat-display",
                              "label": "Failures"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.successCount",
                              "label": "Successes"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "variant": "h2",
                                  "content": "ServiceNode",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "pulse": false,
                              "status": "online",
                              "type": "status-dot",
                              "label": "Circuit Closed"
                            }
                          ],
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "min": 0.0,
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "max": "@entity.threshold"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "type": "typography",
                                  "content": "ServiceNode",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "label": "Circuit Closed",
                              "pulse": false,
                              "status": "online"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "message": "Service is healthy. All requests are being processed.",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.successCount",
                              "label": "Successes"
                            }
                          ]
                        },
                        {
                          "type": "meter",
                          "value": "@entity.failureCount",
                          "min": 0.0,
                          "max": "@entity.threshold"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "content": "ServiceNode",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "status-dot",
                              "pulse": true,
                              "label": "Circuit Open",
                              "status": "critical"
                            }
                          ],
                          "justify": "between",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                          "variant": "error"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.failureCount",
                              "label": "Failures",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "min": 0.0,
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "type": "meter"
                        },
                        {
                          "label": "Reset",
                          "variant": "ghost",
                          "action": "RESET",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "shield",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "ServiceNode"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "status": "online",
                              "type": "status-dot",
                              "label": "Circuit Closed",
                              "pulse": false
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "min": 0.0
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ServiceNodePage",
          "path": "/servicenodes",
          "traits": [
            {
              "ref": "ServiceNodeCircuitBreaker"
            }
          ]
        }
      ]
    }
  ]
}
