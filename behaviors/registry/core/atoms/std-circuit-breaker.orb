{
  "name": "std-circuit-breaker",
  "version": "1.0.0",
  "description": "std-circuit-breaker as a Function",
  "orbitals": [
    {
      "name": "ServiceNodeOrbital",
      "entity": {
        "name": "ServiceNode",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string",
            "description": "A user-defined identifier for the circuit breaker.",
            "synonyms": "identifier, label, designation"
          },
          {
            "name": "description",
            "type": "string",
            "description": "A textual explanation of the service node's function.",
            "synonyms": "explanation, details, notes, information"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ],
            "description": "Current operational state of the component.",
            "synonyms": "state, condition, operationalStatus"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "failureCount",
            "type": "number",
            "default": 0.0,
            "description": "The number of times the circuit breaker has failed.",
            "synonyms": "error count, failures, error occurrences"
          },
          {
            "name": "successCount",
            "type": "number",
            "default": 0.0,
            "description": "Number of successful operations.",
            "synonyms": "successes, hits, completions"
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 5.0,
            "description": "Maximum value before triggering an action.",
            "synonyms": "limit, cap, boundary"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceNodeCircuitBreaker",
          "category": "interaction",
          "linkedEntity": "ServiceNode",
          "emits": [
            {
              "event": "ServiceNodeLoaded",
              "description": "Signals successful loading of a service node.",
              "synonyms": "loaded, initialized, ready",
              "tier": "internal",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "failureCount",
                  "type": "number"
                },
                {
                  "name": "successCount",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ServiceNodeLoadFailed",
              "description": "Indicates a node failed to load, potentially disrupting service.",
              "synonyms": "failure, error, unavailable, outage",
              "tier": "internal",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              },
              {
                "name": "halfOpen"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FAILURE",
                "name": "Failure"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "TIMEOUT",
                "name": "Timeout"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceNodeLoaded",
                "name": "ServiceNode loaded",
                "description": "Signals successful loading of a service node.",
                "synonyms": "loaded, initialized, ready",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "failureCount",
                    "type": "number"
                  },
                  {
                    "name": "successCount",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ServiceNodeLoadFailed",
                "name": "ServiceNode load failed",
                "description": "Indicates a node failed to load, potentially disrupting service.",
                "synonyms": "failure, error, unavailable, outage",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.failureCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.successCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.threshold",
                    5.0
                  ],
                  [
                    "fetch",
                    "ServiceNode",
                    {
                      "emit": {
                        "success": "ServiceNodeLoaded",
                        "failure": "ServiceNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "gap": "md",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "shield",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "ServiceNode",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "pulse": false,
                              "status": "online",
                              "label": "Circuit Closed",
                              "type": "status-dot"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "look": "@config.statLook",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.successCount",
                              "look": "@config.statLook",
                              "label": "Successes",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 2.0
                        },
                        {
                          "min": 0.0,
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "ServiceNode",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center",
                              "gap": "md"
                            },
                            {
                              "type": "status-dot",
                              "label": "Circuit Open",
                              "pulse": true,
                              "status": "critical"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures."
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "look": "@config.statLook",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "value": "@entity.successCount"
                            }
                          ]
                        },
                        {
                          "type": "meter",
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "min": 0.0
                        },
                        {
                          "type": "button",
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "variant": "ghost",
                          "label": "Reset"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "variant": "h2",
                                  "content": "ServiceNode",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "status": "online",
                              "label": "Circuit Closed",
                              "pulse": false
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Service is healthy. All requests are being processed.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "look": "@config.statLook",
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "look": "@config.statLook",
                              "value": "@entity.successCount",
                              "label": "Successes",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0.0,
                          "max": "@entity.threshold"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "halfOpen",
                "event": "TIMEOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "name": "activity",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "ServiceNode"
                                }
                              ]
                            },
                            {
                              "status": "warning",
                              "pulse": true,
                              "type": "status-dot",
                              "label": "Circuit Half-Open"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Testing recovery. Limited requests are being allowed through.",
                          "type": "alert",
                          "variant": "warning"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "look": "@config.statLook",
                              "value": "@entity.failureCount",
                              "label": "Failures",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.successCount",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Successes"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "ServiceNode"
                                }
                              ]
                            },
                            {
                              "type": "status-dot",
                              "pulse": false,
                              "status": "online",
                              "label": "Circuit Closed"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Service is healthy. All requests are being processed.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "value": "@entity.successCount",
                              "label": "Successes"
                            }
                          ],
                          "cols": 2.0
                        },
                        {
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "min": 0.0
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "type": "typography",
                                  "content": "ServiceNode",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "status": "online",
                              "label": "Circuit Closed",
                              "type": "status-dot",
                              "pulse": false
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "children": [
                            {
                              "look": "@config.statLook",
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0.0,
                          "max": "@entity.threshold"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "ServiceNode"
                                }
                              ]
                            },
                            {
                              "type": "status-dot",
                              "pulse": true,
                              "status": "critical",
                              "label": "Circuit Open"
                            }
                          ],
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.failureCount",
                              "look": "@config.statLook",
                              "label": "Failures"
                            },
                            {
                              "value": "@entity.successCount",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "label": "Successes"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "min": 0.0,
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount"
                        },
                        {
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "variant": "ghost",
                          "type": "button",
                          "label": "Reset"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "shield",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "ServiceNode",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "pulse": false,
                              "status": "online",
                              "type": "status-dot",
                              "label": "Circuit Closed"
                            }
                          ],
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Service is healthy. All requests are being processed.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "value": "@entity.failureCount",
                              "label": "Failures"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "look": "@config.statLook",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "type": "meter",
                          "min": 0.0,
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "halfOpenRequests": {
              "type": "number",
              "default": 1.0,
              "label": "Half-open probe requests",
              "description": "Probe requests allowed through in the half-open state before deciding to close or re-open. Lower = cautious single-probe recovery; higher = aggressive parallel re-validation.",
              "synonyms": "probe count, recovery test size, probe aggressiveness, recovery test volume, cautious vs fast recovery",
              "tier": "domain"
            },
            "fallbackBehavior": {
              "type": "string",
              "default": "reject",
              "label": "Fallback behavior",
              "description": "What to return to callers while the circuit is open: reject = fail-fast/strict, cached-response = graceful degrade with stale data, queue = retry-later/no data loss, static-default = safe placeholder.",
              "synonyms": "open-state response, degraded mode, fail-fast vs graceful degrade",
              "tier": "domain",
              "values": [
                "reject",
                "cached-response",
                "queue",
                "static-default"
              ]
            },
            "statLook": {
              "type": "string",
              "default": "elevated",
              "label": "Stat display look",
              "description": "Layer 2 visual treatment for stat / KPI cards.",
              "tier": "presentation",
              "values": [
                "elevated",
                "flat",
                "progress-backed",
                "gauge",
                "sparkline"
              ]
            },
            "failureThreshold": {
              "type": "number",
              "default": 5.0,
              "label": "Failure threshold",
              "description": "Number of consecutive failures before the circuit opens and starts rejecting requests.",
              "synonyms": "open trigger, failure count",
              "tier": "domain"
            },
            "cooldownSeconds": {
              "type": "number",
              "default": 30.0,
              "label": "Cooldown (seconds)",
              "description": "Seconds the circuit stays open before transitioning to half-open and probing for recovery.",
              "synonyms": "reset timeout, open duration",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ServiceNodePage",
          "path": "/servicenodes",
          "traits": [
            {
              "ref": "ServiceNodeCircuitBreaker"
            }
          ]
        }
      ]
    }
  ]
}
