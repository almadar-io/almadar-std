{
  "name": "std-search",
  "version": "1.0.0",
  "description": "std-search as a Function — single primitive: search-input",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "category": "interaction",
          "linkedEntity": "SearchResult",
          "emits": [
            {
              "event": "SEARCH",
              "payloadSchema": [
                {
                  "name": "query",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SearchResultLoaded",
              "description": "Fired when SearchResult collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[SearchResult]"
                }
              ]
            },
            {
              "event": "SearchResultLoadFailed",
              "description": "Fired when SearchResult collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "searching"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SearchResultLoaded",
                "name": "SearchResult loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SearchResult]"
                  }
                ]
              },
              {
                "key": "SearchResultLoadFailed",
                "name": "SearchResult load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "success": "SearchResultLoaded",
                        "failure": "SearchResultLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "event": "@config.event",
                      "placeholder": "@config.placeholder",
                      "type": "search-input"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "success": "SearchResultLoaded",
                        "failure": "SearchResultLoadFailed"
                      },
                      "filter": [
                        "str/includes",
                        [
                          "object/get",
                          "@entity",
                          "name"
                        ],
                        "@payload.query"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "sm",
                      "direction": "horizontal",
                      "type": "stack",
                      "children": [
                        {
                          "placeholder": "@config.placeholder",
                          "type": "search-input",
                          "event": "@config.event"
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "searching",
                "event": "SearchResultLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "placeholder": "@config.placeholder",
                      "event": "@config.event",
                      "type": "search-input"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SearchResultLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "@config.event",
                          "type": "search-input",
                          "placeholder": "@config.placeholder"
                        },
                        {
                          "color": "error",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "xs"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "failure": "SearchResultLoadFailed",
                        "success": "SearchResultLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center",
                      "children": [
                        {
                          "placeholder": "@config.placeholder",
                          "type": "search-input",
                          "event": "@config.event"
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "failure": "SearchResultLoadFailed",
                        "success": "SearchResultLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "@config.event",
                          "placeholder": "@config.placeholder",
                          "type": "search-input"
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "placeholder": "@config.placeholder",
                      "event": "@config.event",
                      "type": "search-input"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "success": "SearchResultLoaded",
                        "failure": "SearchResultLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "horizontal",
                      "type": "stack",
                      "gap": "sm",
                      "align": "center",
                      "children": [
                        {
                          "placeholder": "@config.placeholder",
                          "type": "search-input",
                          "event": "@config.event"
                        },
                        {
                          "size": "sm",
                          "type": "spinner"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "placeholder": {
              "type": "string",
              "default": "Search…"
            },
            "event": {
              "type": "string",
              "default": "SEARCH"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}
