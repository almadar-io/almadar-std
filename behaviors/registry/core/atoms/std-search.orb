{
  "name": "std-search",
  "version": "1.0.0",
  "description": "std-search as a Function — single primitive: search-input. The atom's\nown SearchResult entity is the UI-state container — SEARCH persists\n@payload.searchTerm (matching the SearchInput component's emit shape)\ninto @entity.searchTerm. Cross-trait listeners route the same payload\nfield to data atoms (Browse REFETCH_QUERY).",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "searchTerm",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "category": "interaction",
          "linkedEntity": "SearchResult",
          "emits": [
            {
              "event": "SEARCH",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-input",
                      "placeholder": "@config.placeholder",
                      "event": "@config.event"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-input",
                      "placeholder": "@config.placeholder",
                      "event": "@config.event"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "placeholder": {
              "type": "string",
              "default": "Search…"
            },
            "event": {
              "type": "string",
              "default": "SEARCH"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}
