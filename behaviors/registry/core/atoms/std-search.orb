{
  "name": "std-search",
  "version": "1.0.0",
  "description": "std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY).",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "searchTerm",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "category": "interaction",
          "linkedEntity": "SearchResult",
          "emits": [
            {
              "event": "SEARCH",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "event": "@config.event",
                      "type": "search-input",
                      "placeholder": "@config.placeholder"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "event": "@config.event",
                      "type": "search-input",
                      "placeholder": "@config.placeholder"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "placeholder": {
              "type": "string",
              "default": "Search…",
              "label": "Placeholder text",
              "description": "Hint text shown inside the empty search input",
              "tier": "presentation"
            },
            "event": {
              "type": "string",
              "default": "SEARCH",
              "label": "Search event",
              "description": "Event emitted when the user submits a query",
              "tier": "internal"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}