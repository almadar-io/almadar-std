{
  "name": "std-search",
  "version": "1.0.0",
  "description": "std-search as a Function",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "category": "interaction",
          "linkedEntity": "SearchResult",
          "emits": [
            {
              "event": "SearchResultLoaded",
              "description": "Fired when SearchResult collection finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[SearchResult]"
                }
              ]
            },
            {
              "event": "SearchResultLoadFailed",
              "description": "Fired when SearchResult collection fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "searching"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payload": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SearchResultLoaded",
                "name": "SearchResult loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[SearchResult]"
                  }
                ]
              },
              {
                "key": "SearchResultLoadFailed",
                "name": "SearchResult load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "failure": "SearchResultLoadFailed",
                        "success": "SearchResultLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "search",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Search SearchResults",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "event": "SEARCH",
                          "type": "search-input",
                          "placeholder": "Search..."
                        },
                        {
                          "type": "empty-state",
                          "title": "Search to find results",
                          "description": "Type a query to search across searchresults.",
                          "icon": "search"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "success": "SearchResultLoaded",
                        "failure": "SearchResultLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": [
                            "str/concat",
                            "Searching for \"",
                            "@payload.query",
                            "\"…"
                          ],
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-8",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "searching",
                "event": "SearchResultLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "search"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Results",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Clear",
                              "action": "CLEAR",
                              "icon": "x"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "h4",
                                  "content": "@item.name",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "fields": [],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SearchResultLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "Search failed"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "action": "SEARCH",
                          "label": "Retry",
                          "type": "button"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-8",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "success": "SearchResultLoaded",
                        "failure": "SearchResultLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "failure": "SearchResultLoadFailed",
                        "success": "SearchResultLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "success": "SearchResultLoaded",
                        "failure": "SearchResultLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "type": "typography",
                              "content": "Search SearchResults",
                              "variant": "h2"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "search-input",
                          "placeholder": "Search...",
                          "event": "SEARCH"
                        },
                        {
                          "type": "empty-state",
                          "icon": "search",
                          "title": "Search to find results",
                          "description": "Type a query to search across searchresults."
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult",
                    {
                      "emit": {
                        "failure": "SearchResultLoadFailed",
                        "success": "SearchResultLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}