{
  "description": "std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY).",
  "name": "std-search",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The text entered by the user in the search field.",
            "name": "searchTerm",
            "synonyms": "query, search term, input, text",
            "type": "string"
          }
        ],
        "name": "SearchResult",
        "persistence": "runtime"
      },
      "name": "SearchResultOrbital",
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearchRender"
            },
            {
              "ref": "SearchResultSearchEvents"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "event": {
              "default": "@config.event",
              "type": "unknown"
            },
            "placeholder": {
              "default": "@config.placeholder",
              "type": "unknown"
            }
          },
          "linkedEntity": "SearchResult",
          "name": "SearchResultSearchRender",
          "ref": "SearchInput.traits.SearchInputRender"
        },
        {
          "category": "interaction",
          "config": {
            "event": {
              "default": "SEARCH",
              "description": "Event emitted when the user submits a query",
              "label": "Search event",
              "tier": "internal",
              "type": "string"
            },
            "placeholder": {
              "default": "Search…",
              "description": "Hint text shown inside the empty search input",
              "label": "Placeholder text",
              "tier": "presentation",
              "type": "string"
            }
          },
          "emits": [
            {
              "description": "Initiates a search operation based on the input term.",
              "event": "SEARCH",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "required": true,
                  "type": "string"
                }
              ],
              "scope": "external",
              "synonyms": "query, lookup, find",
              "tier": "domain"
            }
          ],
          "linkedEntity": "SearchResult",
          "name": "SearchResultSearchEvents",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Initiates a search operation based on the input term.",
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "required": true,
                    "type": "string"
                  }
                ],
                "synonyms": "query, lookup, find",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "idle"
              }
            ],
            "transitions": [
              {
                "event": "INIT",
                "from": "idle",
                "to": "idle"
              },
              {
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ]
                ],
                "event": "SEARCH",
                "from": "idle",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "SearchInput",
          "from": "std/behaviors/ui-search-input"
        }
      ]
    }
  ],
  "version": "1.0.0"
}