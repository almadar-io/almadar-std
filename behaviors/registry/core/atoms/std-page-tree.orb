{
  "name": "std-page-tree",
  "version": "1.0.0",
  "description": "std-page-tree — hierarchical wiki navigation with parent/child PageNode rows. Browses pages in a file-tree + data-list; opens a page in `viewing_single` with Delete action; supports drag-reorder.",
  "orbitals": [
    {
      "name": "PageTreeOrbital",
      "entity": {
        "name": "PageNode",
        "collection": "pagenodes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "slug",
            "type": "string"
          },
          {
            "name": "order",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "documentId",
            "type": "string"
          },
          {
            "name": "iconName",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PageNodeBrowse",
          "category": "interaction",
          "linkedEntity": "PageNode",
          "emits": [
            {
              "event": "OPEN_PAGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REORDER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DELETE_PAGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PageNodeLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PageNode]"
                }
              ]
            },
            {
              "event": "PageNodeLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PageNodeLoaded",
                "name": "PageNode loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PageNode]"
                  }
                ]
              },
              {
                "key": "PageNodeLoadFailed",
                "name": "PageNode load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_PAGE",
                "name": "Open Page",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "PageNode"
                  }
                ]
              },
              {
                "key": "REORDER",
                "name": "Reorder",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "PageNode"
                  }
                ]
              },
              {
                "key": "DELETE_PAGE",
                "name": "Delete Page",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading pages…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PageNodeLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "list-tree",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "file-text",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total pages"
                            },
                            {
                              "type": "stat-display",
                              "value": "12",
                              "icon": "folder",
                              "label": "Top-level"
                            },
                            {
                              "value": "8",
                              "type": "stat-display",
                              "icon": "edit-3",
                              "label": "Updated this week"
                            },
                            {
                              "icon": "file",
                              "label": "Drafts",
                              "type": "stat-display",
                              "value": "3"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "file-tree",
                          "tree": [
                            {
                              "path": "Getting Started",
                              "name": "Getting Started",
                              "children": [
                                {
                                  "type": "file",
                                  "path": "Overview.md",
                                  "name": "Overview.md"
                                },
                                {
                                  "name": "Quickstart.md",
                                  "path": "Quickstart.md",
                                  "type": "file"
                                }
                              ],
                              "type": "dir"
                            },
                            {
                              "path": "Architecture",
                              "type": "dir",
                              "name": "Architecture",
                              "children": [
                                {
                                  "name": "Overview.md",
                                  "path": "Architecture/Overview.md",
                                  "type": "file"
                                },
                                {
                                  "path": "Architecture/State Machine.md",
                                  "name": "State Machine.md",
                                  "type": "file"
                                }
                              ]
                            },
                            {
                              "path": "Runbooks",
                              "name": "Runbooks",
                              "type": "dir",
                              "children": [
                                {
                                  "path": "Runbooks/Incident.md",
                                  "name": "Incident.md",
                                  "type": "file"
                                },
                                {
                                  "name": "Deployment.md",
                                  "path": "Runbooks/Deployment.md",
                                  "type": "file"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "icon": "arrow-right",
                              "variant": "primary",
                              "label": "Open",
                              "event": "OPEN_PAGE"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "icon": "trash",
                              "event": "DELETE_PAGE"
                            }
                          ],
                          "reorderEvent": "REORDER",
                          "fields": [
                            {
                              "name": "title",
                              "variant": "h4",
                              "label": "Title"
                            },
                            {
                              "label": "Slug",
                              "name": "slug",
                              "variant": "caption"
                            },
                            {
                              "label": "Parent",
                              "variant": "caption",
                              "name": "parentId"
                            },
                            {
                              "name": "order",
                              "label": "Order",
                              "variant": "badge"
                            }
                          ],
                          "gap": "sm",
                          "entity": "@payload.data",
                          "reorderable": true,
                          "type": "data-list"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PageNodeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.slug",
                    "@payload.row.slug"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.iconName",
                    "@payload.row.iconName"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "content": "@entity.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Slug",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.slug",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Parent",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.parentId",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Document",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.documentId"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.order",
                              "icon": "list",
                              "label": "Order",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Slug",
                              "value": "@entity.slug",
                              "icon": "link"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Delete",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "DELETE_PAGE"
                            }
                          ]
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REORDER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Reordering pages…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE_PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Deleting page…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading pages…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DELETE_PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Deleting page…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Pages",
              "label": "Section title",
              "description": "Heading shown above the page tree",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PageNodeBrowsePage",
          "path": "/pages/browse",
          "traits": [
            {
              "ref": "PageNodeBrowse"
            }
          ]
        }
      ]
    }
  ]
}