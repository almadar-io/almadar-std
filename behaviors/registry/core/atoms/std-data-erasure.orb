{
  "name": "std-data-erasure",
  "version": "1.0.0",
  "description": "std-data-erasure — GDPR Art. 17 right-to-be-forgotten queue. Tracks ErasureRequest rows through pending → grace → executed lifecycle with Cancel during grace. v1.0 ships the request lifecycle UI + knob set; auto-emit of ExecuteErasure after grace lands in v1.1 (loop-with-emit gap — docs/Almadar_Std_Factories.md). Target app/ atoms then own the actual delete or piiFields scrub via an ExecuteErasure listener.",
  "orbitals": [
    {
      "name": "DataErasureOrbital",
      "entity": {
        "name": "ErasureRequest",
        "collection": "erasure_requests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subjectId",
            "type": "string",
            "default": ""
          },
          {
            "name": "targetEntity",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "grace",
              "executed",
              "cancelled"
            ]
          },
          {
            "name": "requestedAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "executesAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "executedAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "cancelledAt",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ErasureWorkflow",
          "category": "interaction",
          "linkedEntity": "ErasureRequest",
          "emits": [
            {
              "event": "CANCEL_ERASURE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subjectId",
                  "type": "string"
                },
                {
                  "name": "row.targetEntity",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.executesAt",
                  "type": "number"
                },
                {
                  "name": "row.executedAt",
                  "type": "number"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ErasureLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ErasureRequest]"
                }
              ]
            },
            {
              "event": "ErasureLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ErasureSaved",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subjectId",
                  "type": "string"
                },
                {
                  "name": "row.targetEntity",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "number"
                },
                {
                  "name": "row.executesAt",
                  "type": "number"
                },
                {
                  "name": "row.executedAt",
                  "type": "number"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ErasureSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ErasureLoaded",
                "name": "Erasure loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ErasureRequest]"
                  }
                ]
              },
              {
                "key": "ErasureLoadFailed",
                "name": "Erasure load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL_ERASURE",
                "name": "Cancel Erasure",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ErasureRequest"
                  }
                ]
              },
              {
                "key": "ErasureSaved",
                "name": "Erasure saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ErasureRequest"
                  }
                ]
              },
              {
                "key": "ErasureSaveFailed",
                "name": "Erasure save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ErasureRequest",
                    {
                      "emit": {
                        "failure": "ErasureLoadFailed",
                        "success": "ErasureLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading erasure requests…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ErasureLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "trash-2",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Erasure requests",
                              "variant": "h3"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "look": "@config.tableLook",
                          "gap": "sm",
                          "cols": 1.0,
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "subjectId",
                              "label": "Subject"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "name": "executesAt",
                              "label": "Executes",
                              "variant": "caption"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Cancel",
                              "event": "CANCEL_ERASURE",
                              "variant": "secondary",
                              "icon": "x"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ErasureLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_ERASURE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "ErasureRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ErasureSaveFailed",
                        "success": "ErasureSaved"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ErasureSaved",
                "effects": [
                  [
                    "fetch",
                    "ErasureRequest",
                    {
                      "emit": {
                        "success": "ErasureLoaded",
                        "failure": "ErasureLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ErasureSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ErasureRequest",
                    {
                      "emit": {
                        "failure": "ErasureLoadFailed",
                        "success": "ErasureLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "piiFields": {
              "type": "[string]",
              "default": [],
              "label": "PII fields to scrub",
              "description": "Fields the target atom should null when anonymizeVsDelete='anonymize'.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "anonymizeVsDelete": {
              "type": "string",
              "default": "anonymize",
              "label": "Mode",
              "description": "anonymize = scrub piiFields and retain row for audit. delete = remove the row entirely.",
              "tier": "domain",
              "values": [
                "anonymize",
                "delete"
              ]
            },
            "gracePeriodDays": {
              "type": "number",
              "default": 30.0,
              "label": "Grace period (days)",
              "description": "Days between request and execution. Customer can CANCEL during this window. Default 30 days matches typical GDPR practice.",
              "tier": "domain"
            },
            "targetEntity": {
              "type": "string",
              "default": "",
              "label": "Target entity",
              "description": "Entity name whose records erasure requests apply to (e.g. 'CustomerAccount').",
              "tier": "domain"
            },
            "tableLook": {
              "type": "string",
              "default": "dense",
              "label": "Table look",
              "description": "Layer 2 visual treatment for the data table rendered by this atom.",
              "tier": "presentation",
              "values": [
                "dense",
                "spacious",
                "striped",
                "borderless",
                "card-rows"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ErasureWorkflowPage",
          "path": "/erasure/queue",
          "traits": [
            {
              "ref": "ErasureWorkflow"
            }
          ]
        }
      ]
    }
  ]
}