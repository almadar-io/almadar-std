{
  "name": "std-form-advanced",
  "version": "1.0.0",
  "description": "std-form-advanced as a Function",
  "orbitals": [
    {
      "name": "FormEntryOrbital",
      "entity": {
        "name": "FormEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "age",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": false
          },
          {
            "name": "birthDate",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "categoryId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "FormEntryFormAdvanced",
          "category": "interaction",
          "linkedEntity": "FormEntry",
          "emits": [
            {
              "event": "FormEntryLoaded",
              "description": "Fired when FormEntry finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "age",
                  "type": "number"
                },
                {
                  "name": "isActive",
                  "type": "boolean"
                },
                {
                  "name": "birthDate",
                  "type": "datetime"
                },
                {
                  "name": "priority",
                  "type": "string"
                },
                {
                  "name": "categoryId",
                  "type": "relation"
                }
              ]
            },
            {
              "event": "FormEntryLoadFailed",
              "description": "Fired when FormEntry fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FormEntrySaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FormEntrySaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "editing",
                "isInitial": true
              },
              {
                "name": "submitted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "FormEntryLoaded",
                "name": "FormEntry loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "age",
                    "type": "number"
                  },
                  {
                    "name": "isActive",
                    "type": "boolean"
                  },
                  {
                    "name": "birthDate",
                    "type": "datetime"
                  },
                  {
                    "name": "priority",
                    "type": "string"
                  },
                  {
                    "name": "categoryId",
                    "type": "relation"
                  }
                ]
              },
              {
                "key": "FormEntryLoadFailed",
                "name": "FormEntry load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FormEntrySaved",
                "name": "FormEntry saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FormEntrySaveFailed",
                "name": "FormEntry save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "editing",
                "to": "editing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "success": "FormEntryLoaded",
                        "failure": "FormEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "failure": "FormEntryLoadFailed",
                        "success": "FormEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "type": "typography",
                              "content": "FormEntry Form",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "fields": [
                            {
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "name": "description"
                            },
                            {
                              "values": [
                                "active",
                                "inactive",
                                "pending"
                              ],
                              "type": "enum",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "name": "notes",
                              "label": "Notes",
                              "type": "textarea"
                            },
                            {
                              "name": "age",
                              "label": "Age",
                              "type": "number"
                            },
                            {
                              "label": "Is Active",
                              "type": "boolean",
                              "name": "isActive"
                            },
                            {
                              "type": "date",
                              "label": "Birth Date",
                              "name": "birthDate"
                            },
                            {
                              "values": [
                                "low",
                                "medium",
                                "high",
                                "critical"
                              ],
                              "label": "Priority",
                              "type": "enum",
                              "name": "priority"
                            },
                            {
                              "relation": {
                                "cardinality": "one",
                                "entity": "FormEntry"
                              },
                              "label": "Category ID",
                              "name": "categoryId",
                              "type": "relation"
                            }
                          ],
                          "cancelEvent": "INIT",
                          "type": "form-section",
                          "submitEvent": "SUBMIT"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "submitted",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.name",
                    "@payload.data.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.data.description"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.data.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.data.notes"
                  ],
                  [
                    "set",
                    "@entity.age",
                    "@payload.data.age"
                  ],
                  [
                    "set",
                    "@entity.isActive",
                    "@payload.data.isActive"
                  ],
                  [
                    "set",
                    "@entity.birthDate",
                    "@payload.data.birthDate"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.data.priority"
                  ],
                  [
                    "set",
                    "@entity.categoryId",
                    "@payload.data.categoryId"
                  ],
                  [
                    "persist",
                    "create",
                    "FormEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "FormEntrySaveFailed",
                        "success": "FormEntrySaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Form Submitted"
                        },
                        {
                          "type": "alert",
                          "message": "Your form has been submitted successfully.",
                          "variant": "success"
                        },
                        {
                          "children": [
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "content": "Name",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.name"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Description"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.description"
                                }
                              ],
                              "gap": "xs"
                            },
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Status"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.status",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "xs"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Notes",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.notes",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "xs"
                            },
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "xs",
                              "children": [
                                {
                                  "content": "Age",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.age",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Is Active"
                                },
                                {
                                  "content": "@entity.isActive",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "gap": "xs",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Birth Date",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.birthDate"
                                }
                              ],
                              "direction": "vertical"
                            },
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "content": "Priority",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.priority"
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "gap": "xs",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Category ID",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.categoryId"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ],
                          "type": "grid",
                          "gap": "md",
                          "cols": 2.0
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "action": "RESET",
                          "label": "New Entry",
                          "icon": "plus"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "editing",
                "event": "RESET",
                "effects": [
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "success": "FormEntryLoaded",
                        "failure": "FormEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "FormEntry",
                    {
                      "emit": {
                        "failure": "FormEntryLoadFailed",
                        "success": "FormEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "FormEntry Form"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SUBMIT",
                          "type": "form-section",
                          "cancelEvent": "INIT",
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "label": "Status",
                              "values": [
                                "active",
                                "inactive",
                                "pending"
                              ],
                              "name": "status",
                              "type": "enum"
                            },
                            {
                              "type": "textarea",
                              "label": "Notes",
                              "name": "notes"
                            },
                            {
                              "type": "number",
                              "label": "Age",
                              "name": "age"
                            },
                            {
                              "type": "boolean",
                              "label": "Is Active",
                              "name": "isActive"
                            },
                            {
                              "name": "birthDate",
                              "type": "date",
                              "label": "Birth Date"
                            },
                            {
                              "label": "Priority",
                              "type": "enum",
                              "name": "priority",
                              "values": [
                                "low",
                                "medium",
                                "high",
                                "critical"
                              ]
                            },
                            {
                              "relation": {
                                "entity": "FormEntry",
                                "cardinality": "one"
                              },
                              "type": "relation",
                              "name": "categoryId",
                              "label": "Category ID"
                            }
                          ],
                          "mode": "create"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FormEntryFormPage",
          "path": "/formentrys/form",
          "traits": [
            {
              "ref": "FormEntryFormAdvanced"
            }
          ]
        }
      ]
    }
  ]
}