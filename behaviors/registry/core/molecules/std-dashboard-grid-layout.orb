{
  "name": "std-dashboard-grid-layout",
  "version": "1.0.0",
  "description": "std-dashboard-grid-layout — std-stats + std-graphs + std-browse inside a dashboard-layout chrome with sidebar nav.",
  "orbitals": [
    {
      "name": "DashboardGridItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "DashboardGridItem",
        "collection": "dashboardgriditems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "label",
            "type": "string"
          },
          {
            "name": "amount",
            "type": "number"
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "timestamp",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "DashboardStats",
          "config": {
            "aggregations": [
              {
                "type": "sum",
                "label": "Total",
                "field": "amount"
              },
              {
                "field": "amount",
                "type": "avg",
                "label": "Average"
              },
              {
                "field": "id",
                "type": "count",
                "label": "Count"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "DashboardFeed"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DashboardGraphs",
          "config": {
            "chartType": "bar",
            "valueField": "amount",
            "categoryField": "category"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "DashboardFeed"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DashboardFeed",
          "linkedEntity": "DashboardGridItem",
          "config": {
            "pageSize": 10.0,
            "fields": [
              {
                "name": "timestamp",
                "label": "When",
                "variant": "caption"
              },
              {
                "name": "label",
                "label": "Activity",
                "variant": "h5"
              },
              {
                "name": "amount",
                "label": "Amount",
                "variant": "badge"
              }
            ]
          }
        },
        {
          "name": "DashboardLayout",
          "category": "interaction",
          "linkedEntity": "DashboardGridItem",
          "emits": [
            {
              "event": "DashboardGridItemLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DashboardGridItemLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DashboardGridItem]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DashboardGridItemLoadFailed",
                "name": "DashboardGridItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DashboardGridItemLoaded",
                "name": "DashboardGridItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DashboardGridItem]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DashboardGridItem",
                    {
                      "emit": {
                        "failure": "DashboardGridItemLoadFailed",
                        "success": "DashboardGridItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "icon": "bar-chart-3",
                          "href": "/dashboard",
                          "label": "Dashboard"
                        }
                      ],
                      "children": [
                        {
                          "gap": "lg",
                          "type": "stack",
                          "direction": "vertical",
                          "className": "max-w-6xl mx-auto w-full",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "bar-chart-3",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Dashboard",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            "@trait.DashboardStats",
                            "@trait.DashboardGraphs",
                            {
                              "type": "typography",
                              "variant": "h4",
                              "content": "Recent Activity"
                            },
                            "@trait.DashboardFeed"
                          ]
                        }
                      ],
                      "appName": "Dashboard",
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Dashboard",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardLayout"
            },
            {
              "ref": "DashboardStats"
            },
            {
              "ref": "DashboardGraphs"
            },
            {
              "ref": "DashboardFeed"
            }
          ]
        }
      ]
    }
  ]
}
