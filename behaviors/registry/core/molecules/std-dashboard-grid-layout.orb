{
  "name": "std-dashboard-grid-layout",
  "version": "2.0.0",
  "description": "std-dashboard-grid-layout — dashboard-layout chrome with three trait config slots: statsTrait, graphsTrait, feedTrait.",
  "orbitals": [
    {
      "name": "DashboardGridLayoutOrbital",
      "entity": {
        "name": "DashboardGridLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DashboardGridLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": "@config.navItems",
                      "type": "dashboard-layout",
                      "appName": "@config.appName",
                      "children": [
                        "@config.statsTrait",
                        "@config.graphsTrait",
                        {
                          "content": "Recent Activity",
                          "variant": "h4",
                          "type": "typography"
                        },
                        "@config.feedTrait"
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "statsTrait": {
              "type": "trait"
            },
            "graphsTrait": {
              "type": "trait"
            },
            "feedTrait": {
              "type": "trait"
            },
            "navItems": {
              "type": "[object]",
              "default": [
                {
                  "icon": "bar-chart-3",
                  "href": "/dashboard",
                  "label": "Dashboard"
                }
              ]
            },
            "appName": {
              "type": "string",
              "default": "Dashboard"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DashboardGridLayoutPage",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardGridLayout"
            }
          ]
        }
      ]
    }
  ]
}