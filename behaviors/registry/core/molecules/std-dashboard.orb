{
  "description": "std-dashboard — molecule composing std-stats + std-graphs + std-browse (stat cards top, charts middle, data list bottom). Browse is the data hub; Stats and Graphs listen for `BrowseItemLoaded -> ITEMS_LOADED`.",
  "name": "std-dashboard",
  "orbitals": [
    {
      "entity": {
        "collection": "dashboarditems",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "A human-readable identifier for the item.",
            "name": "name",
            "synonyms": "title, label, identifier",
            "type": "string"
          },
          {
            "description": "The type or classification of the dashboard item.",
            "name": "category",
            "synonyms": "type, kind, group",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the item.",
            "name": "status",
            "synonyms": "state, condition, enabled, disabled",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "default": 0.0,
            "description": "The numerical value being represented.",
            "name": "amount",
            "synonyms": "value, quantity, count, total",
            "type": "number"
          },
          {
            "default": 0.0,
            "description": "Represents a numerical measurement or quantity.",
            "name": "units",
            "synonyms": "value, count, measure",
            "type": "number"
          }
        ],
        "name": "DashboardItem",
        "persistence": "persistent"
      },
      "name": "DashboardItemOrbital",
      "pages": [
        {
          "name": "Dashboard",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardLayout"
            },
            {
              "ref": "DashboardSummary"
            },
            {
              "ref": "DashboardCategoryChart"
            },
            {
              "ref": "DashboardStatusChart"
            },
            {
              "ref": "DashboardItemBrowse"
            },
            {
              "ref": "Icon1"
            },
            {
              "ref": "Typography1"
            },
            {
              "ref": "Divider1"
            },
            {
              "ref": "SimpleGrid1"
            },
            {
              "ref": "Typography2"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "metrics": {
              "default": [
                {
                  "aggregation": "count",
                  "format": "number",
                  "icon": "list",
                  "label": "Total Items",
                  "variant": "primary"
                },
                {
                  "aggregation": "count",
                  "filter": [
                    "fn",
                    "row",
                    [
                      "=",
                      "@row.status",
                      "active"
                    ]
                  ],
                  "format": "number",
                  "icon": "check-circle",
                  "label": "Active",
                  "variant": "success"
                },
                {
                  "aggregation": "sum",
                  "field": "amount",
                  "format": "currency",
                  "icon": "dollar-sign",
                  "label": "Total Revenue",
                  "target": 10000.0,
                  "variant": "info"
                },
                {
                  "aggregation": "avg",
                  "field": "units",
                  "format": "number",
                  "icon": "trending-up",
                  "label": "Avg Units",
                  "suffix": " units",
                  "variant": "default"
                }
              ],
              "type": "unknown"
            },
            "title": {
              "default": "Summary",
              "type": "unknown"
            }
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "source": {
                "kind": "trait",
                "trait": "DashboardItemBrowse"
              },
              "triggers": "ITEMS_LOADED"
            }
          ],
          "name": "DashboardSummary",
          "ref": "Stats.traits.StatsItemStats"
        },
        {
          "config": {
            "aggregation": {
              "default": "count",
              "type": "unknown"
            },
            "categoryField": {
              "default": "category",
              "type": "unknown"
            },
            "chartType": {
              "default": "bar",
              "type": "unknown"
            },
            "height": {
              "default": 280.0,
              "type": "unknown"
            },
            "showLegend": {
              "default": false,
              "type": "unknown"
            },
            "subtitle": {
              "default": "Count across categories",
              "type": "unknown"
            },
            "title": {
              "default": "Items by Category",
              "type": "unknown"
            }
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "source": {
                "kind": "trait",
                "trait": "DashboardItemBrowse"
              },
              "triggers": "ITEMS_LOADED"
            }
          ],
          "name": "DashboardCategoryChart",
          "ref": "Graphs.traits.GraphItemGraph"
        },
        {
          "config": {
            "aggregation": {
              "default": "count",
              "type": "unknown"
            },
            "categoryField": {
              "default": "status",
              "type": "unknown"
            },
            "chartType": {
              "default": "donut",
              "type": "unknown"
            },
            "height": {
              "default": 280.0,
              "type": "unknown"
            },
            "showLegend": {
              "default": true,
              "type": "unknown"
            },
            "title": {
              "default": "Status Mix",
              "type": "unknown"
            }
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "source": {
                "kind": "trait",
                "trait": "DashboardItemBrowse"
              },
              "triggers": "ITEMS_LOADED"
            }
          ],
          "name": "DashboardStatusChart",
          "ref": "Graphs.traits.GraphItemGraph"
        },
        {
          "config": {
            "displayPageSize": {
              "default": 5.0,
              "type": "unknown"
            },
            "fields": {
              "default": [
                {
                  "label": "Name",
                  "name": "name",
                  "variant": "h4"
                },
                {
                  "label": "Category",
                  "name": "category",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                },
                {
                  "label": "Amount",
                  "name": "amount",
                  "variant": "caption"
                }
              ],
              "type": "unknown"
            },
            "pageSize": {
              "default": 100.0,
              "type": "unknown"
            }
          },
          "linkedEntity": "DashboardItem",
          "name": "DashboardItemBrowse",
          "ref": "Browse.traits.BrowseItemBrowse"
        },
        {
          "config": {
            "name": {
              "default": "bar-chart-2",
              "type": "unknown"
            }
          },
          "linkedEntity": "DashboardItem",
          "name": "Icon1",
          "ref": "Icon.traits.IconRender"
        },
        {
          "config": {
            "content": {
              "default": "Dashboard",
              "type": "unknown"
            },
            "variant": {
              "default": "h2",
              "type": "unknown"
            }
          },
          "linkedEntity": "DashboardItem",
          "name": "Typography1",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "linkedEntity": "DashboardItem",
          "name": "Divider1",
          "ref": "Divider.traits.DividerRender"
        },
        {
          "config": {
            "children": {
              "default": [
                "@trait.DashboardCategoryChart",
                "@trait.DashboardStatusChart"
              ],
              "type": "unknown"
            },
            "cols": {
              "default": 2.0,
              "type": "unknown"
            },
            "gap": {
              "default": "md",
              "type": "unknown"
            }
          },
          "linkedEntity": "DashboardItem",
          "name": "SimpleGrid1",
          "ref": "SimpleGrid.traits.SimpleGridRender"
        },
        {
          "config": {
            "content": {
              "default": "Recent Items",
              "type": "unknown"
            },
            "variant": {
              "default": "h3",
              "type": "unknown"
            }
          },
          "linkedEntity": "DashboardItem",
          "name": "Typography2",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Signals a data item has been successfully loaded.",
              "event": "DashboardItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DashboardItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, received, fetched",
              "tier": "domain"
            },
            {
              "description": "Indicates a failure to load a dashboard item.",
              "event": "DashboardItemLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "error, failure, problem, load failed",
              "tier": "internal"
            }
          ],
          "linkedEntity": "DashboardItem",
          "name": "DashboardLayout",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Signals a data item has been successfully loaded.",
                "key": "DashboardItemLoaded",
                "name": "DashboardItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DashboardItem]"
                  }
                ],
                "synonyms": "loaded, received, fetched",
                "tier": "domain"
              },
              {
                "description": "Indicates a failure to load a dashboard item.",
                "key": "DashboardItemLoadFailed",
                "name": "DashboardItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, failure, problem, load failed",
                "tier": "internal"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "composing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "DashboardItem",
                    {
                      "emit": {
                        "failure": "DashboardItemLoadFailed",
                        "success": "DashboardItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            "@trait.Icon1",
                            "@trait.Typography1"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        "@trait.Divider1",
                        "@trait.DashboardSummary",
                        "@trait.SimpleGrid1",
                        "@trait.Divider1",
                        "@trait.Typography2",
                        "@trait.DashboardItemBrowse"
                      ],
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "composing",
                "to": "composing"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Stats",
          "from": "std/behaviors/std-stats"
        },
        {
          "as": "Graphs",
          "from": "std/behaviors/std-graphs"
        },
        {
          "as": "Browse",
          "from": "std/behaviors/std-browse"
        },
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "Divider",
          "from": "std/behaviors/ui-divider"
        },
        {
          "as": "SimpleGrid",
          "from": "std/behaviors/ui-simple-grid"
        }
      ]
    }
  ],
  "version": "1.0.0"
}