{
  "name": "std-dashboard",
  "version": "1.0.0",
  "description": "std-dashboard — molecule composing std-stats + std-graphs + std-browse (stat cards top, charts middle, data list bottom). Browse is the data hub; Stats and Graphs listen for `BrowseItemLoaded -> ITEMS_LOADED`.",
  "orbitals": [
    {
      "name": "DashboardItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "DashboardItem",
        "collection": "dashboarditems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "description": "A human-readable identifier for the item.",
            "synonyms": "title, label, identifier"
          },
          {
            "name": "category",
            "type": "string",
            "description": "The type or classification of the dashboard item.",
            "synonyms": "type, kind, group"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ],
            "description": "Indicates the current operational state of the item.",
            "synonyms": "state, condition, enabled, disabled"
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0,
            "description": "The numerical value being represented.",
            "synonyms": "value, quantity, count, total"
          },
          {
            "name": "units",
            "type": "number",
            "default": 0.0,
            "description": "Represents a numerical measurement or quantity.",
            "synonyms": "value, count, measure"
          }
        ]
      },
      "traits": [
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "DashboardSummary",
          "config": {
            "metrics": [
              {
                "aggregation": "count",
                "label": "Total Items",
                "icon": "list",
                "format": "number",
                "variant": "primary"
              },
              {
                "aggregation": "count",
                "variant": "success",
                "format": "number",
                "label": "Active",
                "icon": "check-circle",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ]
              },
              {
                "field": "amount",
                "target": 10000.0,
                "aggregation": "sum",
                "label": "Total Revenue",
                "variant": "info",
                "icon": "dollar-sign",
                "format": "currency"
              },
              {
                "label": "Avg Units",
                "icon": "trending-up",
                "aggregation": "avg",
                "field": "units",
                "variant": "default",
                "suffix": " units",
                "format": "number"
              }
            ],
            "title": "Summary"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "DashboardItemBrowse"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DashboardCategoryChart",
          "config": {
            "subtitle": "Count across categories",
            "showLegend": false,
            "chartType": "bar",
            "aggregation": "count",
            "categoryField": "category",
            "height": 280.0,
            "title": "Items by Category"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "DashboardItemBrowse"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DashboardStatusChart",
          "config": {
            "aggregation": "count",
            "chartType": "donut",
            "categoryField": "status",
            "height": 280.0,
            "showLegend": true,
            "title": "Status Mix"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "DashboardItemBrowse"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DashboardItemBrowse",
          "linkedEntity": "DashboardItem",
          "config": {
            "pageSize": 100.0,
            "displayPageSize": 5.0,
            "fields": [
              {
                "label": "Name",
                "variant": "h4",
                "name": "name"
              },
              {
                "name": "category",
                "label": "Category",
                "variant": "caption"
              },
              {
                "variant": "badge",
                "name": "status",
                "label": "Status"
              },
              {
                "name": "amount",
                "label": "Amount",
                "variant": "caption"
              }
            ]
          }
        },
        {
          "name": "DashboardLayout",
          "category": "interaction",
          "linkedEntity": "DashboardItem",
          "emits": [
            {
              "event": "DashboardItemLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DashboardItem]"
                }
              ]
            },
            {
              "event": "DashboardItemLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DashboardItemLoaded",
                "name": "DashboardItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DashboardItem]"
                  }
                ]
              },
              {
                "key": "DashboardItemLoadFailed",
                "name": "DashboardItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DashboardItem",
                    {
                      "emit": {
                        "success": "DashboardItemLoaded",
                        "failure": "DashboardItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "bar-chart-2",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Dashboard"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.DashboardSummary",
                        {
                          "cols": 2.0,
                          "gap": "md",
                          "children": [
                            "@trait.DashboardCategoryChart",
                            "@trait.DashboardStatusChart"
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Recent Items",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.DashboardItemBrowse"
                      ],
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Dashboard",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardLayout"
            },
            {
              "ref": "DashboardSummary"
            },
            {
              "ref": "DashboardCategoryChart"
            },
            {
              "ref": "DashboardStatusChart"
            },
            {
              "ref": "DashboardItemBrowse"
            }
          ]
        }
      ]
    }
  ]
}
