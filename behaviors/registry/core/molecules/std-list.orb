{
  "name": "std-list",
  "version": "1.0.0",
  "description": "std-list as a Function",
  "orbitals": [
    {
      "name": "ListItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "ListItem",
        "collection": "listitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ListItemBrowse",
          "category": "interaction",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ListItemLoaded",
              "description": "Fired when the ListItem collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ListItem]"
                }
              ]
            },
            {
              "event": "ListItemLoadFailed",
              "description": "Fired when the ListItem collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemPersistor"
              }
            },
            {
              "event": "ITEM_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemPersistor"
              }
            },
            {
              "event": "ITEM_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ListItemLoaded",
                "name": "ListItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ListItem]"
                  }
                ]
              },
              {
                "key": "ListItemLoadFailed",
                "name": "ListItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "DELETE",
                "name": "Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "failure": "ListItemLoadFailed",
                        "success": "ListItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading list…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ListItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "list",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "ListItems"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "button",
                              "icon": "plus",
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "Create"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Name",
                              "icon": "list",
                              "name": "name",
                              "variant": "h4"
                            },
                            {
                              "name": "description",
                              "label": "Description",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Edit",
                              "variant": "ghost",
                              "event": "EDIT"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "event": "DELETE"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ListItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load list",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "type": "button",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "label": "Retry"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "success": "ListItemLoaded",
                        "failure": "ListItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "success": "ListItemLoaded",
                        "failure": "ListItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListItemCreate",
          "linkedEntity": "ListItem",
          "config": {
            "icon": "plus-circle",
            "fields": [
              "name",
              "description",
              "status"
            ],
            "mode": "create",
            "title": "Create ListItem"
          },
          "events": {
            "OPEN": "CREATE",
            "SAVE": "LIST_ITEM_CREATED"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListItemBrowse"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListItemEdit",
          "linkedEntity": "ListItem",
          "config": {
            "title": "Edit ListItem",
            "fields": [
              "name",
              "description",
              "status"
            ],
            "icon": "edit",
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT",
            "SAVE": "LIST_ITEM_UPDATED"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ListItemDelete",
          "linkedEntity": "ListItem",
          "config": {
            "title": "Delete ListItem",
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListItemBrowse"
              }
            }
          ]
        },
        {
          "name": "ListItemPersistor",
          "category": "lifecycle",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "ITEM_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LIST_ITEM_CREATED",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListItemCreate"
              }
            },
            {
              "event": "LIST_ITEM_UPDATED",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ListItemEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListItemDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "ListItem",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "ListItem",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEM_CREATED",
                "name": "Item Created"
              },
              {
                "key": "ITEM_UPDATED",
                "name": "Item Updated"
              },
              {
                "key": "ITEM_DELETED",
                "name": "Item Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ListItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "ListItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "ListItem",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ITEM_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ListItemPage",
          "path": "/listitems",
          "traits": [
            {
              "ref": "ListItemBrowse"
            },
            {
              "ref": "ListItemCreate"
            },
            {
              "ref": "ListItemEdit"
            },
            {
              "ref": "ListItemDelete"
            },
            {
              "ref": "ListItemPersistor"
            }
          ]
        }
      ]
    }
  ]
}
