{
  "name": "std-esign-flow",
  "version": "1.0.0",
  "description": "Generic e-signature flow: pick a stored file, pick a recipient, send for signature, track status.",
  "orbitals": [
    {
      "name": "SignatureSessionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-file-store",
          "as": "StoredFile"
        },
        {
          "from": "std/behaviors/std-esign-request",
          "as": "ESignRequest"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "SignatureSession",
        "collection": "signaturesessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "documentId",
            "type": "string",
            "required": true
          },
          {
            "name": "documentName",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientName",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientEmail",
            "type": "string",
            "required": true
          },
          {
            "name": "requesterName",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "viewed",
              "signed",
              "declined"
            ]
          },
          {
            "name": "sentAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "signedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SignatureSessionBrowse",
          "category": "interaction",
          "linkedEntity": "SignatureSession",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "RESEND_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentName",
                  "type": "string"
                },
                {
                  "name": "row.recipientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.recipientEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.sentAt",
                  "type": "string"
                },
                {
                  "name": "row.signedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.documentName",
                  "type": "string"
                },
                {
                  "name": "row.recipientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.recipientEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.sentAt",
                  "type": "string"
                },
                {
                  "name": "row.signedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SignatureSessionLoaded",
              "description": "Fired when the SignatureSession collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[SignatureSession]"
                }
              ]
            },
            {
              "event": "SignatureSessionLoadFailed",
              "description": "Fired when the SignatureSession collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SESSION_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionPersistor"
              }
            },
            {
              "event": "SESSION_RESENT",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionPersistor"
              }
            },
            {
              "event": "SESSION_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SignatureSessionLoaded",
                "name": "SignatureSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SignatureSession]"
                  }
                ]
              },
              {
                "key": "SignatureSessionLoadFailed",
                "name": "SignatureSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "RESEND_REQUEST",
                "name": "Resend Request"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SignatureSession",
                    {
                      "emit": {
                        "success": "SignatureSessionLoaded",
                        "failure": "SignatureSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading signature requests…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SignatureSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-signature"
                                },
                                {
                                  "type": "typography",
                                  "content": "Signature Requests",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "icon": "plus",
                              "label": "New Signature Request",
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "title": "Document Bundle",
                          "coverImageUrl": "https://picsum.photos/seed/esign-cover/1200/400",
                          "subtitle": "Pending signature review",
                          "type": "book-cover-page",
                          "author": "Legal Operations"
                        },
                        {
                          "parts": [
                            {
                              "title": "Pending",
                              "chapters": [
                                {
                                  "id": "ch-a",
                                  "content": "Recipient hasn't opened the envelope yet.",
                                  "title": "Awaiting Recipient"
                                },
                                {
                                  "title": "Awaiting Counter-Signer",
                                  "content": "Recipient signed; counter-signer pending.",
                                  "id": "ch-b"
                                }
                              ]
                            },
                            {
                              "title": "Completed",
                              "chapters": [
                                {
                                  "content": "All parties signed.",
                                  "id": "ch-c",
                                  "title": "Signed"
                                },
                                {
                                  "title": "Declined",
                                  "content": "Recipient declined to sign.",
                                  "id": "ch-d"
                                }
                              ]
                            }
                          ],
                          "currentChapterId": "ch-a",
                          "type": "book-table-of-contents"
                        },
                        {
                          "code": "document MSA-2026.pdf to alex@example.com status sent",
                          "title": "Sample envelope payload",
                          "type": "code-example",
                          "language": "json",
                          "copyable": true
                        },
                        {
                          "code": "POST /api/esign/send",
                          "language": "http",
                          "showCopyButton": true,
                          "showLanguageBadge": true,
                          "type": "code-block"
                        },
                        {
                          "type": "doc-code-block",
                          "showLineNumbers": true,
                          "code": "Signature recipient alex@example.com doc MSA-2026.pdf",
                          "title": "Document structure",
                          "language": "xml"
                        },
                        {
                          "showLineNumbers": true,
                          "showCopy": true,
                          "code": "sendEnvelope doc recipient via api esign send",
                          "type": "code-viewer",
                          "wordWrap": false,
                          "language": "javascript"
                        },
                        {
                          "data": {
                            "documents": 3.0,
                            "kind": "envelope",
                            "recipients": 2.0,
                            "status": "pending"
                          },
                          "type": "code-view",
                          "defaultExpanded": false,
                          "label": "Inspect envelope JSON"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "label": "Document",
                              "icon": "file-text",
                              "variant": "h4",
                              "name": "documentName"
                            },
                            {
                              "variant": "body",
                              "name": "recipientName",
                              "label": "Recipient"
                            },
                            {
                              "label": "Email",
                              "variant": "caption",
                              "name": "recipientEmail"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "name": "sentAt",
                              "variant": "caption",
                              "label": "Sent"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "RESEND_REQUEST",
                              "variant": "primary",
                              "label": "Resend"
                            },
                            {
                              "variant": "danger",
                              "label": "Cancel",
                              "event": "REQUEST_DELETE"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SignatureSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to load signature requests",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SignatureSession",
                    {
                      "emit": {
                        "success": "SignatureSessionLoaded",
                        "failure": "SignatureSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SignatureSession",
                    {
                      "emit": {
                        "success": "SignatureSessionLoaded",
                        "failure": "SignatureSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SignatureSessionCreate",
          "linkedEntity": "SignatureSession",
          "config": {
            "openButtonLabel": "New Signature Request",
            "title": "New Signature Request",
            "mode": "create",
            "icon": "file-signature",
            "fields": [
              "documentId",
              "recipientName",
              "recipientEmail",
              "requesterName"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "SignatureSessionDelete",
          "linkedEntity": "SignatureSession",
          "config": {
            "icon": "alert-triangle",
            "title": "Cancel Signature Request",
            "alertMessage": "Are you sure you want to cancel this signature request?",
            "confirmLabel": "Cancel Request"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionBrowse"
              }
            }
          ]
        },
        {
          "name": "SignatureSessionPersistor",
          "category": "lifecycle",
          "linkedEntity": "SignatureSession",
          "emits": [
            {
              "event": "SESSION_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SESSION_RESENT",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SESSION_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionCreate"
              }
            },
            {
              "event": "RESEND_REQUEST",
              "triggers": "DO_RESEND",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionBrowse"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "SignatureSessionDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_RESEND",
                "name": "Do Resend",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SESSION_CREATED",
                "name": "Session Created"
              },
              {
                "key": "SESSION_RESENT",
                "name": "Session Resent"
              },
              {
                "key": "SESSION_DELETED",
                "name": "Session Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "SignatureSession",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SESSION_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_RESEND",
                "effects": [
                  [
                    "persist",
                    "update",
                    "SignatureSession",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "SESSION_RESENT"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "SignatureSession",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "SESSION_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SignatureSessionPage",
          "path": "/esign-flow",
          "traits": [
            {
              "ref": "SignatureSessionBrowse"
            },
            {
              "ref": "SignatureSessionCreate"
            },
            {
              "ref": "SignatureSessionDelete"
            },
            {
              "ref": "SignatureSessionPersistor"
            }
          ]
        }
      ]
    }
  ]
}