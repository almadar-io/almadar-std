{
  "description": "std-tabs-layout — chrome with std-tabs strip; consumer overrides config.tabs[].content with @trait.X references.",
  "name": "std-tabs-layout",
  "orbitals": [
    {
      "entity": {
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "name": "TabsLayoutData",
        "persistence": "runtime"
      },
      "name": "TabsLayoutOrbital",
      "pages": [
        {
          "name": "TabsLayoutPage",
          "path": "/tabs-layout",
          "traits": [
            {
              "ref": "TabsLayout"
            },
            {
              "ref": "TabsLayoutTabs"
            }
          ]
        }
      ],
      "traits": [
        {
          "name": "TabsLayoutTabs",
          "ref": "Tabs.traits.TabsItemTabs"
        },
        {
          "category": "interaction",
          "config": {
            "icon": {
              "default": "layout",
              "description": "Icon name displayed next to the title",
              "label": "Header icon",
              "tier": "presentation",
              "type": "string"
            },
            "title": {
              "default": "Tabbed View",
              "description": "Heading shown above the tab strip",
              "label": "Page title",
              "tier": "presentation",
              "type": "string"
            }
          },
          "name": "TabsLayout",
          "scope": "instance",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "composing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "@config.icon",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.TabsLayoutTabs"
                      ],
                      "className": "max-w-6xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "composing",
                "to": "composing"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Tabs",
          "from": "std/behaviors/std-tabs"
        }
      ]
    }
  ],
  "version": "2.0.0"
}