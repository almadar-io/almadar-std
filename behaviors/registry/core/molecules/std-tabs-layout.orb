{
  "name": "std-tabs-layout",
  "version": "2.0.0",
  "description": "std-tabs-layout — chrome with std-tabs strip; consumer overrides config.tabs[].content with @trait.X references.",
  "orbitals": [
    {
      "name": "TabsLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "TabsLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "Tabs.traits.TabsItemTabs",
          "name": "TabsLayoutTabs"
        },
        {
          "name": "TabsLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "max-w-6xl mx-auto w-full",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "@config.icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h2"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.TabsLayoutTabs"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Tabbed View",
              "label": "Page title",
              "description": "Heading shown above the tab strip"
            },
            "icon": {
              "type": "string",
              "default": "layout",
              "label": "Header icon",
              "description": "Icon name displayed next to the title"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TabsLayoutPage",
          "path": "/tabs-layout",
          "traits": [
            {
              "ref": "TabsLayout"
            },
            {
              "ref": "TabsLayoutTabs"
            }
          ]
        }
      ]
    }
  ]
}