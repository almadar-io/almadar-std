{
  "name": "std-master-detail-layout",
  "version": "2.0.0",
  "description": "std-master-detail-layout — chrome with std-drawer side-panel + masterTrait config slot for the consumer's master list.",
  "orbitals": [
    {
      "name": "MasterDetailLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-drawer",
          "as": "Drawer"
        }
      ],
      "entity": {
        "name": "MasterDetailLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "Drawer.traits.DrawerContentDrawer",
          "name": "MasterDetailDrawer"
        },
        {
          "name": "MasterDetailLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "@config.icon"
                            },
                            {
                              "variant": "h2",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@config.masterTrait"
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "max-w-6xl mx-auto w-full"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "masterTrait": {
              "type": "trait"
            },
            "title": {
              "type": "string",
              "default": "Master / Detail"
            },
            "icon": {
              "type": "string",
              "default": "list"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MasterDetailPage",
          "path": "/master-detail",
          "traits": [
            {
              "ref": "MasterDetailLayout"
            },
            {
              "ref": "MasterDetailDrawer"
            }
          ]
        }
      ]
    }
  ]
}
