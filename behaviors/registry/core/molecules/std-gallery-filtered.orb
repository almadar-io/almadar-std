{
  "name": "std-gallery-filtered",
  "version": "1.0.0",
  "description": "std-gallery-filtered as a Function",
  "orbitals": [
    {
      "name": "GalleryFilteredOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-gallery",
          "as": "Gallery"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        }
      ],
      "entity": {
        "name": "GalleryFilteredItem",
        "collection": "galleryfiltereditems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "imageUrl",
            "type": "string"
          },
          {
            "name": "tags",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "GalleryFilteredSearch",
          "linkedEntity": "GalleryFilteredItem"
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "GalleryFilteredFilter",
          "linkedEntity": "GalleryFilteredItem"
        },
        {
          "ref": "Gallery.traits.GalleryItemGallery",
          "name": "GalleryFilteredGallery",
          "linkedEntity": "GalleryFilteredItem"
        },
        {
          "name": "GalleryFilteredLayout",
          "category": "interaction",
          "linkedEntity": "GalleryFilteredItem",
          "emits": [
            {
              "event": "GalleryFilteredItemLoadFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GalleryFilteredItemLoaded",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[GalleryFilteredItem]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GalleryFilteredItemLoadFailed",
                "name": "GalleryFilteredItem load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GalleryFilteredItemLoaded",
                "name": "GalleryFilteredItem loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[GalleryFilteredItem]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryFilteredItem",
                    {
                      "emit": {
                        "success": "GalleryFilteredItemLoaded",
                        "failure": "GalleryFilteredItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            "@trait.GalleryFilteredSearch",
                            "@trait.GalleryFilteredFilter"
                          ]
                        },
                        "@trait.GalleryFilteredGallery"
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Gallery",
          "path": "/gallery",
          "traits": [
            {
              "ref": "GalleryFilteredLayout"
            }
          ]
        }
      ]
    }
  ]
}
