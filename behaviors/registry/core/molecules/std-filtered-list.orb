{
  "name": "std-filtered-list",
  "version": "1.0.0",
  "description": "std-filtered-list — molecule composing slim Search/Filter/Browse/Pagination atoms",
  "orbitals": [
    {
      "name": "FilteredListItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-pagination",
          "as": "Pagination"
        }
      ],
      "entity": {
        "name": "FilteredListItem",
        "collection": "filteredlistitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          }
        ]
      },
      "traits": [
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "FilteredItemSearch",
          "config": {
            "event": "SEARCH",
            "placeholder": "Search filtered items…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "FilteredItemFilter",
          "config": {
            "filters": [
              {
                "field": "status",
                "filterType": "select",
                "options": [
                  "active",
                  "inactive",
                  "pending"
                ],
                "label": "Status"
              }
            ],
            "event": "FILTER"
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "FilteredItemBrowse",
          "linkedEntity": "FilteredListItem",
          "config": {
            "pageSize": 3.0,
            "fields": [
              {
                "label": "Name",
                "variant": "h4",
                "name": "name"
              },
              {
                "label": "Description",
                "variant": "caption",
                "name": "description"
              },
              {
                "label": "Status",
                "variant": "badge",
                "name": "status"
              }
            ]
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemFilter"
              }
            },
            {
              "event": "PAGE",
              "triggers": "REFETCH_PAGE",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemPagination"
              }
            }
          ]
        },
        {
          "ref": "Pagination.traits.PagedItemPagination",
          "name": "FilteredItemPagination",
          "config": {
            "pageSize": 3.0,
            "event": "PAGE"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemBrowse"
              }
            }
          ]
        },
        {
          "name": "FilteredListLayout",
          "category": "interaction",
          "linkedEntity": "FilteredListItem",
          "emits": [
            {
              "event": "FilteredListItemLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FilteredListItemLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[FilteredListItem]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FilteredListItemLoadFailed",
                "name": "FilteredListItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FilteredListItemLoaded",
                "name": "FilteredListItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[FilteredListItem]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilteredListItem",
                    {
                      "emit": {
                        "success": "FilteredListItemLoaded",
                        "failure": "FilteredListItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Filtered List"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            "@trait.FilteredItemSearch",
                            "@trait.FilteredItemFilter"
                          ]
                        },
                        "@trait.FilteredItemBrowse",
                        "@trait.FilteredItemPagination"
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "FilteredList",
          "path": "/filtered-list",
          "traits": [
            {
              "ref": "FilteredListLayout"
            },
            {
              "ref": "FilteredItemSearch"
            },
            {
              "ref": "FilteredItemFilter"
            },
            {
              "ref": "FilteredItemBrowse"
            },
            {
              "ref": "FilteredItemPagination"
            }
          ]
        }
      ]
    }
  ]
}