{
  "description": "std-filtered-list — molecule composing slim Search/Filter/Browse/Pagination atoms",
  "name": "std-filtered-list",
  "orbitals": [
    {
      "entity": {
        "collection": "filteredlistitems",
        "fields": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "description": "The displayed text for the list item.",
            "name": "name",
            "synonyms": "label, title, display_name",
            "type": "string"
          },
          {
            "description": "A textual explanation of the list item's content.",
            "name": "description",
            "synonyms": "text, details, explanation, summary",
            "type": "string"
          },
          {
            "default": "active",
            "description": "Indicates the current operational state of the item.",
            "name": "status",
            "synonyms": "state, condition, enabled, disabled",
            "type": "string",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          }
        ],
        "name": "FilteredListItem",
        "persistence": "persistent"
      },
      "name": "FilteredListItemOrbital",
      "pages": [
        {
          "name": "FilteredList",
          "path": "/filtered-list",
          "traits": [
            {
              "ref": "FilteredListLayout"
            },
            {
              "ref": "FilteredItemSearch"
            },
            {
              "ref": "FilteredItemFilter"
            },
            {
              "ref": "FilteredItemBrowse"
            },
            {
              "ref": "FilteredItemPagination"
            },
            {
              "ref": "Icon1"
            },
            {
              "ref": "Typography1"
            },
            {
              "ref": "Divider1"
            }
          ]
        }
      ],
      "traits": [
        {
          "config": {
            "event": {
              "default": "SEARCH",
              "type": "unknown"
            },
            "placeholder": {
              "default": "Search filtered items…",
              "type": "unknown"
            }
          },
          "name": "FilteredItemSearch",
          "ref": "Search.traits.SearchResultSearch"
        },
        {
          "config": {
            "event": {
              "default": "FILTER",
              "type": "unknown"
            },
            "filters": {
              "default": [
                {
                  "field": "status",
                  "filterType": "select",
                  "label": "Status",
                  "options": [
                    "active",
                    "inactive",
                    "pending"
                  ]
                }
              ],
              "type": "unknown"
            }
          },
          "name": "FilteredItemFilter",
          "ref": "Filter.traits.FilterTargetFilter"
        },
        {
          "config": {
            "fields": {
              "default": [
                {
                  "label": "Name",
                  "name": "name",
                  "variant": "h4"
                },
                {
                  "label": "Description",
                  "name": "description",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                }
              ],
              "type": "unknown"
            },
            "pageSize": {
              "default": 3.0,
              "type": "unknown"
            }
          },
          "linkedEntity": "FilteredListItem",
          "listens": [
            {
              "event": "SEARCH",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemSearch"
              },
              "triggers": "REFETCH_QUERY"
            },
            {
              "event": "FILTER",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemFilter"
              },
              "triggers": "REFETCH_FILTER"
            },
            {
              "event": "PAGE",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemPagination"
              },
              "triggers": "REFETCH_PAGE"
            }
          ],
          "name": "FilteredItemBrowse",
          "ref": "Browse.traits.BrowseItemBrowse"
        },
        {
          "config": {
            "event": {
              "default": "PAGE",
              "type": "unknown"
            },
            "pageSize": {
              "default": 3.0,
              "type": "unknown"
            }
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "source": {
                "kind": "trait",
                "trait": "FilteredItemBrowse"
              },
              "triggers": "ITEMS_LOADED"
            }
          ],
          "name": "FilteredItemPagination",
          "ref": "Pagination.traits.PagedItemPagination"
        },
        {
          "config": {
            "name": {
              "default": "list",
              "type": "unknown"
            }
          },
          "linkedEntity": "FilteredListItem",
          "name": "Icon1",
          "ref": "Icon.traits.IconRender"
        },
        {
          "config": {
            "content": {
              "default": "Filtered List",
              "type": "unknown"
            },
            "variant": {
              "default": "h2",
              "type": "unknown"
            }
          },
          "linkedEntity": "FilteredListItem",
          "name": "Typography1",
          "ref": "Typography.traits.TypographyRender"
        },
        {
          "linkedEntity": "FilteredListItem",
          "name": "Divider1",
          "ref": "Divider.traits.DividerRender"
        },
        {
          "category": "interaction",
          "emits": [
            {
              "description": "Indicates failure to load a list item.",
              "event": "FilteredListItemLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ],
              "scope": "internal",
              "synonyms": "error, fail, problem, unsuccessful",
              "tier": "internal"
            },
            {
              "description": "Signals a filtered list item has been successfully loaded.",
              "event": "FilteredListItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[FilteredListItem]"
                }
              ],
              "scope": "internal",
              "synonyms": "loaded, received, populated",
              "tier": "domain"
            }
          ],
          "linkedEntity": "FilteredListItem",
          "name": "FilteredListLayout",
          "scope": "collection",
          "stateMachine": {
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "description": "Indicates failure to load a list item.",
                "key": "FilteredListItemLoadFailed",
                "name": "FilteredListItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ],
                "synonyms": "error, fail, problem, unsuccessful",
                "tier": "internal"
              },
              {
                "description": "Signals a filtered list item has been successfully loaded.",
                "key": "FilteredListItemLoaded",
                "name": "FilteredListItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[FilteredListItem]"
                  }
                ],
                "synonyms": "loaded, received, populated",
                "tier": "domain"
              }
            ],
            "states": [
              {
                "isInitial": true,
                "name": "composing"
              }
            ],
            "transitions": [
              {
                "effects": [
                  [
                    "fetch",
                    "FilteredListItem",
                    {
                      "emit": {
                        "failure": "FilteredListItemLoadFailed",
                        "success": "FilteredListItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            "@trait.Icon1",
                            "@trait.Typography1"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        "@trait.Divider1",
                        {
                          "children": [
                            "@trait.FilteredItemSearch",
                            "@trait.FilteredItemFilter"
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        "@trait.FilteredItemBrowse",
                        "@trait.FilteredItemPagination"
                      ],
                      "className": "max-w-5xl mx-auto w-full",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ],
                "event": "INIT",
                "from": "composing",
                "to": "composing"
              }
            ]
          }
        }
      ],
      "uses": [
        {
          "as": "Search",
          "from": "std/behaviors/std-search"
        },
        {
          "as": "Filter",
          "from": "std/behaviors/std-filter"
        },
        {
          "as": "Browse",
          "from": "std/behaviors/std-browse"
        },
        {
          "as": "Pagination",
          "from": "std/behaviors/std-pagination"
        },
        {
          "as": "Icon",
          "from": "std/behaviors/ui-icon"
        },
        {
          "as": "Typography",
          "from": "std/behaviors/ui-typography"
        },
        {
          "as": "Divider",
          "from": "std/behaviors/ui-divider"
        }
      ]
    }
  ],
  "version": "1.0.0"
}