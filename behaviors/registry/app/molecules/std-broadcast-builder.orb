{
  "name": "std-broadcast-builder",
  "version": "1.0.0",
  "description": "std-broadcast-builder composes EmailBroadcast + Segment + TemplateEditor + Modal + Confirmation into a unified broadcast-building UI",
  "orbitals": [
    {
      "name": "BroadcastBuilderOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-email-broadcast",
          "as": "EmailBroadcast"
        },
        {
          "from": "std/behaviors/std-segment",
          "as": "Segment"
        },
        {
          "from": "std/behaviors/std-template-editor",
          "as": "TemplateEditor"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "BroadcastDraft",
        "collection": "broadcastdrafts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "segmentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "segmentName",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateId",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateName",
            "type": "string",
            "default": ""
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "ready",
              "sent"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "BroadcastDraftBrowse",
          "category": "interaction",
          "linkedEntity": "BroadcastDraft",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.segmentId",
                  "type": "string"
                },
                {
                  "name": "row.segmentName",
                  "type": "string"
                },
                {
                  "name": "row.templateId",
                  "type": "string"
                },
                {
                  "name": "row.templateName",
                  "type": "string"
                },
                {
                  "name": "row.subject",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BroadcastDraftLoaded",
              "description": "Fired when the broadcast-draft collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BroadcastDraft]"
                }
              ]
            },
            {
              "event": "BroadcastDraftLoadFailed",
              "description": "Fired when the broadcast-draft collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DRAFT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftPersistor"
              }
            },
            {
              "event": "DRAFT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BroadcastDraftLoaded",
                "name": "BroadcastDraft loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BroadcastDraft]"
                  }
                ]
              },
              {
                "key": "BroadcastDraftLoadFailed",
                "name": "BroadcastDraft load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BroadcastDraft",
                    {
                      "emit": {
                        "success": "BroadcastDraftLoaded",
                        "failure": "BroadcastDraftLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading broadcasts…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BroadcastDraftLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "send",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h3",
                                  "content": "Broadcasts"
                                }
                              ],
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "icon": "plus",
                              "label": "New Broadcast",
                              "action": "CREATE"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "icon": "send",
                              "label": "Total drafts"
                            },
                            {
                              "type": "stat-display",
                              "label": "Sent this month",
                              "icon": "check-circle",
                              "value": "128"
                            },
                            {
                              "label": "Open rate",
                              "type": "stat-display",
                              "icon": "mail-open",
                              "value": "42%"
                            },
                            {
                              "type": "stat-display",
                              "label": "Click rate",
                              "value": "11%",
                              "icon": "mouse-pointer"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Delete",
                              "event": "REQUEST_DELETE",
                              "variant": "danger"
                            }
                          ],
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "icon": "send",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Subject",
                              "variant": "caption",
                              "name": "subject"
                            },
                            {
                              "name": "segmentName",
                              "label": "Segment",
                              "variant": "caption"
                            },
                            {
                              "name": "templateName",
                              "label": "Template",
                              "variant": "caption"
                            },
                            {
                              "label": "Scheduled",
                              "variant": "caption",
                              "name": "scheduledAt"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BroadcastDraftLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BroadcastDraft",
                    {
                      "emit": {
                        "failure": "BroadcastDraftLoadFailed",
                        "success": "BroadcastDraftLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BroadcastDraft",
                    {
                      "emit": {
                        "success": "BroadcastDraftLoaded",
                        "failure": "BroadcastDraftLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "BroadcastDraftCreate",
          "linkedEntity": "BroadcastDraft",
          "config": {
            "fields": [
              "name",
              "segmentId",
              "templateId",
              "subject",
              "scheduledAt"
            ],
            "icon": "plus-circle",
            "title": "New Broadcast",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "BroadcastDraftDelete",
          "linkedEntity": "BroadcastDraft",
          "config": {
            "alertMessage": "This will discard the draft.",
            "title": "Delete Draft",
            "confirmLabel": "Delete",
            "icon": "alert-triangle"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftBrowse"
              }
            }
          ]
        },
        {
          "name": "BroadcastDraftPersistor",
          "category": "lifecycle",
          "linkedEntity": "BroadcastDraft",
          "emits": [
            {
              "event": "DRAFT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DRAFT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftCreate"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DRAFT_CREATED",
                "name": "Draft Created"
              },
              {
                "key": "DRAFT_DELETED",
                "name": "Draft Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "BroadcastDraft",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "DRAFT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "BroadcastDraft",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "DRAFT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BroadcastBuilderPage",
          "path": "/broadcast-builder",
          "traits": [
            {
              "ref": "BroadcastDraftBrowse"
            },
            {
              "ref": "BroadcastDraftCreate"
            },
            {
              "ref": "BroadcastDraftDelete"
            },
            {
              "ref": "BroadcastDraftPersistor"
            }
          ]
        }
      ]
    }
  ]
}
