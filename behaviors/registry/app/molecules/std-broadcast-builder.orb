{
  "name": "std-broadcast-builder",
  "version": "1.0.0",
  "description": "std-broadcast-builder composes EmailBroadcast + Segment + TemplateEditor + Modal + Confirmation into a unified broadcast-building UI",
  "orbitals": [
    {
      "name": "BroadcastBuilderOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-email-broadcast",
          "as": "EmailBroadcast"
        },
        {
          "from": "std/behaviors/std-segment",
          "as": "Segment"
        },
        {
          "from": "std/behaviors/std-template-editor",
          "as": "TemplateEditor"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "BroadcastDraft",
        "collection": "broadcastdrafts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "segmentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "segmentName",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateId",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateName",
            "type": "string",
            "default": ""
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "ready",
              "sent"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "BroadcastDraftBrowse",
          "category": "interaction",
          "linkedEntity": "BroadcastDraft",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.segmentId",
                  "type": "string"
                },
                {
                  "name": "row.segmentName",
                  "type": "string"
                },
                {
                  "name": "row.templateId",
                  "type": "string"
                },
                {
                  "name": "row.templateName",
                  "type": "string"
                },
                {
                  "name": "row.subject",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BroadcastDraftLoaded",
              "description": "Fired when the broadcast-draft collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BroadcastDraft]"
                }
              ]
            },
            {
              "event": "BroadcastDraftLoadFailed",
              "description": "Fired when the broadcast-draft collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DRAFT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftPersistor"
              }
            },
            {
              "event": "DRAFT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BroadcastDraftLoaded",
                "name": "BroadcastDraft loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BroadcastDraft]"
                  }
                ]
              },
              {
                "key": "BroadcastDraftLoadFailed",
                "name": "BroadcastDraft load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BroadcastDraft",
                    {
                      "emit": {
                        "success": "BroadcastDraftLoaded",
                        "failure": "BroadcastDraftLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading broadcasts…"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BroadcastDraftLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "entity": "BroadcastDraft",
                          "type": "hero-organism"
                        },
                        {
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "send"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Broadcasts"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "action": "CREATE",
                              "icon": "plus",
                              "type": "button",
                              "label": "New Broadcast",
                              "variant": "primary"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "stats-grid",
                          "columns": 4.0,
                          "stats": [
                            {
                              "label": "Sent this month",
                              "value": "128"
                            },
                            {
                              "label": "Open rate",
                              "value": "42%"
                            },
                            {
                              "value": "11%",
                              "label": "Click rate"
                            },
                            {
                              "value": "0.8%",
                              "label": "Bounce rate"
                            }
                          ]
                        },
                        {
                          "currentStep": 2.0,
                          "type": "wizard-progress",
                          "steps": [
                            {
                              "label": "Audience",
                              "id": "audience"
                            },
                            {
                              "id": "template",
                              "label": "Template"
                            },
                            {
                              "id": "schedule",
                              "label": "Schedule"
                            },
                            {
                              "id": "review",
                              "label": "Review"
                            },
                            {
                              "id": "send",
                              "label": "Send"
                            }
                          ]
                        },
                        {
                          "type": "progress-dots",
                          "currentIndex": 2.0,
                          "size": "md",
                          "count": 5.0
                        },
                        {
                          "tabs": [
                            {
                              "content": {
                                "content": "Broadcast drafts awaiting completion.",
                                "type": "typography"
                              },
                              "label": "Drafts",
                              "id": "drafts"
                            },
                            {
                              "id": "scheduled",
                              "label": "Scheduled",
                              "content": {
                                "type": "typography",
                                "content": "Queued for future delivery."
                              }
                            },
                            {
                              "label": "Sent",
                              "id": "sent",
                              "content": {
                                "type": "typography",
                                "content": "Delivered broadcasts and reports."
                              }
                            }
                          ],
                          "type": "tabbed-container",
                          "defaultTab": "drafts"
                        },
                        {
                          "title": "Boost engagement with segmented broadcasts",
                          "background": "gradient",
                          "align": "center",
                          "subtitle": "Target the right cohort at the right time.",
                          "type": "cta-banner"
                        },
                        {
                          "type": "feature-grid-organism",
                          "entity": "BroadcastDraft"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "description": "Reach the contacts most likely to convert.",
                              "icon": "users",
                              "type": "feature-card",
                              "title": "Audience segmentation",
                              "linkLabel": "View segments"
                            },
                            {
                              "title": "Template library",
                              "icon": "file-text",
                              "description": "Reusable email and SMS templates.",
                              "type": "feature-card",
                              "linkLabel": "Open library"
                            },
                            {
                              "description": "Pick send windows that match recipient time zones.",
                              "title": "Send-time scheduling",
                              "linkLabel": "Schedule",
                              "type": "feature-card",
                              "icon": "clock"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "install-box",
                          "command": "npx almadar broadcast --new",
                          "label": "Author a broadcast from the CLI"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "h4",
                              "label": "Name",
                              "icon": "send",
                              "name": "name"
                            },
                            {
                              "name": "subject",
                              "variant": "body",
                              "label": "Subject"
                            },
                            {
                              "name": "segmentName",
                              "variant": "caption",
                              "label": "Segment"
                            },
                            {
                              "label": "Template",
                              "name": "templateName",
                              "variant": "caption"
                            },
                            {
                              "label": "Scheduled",
                              "name": "scheduledAt",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BroadcastDraftLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load broadcasts"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "label": "Retry",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "INIT"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BroadcastDraft",
                    {
                      "emit": {
                        "success": "BroadcastDraftLoaded",
                        "failure": "BroadcastDraftLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BroadcastDraft",
                    {
                      "emit": {
                        "success": "BroadcastDraftLoaded",
                        "failure": "BroadcastDraftLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "BroadcastDraftCreate",
          "linkedEntity": "BroadcastDraft",
          "config": {
            "mode": "create",
            "icon": "plus-circle",
            "fields": [
              "name",
              "segmentId",
              "templateId",
              "subject",
              "scheduledAt"
            ],
            "title": "New Broadcast"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "BroadcastDraftDelete",
          "linkedEntity": "BroadcastDraft",
          "config": {
            "confirmLabel": "Delete",
            "alertMessage": "This will discard the draft.",
            "icon": "alert-triangle",
            "title": "Delete Draft"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftBrowse"
              }
            }
          ]
        },
        {
          "name": "BroadcastDraftPersistor",
          "category": "lifecycle",
          "linkedEntity": "BroadcastDraft",
          "emits": [
            {
              "event": "DRAFT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DRAFT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftCreate"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "BroadcastDraftDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DRAFT_CREATED",
                "name": "Draft Created"
              },
              {
                "key": "DRAFT_DELETED",
                "name": "Draft Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "BroadcastDraft",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "DRAFT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "BroadcastDraft",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "DRAFT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "BroadcastBuilderPage",
          "path": "/broadcast-builder",
          "traits": [
            {
              "ref": "BroadcastDraftBrowse"
            },
            {
              "ref": "BroadcastDraftCreate"
            },
            {
              "ref": "BroadcastDraftDelete"
            },
            {
              "ref": "BroadcastDraftPersistor"
            }
          ]
        }
      ]
    }
  ]
}