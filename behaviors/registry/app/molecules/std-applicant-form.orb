{
  "name": "std-applicant-form",
  "version": "1.0.0",
  "description": "std-applicant-form — unified applicant intake: capture applicant + first interview slot atomically.",
  "orbitals": [
    {
      "name": "ApplicationIntakeOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-applicant",
          "as": "Applicant"
        },
        {
          "from": "std/behaviors/std-interview-slot",
          "as": "InterviewSlot"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "ApplicationIntake",
        "collection": "applicationintakes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantEmail",
            "type": "string",
            "default": ""
          },
          {
            "name": "applicantPhone",
            "type": "string",
            "default": ""
          },
          {
            "name": "jobId",
            "type": "string",
            "default": ""
          },
          {
            "name": "resumeUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "firstInterviewAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewFormat",
            "type": "string",
            "default": "video",
            "values": [
              "phone",
              "video",
              "onsite"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "interviewing",
              "completed"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApplicationIntakeBrowse",
          "category": "interaction",
          "linkedEntity": "ApplicationIntake",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "REQUEST_EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantEmail",
                  "type": "string"
                },
                {
                  "name": "row.applicantPhone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.firstInterviewAt",
                  "type": "string"
                },
                {
                  "name": "row.interviewerName",
                  "type": "string"
                },
                {
                  "name": "row.interviewFormat",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantEmail",
                  "type": "string"
                },
                {
                  "name": "row.applicantPhone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.firstInterviewAt",
                  "type": "string"
                },
                {
                  "name": "row.interviewerName",
                  "type": "string"
                },
                {
                  "name": "row.interviewFormat",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicationIntakeLoaded",
              "description": "Fired when the intake collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApplicationIntake]"
                }
              ]
            },
            {
              "event": "ApplicationIntakeLoadFailed",
              "description": "Fired when the intake collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "INTAKE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakePersistor"
              }
            },
            {
              "event": "INTAKE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakePersistor"
              }
            },
            {
              "event": "INTAKE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakePersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApplicationIntakeLoaded",
                "name": "ApplicationIntake loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApplicationIntake]"
                  }
                ]
              },
              {
                "key": "ApplicationIntakeLoadFailed",
                "name": "ApplicationIntake load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "REQUEST_EDIT",
                "name": "Request Edit"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApplicationIntake",
                    {
                      "emit": {
                        "success": "ApplicationIntakeLoaded",
                        "failure": "ApplicationIntakeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading applications…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApplicationIntakeLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "user-plus",
                                  "type": "icon"
                                },
                                {
                                  "content": "Applicant Intake",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "icon": "plus",
                              "label": "New Application",
                              "action": "CREATE",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "event": "REQUEST_EDIT",
                              "label": "Edit"
                            },
                            {
                              "event": "REQUEST_DELETE",
                              "variant": "danger",
                              "label": "Delete"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "h4",
                              "name": "applicantName",
                              "icon": "user",
                              "label": "Applicant"
                            },
                            {
                              "label": "Email",
                              "name": "applicantEmail",
                              "variant": "caption"
                            },
                            {
                              "label": "Job",
                              "name": "jobId",
                              "variant": "caption"
                            },
                            {
                              "name": "firstInterviewAt",
                              "label": "First Interview",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApplicationIntakeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load applications",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "variant": "primary",
                          "label": "Retry",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApplicationIntake",
                    {
                      "emit": {
                        "success": "ApplicationIntakeLoaded",
                        "failure": "ApplicationIntakeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApplicationIntake",
                    {
                      "emit": {
                        "failure": "ApplicationIntakeLoadFailed",
                        "success": "ApplicationIntakeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ApplicationIntakeCreate",
          "linkedEntity": "ApplicationIntake",
          "config": {
            "title": "New Application",
            "fields": [
              "applicantName",
              "applicantEmail",
              "applicantPhone",
              "jobId",
              "resumeUrl",
              "firstInterviewAt",
              "interviewerName",
              "interviewFormat"
            ],
            "mode": "create",
            "icon": "user-plus"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakeBrowse"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ApplicationIntakeEdit",
          "linkedEntity": "ApplicationIntake",
          "config": {
            "fields": [
              "applicantName",
              "applicantEmail",
              "applicantPhone",
              "jobId",
              "resumeUrl",
              "firstInterviewAt",
              "interviewerName",
              "interviewFormat"
            ],
            "mode": "edit",
            "title": "Edit Application",
            "icon": "pencil"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "REQUEST_EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakeBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ApplicationIntakeDelete",
          "linkedEntity": "ApplicationIntake",
          "config": {
            "title": "Delete Application",
            "alertMessage": "Are you sure you want to delete this application?",
            "confirmLabel": "Delete",
            "icon": "alert-triangle"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakeBrowse"
              }
            }
          ]
        },
        {
          "name": "ApplicationIntakePersistor",
          "category": "lifecycle",
          "linkedEntity": "ApplicationIntake",
          "emits": [
            {
              "event": "INTAKE_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "INTAKE_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "INTAKE_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakeCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakeEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationIntakeDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INTAKE_CREATED",
                "name": "Intake Created"
              },
              {
                "key": "INTAKE_UPDATED",
                "name": "Intake Updated"
              },
              {
                "key": "INTAKE_DELETED",
                "name": "Intake Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ApplicationIntake",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "INTAKE_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "ApplicationIntake",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "INTAKE_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "ApplicationIntake",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "INTAKE_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ApplicationIntakePage",
          "path": "/intakes",
          "traits": [
            {
              "ref": "ApplicationIntakeBrowse"
            },
            {
              "ref": "ApplicationIntakeCreate"
            },
            {
              "ref": "ApplicationIntakeEdit"
            },
            {
              "ref": "ApplicationIntakeDelete"
            },
            {
              "ref": "ApplicationIntakePersistor"
            }
          ]
        }
      ]
    }
  ]
}
