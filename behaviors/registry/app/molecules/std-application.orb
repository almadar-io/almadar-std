{
  "name": "std-application",
  "version": "1.0.0",
  "description": "std-application — job-style application bundle: form + attachments + status flow (draft/submitted/under-review/accepted/rejected).",
  "orbitals": [
    {
      "name": "ApplicationOrbital",
      "entity": {
        "name": "Application",
        "collection": "applications",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantEmail",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "coverLetter",
            "type": "string"
          },
          {
            "name": "attachmentsJson",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "under-review",
              "accepted",
              "rejected"
            ]
          },
          {
            "name": "submittedAt",
            "type": "string"
          },
          {
            "name": "reviewedAt",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ApplicationManage",
          "category": "interaction",
          "linkedEntity": "Application",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coverLetter",
                  "type": "string"
                },
                {
                  "name": "row.attachmentsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "applicationId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coverLetter",
                  "type": "string"
                },
                {
                  "name": "row.attachmentsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ACCEPT",
              "payloadSchema": [
                {
                  "name": "applicationId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coverLetter",
                  "type": "string"
                },
                {
                  "name": "row.attachmentsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "applicationId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coverLetter",
                  "type": "string"
                },
                {
                  "name": "row.attachmentsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE_SUBMIT",
              "payloadSchema": [
                {
                  "name": "data.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.applicantEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.coverLetter",
                  "type": "string"
                },
                {
                  "name": "data.attachmentsJson",
                  "type": "string"
                },
                {
                  "name": "data.status",
                  "type": "string"
                },
                {
                  "name": "data.submittedAt",
                  "type": "string"
                },
                {
                  "name": "data.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "data.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UPDATE_SUBMIT",
              "payloadSchema": [
                {
                  "name": "data.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.applicantName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.applicantEmail",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "data.coverLetter",
                  "type": "string"
                },
                {
                  "name": "data.attachmentsJson",
                  "type": "string"
                },
                {
                  "name": "data.status",
                  "type": "string"
                },
                {
                  "name": "data.submittedAt",
                  "type": "string"
                },
                {
                  "name": "data.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "data.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_EDIT"
            },
            {
              "event": "UPLOAD",
              "payloadSchema": [
                {
                  "name": "files",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "ApplicationLoaded",
              "description": "Fired when the Application collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Application]"
                }
              ]
            },
            {
              "event": "ApplicationLoadFailed",
              "description": "Fired when the Application collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicationCreated",
              "description": "Fired after a new application persists successfully",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicationUpdated",
              "description": "Fired after an application persists an update",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicationSubmitted",
              "description": "Fired after an application transitions to submitted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicationAccepted",
              "description": "Fired after an application transitions to accepted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicationRejected",
              "description": "Fired after an application transitions to rejected",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ApplicationPersistor"
              }
            },
            {
              "event": "ITEM_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ApplicationPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "submitting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApplicationLoaded",
                "name": "Application loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Application]"
                  }
                ]
              },
              {
                "key": "ApplicationLoadFailed",
                "name": "Application load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Application"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "applicationId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Application"
                  }
                ]
              },
              {
                "key": "ACCEPT",
                "name": "Accept",
                "payloadSchema": [
                  {
                    "name": "applicationId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Application"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "applicationId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Application"
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE_SUBMIT",
                "name": "Create Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE_SUBMIT",
                "name": "Update Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "files",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_EDIT",
                "name": "Cancel Edit"
              },
              {
                "key": "ApplicationCreated",
                "name": "Application created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApplicationUpdated",
                "name": "Application updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApplicationSubmitted",
                "name": "Application submitted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApplicationAccepted",
                "name": "Application accepted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ApplicationRejected",
                "name": "Application rejected",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "failure": "ApplicationLoadFailed",
                        "success": "ApplicationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading applications…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApplicationLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-text"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Applications"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "icon": "plus",
                              "action": "CREATE",
                              "label": "New Application"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "icon": "user",
                              "variant": "h4",
                              "name": "applicantName",
                              "label": "Applicant"
                            },
                            {
                              "variant": "caption",
                              "name": "applicantEmail",
                              "label": "Email"
                            },
                            {
                              "label": "Target",
                              "variant": "caption",
                              "name": "targetType"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "submittedAt",
                              "label": "Submitted"
                            }
                          ],
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "ghost"
                            },
                            {
                              "variant": "primary",
                              "label": "Submit",
                              "event": "SUBMIT"
                            },
                            {
                              "event": "ACCEPT",
                              "label": "Accept",
                              "variant": "success"
                            },
                            {
                              "event": "REJECT",
                              "label": "Reject",
                              "variant": "danger"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApplicationLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load applications"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "body"
                        },
                        {
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "CREATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    ""
                  ],
                  [
                    "set",
                    "@entity.applicantName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.applicantEmail",
                    ""
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    ""
                  ],
                  [
                    "set",
                    "@entity.coverLetter",
                    ""
                  ],
                  [
                    "set",
                    "@entity.attachmentsJson",
                    ""
                  ],
                  [
                    "set",
                    "@entity.status",
                    "draft"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "className": "max-w-3xl mx-auto w-full",
                      "children": [
                        {
                          "content": "New Application",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "fields": [
                            "applicantName",
                            "applicantEmail",
                            "targetId",
                            "targetType",
                            "coverLetter"
                          ],
                          "entity": "@entity",
                          "mode": "create",
                          "submitEvent": "CREATE_SUBMIT",
                          "type": "form-section",
                          "cancelEvent": "CANCEL_EDIT"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Attachments",
                          "type": "typography"
                        },
                        {
                          "icon": "paperclip",
                          "accept": "*/*",
                          "maxSize": 10485760.0,
                          "label": "Drop attachments here",
                          "type": "upload-drop-zone",
                          "maxFiles": 10.0,
                          "description": "Resume, portfolio, references",
                          "action": "UPLOAD"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.applicantName",
                    "@payload.row.applicantName"
                  ],
                  [
                    "set",
                    "@entity.applicantEmail",
                    "@payload.row.applicantEmail"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.row.targetId"
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    "@payload.row.targetType"
                  ],
                  [
                    "set",
                    "@entity.coverLetter",
                    "@payload.row.coverLetter"
                  ],
                  [
                    "set",
                    "@entity.attachmentsJson",
                    "@payload.row.attachmentsJson"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Edit Application"
                        },
                        {
                          "mode": "edit",
                          "cancelEvent": "CANCEL_EDIT",
                          "fields": [
                            "applicantName",
                            "applicantEmail",
                            "targetId",
                            "targetType",
                            "coverLetter"
                          ],
                          "submitEvent": "UPDATE_SUBMIT",
                          "entity": "@entity",
                          "type": "form-section"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Attachments",
                          "type": "typography"
                        },
                        {
                          "label": "Drop attachments here",
                          "accept": "*/*",
                          "maxSize": 10485760.0,
                          "type": "upload-drop-zone",
                          "action": "UPLOAD",
                          "maxFiles": 10.0,
                          "description": "Resume, portfolio, references",
                          "icon": "paperclip"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "className": "max-w-3xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "submitted"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.row.submittedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Application",
                    {
                      "id": "@entity.id",
                      "status": "submitted",
                      "submittedAt": "@entity.submittedAt"
                    },
                    {
                      "emit": {
                        "failure": "ApplicationLoadFailed",
                        "success": "ApplicationSubmitted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Submitting…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "submitting",
                "event": "ACCEPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "accepted"
                  ],
                  [
                    "set",
                    "@entity.reviewedAt",
                    "@payload.row.reviewedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Application",
                    {
                      "status": "accepted",
                      "reviewedAt": "@entity.reviewedAt",
                      "id": "@entity.id"
                    },
                    {
                      "emit": {
                        "failure": "ApplicationLoadFailed",
                        "success": "ApplicationAccepted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Accepting…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "submitting",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "rejected"
                  ],
                  [
                    "set",
                    "@entity.reviewedAt",
                    "@payload.row.reviewedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "persist",
                    "update",
                    "Application",
                    {
                      "status": "rejected",
                      "reviewedAt": "@entity.reviewedAt",
                      "id": "@entity.id",
                      "notes": "@entity.notes"
                    },
                    {
                      "emit": {
                        "success": "ApplicationRejected",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Rejecting…"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "success": "ApplicationLoaded",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "submitting",
                "event": "CREATE_SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Application",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ApplicationCreated",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Saving…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "submitting",
                "event": "UPDATE_SUBMIT",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Application",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ApplicationUpdated",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Updating…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "UPLOAD",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-3xl mx-auto w-full",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "content": "Application",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "submitEvent": "UPDATE_SUBMIT",
                          "cancelEvent": "CANCEL_EDIT",
                          "entity": "@entity",
                          "type": "form-section",
                          "fields": [
                            "applicantName",
                            "applicantEmail",
                            "targetId",
                            "targetType",
                            "coverLetter"
                          ],
                          "mode": "edit"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Attachments"
                        },
                        {
                          "type": "alert",
                          "message": "Attachment uploaded.",
                          "variant": "info"
                        },
                        {
                          "description": "Resume, portfolio, references",
                          "maxSize": 10485760.0,
                          "action": "UPLOAD",
                          "icon": "paperclip",
                          "label": "Drop more attachments",
                          "accept": "*/*",
                          "type": "upload-drop-zone",
                          "maxFiles": 10.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "CANCEL_EDIT",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "failure": "ApplicationLoadFailed",
                        "success": "ApplicationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "loading",
                "event": "ApplicationCreated",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "success": "ApplicationLoaded",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "loading",
                "event": "ApplicationUpdated",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "failure": "ApplicationLoadFailed",
                        "success": "ApplicationLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "loading",
                "event": "ApplicationSubmitted",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "success": "ApplicationLoaded",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "loading",
                "event": "ApplicationAccepted",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "success": "ApplicationLoaded",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "loading",
                "event": "ApplicationRejected",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "success": "ApplicationLoaded",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "error",
                "event": "ApplicationLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Application",
                    {
                      "emit": {
                        "success": "ApplicationLoaded",
                        "failure": "ApplicationLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ApplicationPersistor",
          "category": "lifecycle",
          "linkedEntity": "Application",
          "emits": [
            {
              "event": "ITEM_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE_SUBMIT",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationManage"
              }
            },
            {
              "event": "UPDATE_SUBMIT",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ApplicationManage"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Application",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Application",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEM_CREATED",
                "name": "Item Created"
              },
              {
                "key": "ITEM_UPDATED",
                "name": "Item Updated"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Application",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Application",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_UPDATED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ApplicationPage",
          "path": "/applications",
          "traits": [
            {
              "ref": "ApplicationManage"
            },
            {
              "ref": "ApplicationPersistor"
            }
          ]
        }
      ]
    }
  ]
}