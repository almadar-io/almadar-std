{
  "name": "std-stock-adjustment",
  "version": "1.0.0",
  "description": "Tracks stock-level adjustments as deltas to onHand per sku/warehouse",
  "orbitals": [
    {
      "name": "StockAdjustmentOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stock-level",
          "as": "StockLevel"
        },
        {
          "from": "std/behaviors/std-warehouse",
          "as": "Warehouse"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "StockAdjustment",
        "collection": "stockadjustments",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "stockLevelId",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "default": ""
          },
          {
            "name": "warehouseId",
            "type": "string",
            "default": ""
          },
          {
            "name": "warehouseName",
            "type": "string",
            "default": ""
          },
          {
            "name": "quantityDelta",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reason",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "damaged",
              "transfer_in",
              "transfer_out",
              "shrinkage",
              "recount"
            ]
          },
          {
            "name": "adjustedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "adjustedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "StockAdjustmentBrowse",
          "category": "interaction",
          "linkedEntity": "StockAdjustment",
          "emits": [
            {
              "event": "OPEN_ADJUSTMENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.stockLevelId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sku",
                  "type": "string"
                },
                {
                  "name": "row.warehouseId",
                  "type": "string"
                },
                {
                  "name": "row.warehouseName",
                  "type": "string"
                },
                {
                  "name": "row.quantityDelta",
                  "type": "number"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.adjustedBy",
                  "type": "string"
                },
                {
                  "name": "row.adjustedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CREATE"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.stockLevelId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sku",
                  "type": "string"
                },
                {
                  "name": "row.warehouseId",
                  "type": "string"
                },
                {
                  "name": "row.warehouseName",
                  "type": "string"
                },
                {
                  "name": "row.quantityDelta",
                  "type": "number"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.adjustedBy",
                  "type": "string"
                },
                {
                  "name": "row.adjustedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StockAdjustmentLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StockAdjustment]"
                }
              ]
            },
            {
              "event": "StockAdjustmentLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ADJUSTMENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentPersistor"
              }
            },
            {
              "event": "ADJUSTMENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StockAdjustmentLoaded",
                "name": "StockAdjustment loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StockAdjustment]"
                  }
                ]
              },
              {
                "key": "StockAdjustmentLoadFailed",
                "name": "StockAdjustment load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ADJUSTMENT",
                "name": "Open Adjustment",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "StockAdjustment"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "StockAdjustment"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "StockAdjustmentLoaded",
                        "failure": "StockAdjustmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading adjustments…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StockAdjustmentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "sliders",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Stock Adjustments"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "sliders",
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total adjustments"
                            },
                            {
                              "icon": "trending-up",
                              "type": "stat-display",
                              "value": "+184",
                              "label": "Net delta"
                            },
                            {
                              "type": "stat-display",
                              "label": "This week",
                              "icon": "calendar",
                              "value": "26"
                            },
                            {
                              "value": "4",
                              "label": "Shrinkage flags",
                              "icon": "alert-triangle",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "name": "sku",
                              "variant": "caption",
                              "label": "SKU"
                            },
                            {
                              "label": "Warehouse",
                              "variant": "caption",
                              "name": "warehouseName"
                            },
                            {
                              "name": "quantityDelta",
                              "label": "Delta",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Reason",
                              "name": "reason"
                            },
                            {
                              "name": "adjustedAt",
                              "label": "Adjusted At",
                              "variant": "caption"
                            },
                            {
                              "label": "By",
                              "variant": "caption",
                              "name": "adjustedBy"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "OPEN_ADJUSTMENT",
                              "icon": "arrow-right",
                              "label": "Open"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "cols": 1.0
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StockAdjustmentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ADJUSTMENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.stockLevelId",
                    "@payload.row.stockLevelId"
                  ],
                  [
                    "set",
                    "@entity.sku",
                    "@payload.row.sku"
                  ],
                  [
                    "set",
                    "@entity.warehouseId",
                    "@payload.row.warehouseId"
                  ],
                  [
                    "set",
                    "@entity.warehouseName",
                    "@payload.row.warehouseName"
                  ],
                  [
                    "set",
                    "@entity.quantityDelta",
                    "@payload.row.quantityDelta"
                  ],
                  [
                    "set",
                    "@entity.reason",
                    "@payload.row.reason"
                  ],
                  [
                    "set",
                    "@entity.adjustedBy",
                    "@payload.row.adjustedBy"
                  ],
                  [
                    "set",
                    "@entity.adjustedAt",
                    "@payload.row.adjustedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "sliders",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.sku"
                            },
                            {
                              "label": "@entity.reason",
                              "type": "badge",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Warehouse",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.warehouseName",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Adjusted by",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.adjustedBy",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Notes",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Delta",
                              "icon": "trending-up",
                              "value": "@entity.quantityDelta"
                            },
                            {
                              "label": "Adjusted at",
                              "type": "stat-display",
                              "value": "@entity.adjustedAt",
                              "icon": "calendar"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.reason",
                              "icon": "tag",
                              "label": "Reason"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "label": "Delete",
                              "action": "REQUEST_DELETE",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "StockAdjustmentLoaded",
                        "failure": "StockAdjustmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Opening new adjustment…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "StockAdjustmentLoaded",
                        "failure": "StockAdjustmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Removing adjustment…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "StockAdjustmentLoaded",
                        "failure": "StockAdjustmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading adjustments…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "failure": "StockAdjustmentLoadFailed",
                        "success": "StockAdjustmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Removing adjustment…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "StockAdjustmentLoaded",
                        "failure": "StockAdjustmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "StockAdjustmentCreate",
          "linkedEntity": "StockAdjustment",
          "config": {
            "title": "New Adjustment",
            "fields": [
              "sku",
              "warehouseId",
              "quantityDelta",
              "reason",
              "notes"
            ],
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "StockAdjustmentDelete",
          "linkedEntity": "StockAdjustment",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "title": "Delete Adjustment",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentBrowse"
              }
            }
          ]
        },
        {
          "name": "StockAdjustmentPersistor",
          "category": "lifecycle",
          "linkedEntity": "StockAdjustment",
          "emits": [
            {
              "event": "ADJUSTMENT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ADJUSTMENT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentCreate"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADJUSTMENT_CREATED",
                "name": "Adjustment Created"
              },
              {
                "key": "ADJUSTMENT_DELETED",
                "name": "Adjustment Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "StockAdjustment",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ADJUSTMENT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "StockAdjustment",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ADJUSTMENT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
