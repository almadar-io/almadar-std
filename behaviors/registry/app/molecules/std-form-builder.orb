{
  "name": "std-form-builder",
  "version": "1.0.0",
  "description": "std-form-builder — survey form composer. One Survey entity holds metadata, a JSON-encoded question library, and JSON-encoded branching rules. Three traits coordinate authoring on a single page: SurveyManage (CRUD on the survey), SurveyQuestions (in-place editing of questionsJson), SurveyBranching (in-place editing of rulesJson).",
  "orbitals": [
    {
      "name": "FormBuilderOrbital",
      "entity": {
        "name": "Survey",
        "collection": "surveys",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "questionsJson",
            "type": "string"
          },
          {
            "name": "rulesJson",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SurveyManage",
          "category": "interaction",
          "linkedEntity": "Survey",
          "emits": [
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Survey]"
                }
              ]
            },
            {
              "event": "SurveyLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyPublished",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "QuestionsChanged",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyQuestions"
              }
            },
            {
              "event": "RulesChanged",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyBranching"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SurveyLoaded",
                "name": "Survey loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "SurveyLoadFailed",
                "name": "Survey load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "surveyId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Survey"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "surveyId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Survey"
                  }
                ]
              },
              {
                "key": "SurveyCreated",
                "name": "Survey created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Survey"
                  }
                ]
              },
              {
                "key": "SurveyUpdated",
                "name": "Survey updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Survey"
                  }
                ]
              },
              {
                "key": "SurveyPublished",
                "name": "Survey published",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading surveys…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SurveyLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "clipboard-list"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "@config.title"
                                }
                              ]
                            },
                            {
                              "variant": "primary",
                              "action": "CREATE",
                              "label": "New survey",
                              "type": "button",
                              "icon": "plus"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "fields": [
                            {
                              "label": "Title",
                              "name": "title",
                              "variant": "h4"
                            },
                            {
                              "name": "description",
                              "label": "Description",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "name": "createdAt",
                              "label": "Created",
                              "variant": "caption"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "label": "Edit",
                              "icon": "edit",
                              "event": "UPDATE"
                            },
                            {
                              "label": "Publish",
                              "icon": "send",
                              "event": "PUBLISH",
                              "variant": "primary"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Survey",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SurveyCreated",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.surveyId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.questionsJson",
                    "@payload.row.questionsJson"
                  ],
                  [
                    "set",
                    "@entity.rulesJson",
                    "@payload.row.rulesJson"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.surveyId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "SurveyPublished",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SurveyCreated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SurveyUpdated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SurveyPublished",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "SurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SurveyCreated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SurveyUpdated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SurveyPublished",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "SurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Survey Builder"
            }
          },
          "scope": "collection"
        },
        {
          "name": "SurveyQuestions",
          "category": "interaction",
          "linkedEntity": "Survey",
          "emits": [
            {
              "event": "EDIT_QUESTIONS_JSON",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SAVE_QUESTIONS"
            },
            {
              "event": "SurveyHydrated",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Survey]"
                }
              ]
            },
            {
              "event": "QuestionsChanged",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "QuestionsSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT_QUESTIONS_JSON",
                "name": "Edit Questions Json",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_QUESTIONS",
                "name": "Save Questions"
              },
              {
                "key": "SurveyHydrated",
                "name": "Survey hydrated",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "QuestionsChanged",
                "name": "Questions changed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "QuestionsSaveFailed",
                "name": "Questions save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "QuestionsSaveFailed",
                        "success": "SurveyHydrated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "list-checks",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "value": "@entity.questionsJson",
                          "action": "EDIT_QUESTIONS_JSON",
                          "placeholder": "Questions JSON",
                          "type": "input"
                        },
                        {
                          "action": "SAVE_QUESTIONS",
                          "label": "Save questions",
                          "type": "button",
                          "variant": "primary",
                          "icon": "save"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_QUESTIONS_JSON",
                "effects": [
                  [
                    "set",
                    "@entity.questionsJson",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SAVE_QUESTIONS",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "QuestionsChanged",
                        "failure": "QuestionsSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SurveyHydrated"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QuestionsChanged"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QuestionsSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Survey questions"
            }
          },
          "scope": "instance"
        },
        {
          "name": "SurveyBranching",
          "category": "interaction",
          "linkedEntity": "Survey",
          "emits": [
            {
              "event": "EDIT_RULES_JSON",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SAVE_RULES"
            },
            {
              "event": "SurveyHydrated",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Survey]"
                }
              ]
            },
            {
              "event": "RulesChanged",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RulesSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT_RULES_JSON",
                "name": "Edit Rules Json",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_RULES",
                "name": "Save Rules"
              },
              {
                "key": "SurveyHydrated",
                "name": "Survey hydrated",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "RulesChanged",
                "name": "Rules changed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RulesSaveFailed",
                "name": "Rules save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "RulesSaveFailed",
                        "success": "SurveyHydrated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "git-branch",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "questions": [],
                          "type": "branching-logic-builder",
                          "rules": []
                        },
                        {
                          "placeholder": "Rules JSON",
                          "value": "@entity.rulesJson",
                          "type": "input",
                          "action": "EDIT_RULES_JSON"
                        },
                        {
                          "variant": "primary",
                          "icon": "save",
                          "label": "Save rules",
                          "type": "button",
                          "action": "SAVE_RULES"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_RULES_JSON",
                "effects": [
                  [
                    "set",
                    "@entity.rulesJson",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SAVE_RULES",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "RulesChanged",
                        "failure": "RulesSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SurveyHydrated"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RulesChanged"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RulesSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Branching rules"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FormBuilderPage",
          "path": "/survey-builder",
          "traits": [
            {
              "ref": "SurveyManage"
            },
            {
              "ref": "SurveyQuestions"
            },
            {
              "ref": "SurveyBranching"
            }
          ]
        }
      ]
    }
  ]
}
