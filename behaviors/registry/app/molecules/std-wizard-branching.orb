{
  "name": "std-wizard-branching",
  "version": "2.0.0",
  "description": "std-wizard-branching — domain-specific N-step form wizard. Composes std-wizard with persisted WizardSubmission entity carrying form fields per step. Lights up std-applicant-form (ATS), std-application (HR), std-vendor-onboarding, intake forms in std-healthcare.",
  "orbitals": [
    {
      "name": "WizardBranchingOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-wizard",
          "as": "Wizard"
        }
      ],
      "entity": {
        "name": "WizardSubmission",
        "collection": "wizard_submissions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "category",
            "type": "string",
            "default": "personal",
            "values": [
              "personal",
              "business",
              "internal",
              "external"
            ]
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "urgent"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Wizard.traits.WizardForm",
          "name": "WizardFlow",
          "linkedEntity": "WizardSubmission",
          "config": {
            "steps": [
              {
                "fields": [
                  "title",
                  "description"
                ],
                "description": "Tell us about the request",
                "key": "details",
                "icon": "file-text",
                "label": "Your Details"
              },
              {
                "key": "context",
                "fields": [
                  "category",
                  "priority"
                ],
                "icon": "tag",
                "label": "Context",
                "description": "Categorize and prioritize"
              },
              {
                "description": "Confirm your submission",
                "key": "review",
                "icon": "check-circle",
                "fields": [
                  "notes"
                ],
                "label": "Review & Submit"
              }
            ],
            "currentFields": [
              "title",
              "description",
              "category",
              "priority",
              "notes"
            ],
            "title": "Submission Wizard"
          }
        }
      ],
      "pages": [
        {
          "name": "WizardBranchingPage",
          "path": "/wizard-branching",
          "traits": [
            {
              "ref": "WizardFlow"
            }
          ]
        }
      ]
    }
  ]
}