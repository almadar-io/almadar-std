{
  "name": "std-cart",
  "version": "1.0.0",
  "description": "std-cart — shopping cart molecule composing CartItemCartBrowse + Modal-driven add + Confirmation-driven remove + persistor coordinator.",
  "orbitals": [
    {
      "name": "CartItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "CartItem",
        "collection": "cartitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CartItemCartBrowse",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "ADD_ITEM"
            },
            {
              "event": "REQUEST_REMOVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemLoaded",
              "description": "Fired when the cart collection finishes loading; payload.data holds the CartItem list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CartItem]"
                }
              ]
            },
            {
              "event": "CartItemLoadFailed",
              "description": "Fired when the cart collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CartItemPersistor"
              }
            },
            {
              "event": "ITEM_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CartItemPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CartItem]"
                  }
                ]
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADD_ITEM",
                "name": "Add Item"
              },
              {
                "key": "REQUEST_REMOVE",
                "name": "Request Remove"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading cart…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CartItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shopping-cart"
                                },
                                {
                                  "content": "Shopping Cart",
                                  "variant": "h3",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Add Item",
                              "action": "ADD_ITEM",
                              "variant": "primary",
                              "icon": "plus"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Items in cart",
                              "icon": "shopping-cart",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "check-circle",
                              "value": "3",
                              "label": "Active",
                              "type": "stat-display"
                            },
                            {
                              "icon": "clock",
                              "value": "1",
                              "type": "stat-display",
                              "label": "Pending"
                            },
                            {
                              "icon": "bookmark",
                              "type": "stat-display",
                              "label": "Saved for later",
                              "value": "5"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "event": "REQUEST_REMOVE",
                              "variant": "danger",
                              "label": "Remove"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name",
                              "icon": "shopping-cart"
                            },
                            {
                              "variant": "caption",
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CartItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CartItemAddItem",
          "linkedEntity": "CartItem",
          "config": {
            "icon": "plus-circle",
            "fields": [
              "name",
              "description",
              "status"
            ],
            "mode": "create",
            "title": "Add Item",
            "openButtonLabel": "Add Item"
          },
          "events": {
            "OPEN": "ADD_ITEM"
          },
          "listens": [
            {
              "event": "ADD_ITEM",
              "triggers": "ADD_ITEM",
              "source": {
                "kind": "trait",
                "trait": "CartItemCartBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CartItemRemoveConfirm",
          "linkedEntity": "CartItem",
          "config": {
            "title": "Remove Item",
            "icon": "alert-triangle",
            "confirmLabel": "Remove",
            "alertMessage": "Are you sure you want to remove this item from your cart?"
          },
          "events": {
            "CONFIRM": "CONFIRM_REMOVE",
            "REQUEST": "REQUEST_REMOVE"
          },
          "listens": [
            {
              "event": "REQUEST_REMOVE",
              "triggers": "REQUEST_REMOVE",
              "source": {
                "kind": "trait",
                "trait": "CartItemCartBrowse"
              }
            }
          ]
        },
        {
          "name": "CartItemPersistor",
          "category": "lifecycle",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "ITEM_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ITEM_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "CartItemAddItem"
              }
            },
            {
              "event": "CONFIRM_REMOVE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "CartItemRemoveConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ITEM_CREATED",
                "name": "Item Created"
              },
              {
                "key": "ITEM_DELETED",
                "name": "Item Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "CartItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CartItem",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ITEM_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CartItemPage",
          "path": "/cart",
          "traits": [
            {
              "ref": "CartItemCartBrowse"
            },
            {
              "ref": "CartItemAddItem"
            },
            {
              "ref": "CartItemRemoveConfirm"
            },
            {
              "ref": "CartItemPersistor"
            }
          ]
        }
      ]
    }
  ]
}