{
  "name": "std-ledger-entry-form",
  "version": "1.0.0",
  "description": "Tracks balanced journal-entry pairs (debit + credit) before persisting LedgerEntry rows",
  "orbitals": [
    {
      "name": "JournalTransactionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-ledger-entry",
          "as": "LedgerEntry"
        },
        {
          "from": "std/behaviors/std-chart-of-accounts",
          "as": "Account"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "JournalTransaction",
        "collection": "journaltransactions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "transactionDate",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "debitAccountId",
            "type": "string",
            "default": ""
          },
          {
            "name": "debitAccountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "creditAccountId",
            "type": "string",
            "default": ""
          },
          {
            "name": "creditAccountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "referenceType",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "invoice",
              "bill",
              "payment"
            ]
          },
          {
            "name": "referenceId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isPosted",
            "type": "boolean",
            "default": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "JournalTransactionBrowse",
          "category": "interaction",
          "linkedEntity": "JournalTransaction",
          "emits": [
            {
              "event": "OPEN_TRANSACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.transactionDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountId",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountName",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountId",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountName",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.referenceType",
                  "type": "string"
                },
                {
                  "name": "row.referenceId",
                  "type": "string"
                },
                {
                  "name": "row.isPosted",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CREATE"
            },
            {
              "event": "POST_TRANSACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.transactionDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountId",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountName",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountId",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountName",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.referenceType",
                  "type": "string"
                },
                {
                  "name": "row.referenceId",
                  "type": "string"
                },
                {
                  "name": "row.isPosted",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.transactionDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountId",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountName",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountId",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountName",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.referenceType",
                  "type": "string"
                },
                {
                  "name": "row.referenceId",
                  "type": "string"
                },
                {
                  "name": "row.isPosted",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "JournalTransactionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[JournalTransaction]"
                }
              ]
            },
            {
              "event": "JournalTransactionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TRANSACTION_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionPersistor"
              }
            },
            {
              "event": "TRANSACTION_POSTED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionPersistor"
              }
            },
            {
              "event": "TRANSACTION_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "JournalTransactionLoaded",
                "name": "JournalTransaction loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[JournalTransaction]"
                  }
                ]
              },
              {
                "key": "JournalTransactionLoadFailed",
                "name": "JournalTransaction load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TRANSACTION",
                "name": "Open Transaction",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "JournalTransaction"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "POST_TRANSACTION",
                "name": "Post Transaction",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "JournalTransaction"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "JournalTransaction"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "JournalTransactionLoaded",
                        "failure": "JournalTransactionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading transactions…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "JournalTransactionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "variant": "h3",
                              "content": "Journal Transactions",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "label": "Total entries",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "book-open"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Posted",
                              "value": "84",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Draft",
                              "icon": "edit",
                              "value": "12"
                            },
                            {
                              "label": "Net amount",
                              "icon": "dollar-sign",
                              "value": "$248,500",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "transactionDate",
                              "label": "Date"
                            },
                            {
                              "variant": "caption",
                              "label": "Description",
                              "name": "description"
                            },
                            {
                              "variant": "caption",
                              "name": "debitAccountName",
                              "label": "Debit"
                            },
                            {
                              "name": "creditAccountName",
                              "label": "Credit",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "label": "Amount",
                              "name": "amount"
                            },
                            {
                              "variant": "badge",
                              "name": "referenceType",
                              "label": "Type"
                            }
                          ],
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "OPEN_TRANSACTION",
                              "label": "Open",
                              "icon": "arrow-right",
                              "variant": "primary"
                            },
                            {
                              "event": "REQUEST_DELETE",
                              "label": "Delete",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "JournalTransactionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TRANSACTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.transactionDate",
                    "@payload.row.transactionDate"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.debitAccountId",
                    "@payload.row.debitAccountId"
                  ],
                  [
                    "set",
                    "@entity.debitAccountName",
                    "@payload.row.debitAccountName"
                  ],
                  [
                    "set",
                    "@entity.creditAccountId",
                    "@payload.row.creditAccountId"
                  ],
                  [
                    "set",
                    "@entity.creditAccountName",
                    "@payload.row.creditAccountName"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.referenceType",
                    "@payload.row.referenceType"
                  ],
                  [
                    "set",
                    "@entity.referenceId",
                    "@payload.row.referenceId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "content": "@entity.description",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.referenceType",
                              "variant": "primary",
                              "type": "badge"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Debit Account"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.debitAccountName"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Credit Account"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.creditAccountName"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Reference"
                                },
                                {
                                  "content": "@entity.referenceId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Amount",
                              "type": "stat-display",
                              "value": "@entity.amount",
                              "icon": "dollar-sign"
                            },
                            {
                              "value": "@entity.transactionDate",
                              "type": "stat-display",
                              "label": "Date",
                              "icon": "calendar"
                            },
                            {
                              "icon": "tag",
                              "value": "@entity.referenceType",
                              "type": "stat-display",
                              "label": "Type"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Post Transaction",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary",
                              "action": "POST_TRANSACTION"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "type": "button",
                              "action": "REQUEST_DELETE",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              }
                            }
                          ],
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "failure": "JournalTransactionLoadFailed",
                        "success": "JournalTransactionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Opening new transaction…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "POST_TRANSACTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "failure": "JournalTransactionLoadFailed",
                        "success": "JournalTransactionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Posting transaction…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "JournalTransactionLoaded",
                        "failure": "JournalTransactionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Removing transaction…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "failure": "JournalTransactionLoadFailed",
                        "success": "JournalTransactionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading transactions…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "POST_TRANSACTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "JournalTransactionLoaded",
                        "failure": "JournalTransactionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Posting transaction…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "JournalTransactionLoaded",
                        "failure": "JournalTransactionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Removing transaction…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "JournalTransactionLoaded",
                        "failure": "JournalTransactionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "JournalTransactionCreate",
          "linkedEntity": "JournalTransaction",
          "config": {
            "icon": "plus-circle",
            "mode": "create",
            "title": "New Transaction",
            "fields": [
              "transactionDate",
              "description",
              "debitAccountId",
              "creditAccountId",
              "amount",
              "referenceType",
              "referenceId"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "JournalTransactionDelete",
          "linkedEntity": "JournalTransaction",
          "config": {
            "confirmLabel": "Delete",
            "icon": "alert-triangle",
            "title": "Delete Transaction",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionBrowse"
              }
            }
          ]
        },
        {
          "name": "JournalTransactionPersistor",
          "category": "lifecycle",
          "linkedEntity": "JournalTransaction",
          "emits": [
            {
              "event": "TRANSACTION_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TRANSACTION_POSTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TRANSACTION_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionCreate"
              }
            },
            {
              "event": "POST_TRANSACTION",
              "triggers": "DO_POST",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionBrowse"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_POST",
                "name": "Do Post",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TRANSACTION_CREATED",
                "name": "Transaction Created"
              },
              {
                "key": "TRANSACTION_POSTED",
                "name": "Transaction Posted"
              },
              {
                "key": "TRANSACTION_DELETED",
                "name": "Transaction Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "JournalTransaction",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TRANSACTION_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_POST",
                "effects": [
                  [
                    "persist",
                    "update",
                    "JournalTransaction",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "TRANSACTION_POSTED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "JournalTransaction",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "TRANSACTION_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "JournalTransactionPage",
          "path": "/journal-transactions",
          "traits": [
            {
              "ref": "JournalTransactionBrowse"
            },
            {
              "ref": "JournalTransactionCreate"
            },
            {
              "ref": "JournalTransactionDelete"
            },
            {
              "ref": "JournalTransactionPersistor"
            }
          ]
        }
      ]
    }
  ]
}
