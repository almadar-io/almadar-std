{
  "name": "std-approval-chain",
  "version": "2.0.1",
  "description": "std-approval-chain — single-item N-step sequential approval workflow (manager → finance → executive on ONE request). Composes std-step-flow; agents tune the chain via `config.steps`. Pick this when the user wants a single document/request walked through ordered approvers. For an approver inbox triaging MANY requests (list + detail), use std-approval-request instead. Lights up std-legal-case, std-ap-bill, std-change-order, std-application (hr-portal).",
  "orbitals": [
    {
      "name": "ApprovalChainOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-step-flow",
          "as": "Flow"
        }
      ],
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approval_requests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestType",
            "type": "string",
            "default": "expense",
            "values": [
              "expense",
              "purchase",
              "leave",
              "policy",
              "contract"
            ]
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "requester",
            "type": "string",
            "default": ""
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Flow.traits.StepFlowReview",
          "name": "ApprovalReview",
          "linkedEntity": "ApprovalRequest",
          "config": {
            "steps": [
              {
                "icon": "user-check",
                "label": "Manager Review",
                "description": "Direct manager reviews the request and verifies budget impact",
                "key": "manager"
              },
              {
                "icon": "calculator",
                "key": "finance",
                "description": "Finance team checks compliance with company policy",
                "label": "Finance Approval"
              },
              {
                "key": "executive",
                "label": "Executive Sign-off",
                "description": "Final executive approval before commitment",
                "icon": "shield-check"
              }
            ],
            "title": "Approval Request"
          }
        }
      ],
      "pages": [
        {
          "name": "ApprovalChainPage",
          "path": "/approval-chain",
          "traits": [
            {
              "ref": "ApprovalReview"
            }
          ]
        }
      ]
    }
  ]
}