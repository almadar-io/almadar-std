                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TOGGLE_AVAILABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
