{
  "name": "std-menu",
  "version": "1.2.0",
  "description": "std-menu — restaurant POS menu items grouped by category with availability windows. Manage trait loads, browses, persists Create / Update / Toggle-Available / Delete. Exposes Restaurant/POS knobs (serviceCharge, tipPresets, allergenWarningsEnabled, …).",
  "orbitals": [
    {
      "name": "MenuOrbital",
      "entity": {
        "name": "MenuItem",
        "collection": "menuitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "category",
            "type": "string",
            "required": true
          },
          {
            "name": "imageUrl",
            "type": "string"
          },
          {
            "name": "available",
            "type": "boolean",
            "default": true
          },
          {
            "name": "availableFrom",
            "type": "string"
          },
          {
            "name": "availableUntil",
            "type": "string"
          },
          {
            "name": "tags",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "modifierGroupIds",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "prepTimeMinutes",
            "type": "number",
            "default": 10.0
          },
          {
            "name": "order",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "MenuItemManage",
          "category": "interaction",
          "linkedEntity": "MenuItem",
          "emits": [
            {
              "event": "OPEN_ITEM",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "TOGGLE_AVAILABLE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MenuItem]"
                }
              ]
            },
            {
              "event": "MenuItemLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MenuItemCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemDeleted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemWriteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MenuItemLoaded",
                "name": "MenuItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MenuItem]"
                  }
                ]
              },
              {
                "key": "MenuItemLoadFailed",
                "name": "MenuItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ITEM",
                "name": "Open Item",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemCreated",
                "name": "MenuItem created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemUpdated",
                "name": "MenuItem updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemDeleted",
                "name": "MenuItem deleted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemWriteFailed",
                "name": "MenuItem write failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOGGLE_AVAILABLE",
                "name": "Toggle Available",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "failure": "MenuItemLoadFailed",
                        "success": "MenuItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading menu…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MenuItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "utensils"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Menu items",
                              "icon": "utensils",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "62",
                              "label": "Available"
                            },
                            {
                              "type": "stat-display",
                              "icon": "list",
                              "label": "Categories",
                              "value": "8"
                            },
                            {
                              "label": "Avg price",
                              "icon": "dollar-sign",
                              "value": "$14.50",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MenuItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ITEM",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.imageUrl",
                    "@payload.row.imageUrl"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.row.available"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.tags",
                    "@payload.row.tags"
                  ],
                  [
                    "set",
                    "@entity.modifierGroupIds",
                    "@payload.row.modifierGroupIds"
                  ],
                  [
                    "set",
                    "@entity.prepTimeMinutes",
                    "@payload.row.prepTimeMinutes"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Back",
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "utensils"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.name",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.category",
                              "variant": "primary"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Description"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.description",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Available from",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.availableFrom",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Available until",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.availableUntil"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.price",
                              "icon": "dollar-sign",
                              "label": "Price"
                            },
                            {
                              "value": "@entity.currency",
                              "icon": "circle-dollar-sign",
                              "type": "stat-display",
                              "label": "Currency"
                            },
                            {
                              "label": "Prep (min)",
                              "value": "@entity.prepTimeMinutes",
                              "type": "stat-display",
                              "icon": "clock"
                            },
                            {
                              "label": "Order",
                              "type": "stat-display",
                              "value": "@entity.order",
                              "icon": "list-ordered"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "action": "TOGGLE_AVAILABLE",
                              "actionPayload": {
                                "itemId": "@entity.id",
                                "row": "@entity"
                              },
                              "label": "Toggle Available",
                              "variant": "primary"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "actionPayload": {
                                "row": "@entity",
                                "itemId": "@entity.id"
                              },
                              "type": "button",
                              "action": "DELETE"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.itemId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.imageUrl",
                    "@payload.row.imageUrl"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.row.available"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
