              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "success": "MenuItemLoaded",
                        "failure": "MenuItemLoadFailed"
                      }
                    }
                  ],
                  [
