{
  "name": "std-menu",
  "version": "1.0.0",
  "description": "std-menu — restaurant POS menu items grouped by category with availability windows. Owns a MenuItem entity (price, category, available, prep time, modifier groups) and a single manage trait that loads items, browses them in a data-grid with Create / Update / Toggle-Available / Delete actions, and persists each verdict back to the row.",
  "orbitals": [
    {
      "name": "MenuOrbital",
      "entity": {
        "name": "MenuItem",
        "collection": "menuitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "category",
            "type": "string",
            "required": true
          },
          {
            "name": "imageUrl",
            "type": "string"
          },
          {
            "name": "available",
            "type": "boolean",
            "default": true
          },
          {
            "name": "availableFrom",
            "type": "string"
          },
          {
            "name": "availableUntil",
            "type": "string"
          },
          {
            "name": "tags",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "modifierGroupIds",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "prepTimeMinutes",
            "type": "number",
            "default": 10.0
          },
          {
            "name": "order",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "MenuItemManage",
          "category": "interaction",
          "linkedEntity": "MenuItem",
          "emits": [
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "TOGGLE_AVAILABLE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "itemId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MenuItem]"
                }
              ]
            },
            {
              "event": "MenuItemLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MenuItemCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemDeleted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.imageUrl",
                  "type": "string"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.tags",
                  "type": "[string]"
                },
                {
                  "name": "row.modifierGroupIds",
                  "type": "[string]"
                },
                {
                  "name": "row.prepTimeMinutes",
                  "type": "number"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "MenuItemWriteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MenuItemLoaded",
                "name": "MenuItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MenuItem]"
                  }
                ]
              },
              {
                "key": "MenuItemLoadFailed",
                "name": "MenuItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOGGLE_AVAILABLE",
                "name": "Toggle Available",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "itemId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemCreated",
                "name": "MenuItem created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemUpdated",
                "name": "MenuItem updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemDeleted",
                "name": "MenuItem deleted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MenuItem"
                  }
                ]
              },
              {
                "key": "MenuItemWriteFailed",
                "name": "MenuItem write failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "failure": "MenuItemLoadFailed",
                        "success": "MenuItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading menu…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MenuItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "utensils"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Update",
                              "variant": "secondary",
                              "event": "UPDATE",
                              "icon": "edit"
                            },
                            {
                              "event": "TOGGLE_AVAILABLE",
                              "label": "Toggle",
                              "variant": "primary",
                              "icon": "power"
                            },
                            {
                              "label": "Delete",
                              "icon": "trash",
                              "variant": "destructive",
                              "event": "DELETE"
                            }
                          ],
                          "fields": [
                            {
                              "name": "name",
                              "label": "Item",
                              "variant": "badge"
                            },
                            {
                              "label": "Category",
                              "variant": "badge",
                              "name": "category"
                            },
                            {
                              "variant": "caption",
                              "label": "Price",
                              "name": "price"
                            },
                            {
                              "name": "currency",
                              "variant": "badge",
                              "label": "Currency"
                            },
                            {
                              "variant": "caption",
                              "label": "Prep (min)",
                              "name": "prepTimeMinutes"
                            },
                            {
                              "name": "available",
                              "label": "Available",
                              "variant": "badge"
                            }
                          ]
                        },
                        {
                          "label": "New Item",
                          "type": "button",
                          "variant": "primary",
                          "icon": "plus",
                          "action": "CREATE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MenuItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "MenuItem",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "MenuItemWriteFailed",
                        "success": "MenuItemCreated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.itemId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.imageUrl",
                    "@payload.row.imageUrl"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.row.available"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.tags",
                    "@payload.row.tags"
                  ],
                  [
                    "set",
                    "@entity.modifierGroupIds",
                    "@payload.row.modifierGroupIds"
                  ],
                  [
                    "set",
                    "@entity.prepTimeMinutes",
                    "@payload.row.prepTimeMinutes"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "persist",
                    "update",
                    "MenuItem",
                    "@entity",
                    {
                      "emit": {
                        "success": "MenuItemUpdated",
                        "failure": "MenuItemWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TOGGLE_AVAILABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.itemId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.imageUrl",
                    "@payload.row.imageUrl"
                  ],
                  [
                    "set",
                    "@entity.available",
                    [
                      "not",
                      "@payload.row.available"
                    ]
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.tags",
                    "@payload.row.tags"
                  ],
                  [
                    "set",
                    "@entity.modifierGroupIds",
                    "@payload.row.modifierGroupIds"
                  ],
                  [
                    "set",
                    "@entity.prepTimeMinutes",
                    "@payload.row.prepTimeMinutes"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "persist",
                    "update",
                    "MenuItem",
                    "@entity",
                    {
                      "emit": {
                        "success": "MenuItemUpdated",
                        "failure": "MenuItemWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.itemId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.imageUrl",
                    "@payload.row.imageUrl"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.row.available"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.tags",
                    "@payload.row.tags"
                  ],
                  [
                    "set",
                    "@entity.modifierGroupIds",
                    "@payload.row.modifierGroupIds"
                  ],
                  [
                    "set",
                    "@entity.prepTimeMinutes",
                    "@payload.row.prepTimeMinutes"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "persist",
                    "delete",
                    "MenuItem",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MenuItemWriteFailed",
                        "success": "MenuItemDeleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MenuItemCreated",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "failure": "MenuItemLoadFailed",
                        "success": "MenuItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MenuItemUpdated",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "failure": "MenuItemLoadFailed",
                        "success": "MenuItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MenuItemDeleted",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "success": "MenuItemLoaded",
                        "failure": "MenuItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MenuItemWriteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "failure": "MenuItemLoadFailed",
                        "success": "MenuItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Menu"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MenuItemManagePage",
          "path": "/menu/manage",
          "traits": [
            {
              "ref": "MenuItemManage"
            }
          ]
        }
      ]
    }
  ]
}
