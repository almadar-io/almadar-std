            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Menu",
              "label": "Section title",
              "description": "Heading shown above the menu item list",
              "tier": "customization"
            },
            "kitchenAutoFire": {
              "type": "boolean",
              "default": false,
              "label": "Kitchen auto-fire",
              "description": "Auto-send courses to the kitchen display without explicit fire action.",
              "tier": "customization"
            },
            "tableTurnoverTargetMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "Table turnover target (min)",
              "description": "Target minutes between seatings on a single table. v1.2 declarative.",
              "tier": "advanced"
            },
            "tipPresets": {
              "type": "[number]",
              "default": [
                15.0,
                18.0,
                20.0,
                25.0
              ],
              "label": "Tip presets (%)",
              "description": "Quick-select tip percentages shown on the checkout terminal.",
              "tier": "customization",
              "items": {
                "type": "number"
              }
            },
            "allergenWarningsEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Allergen warnings",
              "description": "Surface allergen warnings on menu items with declared allergens.",
              "tier": "customization"
            },
            "serviceCharge": {
              "type": "number",
              "default": 0.0,
              "label": "Service charge (%)",
              "description": "Default service-charge percentage applied to checks. v1.2 declarative.",
              "tier": "customization"
            },
            "coursingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Coursing enabled",
              "description": "Track ordered courses (apps / mains / desserts) for pacing.",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "name",
                  "label": "Item",
                  "variant": "caption"
                },
                {
                  "label": "Category",
                  "variant": "badge",
                  "name": "category"
                },
                {
                  "label": "Price",
                  "name": "price",
                  "variant": "caption"
                },
                {
                  "label": "Currency",
                  "variant": "badge",
                  "name": "currency"
                },
                {
                  "name": "prepTimeMinutes",
                  "label": "Prep (min)",
                  "variant": "caption"
                },
                {
                  "label": "Available",
                  "variant": "badge",
                  "name": "available"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Menu Item entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_ITEM",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "variant": "danger",
                  "label": "Delete",
                  "icon": "trash",
                  "event": "DELETE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each menu item",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "allowSplitChecks": {
              "type": "boolean",
              "default": true,
              "label": "Allow split checks",
              "description": "Permit splitting a single table check across multiple payments.",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MenuItemManagePage",
          "path": "/menu/manage",
          "traits": [
            {
              "ref": "MenuItemManage"
            }
          ]
        }
      ]
    }
  ]
