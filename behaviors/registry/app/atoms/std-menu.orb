                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "success": "MenuItemLoaded",
                        "failure": "MenuItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading menu…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "MenuItem",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "MenuItemWriteFailed",
                        "success": "MenuItemCreated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
