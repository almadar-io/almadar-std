                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "persist",
                    "delete",
                    "MenuItem",
                    "@entity",
                    {
                      "emit": {
                        "success": "MenuItemDeleted",
                        "failure": "MenuItemWriteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Deleting menu item…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MenuItemCreated",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "success": "MenuItemLoaded",
                        "failure": "MenuItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MenuItemUpdated",
                "effects": [
