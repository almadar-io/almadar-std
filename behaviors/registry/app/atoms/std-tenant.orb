{
  "name": "std-tenant",
  "version": "1.2.0",
  "description": "std-tenant — person/company occupying a leased unit. Lists tenants; detail offers Activate / Move Out. Listens for SET_STATUS so std-lifecycle can drive transitions. Exposes Real-estate knobs (leaseRenewalNoticeDays, petPolicy, lateRentGraceDays, …).",
  "orbitals": [
    {
      "name": "TenantOrbital",
      "entity": {
        "name": "Tenant",
        "collection": "tenants",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "leaseId",
            "type": "string",
            "default": ""
          },
          {
            "name": "moveInDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "moveOutDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "prospective",
            "values": [
              "current",
              "former",
              "prospective"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TenantDirectory",
          "category": "interaction",
          "linkedEntity": "Tenant",
          "emits": [
            {
              "event": "OPEN_TENANT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.leaseId",
                  "type": "string"
                },
                {
                  "name": "row.moveInDate",
                  "type": "string"
                },
                {
                  "name": "row.moveOutDate",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_TENANT"
            },
            {
              "event": "ACTIVATE_TENANT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MOVE_OUT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TenantLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Tenant]"
                }
              ]
            },
            {
              "event": "TenantLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TenantUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.leaseId",
                  "type": "string"
                },
                {
                  "name": "row.moveInDate",
                  "type": "string"
                },
                {
                  "name": "row.moveOutDate",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TenantUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TenantLoaded",
                "name": "Tenant loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Tenant]"
                  }
                ]
              },
              {
                "key": "TenantLoadFailed",
                "name": "Tenant load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TENANT",
                "name": "Open Tenant",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Tenant"
                  }
                ]
              },
              {
                "key": "MOVE_OUT",
                "name": "Move Out",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TenantUpdated",
                "name": "Tenant updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Tenant"
                  }
                ]
              },
              {
                "key": "TenantUpdateFailed",
                "name": "Tenant update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_TENANT",
                "name": "Close Tenant"
              },
              {
                "key": "ACTIVATE_TENANT",
                "name": "Activate Tenant",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "failure": "TenantLoadFailed",
                        "success": "TenantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading tenants…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TenantLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "name": "users",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Total tenants",
                              "type": "stat-display",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "value": "42",
                              "icon": "check-circle",
                              "label": "Current"
                            },
                            {
                              "type": "stat-display",
                              "value": "8",
                              "icon": "user-plus",
                              "label": "Prospective"
                            },
                            {
                              "icon": "user-minus",
                              "label": "Former",
                              "type": "stat-display",
                              "value": "120"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TenantLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "title": "Failed to load tenants",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TENANT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.email",
                    "@payload.row.email"
                  ],
                  [
                    "set",
                    "@entity.phone",
                    "@payload.row.phone"
                  ],
                  [
                    "set",
                    "@entity.leaseId",
                    "@payload.row.leaseId"
                  ],
                  [
                    "set",
                    "@entity.moveInDate",
                    "@payload.row.moveInDate"
                  ],
                  [
                    "set",
                    "@entity.moveOutDate",
                    "@payload.row.moveOutDate"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_TENANT",
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "user"
                            },
                            {
                              "content": "@entity.name",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Email"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.email",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Phone",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.phone"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Lease",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.leaseId"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "content": "Notes",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.moveInDate",
                              "icon": "calendar",
                              "label": "Move-In"
                            },
                            {
                              "value": "@entity.moveOutDate",
                              "type": "stat-display",
                              "icon": "calendar",
                              "label": "Move-Out"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "label": "Activate",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "ACTIVATE_TENANT"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "action": "MOVE_OUT",
                              "label": "Move Out",
                              "type": "button"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MOVE_OUT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "failure": "TenantLoadFailed",
                        "success": "TenantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Recording move-out…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Tenant",
                    "@entity",
                    {
                      "emit": {
                        "success": "TenantUpdated",
                        "failure": "TenantUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating tenant status…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TenantUpdated",
                "effects": [
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "success": "TenantLoaded",
                        "failure": "TenantLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TenantUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_TENANT",
                "effects": [
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "success": "TenantLoaded",
                        "failure": "TenantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading tenants…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACTIVATE_TENANT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "success": "TenantLoaded",
                        "failure": "TenantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Activating tenant…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MOVE_OUT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "failure": "TenantLoadFailed",
                        "success": "TenantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Recording move-out…",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Tenant",
                    {
                      "emit": {
                        "failure": "TenantLoadFailed",
                        "success": "TenantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "securityDepositMonths": {
              "type": "number",
              "default": 1.0,
              "label": "Security deposit (months)",
              "description": "Months of rent required as security deposit.",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Name",
                  "name": "name",
                  "variant": "h4"
                },
                {
                  "label": "Email",
                  "variant": "body",
                  "name": "email"
                },
                {
                  "variant": "caption",
                  "name": "phone",
                  "label": "Phone"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "name": "moveInDate",
                  "variant": "caption",
                  "label": "Move-In"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Tenant entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "inspectionFrequencyMonths": {
              "type": "number",
              "default": 12.0,
              "label": "Inspection cadence (months)",
              "description": "Months between scheduled unit inspections.",
              "tier": "domain"
            },
            "leaseRenewalNoticeDays": {
              "type": "number",
              "default": 60.0,
              "label": "Renewal notice (days)",
              "description": "Days before lease end when a renewal nudge fires for this tenant.",
              "tier": "domain"
            },
            "petPolicy": {
              "type": "string",
              "default": "no-pets",
              "label": "Pet policy",
              "description": "Default pet policy enforced for new tenants.",
              "tier": "domain",
              "values": [
                "no-pets",
                "cats-only",
                "dogs-only",
                "all"
              ]
            },
            "lateRentGraceDays": {
              "type": "number",
              "default": 5.0,
              "label": "Late rent grace (days)",
              "description": "Days after rent due before a tenant rolls into a late status.",
              "tier": "domain"
            },
            "autoRenewEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Auto-renew",
              "description": "Roll over the tenant's lease at term without an explicit non-renew notice.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
