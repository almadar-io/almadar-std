{
  "name": "std-timesheet",
  "version": "1.0.0",
  "description": "std-timesheet — weekly timesheet primitive holding total/billable hours for one employee. Lists timesheets in `browsing`; opens detail in `viewing_single` with Submit / Approve / Reject / Revise / Delete actions.",
  "orbitals": [
    {
      "name": "TimesheetOrbital",
      "entity": {
        "name": "Timesheet",
        "collection": "timesheets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "employeeId",
            "type": "string",
            "required": true
          },
          {
            "name": "employeeName",
            "type": "string",
            "default": ""
          },
          {
            "name": "periodStart",
            "type": "string",
            "required": true
          },
          {
            "name": "periodEnd",
            "type": "string",
            "required": true
          },
          {
            "name": "totalHours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "billableHours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected",
              "needs-revision"
            ]
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TimesheetLedger",
          "category": "interaction",
          "linkedEntity": "Timesheet",
          "emits": [
            {
              "event": "OPEN_TIMESHEET",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_REVISION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TimesheetLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Timesheet]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TimesheetLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TimesheetLoaded",
                "name": "Timesheet loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Timesheet]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TimesheetLoadFailed",
                "name": "Timesheet load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TIMESHEET",
                "name": "Open Timesheet",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REQUEST_REVISION",
                "name": "Request Revision",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading timesheets…"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TimesheetLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "@payload.data.length",
                              "label": "Total timesheets"
                            },
                            {
                              "label": "Pending approval",
                              "type": "stat-display",
                              "value": "14",
                              "icon": "hourglass"
                            },
                            {
                              "icon": "dollar-sign",
                              "value": "1,240",
                              "type": "stat-display",
                              "label": "Billable hours wk"
                            },
                            {
                              "icon": "check-circle",
                              "value": "38",
                              "type": "stat-display",
                              "label": "Approved this wk"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "icon": "arrow-right",
                              "variant": "primary",
                              "label": "Open",
                              "event": "OPEN_TIMESHEET"
                            },
                            {
                              "event": "REQUEST_DELETE",
                              "label": "Delete",
                              "variant": "danger"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "employeeName",
                              "label": "Employee",
                              "variant": "caption"
                            },
                            {
                              "name": "periodStart",
                              "label": "Period Start",
                              "variant": "caption"
                            },
                            {
                              "name": "periodEnd",
                              "variant": "caption",
                              "label": "Period End"
                            },
                            {
                              "variant": "caption",
                              "name": "totalHours",
                              "label": "Total Hours"
                            },
                            {
                              "variant": "caption",
                              "name": "billableHours",
                              "label": "Billable"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "name": "approvedBy",
                              "label": "Approved By",
                              "variant": "caption"
                            }
                          ],
                          "entity": "@payload.data",
                          "gap": "sm",
                          "cols": 1.0
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TimesheetLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TIMESHEET",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.employeeId",
                    "@payload.row.employeeId"
                  ],
                  [
                    "set",
                    "@entity.employeeName",
                    "@payload.row.employeeName"
                  ],
                  [
                    "set",
                    "@entity.periodStart",
                    "@payload.row.periodStart"
                  ],
                  [
                    "set",
                    "@entity.periodEnd",
                    "@payload.row.periodEnd"
                  ],
                  [
                    "set",
                    "@entity.totalHours",
                    "@payload.row.totalHours"
                  ],
                  [
                    "set",
                    "@entity.billableHours",
                    "@payload.row.billableHours"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.row.submittedAt"
                  ],
                  [
                    "set",
                    "@entity.approvedBy",
                    "@payload.row.approvedBy"
                  ],
                  [
                    "set",
                    "@entity.approvedAt",
                    "@payload.row.approvedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.employeeName"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Employee ID",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.employeeId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Approved by",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.approvedBy",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Notes",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.totalHours",
                              "type": "stat-display",
                              "label": "Total hours",
                              "icon": "clock"
                            },
                            {
                              "label": "Billable",
                              "value": "@entity.billableHours",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "label": "Period start",
                              "value": "@entity.periodStart",
                              "type": "stat-display",
                              "icon": "calendar"
                            },
                            {
                              "type": "stat-display",
                              "icon": "calendar-check",
                              "value": "@entity.periodEnd",
                              "label": "Period end"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "action": "SUBMIT",
                              "label": "Submit",
                              "variant": "primary",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              }
                            },
                            {
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "label": "Approve",
                              "variant": "primary",
                              "action": "APPROVE",
                              "type": "button"
                            },
                            {
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "action": "REJECT",
                              "type": "button",
                              "label": "Reject",
                              "variant": "danger"
                            },
                            {
                              "action": "REQUEST_REVISION",
                              "variant": "secondary",
                              "label": "Revise",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              }
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "REQUEST_DELETE",
                              "label": "Delete",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Deleting timesheet…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
