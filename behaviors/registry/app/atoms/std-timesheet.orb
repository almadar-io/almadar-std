{
  "name": "std-timesheet",
  "version": "1.1.0",
  "description": "std-timesheet — weekly timesheet primitive holding total/billable hours for one employee. Lists timesheets in `browsing`; opens detail in `viewing_single` with Submit / Approve / Reject / Revise / Delete actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "TimesheetOrbital",
      "entity": {
        "name": "Timesheet",
        "collection": "timesheets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "employeeId",
            "type": "string",
            "required": true
          },
          {
            "name": "employeeName",
            "type": "string",
            "default": ""
          },
          {
            "name": "periodStart",
            "type": "string",
            "required": true
          },
          {
            "name": "periodEnd",
            "type": "string",
            "required": true
          },
          {
            "name": "totalHours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "billableHours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected",
              "needs-revision"
            ]
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TimesheetLedger",
          "category": "interaction",
          "linkedEntity": "Timesheet",
          "emits": [
            {
              "event": "OPEN_TIMESHEET",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_REVISION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TimesheetLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Timesheet]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TimesheetLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TimesheetLoaded",
                "name": "Timesheet loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Timesheet]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TimesheetLoadFailed",
                "name": "Timesheet load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TIMESHEET",
                "name": "Open Timesheet",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REQUEST_REVISION",
                "name": "Request Revision",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading timesheets…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TimesheetLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total timesheets",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "clock"
                            },
                            {
                              "type": "stat-display",
                              "icon": "hourglass",
                              "value": "14",
                              "label": "Pending approval"
                            },
                            {
                              "label": "Billable hours wk",
                              "type": "stat-display",
                              "icon": "dollar-sign",
                              "value": "1,240"
                            },
                            {
                              "value": "38",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "label": "Approved this wk"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TimesheetLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TIMESHEET",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.employeeId",
                    "@payload.row.employeeId"
                  ],
                  [
                    "set",
                    "@entity.employeeName",
                    "@payload.row.employeeName"
                  ],
                  [
                    "set",
                    "@entity.periodStart",
                    "@payload.row.periodStart"
                  ],
                  [
                    "set",
                    "@entity.periodEnd",
                    "@payload.row.periodEnd"
                  ],
                  [
                    "set",
                    "@entity.totalHours",
                    "@payload.row.totalHours"
                  ],
                  [
                    "set",
                    "@entity.billableHours",
                    "@payload.row.billableHours"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.row.submittedAt"
                  ],
                  [
                    "set",
                    "@entity.approvedBy",
                    "@payload.row.approvedBy"
                  ],
                  [
                    "set",
                    "@entity.approvedAt",
                    "@payload.row.approvedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.employeeName",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Employee ID"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.employeeId",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Approved by"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.approvedBy",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "content": "Notes",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Total hours",
                              "type": "stat-display",
                              "value": "@entity.totalHours",
                              "icon": "clock"
                            },
                            {
                              "label": "Billable",
                              "value": "@entity.billableHours",
                              "type": "stat-display",
                              "icon": "dollar-sign"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Period start",
                              "value": "@entity.periodStart"
                            },
                            {
                              "label": "Period end",
                              "icon": "calendar-check",
                              "value": "@entity.periodEnd",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "children": [
                            {
                              "action": "SUBMIT",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "label": "Submit",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "label": "Approve",
                              "type": "button",
                              "variant": "primary",
                              "action": "APPROVE"
                            },
                            {
                              "type": "button",
                              "action": "REJECT",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "label": "Reject",
                              "variant": "danger"
                            },
                            {
                              "variant": "secondary",
                              "action": "REQUEST_REVISION",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "type": "button",
                              "label": "Revise"
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "label": "Delete",
                              "action": "REQUEST_DELETE"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Deleting timesheet…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading timesheets…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Submitting timesheet…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Approving timesheet…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Rejecting timesheet…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_REVISION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Requesting revision…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Deleting timesheet…",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "name": "employeeName",
                  "label": "Employee"
                },
                {
                  "variant": "caption",
                  "name": "periodStart",
                  "label": "Period Start"
                },
                {
