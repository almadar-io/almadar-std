              }
            },
            "title": {
              "type": "string",
              "default": "Timesheets",
              "label": "Section title",
              "description": "Heading shown above the weekly timesheet list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TimesheetPage",
