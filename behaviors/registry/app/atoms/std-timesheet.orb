{
  "name": "std-timesheet",
  "version": "1.2.0",
  "description": "std-timesheet — weekly timesheet primitive. Listens for SET_STATUS so std-lifecycle can auto-close periods. Exposes HR knobs (backgroundCheckRequired, anonymizeOnRejection, …).",
  "orbitals": [
    {
      "name": "TimesheetOrbital",
      "entity": {
        "name": "Timesheet",
        "collection": "timesheets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "employeeId",
            "type": "string",
            "required": true
          },
          {
            "name": "employeeName",
            "type": "string",
            "default": ""
          },
          {
            "name": "periodStart",
            "type": "string",
            "required": true
          },
          {
            "name": "periodEnd",
            "type": "string",
            "required": true
          },
          {
            "name": "totalHours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "billableHours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected",
              "needs-revision"
            ]
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TimesheetLedger",
          "category": "interaction",
          "linkedEntity": "Timesheet",
          "emits": [
            {
              "event": "OPEN_TIMESHEET",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_REVISION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.employeeName",
                  "type": "string"
                },
                {
                  "name": "row.periodStart",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.periodEnd",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.totalHours",
                  "type": "number"
                },
                {
                  "name": "row.billableHours",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TimesheetLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Timesheet]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TimesheetLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TimesheetLoaded",
                "name": "Timesheet loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Timesheet]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TimesheetLoadFailed",
                "name": "Timesheet load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TIMESHEET",
                "name": "Open Timesheet",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              },
              {
                "key": "REQUEST_REVISION",
                "name": "Request Revision",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Timesheet"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading timesheets…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TimesheetLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total timesheets",
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "@payload.data.length"
                            },
                            {
                              "label": "Pending approval",
                              "type": "stat-display",
                              "value": "14",
                              "icon": "hourglass"
                            },
                            {
                              "label": "Billable hours wk",
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "value": "1,240"
                            },
                            {
                              "value": "38",
                              "type": "stat-display",
                              "label": "Approved this wk",
                              "icon": "check-circle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TimesheetLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TIMESHEET",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.employeeId",
                    "@payload.row.employeeId"
                  ],
                  [
                    "set",
                    "@entity.employeeName",
                    "@payload.row.employeeName"
                  ],
                  [
                    "set",
                    "@entity.periodStart",
                    "@payload.row.periodStart"
                  ],
                  [
                    "set",
                    "@entity.periodEnd",
                    "@payload.row.periodEnd"
                  ],
                  [
                    "set",
                    "@entity.totalHours",
                    "@payload.row.totalHours"
                  ],
                  [
                    "set",
                    "@entity.billableHours",
                    "@payload.row.billableHours"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.row.submittedAt"
                  ],
                  [
                    "set",
                    "@entity.approvedBy",
                    "@payload.row.approvedBy"
                  ],
                  [
                    "set",
                    "@entity.approvedAt",
                    "@payload.row.approvedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.employeeName",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.status",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Employee ID",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.employeeId",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Approved by",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.approvedBy",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Notes"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "@entity.totalHours",
                              "label": "Total hours"
                            },
                            {
                              "value": "@entity.billableHours",
                              "icon": "dollar-sign",
                              "label": "Billable",
                              "type": "stat-display"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.periodStart",
                              "label": "Period start"
                            },
                            {
                              "label": "Period end",
                              "value": "@entity.periodEnd",
                              "icon": "calendar-check",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Submit",
                              "action": "SUBMIT",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              }
                            },
                            {
                              "label": "Approve",
                              "action": "APPROVE",
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "action": "REJECT",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "variant": "danger",
                              "label": "Reject"
                            },
                            {
                              "label": "Revise",
                              "variant": "secondary",
                              "type": "button",
                              "action": "REQUEST_REVISION",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              }
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "type": "button",
                              "action": "REQUEST_DELETE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Deleting timesheet…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Timesheet",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Updating timesheet status…",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading timesheets…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Submitting timesheet…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Approving timesheet…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Rejecting timesheet…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_REVISION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Requesting revision…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "failure": "TimesheetLoadFailed",
                        "success": "TimesheetLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Deleting timesheet…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Timesheet",
                    {
                      "emit": {
                        "success": "TimesheetLoaded",
                        "failure": "TimesheetLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "eVerifyRequired": {
              "type": "boolean",
              "default": false,
              "label": "E-Verify required",
              "description": "Block APPROVE until E-Verify confirms work eligibility.",
              "tier": "customization"
            },
            "i9DocumentsRequired": {
              "type": "boolean",
              "default": false,
              "label": "I-9 documents required",
              "description": "Require I-9 on file before timesheet APPROVE.",
              "tier": "customization"
            },
            "title": {
              "type": "string",
              "default": "Timesheets",
              "label": "Section title",
              "description": "Heading shown above the weekly timesheet list",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Employee",
                  "variant": "caption",
                  "name": "employeeName"
                },
                {
                  "name": "periodStart",
                  "label": "Period Start",
                  "variant": "caption"
                },
                {
                  "label": "Period End",
                  "variant": "caption",
                  "name": "periodEnd"
                },
                {
                  "label": "Total Hours",
                  "variant": "caption",
                  "name": "totalHours"
                },
                {
                  "name": "billableHours",
                  "variant": "caption",
                  "label": "Billable"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "variant": "caption",
                  "name": "approvedBy",
                  "label": "Approved By"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Timesheet entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "retentionAfterRejectionDays": {
              "type": "number",
              "default": 1095.0,
              "label": "Retention after rejection (days)",
              "description": "Days to keep rejected timesheets. Default 1095 (3 years) typical wage-and-hour.",
              "tier": "advanced"
            },
            "backgroundCheckRequired": {
              "type": "boolean",
              "default": false,
              "label": "Background check required",
              "description": "Block SUBMIT until employee background check is on file.",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_TIMESHEET",
                  "variant": "primary",
                  "label": "Open"
                },
                {
                  "label": "Delete",
                  "variant": "danger",
                  "event": "REQUEST_DELETE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each timesheet row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "anonymizeOnRejection": {
              "type": "boolean",
              "default": false,
              "label": "Anonymize on rejection",
              "description": "When true, scrub employee PII on rejected timesheets. Pair with std-data-erasure.",
              "tier": "customization"
            },
            "equalOpportunityTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Equal opportunity tracking",
              "description": "Capture demographic data separately for EEO reporting (sibling collection).",
              "tier": "advanced"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TimesheetPage",
