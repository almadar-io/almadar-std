{
  "name": "std-health-score",
  "version": "1.1.0",
  "description": "std-health-score — customer success health score primitive surfacing churn risk via composite usage/support/engagement signals. Lists health scores in `browsing`; opens detail in `viewing_single` with Recalculate / Assign CSM actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "HealthScoreOrbital",
      "entity": {
        "name": "HealthScore",
        "collection": "healthscores",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "score",
            "type": "number",
            "default": 50.0
          },
          {
            "name": "tier",
            "type": "string",
            "default": "green",
            "values": [
              "green",
              "yellow",
              "red"
            ]
          },
          {
            "name": "usageScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "supportScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "engagementScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "trend",
            "type": "string",
            "default": "stable",
            "values": [
              "improving",
              "stable",
              "declining"
            ]
          },
          {
            "name": "lastCalculatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HealthScoreDashboard",
          "category": "interaction",
          "linkedEntity": "HealthScore",
          "emits": [
            {
              "event": "OPEN_SCORE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.score",
                  "type": "number"
                },
                {
                  "name": "row.tier",
                  "type": "string"
                },
                {
                  "name": "row.usageScore",
                  "type": "number"
                },
                {
                  "name": "row.supportScore",
                  "type": "number"
                },
                {
                  "name": "row.engagementScore",
                  "type": "number"
                },
                {
                  "name": "row.trend",
                  "type": "string"
                },
                {
                  "name": "row.lastCalculatedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedCsm",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "RECALCULATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ASSIGN_CSM",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "HealthScoreLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HealthScore]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HealthScoreLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HealthScoreLoaded",
                "name": "HealthScore loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HealthScore]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HealthScoreLoadFailed",
                "name": "HealthScore load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SCORE",
                "name": "Open Score",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "HealthScore"
                  }
                ]
              },
              {
                "key": "RECALCULATE",
                "name": "Recalculate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ASSIGN_CSM",
                "name": "Assign Csm",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading health scores…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "HealthScoreLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total customers",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "value": "62%",
                              "label": "Green tier",
                              "icon": "smile"
                            },
                            {
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "At risk (red)",
                              "value": "8"
                            },
                            {
                              "icon": "trending-up",
                              "label": "30d trend",
                              "value": "+4.2%",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HealthScoreLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.message"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.customerName",
                    "@payload.row.customerName"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@payload.row.score"
                  ],
                  [
                    "set",
                    "@entity.tier",
                    "@payload.row.tier"
                  ],
                  [
                    "set",
                    "@entity.usageScore",
                    "@payload.row.usageScore"
                  ],
                  [
                    "set",
                    "@entity.supportScore",
                    "@payload.row.supportScore"
                  ],
                  [
                    "set",
                    "@entity.engagementScore",
                    "@payload.row.engagementScore"
                  ],
                  [
                    "set",
                    "@entity.trend",
                    "@payload.row.trend"
                  ],
                  [
                    "set",
                    "@entity.lastCalculatedAt",
                    "@payload.row.lastCalculatedAt"
                  ],
                  [
                    "set",
                    "@entity.assignedCsm",
                    "@payload.row.assignedCsm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.customerName",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.tier",
                              "variant": "primary",
                              "type": "badge"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.trend"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Customer ID",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.customerId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Assigned CSM"
                                },
                                {
                                  "content": "@entity.assignedCsm",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@entity.score",
                              "type": "stat-display",
                              "label": "Composite",
                              "icon": "activity"
                            },
                            {
                              "value": "@entity.usageScore",
                              "type": "stat-display",
                              "icon": "bar-chart",
                              "label": "Usage"
                            },
                            {
                              "type": "stat-display",
                              "label": "Support",
                              "value": "@entity.supportScore",
                              "icon": "life-buoy"
                            },
                            {
                              "icon": "users",
                              "value": "@entity.engagementScore",
                              "label": "Engagement",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "RECALCULATE",
                              "variant": "primary",
                              "label": "Recalculate",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "variant": "secondary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Assign CSM",
                              "action": "ASSIGN_CSM"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Recalculating health score…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading health scores…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Recalculating health score…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN_CSM",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Assigning CSM…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_SCORE",
                  "label": "Open"
                },
                {
                  "event": "RECALCULATE",
                  "variant": "secondary",
                  "label": "Recalculate"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each customer row",
              "items": {
                "type": "object"
              }
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Customer",
                  "name": "customerName"
                },
                {
                  "variant": "badge",
                  "name": "score",
                  "label": "Score"
                },
                {
                  "name": "tier",
                  "label": "Tier",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "label": "Usage",
                  "name": "usageScore"
                },
                {
                  "variant": "caption",
                  "label": "Support",
                  "name": "supportScore"
                },
                {
                  "variant": "badge",
                  "name": "trend",
                  "label": "Trend"
                },
                {
                  "name": "assignedCsm",
                  "label": "CSM",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Health Score entity",
              "items": {
                "type": "object"
              }
            },
            "title": {
              "type": "string",
              "default": "Customer Health Scores",
              "label": "Section title",
              "description": "Heading shown above the customer health dashboard"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HealthScorePage",
          "path": "/health-scores",
          "traits": [
            {
              "ref": "HealthScoreDashboard"
            }
          ]
        }
      ]
    }
  ]
}