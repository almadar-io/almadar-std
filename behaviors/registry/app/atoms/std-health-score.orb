{
  "name": "std-health-score",
  "version": "1.0.0",
  "description": "std-health-score — Customer success health score primitive surfacing churn risk via composite usage/support/engagement signals.",
  "orbitals": [
    {
      "name": "HealthScoreOrbital",
      "entity": {
        "name": "HealthScore",
        "collection": "healthscores",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "score",
            "type": "number",
            "default": 50.0
          },
          {
            "name": "tier",
            "type": "string",
            "default": "green",
            "values": [
              "green",
              "yellow",
              "red"
            ]
          },
          {
            "name": "usageScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "supportScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "engagementScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "trend",
            "type": "string",
            "default": "stable",
            "values": [
              "improving",
              "stable",
              "declining"
            ]
          },
          {
            "name": "lastCalculatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HealthScoreDashboard",
          "category": "interaction",
          "linkedEntity": "HealthScore",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RECALCULATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ASSIGN_CSM",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HealthScoreLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HealthScore]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HealthScoreLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HealthScoreLoaded",
                "name": "HealthScore loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HealthScore]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HealthScoreLoadFailed",
                "name": "HealthScore load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TIER",
                "name": "Filter Tier",
                "payloadSchema": [
                  {
                    "name": "tier",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TREND",
                "name": "Filter Trend",
                "payloadSchema": [
                  {
                    "name": "trend",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RECALCULATE",
                "name": "Recalculate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ASSIGN_CSM",
                "name": "Assign Csm",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading health scores…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "HealthScoreLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "variant": "secondary",
                              "label": "View",
                              "event": "VIEW"
                            },
                            {
                              "event": "EDIT",
                              "label": "Edit",
                              "variant": "secondary"
                            },
                            {
                              "label": "Recalculate",
                              "event": "RECALCULATE",
                              "variant": "primary"
                            },
                            {
                              "label": "Assign CSM",
                              "variant": "ghost",
                              "event": "ASSIGN_CSM"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "customerName",
                              "label": "Customer"
                            },
                            {
                              "label": "Score",
                              "name": "score",
                              "variant": "badge"
                            },
                            {
                              "name": "tier",
                              "label": "Tier",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "label": "Usage",
                              "name": "usageScore"
                            },
                            {
                              "label": "Support",
                              "name": "supportScore",
                              "variant": "caption"
                            },
                            {
                              "name": "trend",
                              "variant": "badge",
                              "label": "Trend"
                            },
                            {
                              "name": "assignedCsm",
                              "variant": "caption",
                              "label": "CSM"
                            },
                            {
                              "name": "lastCalculatedAt",
                              "label": "Updated",
                              "variant": "caption"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HealthScoreLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.message",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Refreshing health scores…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Searching health scores…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TIER",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Filtering by tier…"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TREND",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Filtering by trend…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Viewing health score",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Editing health score",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "type": "alert",
                      "message": "Recalculation triggered"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "ASSIGN_CSM",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Assigning CSM"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Customer Health Scores"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HealthScorePage",
          "path": "/health-scores",
          "traits": [
            {
              "ref": "HealthScoreDashboard"
            }
          ]
        }
      ]
    }
  ]
}
