{
  "name": "std-health-score",
  "version": "1.0.0",
  "description": "std-health-score — Customer success health score primitive surfacing churn risk via composite usage/support/engagement signals.",
  "orbitals": [
    {
      "name": "HealthScoreOrbital",
      "entity": {
        "name": "HealthScore",
        "collection": "healthscores",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "score",
            "type": "number",
            "default": 50.0
          },
          {
            "name": "tier",
            "type": "string",
            "default": "green",
            "values": [
              "green",
              "yellow",
              "red"
            ]
          },
          {
            "name": "usageScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "supportScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "engagementScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "trend",
            "type": "string",
            "default": "stable",
            "values": [
              "improving",
              "stable",
              "declining"
            ]
          },
          {
            "name": "lastCalculatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HealthScoreDashboard",
          "category": "interaction",
          "linkedEntity": "HealthScore",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RECALCULATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ASSIGN_CSM",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HealthScoreLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HealthScore]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HealthScoreLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HealthScoreLoaded",
                "name": "HealthScore loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HealthScore]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HealthScoreLoadFailed",
                "name": "HealthScore load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TIER",
                "name": "Filter Tier",
                "payloadSchema": [
                  {
                    "name": "tier",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TREND",
                "name": "Filter Trend",
                "payloadSchema": [
                  {
                    "name": "trend",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RECALCULATE",
                "name": "Recalculate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ASSIGN_CSM",
                "name": "Assign Csm",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading health scores…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "HealthScoreLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "title": "Customer Health Overview",
                          "type": "section-header",
                          "align": "left",
                          "level": 2.0,
                          "subtitle": "Composite signals across usage, support, and engagement"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "max": 100.0,
                              "size": "md",
                              "showValue": true,
                              "type": "meter",
                              "variant": "radial",
                              "min": 0.0,
                              "value": 78.0,
                              "unit": "%",
                              "label": "Composite Health",
                              "thresholds": [
                                {
                                  "value": 40.0,
                                  "color": "danger"
                                },
                                {
                                  "value": 70.0,
                                  "color": "warning"
                                }
                              ]
                            },
                            {
                              "type": "health-bar",
                              "current": 78.0,
                              "animated": true,
                              "format": "bar",
                              "max": 100.0,
                              "size": "md"
                            },
                            {
                              "type": "trend-indicator",
                              "value": 4.2,
                              "label": "30d trend",
                              "size": "md",
                              "direction": "up",
                              "showValue": true
                            },
                            {
                              "type": "combo-counter",
                              "size": "md",
                              "streak": 4.0,
                              "combo": 6.0,
                              "multiplier": 2.0
                            }
                          ]
                        },
                        {
                          "items": [
                            {
                              "label": "Engagement",
                              "id": "engagement"
                            },
                            {
                              "id": "usage",
                              "label": "Usage"
                            },
                            {
                              "label": "Health",
                              "id": "health"
                            }
                          ],
                          "orientation": "horizontal",
                          "type": "tabs",
                          "variant": "default",
                          "activeTab": "health"
                        },
                        {
                          "type": "sidebar",
                          "brandName": "Health Detail",
                          "hideCollapseButton": true,
                          "items": [
                            {
                              "label": "Summary",
                              "id": "summary"
                            },
                            {
                              "id": "history",
                              "label": "History"
                            },
                            {
                              "label": "Playbook",
                              "id": "playbook"
                            },
                            {
                              "label": "CSM Notes",
                              "id": "csm"
                            }
                          ],
                          "showCloseButton": false
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "elevated",
                              "size": "md",
                              "description": "Identifies subscribers trending toward renewal vs churn",
                              "type": "feature-card",
                              "icon": "refresh-cw",
                              "title": "Auto-Renewal Insights"
                            },
                            {
                              "variant": "bordered",
                              "size": "md",
                              "type": "feature-card",
                              "description": "Triggers CSM workflows when health drops below threshold",
                              "title": "Risk Escalation",
                              "icon": "alert-triangle"
                            },
                            {
                              "avatar": "https://i.pravatar.cc/120?u=priya",
                              "role": "Senior CSM",
                              "name": "Priya Sharma",
                              "bio": "Owns enterprise accounts across NA West",
                              "type": "team-card"
                            }
                          ]
                        },
                        {
                          "subtitle": "Top contributors to composite score",
                          "type": "feature-grid-organism",
                          "columns": 3.0,
                          "heading": "Health Signal Drivers"
                        },
                        {
                          "type": "team-organism",
                          "heading": "Customer Success Team",
                          "subtitle": "CSMs supporting this segment"
                        },
                        {
                          "type": "stats-organism",
                          "columns": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "type": "data-grid",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW",
                              "variant": "secondary"
                            },
                            {
                              "event": "EDIT",
                              "label": "Edit",
                              "variant": "secondary"
                            },
                            {
                              "event": "RECALCULATE",
                              "variant": "primary",
                              "label": "Recalculate"
                            },
                            {
                              "event": "ASSIGN_CSM",
                              "variant": "ghost",
                              "label": "Assign CSM"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Customer",
                              "name": "customerName"
                            },
                            {
                              "variant": "badge",
                              "name": "score",
                              "label": "Score"
                            },
                            {
                              "variant": "badge",
                              "label": "Tier",
                              "name": "tier"
                            },
                            {
                              "name": "usageScore",
                              "label": "Usage",
                              "variant": "caption"
                            },
                            {
                              "label": "Support",
                              "name": "supportScore",
                              "variant": "caption"
                            },
                            {
                              "name": "trend",
                              "label": "Trend",
                              "variant": "badge"
                            },
                            {
                              "name": "assignedCsm",
                              "variant": "caption",
                              "label": "CSM"
                            },
                            {
                              "label": "Updated",
                              "name": "lastCalculatedAt",
                              "variant": "caption"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HealthScoreLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.message",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Refreshing health scores…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Searching health scores…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TIER",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Filtering by tier…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TREND",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Filtering by trend…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Viewing health score",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Editing health score",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Recalculation triggered",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "ASSIGN_CSM",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Assigning CSM",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Customer Health Scores"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HealthScorePage",
          "path": "/health-scores",
          "traits": [
            {
              "ref": "HealthScoreDashboard"
            }
          ]
        }
      ]
    }
  ]
}
