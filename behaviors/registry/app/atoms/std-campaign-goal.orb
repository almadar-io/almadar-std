{
  "name": "std-campaign-goal",
  "version": "1.0.0",
  "description": "std-campaign-goal — nonprofit fundraising campaign primitive with a target dollar amount, running raised total, donor count, deadline, and status. Browses campaigns in a data-grid with Launch / End row actions.",
  "orbitals": [
    {
      "name": "CampaignGoalOrbital",
      "entity": {
        "name": "CampaignGoal",
        "collection": "campaigngoals",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "targetAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "raisedAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "donorCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "startDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "endDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "achieved",
              "ended"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "CampaignGoalTracker",
          "category": "interaction",
          "linkedEntity": "CampaignGoal",
          "emits": [
            {
              "event": "LAUNCH_CAMPAIGN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "END_CAMPAIGN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CampaignGoalLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CampaignGoal]"
                }
              ]
            },
            {
              "event": "CampaignGoalLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CampaignGoalLoaded",
                "name": "CampaignGoal loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CampaignGoal]"
                  }
                ]
              },
              {
                "key": "CampaignGoalLoadFailed",
                "name": "CampaignGoal load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LAUNCH_CAMPAIGN",
                "name": "Launch Campaign",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "END_CAMPAIGN",
                "name": "End Campaign",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CampaignGoal",
                    {
                      "emit": {
                        "failure": "CampaignGoalLoadFailed",
                        "success": "CampaignGoalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading campaigns…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CampaignGoalLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "tag": "Campaign",
                          "primaryAction": {
                            "label": "Donate Now",
                            "href": "#donate"
                          },
                          "type": "hero-section",
                          "title": "Help us reach our goal",
                          "tagVariant": "primary",
                          "titleAccent": "@config.title",
                          "subtitle": "Every gift moves the needle. Join thousands of donors making impact possible.",
                          "secondaryAction": {
                            "href": "#story",
                            "label": "Learn More"
                          }
                        },
                        {
                          "children": [
                            {
                              "value": 482000.0,
                              "duration": 1500.0,
                              "type": "animated-counter",
                              "prefix": "$",
                              "suffix": " raised"
                            },
                            {
                              "suffix": " donors",
                              "type": "animated-counter",
                              "value": 1240.0,
                              "duration": 1500.0
                            },
                            {
                              "type": "animated-counter",
                              "value": 87.0,
                              "suffix": "% of goal",
                              "duration": 1500.0
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "lg",
                          "type": "stack",
                          "justify": "around"
                        },
                        {
                          "type": "progress-bar",
                          "max": 100.0,
                          "color": "primary",
                          "showPercentage": true,
                          "value": 87.0
                        },
                        {
                          "animation": "fade-up",
                          "trigger": "scroll",
                          "children": [
                            {
                              "text": "Together, we change lives.",
                              "type": "typewriter-text",
                              "speed": 60.0
                            }
                          ],
                          "type": "animated-reveal"
                        },
                        {
                          "background": "alt",
                          "padding": "lg",
                          "type": "content-section",
                          "children": [
                            {
                              "variant": "h3",
                              "content": "Choose your donation tier",
                              "type": "typography"
                            },
                            {
                              "plans": [
                                {
                                  "action": {
                                    "href": "#",
                                    "label": "Give $25"
                                  },
                                  "price": "$25",
                                  "description": "Provides one week of meals",
                                  "name": "Supporter",
                                  "features": [
                                    "Tax receipt",
                                    "Thank-you email"
                                  ]
                                },
                                {
                                  "description": "Funds a child's school supplies for a year",
                                  "highlighted": true,
                                  "features": [
                                    "Tax receipt",
                                    "Personalized note",
                                    "Quarterly update"
                                  ],
                                  "name": "Advocate",
                                  "price": "$100",
                                  "action": {
                                    "href": "#",
                                    "label": "Give $100"
                                  }
                                },
                                {
                                  "action": {
                                    "href": "#",
                                    "label": "Give $500"
                                  },
                                  "description": "Sponsors a community clean-water station",
                                  "price": "$500",
                                  "name": "Champion",
                                  "features": [
                                    "Tax receipt",
                                    "Recognition in newsletter",
                                    "Site-visit invite"
                                  ]
                                }
                              ],
                              "type": "pricing-grid"
                            }
                          ]
                        },
                        {
                          "background": "default",
                          "type": "content-section",
                          "padding": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Impact in pictures"
                            },
                            {
                              "items": [
                                {
                                  "id": "i1",
                                  "src": "https://picsum.photos/seed/campaign1/800/600",
                                  "alt": "Clean water delivery"
                                },
                                {
                                  "alt": "School supplies handout",
                                  "id": "i2",
                                  "src": "https://picsum.photos/seed/campaign2/800/600"
                                },
                                {
                                  "alt": "Community meal program",
                                  "src": "https://picsum.photos/seed/campaign3/800/600",
                                  "id": "i3"
                                },
                                {
                                  "alt": "Volunteer team",
                                  "src": "https://picsum.photos/seed/campaign4/800/600",
                                  "id": "i4"
                                }
                              ],
                              "type": "media-gallery"
                            }
                          ]
                        },
                        {
                          "images": [
                            {
                              "caption": "Clean water",
                              "alt": "Impact",
                              "src": "https://picsum.photos/seed/campaign1/1200/800"
                            }
                          ],
                          "type": "lightbox",
                          "isOpen": false,
                          "showCounter": true,
                          "currentIndex": 0.0
                        },
                        {
                          "variant": "quotes",
                          "type": "social-proof",
                          "items": [
                            {
                              "name": "Maria S.",
                              "quote": "This nonprofit changed my family's life."
                            },
                            {
                              "name": "James W.",
                              "quote": "Every dollar I give I can see in the field."
                            },
                            {
                              "quote": "Transparent, honest, and effective.",
                              "name": "Lina P."
                            }
                          ]
                        },
                        {
                          "twitter": {
                            "url": "https://twitter.com/example"
                          },
                          "github": {
                            "url": "https://github.com/example"
                          },
                          "heading": "Stay connected",
                          "type": "community-links",
                          "discord": {
                            "url": "https://discord.gg/example"
                          }
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "target",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Name",
                              "variant": "caption",
                              "name": "name"
                            },
                            {
                              "name": "targetAmount",
                              "label": "Target",
                              "variant": "caption"
                            },
                            {
                              "label": "Raised",
                              "variant": "caption",
                              "name": "raisedAmount"
                            },
                            {
                              "variant": "caption",
                              "name": "donorCount",
                              "label": "Donors"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "cols": 1.0,
                          "gap": "sm",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "LAUNCH_CAMPAIGN",
                              "label": "Launch",
                              "variant": "primary"
                            },
                            {
                              "event": "END_CAMPAIGN",
                              "variant": "danger",
                              "label": "End"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CampaignGoalLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "LAUNCH_CAMPAIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Campaign launched",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "END_CAMPAIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Campaign ended",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CampaignGoal",
                    {
                      "emit": {
                        "success": "CampaignGoalLoaded",
                        "failure": "CampaignGoalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Campaigns"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CampaignGoalPage",
          "path": "/campaigns",
          "traits": [
            {
              "ref": "CampaignGoalTracker"
            }
          ]
        }
      ]
    }
  ]
}
