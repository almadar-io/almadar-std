{
  "name": "std-time-entry",
  "version": "1.2.0",
  "description": "std-time-entry — time tracking line within a timesheet. Listens for SET_STATUS so std-lifecycle can auto-submit / auto-approve. Exposes HR knobs (backgroundCheckRequired, anonymizeOnRejection, …).",
  "orbitals": [
    {
      "name": "TimeEntryOrbital",
      "entity": {
        "name": "TimeEntry",
        "collection": "timeentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "timesheetId",
            "type": "string",
            "required": true
          },
          {
            "name": "projectId",
            "type": "string",
            "default": ""
          },
          {
            "name": "projectName",
            "type": "string",
            "default": ""
          },
          {
            "name": "taskDescription",
            "type": "string",
            "required": true
          },
          {
            "name": "workDate",
            "type": "string",
            "required": true
          },
          {
            "name": "hours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "billable",
            "type": "boolean",
            "default": false
          },
          {
            "name": "hourlyRate",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TimeEntryLog",
          "category": "interaction",
          "linkedEntity": "TimeEntry",
          "emits": [
            {
              "event": "OPEN_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.timesheetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.projectId",
                  "type": "string"
                },
                {
                  "name": "row.projectName",
                  "type": "string"
                },
                {
                  "name": "row.taskDescription",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.workDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.hours",
                  "type": "number"
                },
                {
                  "name": "row.billable",
                  "type": "boolean"
                },
                {
                  "name": "row.hourlyRate",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TimeEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TimeEntry]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TimeEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TimeEntryLoaded",
                "name": "TimeEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TimeEntry]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TimeEntryLoadFailed",
                "name": "TimeEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ENTRY",
                "name": "Open Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TimeEntry"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading time entries…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TimeEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total entries",
                              "icon": "list",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "value": "32",
                              "label": "Hours this week",
                              "type": "stat-display",
                              "icon": "clock"
                            },
                            {
                              "icon": "dollar-sign",
                              "value": "78%",
                              "label": "Billable %",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "trending-up",
                              "label": "Avg per day",
                              "value": "6.4h"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TimeEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.timesheetId",
                    "@payload.row.timesheetId"
                  ],
                  [
                    "set",
                    "@entity.projectId",
                    "@payload.row.projectId"
                  ],
                  [
                    "set",
                    "@entity.projectName",
                    "@payload.row.projectName"
                  ],
                  [
                    "set",
                    "@entity.taskDescription",
                    "@payload.row.taskDescription"
                  ],
                  [
                    "set",
                    "@entity.workDate",
                    "@payload.row.workDate"
                  ],
                  [
                    "set",
                    "@entity.hours",
                    "@payload.row.hours"
                  ],
                  [
                    "set",
                    "@entity.hourlyRate",
                    "@payload.row.hourlyRate"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.projectName",
                              "variant": "h3"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Task",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.taskDescription"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Timesheet",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.timesheetId"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Notes"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.notes",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Hours",
                              "icon": "clock",
                              "value": "@entity.hours",
                              "type": "stat-display"
                            },
                            {
                              "label": "Rate",
                              "type": "stat-display",
                              "value": "@entity.hourlyRate",
                              "icon": "dollar-sign"
                            },
                            {
                              "label": "Date",
                              "icon": "calendar",
                              "value": "@entity.workDate",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "REQUEST_DELETE"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Deleting time entry…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "TimeEntry",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TimeEntryLoadFailed",
                        "success": "TimeEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Updating time entry status…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "failure": "TimeEntryLoadFailed",
                        "success": "TimeEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading time entries…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Deleting time entry…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "i9DocumentsRequired": {
              "type": "boolean",
              "default": false,
              "label": "I-9 documents required",
              "description": "Require I-9 on file before billable hours are submitted.",
              "tier": "customization"
            },
            "equalOpportunityTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Equal opportunity tracking",
              "description": "Capture demographic data separately for EEO reporting (sibling collection).",
              "tier": "advanced"
            },
            "eVerifyRequired": {
              "type": "boolean",
              "default": false,
              "label": "E-Verify required",
              "description": "Block submission until E-Verify confirms work eligibility.",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_ENTRY",
                  "variant": "primary",
                  "label": "Open"
                },
                {
                  "label": "Delete",
                  "event": "REQUEST_DELETE",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each entry row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "retentionAfterRejectionDays": {
              "type": "number",
              "default": 1095.0,
              "label": "Retention after rejection (days)",
              "description": "Days to keep rejected time entries. Default 1095 (3 years) typical wage-and-hour.",
              "tier": "advanced"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "projectName",
                  "label": "Project"
                },
                {
                  "variant": "caption",
                  "name": "taskDescription",
                  "label": "Task"
                },
                {
                  "name": "workDate",
                  "label": "Date",
                  "variant": "caption"
                },
                {
                  "name": "hours",
                  "variant": "caption",
                  "label": "Hours"
                },
                {
                  "name": "billable",
                  "label": "Billable",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "name": "hourlyRate",
                  "label": "Rate"
                },
                {
                  "name": "status",
                  "variant": "badge",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Time Entry entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Time Entries",
              "label": "Section title",
              "description": "Heading shown above the time entry log",
              "tier": "customization"
            },
            "anonymizeOnRejection": {
              "type": "boolean",
              "default": false,
              "label": "Anonymize on rejection",
              "description": "When true, scrub worker PII on rejected entries. Pair with std-data-erasure.",
              "tier": "customization"
            },
            "backgroundCheckRequired": {
              "type": "boolean",
              "default": false,
              "label": "Background check required",
              "description": "Block billable submission until a background check is on file.",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TimeEntryPage",
          "path": "/time-entries",
          "traits": [
            {
              "ref": "TimeEntryLog"
            }
          ]
        }
      ]
    }
  ]
}