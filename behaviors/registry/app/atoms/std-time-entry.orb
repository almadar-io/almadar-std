{
  "name": "std-time-entry",
  "version": "1.1.0",
  "description": "std-time-entry — time tracking line within a timesheet: project/task, hours, date, billable flag, rate. Lists entries in `browsing`; opens entry detail in `viewing_single` with Delete action. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "TimeEntryOrbital",
      "entity": {
        "name": "TimeEntry",
        "collection": "timeentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "timesheetId",
            "type": "string",
            "required": true
          },
          {
            "name": "projectId",
            "type": "string",
            "default": ""
          },
          {
            "name": "projectName",
            "type": "string",
            "default": ""
          },
          {
            "name": "taskDescription",
            "type": "string",
            "required": true
          },
          {
            "name": "workDate",
            "type": "string",
            "required": true
          },
          {
            "name": "hours",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "billable",
            "type": "boolean",
            "default": false
          },
          {
            "name": "hourlyRate",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TimeEntryLog",
          "category": "interaction",
          "linkedEntity": "TimeEntry",
          "emits": [
            {
              "event": "OPEN_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.timesheetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.projectId",
                  "type": "string"
                },
                {
                  "name": "row.projectName",
                  "type": "string"
                },
                {
                  "name": "row.taskDescription",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.workDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.hours",
                  "type": "number"
                },
                {
                  "name": "row.billable",
                  "type": "boolean"
                },
                {
                  "name": "row.hourlyRate",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TimeEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TimeEntry]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TimeEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TimeEntryLoaded",
                "name": "TimeEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TimeEntry]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TimeEntryLoadFailed",
                "name": "TimeEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ENTRY",
                "name": "Open Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TimeEntry"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading time entries…"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TimeEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Total entries",
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "icon": "list"
                            },
                            {
                              "value": "32",
                              "label": "Hours this week",
                              "icon": "clock",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "78%",
                              "label": "Billable %",
                              "icon": "dollar-sign"
                            },
                            {
                              "label": "Avg per day",
                              "value": "6.4h",
                              "type": "stat-display",
                              "icon": "trending-up"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TimeEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.timesheetId",
                    "@payload.row.timesheetId"
                  ],
                  [
                    "set",
                    "@entity.projectId",
                    "@payload.row.projectId"
                  ],
                  [
                    "set",
                    "@entity.projectName",
                    "@payload.row.projectName"
                  ],
                  [
                    "set",
                    "@entity.taskDescription",
                    "@payload.row.taskDescription"
                  ],
                  [
                    "set",
                    "@entity.workDate",
                    "@payload.row.workDate"
                  ],
                  [
                    "set",
                    "@entity.hours",
                    "@payload.row.hours"
                  ],
                  [
                    "set",
                    "@entity.hourlyRate",
                    "@payload.row.hourlyRate"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.projectName"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Task",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.taskDescription",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "content": "Timesheet",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.timesheetId"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Notes"
                                },
                                {
                                  "content": "@entity.notes",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.hours",
                              "icon": "clock",
                              "label": "Hours"
                            },
                            {
                              "type": "stat-display",
                              "label": "Rate",
                              "value": "@entity.hourlyRate",
                              "icon": "dollar-sign"
                            },
                            {
                              "type": "stat-display",
                              "label": "Date",
                              "value": "@entity.workDate",
                              "icon": "calendar"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "type": "button",
                              "action": "REQUEST_DELETE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Deleting time entry…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "success": "TimeEntryLoaded",
                        "failure": "TimeEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading time entries…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "failure": "TimeEntryLoadFailed",
                        "success": "TimeEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Deleting time entry…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TimeEntry",
                    {
                      "emit": {
                        "failure": "TimeEntryLoadFailed",
                        "success": "TimeEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "Project",
                  "variant": "caption",
                  "name": "projectName"
                },
                {
                  "variant": "caption",
                  "name": "taskDescription",
                  "label": "Task"
                },
                {
                  "variant": "caption",
                  "name": "workDate",
                  "label": "Date"
                },
                {
                  "name": "hours",
                  "label": "Hours",
                  "variant": "caption"
                },
                {
                  "label": "Billable",
                  "name": "billable",
                  "variant": "badge"
                },
                {
                  "label": "Rate",
                  "variant": "caption",
                  "name": "hourlyRate"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_ENTRY",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "event": "REQUEST_DELETE",
                  "label": "Delete",
                  "variant": "danger"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Time Entries"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TimeEntryPage",
          "path": "/time-entries",
          "traits": [
            {
              "ref": "TimeEntryLog"
            }
          ]
        }
      ]
    }
  ]
}
