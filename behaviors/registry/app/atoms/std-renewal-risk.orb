{
  "name": "std-renewal-risk",
  "version": "1.2.0",
  "description": "std-renewal-risk — Customer Success renewal risk tracker with Mark Saved / Mark Churned actions. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs.",
  "orbitals": [
    {
      "name": "RenewalRiskOrbital",
      "entity": {
        "name": "RenewalRisk",
        "collection": "renewalrisks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "renewalDate",
            "type": "string",
            "required": true
          },
          {
            "name": "arrAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "riskLevel",
            "type": "string",
            "default": "low",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "reason",
            "type": "string",
            "default": ""
          },
          {
            "name": "mitigationPlan",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "monitoring",
            "values": [
              "monitoring",
              "in-progress",
              "saved",
              "churned"
            ]
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastCheckIn",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RenewalRiskWatch",
          "category": "interaction",
          "linkedEntity": "RenewalRisk",
          "emits": [
            {
              "event": "OPEN_RISK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.renewalDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.arrAmount",
                  "type": "number"
                },
                {
                  "name": "row.riskLevel",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.mitigationPlan",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedCsm",
                  "type": "string"
                },
                {
                  "name": "row.lastCheckIn",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "MARK_SAVED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_CHURNED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RenewalRiskLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RenewalRisk]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "RenewalRiskLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RenewalRiskUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.renewalDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.arrAmount",
                  "type": "number"
                },
                {
                  "name": "row.riskLevel",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.mitigationPlan",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedCsm",
                  "type": "string"
                },
                {
                  "name": "row.lastCheckIn",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RenewalRiskUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RenewalRiskLoaded",
                "name": "RenewalRisk loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RenewalRisk]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RenewalRiskLoadFailed",
                "name": "RenewalRisk load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RISK",
                "name": "Open Risk",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "RenewalRisk"
                  }
                ]
              },
              {
                "key": "MARK_SAVED",
                "name": "Mark Saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_CHURNED",
                "name": "Mark Churned",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RenewalRiskUpdated",
                "name": "RenewalRisk updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "RenewalRisk"
                  }
                ]
              },
              {
                "key": "RenewalRiskUpdateFailed",
                "name": "RenewalRisk update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading renewal risks…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RenewalRiskLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "alert-triangle",
                              "label": "At-risk accounts"
                            },
                            {
                              "label": "ARR at risk",
                              "type": "stat-display",
                              "value": "$1.2M",
                              "icon": "dollar-sign"
                            },
                            {
                              "icon": "flame",
                              "value": "8",
                              "label": "Critical",
                              "type": "stat-display"
                            },
                            {
                              "label": "Save rate",
                              "type": "stat-display",
                              "icon": "trending-up",
                              "value": "67%"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RenewalRiskLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.message",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RISK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.customerName",
                    "@payload.row.customerName"
                  ],
                  [
                    "set",
                    "@entity.renewalDate",
                    "@payload.row.renewalDate"
                  ],
                  [
                    "set",
                    "@entity.arrAmount",
                    "@payload.row.arrAmount"
                  ],
                  [
                    "set",
                    "@entity.riskLevel",
                    "@payload.row.riskLevel"
                  ],
                  [
                    "set",
                    "@entity.reason",
                    "@payload.row.reason"
                  ],
                  [
                    "set",
                    "@entity.mitigationPlan",
                    "@payload.row.mitigationPlan"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.assignedCsm",
                    "@payload.row.assignedCsm"
                  ],
                  [
                    "set",
                    "@entity.lastCheckIn",
                    "@payload.row.lastCheckIn"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.customerName",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "danger",
                              "label": "@entity.riskLevel",
                              "type": "badge"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Reason",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.reason",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Mitigation plan",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.mitigationPlan"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "CSM",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.assignedCsm",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "dollar-sign",
                              "label": "ARR",
                              "value": "@entity.arrAmount",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Renewal",
                              "value": "@entity.renewalDate",
                              "icon": "calendar"
                            },
                            {
                              "type": "stat-display",
                              "icon": "phone",
                              "value": "@entity.lastCheckIn",
                              "label": "Last check-in"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "label": "Mark Saved",
                              "variant": "primary",
                              "type": "button",
                              "action": "MARK_SAVED",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "MARK_CHURNED",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "label": "Mark Churned"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_SAVED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Marking saved…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_CHURNED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Marking churned…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "RenewalRisk",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RenewalRiskUpdateFailed",
                        "success": "RenewalRiskUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Updating risk status…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RenewalRiskUpdated",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RenewalRiskUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading renewal risks…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_SAVED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Marking saved…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_CHURNED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Marking churned…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "renewalReminderDaysBefore": {
              "type": "[number]",
              "default": [
                90.0,
                60.0,
                30.0,
                14.0
              ],
              "label": "Renewal reminder days-before",
              "description": "Days before renewalDate to send CSM reminder pings. Declarative; wire via sibling std-reminder-scheduler.",
              "tier": "domain",
              "items": {
                "type": "number"
              }
            },
            "healthScoreThresholdAlert": {
              "type": "number",
              "default": 40.0,
              "label": "Health score threshold",
              "description": "Accounts below this health score auto-promote to high/critical risk. Declarative; wire via sibling std-notify.",
              "tier": "domain"
            },
            "consentTrackingEnabled": {
