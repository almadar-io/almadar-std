{
  "name": "std-renewal-risk",
  "version": "1.0.0",
  "description": "std-renewal-risk — Customer Success renewal risk tracker for upcoming subscriptions with risk level, ARR, and CS action plan.",
  "orbitals": [
    {
      "name": "RenewalRiskOrbital",
      "entity": {
        "name": "RenewalRisk",
        "collection": "renewalrisks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "renewalDate",
            "type": "string",
            "required": true
          },
          {
            "name": "arrAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "riskLevel",
            "type": "string",
            "default": "low",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "reason",
            "type": "string",
            "default": ""
          },
          {
            "name": "mitigationPlan",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "monitoring",
            "values": [
              "monitoring",
              "in-progress",
              "saved",
              "churned"
            ]
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastCheckIn",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RenewalRiskWatch",
          "category": "interaction",
          "linkedEntity": "RenewalRisk",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_SAVED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.renewalDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.arrAmount",
                  "type": "number"
                },
                {
                  "name": "row.riskLevel",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.mitigationPlan",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedCsm",
                  "type": "string"
                },
                {
                  "name": "row.lastCheckIn",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_CHURNED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.renewalDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.arrAmount",
                  "type": "number"
                },
                {
                  "name": "row.riskLevel",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.mitigationPlan",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedCsm",
                  "type": "string"
                },
                {
                  "name": "row.lastCheckIn",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RenewalRiskLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RenewalRisk]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "RenewalRiskLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RenewalRiskLoaded",
                "name": "RenewalRisk loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RenewalRisk]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RenewalRiskLoadFailed",
                "name": "RenewalRisk load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_RISK",
                "name": "Filter Risk",
                "payloadSchema": [
                  {
                    "name": "riskLevel",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_SAVED",
                "name": "Mark Saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_CHURNED",
                "name": "Mark Churned",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading renewal risks…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "RenewalRiskLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "Track Renewal Risk"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "line-chart",
                          "showGrid": true,
                          "data": [
                            {
                              "value": 8.0,
                              "date": "Jan"
                            },
                            {
                              "value": 11.0,
                              "date": "Feb"
                            },
                            {
                              "value": 9.0,
                              "date": "Mar"
                            },
                            {
                              "value": 14.0,
                              "date": "Apr"
                            },
                            {
                              "value": 12.0,
                              "date": "May"
                            }
                          ],
                          "showArea": true
                        },
                        {
                          "title": "Risk Event Chronology",
                          "type": "timeline",
                          "items": [
                            {
                              "status": "completed",
                              "date": "2026-04-01",
                              "id": "flagged",
                              "description": "Account flagged at risk",
                              "title": "Flagged"
                            },
                            {
                              "date": "2026-04-15",
                              "status": "completed",
                              "description": "CSM outreach attempted",
                              "id": "outreach",
                              "title": "Outreach"
                            },
                            {
                              "id": "exec-review",
                              "status": "current",
                              "date": "2026-05-01",
                              "title": "Exec Review",
                              "description": "Escalated to leadership"
                            },
                            {
                              "id": "renewal",
                              "title": "Renewal Date",
                              "status": "upcoming",
                              "description": "Subscription renewal",
                              "date": "2026-06-15"
                            }
                          ],
                          "fields": [
                            {
                              "name": "title",
                              "label": "Milestone"
                            },
                            {
                              "name": "date",
                              "label": "Date"
                            },
                            {
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "name": "description",
                              "label": "Notes"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "variant": "secondary",
                              "label": "View",
                              "event": "VIEW"
                            },
                            {
                              "event": "EDIT",
                              "variant": "secondary",
                              "label": "Edit"
                            },
                            {
                              "event": "MARK_SAVED",
                              "label": "Mark Saved",
                              "variant": "primary"
                            },
                            {
                              "variant": "ghost",
                              "event": "MARK_CHURNED",
                              "label": "Mark Churned"
                            },
                            {
                              "label": "Delete",
                              "event": "REQUEST_DELETE",
                              "variant": "danger"
                            }
                          ],
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Customer",
                              "name": "customerName"
                            },
                            {
                              "name": "renewalDate",
                              "variant": "caption",
                              "label": "Renewal Date"
                            },
                            {
                              "variant": "caption",
                              "name": "arrAmount",
                              "label": "ARR"
                            },
                            {
                              "name": "riskLevel",
                              "label": "Risk",
                              "variant": "badge"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "variant": "caption",
                              "name": "assignedCsm",
                              "label": "CSM"
                            },
                            {
                              "name": "lastCheckIn",
                              "label": "Last Check-In",
                              "variant": "caption"
                            }
                          ],
                          "cols": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RenewalRiskLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.message"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Refreshing renewal risks…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Searching renewal risks…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_RISK",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Filtering renewal risks…"
                        }
                      ],
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_STATUS",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Filtering renewal risks…"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Tracking new renewal risk"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Viewing renewal risk"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Editing renewal risk"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "MARK_SAVED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Renewal saved",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "MARK_CHURNED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "warning",
                      "message": "Customer churned",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "warning",
                      "message": "Delete requested"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Renewal Risk"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RenewalRiskPage",
          "path": "/renewal-risks",
          "traits": [
            {
              "ref": "RenewalRiskWatch"
            }
          ]
        }
      ]
    }
  ]
}