{
  "name": "std-renewal-risk",
  "version": "1.1.0",
  "description": "std-renewal-risk — Customer Success renewal risk tracker. Lists at-risk accounts in `browsing`; opens detail in `viewing_single` with Mark Saved / Mark Churned actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "RenewalRiskOrbital",
      "entity": {
        "name": "RenewalRisk",
        "collection": "renewalrisks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "renewalDate",
            "type": "string",
            "required": true
          },
          {
            "name": "arrAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "riskLevel",
            "type": "string",
            "default": "low",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "reason",
            "type": "string",
            "default": ""
          },
          {
            "name": "mitigationPlan",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "monitoring",
            "values": [
              "monitoring",
              "in-progress",
              "saved",
              "churned"
            ]
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastCheckIn",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RenewalRiskWatch",
          "category": "interaction",
          "linkedEntity": "RenewalRisk",
          "emits": [
            {
              "event": "OPEN_RISK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.renewalDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.arrAmount",
                  "type": "number"
                },
                {
                  "name": "row.riskLevel",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.mitigationPlan",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedCsm",
                  "type": "string"
                },
                {
                  "name": "row.lastCheckIn",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "MARK_SAVED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_CHURNED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RenewalRiskLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RenewalRisk]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "RenewalRiskLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RenewalRiskLoaded",
                "name": "RenewalRisk loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RenewalRisk]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RenewalRiskLoadFailed",
                "name": "RenewalRisk load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RISK",
                "name": "Open Risk",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "RenewalRisk"
                  }
                ]
              },
              {
                "key": "MARK_SAVED",
                "name": "Mark Saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_CHURNED",
                "name": "Mark Churned",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading renewal risks…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RenewalRiskLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "alert-triangle",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "At-risk accounts"
                            },
                            {
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "label": "ARR at risk",
                              "value": "$1.2M"
                            },
                            {
                              "type": "stat-display",
                              "label": "Critical",
                              "icon": "flame",
                              "value": "8"
                            },
                            {
                              "type": "stat-display",
                              "icon": "trending-up",
                              "label": "Save rate",
                              "value": "67%"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RenewalRiskLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.message"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RISK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.customerName",
                    "@payload.row.customerName"
                  ],
                  [
                    "set",
                    "@entity.renewalDate",
                    "@payload.row.renewalDate"
                  ],
                  [
                    "set",
                    "@entity.arrAmount",
                    "@payload.row.arrAmount"
                  ],
                  [
                    "set",
                    "@entity.riskLevel",
                    "@payload.row.riskLevel"
                  ],
                  [
                    "set",
                    "@entity.reason",
                    "@payload.row.reason"
                  ],
                  [
                    "set",
                    "@entity.mitigationPlan",
                    "@payload.row.mitigationPlan"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.assignedCsm",
                    "@payload.row.assignedCsm"
                  ],
                  [
                    "set",
                    "@entity.lastCheckIn",
                    "@payload.row.lastCheckIn"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.customerName",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "danger",
                              "type": "badge",
                              "label": "@entity.riskLevel"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Reason",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.reason",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "content": "Mitigation plan",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.mitigationPlan"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "CSM",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.assignedCsm",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "value": "@entity.arrAmount",
                              "type": "stat-display",
                              "label": "ARR",
                              "icon": "dollar-sign"
                            },
                            {
                              "type": "stat-display",
                              "label": "Renewal",
                              "value": "@entity.renewalDate",
                              "icon": "calendar"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.lastCheckIn",
                              "icon": "phone",
                              "label": "Last check-in"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Mark Saved",
                              "action": "MARK_SAVED",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "label": "Mark Churned",
                              "type": "button",
                              "action": "MARK_CHURNED",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_SAVED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Marking saved…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_CHURNED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Marking churned…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading renewal risks…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_SAVED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Marking saved…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_CHURNED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "failure": "RenewalRiskLoadFailed",
                        "success": "RenewalRiskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Marking churned…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RenewalRisk",
                    {
                      "emit": {
                        "success": "RenewalRiskLoaded",
                        "failure": "RenewalRiskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_RISK",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "variant": "danger",
                  "label": "Mark Churned",
                  "event": "MARK_CHURNED"
                }
              ]
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Customer",
                  "name": "customerName"
                },
                {
                  "label": "Renewal",
                  "variant": "caption",
                  "name": "renewalDate"
                },
                {
                  "label": "ARR",
                  "variant": "caption",
                  "name": "arrAmount"
                },
                {
                  "label": "Risk",
                  "name": "riskLevel",
                  "variant": "badge"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "variant": "caption",
                  "label": "CSM",
                  "name": "assignedCsm"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Renewal Risk"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RenewalRiskPage",
          "path": "/renewal-risks",
          "traits": [
            {
              "ref": "RenewalRiskWatch"
            }
          ]
        }
      ]
    }
  ]
}
