{
  "name": "std-chart-of-accounts",
  "version": "1.0.0",
  "description": "std-chart-of-accounts — list of all accounts (asset, liability, equity, revenue, expense) that ledger entries post against. Owns an Account entity and a single chart trait that loads accounts, renders them in a data-grid, and surfaces Activate / Deactivate per row.",
  "orbitals": [
    {
      "name": "ChartOfAccountsOrbital",
      "entity": {
        "name": "Account",
        "collection": "accounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "type",
            "type": "string",
            "default": "asset",
            "values": [
              "asset",
              "liability",
              "equity",
              "revenue",
              "expense"
            ]
          },
          {
            "name": "parentCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "balance",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AccountChart",
          "category": "interaction",
          "linkedEntity": "Account",
          "emits": [
            {
              "event": "ACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DEACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Account]"
                }
              ]
            },
            {
              "event": "AccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AccountLoaded",
                "name": "Account loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Account]"
                  }
                ]
              },
              {
                "key": "AccountLoadFailed",
                "name": "Account load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ACTIVATE_ACCOUNT",
                "name": "Activate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DEACTIVATE_ACCOUNT",
                "name": "Deactivate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading accounts…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "chart-legend",
                          "items": [
                            {
                              "label": "Assets",
                              "color": "primary"
                            },
                            {
                              "label": "Liabilities",
                              "color": "warning"
                            },
                            {
                              "color": "secondary",
                              "label": "Equity"
                            },
                            {
                              "color": "success",
                              "label": "Revenue"
                            },
                            {
                              "color": "destructive",
                              "label": "Expense"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "items": [
                            {
                              "title": "Assets",
                              "id": "assets",
                              "content": "Current assets, fixed assets, and other resources owned."
                            },
                            {
                              "id": "liabilities",
                              "title": "Liabilities",
                              "content": "Accounts payable, loans, and other obligations."
                            },
                            {
                              "content": "Owner capital, retained earnings, and contributions.",
                              "id": "equity",
                              "title": "Equity"
                            },
                            {
                              "content": "Operating income from sales and services.",
                              "id": "revenue",
                              "title": "Revenue"
                            },
                            {
                              "title": "Expense",
                              "content": "Operating costs, depreciation, and write-offs.",
                              "id": "expense"
                            }
                          ],
                          "multiple": true,
                          "type": "accordion"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "icon": "check-circle",
                              "variant": "primary",
                              "label": "Activate",
                              "event": "ACTIVATE_ACCOUNT"
                            },
                            {
                              "label": "Deactivate",
                              "variant": "danger",
                              "icon": "x-circle",
                              "event": "DEACTIVATE_ACCOUNT"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Code",
                              "name": "code"
                            },
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Type",
                              "name": "type",
                              "variant": "caption"
                            },
                            {
                              "label": "Parent",
                              "name": "parentCode",
                              "variant": "caption"
                            },
                            {
                              "label": "Balance",
                              "variant": "caption",
                              "name": "balance"
                            },
                            {
                              "label": "Active",
                              "name": "isActive",
                              "variant": "caption"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Account activated",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DEACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Account deactivated"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "failure": "AccountLoadFailed",
                        "success": "AccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Chart of Accounts"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AccountPage",
          "path": "/accounts",
          "traits": [
            {
              "ref": "AccountChart"
            }
          ]
        }
      ]
    }
  ]
}