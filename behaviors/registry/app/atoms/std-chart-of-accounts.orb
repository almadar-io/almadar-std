{
  "name": "std-chart-of-accounts",
  "version": "1.1.0",
  "description": "std-chart-of-accounts — list of all accounts (asset, liability, equity, revenue, expense) that ledger entries post against. Lists accounts in `browsing`; opens detail in `viewing_single` with Activate / Deactivate actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ChartOfAccountsOrbital",
      "entity": {
        "name": "Account",
        "collection": "accounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "type",
            "type": "string",
            "default": "asset",
            "values": [
              "asset",
              "liability",
              "equity",
              "revenue",
              "expense"
            ]
          },
          {
            "name": "parentCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "balance",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AccountChart",
          "category": "interaction",
          "linkedEntity": "Account",
          "emits": [
            {
              "event": "OPEN_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.code",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.type",
                  "type": "string"
                },
                {
                  "name": "row.parentCode",
                  "type": "string"
                },
                {
                  "name": "row.isActive",
                  "type": "boolean"
                },
                {
                  "name": "row.balance",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DEACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Account]"
                }
              ]
            },
            {
              "event": "AccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AccountLoaded",
                "name": "Account loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Account]"
                  }
                ]
              },
              {
                "key": "AccountLoadFailed",
                "name": "Account load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ACCOUNT",
                "name": "Open Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Account"
                  }
                ]
              },
              {
                "key": "DEACTIVATE_ACCOUNT",
                "name": "Deactivate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ACTIVATE_ACCOUNT",
                "name": "Activate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading accounts…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "book-open",
                              "label": "Total accounts"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Active",
                              "type": "stat-display",
                              "value": "118"
                            },
                            {
                              "label": "Assets balance",
                              "type": "stat-display",
                              "icon": "trending-up",
                              "value": "$2.4M"
                            },
                            {
                              "type": "stat-display",
                              "label": "Liabilities",
                              "icon": "trending-down",
                              "value": "$840K"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.code",
                    "@payload.row.code"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.type",
                    "@payload.row.type"
                  ],
                  [
                    "set",
                    "@entity.parentCode",
                    "@payload.row.parentCode"
                  ],
                  [
                    "set",
                    "@entity.isActive",
                    "@payload.row.isActive"
                  ],
                  [
                    "set",
                    "@entity.balance",
                    "@payload.row.balance"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.type",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Code",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.code",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Parent",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.parentCode",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.balance",
                              "type": "stat-display",
                              "label": "Balance",
                              "icon": "dollar-sign"
                            },
                            {
                              "label": "Type",
                              "value": "@entity.type",
                              "type": "stat-display",
                              "icon": "tag"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Activate",
                              "variant": "primary",
                              "action": "ACTIVATE_ACCOUNT",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "label": "Deactivate",
                              "action": "DEACTIVATE_ACCOUNT",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DEACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Deactivating account…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "failure": "AccountLoadFailed",
                        "success": "AccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading accounts…"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "failure": "AccountLoadFailed",
                        "success": "AccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Activating account…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DEACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Deactivating account…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Chart of Accounts"
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_ACCOUNT",
                  "variant": "primary"
                },
                {
                  "event": "DEACTIVATE_ACCOUNT",
                  "variant": "danger",
                  "label": "Deactivate"
                }
              ]
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "code",
                  "variant": "caption",
                  "label": "Code"
                },
                {
                  "label": "Name",
                  "variant": "caption",
                  "name": "name"
                },
                {
                  "name": "type",
                  "label": "Type",
                  "variant": "badge"
                },
                {
                  "label": "Parent",
                  "variant": "caption",
                  "name": "parentCode"
                },
                {
                  "label": "Balance",
                  "name": "balance",
                  "variant": "caption"
                }
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AccountPage",
          "path": "/accounts",
          "traits": [
            {
              "ref": "AccountChart"
            }
          ]
        }
      ]
    }
  ]
}
