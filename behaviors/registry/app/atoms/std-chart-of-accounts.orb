{
  "name": "std-chart-of-accounts",
  "version": "1.2.0",
  "description": "std-chart-of-accounts — accounts catalog (asset/liability/equity/revenue/expense) with Activate / Deactivate actions. Exposes Financial-pattern knobs (currency, jurisdiction, retention).",
  "orbitals": [
    {
      "name": "ChartOfAccountsOrbital",
      "entity": {
        "name": "Account",
        "collection": "accounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "type",
            "type": "string",
            "default": "asset",
            "values": [
              "asset",
              "liability",
              "equity",
              "revenue",
              "expense"
            ]
          },
          {
            "name": "parentCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "balance",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "AccountChart",
          "category": "interaction",
          "linkedEntity": "Account",
          "emits": [
            {
              "event": "OPEN_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.code",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.type",
                  "type": "string"
                },
                {
                  "name": "row.parentCode",
                  "type": "string"
                },
                {
                  "name": "row.isActive",
                  "type": "boolean"
                },
                {
                  "name": "row.balance",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DEACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Account]"
                }
              ]
            },
            {
              "event": "AccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AccountLoaded",
                "name": "Account loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Account]"
                  }
                ]
              },
              {
                "key": "AccountLoadFailed",
                "name": "Account load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ACCOUNT",
                "name": "Open Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Account"
                  }
                ]
              },
              {
                "key": "DEACTIVATE_ACCOUNT",
                "name": "Deactivate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ACTIVATE_ACCOUNT",
                "name": "Activate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading accounts…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "book-open",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total accounts"
                            },
                            {
                              "label": "Active",
                              "type": "stat-display",
                              "value": "118",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "icon": "trending-up",
                              "value": "$2.4M",
                              "label": "Assets balance"
                            },
                            {
                              "label": "Liabilities",
                              "type": "stat-display",
                              "icon": "trending-down",
                              "value": "$840K"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "gap": "sm",
                          "type": "data-grid",
                          "cols": 1.0
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.code",
                    "@payload.row.code"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.type",
                    "@payload.row.type"
                  ],
                  [
                    "set",
                    "@entity.parentCode",
                    "@payload.row.parentCode"
                  ],
                  [
                    "set",
                    "@entity.isActive",
                    "@payload.row.isActive"
                  ],
                  [
                    "set",
                    "@entity.balance",
                    "@payload.row.balance"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.type"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Code",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.code"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Parent"
                                },
                                {
                                  "content": "@entity.parentCode",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "value": "@entity.balance",
                              "label": "Balance"
                            },
                            {
                              "label": "Type",
                              "type": "stat-display",
                              "value": "@entity.type",
                              "icon": "tag"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "ACTIVATE_ACCOUNT",
                              "label": "Activate",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            },
                            {
                              "variant": "danger",
                              "action": "DEACTIVATE_ACCOUNT",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Deactivate"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DEACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Deactivating account…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "failure": "AccountLoadFailed",
                        "success": "AccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading accounts…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Activating account…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DEACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Deactivating account…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "failure": "AccountLoadFailed",
                        "success": "AccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "currency": {
              "type": "string",
              "default": "USD",
              "label": "Default currency",
              "description": "ISO 4217 currency code (USD, EUR, GBP, …) for account balances.",
              "tier": "essential"
            },
            "lateFeeAmount": {
              "type": "number",
              "default": 0.0,
              "label": "Late fee amount",
              "description": "Flat cash amount or percentage (per lateFeePolicy).",
              "tier": "customization"
            },
            "gracePeriodDays": {
              "type": "number",
              "default": 0.0,
              "label": "Grace period (days)",
              "description": "Days a deactivated account may continue to accept postings. Declarative.",
              "tier": "customization"
            },
            "complianceJurisdiction": {
              "type": "string",
              "default": "",
              "label": "Compliance jurisdiction",
              "description": "Drives chart structure + retention per locale: 'US-GAAP', 'EU-IFRS', 'UK-FRS', etc. Declarative.",
              "tier": "advanced"
            },
            "roundingMode": {
              "type": "string",
              "default": "bankers",
              "label": "Rounding mode",
              "description": "Sub-cent rounding behavior for ledger postings.",
              "tier": "advanced",
              "values": [
                "bankers",
                "half-up",
                "down"
              ]
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "code",
                  "label": "Code",
                  "variant": "caption"
                },
                {
                  "name": "name",
                  "label": "Name",
                  "variant": "caption"
                },
                {
                  "name": "type",
                  "variant": "badge",
                  "label": "Type"
                },
                {
                  "name": "parentCode",
                  "label": "Parent",
                  "variant": "caption"
                },
                {
                  "name": "balance",
                  "variant": "caption",
                  "label": "Balance"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Account entity",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "taxStrategy": {
              "type": "string",
              "default": "none",
              "label": "Tax strategy",
              "description": "How tax-related accounts treat their balances. inclusive/exclusive/none.",
              "tier": "customization",
              "values": [
                "inclusive",
                "exclusive",
                "none"
              ]
            },
            "lateFeePolicy": {
              "type": "string",
              "default": "none",
              "label": "Late fee policy",
              "description": "Per-account late fee policy (rarely used on COA). Declarative; wiring deferred.",
              "tier": "customization",
              "values": [
                "none",
                "flat",
                "percent"
              ]
            },
            "retentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Retention (years)",
              "description": "Years to keep account records for compliance.",
              "tier": "advanced"
            },
            "title": {
              "type": "string",
              "default": "Chart of Accounts",
              "label": "Section title",
              "description": "Heading shown above the accounts list",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_ACCOUNT",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "label": "Deactivate",
                  "event": "DEACTIVATE_ACCOUNT",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each account row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AccountPage",
          "path": "/accounts",
          "traits": [
            {
              "ref": "AccountChart"
            }
          ]
        }
      ]
    }
  ]
}