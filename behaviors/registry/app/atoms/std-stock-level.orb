{
  "name": "std-stock-level",
  "version": "1.1.0",
  "description": "std-stock-level — on-hand quantity primitive for a SKU at a location. Lists stock rows in `browsing`; opens row detail in `viewing_single` with Adjust / Recount actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "StockLevelOrbital",
      "entity": {
        "name": "StockLevel",
        "collection": "stocklevels",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "required": true
          },
          {
            "name": "productName",
            "type": "string",
            "default": ""
          },
          {
            "name": "locationId",
            "type": "string",
            "default": ""
          },
          {
            "name": "onHand",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reserved",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reorderPoint",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastCounted",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "StockLevelLedger",
          "category": "interaction",
          "linkedEntity": "StockLevel",
          "emits": [
            {
              "event": "OPEN_STOCK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sku",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.productName",
                  "type": "string"
                },
                {
                  "name": "row.locationId",
                  "type": "string"
                },
                {
                  "name": "row.onHand",
                  "type": "number"
                },
                {
                  "name": "row.reserved",
                  "type": "number"
                },
                {
                  "name": "row.reorderPoint",
                  "type": "number"
                },
                {
                  "name": "row.lastCounted",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ADJUST_STOCK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RECOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "StockLevelLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StockLevel]"
                }
              ]
            },
            {
              "event": "StockLevelLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StockLevelLoaded",
                "name": "StockLevel loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StockLevel]"
                  }
                ]
              },
              {
                "key": "StockLevelLoadFailed",
                "name": "StockLevel load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_STOCK",
                "name": "Open Stock",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "StockLevel"
                  }
                ]
              },
              {
                "key": "ADJUST_STOCK",
                "name": "Adjust Stock",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RECOUNT",
                "name": "Recount",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "success": "StockLevelLoaded",
                        "failure": "StockLevelLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading stock levels…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StockLevelLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "package"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "package",
                              "label": "Total SKUs",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "alert-triangle",
                              "label": "Below reorder",
                              "value": "12",
                              "type": "stat-display"
                            },
                            {
                              "label": "Total on hand",
                              "icon": "boxes",
                              "value": "8,420",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Reserved",
                              "value": "1,260",
                              "icon": "lock"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StockLevelLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_STOCK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.sku",
                    "@payload.row.sku"
                  ],
                  [
                    "set",
                    "@entity.productName",
                    "@payload.row.productName"
                  ],
                  [
                    "set",
                    "@entity.locationId",
                    "@payload.row.locationId"
                  ],
                  [
                    "set",
                    "@entity.onHand",
                    "@payload.row.onHand"
                  ],
                  [
                    "set",
                    "@entity.reserved",
                    "@payload.row.reserved"
                  ],
                  [
                    "set",
                    "@entity.reorderPoint",
                    "@payload.row.reorderPoint"
                  ],
                  [
                    "set",
                    "@entity.lastCounted",
                    "@payload.row.lastCounted"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "package",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.productName"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.sku",
                              "variant": "primary"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Location",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.locationId",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Last counted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.lastCounted",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "boxes",
                              "type": "stat-display",
                              "value": "@entity.onHand",
                              "label": "On hand"
                            },
                            {
                              "label": "Reserved",
                              "type": "stat-display",
                              "value": "@entity.reserved",
                              "icon": "lock"
                            },
                            {
                              "value": "@entity.reorderPoint",
                              "label": "Reorder at",
                              "icon": "alert-triangle",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "action": "ADJUST_STOCK",
                              "type": "button",
                              "label": "Adjust",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Recount",
                              "variant": "secondary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "RECOUNT"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ADJUST_STOCK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "success": "StockLevelLoaded",
                        "failure": "StockLevelLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Adjusting stock…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RECOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "success": "StockLevelLoaded",
                        "failure": "StockLevelLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Recounting stock…"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "success": "StockLevelLoaded",
                        "failure": "StockLevelLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading stock levels…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ADJUST_STOCK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "success": "StockLevelLoaded",
                        "failure": "StockLevelLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Adjusting stock…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RECOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "failure": "StockLevelLoadFailed",
                        "success": "StockLevelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Recounting stock…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "failure": "StockLevelLoadFailed",
                        "success": "StockLevelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "label": "Open",
                  "event": "OPEN_STOCK",
                  "variant": "primary"
                },
                {
                  "label": "Adjust",
                  "variant": "danger",
                  "event": "ADJUST_STOCK"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each SKU row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Stock Levels",
              "label": "Section title",
              "description": "Heading shown above the inventory stock list",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "sku",
                  "label": "SKU"
                },
                {
                  "name": "productName",
                  "label": "Product",
                  "variant": "caption"
                },
                {
                  "label": "Location",
                  "variant": "caption",
                  "name": "locationId"
                },
                {
                  "name": "onHand",
                  "label": "On Hand",
                  "variant": "caption"
                },
                {
                  "label": "Reorder At",
                  "variant": "caption",
                  "name": "reorderPoint"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Stock Level entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "StockLevelPage",
          "path": "/stock",
          "traits": [
            {
              "ref": "StockLevelLedger"
            }
          ]
        }
      ]
    }
  ]
}
