{
  "name": "std-stock-level",
  "version": "1.0.0",
  "description": "std-stock-level — on-hand quantity primitive for a SKU at a location. Owns a StockLevel entity and a single ledger trait that loads current levels, renders them in a data-grid, and surfaces Adjust / Recount actions per row.",
  "orbitals": [
    {
      "name": "StockLevelOrbital",
      "entity": {
        "name": "StockLevel",
        "collection": "stocklevels",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "required": true
          },
          {
            "name": "productName",
            "type": "string",
            "default": ""
          },
          {
            "name": "locationId",
            "type": "string",
            "default": ""
          },
          {
            "name": "onHand",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reserved",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reorderPoint",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastCounted",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "StockLevelLedger",
          "category": "interaction",
          "linkedEntity": "StockLevel",
          "emits": [
            {
              "event": "ADJUST_STOCK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RECOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "StockLevelLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StockLevel]"
                }
              ]
            },
            {
              "event": "StockLevelLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StockLevelLoaded",
                "name": "StockLevel loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StockLevel]"
                  }
                ]
              },
              {
                "key": "StockLevelLoadFailed",
                "name": "StockLevel load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADJUST_STOCK",
                "name": "Adjust Stock",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RECOUNT",
                "name": "Recount",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "failure": "StockLevelLoadFailed",
                        "success": "StockLevelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading stock levels…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StockLevelLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "package"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "items": [
                            {
                              "src": "https://picsum.photos/seed/sku1/800/400",
                              "alt": "Featured SKU 1"
                            },
                            {
                              "src": "https://picsum.photos/seed/sku2/800/400",
                              "alt": "Featured SKU 2"
                            },
                            {
                              "alt": "Featured SKU 3",
                              "src": "https://picsum.photos/seed/sku3/800/400"
                            }
                          ],
                          "type": "carousel",
                          "showDots": true,
                          "showArrows": true,
                          "autoPlayInterval": 5000.0,
                          "autoPlay": true,
                          "loop": true
                        },
                        {
                          "variant": "primary",
                          "tags": [
                            {
                              "label": "Electronics"
                            },
                            {
                              "label": "Apparel"
                            },
                            {
                              "label": "Home Goods"
                            },
                            {
                              "label": "Grocery"
                            },
                            {
                              "label": "Outdoor"
                            },
                            {
                              "label": "Books"
                            }
                          ],
                          "type": "tag-cloud"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total SKUs",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "label": "Reorder Threshold",
                              "value": 0.0
                            },
                            {
                              "type": "stat-display",
                              "label": "On Hand",
                              "value": 0.0
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "sku",
                              "variant": "caption",
                              "label": "SKU"
                            },
                            {
                              "name": "productName",
                              "label": "Product",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "locationId",
                              "label": "Location"
                            },
                            {
                              "name": "onHand",
                              "label": "On Hand",
                              "variant": "caption"
                            },
                            {
                              "name": "reorderPoint",
                              "label": "Reorder At",
                              "variant": "caption"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "ADJUST_STOCK",
                              "icon": "sliders",
                              "label": "Adjust",
                              "variant": "primary"
                            },
                            {
                              "variant": "ghost",
                              "icon": "clipboard-check",
                              "event": "RECOUNT",
                              "label": "Recount"
                            }
                          ]
                        },
                        {
                          "hasMore": true,
                          "threshold": "200px",
                          "isLoading": false,
                          "type": "infinite-scroll-sentinel",
                          "loadMoreEvent": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StockLevelLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ADJUST_STOCK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Stock adjustment requested",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RECOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Recount scheduled",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockLevel",
                    {
                      "emit": {
                        "failure": "StockLevelLoadFailed",
                        "success": "StockLevelLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Stock Levels"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "StockLevelPage",
          "path": "/stock",
          "traits": [
            {
              "ref": "StockLevelLedger"
            }
          ]
        }
      ]
    }
  ]
}