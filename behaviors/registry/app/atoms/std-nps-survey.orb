{
  "name": "std-nps-survey",
  "version": "1.1.0",
  "description": "std-nps-survey — NPS survey primitive tracking per-customer Net Promoter Score responses with category, comment, and follow-up status. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "NpsSurveyOrbital",
      "entity": {
        "name": "NpsSurvey",
        "collection": "npssurveys",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "score",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "category",
            "type": "string",
            "default": "passive",
            "values": [
              "promoter",
              "passive",
              "detractor"
            ]
          },
          {
            "name": "comment",
            "type": "string",
            "default": ""
          },
          {
            "name": "surveyedAt",
            "type": "string",
            "required": true
          },
          {
            "name": "channel",
            "type": "string",
            "default": "email",
            "values": [
              "email",
              "in-app",
              "sms",
              "phone"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "sent",
            "values": [
              "sent",
              "responded",
              "expired",
              "no-response"
            ]
          },
          {
            "name": "followedUp",
            "type": "boolean",
            "default": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "NpsSurveyTracker",
          "category": "interaction",
          "linkedEntity": "NpsSurvey",
          "emits": [
            {
              "event": "OPEN_SURVEY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string"
                },
                {
                  "name": "row.score",
                  "type": "number"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.surveyedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.channel",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.followedUp",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "MARK_FOLLOWED_UP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "NpsSurveyLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[NpsSurvey]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "NpsSurveyLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NpsSurveyLoaded",
                "name": "NpsSurvey loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[NpsSurvey]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "NpsSurveyLoadFailed",
                "name": "NpsSurvey load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SURVEY",
                "name": "Open Survey",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "NpsSurvey"
                  }
                ]
              },
              {
                "key": "MARK_FOLLOWED_UP",
                "name": "Mark Followed Up",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "failure": "NpsSurveyLoadFailed",
                        "success": "NpsSurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading NPS surveys…"
                        }
                      ],
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "NpsSurveyLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "message-square",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "message-square",
                              "label": "Total surveys",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "label": "Promoters",
                              "icon": "thumbs-up",
                              "type": "stat-display",
                              "value": "412"
                            },
                            {
                              "label": "Detractors",
                              "type": "stat-display",
                              "value": "84",
                              "icon": "thumbs-down"
                            },
                            {
                              "label": "Avg NPS",
                              "value": "47",
                              "type": "stat-display",
                              "icon": "trending-up"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "NpsSurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SURVEY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.customerName",
                    "@payload.row.customerName"
                  ],
                  [
                    "set",
                    "@entity.score",
                    "@payload.row.score"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.comment",
                    "@payload.row.comment"
                  ],
                  [
                    "set",
                    "@entity.surveyedAt",
                    "@payload.row.surveyedAt"
                  ],
                  [
                    "set",
                    "@entity.channel",
                    "@payload.row.channel"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.followedUp",
                    "@payload.row.followedUp"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "message-square"
                            },
                            {
                              "content": "@entity.customerName",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.category"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Customer ID"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.customerId"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Comment",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.comment",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "star",
                              "value": "@entity.score",
                              "type": "stat-display",
                              "label": "Score"
                            },
                            {
                              "icon": "calendar",
                              "value": "@entity.surveyedAt",
                              "label": "Surveyed",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Channel",
                              "value": "@entity.channel",
                              "icon": "send"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Mark Followed Up",
                              "type": "button",
                              "variant": "primary",
                              "action": "MARK_FOLLOWED_UP"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_FOLLOWED_UP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "success": "NpsSurveyLoaded",
                        "failure": "NpsSurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Marking survey followed up…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "success": "NpsSurveyLoaded",
                        "failure": "NpsSurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading NPS surveys…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_FOLLOWED_UP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "success": "NpsSurveyLoaded",
                        "failure": "NpsSurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Marking survey followed up…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "failure": "NpsSurveyLoadFailed",
                        "success": "NpsSurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_SURVEY",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "label": "Mark Followed Up",
                  "variant": "danger",
                  "event": "MARK_FOLLOWED_UP"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "NPS Surveys"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "name": "customerName",
                  "label": "Customer"
                },
                {
                  "label": "Score",
                  "name": "score",
                  "variant": "caption"
                },
                {
                  "label": "Category",
                  "variant": "badge",
                  "name": "category"
                },
                {
                  "variant": "caption",
                  "label": "Surveyed",
                  "name": "surveyedAt"
                },
                {
                  "label": "Channel",
                  "variant": "caption",
                  "name": "channel"
                },
                {
                  "variant": "badge",
                  "label": "Status",
                  "name": "status"
                }
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "NpsSurveyPage",
          "path": "/nps-surveys",
          "traits": [
            {
              "ref": "NpsSurveyTracker"
            }
          ]
        }
      ]
    }
  ]
}
