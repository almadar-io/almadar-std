{
  "name": "std-event",
  "version": "1.2.0",
  "description": "std-event — event-ticketing event entity. Listens for SET_STATUS so sibling std-lifecycle can auto-transition. Exposes Scheduling/Booking knobs (bookingWindowDays, leadTimeMinutes, cancellationPolicy, …).",
  "orbitals": [
    {
      "name": "EventOrbital",
      "entity": {
        "name": "EventRecord",
        "collection": "events",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "venue",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "startsAt",
            "type": "string",
            "required": true
          },
          {
            "name": "endsAt",
            "type": "string",
            "required": true
          },
          {
            "name": "recurrenceRule",
            "type": "string"
          },
          {
            "name": "capacity",
            "type": "number"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "sold-out",
              "cancelled"
            ]
          },
          {
            "name": "organizerId",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "EventManage",
          "category": "interaction",
          "linkedEntity": "EventRecord",
          "emits": [
            {
              "event": "OPEN_EVENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.venue",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.startsAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.endsAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.recurrenceRule",
                  "type": "string"
                },
                {
                  "name": "row.capacity",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.organizerId",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "eventId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "eventId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "eventId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EventLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[EventRecord]"
                }
              ]
            },
            {
              "event": "EventLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EventLoaded",
                "name": "Event loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[EventRecord]"
                  }
                ]
              },
              {
                "key": "EventLoadFailed",
                "name": "Event load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_EVENT",
                "name": "Open Event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "EventRecord"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "eventId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "eventId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "eventId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "failure": "EventLoadFailed",
                        "success": "EventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading events…"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "EventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "calendar"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "calendar",
                              "value": "@payload.data.length",
                              "label": "Total events"
                            },
                            {
                              "icon": "check-circle",
                              "type": "stat-display",
                              "value": "28",
                              "label": "Published"
                            },
                            {
                              "value": "4,820",
                              "label": "Tickets sold",
                              "icon": "ticket",
                              "type": "stat-display"
                            },
                            {
                              "icon": "alert-circle",
                              "label": "Sold-out",
                              "type": "stat-display",
                              "value": "6"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "EventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_EVENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.venue",
                    "@payload.row.venue"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.row.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.row.lng"
                  ],
                  [
                    "set",
                    "@entity.startsAt",
                    "@payload.row.startsAt"
                  ],
                  [
                    "set",
                    "@entity.endsAt",
                    "@payload.row.endsAt"
                  ],
                  [
                    "set",
                    "@entity.recurrenceRule",
                    "@payload.row.recurrenceRule"
                  ],
                  [
                    "set",
                    "@entity.capacity",
                    "@payload.row.capacity"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.organizerId",
                    "@payload.row.organizerId"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button"
                            },
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.status",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Venue"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.venue",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Description"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.description"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Organizer",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.organizerId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Recurrence"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.recurrenceRule",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Starts",
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.startsAt"
                            },
                            {
                              "label": "Ends",
                              "value": "@entity.endsAt",
                              "type": "stat-display",
                              "icon": "calendar-check"
                            },
                            {
                              "label": "Capacity",
                              "value": "@entity.capacity",
                              "type": "stat-display",
                              "icon": "users"
                            },
                            {
                              "icon": "clock",
                              "label": "Created",
                              "type": "stat-display",
                              "value": "@entity.createdAt"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Publish",
                              "action": "PUBLISH",
                              "variant": "primary",
                              "actionPayload": {
                                "eventId": "@entity.id",
                                "id": "@entity.id"
                              }
                            },
                            {
                              "variant": "secondary",
                              "actionPayload": {
                                "eventId": "@entity.id",
                                "id": "@entity.id"
                              },
                              "label": "Update",
                              "action": "UPDATE",
                              "type": "button"
                            },
                            {
                              "action": "CANCEL",
                              "actionPayload": {
                                "eventId": "@entity.id",
                                "id": "@entity.id"
                              },
                              "label": "Cancel",
                              "variant": "danger",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.eventId"
                  ],
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "failure": "EventLoadFailed",
                        "success": "EventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling event…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "EventRecord",
                    "@entity",
                    {
                      "emit": {
                        "failure": "EventLoadFailed",
                        "success": "EventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Updating event status…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "success": "EventLoaded",
                        "failure": "EventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading events…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.eventId"
                  ],
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "success": "EventLoaded",
                        "failure": "EventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Publishing event…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.eventId"
                  ],
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "failure": "EventLoadFailed",
                        "success": "EventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Updating event…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.eventId"
                  ],
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "failure": "EventLoadFailed",
                        "success": "EventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Cancelling event…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EventRecord",
                    {
                      "emit": {
                        "success": "EventLoaded",
                        "failure": "EventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_EVENT",
                  "variant": "primary",
                  "icon": "arrow-right",
                  "label": "Open"
                },
                {
                  "event": "CANCEL",
                  "variant": "danger",
                  "icon": "x",
                  "label": "Cancel"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each event row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "bookingWindowDays": {
              "type": "number",
              "default": 180.0,
              "label": "Booking window (days)",
              "description": "How far in advance attendees can purchase tickets.",
              "tier": "customization"
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 48.0,
              "label": "Reschedule window (hours)",
              "description": "Hours before startsAt during which attendees can self-reschedule.",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "name",
                  "label": "Name",
                  "variant": "caption"
                },
                {
                  "label": "Venue",
                  "variant": "caption",
                  "name": "venue"
                },
                {
                  "name": "startsAt",
                  "label": "Starts",
                  "variant": "caption"
                },
                {
                  "name": "endsAt",
                  "label": "Ends",
                  "variant": "caption"
                },
                {
                  "name": "capacity",
                  "label": "Capacity",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Event entity",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
