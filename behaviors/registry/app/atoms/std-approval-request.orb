{
  "name": "std-approval-request",
  "version": "1.3.0",
  "description": "std-approval-request — approver inbox / triage queue. Browses many pending approval requests in a list (data-grid), opens one at a time for detail with Approve / Reject / Request Info / Withdraw. Pick this when the user is an approver working through a queue. For single-item N-step sequential approval (manager → finance → exec on ONE item), use std-approval-chain instead. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ApprovalRequestOrbital",
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approvalrequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "default": "timesheet",
            "values": [
              "timesheet",
              "expense-report",
              "pto-request",
              "purchase-order",
              "change-order",
              "other"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "requestedBy",
            "type": "string",
            "required": true
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedApprover",
            "type": "string",
            "default": ""
          },
          {
            "name": "approverDecision",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "approved",
              "rejected",
              "needs-info"
            ]
          },
          {
            "name": "decidedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "comment",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected",
              "withdrawn"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApprovalRequestPipeline",
          "category": "interaction",
          "linkedEntity": "ApprovalRequest",
          "emits": [
            {
              "event": "OPEN_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedBy",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedApprover",
                  "type": "string"
                },
                {
                  "name": "row.approverDecision",
                  "type": "string"
                },
                {
                  "name": "row.decidedAt",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_REQUEST"
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REQUEST_INFO",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WITHDRAW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_COMMENT",
              "payloadSchema": [
                {
                  "name": "comment",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUBMIT_REJECTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "comment",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_REJECTION"
            },
            {
              "event": "ApprovalRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApprovalRequest]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "rejecting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_REQUEST",
                "name": "Open Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "WITHDRAW",
                "name": "Withdraw",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_REQUEST",
                "name": "Close Request"
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_INFO",
                "name": "Request Info",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_COMMENT",
                "name": "Edit Comment",
                "payloadSchema": [
                  {
                    "name": "comment",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT_REJECTION",
                "name": "Submit Rejection",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "comment",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL_REJECTION",
                "name": "Cancel Rejection"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading approval requests…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "check-circle",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "label": "Total requests",
                              "icon": "inbox",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "value": "14",
                              "label": "Pending",
                              "type": "stat-display",
                              "icon": "clock"
                            },
                            {
                              "type": "stat-display",
                              "label": "Approved",
                              "value": "82%",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "value": "1.4 days",
                              "icon": "timer",
                              "label": "Avg cycle"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.message",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    "@payload.row.targetType"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.row.targetId"
                  ],
                  [
                    "set",
                    "@entity.requestedBy",
                    "@payload.row.requestedBy"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "@payload.row.requestedAt"
                  ],
                  [
                    "set",
                    "@entity.assignedApprover",
                    "@payload.row.assignedApprover"
                  ],
                  [
                    "set",
                    "@entity.approverDecision",
                    "@payload.row.approverDecision"
                  ],
                  [
                    "set",
                    "@entity.decidedAt",
                    "@payload.row.decidedAt"
                  ],
                  [
                    "set",
                    "@entity.comment",
                    "@payload.row.comment"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_REQUEST",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "name": "check-circle",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.title"
                            },
                            {
                              "variant": "default",
                              "label": "@entity.status",
                              "type": "badge"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.approverDecision"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Target",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.targetType",
                                  "type": "typography",
                                  "variant": "body"
                                },
                                {
                                  "content": "@entity.targetId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Requested by",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.requestedBy"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Approver",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.assignedApprover"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Comment",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.comment",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Requested at",
                              "type": "stat-display",
                              "value": "@entity.requestedAt",
                              "icon": "calendar"
                            },
                            {
                              "icon": "calendar-check",
                              "type": "stat-display",
                              "label": "Decided at",
                              "value": "@entity.decidedAt"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "APPROVE",
                              "label": "Approve",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Reject",
                              "type": "button",
                              "action": "REJECT",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger"
                            },
                            {
                              "variant": "secondary",
                              "action": "REQUEST_INFO",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Request Info"
                            },
                            {
                              "variant": "ghost",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Withdraw",
                              "action": "WITHDRAW",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Withdrawing request…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_REQUEST",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading approval requests…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Recording approval…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "guard": [
                  "=",
                  "@config.requireCommentOnReject",
                  false
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Recording rejection…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "rejecting",
                "event": "REJECT",
                "guard": [
                  "=",
                  "@config.requireCommentOnReject",
                  true
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.comment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "x-circle"
                            },
                            {
                              "content": "Reject request",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Provide a reason for rejecting this request."
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Reason for rejection",
                          "action": "EDIT_COMMENT"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id",
                                "comment": "@entity.comment"
                              },
                              "variant": "danger",
                              "type": "button",
                              "icon": "send",
                              "label": "Submit rejection",
                              "action": "SUBMIT_REJECTION"
                            },
                            {
                              "variant": "ghost",
                              "label": "Cancel",
                              "type": "button",
                              "action": "CANCEL_REJECTION",
                              "icon": "x"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_INFO",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Requesting more info…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Withdrawing request…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "rejecting",
                "to": "rejecting",
                "event": "EDIT_COMMENT",
                "effects": [
                  [
                    "set",
                    "@entity.comment",
                    "@payload.comment"
                  ]
                ]
              },
              {
                "from": "rejecting",
                "to": "loading",
                "event": "SUBMIT_REJECTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Recording rejection…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "rejecting",
                "to": "loading",
                "event": "CANCEL_REJECTION",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading approval requests…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "title",
                  "label": "Title",
                  "variant": "caption"
                },
                {
                  "label": "Target",
                  "variant": "badge",
                  "name": "targetType"
                },
                {
                  "name": "requestedBy",
                  "variant": "caption",
                  "label": "Requested By"
                },
                {
                  "label": "Approver",
                  "name": "assignedApprover",
                  "variant": "caption"
                },
                {
                  "label": "Decision",
                  "variant": "badge",
                  "name": "approverDecision"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "label": "Decided",
                  "variant": "caption",
                  "name": "decidedAt"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Approval Request entity",
              "items": {
                "type": "object"
              }
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_REQUEST",
                  "variant": "primary",
                  "icon": "arrow-right"
                },
                {
                  "label": "Withdraw",
                  "event": "WITHDRAW",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each request row",
              "items": {
                "type": "object"
              }
            },
            "title": {
              "type": "string",
              "default": "Approval Requests",
              "label": "Section title",
              "description": "Heading shown above the approval queue"
            },
            "requireCommentOnReject": {
              "type": "boolean",
              "default": false,
              "label": "Require reject comment",
              "description": "Force approvers to enter a reason when rejecting"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApprovalRequestPage",
          "path": "/approval-requests",
          "traits": [
            {
              "ref": "ApprovalRequestPipeline"
            }
          ]
        }
      ]
    }
  ]
}