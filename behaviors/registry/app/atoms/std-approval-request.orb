{
  "name": "std-approval-request",
  "version": "1.4.0",
  "description": "std-approval-request — approver inbox/triage queue (use std-approval-chain for sequential single-item approvals). Listens for SET_STATUS so std-lifecycle can auto-withdraw stale requests. Exposes Service/Operations knobs (responseTimeMinutes, resolutionSLAHours, …).",
  "orbitals": [
    {
      "name": "ApprovalRequestOrbital",
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approvalrequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "default": "timesheet",
            "values": [
              "timesheet",
              "expense-report",
              "pto-request",
              "purchase-order",
              "change-order",
              "other"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "requestedBy",
            "type": "string",
            "required": true
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedApprover",
            "type": "string",
            "default": ""
          },
          {
            "name": "approverDecision",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "approved",
              "rejected",
              "needs-info"
            ]
          },
          {
            "name": "decidedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "comment",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected",
              "withdrawn"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApprovalRequestPipeline",
          "category": "interaction",
          "linkedEntity": "ApprovalRequest",
          "emits": [
            {
              "event": "OPEN_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedBy",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedApprover",
                  "type": "string"
                },
                {
                  "name": "row.approverDecision",
                  "type": "string"
                },
                {
                  "name": "row.decidedAt",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_REQUEST"
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REQUEST_INFO",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WITHDRAW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_COMMENT",
              "payloadSchema": [
                {
                  "name": "comment",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUBMIT_REJECTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "comment",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_REJECTION"
            },
            {
              "event": "ApprovalRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApprovalRequest]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "rejecting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_REQUEST",
                "name": "Open Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApprovalRequest"
                  }
                ]
              },
              {
                "key": "WITHDRAW",
                "name": "Withdraw",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_REQUEST",
                "name": "Close Request"
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_INFO",
                "name": "Request Info",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_COMMENT",
                "name": "Edit Comment",
                "payloadSchema": [
                  {
                    "name": "comment",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT_REJECTION",
                "name": "Submit Rejection",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "comment",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CANCEL_REJECTION",
                "name": "Cancel Rejection"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading approval requests…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "inbox",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total requests"
                            },
                            {
                              "label": "Pending",
                              "value": "14",
                              "icon": "clock",
                              "type": "stat-display"
                            },
                            {
                              "value": "82%",
                              "type": "stat-display",
                              "label": "Approved",
                              "icon": "check-circle"
                            },
                            {
                              "label": "Avg cycle",
                              "type": "stat-display",
                              "value": "1.4 days",
                              "icon": "timer"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions",
                          "gap": "sm",
                          "fields": "@config.fields",
                          "cols": 1.0
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.message"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    "@payload.row.targetType"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.row.targetId"
                  ],
                  [
                    "set",
                    "@entity.requestedBy",
                    "@payload.row.requestedBy"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "@payload.row.requestedAt"
                  ],
                  [
                    "set",
                    "@entity.assignedApprover",
                    "@payload.row.assignedApprover"
                  ],
                  [
                    "set",
                    "@entity.approverDecision",
                    "@payload.row.approverDecision"
                  ],
                  [
                    "set",
                    "@entity.decidedAt",
                    "@payload.row.decidedAt"
                  ],
                  [
                    "set",
                    "@entity.comment",
                    "@payload.row.comment"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_REQUEST",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.title",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.approverDecision"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Target"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.targetType"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.targetId",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Requested by"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.requestedBy"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Approver"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.assignedApprover"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Comment",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.comment"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Requested at",
                              "icon": "calendar",
                              "value": "@entity.requestedAt"
                            },
                            {
                              "value": "@entity.decidedAt",
                              "icon": "calendar-check",
                              "type": "stat-display",
                              "label": "Decided at"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary",
                              "action": "APPROVE",
                              "label": "Approve"
                            },
                            {
                              "action": "REJECT",
                              "label": "Reject",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger"
                            },
                            {
                              "action": "REQUEST_INFO",
                              "variant": "secondary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Request Info"
                            },
                            {
                              "label": "Withdraw",
                              "action": "WITHDRAW",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Withdrawing request…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "ApprovalRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Updating approval status…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_REQUEST",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading approval requests…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Recording approval…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "guard": [
                  "=",
                  "@config.requireCommentOnReject",
                  false
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Recording rejection…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "rejecting",
                "event": "REJECT",
                "guard": [
                  "=",
                  "@config.requireCommentOnReject",
                  true
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.comment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "x-circle"
                            },
                            {
                              "type": "typography",
                              "content": "Reject request",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Provide a reason for rejecting this request.",
                          "color": "muted"
                        },
                        {
                          "action": "EDIT_COMMENT",
                          "type": "textarea",
                          "placeholder": "Reason for rejection"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "variant": "danger",
                              "action": "SUBMIT_REJECTION",
                              "actionPayload": {
                                "comment": "@entity.comment",
                                "id": "@entity.id"
                              },
                              "icon": "send",
                              "label": "Submit rejection"
                            },
                            {
                              "label": "Cancel",
                              "variant": "ghost",
                              "action": "CANCEL_REJECTION",
                              "icon": "x",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_INFO",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Requesting more info…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Withdrawing request…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "rejecting",
                "to": "rejecting",
                "event": "EDIT_COMMENT",
                "effects": [
                  [
                    "set",
                    "@entity.comment",
                    "@payload.comment"
                  ]
                ]
              },
              {
                "from": "rejecting",
                "to": "loading",
                "event": "SUBMIT_REJECTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Recording rejection…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "rejecting",
                "to": "loading",
                "event": "CANCEL_REJECTION",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading approval requests…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "responseTimeMinutes": {
              "type": "number",
              "default": 240.0,
              "label": "Response time SLA (min)",
              "description": "Target minutes from request submitted to first approver acknowledgement.",
              "tier": "essential"
            },
            "requireCommentOnReject": {
              "type": "boolean",
              "default": false,
              "label": "Require reject comment",
              "description": "Force approvers to enter a reason when rejecting",
              "tier": "customization"
            },
            "serviceAreaRadius": {
              "type": "number",
              "default": 0.0,
              "label": "Service area radius (mi)",
              "description": "Geographic distance limit for assignable approvers. Zero = no restriction.",
              "tier": "customization"
            },
            "serviceZones": {
              "type": "[string]",
              "default": [],
              "label": "Service zones",
              "description": "Named approver pools (e.g. by region, department, business unit).",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "skillsRequired": {
              "type": "[string]",
              "default": [],
              "label": "Required skills",
              "description": "Capability tags an approver must hold (e.g. 'finance', 'legal', 'security').",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "resolutionSLAHours": {
              "type": "number",
              "default": 48.0,
              "label": "Resolution SLA (hours)",
              "description": "Target hours from submitted to decided. Compose std-lifecycle to auto-escalate.",
              "tier": "essential"
            },
            "escalationThresholdHours": {
              "type": "number",
              "default": 72.0,
              "label": "Escalation threshold (hours)",
              "description": "Hours after which a pending request auto-escalates to backup approvers.",
              "tier": "customization"
            },
            "requirePhotoOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require photo on complete",
              "description": "Block APPROVE unless supporting evidence is attached.",
              "tier": "customization"
            },
            "requireSignatureOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require approver signature on complete",
              "description": "Block APPROVE unless approver signature is captured (compose std-signature-capture).",
              "tier": "customization"
            },
            "customerVisibleStatuses": {
              "type": "[string]",
              "default": [
                "submitted",
                "approved",
                "rejected"
              ],
              "label": "Customer-visible statuses",
              "description": "Subset of statuses the requester sees in their tracking view.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "default": "Approval Requests",
              "label": "Section title",
              "description": "Heading shown above the approval queue",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Title",
                  "name": "title",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "label": "Target",
                  "name": "targetType"
                },
                {
                  "label": "Requested By",
                  "variant": "caption",
                  "name": "requestedBy"
                },
                {
                  "name": "assignedApprover",
                  "label": "Approver",
                  "variant": "caption"
                },
                {
                  "name": "approverDecision",
                  "label": "Decision",
                  "variant": "badge"
                },
                {
                  "variant": "badge",
                  "label": "Status",
                  "name": "status"
                },
                {
                  "label": "Decided",
                  "name": "decidedAt",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Approval Request entity",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_REQUEST"
                },
                {
                  "variant": "danger",
                  "event": "WITHDRAW",
                  "label": "Withdraw"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each request row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "dispatchStrategy": {
              "type": "string",
              "default": "manual",
              "label": "Dispatch strategy",
              "description": "How approvers are assigned to incoming requests.",
              "tier": "customization",
              "values": [
                "nearest",
                "round-robin",
                "manual"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApprovalRequestPage",
          "path": "/approval-requests",
          "traits": [
            {
              "ref": "ApprovalRequestPipeline"
            }
          ]
        }
      ]
    }
  ]
}