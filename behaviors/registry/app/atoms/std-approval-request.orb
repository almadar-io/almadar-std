{
  "name": "std-approval-request",
  "version": "1.0.0",
  "description": "std-approval-request — Generic approval step primitive for routing a target (timesheet, expense, PTO, etc.) through requestor + approver decisions.",
  "orbitals": [
    {
      "name": "ApprovalRequestOrbital",
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approvalrequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "default": "timesheet",
            "values": [
              "timesheet",
              "expense-report",
              "pto-request",
              "purchase-order",
              "change-order",
              "other"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "requestedBy",
            "type": "string",
            "required": true
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedApprover",
            "type": "string",
            "default": ""
          },
          {
            "name": "approverDecision",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "approved",
              "rejected",
              "needs-info"
            ]
          },
          {
            "name": "decidedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "comment",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "approved",
              "rejected",
              "withdrawn"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApprovalRequestPipeline",
          "category": "interaction",
          "linkedEntity": "ApprovalRequest",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedBy",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedApprover",
                  "type": "string"
                },
                {
                  "name": "row.approverDecision",
                  "type": "string"
                },
                {
                  "name": "row.decidedAt",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedBy",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedApprover",
                  "type": "string"
                },
                {
                  "name": "row.approverDecision",
                  "type": "string"
                },
                {
                  "name": "row.decidedAt",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_INFO",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedBy",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedApprover",
                  "type": "string"
                },
                {
                  "name": "row.approverDecision",
                  "type": "string"
                },
                {
                  "name": "row.decidedAt",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WITHDRAW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedBy",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.assignedApprover",
                  "type": "string"
                },
                {
                  "name": "row.approverDecision",
                  "type": "string"
                },
                {
                  "name": "row.decidedAt",
                  "type": "string"
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApprovalRequest]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ApprovalRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TYPE",
                "name": "Filter Type",
                "payloadSchema": [
                  {
                    "name": "targetType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_INFO",
                "name": "Request Info",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "WITHDRAW",
                "name": "Withdraw",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading approval requests…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "check-circle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            },
                            {
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "New Approval Request",
                              "type": "button"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "currentStep": 1.0,
                          "type": "wizard-progress",
                          "steps": [
                            {
                              "title": "Submitted",
                              "id": "submitted"
                            },
                            {
                              "id": "review",
                              "title": "Review"
                            },
                            {
                              "id": "decision",
                              "title": "Decision"
                            },
                            {
                              "id": "closed",
                              "title": "Closed"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "currentTurn": 2.0,
                              "phase": "Review",
                              "type": "turn-indicator",
                              "size": "md",
                              "activeTeam": "Approver",
                              "maxTurns": 4.0
                            },
                            {
                              "direction": "up",
                              "showValue": true,
                              "label": "Approval rate trend",
                              "type": "trend-indicator",
                              "value": 12.5,
                              "size": "md"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "maxTurns": 4.0,
                          "type": "turn-panel",
                          "phase": "Review",
                          "actions": [
                            {
                              "label": "Approve",
                              "event": "APPROVE",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "label": "Reject",
                              "event": "REJECT"
                            }
                          ],
                          "activeTeam": "Approver",
                          "currentTurn": 2.0
                        },
                        {
                          "fields": [
                            {
                              "name": "title",
                              "label": "Step"
                            },
                            {
                              "label": "Date",
                              "name": "date"
                            },
                            {
                              "label": "Status",
                              "name": "status"
                            },
                            {
                              "label": "Notes",
                              "name": "description"
                            }
                          ],
                          "items": [
                            {
                              "date": "2026-05-08",
                              "description": "Request submitted",
                              "status": "completed",
                              "id": "submitted",
                              "title": "Submitted"
                            },
                            {
                              "date": "2026-05-09",
                              "id": "assigned",
                              "status": "completed",
                              "description": "Approver assigned",
                              "title": "Assigned"
                            },
                            {
                              "title": "Review",
                              "status": "current",
                              "description": "Approver reviewing",
                              "date": "2026-05-11",
                              "id": "review"
                            },
                            {
                              "id": "decision",
                              "title": "Decision",
                              "description": "Pending decision",
                              "status": "upcoming",
                              "date": "2026-05-12"
                            }
                          ],
                          "type": "timeline",
                          "title": "Approval Chronology"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "View",
                              "variant": "secondary",
                              "event": "VIEW"
                            },
                            {
                              "event": "EDIT",
                              "variant": "secondary",
                              "label": "Edit"
                            },
                            {
                              "variant": "primary",
                              "label": "Approve",
                              "event": "APPROVE"
                            },
                            {
                              "variant": "danger",
                              "event": "REJECT",
                              "label": "Reject"
                            },
                            {
                              "variant": "ghost",
                              "event": "REQUEST_INFO",
                              "label": "Request Info"
                            },
                            {
                              "variant": "ghost",
                              "event": "WITHDRAW",
                              "label": "Withdraw"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "fields": [
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "name": "targetType",
                              "variant": "badge",
                              "label": "Target"
                            },
                            {
                              "label": "Requested By",
                              "variant": "caption",
                              "name": "requestedBy"
                            },
                            {
                              "name": "assignedApprover",
                              "label": "Approver",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "approverDecision",
                              "label": "Decision"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "label": "Decided",
                              "name": "decidedAt",
                              "variant": "caption"
                            }
                          ],
                          "cols": 1.0,
                          "type": "data-grid"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.message",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Refreshing approval requests…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Searching approval requests…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_STATUS",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Filtering approval requests…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TYPE",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Filtering approval requests…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Creating new approval request",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Viewing approval request",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Editing approval request",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Approval recorded",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Rejection recorded",
                      "type": "alert",
                      "variant": "warning"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_INFO",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "More information requested",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Request withdrawn"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "warning",
                      "message": "Delete requested"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "failure": "ApprovalRequestLoadFailed",
                        "success": "ApprovalRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Approval Requests"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApprovalRequestPage",
          "path": "/approval-requests",
          "traits": [
            {
              "ref": "ApprovalRequestPipeline"
            }
          ]
        }
      ]
    }
  ]
}