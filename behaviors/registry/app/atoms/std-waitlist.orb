{
  "name": "std-waitlist",
  "version": "1.1.0",
  "description": "std-waitlist — sorted queue with auto-promote-on-cancel. Lists waitlist entries in `browsing`; opens detail in `viewing_single` with Promote / Cancel actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "WaitlistOrbital",
      "entity": {
        "name": "WaitlistEntry",
        "collection": "waitlistentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "userId",
            "type": "string",
            "required": true
          },
          {
            "name": "position",
            "type": "number",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "waiting",
            "values": [
              "waiting",
              "promoted",
              "cancelled",
              "expired"
            ]
          },
          {
            "name": "joinedAt",
            "type": "string"
          },
          {
            "name": "promotedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WaitlistManage",
          "category": "interaction",
          "linkedEntity": "WaitlistEntry",
          "emits": [
            {
              "event": "OPEN_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "PROMOTE",
              "payloadSchema": [
                {
                  "name": "entryId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "entryId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WaitlistEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[WaitlistEntry]"
                }
              ]
            },
            {
              "event": "WaitlistEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WaitlistEntryLoaded",
                "name": "WaitlistEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WaitlistEntry]"
                  }
                ]
              },
              {
                "key": "WaitlistEntryLoadFailed",
                "name": "WaitlistEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ENTRY",
                "name": "Open Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "entryId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "PROMOTE",
                "name": "Promote",
                "payloadSchema": [
                  {
                    "name": "entryId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "success": "WaitlistEntryLoaded",
                        "failure": "WaitlistEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading waitlist…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WaitlistEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "users",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "label": "Total entries",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "value": "126",
                              "label": "Waiting",
                              "icon": "hourglass"
                            },
                            {
                              "value": "24",
                              "icon": "arrow-up",
                              "label": "Promoted 7d",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Avg wait time",
                              "value": "3d",
                              "icon": "clock"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WaitlistEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.row.targetId"
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    "@payload.row.targetType"
                  ],
                  [
                    "set",
                    "@entity.userId",
                    "@payload.row.userId"
                  ],
                  [
                    "set",
                    "@entity.position",
                    "@payload.row.position"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.joinedAt",
                    "@payload.row.joinedAt"
                  ],
                  [
                    "set",
                    "@entity.promotedAt",
                    "@payload.row.promotedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.userId",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Target",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.targetId"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Target type"
                                },
                                {
                                  "content": "@entity.targetType",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Position",
                              "value": "@entity.position",
                              "type": "stat-display",
                              "icon": "hash"
                            },
                            {
                              "type": "stat-display",
                              "label": "Joined",
                              "icon": "calendar",
                              "value": "@entity.joinedAt"
                            },
                            {
                              "type": "stat-display",
                              "icon": "arrow-up",
                              "label": "Promoted",
                              "value": "@entity.promotedAt"
                            },
                            {
                              "label": "Notified",
                              "value": "@entity.notifiedAt",
                              "type": "stat-display",
                              "icon": "bell"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "PROMOTE",
                              "type": "button",
                              "label": "Promote",
                              "variant": "primary",
                              "actionPayload": {
                                "entryId": "@entity.id",
                                "row": "@entity"
                              }
                            },
                            {
                              "action": "CANCEL",
                              "label": "Cancel",
                              "actionPayload": {
                                "entryId": "@entity.id",
                                "row": "@entity"
                              },
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entryId"
                  ],
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "success": "WaitlistEntryLoaded",
                        "failure": "WaitlistEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Cancelling entry…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "failure": "WaitlistEntryLoadFailed",
                        "success": "WaitlistEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading waitlist…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PROMOTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entryId"
                  ],
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "failure": "WaitlistEntryLoadFailed",
                        "success": "WaitlistEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Promoting entry…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entryId"
                  ],
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "success": "WaitlistEntryLoaded",
                        "failure": "WaitlistEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Cancelling entry…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "success": "WaitlistEntryLoaded",
                        "failure": "WaitlistEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_ENTRY",
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "variant": "danger",
                  "event": "CANCEL",
                  "label": "Cancel",
                  "icon": "x"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each waitlist entry"
            },
            "title": {
              "type": "string",
              "default": "Waitlist",
              "label": "Section title",
              "description": "Heading shown above the waitlist queue"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "#",
                  "variant": "badge",
                  "name": "position"
                },
                {
                  "variant": "caption",
                  "name": "userId",
                  "label": "User"
                },
                {
                  "label": "Type",
                  "name": "targetType",
                  "variant": "badge"
                },
                {
                  "name": "status",
                  "variant": "badge",
                  "label": "Status"
                },
                {
                  "name": "joinedAt",
                  "variant": "caption",
                  "label": "Joined"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Waitlist Entry entity"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WaitlistManagePage",
          "path": "/waitlistentries/manage",
          "traits": [
            {
              "ref": "WaitlistManage"
            }
          ]
        }
      ]
    }
  ]
}
