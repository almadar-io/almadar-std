{
  "name": "std-ap-bill",
  "version": "1.2.0",
  "description": "std-ap-bill — accounts-payable bill (vendor bills we owe). Lists bills with Pay / Void actions. Listens for SET_STATUS so sibling std-lifecycle can drive automated transitions. Exposes Financial-pattern knobs (currency, taxStrategy, gracePeriodDays, lateFeePolicy, …).",
  "orbitals": [
    {
      "name": "ApBillOrbital",
      "entity": {
        "name": "ApBill",
        "collection": "apbills",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vendor",
            "type": "string",
            "required": true
          },
          {
            "name": "billNumber",
            "type": "string",
            "default": ""
          },
          {
            "name": "billDate",
            "type": "string",
            "required": true
          },
          {
            "name": "dueDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "amountTotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "amountPaid",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "partial",
              "paid",
              "overdue",
              "void"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApBillLedger",
          "category": "interaction",
          "linkedEntity": "ApBill",
          "emits": [
            {
              "event": "OPEN_BILL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendor",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.billNumber",
                  "type": "string"
                },
                {
                  "name": "row.billDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dueDate",
                  "type": "string"
                },
                {
                  "name": "row.amountTotal",
                  "type": "number"
                },
                {
                  "name": "row.amountPaid",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "PAY_BILL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_BILL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ApBillLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApBill]"
                }
              ]
            },
            {
              "event": "ApBillLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApBillUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendor",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.billNumber",
                  "type": "string"
                },
                {
                  "name": "row.billDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dueDate",
                  "type": "string"
                },
                {
                  "name": "row.amountTotal",
                  "type": "number"
                },
                {
                  "name": "row.amountPaid",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApBillUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApBillLoaded",
                "name": "ApBill loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApBill]"
                  }
                ]
              },
              {
                "key": "ApBillLoadFailed",
                "name": "ApBill load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_BILL",
                "name": "Open Bill",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApBill"
                  }
                ]
              },
              {
                "key": "VOID_BILL",
                "name": "Void Bill",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ApBillUpdated",
                "name": "ApBill updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ApBill"
                  }
                ]
              },
              {
                "key": "ApBillUpdateFailed",
                "name": "ApBill update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "PAY_BILL",
                "name": "Pay Bill",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "failure": "ApBillLoadFailed",
                        "success": "ApBillLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading bills…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApBillLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Open bills",
                              "icon": "file-text",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "label": "Total payable",
                              "value": "$48,200",
                              "type": "stat-display",
                              "icon": "dollar-sign"
                            },
                            {
                              "label": "Overdue",
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "value": "6"
                            },
                            {
                              "label": "Paid this month",
                              "value": "32",
                              "type": "stat-display",
                              "icon": "check-circle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApBillLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vendor",
                    "@payload.row.vendor"
                  ],
                  [
                    "set",
                    "@entity.billNumber",
                    "@payload.row.billNumber"
                  ],
                  [
                    "set",
                    "@entity.billDate",
                    "@payload.row.billDate"
                  ],
                  [
                    "set",
                    "@entity.dueDate",
                    "@payload.row.dueDate"
                  ],
                  [
                    "set",
                    "@entity.amountTotal",
                    "@payload.row.amountTotal"
                  ],
                  [
                    "set",
                    "@entity.amountPaid",
                    "@payload.row.amountPaid"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.vendor",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Bill #"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.billNumber"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Notes",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.notes",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Total",
                              "value": "@entity.amountTotal",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.amountPaid",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "label": "Paid"
                            },
                            {
                              "type": "stat-display",
                              "label": "Bill date",
                              "value": "@entity.billDate",
                              "icon": "calendar"
                            },
                            {
                              "icon": "calendar-clock",
                              "type": "stat-display",
                              "label": "Due",
                              "value": "@entity.dueDate"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "PAY_BILL",
                              "label": "Pay Bill",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Void",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "VOID_BILL",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "VOID_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "failure": "ApBillLoadFailed",
                        "success": "ApBillLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Voiding bill…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "ApBill",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ApBillUpdateFailed",
                        "success": "ApBillUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating bill status…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ApBillUpdated",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ApBillUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading bills…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PAY_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Paying bill…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VOID_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "failure": "ApBillLoadFailed",
                        "success": "ApBillLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Voiding bill…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "failure": "ApBillLoadFailed",
                        "success": "ApBillLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "label": "Open",
                  "event": "OPEN_BILL",
                  "variant": "primary"
                },
                {
                  "label": "Void",
                  "event": "VOID_BILL",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each bill row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Bills Payable",
              "label": "Section title",
              "description": "Heading shown above the vendor bills list",
              "tier": "customization"
            },
            "currency": {
              "type": "string",
              "default": "USD",
              "label": "Default currency",
              "description": "ISO 4217 currency code (USD, EUR, GBP, …) for bill amounts.",
              "tier": "essential"
            },
            "taxStrategy": {
              "type": "string",
              "default": "exclusive",
              "label": "Tax strategy",
              "description": "inclusive = tax baked into the line item totals; exclusive = tax added on top; none = no tax.",
              "tier": "customization",
              "values": [
                "inclusive",
                "exclusive",
                "none"
              ]
            },
            "lateFeeAmount": {
              "type": "number",
              "default": 0.0,
              "label": "Late fee amount",
              "description": "Flat cash amount or percentage (per lateFeePolicy).",
              "tier": "customization"
            },
            "complianceJurisdiction": {
              "type": "string",
              "default": "",
              "label": "Compliance jurisdiction",
              "description": "Drives tax + retention rules per locale: 'US-CA', 'EU-DE', 'UK', etc. Declarative.",
              "tier": "advanced"
            },
            "gracePeriodDays": {
              "type": "number",
              "default": 30.0,
              "label": "Grace period (days)",
              "description": "Days after dueDate before a bill is treated as overdue. Wire via sibling std-lifecycle rule.",
              "tier": "customization"
            },
            "retentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Retention (years)",
              "description": "Years to keep bill records for compliance. Default 7 matches common regimes.",
              "tier": "advanced"
            },
            "lateFeePolicy": {
              "type": "string",
              "default": "none",
              "label": "Late fee policy",
              "description": "How late fees compute when overdue: none, flat (lateFeeAmount cash), or percent (% of total). Declarative; wiring deferred.",
              "tier": "customization",
              "values": [
                "none",
                "flat",
                "percent"
              ]
            },
            "roundingMode": {
              "type": "string",
              "default": "half-up",
              "label": "Rounding mode",
              "description": "Sub-cent rounding behavior for line items and totals.",
              "tier": "advanced",
              "values": [
                "bankers",
                "half-up",
                "down"
              ]
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Vendor",
                  "name": "vendor",
                  "variant": "caption"
                },
                {
