{
  "name": "std-ap-bill",
  "version": "1.1.0",
  "description": "std-ap-bill — accounts-payable bill (vendor bills we owe). Lists bills in `browsing`; opens bill detail in `viewing_single` with Pay / Void actions. Counterpart to std-invoice on the payables side. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ApBillOrbital",
      "entity": {
        "name": "ApBill",
        "collection": "apbills",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vendor",
            "type": "string",
            "required": true
          },
          {
            "name": "billNumber",
            "type": "string",
            "default": ""
          },
          {
            "name": "billDate",
            "type": "string",
            "required": true
          },
          {
            "name": "dueDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "amountTotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "amountPaid",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "partial",
              "paid",
              "overdue",
              "void"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApBillLedger",
          "category": "interaction",
          "linkedEntity": "ApBill",
          "emits": [
            {
              "event": "OPEN_BILL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendor",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.billNumber",
                  "type": "string"
                },
                {
                  "name": "row.billDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dueDate",
                  "type": "string"
                },
                {
                  "name": "row.amountTotal",
                  "type": "number"
                },
                {
                  "name": "row.amountPaid",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "PAY_BILL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_BILL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ApBillLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ApBill]"
                }
              ]
            },
            {
              "event": "ApBillLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApBillLoaded",
                "name": "ApBill loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApBill]"
                  }
                ]
              },
              {
                "key": "ApBillLoadFailed",
                "name": "ApBill load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_BILL",
                "name": "Open Bill",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ApBill"
                  }
                ]
              },
              {
                "key": "VOID_BILL",
                "name": "Void Bill",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "PAY_BILL",
                "name": "Pay Bill",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading bills…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApBillLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Open bills",
                              "value": "@payload.data.length",
                              "icon": "file-text"
                            },
                            {
                              "value": "$48,200",
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "label": "Total payable"
                            },
                            {
                              "icon": "alert-triangle",
                              "value": "6",
                              "label": "Overdue",
                              "type": "stat-display"
                            },
                            {
                              "icon": "check-circle",
                              "value": "32",
                              "type": "stat-display",
                              "label": "Paid this month"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApBillLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vendor",
                    "@payload.row.vendor"
                  ],
                  [
                    "set",
                    "@entity.billNumber",
                    "@payload.row.billNumber"
                  ],
                  [
                    "set",
                    "@entity.billDate",
                    "@payload.row.billDate"
                  ],
                  [
                    "set",
                    "@entity.dueDate",
                    "@payload.row.dueDate"
                  ],
                  [
                    "set",
                    "@entity.amountTotal",
                    "@payload.row.amountTotal"
                  ],
                  [
                    "set",
                    "@entity.amountPaid",
                    "@payload.row.amountPaid"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "content": "@entity.vendor",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Bill #",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.billNumber",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Notes"
                                },
                                {
                                  "content": "@entity.notes",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total",
                              "value": "@entity.amountTotal",
                              "icon": "dollar-sign"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Paid",
                              "type": "stat-display",
                              "value": "@entity.amountPaid"
                            },
                            {
                              "value": "@entity.billDate",
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Bill date"
                            },
                            {
                              "label": "Due",
                              "value": "@entity.dueDate",
                              "icon": "calendar-clock",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "PAY_BILL",
                              "variant": "primary",
                              "label": "Pay Bill",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "VOID_BILL",
                              "variant": "danger",
                              "type": "button",
                              "label": "Void",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "VOID_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Voiding bill…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading bills…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PAY_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "failure": "ApBillLoadFailed",
                        "success": "ApBillLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Paying bill…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VOID_BILL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Voiding bill…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApBill",
                    {
                      "emit": {
                        "success": "ApBillLoaded",
                        "failure": "ApBillLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "Vendor",
                  "name": "vendor",
                  "variant": "caption"
                },
                {
                  "name": "billNumber",
                  "label": "Bill #",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "billDate",
                  "label": "Bill Date"
                },
                {
                  "label": "Due",
                  "variant": "caption",
                  "name": "dueDate"
                },
                {
                  "name": "amountTotal",
                  "label": "Total",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_BILL",
                  "icon": "arrow-right",
                  "variant": "primary"
                },
                {
                  "label": "Void",
                  "event": "VOID_BILL",
                  "variant": "danger"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Bills Payable"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApBillPage",
          "path": "/bills",
          "traits": [
            {
              "ref": "ApBillLedger"
            }
          ]
        }
      ]
    }
  ]
}
