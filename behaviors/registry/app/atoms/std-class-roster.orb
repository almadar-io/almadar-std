{
  "name": "std-class-roster",
  "version": "1.1.0",
  "description": "std-class-roster — list of members enrolled in a specific class session. Lists roster entries in `browsing`; opens entry detail in `viewing_single` with Check In / No Show actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ClassRosterOrbital",
      "entity": {
        "name": "RosterEntry",
        "collection": "rosterentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sessionId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberName",
            "type": "string",
            "default": ""
          },
          {
            "name": "enrolledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "checkedInAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "enrolled",
            "values": [
              "enrolled",
              "checked_in",
              "no_show",
              "waitlist"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RosterEntryRoster",
          "category": "interaction",
          "linkedEntity": "RosterEntry",
          "emits": [
            {
              "event": "OPEN_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sessionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberName",
                  "type": "string"
                },
                {
                  "name": "row.enrolledAt",
                  "type": "string"
                },
                {
                  "name": "row.checkedInAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CHECK_IN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_NO_SHOW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RosterEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RosterEntry]"
                }
              ]
            },
            {
              "event": "RosterEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RosterEntryLoaded",
                "name": "RosterEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RosterEntry]"
                  }
                ]
              },
              {
                "key": "RosterEntryLoadFailed",
                "name": "RosterEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ENTRY",
                "name": "Open Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "RosterEntry"
                  }
                ]
              },
              {
                "key": "CHECK_IN",
                "name": "Check In",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_NO_SHOW",
                "name": "Mark No Show",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading roster…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RosterEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Enrolled",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "label": "Checked in",
                              "icon": "check-circle",
                              "value": "14"
                            },
                            {
                              "label": "No shows",
                              "icon": "user-x",
                              "type": "stat-display",
                              "value": "3"
                            },
                            {
                              "label": "Waitlist",
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "5"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "gap": "sm",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RosterEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.sessionId",
                    "@payload.row.sessionId"
                  ],
                  [
                    "set",
                    "@entity.memberId",
                    "@payload.row.memberId"
                  ],
                  [
                    "set",
                    "@entity.memberName",
                    "@payload.row.memberName"
                  ],
                  [
                    "set",
                    "@entity.enrolledAt",
                    "@payload.row.enrolledAt"
                  ],
                  [
                    "set",
                    "@entity.checkedInAt",
                    "@payload.row.checkedInAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.memberName"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Session",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.sessionId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Notes",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "calendar",
                              "label": "Enrolled at",
                              "type": "stat-display",
                              "value": "@entity.enrolledAt"
                            },
                            {
                              "label": "Checked in at",
                              "value": "@entity.checkedInAt",
                              "type": "stat-display",
                              "icon": "check-circle"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "action": "CHECK_IN",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Check In",
                              "variant": "primary"
                            },
                            {
                              "label": "No Show",
                              "type": "button",
                              "variant": "danger",
                              "action": "MARK_NO_SHOW",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CHECK_IN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Checking in…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_NO_SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Marking no-show…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading roster…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CHECK_IN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Checking in…"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_NO_SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Marking no-show…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Class Roster"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "memberName",
                  "label": "Member",
                  "variant": "caption"
                },
                {
                  "label": "Session",
                  "variant": "caption",
                  "name": "sessionId"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "name": "checkedInAt",
                  "label": "Checked In"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_ENTRY",
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary"
                },
                {
                  "label": "Check In",
                  "event": "CHECK_IN",
                  "variant": "secondary"
                },
                {
                  "variant": "danger",
                  "event": "MARK_NO_SHOW",
                  "label": "No Show"
                }
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RosterEntryPage",
          "path": "/roster",
          "traits": [
            {
              "ref": "RosterEntryRoster"
            }
          ]
        }
      ]
    }
  ]
}
