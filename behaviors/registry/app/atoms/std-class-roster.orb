{
  "name": "std-class-roster",
  "version": "1.2.0",
  "description": "std-class-roster — members enrolled in a class session. Listens for SET_STATUS so sibling std-lifecycle can auto-transition. Exposes Scheduling/Booking + HR knobs (bookingWindowDays, noShowGracePeriodMinutes, anonymizeOnRejection, …).",
  "orbitals": [
    {
      "name": "ClassRosterOrbital",
      "entity": {
        "name": "RosterEntry",
        "collection": "rosterentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sessionId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberName",
            "type": "string",
            "default": ""
          },
          {
            "name": "enrolledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "checkedInAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "enrolled",
            "values": [
              "enrolled",
              "checked_in",
              "no_show",
              "waitlist"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RosterEntryRoster",
          "category": "interaction",
          "linkedEntity": "RosterEntry",
          "emits": [
            {
              "event": "OPEN_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sessionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberName",
                  "type": "string"
                },
                {
                  "name": "row.enrolledAt",
                  "type": "string"
                },
                {
                  "name": "row.checkedInAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CHECK_IN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_NO_SHOW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RosterEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RosterEntry]"
                }
              ]
            },
            {
              "event": "RosterEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RosterEntryLoaded",
                "name": "RosterEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RosterEntry]"
                  }
                ]
              },
              {
                "key": "RosterEntryLoadFailed",
                "name": "RosterEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ENTRY",
                "name": "Open Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "RosterEntry"
                  }
                ]
              },
              {
                "key": "CHECK_IN",
                "name": "Check In",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_NO_SHOW",
                "name": "Mark No Show",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading roster…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RosterEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "icon": "users",
                              "label": "Enrolled"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Checked in",
                              "value": "14",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "3",
                              "label": "No shows",
                              "icon": "user-x"
                            },
                            {
                              "icon": "clock",
                              "value": "5",
                              "label": "Waitlist",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RosterEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.sessionId",
                    "@payload.row.sessionId"
                  ],
                  [
                    "set",
                    "@entity.memberId",
                    "@payload.row.memberId"
                  ],
                  [
                    "set",
                    "@entity.memberName",
                    "@payload.row.memberName"
                  ],
                  [
                    "set",
                    "@entity.enrolledAt",
                    "@payload.row.enrolledAt"
                  ],
                  [
                    "set",
                    "@entity.checkedInAt",
                    "@payload.row.checkedInAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "label": "Back",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "user"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.memberName"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Session",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.sessionId"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Notes",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.notes",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "calendar",
                              "value": "@entity.enrolledAt",
                              "label": "Enrolled at",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.checkedInAt",
                              "type": "stat-display",
                              "label": "Checked in at",
                              "icon": "check-circle"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "action": "CHECK_IN",
                              "label": "Check In",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "No Show",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "MARK_NO_SHOW",
                              "variant": "danger",
                              "type": "button"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CHECK_IN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Checking in…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_NO_SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Marking no-show…"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "RosterEntry",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Updating roster entry status…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading roster…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CHECK_IN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Checking in…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_NO_SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Marking no-show…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Class Roster",
              "label": "Section title",
              "description": "Heading shown above the class roster",
              "tier": "customization"
            },
            "eVerifyRequired": {
              "type": "boolean",
              "default": false,
              "label": "E-Verify required",
              "description": "US I-9 / E-Verify gate (relevant for instructor rosters).",
              "tier": "customization"
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 4.0,
              "label": "Reschedule window (hours)",
              "description": "Hours before class start during which the member can self-reschedule.",
              "tier": "customization"
            },
            "i9DocumentsRequired": {
              "type": "boolean",
              "default": false,
              "label": "I-9 documents required",
              "description": "Require I-9 supporting documents (instructor rosters).",
              "tier": "customization"
            },
            "bookingHours": {
              "type": "string",
              "default": "06:00-22:00",
              "label": "Booking hours",
              "description": "Daily window during which enrollments can be made (HH:MM-HH:MM).",
              "tier": "customization"
            },
            "maxReschedules": {
              "type": "number",
              "default": 3.0,
              "label": "Max reschedules",
              "description": "Hard cap on reschedule count per enrollment.",
              "tier": "advanced"
            },
            "anonymizeOnRejection": {
              "type": "boolean",
              "default": false,
              "label": "Anonymize on rejection",
              "description": "When true, scrub member PII on no_show / removal. Pair with std-data-erasure.",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "memberName",
                  "variant": "caption",
                  "label": "Member"
                },
                {
                  "label": "Session",
                  "variant": "caption",
                  "name": "sessionId"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "label": "Checked In",
                  "variant": "caption",
                  "name": "checkedInAt"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Roster Entry entity",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "noShowGracePeriodMinutes": {
              "type": "number",
              "default": 10.0,
              "label": "No-show grace (minutes)",
              "description": "Minutes after class start before the entry auto-marks no_show. Wire via std-lifecycle.",
              "tier": "customization"
            },
            "cancellationPolicy": {
              "type": "string",
              "default": "free",
              "label": "Cancellation policy",
              "description": "Refund treatment when an enrollment is cancelled inside the reschedule window.",
              "tier": "customization",
              "values": [
                "free",
                "partial-refund",
                "no-refund"
              ]
            },
            "equalOpportunityTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Equal opportunity tracking",
              "description": "Capture demographic data separately for EEO reporting (sibling collection).",
              "tier": "advanced"
            },
            "blackoutDates": {
              "type": "[string]",
              "default": [],
              "label": "Blackout dates",
              "description": "ISO dates blocked from booking (e.g. holidays). Compose std-lifecycle to enforce.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "icon": "arrow-right",
                  "label": "Open",
                  "event": "OPEN_ENTRY"
                },
                {
                  "event": "CHECK_IN",
                  "label": "Check In",
                  "variant": "secondary"
                },
                {
                  "variant": "danger",
                  "event": "MARK_NO_SHOW",
                  "label": "No Show"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each enrolled member",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "bookingWindowDays": {
              "type": "number",
              "default": 30.0,
              "label": "Booking window (days)",
              "description": "How far in advance members can enroll in a class.",
