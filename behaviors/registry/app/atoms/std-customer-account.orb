{
  "name": "std-customer-account",
  "version": "1.2.0",
  "description": "std-customer-account — retail customer profile with loyalty points, store credit and Grant Points / Issue Credit / Ban actions. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs.",
  "orbitals": [
    {
      "name": "CustomerAccountOrbital",
      "entity": {
        "name": "CustomerAccount",
        "collection": "customeraccounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "loyaltyPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "storeCreditAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSpent",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "joinedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastVisitAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "banned"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "CustomerAccountDirectory",
          "category": "interaction",
          "linkedEntity": "CustomerAccount",
          "emits": [
            {
              "event": "OPEN_CUSTOMER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.loyaltyPoints",
                  "type": "number"
                },
                {
                  "name": "row.storeCreditAmount",
                  "type": "number"
                },
                {
                  "name": "row.totalSpent",
                  "type": "number"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.lastVisitAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "GRANT_POINTS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "GRANT_CREDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BAN_CUSTOMER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CustomerAccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CustomerAccount]"
                }
              ]
            },
            {
              "event": "CustomerAccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CustomerAccountUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.loyaltyPoints",
                  "type": "number"
                },
                {
                  "name": "row.storeCreditAmount",
                  "type": "number"
                },
                {
                  "name": "row.totalSpent",
                  "type": "number"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.lastVisitAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CustomerAccountUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CustomerAccountLoaded",
                "name": "CustomerAccount loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CustomerAccount]"
                  }
                ]
              },
              {
                "key": "CustomerAccountLoadFailed",
                "name": "CustomerAccount load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CUSTOMER",
                "name": "Open Customer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "CustomerAccount"
                  }
                ]
              },
              {
                "key": "BAN_CUSTOMER",
                "name": "Ban Customer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CustomerAccountUpdated",
                "name": "CustomerAccount updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "CustomerAccount"
                  }
                ]
              },
              {
                "key": "CustomerAccountUpdateFailed",
                "name": "CustomerAccount update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "GRANT_POINTS",
                "name": "Grant Points",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GRANT_CREDIT",
                "name": "Grant Credit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading customers…"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CustomerAccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total customers",
                              "icon": "users",
                              "value": "@payload.data.length",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Active",
                              "icon": "check-circle",
                              "value": "1,284"
                            },
                            {
                              "icon": "award",
                              "type": "stat-display",
                              "label": "Loyalty members",
                              "value": "76%"
                            },
                            {
                              "type": "stat-display",
                              "value": "$412",
                              "label": "Avg lifetime value",
                              "icon": "dollar-sign"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CustomerAccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CUSTOMER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.email",
                    "@payload.row.email"
                  ],
                  [
                    "set",
                    "@entity.phone",
                    "@payload.row.phone"
                  ],
                  [
                    "set",
                    "@entity.loyaltyPoints",
                    "@payload.row.loyaltyPoints"
                  ],
                  [
                    "set",
                    "@entity.storeCreditAmount",
                    "@payload.row.storeCreditAmount"
                  ],
                  [
                    "set",
                    "@entity.totalSpent",
                    "@payload.row.totalSpent"
                  ],
                  [
                    "set",
                    "@entity.joinedAt",
                    "@payload.row.joinedAt"
                  ],
                  [
                    "set",
                    "@entity.lastVisitAt",
                    "@payload.row.lastVisitAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "user"
                            },
                            {
                              "content": "@entity.name",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Email",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.email",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Phone",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.phone",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Loyalty points",
                              "value": "@entity.loyaltyPoints",
                              "icon": "award"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.storeCreditAmount",
                              "label": "Store credit",
                              "icon": "credit-card"
                            },
                            {
                              "type": "stat-display",
                              "icon": "dollar-sign",
                              "label": "Total spent",
                              "value": "@entity.totalSpent"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.lastVisitAt",
                              "label": "Last visit"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "action": "GRANT_POINTS",
                              "label": "Grant Points",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "GRANT_CREDIT",
                              "variant": "secondary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Issue Credit"
                            },
                            {
                              "type": "button",
                              "label": "Ban",
                              "variant": "danger",
                              "action": "BAN_CUSTOMER",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "BAN_CUSTOMER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Banning customer…"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "CustomerAccount",
                    "@entity",
                    {
                      "emit": {
                        "failure": "CustomerAccountUpdateFailed",
                        "success": "CustomerAccountUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Updating customer status…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CustomerAccountUpdated",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CustomerAccountUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading customers…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "GRANT_POINTS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Granting points…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "GRANT_CREDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Issuing store credit…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "BAN_CUSTOMER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Banning customer…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_CUSTOMER",
                  "icon": "arrow-right",
                  "label": "Open"
                },
                {
                  "variant": "danger",
                  "label": "Ban",
                  "event": "BAN_CUSTOMER"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each customer row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Name",
                  "name": "name"
                },
                {
                  "label": "Email",
                  "variant": "caption",
                  "name": "email"
                },
                {
                  "name": "phone",
                  "label": "Phone",
                  "variant": "caption"
                },
                {
                  "name": "loyaltyPoints",
                  "label": "Points",
                  "variant": "caption"
                },
                {
                  "name": "totalSpent",
                  "label": "Total Spent",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "variant": "badge",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Customer entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "contactFrequencyCapPerWeek": {
              "type": "number",
              "default": 5.0,
              "label": "Contact frequency cap (per week)",
              "description": "Maximum outbound contacts (email/SMS/call) per customer per week. 0 = uncapped.",
              "synonyms": "outreach cap, contact limit",
              "tier": "domain"
            },
            "lifecycleStagePolicy": {
              "type": "string",
              "default": "linear",
              "label": "Lifecycle stage policy",
              "description": "linear = standard lead→customer→inactive progression; branching = supports parallel sub-stages; none = free-form status.",
              "synonyms": "customer journey, stage progression",
              "tier": "domain",
              "values": [
                "linear",
                "branching",
                "none"
              ]
            },
            "defaultRetentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Customer record retention (years)",
              "description": "Years to keep a closed customer profile before deletion. Compose std-lifecycle + std-data-erasure to enforce.",
              "synonyms": "keep customer for, GDPR retention",
              "tier": "domain"
            },
            "healthScoreThresholdAlert": {
              "type": "number",
              "default": 50.0,
              "label": "Health score threshold",
              "description": "Customers with health score below this trigger an alert. Declarative; wire via sibling std-notify.",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Customers",
              "label": "Section title",
              "description": "Heading shown above the customer directory",
              "tier": "presentation"
            },
            "renewalReminderDaysBefore": {
              "type": "[number]",
              "default": [
                30.0,
                7.0,
                1.0
              ],
              "label": "Renewal reminder days-before",
              "description": "Days before subscription renewal to send reminders. Declarative; wire via sibling std-reminder-scheduler.",
              "tier": "domain",
              "items": {
                "type": "number"
              }
            },
            "gdprConsentRequired": {
              "type": "boolean",
              "default": true,
              "label": "GDPR consent required",
              "description": "When true, customer profiles require explicit GDPR-compliant consent before storing PII. Drives consent-capture UI.",
              "synonyms": "GDPR opt-in, data processing consent",
              "tier": "domain"
            },
            "consentTrackingEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Track consent",
              "description": "Whether to record marketing/data-processing consent on the customer profile. Declarative.",
              "tier": "domain"
            },
            "archiveInactiveAfterDays": {
              "type": "number",
              "default": 365.0,
              "label": "Archive inactive after (days)",
              "description": "Days of inactivity before customer is auto-archived. Declarative; wire via sibling std-lifecycle.",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CustomerAccountPage",
          "path": "/customers",
          "traits": [
            {
              "ref": "CustomerAccountDirectory"
            }
          ]
        }
      ]
    }
  ]
