{
  "name": "std-customer-account",
  "version": "1.0.0",
  "description": "Retail customer profile primitive with purchase history reference, store credit, and loyalty points.",
  "orbitals": [
    {
      "name": "CustomerAccountOrbital",
      "entity": {
        "name": "CustomerAccount",
        "collection": "customeraccounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "loyaltyPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "storeCreditAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSpent",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "joinedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastVisitAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "banned"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "CustomerAccountDirectory",
          "category": "interaction",
          "linkedEntity": "CustomerAccount",
          "emits": [
            {
              "event": "GRANT_POINTS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "GRANT_CREDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CustomerAccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CustomerAccount]"
                }
              ]
            },
            {
              "event": "CustomerAccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CustomerAccountLoaded",
                "name": "CustomerAccount loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CustomerAccount]"
                  }
                ]
              },
              {
                "key": "CustomerAccountLoadFailed",
                "name": "CustomerAccount load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GRANT_POINTS",
                "name": "Grant Points",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GRANT_CREDIT",
                "name": "Grant Credit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CustomerAccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "data": [
                            {
                              "name": "Receipt #1024",
                              "id": "r1",
                              "imageUrl": "https://picsum.photos/seed/receipt1/400/300"
                            },
                            {
                              "imageUrl": "https://picsum.photos/seed/receipt2/400/300",
                              "id": "r2",
                              "name": "Receipt #1025"
                            },
                            {
                              "name": "Receipt #1026",
                              "id": "r3",
                              "imageUrl": "https://picsum.photos/seed/receipt3/400/300"
                            },
                            {
                              "id": "r4",
                              "imageUrl": "https://picsum.photos/seed/receipt4/400/300",
                              "name": "Receipt #1027"
                            }
                          ],
                          "type": "media-gallery"
                        },
                        {
                          "back": {
                            "direction": "vertical",
                            "type": "stack",
                            "gap": "sm",
                            "children": [
                              {
                                "type": "typography",
                                "variant": "h4",
                                "content": "2,450 points"
                              },
                              {
                                "type": "typography",
                                "variant": "body",
                                "content": "Next reward at 3,000 points"
                              }
                            ],
                            "align": "center"
                          },
                          "height": "h-48",
                          "front": {
                            "children": [
                              {
                                "type": "icon",
                                "name": "award"
                              },
                              {
                                "type": "typography",
                                "variant": "h4",
                                "content": "Loyalty Tier: Gold"
                              },
                              {
                                "variant": "caption",
                                "color": "muted",
                                "type": "typography",
                                "content": "Tap to view points"
                              }
                            ],
                            "direction": "vertical",
                            "align": "center",
                            "gap": "sm",
                            "type": "stack"
                          },
                          "type": "flip-card"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Add Points",
                              "event": "GRANT_POINTS",
                              "variant": "primary"
                            },
                            {
                              "event": "GRANT_CREDIT",
                              "variant": "ghost",
                              "label": "Issue Credit"
                            }
                          ],
                          "fields": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "label": "Name"
                            },
                            {
                              "variant": "body",
                              "name": "email",
                              "label": "Email"
                            },
                            {
                              "variant": "caption",
                              "name": "phone",
                              "label": "Phone"
                            },
                            {
                              "name": "loyaltyPoints",
                              "label": "Points",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "totalSpent",
                              "label": "Total Spent"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CustomerAccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "GRANT_POINTS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Points granted",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "GRANT_CREDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Store credit issued",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Customers"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CustomerAccountPage",
          "path": "/customers",
          "traits": [
            {
              "ref": "CustomerAccountDirectory"
            }
          ]
        }
      ]
    }
  ]
}