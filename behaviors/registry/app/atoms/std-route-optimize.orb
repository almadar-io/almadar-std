{
  "name": "std-route-optimize",
  "version": "1.2.0",
  "description": "std-route-optimize — multi-stop route ordering for technician dispatch. Lists routes; detail offers Optimize / Reset. Exposes Inventory/Logistics knobs (defaultWarehouse, multiLocationEnabled, hazmatEnabled, …) for the questionnaire.",
  "orbitals": [
    {
      "name": "RouteOptimizeOrbital",
      "entity": {
        "name": "Route",
        "collection": "routes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "technicianId",
            "type": "string"
          },
          {
            "name": "originLat",
            "type": "number"
          },
          {
            "name": "originLng",
            "type": "number"
          },
          {
            "name": "stops",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "totalDistanceKm",
            "type": "number"
          },
          {
            "name": "totalDurationMinutes",
            "type": "number"
          },
          {
            "name": "optimizedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RouteOptimize",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "OPEN_ROUTE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.technicianId",
                  "type": "string"
                },
                {
                  "name": "row.originLat",
                  "type": "number"
                },
                {
                  "name": "row.originLng",
                  "type": "number"
                },
                {
                  "name": "row.stops",
                  "type": "[string]"
                },
                {
                  "name": "row.totalDistanceKm",
                  "type": "number"
                },
                {
                  "name": "row.totalDurationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.optimizedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "OPTIMIZE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RESET_ROUTE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RouteLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ROUTE",
                "name": "Open Route",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Route"
                  }
                ]
              },
              {
                "key": "OPTIMIZE",
                "name": "Optimize",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET_ROUTE",
                "name": "Reset Route",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading routes…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RouteLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "map"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "map",
                              "label": "Total routes",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "check-circle",
                              "value": "14",
                              "type": "stat-display",
                              "label": "Optimized today"
                            },
                            {
                              "label": "Total distance",
                              "value": "1,284 km",
                              "type": "stat-display",
                              "icon": "navigation"
                            },
                            {
                              "label": "Avg duration",
                              "value": "92 min",
                              "type": "stat-display",
                              "icon": "clock"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "gap": "sm",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RouteLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ROUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.technicianId",
                    "@payload.row.technicianId"
                  ],
                  [
                    "set",
                    "@entity.originLat",
                    "@payload.row.originLat"
                  ],
                  [
                    "set",
                    "@entity.originLng",
                    "@payload.row.originLng"
                  ],
                  [
                    "set",
                    "@entity.totalDistanceKm",
                    "@payload.row.totalDistanceKm"
                  ],
                  [
                    "set",
                    "@entity.totalDurationMinutes",
                    "@payload.row.totalDurationMinutes"
                  ],
                  [
                    "set",
                    "@entity.optimizedAt",
                    "@payload.row.optimizedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "map"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.technicianId"
                            },
                            {
                              "label": "Optimized",
                              "variant": "success",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Origin lat",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.originLat",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Origin lng"
                                },
                                {
                                  "content": "@entity.originLng",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "label": "Distance (km)",
                              "type": "stat-display",
                              "value": "@entity.totalDistanceKm",
                              "icon": "navigation"
                            },
                            {
                              "icon": "clock",
                              "label": "Duration (min)",
                              "value": "@entity.totalDurationMinutes",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.optimizedAt",
                              "label": "Last optimized",
                              "type": "stat-display",
                              "icon": "calendar"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "OPTIMIZE",
                              "variant": "primary",
                              "label": "Optimize",
                              "type": "button"
                            },
                            {
                              "action": "RESET_ROUTE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "type": "button",
                              "label": "Reset"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "OPTIMIZE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Optimizing route…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RESET_ROUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Resetting route…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading routes…"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "OPTIMIZE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Optimizing route…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RESET_ROUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Resetting route…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "cycleCountFrequencyDays": {
              "type": "number",
              "default": 30.0,
              "label": "Cycle count cadence (days)",
              "description": "Days between scheduled cycle counts on vehicles assigned to optimized routes. v1.2 declarative.",
              "tier": "domain"
            },
            "multiLocationEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Multi-location",
              "description": "Allow routes to span multiple depots/warehouses.",
              "tier": "domain"
            },
            "lotTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Lot tracking",
              "description": "Honor lot/batch tracking when ordering pickups/drops.",
              "tier": "domain"
            },
            "hazmatEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Hazmat routing",
              "description": "Route honors hazmat-restricted lanes and depots.",
              "tier": "domain"
            },
            "expiryTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Expiry tracking",
              "description": "Prioritize near-expiry items in route ordering.",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Routes",
              "label": "Section title",
              "description": "Heading shown above the technician route list",
              "tier": "presentation"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "event": "OPEN_ROUTE",
                  "icon": "arrow-right"
                },
                {
                  "label": "Optimize",
                  "event": "OPTIMIZE",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each route row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Technician",
                  "name": "technicianId"
                },
                {
                  "label": "Distance (km)",
                  "name": "totalDistanceKm",
                  "variant": "caption"
                },
                {
                  "name": "totalDurationMinutes",
                  "label": "Duration (min)",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "optimizedAt",
                  "label": "Optimized"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Route entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "defaultWarehouse": {
              "type": "string",
              "default": "",
              "label": "Default depot / warehouse",
              "description": "Origin depot routes start from by default.",
              "tier": "domain"
            },
            "serialTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Serial tracking",
              "description": "Honor serial-tracked items on route stops. v1.2 declarative.",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RouteOptimizePage",
          "path": "/routes/optimize",
          "traits": [
            {
              "ref": "RouteOptimize"
            }
          ]
        }
      ]
    }
  ]
}