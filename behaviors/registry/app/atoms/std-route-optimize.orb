{
  "name": "std-route-optimize",
  "version": "1.1.0",
  "description": "std-route-optimize — multi-stop route ordering for technician dispatch. Lists routes in `browsing`; opens detail in `viewing_single` with Optimize / Reset actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "RouteOptimizeOrbital",
      "entity": {
        "name": "Route",
        "collection": "routes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "technicianId",
            "type": "string"
          },
          {
            "name": "originLat",
            "type": "number"
          },
          {
            "name": "originLng",
            "type": "number"
          },
          {
            "name": "stops",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "totalDistanceKm",
            "type": "number"
          },
          {
            "name": "totalDurationMinutes",
            "type": "number"
          },
          {
            "name": "optimizedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RouteOptimize",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "OPEN_ROUTE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.technicianId",
                  "type": "string"
                },
                {
                  "name": "row.originLat",
                  "type": "number"
                },
                {
                  "name": "row.originLng",
                  "type": "number"
                },
                {
                  "name": "row.stops",
                  "type": "[string]"
                },
                {
                  "name": "row.totalDistanceKm",
                  "type": "number"
                },
                {
                  "name": "row.totalDurationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.optimizedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "OPTIMIZE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RESET_ROUTE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RouteLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ROUTE",
                "name": "Open Route",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Route"
                  }
                ]
              },
              {
                "key": "OPTIMIZE",
                "name": "Optimize",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET_ROUTE",
                "name": "Reset Route",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading routes…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RouteLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "map"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total routes",
                              "value": "@payload.data.length",
                              "icon": "map"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "14",
                              "label": "Optimized today"
                            },
                            {
                              "value": "1,284 km",
                              "label": "Total distance",
                              "type": "stat-display",
                              "icon": "navigation"
                            },
                            {
                              "icon": "clock",
                              "value": "92 min",
                              "type": "stat-display",
                              "label": "Avg duration"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RouteLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ROUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.technicianId",
                    "@payload.row.technicianId"
                  ],
                  [
                    "set",
                    "@entity.originLat",
                    "@payload.row.originLat"
                  ],
                  [
                    "set",
                    "@entity.originLng",
                    "@payload.row.originLng"
                  ],
                  [
                    "set",
                    "@entity.totalDistanceKm",
                    "@payload.row.totalDistanceKm"
                  ],
                  [
                    "set",
                    "@entity.totalDurationMinutes",
                    "@payload.row.totalDurationMinutes"
                  ],
                  [
                    "set",
                    "@entity.optimizedAt",
                    "@payload.row.optimizedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "variant": "ghost",
                              "label": "Back",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "map",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.technicianId"
                            },
                            {
                              "type": "badge",
                              "label": "Optimized",
                              "variant": "success"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Origin lat",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.originLat"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Origin lng",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.originLng",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Distance (km)",
                              "value": "@entity.totalDistanceKm",
                              "icon": "navigation"
                            },
                            {
                              "label": "Duration (min)",
                              "value": "@entity.totalDurationMinutes",
                              "icon": "clock",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.optimizedAt",
                              "type": "stat-display",
                              "label": "Last optimized",
                              "icon": "calendar"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "label": "Optimize",
                              "variant": "primary",
                              "type": "button",
                              "action": "OPTIMIZE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Reset",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "type": "button",
                              "action": "RESET_ROUTE"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "OPTIMIZE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Optimizing route…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RESET_ROUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Resetting route…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading routes…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "OPTIMIZE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Optimizing route…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RESET_ROUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Resetting route…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Technician",
                  "variant": "caption",
                  "name": "technicianId"
                },
                {
                  "name": "totalDistanceKm",
                  "label": "Distance (km)",
                  "variant": "caption"
                },
                {
                  "label": "Duration (min)",
                  "variant": "caption",
                  "name": "totalDurationMinutes"
                },
                {
                  "variant": "caption",
                  "name": "optimizedAt",
                  "label": "Optimized"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Route entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "event": "OPEN_ROUTE",
                  "icon": "arrow-right"
                },
                {
                  "event": "OPTIMIZE",
                  "label": "Optimize",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each route row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Routes",
              "label": "Section title",
              "description": "Heading shown above the technician route list",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RouteOptimizePage",
          "path": "/routes/optimize",
          "traits": [
            {
              "ref": "RouteOptimize"
            }
          ]
        }
      ]
    }
  ]
}
