{
  "name": "std-route-optimize",
  "version": "1.0.0",
  "description": "std-route-optimize — multi-stop route ordering for technician dispatch. Owns a Route entity (origin coords + ordered stops + totals); OPTIMIZE invokes the route-optimize service to reorder stops, then persists the updated row and emits RouteUpdated for downstream listeners.",
  "orbitals": [
    {
      "name": "RouteOptimizeOrbital",
      "entity": {
        "name": "Route",
        "collection": "routes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "technicianId",
            "type": "string"
          },
          {
            "name": "originLat",
            "type": "number"
          },
          {
            "name": "originLng",
            "type": "number"
          },
          {
            "name": "stops",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "totalDistanceKm",
            "type": "number"
          },
          {
            "name": "totalDurationMinutes",
            "type": "number"
          },
          {
            "name": "optimizedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RouteOptimize",
          "category": "interaction",
          "linkedEntity": "Route",
          "emits": [
            {
              "event": "OPTIMIZE",
              "payloadSchema": [
                {
                  "name": "routeId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RouteLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Route]"
                }
              ]
            },
            {
              "event": "RouteLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteOptimized",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.technicianId",
                  "type": "string"
                },
                {
                  "name": "row.originLat",
                  "type": "number"
                },
                {
                  "name": "row.originLng",
                  "type": "number"
                },
                {
                  "name": "row.stops",
                  "type": "[string]"
                },
                {
                  "name": "row.totalDistanceKm",
                  "type": "number"
                },
                {
                  "name": "row.totalDurationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.optimizedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteOptimizeFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RouteUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.technicianId",
                  "type": "string"
                },
                {
                  "name": "row.originLat",
                  "type": "number"
                },
                {
                  "name": "row.originLng",
                  "type": "number"
                },
                {
                  "name": "row.stops",
                  "type": "[string]"
                },
                {
                  "name": "row.totalDistanceKm",
                  "type": "number"
                },
                {
                  "name": "row.totalDurationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.optimizedAt",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "optimizing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RouteLoaded",
                "name": "Route loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Route]"
                  }
                ]
              },
              {
                "key": "RouteLoadFailed",
                "name": "Route load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPTIMIZE",
                "name": "Optimize",
                "payloadSchema": [
                  {
                    "name": "routeId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RouteUpdated",
                "name": "Route updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Route"
                  }
                ]
              },
              {
                "key": "RouteOptimized",
                "name": "Route optimized",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Route"
                  }
                ]
              },
              {
                "key": "RouteOptimizeFailed",
                "name": "Route optimize failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "failure": "RouteLoadFailed",
                        "success": "RouteLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading routes…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RouteLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "map"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Optimize",
                              "event": "OPTIMIZE",
                              "variant": "primary",
                              "icon": "route"
                            }
                          ],
                          "gap": "sm",
                          "cols": 1.0,
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "technicianId",
                              "label": "Technician",
                              "variant": "caption"
                            },
                            {
                              "label": "Stops",
                              "variant": "caption",
                              "name": "stops"
                            },
                            {
                              "name": "totalDistanceKm",
                              "label": "Distance (km)",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "label": "Duration (min)",
                              "name": "totalDurationMinutes"
                            },
                            {
                              "label": "Optimized",
                              "variant": "caption",
                              "name": "optimizedAt"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RouteLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "optimizing",
                "event": "OPTIMIZE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.routeId"
                  ],
                  [
                    "call-service",
                    "route-optimize",
                    "optimize",
                    "@entity",
                    {
                      "emit": {
                        "success": "RouteOptimized",
                        "failure": "RouteOptimizeFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Optimizing route…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RouteUpdated",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Route updated"
                    }
                  ]
                ]
              },
              {
                "from": "optimizing",
                "to": "browsing",
                "event": "RouteOptimized",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Route",
                    "@payload.row",
                    {
                      "emit": {
                        "success": "RouteUpdated",
                        "failure": "RouteOptimizeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "optimizing",
                "to": "browsing",
                "event": "RouteOptimizeFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Route",
                    {
                      "emit": {
                        "success": "RouteLoaded",
                        "failure": "RouteLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Routes"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RouteOptimizePage",
          "path": "/routes/optimize",
          "traits": [
            {
              "ref": "RouteOptimize"
            }
          ]
        }
      ]
    }
  ]
}
