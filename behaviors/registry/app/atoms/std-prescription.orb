{
  "name": "std-prescription",
  "version": "1.0.0",
  "description": "std-prescription — prescription lifecycle (draft → signed → sent → dispensed) with controlled-substance, refill, and pharmacist-consult knobs.",
  "orbitals": [
    {
      "name": "PrescriptionOrbital",
      "entity": {
        "name": "Prescription",
        "collection": "prescriptions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "patientId",
            "type": "string",
            "required": true
          },
          {
            "name": "medication",
            "type": "string",
            "required": true
          },
          {
            "name": "dosage",
            "type": "string",
            "default": ""
          },
          {
            "name": "quantity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "refillsRemaining",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "controlled",
            "type": "boolean",
            "default": false
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "signed",
              "sent",
              "dispensed",
              "expired",
              "voided"
            ]
          },
          {
            "name": "prescribedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "pharmacy",
            "type": "string",
            "default": ""
          },
          {
            "name": "signedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "PrescriptionManage",
          "category": "interaction",
          "linkedEntity": "Prescription",
          "emits": [
            {
              "event": "OPEN_RX",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.patientId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.medication",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dosage",
                  "type": "string"
                },
                {
                  "name": "row.quantity",
                  "type": "number"
                },
                {
                  "name": "row.refillsRemaining",
                  "type": "number"
                },
                {
                  "name": "row.controlled",
                  "type": "boolean"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.prescribedBy",
                  "type": "string"
                },
                {
                  "name": "row.pharmacy",
                  "type": "string"
                },
                {
                  "name": "row.signedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SIGN_RX",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SEND_RX",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DISPENSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_RX",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PrescriptionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Prescription]"
                }
              ]
            },
            {
              "event": "PrescriptionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PrescriptionUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.patientId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.medication",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dosage",
                  "type": "string"
                },
                {
                  "name": "row.quantity",
                  "type": "number"
                },
                {
                  "name": "row.refillsRemaining",
                  "type": "number"
                },
                {
                  "name": "row.controlled",
                  "type": "boolean"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.prescribedBy",
                  "type": "string"
                },
                {
                  "name": "row.pharmacy",
                  "type": "string"
                },
                {
                  "name": "row.signedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PrescriptionUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PrescriptionLoaded",
                "name": "Prescription loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Prescription]"
                  }
                ]
              },
              {
                "key": "PrescriptionLoadFailed",
                "name": "Prescription load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RX",
                "name": "Open Rx",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Prescription"
                  }
                ]
              },
              {
                "key": "VOID_RX",
                "name": "Void Rx",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PrescriptionUpdated",
                "name": "Prescription updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Prescription"
                  }
                ]
              },
              {
                "key": "PrescriptionUpdateFailed",
                "name": "Prescription update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SIGN_RX",
                "name": "Sign Rx",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SEND_RX",
                "name": "Send Rx",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DISPENSE",
                "name": "Dispense",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Prescription",
                    {
                      "emit": {
                        "success": "PrescriptionLoaded",
                        "failure": "PrescriptionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading prescriptions…",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PrescriptionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "file-text",
                              "label": "Total Rx"
                            },
                            {
                              "value": "0",
                              "label": "Pending sign",
                              "icon": "edit",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "0",
                              "label": "Dispensed today"
                            },
                            {
                              "value": "0",
                              "type": "stat-display",
                              "label": "Controlled",
                              "icon": "shield"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PrescriptionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RX",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.patientId",
                    "@payload.row.patientId"
                  ],
                  [
                    "set",
                    "@entity.medication",
                    "@payload.row.medication"
                  ],
                  [
                    "set",
                    "@entity.dosage",
                    "@payload.row.dosage"
                  ],
                  [
                    "set",
                    "@entity.quantity",
                    "@payload.row.quantity"
                  ],
                  [
                    "set",
                    "@entity.refillsRemaining",
                    "@payload.row.refillsRemaining"
                  ],
                  [
                    "set",
                    "@entity.controlled",
                    "@payload.row.controlled"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.prescribedBy",
                    "@payload.row.prescribedBy"
                  ],
                  [
                    "set",
                    "@entity.pharmacy",
                    "@payload.row.pharmacy"
                  ],
                  [
                    "set",
                    "@entity.signedAt",
                    "@payload.row.signedAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.medication",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Patient",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.patientId"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Dosage",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.dosage",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Pharmacy",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.pharmacy",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Prescriber",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.prescribedBy",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.quantity",
                              "icon": "hash",
                              "label": "Quantity",
                              "type": "stat-display"
                            },
                            {
                              "label": "Refills left",
                              "icon": "repeat",
                              "type": "stat-display",
                              "value": "@entity.refillsRemaining"
                            },
                            {
                              "label": "Signed",
                              "icon": "calendar",
                              "value": "@entity.signedAt",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 3.0
                        },
                        {
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Sign",
                              "action": "SIGN_RX",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "variant": "primary",
                              "action": "SEND_RX",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Send"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "DISPENSE",
                              "label": "Dispense",
                              "variant": "primary",
                              "type": "button"
                            },
                            {
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "VOID_RX",
                              "label": "Void"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "VOID_RX",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "voided"
                  ],
                  [
                    "persist",
                    "update",
                    "Prescription",
                    "@entity",
                    {
                      "emit": {
                        "failure": "PrescriptionUpdateFailed",
                        "success": "PrescriptionUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Voiding prescription…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PrescriptionUpdated",
                "effects": [
                  [
                    "fetch",
                    "Prescription",
                    {
                      "emit": {
                        "success": "PrescriptionLoaded",
                        "failure": "PrescriptionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PrescriptionUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Prescription",
                    "@entity",
                    {
                      "emit": {
                        "success": "PrescriptionUpdated",
                        "failure": "PrescriptionUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Updating prescription status…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Prescription",
                    {
                      "emit": {
                        "success": "PrescriptionLoaded",
                        "failure": "PrescriptionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading prescriptions…"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SIGN_RX",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "signed"
                  ],
                  [
                    "set",
                    "@entity.signedAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "Prescription",
                    "@entity",
                    {
                      "emit": {
                        "success": "PrescriptionUpdated",
                        "failure": "PrescriptionUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Signing prescription…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SEND_RX",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "persist",
                    "update",
                    "Prescription",
                    "@entity",
                    {
                      "emit": {
                        "failure": "PrescriptionUpdateFailed",
                        "success": "PrescriptionUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Sending prescription…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DISPENSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "dispensed"
                  ],
                  [
                    "persist",
                    "update",
                    "Prescription",
                    "@entity",
                    {
                      "emit": {
                        "success": "PrescriptionUpdated",
                        "failure": "PrescriptionUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Dispensing prescription…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VOID_RX",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "voided"
                  ],
                  [
                    "persist",
                    "update",
                    "Prescription",
                    "@entity",
                    {
                      "emit": {
                        "failure": "PrescriptionUpdateFailed",
                        "success": "PrescriptionUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Voiding prescription…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Prescription",
                    {
                      "emit": {
                        "success": "PrescriptionLoaded",
                        "failure": "PrescriptionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "epaRequired": {
              "type": "boolean",
              "default": false,
              "label": "EPA required",
              "description": "When true, controlled-substance prescriptions require electronic-prescribing-of-controlled-substances signing.",
              "synonyms": "EPCS",
              "tier": "domain"
            },
            "controlledSubstanceSchedule": {
              "type": "string",
              "default": "none",
              "label": "Controlled-substance schedule",
              "description": "DEA schedule. Drives e-prescribing + paper-trail requirements.",
              "synonyms": "DEA schedule, narcotic class",
              "tier": "domain",
              "values": [
                "none",
                "II",
                "III",
                "IV",
                "V"
              ]
            },
            "genericSubstitutionAllowed": {
              "type": "string",
              "default": "patient-consent",
              "label": "Generic substitution",
              "description": "Policy for substituting brand→generic at the pharmacy.",
              "tier": "domain",
              "values": [
                "always",
                "patient-consent",
                "prescriber-only",
                "never"
              ]
            },
            "priorAuthRequiredFor": {
              "type": "[string]",
              "default": [],
              "label": "Prior-auth required for",
              "description": "Medications requiring insurance prior-authorization before dispensing.",
              "synonyms": "PA required, insurance pre-approval",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "refillsAllowedPerYear": {
              "type": "number",
              "default": 5.0,
              "label": "Max refills per year",
              "description": "Annual cap on refills for the same prescription.",
              "tier": "domain"
            },
            "pharmacistConsultationRequired": {
              "type": "string",
              "default": "controlled-only",
              "label": "Pharmacist consultation",
              "description": "When the pharmacist must counsel the patient at pickup.",
              "tier": "domain",
              "values": [
                "always",
                "controlled-only",
                "high-risk",
                "never"
              ]
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_RX",
                  "variant": "primary",
                  "label": "Open"
                },
                {
                  "event": "VOID_RX",
                  "label": "Void",
                  "icon": "x",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each prescription row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Prescriptions",
              "label": "Section title",
              "description": "Heading shown above the prescription list",
              "tier": "presentation"
            },
            "dispenseQuantityLimit": {
              "type": "number",
              "default": 90.0,
              "label": "Dispense quantity limit",
              "description": "Maximum days-supply dispensed per fill.",
              "synonyms": "days supply, fill limit",
              "tier": "domain"
            },
            "dawCodeRequired": {
              "type": "boolean",
              "default": false,
              "label": "DAW code required",
              "description": "When true, prescriber must include a Dispense-As-Written code on every Rx.",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "medication",
                  "label": "Medication",
                  "variant": "caption"
                },
                {
                  "label": "Patient",
                  "variant": "caption",
                  "name": "patientId"
                },
                {
                  "label": "Dosage",
                  "variant": "caption",
                  "name": "dosage"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "label": "Pharmacy",
                  "name": "pharmacy",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "prescribedBy",
                  "label": "Prescriber"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Prescription entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PrescriptionManagePage",
          "path": "/prescriptions",
          "traits": [
            {
              "ref": "PrescriptionManage"
            }
          ]
        }
      ]
    }
  ]
}