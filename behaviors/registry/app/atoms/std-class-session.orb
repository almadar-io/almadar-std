{
  "name": "std-class-session",
  "version": "1.2.0",
  "description": "std-class-session — scheduled fitness/class session. Listens for SET_STATUS so sibling std-lifecycle can auto-transition. Exposes Scheduling/Booking knobs (bookingWindowDays, leadTimeMinutes, cancellationPolicy, …).",
  "orbitals": [
    {
      "name": "ClassSessionOrbital",
      "entity": {
        "name": "ClassSession",
        "collection": "classsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "className",
            "type": "string",
            "required": true
          },
          {
            "name": "instructorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "startTime",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "capacity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "bookedCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "location",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "scheduled",
            "values": [
              "scheduled",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ClassSessionSchedule",
          "category": "interaction",
          "linkedEntity": "ClassSession",
          "emits": [
            {
              "event": "OPEN_SESSION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.className",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.instructorName",
                  "type": "string"
                },
                {
                  "name": "row.startTime",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.durationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.capacity",
                  "type": "number"
                },
                {
                  "name": "row.bookedCount",
                  "type": "number"
                },
                {
                  "name": "row.location",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "START_CLASS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_CLASS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ClassSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ClassSession]"
                }
              ]
            },
            {
              "event": "ClassSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ClassSessionLoaded",
                "name": "ClassSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ClassSession]"
                  }
                ]
              },
              {
                "key": "ClassSessionLoadFailed",
                "name": "ClassSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SESSION",
                "name": "Open Session",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ClassSession"
                  }
                ]
              },
              {
                "key": "CANCEL_CLASS",
                "name": "Cancel Class",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "START_CLASS",
                "name": "Start Class",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading class sessions…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ClassSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "calendar"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "calendar",
                              "label": "Sessions",
                              "type": "stat-display"
                            },
                            {
                              "icon": "clock",
                              "type": "stat-display",
                              "value": "12",
                              "label": "Today"
                            },
                            {
                              "type": "stat-display",
                              "label": "Capacity used",
                              "icon": "users",
                              "value": "78%"
                            },
                            {
                              "type": "stat-display",
                              "label": "Cancelled",
                              "icon": "x-circle",
                              "value": "2"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "gap": "sm",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ClassSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.className",
                    "@payload.row.className"
                  ],
                  [
                    "set",
                    "@entity.instructorName",
                    "@payload.row.instructorName"
                  ],
                  [
                    "set",
                    "@entity.startTime",
                    "@payload.row.startTime"
                  ],
                  [
                    "set",
                    "@entity.durationMinutes",
                    "@payload.row.durationMinutes"
                  ],
                  [
                    "set",
                    "@entity.capacity",
                    "@payload.row.capacity"
                  ],
                  [
                    "set",
                    "@entity.bookedCount",
                    "@payload.row.bookedCount"
                  ],
                  [
                    "set",
                    "@entity.location",
                    "@payload.row.location"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "variant": "ghost"
                            },
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.className"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Instructor",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.instructorName",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "content": "Location",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.location"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Notes"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.notes"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "@entity.startTime",
                              "label": "Start"
                            },
                            {
                              "type": "stat-display",
                              "icon": "timer",
                              "value": "@entity.durationMinutes",
                              "label": "Duration"
                            },
                            {
                              "value": "@entity.bookedCount",
                              "label": "Booked",
                              "type": "stat-display",
                              "icon": "users"
                            },
                            {
                              "value": "@entity.capacity",
                              "label": "Capacity",
                              "type": "stat-display",
                              "icon": "user-plus"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Start Class",
                              "variant": "primary",
                              "action": "START_CLASS",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            },
                            {
                              "label": "Cancel",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "CANCEL_CLASS"
                            }
                          ]
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "success": "ClassSessionLoaded",
                        "failure": "ClassSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Cancelling class…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "ClassSession",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Updating session status…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading class sessions…"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "START_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Starting class…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling class…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "success": "ClassSessionLoaded",
                        "failure": "ClassSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Class",
                  "variant": "caption",
                  "name": "className"
                },
                {
                  "label": "Instructor",
                  "name": "instructorName",
                  "variant": "caption"
                },
                {
                  "label": "Start",
                  "name": "startTime",
                  "variant": "caption"
                },
                {
                  "label": "Capacity",
                  "name": "capacity",
                  "variant": "badge"
                },
                {
                  "variant": "badge",
                  "name": "bookedCount",
                  "label": "Booked"
                },
                {
                  "variant": "badge",
                  "label": "Status",
                  "name": "status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Class Session entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 4.0,
              "label": "Reschedule window (hours)",
              "description": "Hours before startTime during which the member can self-reschedule.",
              "tier": "domain"
            },
            "noShowGracePeriodMinutes": {
              "type": "number",
              "default": 10.0,
              "label": "No-show grace (minutes)",
              "description": "Minutes after startTime before a no-show penalty applies. Wire via std-lifecycle.",
              "tier": "domain"
            },
            "maxReschedules": {
              "type": "number",
              "default": 3.0,
              "label": "Max reschedules",
              "description": "Hard cap on reschedule count per session booking.",
              "tier": "domain"
            },
            "policyId": {
              "type": "string",
              "default": "",
              "label": "Appointment policy reference",
              "description": "Optional reference to a shared std-appointment-policy entity. When set, the policy's reschedule/cancellation/no-show values supersede the local knobs. Declarative — runtime resolution lands separately.",
              "synonyms": "policy ref, shared policy, policy id",
              "tier": "domain"
            },
            "blackoutDates": {
              "type": "[string]",
              "default": [],
              "label": "Blackout dates",
              "description": "ISO dates blocked from booking (e.g. holidays, deep-cleans). Compose std-lifecycle to enforce.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_SESSION",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "label": "Cancel",
                  "event": "CANCEL_CLASS",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each session row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "bookingHours": {
              "type": "string",
              "default": "06:00-22:00",
              "label": "Booking hours",
              "description": "Daily window during which sessions can be booked (HH:MM-HH:MM).",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Class Sessions",
              "label": "Section title",
              "description": "Heading shown above the class schedule",
              "tier": "presentation"
            },
            "bookingWindowDays": {
              "type": "number",
              "default": 30.0,
              "label": "Booking window (days)",
              "description": "How far in advance members can book a session.",
              "tier": "domain"
            },
            "leadTimeMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "Lead time (minutes)",
              "description": "Minimum minutes before startTime that booking is allowed.",
              "tier": "domain"
            },
            "cancellationPolicy": {
              "type": "string",
              "default": "free",
              "label": "Cancellation policy",
              "description": "Refund treatment when a session is cancelled inside the reschedule window.",
              "tier": "domain",
              "values": [
                "free",
                "partial-refund",
                "no-refund"
              ]
            }
          },
