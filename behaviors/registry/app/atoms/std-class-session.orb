{
  "name": "std-class-session",
  "version": "1.0.0",
  "description": "std-class-session — scheduled fitness/yoga/dance class session primitive. Tracks instructor, time, capacity, and attendance; START_CLASS / CANCEL_CLASS drive lifecycle transitions for studio operators.",
  "orbitals": [
    {
      "name": "ClassSessionOrbital",
      "entity": {
        "name": "ClassSession",
        "collection": "classsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "className",
            "type": "string",
            "required": true
          },
          {
            "name": "instructorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "startTime",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "capacity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "bookedCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "location",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "scheduled",
            "values": [
              "scheduled",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ClassSessionSchedule",
          "category": "interaction",
          "linkedEntity": "ClassSession",
          "emits": [
            {
              "event": "START_CLASS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_CLASS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ClassSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ClassSession]"
                }
              ]
            },
            {
              "event": "ClassSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ClassSessionLoaded",
                "name": "ClassSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ClassSession]"
                  }
                ]
              },
              {
                "key": "ClassSessionLoadFailed",
                "name": "ClassSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "START_CLASS",
                "name": "Start Class",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_CLASS",
                "name": "Cancel Class",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading class sessions…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ClassSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "calendar"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "calendar-grid"
                        },
                        {
                          "type": "media-gallery",
                          "title": "Studio photos",
                          "columns": 3.0,
                          "items": [
                            {
                              "alt": "Studio",
                              "src": "https://picsum.photos/seed/studio1/800/600"
                            },
                            {
                              "alt": "Studio",
                              "src": "https://picsum.photos/seed/studio2/800/600"
                            },
                            {
                              "src": "https://picsum.photos/seed/studio3/800/600",
                              "alt": "Studio"
                            }
                          ]
                        },
                        {
                          "type": "star-rating",
                          "max": 5.0,
                          "value": 4.5,
                          "label": "Class rating",
                          "readOnly": true
                        },
                        {
                          "type": "accordion",
                          "items": [
                            {
                              "title": "Equipment",
                              "content": "Mat, blocks, strap",
                              "id": "equipment"
                            },
                            {
                              "content": "Curated session playlist",
                              "id": "playlist",
                              "title": "Playlist"
                            }
                          ]
                        },
                        {
                          "type": "lightbox",
                          "isOpen": false,
                          "currentIndex": 0.0,
                          "showCounter": true,
                          "images": [
                            {
                              "alt": "Studio",
                              "src": "https://picsum.photos/seed/studio1/1200/800",
                              "caption": "Studio"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "fields": [
                            {
                              "label": "Class",
                              "variant": "caption",
                              "name": "className"
                            },
                            {
                              "name": "instructorName",
                              "label": "Instructor",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "label": "Start",
                              "name": "startTime"
                            },
                            {
                              "name": "capacity",
                              "label": "Capacity",
                              "variant": "badge"
                            },
                            {
                              "name": "bookedCount",
                              "label": "Booked",
                              "variant": "badge"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "gap": "sm",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Start",
                              "event": "START_CLASS"
                            },
                            {
                              "event": "CANCEL_CLASS",
                              "variant": "danger",
                              "label": "Cancel"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ClassSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "START_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Class started"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Class cancelled",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading class sessions…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Class Sessions"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ClassSessionPage",
          "path": "/class-sessions",
          "traits": [
            {
              "ref": "ClassSessionSchedule"
            }
          ]
        }
      ]
    }
  ]
}