{
  "name": "std-class-session",
  "version": "1.0.0",
  "description": "std-class-session — scheduled fitness/yoga/dance class session. Lists sessions in `browsing`; opens session detail in `viewing_single` with Start / Cancel actions.",
  "orbitals": [
    {
      "name": "ClassSessionOrbital",
      "entity": {
        "name": "ClassSession",
        "collection": "classsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "className",
            "type": "string",
            "required": true
          },
          {
            "name": "instructorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "startTime",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "capacity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "bookedCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "location",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "scheduled",
            "values": [
              "scheduled",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ClassSessionSchedule",
          "category": "interaction",
          "linkedEntity": "ClassSession",
          "emits": [
            {
              "event": "OPEN_SESSION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.className",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.instructorName",
                  "type": "string"
                },
                {
                  "name": "row.startTime",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.durationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.capacity",
                  "type": "number"
                },
                {
                  "name": "row.bookedCount",
                  "type": "number"
                },
                {
                  "name": "row.location",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "START_CLASS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_CLASS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ClassSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ClassSession]"
                }
              ]
            },
            {
              "event": "ClassSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ClassSessionLoaded",
                "name": "ClassSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ClassSession]"
                  }
                ]
              },
              {
                "key": "ClassSessionLoadFailed",
                "name": "ClassSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SESSION",
                "name": "Open Session",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ClassSession"
                  }
                ]
              },
              {
                "key": "CANCEL_CLASS",
                "name": "Cancel Class",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "START_CLASS",
                "name": "Start Class",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "success": "ClassSessionLoaded",
                        "failure": "ClassSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading class sessions…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ClassSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "calendar",
                              "label": "Sessions",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "clock",
                              "label": "Today",
                              "value": "12",
                              "type": "stat-display"
                            },
                            {
                              "value": "78%",
                              "type": "stat-display",
                              "label": "Capacity used",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "value": "2",
                              "icon": "x-circle",
                              "label": "Cancelled"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "name": "className",
                              "label": "Class",
                              "variant": "caption"
                            },
                            {
                              "label": "Instructor",
                              "name": "instructorName",
                              "variant": "caption"
                            },
                            {
                              "name": "startTime",
                              "label": "Start",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Capacity",
                              "name": "capacity"
                            },
                            {
                              "label": "Booked",
                              "variant": "badge",
                              "name": "bookedCount"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "cols": 1.0,
                          "type": "data-grid",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Open",
                              "icon": "arrow-right",
                              "event": "OPEN_SESSION",
                              "variant": "primary"
                            },
                            {
                              "event": "CANCEL_CLASS",
                              "variant": "danger",
                              "label": "Cancel"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ClassSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.className",
                    "@payload.row.className"
                  ],
                  [
                    "set",
                    "@entity.instructorName",
                    "@payload.row.instructorName"
                  ],
                  [
                    "set",
                    "@entity.startTime",
                    "@payload.row.startTime"
                  ],
                  [
                    "set",
                    "@entity.durationMinutes",
                    "@payload.row.durationMinutes"
                  ],
                  [
                    "set",
                    "@entity.capacity",
                    "@payload.row.capacity"
                  ],
                  [
                    "set",
                    "@entity.bookedCount",
                    "@payload.row.bookedCount"
                  ],
                  [
                    "set",
                    "@entity.location",
                    "@payload.row.location"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.className",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "variant": "default",
                              "label": "@entity.status"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Instructor",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.instructorName",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Location"
                                },
                                {
                                  "content": "@entity.location",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Notes",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Start",
                              "type": "stat-display",
                              "value": "@entity.startTime",
                              "icon": "clock"
                            },
                            {
                              "value": "@entity.durationMinutes",
                              "icon": "timer",
                              "label": "Duration",
                              "type": "stat-display"
                            },
                            {
                              "icon": "users",
                              "type": "stat-display",
                              "value": "@entity.bookedCount",
                              "label": "Booked"
                            },
                            {
                              "icon": "user-plus",
                              "value": "@entity.capacity",
                              "label": "Capacity",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "action": "START_CLASS",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary",
                              "label": "Start Class"
                            },
                            {
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Cancel",
                              "action": "CANCEL_CLASS"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "success": "ClassSessionLoaded",
                        "failure": "ClassSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Cancelling class…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading class sessions…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "START_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "failure": "ClassSessionLoadFailed",
                        "success": "ClassSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Starting class…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_CLASS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "success": "ClassSessionLoaded",
                        "failure": "ClassSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling class…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ClassSession",
                    {
                      "emit": {
                        "success": "ClassSessionLoaded",
                        "failure": "ClassSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Class Sessions"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ClassSessionPage",
          "path": "/class-sessions",
          "traits": [
            {
              "ref": "ClassSessionSchedule"
            }
          ]
        }
      ]
    }
  ]
}
