{
  "name": "std-checkin",
  "version": "1.1.0",
  "description": "std-checkin — arrival check-in atom listing recorded check-ins (qr or geo). Lists check-ins in `browsing`; opens detail in `viewing_single` with Verify / Revoke actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "CheckinOrbital",
      "entity": {
        "name": "Checkin",
        "collection": "checkins",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "mode",
            "type": "string",
            "default": "geo",
            "values": [
              "geo",
              "qr"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "userId",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "qrCode",
            "type": "string"
          },
          {
            "name": "verified",
            "type": "boolean",
            "default": false
          },
          {
            "name": "checkedInAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "CheckinScan",
          "category": "interaction",
          "linkedEntity": "Checkin",
          "emits": [
            {
              "event": "OPEN_CHECKIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.mode",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.qrCode",
                  "type": "string"
                },
                {
                  "name": "row.verified",
                  "type": "boolean"
                },
                {
                  "name": "row.checkedInAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "VERIFY_CHECKIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVOKE_CHECKIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckinLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Checkin]"
                }
              ]
            },
            {
              "event": "CheckinLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckinLoaded",
                "name": "Checkin loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Checkin]"
                  }
                ]
              },
              {
                "key": "CheckinLoadFailed",
                "name": "Checkin load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CHECKIN",
                "name": "Open Checkin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Checkin"
                  }
                ]
              },
              {
                "key": "REVOKE_CHECKIN",
                "name": "Revoke Checkin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "VERIFY_CHECKIN",
                "name": "Verify Checkin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading check-ins…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CheckinLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "name": "map-pin",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "map-pin",
                              "label": "Total check-ins",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "value": "92%",
                              "label": "Verified",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "icon": "calendar",
                              "label": "Today",
                              "value": "47"
                            },
                            {
                              "value": "18",
                              "icon": "globe",
                              "label": "Sites covered",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckinLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.mode",
                    "@payload.row.mode"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.row.targetId"
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    "@payload.row.targetType"
                  ],
                  [
                    "set",
                    "@entity.userId",
                    "@payload.row.userId"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.row.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.row.lng"
                  ],
                  [
                    "set",
                    "@entity.qrCode",
                    "@payload.row.qrCode"
                  ],
                  [
                    "set",
                    "@entity.verified",
                    "@payload.row.verified"
                  ],
                  [
                    "set",
                    "@entity.checkedInAt",
                    "@payload.row.checkedInAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "name": "map-pin",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.targetId",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.mode"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Target type",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.targetType"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "User",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.userId"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "QR code",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.qrCode",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "value": "@entity.lat",
                              "label": "Latitude",
                              "type": "stat-display",
                              "icon": "map"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.lng",
                              "icon": "map",
                              "label": "Longitude"
                            },
                            {
                              "icon": "clock",
                              "label": "Checked in",
                              "value": "@entity.checkedInAt",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Verify",
                              "action": "VERIFY_CHECKIN",
                              "variant": "primary"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Revoke",
                              "variant": "danger",
                              "action": "REVOKE_CHECKIN"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REVOKE_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "failure": "CheckinLoadFailed",
                        "success": "CheckinLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Revoking check-in…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "failure": "CheckinLoadFailed",
                        "success": "CheckinLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading check-ins…",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VERIFY_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Verifying check-in…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REVOKE_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Revoking check-in…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "mode": {
              "type": "string",
              "default": "geo",
              "label": "Check-in mode",
              "description": "How attendees check in (geo location or QR code)"
            },
            "title": {
              "type": "string",
              "default": "Check-ins",
              "label": "Section title",
              "description": "Heading shown above the check-in list"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "badge",
                  "label": "Type",
                  "name": "targetType"
                },
                {
                  "variant": "caption",
                  "name": "targetId",
                  "label": "Target"
                },
                {
                  "label": "User",
                  "variant": "caption",
                  "name": "userId"
                },
                {
                  "name": "mode",
                  "label": "Mode",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "name": "checkedInAt",
                  "label": "When"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Check-in entity",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_CHECKIN"
                },
                {
                  "label": "Revoke",
                  "event": "REVOKE_CHECKIN",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each check-in row",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CheckinScanPage",
          "path": "/checkins",
          "traits": [
            {
              "ref": "CheckinScan"
            }
          ]
        }
      ]
    }
  ]
}