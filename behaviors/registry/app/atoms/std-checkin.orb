{
  "name": "std-checkin",
  "version": "1.2.0",
  "description": "std-checkin — arrival check-in atom (qr / geo). Exposes Scheduling/Booking knobs (bookingWindowDays, leadTimeMinutes, noShowGracePeriodMinutes, …).",
  "orbitals": [
    {
      "name": "CheckinOrbital",
      "entity": {
        "name": "Checkin",
        "collection": "checkins",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "mode",
            "type": "string",
            "default": "geo",
            "values": [
              "geo",
              "qr"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "userId",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "qrCode",
            "type": "string"
          },
          {
            "name": "verified",
            "type": "boolean",
            "default": false
          },
          {
            "name": "checkedInAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "CheckinScan",
          "category": "interaction",
          "linkedEntity": "Checkin",
          "emits": [
            {
              "event": "OPEN_CHECKIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.mode",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.qrCode",
                  "type": "string"
                },
                {
                  "name": "row.verified",
                  "type": "boolean"
                },
                {
                  "name": "row.checkedInAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "VERIFY_CHECKIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVOKE_CHECKIN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckinLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Checkin]"
                }
              ]
            },
            {
              "event": "CheckinLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckinLoaded",
                "name": "Checkin loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Checkin]"
                  }
                ]
              },
              {
                "key": "CheckinLoadFailed",
                "name": "Checkin load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CHECKIN",
                "name": "Open Checkin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Checkin"
                  }
                ]
              },
              {
                "key": "REVOKE_CHECKIN",
                "name": "Revoke Checkin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "VERIFY_CHECKIN",
                "name": "Verify Checkin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "failure": "CheckinLoadFailed",
                        "success": "CheckinLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading check-ins…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CheckinLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "map-pin"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "map-pin",
                              "value": "@payload.data.length",
                              "label": "Total check-ins"
                            },
                            {
                              "label": "Verified",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "value": "92%"
                            },
                            {
                              "value": "47",
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Today"
                            },
                            {
                              "label": "Sites covered",
                              "icon": "globe",
                              "value": "18",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckinLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.mode",
                    "@payload.row.mode"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.row.targetId"
                  ],
                  [
                    "set",
                    "@entity.targetType",
                    "@payload.row.targetType"
                  ],
                  [
                    "set",
                    "@entity.userId",
                    "@payload.row.userId"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.row.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.row.lng"
                  ],
                  [
                    "set",
                    "@entity.qrCode",
                    "@payload.row.qrCode"
                  ],
                  [
                    "set",
                    "@entity.verified",
                    "@payload.row.verified"
                  ],
                  [
                    "set",
                    "@entity.checkedInAt",
                    "@payload.row.checkedInAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "map-pin"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.targetId"
                            },
                            {
                              "label": "@entity.mode",
                              "variant": "primary",
                              "type": "badge"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Target type"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.targetType",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "User",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.userId",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "QR code",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.qrCode",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Latitude",
                              "type": "stat-display",
                              "icon": "map",
                              "value": "@entity.lat"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.lng",
                              "icon": "map",
                              "label": "Longitude"
                            },
                            {
                              "label": "Checked in",
                              "value": "@entity.checkedInAt",
                              "icon": "clock",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "VERIFY_CHECKIN",
                              "type": "button",
                              "label": "Verify",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Revoke",
                              "action": "REVOKE_CHECKIN"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REVOKE_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "failure": "CheckinLoadFailed",
                        "success": "CheckinLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Revoking check-in…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading check-ins…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VERIFY_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Verifying check-in…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REVOKE_CHECKIN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Revoking check-in…"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Type",
                  "variant": "badge",
                  "name": "targetType"
                },
                {
                  "name": "targetId",
                  "label": "Target",
                  "variant": "caption"
                },
                {
                  "label": "User",
                  "variant": "caption",
                  "name": "userId"
                },
                {
                  "name": "mode",
                  "variant": "badge",
                  "label": "Mode"
                },
                {
                  "name": "checkedInAt",
                  "variant": "caption",
                  "label": "When"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Check-in entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "leadTimeMinutes": {
              "type": "number",
              "default": 0.0,
              "label": "Lead time (minutes)",
              "description": "Minutes before scheduled arrival at which check-in is accepted.",
              "tier": "domain"
            },
            "blackoutDates": {
              "type": "[string]",
              "default": [],
              "label": "Blackout dates",
              "description": "ISO dates blocked from check-in. Compose std-lifecycle to enforce.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "bookingWindowDays": {
              "type": "number",
              "default": 1.0,
              "label": "Booking window (days)",
              "description": "How far in advance attendees can pre-register a check-in.",
              "tier": "domain"
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 24.0,
              "label": "Reschedule window (hours)",
              "description": "Hours during which an attendee can amend their pre-registered check-in.",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Check-ins",
              "label": "Section title",
              "description": "Heading shown above the check-in list",
              "tier": "presentation"
            },
            "cancellationPolicy": {
              "type": "string",
              "default": "free",
              "label": "Cancellation policy",
              "description": "Refund treatment when a pre-registered check-in is cancelled.",
              "tier": "domain",
              "values": [
                "free",
                "partial-refund",
                "no-refund"
              ]
            },
            "mode": {
              "type": "string",
              "default": "geo",
              "label": "Check-in mode",
              "description": "How attendees check in (geo location or QR code)",
              "tier": "domain"
            },
            "bookingHours": {
              "type": "string",
              "default": "06:00-23:00",
              "label": "Booking hours",
              "description": "Daily window during which check-ins are accepted (HH:MM-HH:MM).",
              "tier": "domain"
            },
            "maxReschedules": {
              "type": "number",
              "default": 2.0,
              "label": "Max reschedules",
              "description": "Hard cap on reschedule count per pre-registered check-in.",
              "tier": "domain"
            },
            "noShowGracePeriodMinutes": {
              "type": "number",
              "default": 15.0,
              "label": "No-show grace (minutes)",
              "description": "Minutes after the scheduled arrival window before a no-show is logged.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "variant": "primary",
                  "event": "OPEN_CHECKIN",
                  "icon": "arrow-right"
                },
                {
                  "label": "Revoke",
                  "event": "REVOKE_CHECKIN",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each check-in row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CheckinScanPage",
          "path": "/checkins",
          "traits": [
            {
              "ref": "CheckinScan"
            }
          ]
        }
      ]
    }
  ]
}