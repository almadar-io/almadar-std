{
  "name": "std-checkin",
  "version": "1.0.0",
  "description": "std-checkin — unified arrival check-in atom. Config picks the verification mode (qr or geo); SCAN persists the captured location/code against a target (work-order, ticket, or appointment) and emits CheckinRecorded for cross-trait listeners.",
  "orbitals": [
    {
      "name": "CheckinOrbital",
      "entity": {
        "name": "Checkin",
        "collection": "checkins",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "mode",
            "type": "string",
            "default": "geo",
            "values": [
              "geo",
              "qr"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "userId",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "qrCode",
            "type": "string"
          },
          {
            "name": "verified",
            "type": "boolean",
            "default": false
          },
          {
            "name": "checkedInAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "CheckinScan",
          "category": "interaction",
          "linkedEntity": "Checkin",
          "emits": [
            {
              "event": "SCAN",
              "payloadSchema": [
                {
                  "name": "qrCode",
                  "type": "string"
                },
                {
                  "name": "lat",
                  "type": "number"
                },
                {
                  "name": "lng",
                  "type": "number"
                },
                {
                  "name": "latitude",
                  "type": "number"
                },
                {
                  "name": "longitude",
                  "type": "number"
                },
                {
                  "name": "result",
                  "type": "object"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckinLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Checkin]"
                }
              ]
            },
            {
              "event": "CheckinLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CheckinRecorded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.mode",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.qrCode",
                  "type": "string"
                },
                {
                  "name": "row.verified",
                  "type": "boolean"
                },
                {
                  "name": "row.checkedInAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CheckinFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "checking-in"
              },
              {
                "name": "checked-in"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckinLoaded",
                "name": "Checkin loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Checkin]"
                  }
                ]
              },
              {
                "key": "CheckinLoadFailed",
                "name": "Checkin load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SCAN",
                "name": "Scan",
                "payloadSchema": [
                  {
                    "name": "qrCode",
                    "type": "string"
                  },
                  {
                    "name": "lat",
                    "type": "number"
                  },
                  {
                    "name": "lng",
                    "type": "number"
                  },
                  {
                    "name": "latitude",
                    "type": "number"
                  },
                  {
                    "name": "longitude",
                    "type": "number"
                  },
                  {
                    "name": "result",
                    "type": "object"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CheckinRecorded",
                "name": "Checkin recorded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Checkin"
                  }
                ]
              },
              {
                "key": "CheckinFailed",
                "name": "Checkin failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading check-in…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "CheckinLoaded",
                "guard": [
                  "=",
                  "@config.mode",
                  "qr"
                ],
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "onScan": "SCAN",
                          "facingMode": "environment",
                          "showCameraControls": true,
                          "type": "qr-scanner",
                          "showOverlay": true
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "CheckinLoaded",
                "guard": [
                  "=",
                  "@config.mode",
                  "geo"
                ],
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "@config.title"
                        },
                        {
                          "zoom": 14.0,
                          "mapClickEvent": "SCAN",
                          "centerLat": "@entity.lat",
                          "height": "320px",
                          "showClickedPin": true,
                          "centerLng": "@entity.lng",
                          "markers": [],
                          "type": "map-view"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckinLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "checking-in",
                "event": "SCAN",
                "guard": [
                  "=",
                  "@config.mode",
                  "qr"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.mode",
                    "qr"
                  ],
                  [
                    "set",
                    "@entity.verified",
                    true
                  ],
                  [
                    "persist",
                    "create",
                    "Checkin",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CheckinRecorded",
                        "failure": "CheckinFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Recording check-in…"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "checking-in",
                "event": "SCAN",
                "guard": [
                  "=",
                  "@config.mode",
                  "geo"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.mode",
                    "geo"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.latitude"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.longitude"
                  ],
                  [
                    "set",
                    "@entity.verified",
                    true
                  ],
                  [
                    "persist",
                    "create",
                    "Checkin",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CheckinRecorded",
                        "failure": "CheckinFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Recording check-in…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "checking-in",
                "to": "checked-in",
                "event": "CheckinRecorded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "color": "success",
                          "name": "check-circle"
                        },
                        {
                          "type": "typography",
                          "content": "Checked in",
                          "variant": "h3"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "checking-in",
                "to": "error",
                "event": "CheckinFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "checked-in",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading check-in…"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading check-in…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "mode": {
              "type": "string",
              "default": "geo"
            },
            "title": {
              "type": "string",
              "default": "Check in"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CheckinScanPage",
          "path": "/checkins/scan",
          "traits": [
            {
              "ref": "CheckinScan"
            }
          ]
        }
      ]
    }
  ]
}
