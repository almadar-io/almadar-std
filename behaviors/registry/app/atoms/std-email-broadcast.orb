{
  "name": "std-email-broadcast",
  "version": "1.1.0",
  "description": "std-email-broadcast — send an email blast to a segment of contacts using a chosen template. Lists broadcasts in `browsing`; opens detail in `viewing_single` with Send / Cancel actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "EmailBroadcastOrbital",
      "entity": {
        "name": "EmailBroadcast",
        "collection": "emailbroadcasts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "segmentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateId",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "scheduled",
              "sending",
              "sent",
              "failed"
            ]
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "sentCount",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "EmailBroadcastBroadcast",
          "category": "interaction",
          "linkedEntity": "EmailBroadcast",
          "emits": [
            {
              "event": "OPEN_BROADCAST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string"
                },
                {
                  "name": "row.segmentId",
                  "type": "string"
                },
                {
                  "name": "row.templateId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.recipientCount",
                  "type": "number"
                },
                {
                  "name": "row.sentCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SEND",
              "payloadSchema": [
                {
                  "name": "broadcastId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_BROADCAST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EmailBroadcastLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[EmailBroadcast]"
                }
              ]
            },
            {
              "event": "EmailBroadcastLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EmailBroadcastLoaded",
                "name": "EmailBroadcast loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[EmailBroadcast]"
                  }
                ]
              },
              {
                "key": "EmailBroadcastLoadFailed",
                "name": "EmailBroadcast load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_BROADCAST",
                "name": "Open Broadcast",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "EmailBroadcast"
                  }
                ]
              },
              {
                "key": "CANCEL_BROADCAST",
                "name": "Cancel Broadcast",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "broadcastId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "failure": "EmailBroadcastLoadFailed",
                        "success": "EmailBroadcastLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading broadcasts…"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "EmailBroadcastLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Total broadcasts",
                              "value": "@payload.data.length",
                              "icon": "mail",
                              "type": "stat-display"
                            },
                            {
                              "icon": "send",
                              "label": "Sent this month",
                              "type": "stat-display",
                              "value": "23"
                            },
                            {
                              "label": "Open rate",
                              "value": "41%",
                              "type": "stat-display",
                              "icon": "eye"
                            },
                            {
                              "icon": "mouse-pointer",
                              "type": "stat-display",
                              "label": "Click rate",
                              "value": "12%"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "EmailBroadcastLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_BROADCAST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.subject",
                    "@payload.row.subject"
                  ],
                  [
                    "set",
                    "@entity.segmentId",
                    "@payload.row.segmentId"
                  ],
                  [
                    "set",
                    "@entity.templateId",
                    "@payload.row.templateId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.row.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.recipientCount",
                    "@payload.row.recipientCount"
                  ],
                  [
                    "set",
                    "@entity.sentCount",
                    "@payload.row.sentCount"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.name",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "primary",
                              "type": "badge"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Subject"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.subject"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Segment",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.segmentId"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Template",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.templateId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "value": "@entity.recipientCount",
                              "type": "stat-display",
                              "icon": "users",
                              "label": "Recipients"
                            },
                            {
                              "icon": "send",
                              "value": "@entity.sentCount",
                              "type": "stat-display",
                              "label": "Sent"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Scheduled",
                              "value": "@entity.scheduledAt"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id",
                                "broadcastId": "@entity.id"
                              },
                              "label": "Send Now",
                              "variant": "primary",
                              "action": "SEND"
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "CANCEL_BROADCAST",
                              "label": "Cancel",
                              "variant": "danger"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_BROADCAST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "success": "EmailBroadcastLoaded",
                        "failure": "EmailBroadcastLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling broadcast…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "failure": "EmailBroadcastLoadFailed",
                        "success": "EmailBroadcastLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading broadcasts…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.broadcastId"
                  ],
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "failure": "EmailBroadcastLoadFailed",
                        "success": "EmailBroadcastLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Sending broadcast…"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_BROADCAST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "failure": "EmailBroadcastLoadFailed",
                        "success": "EmailBroadcastLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Cancelling broadcast…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "success": "EmailBroadcastLoaded",
                        "failure": "EmailBroadcastLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "name",
                  "label": "Name",
                  "variant": "caption"
                },
                {
                  "label": "Subject",
                  "name": "subject",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                },
                {
                  "name": "recipientCount",
                  "label": "Recipients",
                  "variant": "caption"
                },
                {
                  "name": "sentCount",
                  "label": "Sent",
                  "variant": "caption"
                },
                {
                  "label": "Scheduled",
                  "variant": "caption",
                  "name": "scheduledAt"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Email Broadcast entity",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Email Broadcasts",
              "label": "Section title",
              "description": "Heading shown above the email blast list"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_BROADCAST",
                  "variant": "primary"
                },
                {
                  "label": "Cancel",
                  "event": "CANCEL_BROADCAST",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each broadcast row",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "EmailBroadcastPage",
          "path": "/broadcasts",
          "traits": [
            {
              "ref": "EmailBroadcastBroadcast"
            }
          ]
        }
      ]
    }
  ]
}