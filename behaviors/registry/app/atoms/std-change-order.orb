{
  "name": "std-change-order",
  "version": "1.0.0",
  "description": "std-change-order — construction change-order primitive tracking contract scope/cost/schedule modifications with owner approval. Lists orders in `browsing`; opens detail in `viewing_single` with Approve / Reject / Execute / Delete actions.",
  "orbitals": [
    {
      "name": "ChangeOrderOrbital",
      "entity": {
        "name": "ChangeOrder",
        "collection": "changeorders",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "coNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "reason",
            "type": "string",
            "default": ""
          },
          {
            "name": "costImpact",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "scheduleImpactDays",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "pending-approval",
              "approved",
              "rejected",
              "executed"
            ]
          },
          {
            "name": "requestedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ChangeOrderLedger",
          "category": "interaction",
          "linkedEntity": "ChangeOrder",
          "emits": [
            {
              "event": "OPEN_CHANGE_ORDER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.costImpact",
                  "type": "number"
                },
                {
                  "name": "row.scheduleImpactDays",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.costImpact",
                  "type": "number"
                },
                {
                  "name": "row.scheduleImpactDays",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUBMIT_FOR_APPROVAL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EXECUTE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ChangeOrderLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ChangeOrder]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ChangeOrderLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ChangeOrderLoaded",
                "name": "ChangeOrder loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ChangeOrder]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ChangeOrderLoadFailed",
                "name": "ChangeOrder load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CHANGE_ORDER",
                "name": "Open Change Order",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ChangeOrder"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SUBMIT_FOR_APPROVAL",
                "name": "Submit For Approval",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXECUTE",
                "name": "Execute",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "failure": "ChangeOrderLoadFailed",
                        "success": "ChangeOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading change orders…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ChangeOrderLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "icon": "file-text",
                              "type": "stat-display",
                              "label": "Total orders",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "value": "11",
                              "label": "Pending approval",
                              "icon": "clock"
                            },
                            {
                              "value": "$184,500",
                              "label": "Cost impact",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "value": "47",
                              "icon": "calendar",
                              "label": "Days added",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "CO #",
                              "name": "coNumber",
                              "variant": "caption"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "name": "costImpact",
                              "label": "Cost Impact",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "scheduleImpactDays",
                              "label": "Days"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "requestedBy",
                              "label": "Requested By"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "OPEN_CHANGE_ORDER",
                              "icon": "arrow-right",
                              "label": "Open",
                              "variant": "primary"
                            },
                            {
                              "label": "Delete",
                              "event": "REQUEST_DELETE",
                              "variant": "danger"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ChangeOrderLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CHANGE_ORDER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.coNumber",
                    "@payload.row.coNumber"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.reason",
                    "@payload.row.reason"
                  ],
                  [
                    "set",
                    "@entity.costImpact",
                    "@payload.row.costImpact"
                  ],
                  [
                    "set",
                    "@entity.scheduleImpactDays",
                    "@payload.row.scheduleImpactDays"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.requestedBy",
                    "@payload.row.requestedBy"
                  ],
                  [
                    "set",
                    "@entity.approvedBy",
                    "@payload.row.approvedBy"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "@payload.row.requestedAt"
                  ],
                  [
                    "set",
                    "@entity.approvedAt",
                    "@payload.row.approvedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.coNumber"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "primary",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Description",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.description"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Reason"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.reason"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Requested by"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.requestedBy",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Approved by",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.approvedBy",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "dollar-sign",
                              "value": "@entity.costImpact",
                              "label": "Cost impact"
                            },
                            {
                              "type": "stat-display",
                              "label": "Schedule days",
                              "icon": "calendar",
                              "value": "@entity.scheduleImpactDays"
                            },
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "label": "Requested",
                              "value": "@entity.requestedAt"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.approvedAt",
                              "label": "Approved",
                              "icon": "check-circle"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "action": "SUBMIT_FOR_APPROVAL",
                              "label": "Submit",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Approve",
                              "action": "APPROVE",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Reject",
                              "variant": "danger",
                              "action": "REJECT",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "EXECUTE",
                              "label": "Execute"
                            },
                            {
                              "action": "REQUEST_DELETE",
                              "label": "Delete",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "success": "ChangeOrderLoaded",
                        "failure": "ChangeOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Deleting change order…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "failure": "ChangeOrderLoadFailed",
                        "success": "ChangeOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading change orders…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SUBMIT_FOR_APPROVAL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "failure": "ChangeOrderLoadFailed",
                        "success": "ChangeOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Submitting for approval…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "success": "ChangeOrderLoaded",
                        "failure": "ChangeOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Approving change order…"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "failure": "ChangeOrderLoadFailed",
                        "success": "ChangeOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Rejecting change order…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EXECUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "success": "ChangeOrderLoaded",
                        "failure": "ChangeOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Executing change order…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "failure": "ChangeOrderLoadFailed",
                        "success": "ChangeOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Deleting change order…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "success": "ChangeOrderLoaded",
                        "failure": "ChangeOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Change Orders"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ChangeOrderPage",
          "path": "/change-orders",
          "traits": [
            {
              "ref": "ChangeOrderLedger"
            }
          ]
        }
      ]
    }
  ]
}
