{
  "name": "std-change-order",
  "version": "1.0.0",
  "description": "std-change-order — construction change-order primitive tracking contract scope/cost/schedule modifications with owner approval.",
  "orbitals": [
    {
      "name": "ChangeOrderOrbital",
      "entity": {
        "name": "ChangeOrder",
        "collection": "changeorders",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "coNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "reason",
            "type": "string",
            "default": ""
          },
          {
            "name": "costImpact",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "scheduleImpactDays",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "pending-approval",
              "approved",
              "rejected",
              "executed"
            ]
          },
          {
            "name": "requestedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "approvedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ChangeOrderLedger",
          "category": "interaction",
          "linkedEntity": "ChangeOrder",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.costImpact",
                  "type": "number"
                },
                {
                  "name": "row.scheduleImpactDays",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.costImpact",
                  "type": "number"
                },
                {
                  "name": "row.scheduleImpactDays",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.coNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.costImpact",
                  "type": "number"
                },
                {
                  "name": "row.scheduleImpactDays",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.requestedBy",
                  "type": "string"
                },
                {
                  "name": "row.approvedBy",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.approvedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChangeOrderLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ChangeOrder]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ChangeOrderLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ChangeOrderLoaded",
                "name": "ChangeOrder loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ChangeOrder]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ChangeOrderLoadFailed",
                "name": "ChangeOrder load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT_FOR_APPROVAL",
                "name": "Submit For Approval",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXECUTE",
                "name": "Execute",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "success": "ChangeOrderLoaded",
                        "failure": "ChangeOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading change orders…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "ChangeOrderLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-text"
                                },
                                {
                                  "content": "@config.title",
                                  "variant": "h3",
                                  "type": "typography"
                                }
                              ],
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "actionPayload": {
                                "source": "header"
                              },
                              "variant": "primary",
                              "label": "New Change Order",
                              "action": "CREATE",
                              "type": "button"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 1.0,
                          "steps": [
                            {
                              "id": "draft",
                              "title": "Draft"
                            },
                            {
                              "title": "Pending Approval",
                              "id": "pending-approval"
                            },
                            {
                              "title": "Approved",
                              "id": "approved"
                            },
                            {
                              "title": "Executed",
                              "id": "executed"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "variant": "ghost",
                              "event": "VIEW",
                              "label": "View"
                            },
                            {
                              "event": "EDIT",
                              "variant": "secondary",
                              "label": "Edit"
                            },
                            {
                              "variant": "primary",
                              "label": "Submit",
                              "event": "SUBMIT_FOR_APPROVAL"
                            },
                            {
                              "variant": "primary",
                              "event": "APPROVE",
                              "label": "Approve"
                            },
                            {
                              "variant": "danger",
                              "event": "REJECT",
                              "label": "Reject"
                            },
                            {
                              "label": "Delete",
                              "event": "REQUEST_DELETE",
                              "variant": "ghost"
                            }
                          ],
                          "fields": [
                            {
                              "name": "coNumber",
                              "label": "CO #",
                              "variant": "caption"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "name": "costImpact",
                              "variant": "caption",
                              "label": "Cost Impact"
                            },
                            {
                              "label": "Days",
                              "variant": "caption",
                              "name": "scheduleImpactDays"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            },
                            {
                              "name": "requestedBy",
                              "variant": "caption",
                              "label": "Requested By"
                            }
                          ],
                          "gap": "sm",
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ChangeOrderLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "SUBMIT_FOR_APPROVAL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Change order submitted for approval",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Change order approved",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "Change order rejected",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EXECUTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Change order executed"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Creating new change order",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "failure": "ChangeOrderLoadFailed",
                        "success": "ChangeOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Searching change orders",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "FILTER_STATUS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Filtering by status"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Viewing change order",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Editing change order",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Delete requested",
                      "variant": "warning"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChangeOrder",
                    {
                      "emit": {
                        "success": "ChangeOrderLoaded",
                        "failure": "ChangeOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Change Orders"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ChangeOrderPage",
          "path": "/change-orders",
          "traits": [
            {
              "ref": "ChangeOrderLedger"
            }
          ]
        }
      ]
    }
  ]
}
