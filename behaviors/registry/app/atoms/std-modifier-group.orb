{
  "name": "std-modifier-group",
  "version": "1.1.0",
  "description": "std-modifier-group — restaurant menu item customization groups with required/optional/multi-select constraints. Owns a ModifierGroupRecord entity (constraint type, min/max selections, serialized options) and a single manage trait that loads groups, browses them in a data-grid with Create / Update / Delete actions, and persists each verdict back to the row. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ModifierGroupOrbital",
      "entity": {
        "name": "ModifierGroupRecord",
        "collection": "modifiergroups",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "constraintType",
            "type": "string",
            "default": "single",
            "values": [
              "single",
              "multi"
            ]
          },
          {
            "name": "required",
            "type": "boolean",
            "default": false
          },
          {
            "name": "minSelect",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "maxSelect",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "optionsJson",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ModifierGroupManage",
          "category": "interaction",
          "linkedEntity": "ModifierGroupRecord",
          "emits": [
            {
              "event": "OPEN_GROUP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.constraintType",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.minSelect",
                  "type": "number"
                },
                {
                  "name": "row.maxSelect",
                  "type": "number"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "groupId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.constraintType",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.minSelect",
                  "type": "number"
                },
                {
                  "name": "row.maxSelect",
                  "type": "number"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "groupId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.constraintType",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.minSelect",
                  "type": "number"
                },
                {
                  "name": "row.maxSelect",
                  "type": "number"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModifierGroupLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ModifierGroupRecord]"
                }
              ]
            },
            {
              "event": "ModifierGroupLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModifierGroupCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.constraintType",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.minSelect",
                  "type": "number"
                },
                {
                  "name": "row.maxSelect",
                  "type": "number"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModifierGroupUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.constraintType",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.minSelect",
                  "type": "number"
                },
                {
                  "name": "row.maxSelect",
                  "type": "number"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModifierGroupDeleted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.constraintType",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.minSelect",
                  "type": "number"
                },
                {
                  "name": "row.maxSelect",
                  "type": "number"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModifierGroupWriteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ModifierGroupLoaded",
                "name": "Modifier group loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ModifierGroupRecord]"
                  }
                ]
              },
              {
                "key": "ModifierGroupLoadFailed",
                "name": "Modifier group load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_GROUP",
                "name": "Open Group",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ModifierGroupRecord"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "groupId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ModifierGroupRecord"
                  }
                ]
              },
              {
                "key": "ModifierGroupCreated",
                "name": "Modifier group created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ModifierGroupRecord"
                  }
                ]
              },
              {
                "key": "ModifierGroupUpdated",
                "name": "Modifier group updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ModifierGroupRecord"
                  }
                ]
              },
              {
                "key": "ModifierGroupDeleted",
                "name": "Modifier group deleted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "ModifierGroupRecord"
                  }
                ]
              },
              {
                "key": "ModifierGroupWriteFailed",
                "name": "Modifier group write failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "groupId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ModifierGroupRecord"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModifierGroupRecord",
                    {
                      "emit": {
                        "success": "ModifierGroupLoaded",
                        "failure": "ModifierGroupLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading modifier groups…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ModifierGroupLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "icon": "list-checks",
                              "label": "Total groups"
                            },
                            {
                              "type": "stat-display",
                              "value": "12",
                              "icon": "asterisk",
                              "label": "Required"
                            },
                            {
                              "value": "9",
                              "type": "stat-display",
                              "label": "Multi-select",
                              "icon": "check-square"
                            },
                            {
                              "label": "Avg options",
                              "type": "stat-display",
                              "icon": "list",
                              "value": "5"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ModifierGroupLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_GROUP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.constraintType",
                    "@payload.row.constraintType"
                  ],
                  [
                    "set",
                    "@entity.required",
                    "@payload.row.required"
                  ],
                  [
                    "set",
                    "@entity.minSelect",
                    "@payload.row.minSelect"
                  ],
                  [
                    "set",
                    "@entity.maxSelect",
                    "@payload.row.maxSelect"
                  ],
                  [
                    "set",
                    "@entity.optionsJson",
                    "@payload.row.optionsJson"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "type": "button"
                            },
                            {
                              "name": "list-checks",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.name"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.constraintType"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Options JSON",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.optionsJson"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "minus",
                              "value": "@entity.minSelect",
                              "label": "Min select",
                              "type": "stat-display"
                            },
                            {
                              "label": "Max select",
                              "type": "stat-display",
                              "icon": "plus",
                              "value": "@entity.maxSelect"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "danger",
                              "action": "DELETE",
                              "type": "button",
                              "actionPayload": {
                                "groupId": "@entity.id",
                                "row": "@entity"
                              },
                              "label": "Delete"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.groupId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.constraintType",
                    "@payload.row.constraintType"
                  ],
                  [
                    "set",
                    "@entity.required",
                    "@payload.row.required"
                  ],
                  [
                    "set",
                    "@entity.minSelect",
                    "@payload.row.minSelect"
                  ],
                  [
                    "set",
                    "@entity.maxSelect",
                    "@payload.row.maxSelect"
                  ],
                  [
                    "set",
                    "@entity.optionsJson",
                    "@payload.row.optionsJson"
                  ],
                  [
                    "persist",
                    "delete",
                    "ModifierGroupRecord",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ModifierGroupWriteFailed",
                        "success": "ModifierGroupDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Deleting modifier group…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ModifierGroupCreated",
                "effects": [
                  [
                    "fetch",
                    "ModifierGroupRecord",
                    {
                      "emit": {
                        "success": "ModifierGroupLoaded",
                        "failure": "ModifierGroupLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ModifierGroupUpdated",
                "effects": [
                  [
                    "fetch",
                    "ModifierGroupRecord",
                    {
                      "emit": {
                        "success": "ModifierGroupLoaded",
                        "failure": "ModifierGroupLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ModifierGroupDeleted",
                "effects": [
                  [
                    "fetch",
                    "ModifierGroupRecord",
                    {
                      "emit": {
                        "success": "ModifierGroupLoaded",
                        "failure": "ModifierGroupLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ModifierGroupWriteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ModifierGroupRecord",
                    {
                      "emit": {
                        "failure": "ModifierGroupLoadFailed",
                        "success": "ModifierGroupLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading modifier groups…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ModifierGroupRecord",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ModifierGroupCreated",
                        "failure": "ModifierGroupWriteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Creating modifier group…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.groupId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.constraintType",
                    "@payload.row.constraintType"
                  ],
                  [
                    "set",
                    "@entity.required",
                    "@payload.row.required"
                  ],
                  [
                    "set",
                    "@entity.minSelect",
                    "@payload.row.minSelect"
                  ],
                  [
                    "set",
                    "@entity.maxSelect",
                    "@payload.row.maxSelect"
                  ],
                  [
                    "set",
                    "@entity.optionsJson",
                    "@payload.row.optionsJson"
                  ],
                  [
                    "persist",
                    "update",
                    "ModifierGroupRecord",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ModifierGroupWriteFailed",
                        "success": "ModifierGroupUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Updating modifier group…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.groupId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.constraintType",
                    "@payload.row.constraintType"
                  ],
                  [
                    "set",
                    "@entity.required",
                    "@payload.row.required"
                  ],
                  [
                    "set",
                    "@entity.minSelect",
                    "@payload.row.minSelect"
                  ],
                  [
                    "set",
                    "@entity.maxSelect",
                    "@payload.row.maxSelect"
                  ],
                  [
                    "set",
                    "@entity.optionsJson",
                    "@payload.row.optionsJson"
                  ],
                  [
                    "persist",
                    "delete",
                    "ModifierGroupRecord",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ModifierGroupWriteFailed",
                        "success": "ModifierGroupDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Deleting modifier group…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModifierGroupRecord",
                    {
                      "emit": {
                        "failure": "ModifierGroupLoadFailed",
                        "success": "ModifierGroupLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "name": "name",
                  "label": "Group"
                },
                {
                  "variant": "badge",
                  "name": "constraintType",
                  "label": "Constraint"
                },
                {
                  "variant": "badge",
                  "name": "required",
                  "label": "Required"
                },
                {
                  "variant": "caption",
                  "label": "Min",
                  "name": "minSelect"
                },
                {
                  "name": "maxSelect",
                  "label": "Max",
                  "variant": "caption"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_GROUP",
                  "variant": "primary",
                  "icon": "arrow-right"
                },
                {
                  "icon": "trash",
                  "event": "DELETE",
                  "variant": "danger",
                  "label": "Delete"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Modifier Groups"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ModifierGroupManagePage",
          "path": "/modifiergroups/manage",
          "traits": [
            {
              "ref": "ModifierGroupManage"
            }
          ]
        }
      ]
    }
  ]
}
