{
  "name": "std-ledger-entry",
  "version": "1.1.0",
  "description": "std-ledger-entry — general-ledger journal entry (double-entry debit/credit). Lists entries in `browsing`; opens entry detail in `viewing_single` with Reconcile / Reverse actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "LedgerEntryOrbital",
      "entity": {
        "name": "LedgerEntry",
        "collection": "ledgerentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "accountId",
            "type": "string",
            "required": true
          },
          {
            "name": "accountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "entryDate",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "debit",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "credit",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "referenceType",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "invoice",
              "bill",
              "payment",
              "adjustment"
            ]
          },
          {
            "name": "referenceId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isReconciled",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "LedgerEntryJournal",
          "category": "interaction",
          "linkedEntity": "LedgerEntry",
          "emits": [
            {
              "event": "OPEN_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.accountId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.accountName",
                  "type": "string"
                },
                {
                  "name": "row.entryDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.debit",
                  "type": "number"
                },
                {
                  "name": "row.credit",
                  "type": "number"
                },
                {
                  "name": "row.referenceType",
                  "type": "string"
                },
                {
                  "name": "row.referenceId",
                  "type": "string"
                },
                {
                  "name": "row.isReconciled",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "RECONCILE_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVERSE_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "LedgerEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[LedgerEntry]"
                }
              ]
            },
            {
              "event": "LedgerEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LedgerEntryLoaded",
                "name": "LedgerEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[LedgerEntry]"
                  }
                ]
              },
              {
                "key": "LedgerEntryLoadFailed",
                "name": "LedgerEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ENTRY",
                "name": "Open Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "LedgerEntry"
                  }
                ]
              },
              {
                "key": "REVERSE_ENTRY",
                "name": "Reverse Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "RECONCILE_ENTRY",
                "name": "Reconcile Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading journal entries…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LedgerEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "icon": "book-open",
                              "type": "stat-display",
                              "label": "Entries",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "dollar-sign",
                              "value": "$12,480",
                              "type": "stat-display",
                              "label": "Net balance"
                            },
                            {
                              "value": "84%",
                              "icon": "check-circle",
                              "label": "Reconciled",
                              "type": "stat-display"
                            },
                            {
                              "label": "Pending",
                              "icon": "clock",
                              "value": "23",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LedgerEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.accountId",
                    "@payload.row.accountId"
                  ],
                  [
                    "set",
                    "@entity.accountName",
                    "@payload.row.accountName"
                  ],
                  [
                    "set",
                    "@entity.entryDate",
                    "@payload.row.entryDate"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.debit",
                    "@payload.row.debit"
                  ],
                  [
                    "set",
                    "@entity.credit",
                    "@payload.row.credit"
                  ],
                  [
                    "set",
                    "@entity.referenceType",
                    "@payload.row.referenceType"
                  ],
                  [
                    "set",
                    "@entity.referenceId",
                    "@payload.row.referenceId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "label": "Back",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "content": "@entity.accountName",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "variant": "default",
                              "label": "@entity.referenceType",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Account ID",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.accountId",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Description",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.description"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Reference"
                                },
                                {
                                  "content": "@entity.referenceId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "calendar",
                              "value": "@entity.entryDate",
                              "label": "Date",
                              "type": "stat-display"
                            },
                            {
                              "label": "Debit",
                              "type": "stat-display",
                              "icon": "arrow-down",
                              "value": "@entity.debit"
                            },
                            {
                              "icon": "arrow-up",
                              "type": "stat-display",
                              "value": "@entity.credit",
                              "label": "Credit"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "RECONCILE_ENTRY",
                              "label": "Reconcile",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "REVERSE_ENTRY",
                              "variant": "danger",
                              "label": "Reverse"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REVERSE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Reversing entry…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "failure": "LedgerEntryLoadFailed",
                        "success": "LedgerEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading journal…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RECONCILE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "failure": "LedgerEntryLoadFailed",
                        "success": "LedgerEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Reconciling entry…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REVERSE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Reversing entry…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_ENTRY",
                  "variant": "primary",
                  "icon": "arrow-right"
                },
                {
                  "event": "REVERSE_ENTRY",
                  "variant": "danger",
                  "label": "Reverse"
                }
              ]
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Date",
                  "name": "entryDate"
                },
                {
                  "label": "Account",
                  "name": "accountName",
                  "variant": "caption"
                },
                {
                  "name": "description",
                  "label": "Description",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "debit",
                  "label": "Debit"
                },
                {
                  "variant": "caption",
                  "name": "credit",
                  "label": "Credit"
                },
                {
                  "name": "isReconciled",
                  "label": "Reconciled",
                  "variant": "badge"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Journal Entries"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LedgerEntryPage",
          "path": "/journal",
          "traits": [
            {
              "ref": "LedgerEntryJournal"
            }
          ]
        }
      ]
    }
  ]
}
