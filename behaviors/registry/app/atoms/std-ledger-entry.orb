{
  "name": "std-ledger-entry",
  "version": "1.0.0",
  "description": "std-ledger-entry — general-ledger journal entry atom. Owns a LedgerEntry entity (double-entry debit/credit) and a single trait that loads journal entries into a data-grid with reconcile and reverse row actions.",
  "orbitals": [
    {
      "name": "LedgerEntryOrbital",
      "entity": {
        "name": "LedgerEntry",
        "collection": "ledgerentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "accountId",
            "type": "string",
            "required": true
          },
          {
            "name": "accountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "entryDate",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "debit",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "credit",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "referenceType",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "invoice",
              "bill",
              "payment",
              "adjustment"
            ]
          },
          {
            "name": "referenceId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isReconciled",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "LedgerEntryJournal",
          "category": "interaction",
          "linkedEntity": "LedgerEntry",
          "emits": [
            {
              "event": "RECONCILE_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVERSE_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "LedgerEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[LedgerEntry]"
                }
              ]
            },
            {
              "event": "LedgerEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LedgerEntryLoaded",
                "name": "LedgerEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[LedgerEntry]"
                  }
                ]
              },
              {
                "key": "LedgerEntryLoadFailed",
                "name": "LedgerEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RECONCILE_ENTRY",
                "name": "Reconcile Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVERSE_ENTRY",
                "name": "Reverse Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "failure": "LedgerEntryLoadFailed",
                        "success": "LedgerEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading journal entries…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LedgerEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            },
                            {
                              "position": "right",
                              "content": "Running ledger balance computed from posted debits minus credits.",
                              "children": [
                                {
                                  "name": "info",
                                  "type": "icon"
                                }
                              ],
                              "type": "tooltip"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "activeTab": "journal",
                          "items": [
                            {
                              "id": "journal",
                              "label": "Journal"
                            },
                            {
                              "label": "Ledger",
                              "id": "ledger"
                            },
                            {
                              "label": "Reports",
                              "id": "reports"
                            }
                          ],
                          "type": "tabs"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "animated": true,
                              "value": 12480.0,
                              "type": "score-display",
                              "label": "Net Balance",
                              "size": "lg"
                            },
                            {
                              "cols": 8.0,
                              "spacing": 24.0,
                              "x": 0.0,
                              "y": 0.0,
                              "rows": 4.0,
                              "nodeRadius": 2.0,
                              "color": "muted",
                              "opacity": 0.35,
                              "type": "svg-grid"
                            },
                            {
                              "points": [
                                [
                                  10.0,
                                  30.0
                                ],
                                [
                                  80.0,
                                  30.0
                                ],
                                [
                                  160.0,
                                  30.0
                                ]
                              ],
                              "color": "primary",
                              "strokeWidth": 2.0,
                              "animated": true,
                              "type": "svg-flow"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "minCardWidth": 240.0,
                          "gap": "md",
                          "maxCols": 3.0,
                          "fields": [
                            {
                              "name": "entryDate",
                              "label": "Date"
                            },
                            {
                              "name": "accountName",
                              "label": "Account"
                            },
                            {
                              "name": "debit",
                              "label": "Debit"
                            },
                            {
                              "label": "Credit",
                              "name": "credit"
                            }
                          ],
                          "type": "entity-cards",
                          "entity": "@payload.data"
                        },
                        {
                          "showDividers": true,
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "entryDate",
                              "label": "Date"
                            },
                            {
                              "name": "accountName",
                              "label": "Account"
                            },
                            {
                              "label": "Description",
                              "name": "description"
                            },
                            {
                              "name": "debit",
                              "label": "Debit"
                            },
                            {
                              "name": "credit",
                              "label": "Credit"
                            }
                          ],
                          "type": "entity-list"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "RECONCILE_ENTRY",
                              "label": "Reconcile"
                            },
                            {
                              "label": "Reverse",
                              "event": "REVERSE_ENTRY",
                              "variant": "danger"
                            }
                          ],
                          "fields": [
                            {
                              "name": "entryDate",
                              "label": "Date",
                              "variant": "caption"
                            },
                            {
                              "name": "accountName",
                              "variant": "caption",
                              "label": "Account"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "name": "debit",
                              "label": "Debit",
                              "variant": "caption"
                            },
                            {
                              "name": "credit",
                              "label": "Credit",
                              "variant": "caption"
                            },
                            {
                              "label": "Reconciled",
                              "name": "isReconciled",
                              "variant": "badge"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LedgerEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RECONCILE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Entry reconciled",
                    "success"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REVERSE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Entry reversed",
                    "info"
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Journal Entries"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LedgerEntryPage",
          "path": "/journal",
          "traits": [
            {
              "ref": "LedgerEntryJournal"
            }
          ]
        }
      ]
    }
  ]
}
