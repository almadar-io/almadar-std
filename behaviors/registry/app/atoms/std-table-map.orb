{
  "name": "std-table-map",
  "version": "1.1.0",
  "description": "std-table-map — restaurant POS interactive floor plan: TableNode draggable nodes with seat/clear/select/move actions. Listens for SET_STATUS so std-lifecycle can drive table-status transitions. Exposes Restaurant/POS knobs (allowSplitChecks, allergenWarningsEnabled, …).",
  "orbitals": [
    {
      "name": "TableMapOrbital",
      "entity": {
        "name": "TableNode",
        "collection": "tables",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "label",
            "type": "string",
            "required": true
          },
          {
            "name": "x",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "shape",
            "type": "string",
            "default": "round",
            "values": [
              "round",
              "rectangle",
              "square"
            ]
          },
          {
            "name": "capacity",
            "type": "number",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "empty",
            "values": [
              "empty",
              "seated",
              "ordered",
              "awaiting-bill",
              "cleaning"
            ]
          },
          {
            "name": "partySize",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "serverName",
            "type": "string"
          },
          {
            "name": "currentOrderId",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TableManage",
          "category": "interaction",
          "linkedEntity": "TableNode",
          "emits": [
            {
              "event": "SELECT_TABLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MOVE_TABLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "x",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "y",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "SEAT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "partySize",
                  "type": "number"
                },
                {
                  "name": "serverName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLEAR_TABLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TableLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TableNode]"
                }
              ]
            },
            {
              "event": "TableLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TableSelected",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TableUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.label",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.x",
                  "type": "number"
                },
                {
                  "name": "row.y",
                  "type": "number"
                },
                {
                  "name": "row.shape",
                  "type": "string"
                },
                {
                  "name": "row.capacity",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.partySize",
                  "type": "number"
                },
                {
                  "name": "row.serverName",
                  "type": "string"
                },
                {
                  "name": "row.currentOrderId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TableWriteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TableLoaded",
                "name": "Table loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TableNode]"
                  }
                ]
              },
              {
                "key": "TableLoadFailed",
                "name": "Table load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_TABLE",
                "name": "Select Table",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MOVE_TABLE",
                "name": "Move Table",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "SEAT",
                "name": "Seat",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "partySize",
                    "type": "number"
                  },
                  {
                    "name": "serverName",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR_TABLE",
                "name": "Clear Table",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TableUpdated",
                "name": "Table updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TableNode"
                  }
                ]
              },
              {
                "key": "TableSelected",
                "name": "Table selected",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TableWriteFailed",
                "name": "Table write failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TableNode",
                    {
                      "emit": {
                        "failure": "TableLoadFailed",
                        "success": "TableLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading floor plan…",
                          "type": "typography"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TableLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "layout-grid",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Tables",
                              "icon": "grid",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "users",
                              "value": "18",
                              "type": "stat-display",
                              "label": "Seated"
                            },
                            {
                              "type": "stat-display",
                              "label": "Awaiting bill",
                              "value": "4",
                              "icon": "receipt"
                            },
                            {
                              "type": "stat-display",
                              "value": "3.2",
                              "label": "Avg party size",
                              "icon": "user-plus"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "editable": true,
                          "items": "@payload.data",
                          "height": "@config.canvasHeight",
                          "onSelect": "SELECT_TABLE",
                          "selectedId": "@entity.id",
                          "onMove": "MOVE_TABLE",
                          "type": "positioned-canvas",
                          "width": "@config.canvasWidth"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "SEAT",
                              "label": "Seat Party",
                              "icon": "users",
                              "variant": "primary"
                            },
                            {
                              "variant": "secondary",
                              "label": "Clear Table",
                              "action": "CLEAR_TABLE",
                              "icon": "eraser",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "end",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TableLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SELECT_TABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "TableSelected",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MOVE_TABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.x",
                    "@payload.x"
                  ],
                  [
                    "set",
                    "@entity.y",
                    "@payload.y"
                  ],
                  [
                    "persist",
                    "update",
                    "TableNode",
                    {
                      "id": "@payload.id",
                      "x": "@payload.x",
                      "y": "@payload.y"
                    },
                    {
                      "emit": {
                        "success": "TableUpdated",
                        "failure": "TableWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEAT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "seated"
                  ],
                  [
                    "set",
                    "@entity.partySize",
                    "@payload.partySize"
                  ],
                  [
                    "set",
                    "@entity.serverName",
                    "@payload.serverName"
                  ],
                  [
                    "persist",
                    "update",
                    "TableNode",
                    {
                      "status": "seated",
                      "id": "@payload.id",
                      "serverName": "@payload.serverName",
                      "partySize": "@payload.partySize"
                    },
                    {
                      "emit": {
                        "failure": "TableWriteFailed",
                        "success": "TableUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CLEAR_TABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "empty"
                  ],
                  [
                    "set",
                    "@entity.partySize",
                    0.0
                  ],
                  [
                    "persist",
                    "update",
                    "TableNode",
                    {
                      "status": "empty",
                      "id": "@payload.id",
                      "partySize": 0.0
                    },
                    {
                      "emit": {
                        "success": "TableUpdated",
                        "failure": "TableWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "TableNode",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TableWriteFailed",
                        "success": "TableUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Updating table status…"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TableUpdated",
                "effects": [
                  [
                    "fetch",
                    "TableNode",
                    {
                      "emit": {
                        "failure": "TableLoadFailed",
                        "success": "TableLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TableSelected",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TableWriteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TableNode",
                    {
                      "emit": {
                        "failure": "TableLoadFailed",
                        "success": "TableLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Floor Plan",
              "label": "Section title",
              "description": "Heading shown above the restaurant floor plan",
              "tier": "presentation"
            },
            "canvasWidth": {
              "type": "number",
              "default": 800.0,
              "label": "Canvas width",
              "description": "Floor plan canvas width in pixels",
              "tier": "presentation"
            },
            "canvasHeight": {
              "type": "number",
              "default": 600.0,
              "label": "Canvas height",
              "description": "Floor plan canvas height in pixels",
              "tier": "presentation"
            },
            "kitchenAutoFire": {
              "type": "boolean",
              "default": false,
              "label": "Kitchen auto-fire",
              "description": "Auto-fire courses to the kitchen display when a table moves to ordered.",
              "tier": "domain"
            },
            "tipPresets": {
              "type": "[number]",
              "default": [
                15.0,
                18.0,
                20.0,
                25.0
              ],
              "label": "Tip presets (%)",
              "description": "Quick-select tip percentages shown when closing a table check.",
              "tier": "domain",
              "items": {
                "type": "number"
              }
            },
            "serviceCharge": {
              "type": "number",
              "default": 0.0,
              "label": "Service charge (%)",
              "description": "Default service-charge percentage applied to checks for these tables.",
              "tier": "domain"
            },
            "allowSplitChecks": {
              "type": "boolean",
              "default": true,
              "label": "Allow split checks",
              "description": "Permit splitting a table check across multiple payments.",
              "tier": "domain"
            },
            "tableTurnoverTargetMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "Table turnover target (min)",
              "description": "Target minutes between seatings on a single table. v1.1 declarative.",
              "tier": "domain"
            },
            "coursingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Coursing enabled",
              "description": "Track courses for table pacing.",
              "tier": "domain"
            },
            "allergenWarningsEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Allergen warnings",
              "description": "Surface allergen warnings on items selected for a seated table.",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TableManagePage",
          "path": "/tables/manage",
          "traits": [
            {
              "ref": "TableManage"
            }
          ]
        }
      ]
    }
  ]
}