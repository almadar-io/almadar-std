{
  "name": "std-drip-sequence",
  "version": "1.1.0",
  "description": "std-drip-sequence — ordered email drip campaign primitive. Lists sequences in `browsing`; opens detail in `viewing_single` with Activate / Pause / Archive actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "DripSequenceOrbital",
      "entity": {
        "name": "DripSequence",
        "collection": "dripsequences",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "triggerEvent",
            "type": "string",
            "default": ""
          },
          {
            "name": "stepsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "paused",
              "archived"
            ]
          },
          {
            "name": "totalEnrolled",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalCompleted",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "DripSequenceSequence",
          "category": "interaction",
          "linkedEntity": "DripSequence",
          "emits": [
            {
              "event": "OPEN_SEQUENCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.totalEnrolled",
                  "type": "number"
                },
                {
                  "name": "row.totalCompleted",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ACTIVATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PAUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DripSequenceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DripSequence]"
                }
              ]
            },
            {
              "event": "DripSequenceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DripSequenceLoaded",
                "name": "DripSequence loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DripSequence]"
                  }
                ]
              },
              {
                "key": "DripSequenceLoadFailed",
                "name": "DripSequence load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SEQUENCE",
                "name": "Open Sequence",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DripSequence"
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ACTIVATE",
                "name": "Activate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "failure": "DripSequenceLoadFailed",
                        "success": "DripSequenceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading drip sequences…"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DripSequenceLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Total sequences",
                              "type": "stat-display",
                              "icon": "mail"
                            },
                            {
                              "label": "Active",
                              "value": "14",
                              "type": "stat-display",
                              "icon": "play-circle"
                            },
                            {
                              "value": "8,420",
                              "label": "Enrolled",
                              "icon": "users",
                              "type": "stat-display"
                            },
                            {
                              "value": "67%",
                              "type": "stat-display",
                              "label": "Completion rate",
                              "icon": "check-circle"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": "@config.fields",
                          "gap": "sm",
                          "cols": 1.0,
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DripSequenceLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SEQUENCE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.triggerEvent",
                    "@payload.row.triggerEvent"
                  ],
                  [
                    "set",
                    "@entity.stepsJson",
                    "@payload.row.stepsJson"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.totalEnrolled",
                    "@payload.row.totalEnrolled"
                  ],
                  [
                    "set",
                    "@entity.totalCompleted",
                    "@payload.row.totalCompleted"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "mail"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.name"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "primary",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Description"
                                },
                                {
                                  "content": "@entity.description",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Trigger"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.triggerEvent",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Enrolled",
                              "value": "@entity.totalEnrolled",
                              "type": "stat-display",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "@entity.totalCompleted",
                              "label": "Completed"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "ACTIVATE",
                              "variant": "primary",
                              "type": "button",
                              "label": "Activate",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Pause",
                              "action": "PAUSE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PAUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Pausing sequence…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading drip sequences…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACTIVATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "failure": "DripSequenceLoadFailed",
                        "success": "DripSequenceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Activating sequence…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PAUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Pausing sequence…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "Name",
                  "variant": "caption",
                  "name": "name"
                },
                {
                  "label": "Description",
                  "variant": "caption",
                  "name": "description"
                },
                {
                  "label": "Trigger",
                  "name": "triggerEvent",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                },
                {
                  "name": "totalEnrolled",
                  "label": "Enrolled",
                  "variant": "caption"
                },
                {
                  "label": "Completed",
                  "variant": "caption",
                  "name": "totalCompleted"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Drip Sequence entity"
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "variant": "primary",
                  "icon": "arrow-right",
                  "event": "OPEN_SEQUENCE"
                },
                {
                  "label": "Pause",
                  "variant": "danger",
                  "event": "PAUSE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each sequence row"
            },
            "title": {
              "type": "string",
              "default": "Drip Sequences",
              "label": "Section title",
              "description": "Heading shown above the drip campaign list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DripSequencePage",
          "path": "/sequences",
          "traits": [
            {
              "ref": "DripSequenceSequence"
            }
          ]
        }
      ]
    }
  ]
}
