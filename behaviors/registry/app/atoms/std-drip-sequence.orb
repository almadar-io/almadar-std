{
  "name": "std-drip-sequence",
  "version": "1.2.0",
  "description": "std-drip-sequence — ordered email drip campaign primitive. Lists sequences; detail offers Activate / Pause / Archive. Listens for SET_STATUS so std-lifecycle can drive transitions. Exposes Communication knobs (sendsPerHour, gdprConsentRequired, unsubscribe link, …).",
  "orbitals": [
    {
      "name": "DripSequenceOrbital",
      "entity": {
        "name": "DripSequence",
        "collection": "dripsequences",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "triggerEvent",
            "type": "string",
            "default": ""
          },
          {
            "name": "stepsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "paused",
              "archived"
            ]
          },
          {
            "name": "totalEnrolled",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalCompleted",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "DripSequenceSequence",
          "category": "interaction",
          "linkedEntity": "DripSequence",
          "emits": [
            {
              "event": "OPEN_SEQUENCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.totalEnrolled",
                  "type": "number"
                },
                {
                  "name": "row.totalCompleted",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ACTIVATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PAUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DripSequenceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DripSequence]"
                }
              ]
            },
            {
              "event": "DripSequenceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DripSequenceUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.totalEnrolled",
                  "type": "number"
                },
                {
                  "name": "row.totalCompleted",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DripSequenceUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DripSequenceLoaded",
                "name": "DripSequence loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DripSequence]"
                  }
                ]
              },
              {
                "key": "DripSequenceLoadFailed",
                "name": "DripSequence load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SEQUENCE",
                "name": "Open Sequence",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DripSequence"
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DripSequenceUpdated",
                "name": "DripSequence updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DripSequence"
                  }
                ]
              },
              {
                "key": "DripSequenceUpdateFailed",
                "name": "DripSequence update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ACTIVATE",
                "name": "Activate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading drip sequences…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DripSequenceLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "mail",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total sequences"
                            },
                            {
                              "value": "14",
                              "icon": "play-circle",
                              "label": "Active",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Enrolled",
                              "value": "8,420",
                              "icon": "users"
                            },
                            {
                              "value": "67%",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "label": "Completion rate"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DripSequenceLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SEQUENCE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.triggerEvent",
                    "@payload.row.triggerEvent"
                  ],
                  [
                    "set",
                    "@entity.stepsJson",
                    "@payload.row.stepsJson"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.totalEnrolled",
                    "@payload.row.totalEnrolled"
                  ],
                  [
                    "set",
                    "@entity.totalCompleted",
                    "@payload.row.totalCompleted"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.name"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Description",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.description"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Trigger",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.triggerEvent"
                                }
                              ]
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Enrolled",
                              "icon": "users",
                              "type": "stat-display",
                              "value": "@entity.totalEnrolled"
                            },
                            {
                              "label": "Completed",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "value": "@entity.totalCompleted"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Activate",
                              "variant": "primary",
                              "action": "ACTIVATE"
                            },
                            {
                              "action": "PAUSE",
                              "type": "button",
                              "variant": "danger",
                              "label": "Pause",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PAUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Pausing sequence…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "DripSequence",
                    "@entity",
                    {
                      "emit": {
                        "success": "DripSequenceUpdated",
                        "failure": "DripSequenceUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Updating sequence status…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DripSequenceUpdated",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "failure": "DripSequenceLoadFailed",
                        "success": "DripSequenceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DripSequenceUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading drip sequences…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACTIVATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "failure": "DripSequenceLoadFailed",
                        "success": "DripSequenceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Activating sequence…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PAUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "failure": "DripSequenceLoadFailed",
                        "success": "DripSequenceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Pausing sequence…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "includeUnsubscribeLink": {
              "type": "boolean",
              "default": true,
              "label": "Include unsubscribe link",
              "description": "Append a CAN-SPAM/GDPR-compliant unsubscribe link to every step.",
              "tier": "essential"
            },
            "suppressionListEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Honor suppression list",
              "description": "Skip enrolled contacts on the global suppression / bounce list.",
              "tier": "customization"
            },
            "trackClicks": {
              "type": "boolean",
              "default": true,
              "label": "Track clicks",
              "description": "Wrap outbound links for click attribution per step.",
              "tier": "advanced"
            },
            "physicalAddressFooter": {
              "type": "string",
              "default": "",
              "label": "Physical address footer",
              "description": "CAN-SPAM-required postal address appended to every step.",
              "tier": "essential"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Name",
                  "name": "name"
                },
                {
                  "label": "Description",
                  "name": "description",
                  "variant": "caption"
                },
                {
                  "label": "Trigger",
                  "name": "triggerEvent",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "variant": "caption",
                  "name": "totalEnrolled",
                  "label": "Enrolled"
                },
                {
                  "name": "totalCompleted",
                  "label": "Completed",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Drip Sequence entity",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "trackOpens": {
              "type": "boolean",
              "default": true,
              "label": "Track opens",
              "description": "Embed a tracking pixel on each step message.",
              "tier": "advanced"
            },
            "frequencyCapPerWeek": {
              "type": "number",
              "default": 5.0,
              "label": "Frequency cap (per week)",
              "description": "Max drip + broadcast messages a recipient sees per 7-day window.",
              "tier": "customization"
            },
            "title": {
              "type": "string",
              "default": "Drip Sequences",
              "label": "Section title",
              "description": "Heading shown above the drip campaign list",
              "tier": "customization"
            },
            "sendsPerHour": {
              "type": "number",
              "default": 500.0,
              "label": "Sends per hour",
              "description": "Cap on outbound drip messages per hour for throttling. v1.2 declarative.",
              "tier": "customization"
            },
            "gdprConsentRequired": {
              "type": "boolean",
              "default": true,
              "label": "GDPR consent required",
              "description": "Require explicit marketing consent before enrolling EU/UK recipients.",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_SEQUENCE",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "event": "PAUSE",
                  "variant": "danger",
                  "label": "Pause"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each sequence row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
