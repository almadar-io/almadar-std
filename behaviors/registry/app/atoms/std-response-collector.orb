{
  "name": "std-response-collector",
  "version": "1.1.0",
  "description": "std-response-collector — survey per-respondent answer accumulator. Lists responses in `browsing`; opens detail in `viewing_single` with Resubmit / Delete actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ResponseCollectorOrbital",
      "entity": {
        "name": "Response",
        "collection": "responses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "surveyId",
            "type": "string",
            "required": true
          },
          {
            "name": "respondentId",
            "type": "string",
            "required": true
          },
          {
            "name": "questionId",
            "type": "string",
            "required": true
          },
          {
            "name": "answerJson",
            "type": "string"
          },
          {
            "name": "submittedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ResponseCollect",
          "category": "interaction",
          "linkedEntity": "Response",
          "emits": [
            {
              "event": "OPEN_RESPONSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.respondentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.questionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.answerJson",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "RESUBMIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE_RESPONSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ResponseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Response]"
                }
              ]
            },
            {
              "event": "ResponseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ResponseLoaded",
                "name": "Response loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Response]"
                  }
                ]
              },
              {
                "key": "ResponseLoadFailed",
                "name": "Response load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RESPONSE",
                "name": "Open Response",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Response"
                  }
                ]
              },
              {
                "key": "RESUBMIT",
                "name": "Resubmit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE_RESPONSE",
                "name": "Delete Response",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "success": "ResponseLoaded",
                        "failure": "ResponseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading responses…"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ResponseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clipboard-list"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "clipboard-list",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total responses"
                            },
                            {
                              "type": "stat-display",
                              "value": "84%",
                              "label": "Completion",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "value": "312",
                              "label": "Respondents",
                              "icon": "users"
                            },
                            {
                              "value": "6",
                              "type": "stat-display",
                              "icon": "file-text",
                              "label": "Surveys"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ResponseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.surveyId",
                    "@payload.row.surveyId"
                  ],
                  [
                    "set",
                    "@entity.respondentId",
                    "@payload.row.respondentId"
                  ],
                  [
                    "set",
                    "@entity.questionId",
                    "@payload.row.questionId"
                  ],
                  [
                    "set",
                    "@entity.answerJson",
                    "@payload.row.answerJson"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.row.submittedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "clipboard-list"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.respondentId"
                            },
                            {
                              "label": "Submitted",
                              "type": "badge",
                              "variant": "success"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Survey",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.surveyId",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Question"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.questionId",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Answer",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.answerJson",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "user",
                              "type": "stat-display",
                              "label": "Respondent",
                              "value": "@entity.respondentId"
                            },
                            {
                              "label": "Submitted",
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.submittedAt"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Resubmit",
                              "type": "button",
                              "variant": "primary",
                              "action": "RESUBMIT",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "DELETE_RESPONSE",
                              "label": "Delete"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RESUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "success": "ResponseLoaded",
                        "failure": "ResponseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Resubmitting response…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "failure": "ResponseLoadFailed",
                        "success": "ResponseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Deleting response…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "success": "ResponseLoaded",
                        "failure": "ResponseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading responses…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RESUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "success": "ResponseLoaded",
                        "failure": "ResponseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Resubmitting response…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DELETE_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "failure": "ResponseLoadFailed",
                        "success": "ResponseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Deleting response…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "failure": "ResponseLoadFailed",
                        "success": "ResponseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_RESPONSE"
                },
                {
                  "event": "DELETE_RESPONSE",
                  "label": "Delete",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each response row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Responses",
              "label": "Section title",
              "description": "Heading shown above the survey response list",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "questionId",
                  "variant": "caption",
                  "label": "Question"
                },
                {
                  "label": "Respondent",
                  "name": "respondentId",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "surveyId",
                  "label": "Survey"
                },
                {
                  "label": "Answer",
                  "name": "answerJson",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Submitted",
                  "name": "submittedAt"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Response entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ResponseCollectPage",
          "path": "/responses/collect",
          "traits": [
            {
              "ref": "ResponseCollect"
            }
          ]
        }
      ]
    }
  ]
}
