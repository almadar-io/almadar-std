{
  "name": "std-response-collector",
  "version": "1.0.0",
  "description": "std-response-collector — survey per-respondent answer accumulator. ResponseCollect fetches Response rows on INIT, lists them, and on SUBMIT persists a new answer row tagged with surveyId, respondentId, questionId, and serialized answerJson, emitting ResponseSubmitted for cross-trait listeners.",
  "orbitals": [
    {
      "name": "ResponseCollectorOrbital",
      "entity": {
        "name": "Response",
        "collection": "responses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "surveyId",
            "type": "string",
            "required": true
          },
          {
            "name": "respondentId",
            "type": "string",
            "required": true
          },
          {
            "name": "questionId",
            "type": "string",
            "required": true
          },
          {
            "name": "answerJson",
            "type": "string"
          },
          {
            "name": "submittedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ResponseCollect",
          "category": "interaction",
          "linkedEntity": "Response",
          "emits": [
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "respondentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "questionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "answerJson",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "ResponseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Response]"
                }
              ]
            },
            {
              "event": "ResponseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ResponseSubmitted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.respondentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.questionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.answerJson",
                  "type": "string"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ResponseSubmitFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "submitting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ResponseLoaded",
                "name": "Response loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Response]"
                  }
                ]
              },
              {
                "key": "ResponseLoadFailed",
                "name": "Response load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "surveyId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "respondentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "questionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "answerJson",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ResponseSubmitted",
                "name": "Response submitted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Response"
                  }
                ]
              },
              {
                "key": "ResponseSubmitFailed",
                "name": "Response submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "success": "ResponseLoaded",
                        "failure": "ResponseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading responses…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ResponseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@config.title",
                          "variant": "h3"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Question",
                              "name": "questionId"
                            },
                            {
                              "name": "respondentId",
                              "label": "Respondent"
                            },
                            {
                              "name": "answerJson",
                              "label": "Answer"
                            },
                            {
                              "name": "submittedAt",
                              "label": "Submitted"
                            }
                          ],
                          "itemActions": [
                            {
                              "icon": "eye",
                              "label": "View",
                              "event": "SUBMIT"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ResponseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.surveyId",
                    "@payload.surveyId"
                  ],
                  [
                    "set",
                    "@entity.respondentId",
                    "@payload.respondentId"
                  ],
                  [
                    "set",
                    "@entity.questionId",
                    "@payload.questionId"
                  ],
                  [
                    "set",
                    "@entity.answerJson",
                    "@payload.answerJson"
                  ],
                  [
                    "persist",
                    "create",
                    "Response",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "ResponseSubmitFailed",
                        "success": "ResponseSubmitted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Submitting response…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "loading",
                "event": "ResponseSubmitted",
                "effects": [
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "success": "ResponseLoaded",
                        "failure": "ResponseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Refreshing responses…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "error",
                "event": "ResponseSubmitFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Response",
                    {
                      "emit": {
                        "failure": "ResponseLoadFailed",
                        "success": "ResponseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading responses…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Responses"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ResponseCollectPage",
          "path": "/responses/collect",
          "traits": [
            {
              "ref": "ResponseCollect"
            }
          ]
        }
      ]
    }
  ]
}