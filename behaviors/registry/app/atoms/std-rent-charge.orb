{
  "name": "std-rent-charge",
  "version": "1.2.0",
  "description": "std-rent-charge — monthly rent charge ledger with Mark Paid / Late Fee / Waive. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes Financial + Real-Estate-pattern knobs.",
  "orbitals": [
    {
      "name": "RentChargeOrbital",
      "entity": {
        "name": "RentCharge",
        "collection": "rentcharges",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "required": true
          },
          {
            "name": "leaseId",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "dueDate",
            "type": "string",
            "required": true
          },
          {
            "name": "paidAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "unpaid",
            "values": [
              "unpaid",
              "paid",
              "overdue",
              "waived"
            ]
          },
          {
            "name": "lateFee",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RentChargeLedger",
          "category": "interaction",
          "linkedEntity": "RentCharge",
          "emits": [
            {
              "event": "OPEN_CHARGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.leaseId",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.dueDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lateFee",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "MARK_PAID",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ASSESS_LATE_FEE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WAIVE_CHARGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RentChargeLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RentCharge]"
                }
              ]
            },
            {
              "event": "RentChargeLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RentChargeUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.leaseId",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.dueDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lateFee",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RentChargeUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RentChargeLoaded",
                "name": "RentCharge loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RentCharge]"
                  }
                ]
              },
              {
                "key": "RentChargeLoadFailed",
                "name": "RentCharge load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CHARGE",
                "name": "Open Charge",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "RentCharge"
                  }
                ]
              },
              {
                "key": "MARK_PAID",
                "name": "Mark Paid",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ASSESS_LATE_FEE",
                "name": "Assess Late Fee",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "WAIVE_CHARGE",
                "name": "Waive Charge",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RentChargeUpdated",
                "name": "RentCharge updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "RentCharge"
                  }
                ]
              },
              {
                "key": "RentChargeUpdateFailed",
                "name": "RentCharge update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "failure": "RentChargeLoadFailed",
                        "success": "RentChargeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading rent charges…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RentChargeLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "home"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total charges",
                              "icon": "home"
                            },
                            {
                              "value": "$284,500",
                              "type": "stat-display",
                              "label": "Collected",
                              "icon": "check-circle"
                            },
                            {
                              "label": "Overdue",
                              "value": "11",
                              "type": "stat-display",
                              "icon": "alert-triangle"
                            },
                            {
                              "type": "stat-display",
                              "value": "$1,840",
                              "label": "Late fees",
                              "icon": "dollar-sign"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "gap": "sm",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RentChargeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CHARGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.tenantId",
                    "@payload.row.tenantId"
                  ],
                  [
                    "set",
                    "@entity.leaseId",
                    "@payload.row.leaseId"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.dueDate",
                    "@payload.row.dueDate"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "@payload.row.paidAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.lateFee",
                    "@payload.row.lateFee"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "home",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.tenantId"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Lease",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.leaseId",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Notes"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Amount",
                              "value": "@entity.amount",
                              "type": "stat-display",
                              "icon": "dollar-sign"
                            },
                            {
                              "label": "Late fee",
                              "value": "@entity.lateFee",
                              "type": "stat-display",
                              "icon": "alert-triangle"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.dueDate",
                              "label": "Due"
                            },
                            {
                              "label": "Paid",
                              "value": "@entity.paidAt",
                              "icon": "check-circle",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Mark Paid",
                              "variant": "primary",
                              "action": "MARK_PAID"
                            },
                            {
                              "label": "Assess Late Fee",
                              "variant": "secondary",
                              "type": "button",
                              "action": "ASSESS_LATE_FEE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "WAIVE_CHARGE",
                              "type": "button",
                              "label": "Waive",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "failure": "RentChargeLoadFailed",
                        "success": "RentChargeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Recording payment…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ASSESS_LATE_FEE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "failure": "RentChargeLoadFailed",
                        "success": "RentChargeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Assessing late fee…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WAIVE_CHARGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "success": "RentChargeLoaded",
                        "failure": "RentChargeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Waiving charge…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "RentCharge",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RentChargeUpdateFailed",
                        "success": "RentChargeUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating charge status…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RentChargeUpdated",
                "effects": [
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "success": "RentChargeLoaded",
                        "failure": "RentChargeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RentChargeUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "failure": "RentChargeLoadFailed",
                        "success": "RentChargeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading rent charges…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "failure": "RentChargeLoadFailed",
                        "success": "RentChargeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Recording payment…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSESS_LATE_FEE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "success": "RentChargeLoaded",
                        "failure": "RentChargeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Assessing late fee…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "WAIVE_CHARGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "failure": "RentChargeLoadFailed",
                        "success": "RentChargeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Waiving charge…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RentCharge",
                    {
                      "emit": {
                        "success": "RentChargeLoaded",
                        "failure": "RentChargeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "retentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Retention (years)",
              "description": "Years to keep rent records for compliance.",
              "tier": "advanced"
            },
            "title": {
              "type": "string",
              "default": "Rent Charges",
              "label": "Section title",
              "description": "Heading shown above the rent charge ledger",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "tenantId",
                  "label": "Tenant",
                  "variant": "caption"
                },
                {
                  "label": "Amount",
                  "variant": "caption",
                  "name": "amount"
                },
                {
                  "name": "dueDate",
                  "variant": "caption",
                  "label": "Due"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "name": "paidAt",
                  "variant": "caption",
                  "label": "Paid"
                },
                {
                  "name": "lateFee",
                  "label": "Late Fee",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Rent Charge entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "currency": {
              "type": "string",
              "default": "USD",
              "label": "Default currency",
              "description": "ISO 4217 currency code (USD, EUR, GBP, …) for rent amounts.",
              "tier": "essential"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_CHARGE",
                  "variant": "primary",
                  "icon": "arrow-right",
                  "label": "Open"
                },
                {
                  "variant": "danger",
                  "label": "Waive",
                  "event": "WAIVE_CHARGE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each charge row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "autoRenewEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Auto-renew lease",
              "description": "When true, leases auto-renew on expiry rather than going month-to-month. Declarative on rent-charge.",
              "tier": "customization"
            },
            "securityDepositMonths": {
              "type": "number",
              "default": 1.0,
              "label": "Security deposit (months of rent)",
              "description": "How many months of rent are held as a security deposit. Declarative on rent-charge.",
              "tier": "customization"
            },
            "inspectionFrequencyMonths": {
              "type": "number",
              "default": 12.0,
              "label": "Inspection frequency (months)",
              "description": "How often property inspections are scheduled. Declarative.",
              "tier": "advanced"
            },
            "lateFeePolicy": {
              "type": "string",
              "default": "flat",
              "label": "Late fee policy",
              "description": "How late fees compute on overdue rent: none, flat (lateFeeAmount cash), or percent (% of rent). Declarative; wiring deferred.",
              "tier": "customization",
              "values": [
                "none",
                "flat",
                "percent"
              ]
            },
            "roundingMode": {
              "type": "string",
              "default": "half-up",
              "label": "Rounding mode",
              "description": "Sub-cent rounding behavior for rent + late fee calculations.",
              "tier": "advanced",
              "values": [
                "bankers",
                "half-up",
                "down"
              ]
            },
            "complianceJurisdiction": {
              "type": "string",
              "default": "",
              "label": "Compliance jurisdiction",
              "description": "Drives rent regulations per locale: 'US-CA', 'EU-DE', 'UK', etc. Declarative.",
              "tier": "advanced"
            },
            "leaseRenewalNoticeDays": {
              "type": "number",
              "default": 60.0,
              "label": "Lease renewal notice (days)",
              "description": "Days before lease end when a renewal notice should fire. Declarative on rent-charge; wired upstream by std-lease.",
              "tier": "customization"
            },
            "gracePeriodDays": {
              "type": "number",
              "default": 5.0,
              "label": "Grace period (days)",
              "description": "Days after dueDate before the charge is treated as overdue. Wire via sibling std-lifecycle rule.",
              "tier": "customization"
            },
            "taxStrategy": {
              "type": "string",
              "default": "none",
              "label": "Tax strategy",
              "description": "inclusive = tax baked into rent; exclusive = tax added on top; none = no tax.",
              "tier": "customization",
              "values": [
                "inclusive",
                "exclusive",
                "none"
              ]
            },
            "lateFeeAmount": {
              "type": "number",
              "default": 25.0,
              "label": "Late fee amount",
              "description": "Flat cash amount or percentage (per lateFeePolicy).",
              "tier": "customization"
            },
            "lateRentGraceDays": {
              "type": "number",
              "default": 5.0,
              "label": "Late rent grace (days)",
              "description": "Days after dueDate before late fee is auto-assessed. Real-estate-specific alias for gracePeriodDays. Declarative.",
              "tier": "customization"
            },
            "petPolicy": {
              "type": "string",
              "default": "no-pets",
              "label": "Pet policy",
              "description": "Property-level pet policy. Declarative.",
              "tier": "customization",
              "values": [
                "no-pets",
                "cats-only",
                "dogs-only",
                "all"
              ]
            }
          },
          "scope": "collection"
        }
