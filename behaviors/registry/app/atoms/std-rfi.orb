{
  "name": "std-rfi",
  "version": "1.2.0",
  "description": "std-rfi — RFI pipeline for construction projects. Listens for SET_STATUS so std-lifecycle can auto-close stale RFIs. Exposes Service/Operations knobs (responseTimeMinutes, resolutionSLAHours, …).",
  "orbitals": [
    {
      "name": "RfiOrbital",
      "entity": {
        "name": "Rfi",
        "collection": "rfis",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "rfiNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "required": true
          },
          {
            "name": "question",
            "type": "string",
            "default": ""
          },
          {
            "name": "response",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "answered",
              "closed"
            ]
          },
          {
            "name": "raisedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "raisedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "dueAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "answeredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RfiPipeline",
          "category": "interaction",
          "linkedEntity": "Rfi",
          "emits": [
            {
              "event": "OPEN_RFI",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.rfiNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.question",
                  "type": "string"
                },
                {
                  "name": "row.response",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.raisedBy",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.raisedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.answeredAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ANSWER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RfiLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Rfi]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "RfiLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RfiLoaded",
                "name": "Rfi loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Rfi]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "RfiLoadFailed",
                "name": "Rfi load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RFI",
                "name": "Open Rfi",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Rfi"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ANSWER",
                "name": "Answer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "success": "RfiLoaded",
                        "failure": "RfiLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading RFIs…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RfiLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "help-circle"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "label": "Total RFIs",
                              "value": "@payload.data.length",
                              "icon": "help-circle",
                              "type": "stat-display"
                            },
                            {
                              "value": "18",
                              "label": "Open",
                              "icon": "mail",
                              "type": "stat-display"
                            },
                            {
                              "label": "Overdue",
                              "icon": "alert-triangle",
                              "value": "5",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Avg response",
                              "icon": "clock",
                              "value": "3.2d"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "type": "data-grid",
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RfiLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RFI",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.rfiNumber",
                    "@payload.row.rfiNumber"
                  ],
                  [
                    "set",
                    "@entity.subject",
                    "@payload.row.subject"
                  ],
                  [
                    "set",
                    "@entity.question",
                    "@payload.row.question"
                  ],
                  [
                    "set",
                    "@entity.response",
                    "@payload.row.response"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.raisedBy",
                    "@payload.row.raisedBy"
                  ],
                  [
                    "set",
                    "@entity.assignedTo",
                    "@payload.row.assignedTo"
                  ],
                  [
                    "set",
                    "@entity.raisedAt",
                    "@payload.row.raisedAt"
                  ],
                  [
                    "set",
                    "@entity.dueAt",
                    "@payload.row.dueAt"
                  ],
                  [
                    "set",
                    "@entity.answeredAt",
                    "@payload.row.answeredAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "help-circle"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.subject",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "RFI #",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.rfiNumber"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Question"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.question"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Response",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.response"
                                }
                              ]
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.raisedBy",
                              "label": "Raised by",
                              "icon": "user"
                            },
                            {
                              "type": "stat-display",
                              "label": "Assigned",
                              "icon": "user-check",
                              "value": "@entity.assignedTo"
                            },
                            {
                              "value": "@entity.dueAt",
                              "type": "stat-display",
                              "icon": "calendar",
                              "label": "Due"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "@entity.answeredAt",
                              "label": "Answered"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Submit",
                              "variant": "primary",
                              "action": "SUBMIT"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "secondary",
                              "action": "ANSWER",
                              "label": "Answer",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Close",
                              "action": "CLOSE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "failure": "RfiLoadFailed",
                        "success": "RfiLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Submitting RFI…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ANSWER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "failure": "RfiLoadFailed",
                        "success": "RfiLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Answering RFI…"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "success": "RfiLoaded",
                        "failure": "RfiLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Closing RFI…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Rfi",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RfiLoadFailed",
                        "success": "RfiLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating RFI status…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "failure": "RfiLoadFailed",
                        "success": "RfiLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading RFIs…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "success": "RfiLoaded",
                        "failure": "RfiLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Submitting RFI…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ANSWER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "failure": "RfiLoadFailed",
                        "success": "RfiLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Answering RFI…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "success": "RfiLoaded",
                        "failure": "RfiLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Closing RFI…"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Rfi",
                    {
                      "emit": {
                        "failure": "RfiLoadFailed",
                        "success": "RfiLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "resolutionSLAHours": {
              "type": "number",
              "default": 120.0,
              "label": "Resolution SLA (hours)",
              "description": "Target hours from raised to answered (default 5 business days). Compose std-lifecycle to escalate.",
              "tier": "essential"
            },
            "responseTimeMinutes": {
              "type": "number",
              "default": 480.0,
              "label": "Response time SLA (min)",
              "description": "Target minutes from raised to first acknowledgement (default 8 business hours).",
              "tier": "essential"
            },
            "skillsRequired": {
              "type": "[string]",
              "default": [],
              "label": "Required skills",
              "description": "Discipline tags a responder must hold (e.g. 'structural', 'mep', 'arch').",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "default": "RFIs",
              "label": "Section title",
              "description": "Heading shown above the RFI pipeline",
              "tier": "customization"
            },
            "dispatchStrategy": {
              "type": "string",
              "default": "manual",
              "label": "Dispatch strategy",
              "description": "How responders are picked when an RFI is raised.",
              "tier": "customization",
              "values": [
                "nearest",
                "round-robin",
                "manual"
              ]
            },
            "serviceAreaRadius": {
              "type": "number",
              "default": 0.0,
              "label": "Service area radius (mi)",
              "description": "Project-site distance limit for assignable responders. Zero = no restriction.",
              "tier": "customization"
            },
            "customerVisibleStatuses": {
              "type": "[string]",
              "default": [
                "submitted",
                "answered",
                "closed"
              ],
              "label": "Customer-visible statuses",
              "description": "Subset of statuses external collaborators see.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "rfiNumber",
                  "variant": "caption",
                  "label": "RFI #"
                },
                {
                  "label": "Subject",
                  "name": "subject",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "name": "raisedBy",
                  "label": "Raised By",
                  "variant": "caption"
                },
                {
                  "name": "assignedTo",
                  "variant": "caption",
                  "label": "Assigned"
                },
                {
                  "variant": "caption",
                  "name": "dueAt",
                  "label": "Due"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the RFI entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "serviceZones": {
              "type": "[string]",
              "default": [],
              "label": "Service zones",
              "description": "Named project zones for routing RFIs to the right responder pool.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "escalationThresholdHours": {
              "type": "number",
              "default": 168.0,
              "label": "Escalation threshold (hours)",
              "description": "Hours after which a stalled RFI auto-escalates (default 7 days).",
              "tier": "customization"
            },
            "requirePhotoOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require photo on complete",
              "description": "Block ANSWER unless a supporting attachment is provided.",
              "tier": "customization"
            },
            "requireSignatureOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require responder signature on complete",
              "description": "Block ANSWER unless responder signature is captured (compose std-signature-capture).",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_RFI"
                },
                {
                  "event": "CLOSE",
                  "label": "Close",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each RFI row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
