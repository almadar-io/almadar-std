{
  "name": "std-kitchen-display",
  "version": "1.0.0",
  "description": "std-kitchen-display — restaurant POS kitchen display system. Owns a KitchenTicket entity (one row per kitchen-bound order) and a single management trait that loads pending tickets, renders them in a data-grid with Mark Preparing / Ready / Served actions, and persists status + aging back to the row.",
  "orbitals": [
    {
      "name": "KitchenTicketOrbital",
      "entity": {
        "name": "KitchenTicket",
        "collection": "kitchentickets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "orderId",
            "type": "string",
            "required": true
          },
          {
            "name": "tableLabel",
            "type": "string"
          },
          {
            "name": "serverName",
            "type": "string"
          },
          {
            "name": "itemsJson",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "preparing",
              "ready",
              "served"
            ]
          },
          {
            "name": "aging",
            "type": "string",
            "default": "fresh",
            "values": [
              "fresh",
              "normal",
              "aging",
              "overdue"
            ]
          },
          {
            "name": "receivedAt",
            "type": "string"
          },
          {
            "name": "readyAt",
            "type": "string"
          },
          {
            "name": "servedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "KitchenTicketManage",
          "category": "interaction",
          "linkedEntity": "KitchenTicket",
          "emits": [
            {
              "event": "MARK_PREPARING",
              "payloadSchema": [
                {
                  "name": "ticketId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.orderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tableLabel",
                  "type": "string"
                },
                {
                  "name": "row.serverName",
                  "type": "string"
                },
                {
                  "name": "row.itemsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.aging",
                  "type": "string"
                },
                {
                  "name": "row.receivedAt",
                  "type": "string"
                },
                {
                  "name": "row.readyAt",
                  "type": "string"
                },
                {
                  "name": "row.servedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_READY",
              "payloadSchema": [
                {
                  "name": "ticketId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "readyAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.orderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tableLabel",
                  "type": "string"
                },
                {
                  "name": "row.serverName",
                  "type": "string"
                },
                {
                  "name": "row.itemsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.aging",
                  "type": "string"
                },
                {
                  "name": "row.receivedAt",
                  "type": "string"
                },
                {
                  "name": "row.readyAt",
                  "type": "string"
                },
                {
                  "name": "row.servedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_SERVED",
              "payloadSchema": [
                {
                  "name": "ticketId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "servedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.orderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tableLabel",
                  "type": "string"
                },
                {
                  "name": "row.serverName",
                  "type": "string"
                },
                {
                  "name": "row.itemsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.aging",
                  "type": "string"
                },
                {
                  "name": "row.receivedAt",
                  "type": "string"
                },
                {
                  "name": "row.readyAt",
                  "type": "string"
                },
                {
                  "name": "row.servedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "KitchenTicketLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[KitchenTicket]"
                }
              ]
            },
            {
              "event": "KitchenTicketLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "KitchenTicketUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.orderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tableLabel",
                  "type": "string"
                },
                {
                  "name": "row.serverName",
                  "type": "string"
                },
                {
                  "name": "row.itemsJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.aging",
                  "type": "string"
                },
                {
                  "name": "row.receivedAt",
                  "type": "string"
                },
                {
                  "name": "row.readyAt",
                  "type": "string"
                },
                {
                  "name": "row.servedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "KitchenTicketUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "KitchenTicketLoaded",
                "name": "KitchenTicket loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[KitchenTicket]"
                  }
                ]
              },
              {
                "key": "KitchenTicketLoadFailed",
                "name": "KitchenTicket load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MARK_PREPARING",
                "name": "Mark Preparing",
                "payloadSchema": [
                  {
                    "name": "ticketId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "KitchenTicket"
                  }
                ]
              },
              {
                "key": "MARK_READY",
                "name": "Mark Ready",
                "payloadSchema": [
                  {
                    "name": "ticketId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "readyAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "KitchenTicket"
                  }
                ]
              },
              {
                "key": "MARK_SERVED",
                "name": "Mark Served",
                "payloadSchema": [
                  {
                    "name": "ticketId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "servedAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "KitchenTicket"
                  }
                ]
              },
              {
                "key": "KitchenTicketUpdated",
                "name": "KitchenTicket updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "KitchenTicket"
                  }
                ]
              },
              {
                "key": "KitchenTicketUpdateFailed",
                "name": "KitchenTicket update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "KitchenTicket",
                    {
                      "emit": {
                        "success": "KitchenTicketLoaded",
                        "failure": "KitchenTicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading kitchen tickets…"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "KitchenTicketLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "chef-hat"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "secondary",
                              "event": "MARK_PREPARING",
                              "icon": "flame",
                              "label": "Mark Preparing"
                            },
                            {
                              "label": "Mark Ready",
                              "icon": "check",
                              "variant": "primary",
                              "event": "MARK_READY"
                            },
                            {
                              "icon": "utensils",
                              "event": "MARK_SERVED",
                              "variant": "primary",
                              "label": "Mark Served"
                            }
                          ],
                          "fields": [
                            {
                              "name": "orderId",
                              "label": "Order",
                              "variant": "label"
                            },
                            {
                              "name": "tableLabel",
                              "label": "Table",
                              "variant": "caption"
                            },
                            {
                              "name": "serverName",
                              "label": "Server",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "label": "Aging",
                              "variant": "badge",
                              "name": "aging"
                            },
                            {
                              "label": "Received",
                              "variant": "caption",
                              "name": "receivedAt"
                            }
                          ],
                          "type": "data-grid",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "KitchenTicketLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_PREPARING",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.ticketId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "preparing"
                  ],
                  [
                    "persist",
                    "update",
                    "KitchenTicket",
                    "@entity",
                    {
                      "emit": {
                        "success": "KitchenTicketUpdated",
                        "failure": "KitchenTicketUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_READY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.ticketId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "ready"
                  ],
                  [
                    "set",
                    "@entity.readyAt",
                    "@payload.readyAt"
                  ],
                  [
                    "persist",
                    "update",
                    "KitchenTicket",
                    "@entity",
                    {
                      "emit": {
                        "success": "KitchenTicketUpdated",
                        "failure": "KitchenTicketUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_SERVED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.ticketId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "served"
                  ],
                  [
                    "set",
                    "@entity.servedAt",
                    "@payload.servedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "KitchenTicket",
                    "@entity",
                    {
                      "emit": {
                        "success": "KitchenTicketUpdated",
                        "failure": "KitchenTicketUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "KitchenTicketUpdated",
                "effects": [
                  [
                    "fetch",
                    "KitchenTicket",
                    {
                      "emit": {
                        "success": "KitchenTicketLoaded",
                        "failure": "KitchenTicketLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "KitchenTicketUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "KitchenTicket",
                    {
                      "emit": {
                        "success": "KitchenTicketLoaded",
                        "failure": "KitchenTicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "overdueMinutes": {
              "type": "number",
              "default": 20.0
            },
            "title": {
              "type": "string",
              "default": "Kitchen Display"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "KitchenTicketManagePage",
          "path": "/kitchentickets/manage",
          "traits": [
            {
              "ref": "KitchenTicketManage"
            }
          ]
        }
      ]
    }
  ]
}
