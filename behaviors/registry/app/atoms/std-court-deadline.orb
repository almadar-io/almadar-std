{
  "name": "std-court-deadline",
  "version": "1.0.0",
  "description": "std-court-deadline — statutory filing deadline tied to a legal matter. Browses deadlines in a data-grid with Complete / Extend row actions.",
  "orbitals": [
    {
      "name": "CourtDeadlineOrbital",
      "entity": {
        "name": "CourtDeadline",
        "collection": "courtdeadlines",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterId",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "deadlineType",
            "type": "string",
            "default": "filing",
            "values": [
              "filing",
              "response",
              "discovery",
              "hearing",
              "trial",
              "other"
            ]
          },
          {
            "name": "dueAt",
            "type": "string",
            "required": true
          },
          {
            "name": "jurisdiction",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "upcoming",
            "values": [
              "upcoming",
              "completed",
              "missed",
              "extended"
            ]
          },
          {
            "name": "reminderSent",
            "type": "boolean",
            "default": false
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CourtDeadlineDocket",
          "category": "interaction",
          "linkedEntity": "CourtDeadline",
          "emits": [
            {
              "event": "MARK_COMPLETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EXTEND_DEADLINE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CourtDeadlineLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CourtDeadline]"
                }
              ]
            },
            {
              "event": "CourtDeadlineLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CourtDeadlineLoaded",
                "name": "CourtDeadline loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CourtDeadline]"
                  }
                ]
              },
              {
                "key": "CourtDeadlineLoadFailed",
                "name": "CourtDeadline load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MARK_COMPLETED",
                "name": "Mark Completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXTEND_DEADLINE",
                "name": "Extend Deadline",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "failure": "CourtDeadlineLoadFailed",
                        "success": "CourtDeadlineLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CourtDeadlineLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "date-range-selector",
                          "options": [
                            {
                              "label": "This Week",
                              "value": "this-week"
                            },
                            {
                              "value": "this-month",
                              "label": "This Month"
                            },
                            {
                              "value": "this-quarter",
                              "label": "This Quarter"
                            },
                            {
                              "label": "This Year",
                              "value": "this-year"
                            }
                          ],
                          "selected": "this-month"
                        },
                        {
                          "title": "Deadline Chronology",
                          "fields": [
                            "title",
                            "date",
                            "status",
                            "description"
                          ],
                          "type": "timeline",
                          "items": [
                            {
                              "id": "filing",
                              "status": "completed",
                              "date": "2026-01-15",
                              "description": "Initial filing submitted",
                              "title": "Filing"
                            },
                            {
                              "date": "2026-02-20",
                              "description": "Defendant response due",
                              "status": "current",
                              "id": "response",
                              "title": "Response"
                            },
                            {
                              "status": "upcoming",
                              "date": "2026-04-10",
                              "description": "Discovery cutoff",
                              "id": "discovery",
                              "title": "Discovery"
                            },
                            {
                              "date": "2026-06-15",
                              "id": "hearing",
                              "status": "upcoming",
                              "description": "Pretrial hearing",
                              "title": "Hearing"
                            },
                            {
                              "title": "Trial",
                              "status": "upcoming",
                              "date": "2026-09-01",
                              "description": "Trial date",
                              "id": "trial"
                            }
                          ]
                        },
                        {
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "title",
                              "variant": "caption",
                              "label": "Title"
                            },
                            {
                              "variant": "badge",
                              "name": "deadlineType",
                              "label": "Type"
                            },
                            {
                              "name": "dueAt",
                              "label": "Due",
                              "variant": "caption"
                            },
                            {
                              "name": "jurisdiction",
                              "label": "Jurisdiction",
                              "variant": "caption"
                            },
                            {
                              "name": "assignedTo",
                              "label": "Assigned",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "itemActions": [
                            {
                              "label": "Complete",
                              "event": "MARK_COMPLETED",
                              "variant": "primary"
                            },
                            {
                              "label": "Extend",
                              "event": "EXTEND_DEADLINE",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CourtDeadlineLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_COMPLETED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Deadline completed",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EXTEND_DEADLINE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Deadline extended",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Deadlines"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CourtDeadlinePage",
          "path": "/deadlines",
          "traits": [
            {
              "ref": "CourtDeadlineDocket"
            }
          ]
        }
      ]
    }
  ]
}