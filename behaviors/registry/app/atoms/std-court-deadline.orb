{
  "name": "std-court-deadline",
  "version": "1.2.0",
  "description": "std-court-deadline — statutory filing deadline tied to a legal matter. Listens for SET_STATUS so std-lifecycle can auto-miss / auto-complete. Exposes Scheduling + Legal knobs (bookingWindowDays, practiceArea, conflictCheckRequired, …).",
  "orbitals": [
    {
      "name": "CourtDeadlineOrbital",
      "entity": {
        "name": "CourtDeadline",
        "collection": "courtdeadlines",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterId",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "deadlineType",
            "type": "string",
            "default": "filing",
            "values": [
              "filing",
              "response",
              "discovery",
              "hearing",
              "trial",
              "other"
            ]
          },
          {
            "name": "dueAt",
            "type": "string",
            "required": true
          },
          {
            "name": "jurisdiction",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "upcoming",
            "values": [
              "upcoming",
              "completed",
              "missed",
              "extended"
            ]
          },
          {
            "name": "reminderSent",
            "type": "boolean",
            "default": false
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CourtDeadlineDocket",
          "category": "interaction",
          "linkedEntity": "CourtDeadline",
          "emits": [
            {
              "event": "OPEN_DEADLINE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.deadlineType",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.jurisdiction",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.reminderSent",
                  "type": "boolean"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "MARK_COMPLETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EXTEND_DEADLINE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CourtDeadlineLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CourtDeadline]"
                }
              ]
            },
            {
              "event": "CourtDeadlineLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CourtDeadlineLoaded",
                "name": "CourtDeadline loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CourtDeadline]"
                  }
                ]
              },
              {
                "key": "CourtDeadlineLoadFailed",
                "name": "CourtDeadline load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_DEADLINE",
                "name": "Open Deadline",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "CourtDeadline"
                  }
                ]
              },
              {
                "key": "MARK_COMPLETED",
                "name": "Mark Completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "EXTEND_DEADLINE",
                "name": "Extend Deadline",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "failure": "CourtDeadlineLoadFailed",
                        "success": "CourtDeadlineLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading deadlines…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CourtDeadlineLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "calendar-clock",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "label": "Total deadlines",
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "icon": "calendar-clock"
                            },
                            {
                              "type": "stat-display",
                              "icon": "alert-triangle",
                              "label": "Due this week",
                              "value": "7"
                            },
                            {
                              "value": "84%",
                              "label": "Completed",
                              "type": "stat-display",
                              "icon": "check-circle"
                            },
                            {
                              "value": "2",
                              "type": "stat-display",
                              "label": "Missed YTD",
                              "icon": "x-circle"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "fields": "@config.fields"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CourtDeadlineLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_DEADLINE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.matterId",
                    "@payload.row.matterId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.deadlineType",
                    "@payload.row.deadlineType"
                  ],
                  [
                    "set",
                    "@entity.dueAt",
                    "@payload.row.dueAt"
                  ],
                  [
                    "set",
                    "@entity.jurisdiction",
                    "@payload.row.jurisdiction"
                  ],
                  [
                    "set",
                    "@entity.assignedTo",
                    "@payload.row.assignedTo"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "name": "calendar-clock",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.title",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.deadlineType",
                              "type": "badge",
                              "variant": "primary"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Matter",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.matterId",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Jurisdiction",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.jurisdiction"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Assigned to",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.assignedTo",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Notes",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.notes",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.dueAt",
                              "label": "Due",
                              "type": "stat-display",
                              "icon": "calendar"
                            },
                            {
                              "type": "stat-display",
                              "label": "Status",
                              "icon": "tag",
                              "value": "@entity.status"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "MARK_COMPLETED",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Mark Complete"
                            },
                            {
                              "variant": "secondary",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Extend",
                              "action": "EXTEND_DEADLINE"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_COMPLETED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "failure": "CourtDeadlineLoadFailed",
                        "success": "CourtDeadlineLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Completing deadline…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "CourtDeadline",
                    "@entity",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Updating deadline status…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading deadlines…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_COMPLETED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Completing deadline…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EXTEND_DEADLINE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "failure": "CourtDeadlineLoadFailed",
                        "success": "CourtDeadlineLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Extending deadline…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Deadlines",
              "label": "Section title",
              "description": "Heading shown above the legal deadlines docket",
              "tier": "presentation"
            },
            "retainerRequired": {
              "type": "boolean",
              "default": false,
              "label": "Retainer required",
              "description": "Require a signed retainer before work begins on the matter.",
              "tier": "domain"
            },
            "billingRateDefault": {
              "type": "number",
              "default": 0.0,
              "label": "Default billing rate",
              "description": "Default hourly billing rate applied to work logged against this deadline.",
              "tier": "domain"
            },
            "maxReschedules": {
              "type": "number",
              "default": 2.0,
              "label": "Max reschedules",
              "description": "Hard cap on extension count per deadline.",
              "tier": "domain"
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 72.0,
              "label": "Reschedule window (hours)",
              "description": "Hours before dueAt during which an extension request is accepted.",
              "tier": "domain"
            },
            "practiceArea": {
              "type": "string",
              "default": "",
              "label": "Practice area",
              "description": "Practice area (e.g. litigation, IP, family). Drives docket grouping.",
              "tier": "domain"
            },
            "blackoutDates": {
              "type": "[string]",
              "default": [],
              "label": "Blackout dates",
              "description": "ISO dates (court holidays) blocked from scheduling. Compose std-lifecycle to auto-shift.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "title",
                  "variant": "caption",
                  "label": "Title"
                },
                {
                  "label": "Type",
                  "name": "deadlineType",
                  "variant": "badge"
                },
                {
                  "label": "Due",
                  "name": "dueAt",
                  "variant": "caption"
                },
                {
                  "name": "jurisdiction",
                  "label": "Jurisdiction",
                  "variant": "caption"
                },
                {
                  "name": "assignedTo",
                  "variant": "caption",
                  "label": "Assigned"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Court Deadline entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "cancellationPolicy": {
              "type": "string",
              "default": "no-refund",
              "label": "Cancellation policy",
              "description": "Refund treatment when a deadline is cancelled (typically n/a for legal).",
              "tier": "domain",
              "values": [
                "free",
                "partial-refund",
                "no-refund"
              ]
            },
            "policyId": {
              "type": "string",
              "default": "",
              "label": "Appointment policy reference",
              "description": "Optional reference to a shared std-appointment-policy entity. When set, the policy's reschedule/cancellation/no-show values supersede the local knobs. Declarative — runtime resolution lands separately.",
              "synonyms": "policy ref, shared policy, policy id",
              "tier": "domain"
            },
            "leadTimeMinutes": {
              "type": "number",
              "default": 1440.0,
              "label": "Lead time (minutes)",
              "description": "Minimum minutes before dueAt at which a deadline can still be created (default 1 day).",
              "tier": "domain"
            },
            "conflictCheckRequired": {
              "type": "boolean",
              "default": true,
              "label": "Conflict check required",
              "description": "Block creation until a conflict-of-interest check is on file.",
              "tier": "domain"
            },
            "bookingHours": {
              "type": "string",
              "default": "00:00-23:59",
              "label": "Booking hours",
              "description": "Daily window during which deadlines can be created (HH:MM-HH:MM).",
              "tier": "domain"
            },
            "noShowGracePeriodMinutes": {
