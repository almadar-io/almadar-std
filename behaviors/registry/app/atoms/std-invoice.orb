{
  "name": "std-invoice",
  "version": "1.0.0",
  "description": "std-invoice — invoice generation atom. Owns an Invoice entity (line-items + tax + total + refund tiers via config). Browses invoices in a data-grid with Send / Mark-Paid / Void / Refund actions; viewing state renders the canonical invoice pattern detail.",
  "orbitals": [
    {
      "name": "InvoiceOrbital",
      "entity": {
        "name": "InvoiceRecord",
        "collection": "invoices",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "invoiceNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "paid",
              "overdue",
              "void"
            ]
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "issuedAt",
            "type": "string"
          },
          {
            "name": "dueAt",
            "type": "string"
          },
          {
            "name": "paidAt",
            "type": "string"
          },
          {
            "name": "lineItemsJson",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "InvoiceManage",
          "category": "interaction",
          "linkedEntity": "InvoiceRecord",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SEND",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_PAID",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REFUND",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "InvoiceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[InvoiceRecord]"
                }
              ]
            },
            {
              "event": "InvoiceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceRefunded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceRefundFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InvoiceLoaded",
                "name": "Invoice loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[InvoiceRecord]"
                  }
                ]
              },
              {
                "key": "InvoiceLoadFailed",
                "name": "Invoice load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_PAID",
                "name": "Mark Paid",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VOID",
                "name": "Void",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFUND",
                "name": "Refund",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "InvoiceUpdated",
                "name": "Invoice updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "InvoiceUpdateFailed",
                "name": "Invoice update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "InvoiceRefunded",
                "name": "Invoice refunded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "InvoiceRefundFailed",
                "name": "Invoice refund failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading invoices…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InvoiceLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": [
                            {
                              "name": "invoiceNumber",
                              "label": "Invoice #",
                              "variant": "caption"
                            },
                            {
                              "name": "customerId",
                              "label": "Customer",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "label": "Total",
                              "name": "total",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "currency",
                              "label": "Currency"
                            },
                            {
                              "name": "dueAt",
                              "label": "Due",
                              "variant": "caption"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "secondary",
                              "icon": "eye"
                            },
                            {
                              "variant": "primary",
                              "icon": "send",
                              "label": "Send",
                              "event": "SEND"
                            },
                            {
                              "event": "MARK_PAID",
                              "label": "Mark Paid",
                              "icon": "check",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "icon": "x",
                              "label": "Void",
                              "event": "VOID"
                            },
                            {
                              "label": "Refund",
                              "event": "REFUND",
                              "variant": "danger",
                              "icon": "rotate-ccw"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InvoiceLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.invoiceNumber",
                    "@payload.row.invoiceNumber"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "@payload.row.issuedAt"
                  ],
                  [
                    "set",
                    "@entity.dueAt",
                    "@payload.row.dueAt"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.invoiceNumber"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "secondary",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Issued",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body2",
                                  "content": "@entity.issuedAt"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            },
                            {
                              "direction": "vertical",
                              "children": [
                                {
                                  "content": "Due",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.dueAt",
                                  "variant": "body2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "xs",
                              "type": "stack"
                            },
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "xs",
                              "children": [
                                {
                                  "content": "Currency",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.currency",
                                  "variant": "body2",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "gap": "lg"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "@entity.notes",
                          "variant": "body2",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "icon": "send",
                              "label": "Send",
                              "type": "button",
                              "action": "SEND",
                              "variant": "primary"
                            },
                            {
                              "label": "Mark Paid",
                              "action": "MARK_PAID",
                              "variant": "primary",
                              "type": "button",
                              "icon": "check"
                            },
                            {
                              "icon": "x",
                              "variant": "danger",
                              "action": "VOID",
                              "type": "button",
                              "label": "Void"
                            },
                            {
                              "icon": "rotate-ccw",
                              "action": "REFUND",
                              "label": "Refund",
                              "type": "button",
                              "variant": "danger"
                            },
                            {
                              "label": "Back",
                              "action": "INIT",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "arrow-left"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "invoiceId": "@payload.invoiceId"
                    },
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "paid"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VOID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "void"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REFUND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "call-service",
                    "stripe",
                    "refund",
                    {
                      "amount": "@payload.amount",
                      "invoiceId": "@payload.invoiceId"
                    },
                    {
                      "emit": {
                        "success": "InvoiceRefunded",
                        "failure": "InvoiceRefundFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "InvoiceUpdated",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "InvoiceUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "InvoiceRefunded",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "InvoiceRefundFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "InvoiceUpdated",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "success": "InvoiceLoaded",
                        "failure": "InvoiceLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "success": "InvoiceLoaded",
                        "failure": "InvoiceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Invoices"
            },
            "refundTiersJson": {
              "type": "string",
              "default": "[]"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "InvoiceManagePage",
          "path": "/invoices/manage",
          "traits": [
            {
              "ref": "InvoiceManage"
            }
          ]
        }
      ]
    }
  ]
}
