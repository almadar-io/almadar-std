{
  "name": "std-invoice",
  "version": "1.1.0",
  "description": "std-invoice — invoice generation atom. Owns an Invoice entity (line-items + tax + total + refund tiers via config). Browses invoices in a data-grid with Send / Mark-Paid / Void / Refund actions; viewing state renders the canonical invoice pattern detail. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "InvoiceOrbital",
      "entity": {
        "name": "InvoiceRecord",
        "collection": "invoices",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "invoiceNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "paid",
              "overdue",
              "void"
            ]
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "issuedAt",
            "type": "string"
          },
          {
            "name": "dueAt",
            "type": "string"
          },
          {
            "name": "paidAt",
            "type": "string"
          },
          {
            "name": "lineItemsJson",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "InvoiceManage",
          "category": "interaction",
          "linkedEntity": "InvoiceRecord",
          "emits": [
            {
              "event": "OPEN_INVOICE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SEND",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_PAID",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REFUND",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "InvoiceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[InvoiceRecord]"
                }
              ]
            },
            {
              "event": "InvoiceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceRefunded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceRefundFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InvoiceLoaded",
                "name": "Invoice loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[InvoiceRecord]"
                  }
                ]
              },
              {
                "key": "InvoiceLoadFailed",
                "name": "Invoice load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_INVOICE",
                "name": "Open Invoice",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "VOID",
                "name": "Void",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "InvoiceUpdated",
                "name": "Invoice updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "InvoiceUpdateFailed",
                "name": "Invoice update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "InvoiceRefunded",
                "name": "Invoice refunded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "InvoiceRefundFailed",
                "name": "Invoice refund failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_PAID",
                "name": "Mark Paid",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFUND",
                "name": "Refund",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "success": "InvoiceLoaded",
                        "failure": "InvoiceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading invoices…"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InvoiceLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total invoices",
                              "icon": "receipt"
                            },
                            {
                              "type": "stat-display",
                              "label": "Outstanding",
                              "value": "$28,400",
                              "icon": "alert-triangle"
                            },
                            {
                              "icon": "dollar-sign",
                              "value": "$112,800",
                              "type": "stat-display",
                              "label": "Paid this month"
                            },
                            {
                              "icon": "clock",
                              "label": "Overdue",
                              "value": "9",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InvoiceLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_INVOICE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.invoiceNumber",
                    "@payload.row.invoiceNumber"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.subtotal",
                    "@payload.row.subtotal"
                  ],
                  [
                    "set",
                    "@entity.tax",
                    "@payload.row.tax"
                  ],
                  [
                    "set",
                    "@entity.total",
                    "@payload.row.total"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "@payload.row.issuedAt"
                  ],
                  [
                    "set",
                    "@entity.dueAt",
                    "@payload.row.dueAt"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "@payload.row.paidAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.invoiceNumber"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Customer",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.customerId"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Currency"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.currency",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Notes",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Subtotal",
                              "icon": "dollar-sign",
                              "value": "@entity.subtotal"
                            },
                            {
                              "icon": "percent",
                              "type": "stat-display",
                              "label": "Tax",
                              "value": "@entity.tax"
                            },
                            {
                              "type": "stat-display",
                              "icon": "dollar-sign",
                              "value": "@entity.total",
                              "label": "Total"
                            },
                            {
                              "label": "Due",
                              "value": "@entity.dueAt",
                              "type": "stat-display",
                              "icon": "calendar"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "Send",
                              "variant": "primary",
                              "action": "SEND",
                              "actionPayload": {
                                "invoiceId": "@entity.id"
                              }
                            },
                            {
                              "actionPayload": {
                                "invoiceId": "@entity.id"
                              },
                              "type": "button",
                              "label": "Mark Paid",
                              "action": "MARK_PAID",
                              "variant": "primary"
                            },
                            {
                              "label": "Void",
                              "actionPayload": {
                                "invoiceId": "@entity.id"
                              },
                              "action": "VOID",
                              "type": "button",
                              "variant": "danger"
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Refund",
                              "actionPayload": {
                                "amount": 0.0,
                                "invoiceId": "@entity.id"
                              },
                              "action": "REFUND"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "VOID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "void"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "failure": "InvoiceUpdateFailed",
                        "success": "InvoiceUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Voiding invoice…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "InvoiceUpdated",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "InvoiceUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "InvoiceRefunded",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "success": "InvoiceLoaded",
                        "failure": "InvoiceLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "InvoiceRefundFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "success": "InvoiceLoaded",
                        "failure": "InvoiceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading invoices…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Sending invoice…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "paid"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "failure": "InvoiceUpdateFailed",
                        "success": "InvoiceUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Marking invoice paid…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VOID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "void"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Voiding invoice…"
                        }
                      ],
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REFUND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "call-service",
                    "stripe",
                    "refund",
                    {
                      "invoiceId": "@payload.invoiceId",
                      "amount": "@payload.amount"
                    },
                    {
                      "emit": {
                        "failure": "InvoiceRefundFailed",
                        "success": "InvoiceRefunded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Refunding invoice…"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "success": "InvoiceLoaded",
                        "failure": "InvoiceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_INVOICE",
                  "variant": "primary",
                  "icon": "arrow-right"
                },
                {
                  "event": "VOID",
                  "label": "Void",
                  "variant": "danger",
                  "icon": "x"
                }
              ]
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "invoiceNumber",
                  "label": "Invoice #",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Customer",
                  "name": "customerId"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "name": "total",
                  "label": "Total",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "name": "currency",
                  "label": "Currency"
                },
                {
                  "label": "Due",
                  "variant": "caption",
                  "name": "dueAt"
                }
              ]
            },
            "refundTiersJson": {
              "type": "string",
              "default": "[]"
            },
            "title": {
              "type": "string",
              "default": "Invoices"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "InvoiceManagePage",
          "path": "/invoices/manage",
          "traits": [
            {
              "ref": "InvoiceManage"
            }
          ]
        }
      ]
    }
  ]
}
