{
  "name": "std-template-editor",
  "version": "1.0.0",
  "description": "std-template-editor — message template authoring primitive. Edits email/SMS templates with variables like {{firstName}}. Templates are reused across broadcasts and drip sequences.",
  "orbitals": [
    {
      "name": "MessageTemplateOrbital",
      "entity": {
        "name": "MessageTemplate",
        "collection": "messagetemplates",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "channel",
            "type": "string",
            "default": "email",
            "values": [
              "email",
              "sms"
            ]
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "variables",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastEditedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MessageTemplateEditor",
          "category": "interaction",
          "linkedEntity": "MessageTemplate",
          "emits": [
            {
              "event": "EDIT_TEMPLATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SAVE_TEMPLATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MessageTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MessageTemplate]"
                }
              ]
            },
            {
              "event": "MessageTemplateLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MessageTemplateLoaded",
                "name": "MessageTemplate loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MessageTemplate]"
                  }
                ]
              },
              {
                "key": "MessageTemplateLoadFailed",
                "name": "MessageTemplate load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EDIT_TEMPLATE",
                "name": "Edit Template",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_TEMPLATE",
                "name": "Save Template",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading templates…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MessageTemplateLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Channel",
                              "variant": "badge",
                              "name": "channel"
                            },
                            {
                              "label": "Subject",
                              "variant": "caption",
                              "name": "subject"
                            },
                            {
                              "variant": "caption",
                              "name": "lastEditedAt",
                              "label": "Updated"
                            }
                          ],
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Edit",
                              "variant": "ghost",
                              "event": "EDIT_TEMPLATE"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MessageTemplateLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT_TEMPLATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "card",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "edit"
                                },
                                {
                                  "type": "typography",
                                  "content": "Edit template",
                                  "variant": "h3"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "label": "Save",
                              "variant": "primary",
                              "action": "SAVE_TEMPLATE",
                              "type": "button"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "SAVE_TEMPLATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Template saved",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Templates"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MessageTemplatePage",
          "path": "/templates",
          "traits": [
            {
              "ref": "MessageTemplateEditor"
            }
          ]
        }
      ]
    }
  ]
}
