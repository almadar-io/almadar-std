{
  "name": "std-template-editor",
  "version": "1.1.0",
  "description": "std-template-editor — message template authoring primitive. Lists templates in `browsing`; opens detail in `viewing_single` with Edit / Save / Delete actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "MessageTemplateOrbital",
      "entity": {
        "name": "MessageTemplate",
        "collection": "messagetemplates",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "channel",
            "type": "string",
            "default": "email",
            "values": [
              "email",
              "sms"
            ]
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "variables",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastEditedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MessageTemplateEditor",
          "category": "interaction",
          "linkedEntity": "MessageTemplate",
          "emits": [
            {
              "event": "OPEN_TEMPLATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.channel",
                  "type": "string"
                },
                {
                  "name": "row.subject",
                  "type": "string"
                },
                {
                  "name": "row.body",
                  "type": "string"
                },
                {
                  "name": "row.variables",
                  "type": "string"
                },
                {
                  "name": "row.lastEditedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "EDIT_TEMPLATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SAVE_TEMPLATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE_TEMPLATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MessageTemplateLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MessageTemplate]"
                }
              ]
            },
            {
              "event": "MessageTemplateLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MessageTemplateLoaded",
                "name": "MessageTemplate loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MessageTemplate]"
                  }
                ]
              },
              {
                "key": "MessageTemplateLoadFailed",
                "name": "MessageTemplate load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TEMPLATE",
                "name": "Open Template",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MessageTemplate"
                  }
                ]
              },
              {
                "key": "DELETE_TEMPLATE",
                "name": "Delete Template",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "EDIT_TEMPLATE",
                "name": "Edit Template",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_TEMPLATE",
                "name": "Save Template",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading templates…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MessageTemplateLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total templates",
                              "icon": "file-text"
                            },
                            {
                              "value": "32",
                              "icon": "mail",
                              "label": "Email",
                              "type": "stat-display"
                            },
                            {
                              "value": "14",
                              "type": "stat-display",
                              "icon": "message-square",
                              "label": "SMS"
                            },
                            {
                              "label": "Edited 7d",
                              "icon": "edit",
                              "type": "stat-display",
                              "value": "9"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MessageTemplateLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TEMPLATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.channel",
                    "@payload.row.channel"
                  ],
                  [
                    "set",
                    "@entity.subject",
                    "@payload.row.subject"
                  ],
                  [
                    "set",
                    "@entity.body",
                    "@payload.row.body"
                  ],
                  [
                    "set",
                    "@entity.variables",
                    "@payload.row.variables"
                  ],
                  [
                    "set",
                    "@entity.lastEditedAt",
                    "@payload.row.lastEditedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.name",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.channel"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Subject",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.subject",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Body"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.body",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Variables",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.variables",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "send",
                              "value": "@entity.channel",
                              "type": "stat-display",
                              "label": "Channel"
                            },
                            {
                              "label": "Last edited",
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.lastEditedAt"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "label": "Edit",
                              "action": "EDIT_TEMPLATE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary",
                              "type": "button"
                            },
                            {
                              "label": "Save",
                              "type": "button",
                              "action": "SAVE_TEMPLATE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "secondary"
                            },
                            {
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Delete",
                              "type": "button",
                              "action": "DELETE_TEMPLATE"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE_TEMPLATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "success": "MessageTemplateLoaded",
                        "failure": "MessageTemplateLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Deleting template…"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading templates…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EDIT_TEMPLATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading editor…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SAVE_TEMPLATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Saving template…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DELETE_TEMPLATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Deleting template…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MessageTemplate",
                    {
                      "emit": {
                        "failure": "MessageTemplateLoadFailed",
                        "success": "MessageTemplateLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "name",
                  "variant": "caption",
                  "label": "Name"
                },
                {
                  "name": "channel",
                  "label": "Channel",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "name": "subject",
                  "label": "Subject"
                },
                {
                  "name": "lastEditedAt",
                  "label": "Updated",
                  "variant": "caption"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "icon": "arrow-right",
                  "label": "Open",
                  "event": "OPEN_TEMPLATE",
                  "variant": "primary"
                },
                {
                  "variant": "danger",
                  "label": "Delete",
                  "event": "DELETE_TEMPLATE"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Templates"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MessageTemplatePage",
          "path": "/templates",
          "traits": [
            {
              "ref": "MessageTemplateEditor"
            }
          ]
        }
      ]
    }
  ]
}
