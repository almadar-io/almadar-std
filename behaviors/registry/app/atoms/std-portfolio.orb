{
  "name": "std-portfolio",
  "version": "1.0.0",
  "description": "std-portfolio — portfolio rebalancing, tax-lot accounting, and drift policies for trading apps.",
  "orbitals": [
    {
      "name": "PortfolioOrbital",
      "entity": {
        "name": "Portfolio",
        "collection": "portfolios",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "ownerAccountId",
            "type": "string",
            "required": true
          },
          {
            "name": "currentValueUSD",
            "type": "number"
          },
          {
            "name": "targetAllocationJson",
            "type": "string",
            "default": "{}"
          },
          {
            "name": "driftBps",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "rebalancing",
              "frozen",
              "archived"
            ]
          },
          {
            "name": "lastRebalancedAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PortfolioManage",
          "category": "interaction",
          "linkedEntity": "Portfolio",
          "emits": [
            {
              "event": "OPEN_PORTFOLIO",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.ownerAccountId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.currentValueUSD",
                  "type": "number"
                },
                {
                  "name": "row.targetAllocationJson",
                  "type": "string"
                },
                {
                  "name": "row.driftBps",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastRebalancedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REBALANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.ownerAccountId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.currentValueUSD",
                  "type": "number"
                },
                {
                  "name": "row.targetAllocationJson",
                  "type": "string"
                },
                {
                  "name": "row.driftBps",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastRebalancedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FREEZE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.ownerAccountId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.currentValueUSD",
                  "type": "number"
                },
                {
                  "name": "row.targetAllocationJson",
                  "type": "string"
                },
                {
                  "name": "row.driftBps",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastRebalancedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARCHIVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.ownerAccountId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.currentValueUSD",
                  "type": "number"
                },
                {
                  "name": "row.targetAllocationJson",
                  "type": "string"
                },
                {
                  "name": "row.driftBps",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastRebalancedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PortfolioLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Portfolio]"
                }
              ]
            },
            {
              "event": "PortfolioLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PortfolioLoaded",
                "name": "Portfolio loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Portfolio]"
                  }
                ]
              },
              {
                "key": "PortfolioLoadFailed",
                "name": "Portfolio load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_PORTFOLIO",
                "name": "Open Portfolio",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Portfolio"
                  }
                ]
              },
              {
                "key": "REBALANCE",
                "name": "Rebalance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Portfolio"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "FREEZE",
                "name": "Freeze",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Portfolio"
                  }
                ]
              },
              {
                "key": "ARCHIVE",
                "name": "Archive",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Portfolio"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "failure": "PortfolioLoadFailed",
                        "success": "PortfolioLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading portfolios…"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PortfolioLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "pie-chart"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total portfolios",
                              "icon": "pie-chart",
                              "value": "@payload.data.length",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "AUM",
                              "icon": "dollar-sign",
                              "value": "$8.4M"
                            },
                            {
                              "value": "6",
                              "label": "Needs rebalance",
                              "type": "stat-display",
                              "icon": "alert-triangle"
                            },
                            {
                              "label": "Rebalanced today",
                              "value": "3",
                              "type": "stat-display",
                              "icon": "refresh-cw"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "fields": "@config.fields"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PortfolioLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_PORTFOLIO",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.ownerAccountId",
                    "@payload.row.ownerAccountId"
                  ],
                  [
                    "set",
                    "@entity.currentValueUSD",
                    "@payload.row.currentValueUSD"
                  ],
                  [
                    "set",
                    "@entity.targetAllocationJson",
                    "@payload.row.targetAllocationJson"
                  ],
                  [
                    "set",
                    "@entity.driftBps",
                    "@payload.row.driftBps"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.lastRebalancedAt",
                    "@payload.row.lastRebalancedAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "pie-chart"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.name",
                              "type": "typography"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Owner",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.ownerAccountId",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Target Allocation",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.targetAllocationJson"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Current Value",
                              "value": "@entity.currentValueUSD",
                              "icon": "dollar-sign"
                            },
                            {
                              "type": "stat-display",
                              "label": "Drift (bps)",
                              "value": "@entity.driftBps",
                              "icon": "trending-up"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Last Rebalanced",
                              "value": "@entity.lastRebalancedAt"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "variant": "primary",
                              "action": "REBALANCE",
                              "label": "Rebalance"
                            },
                            {
                              "label": "Freeze",
                              "action": "FREEZE",
                              "variant": "secondary",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "type": "button"
                            },
                            {
                              "label": "Archive",
                              "type": "button",
                              "variant": "danger",
                              "action": "ARCHIVE",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              }
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REBALANCE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "success": "PortfolioLoaded",
                        "failure": "PortfolioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Rebalancing portfolio…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "failure": "PortfolioLoadFailed",
                        "success": "PortfolioLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading portfolios…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REBALANCE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "success": "PortfolioLoaded",
                        "failure": "PortfolioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Rebalancing portfolio…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "FREEZE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "success": "PortfolioLoaded",
                        "failure": "PortfolioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Freezing portfolio…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "success": "PortfolioLoaded",
                        "failure": "PortfolioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Archiving portfolio…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Portfolio",
                    {
                      "emit": {
                        "success": "PortfolioLoaded",
                        "failure": "PortfolioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "rebalancingFrequencyDays": {
              "type": "number",
              "default": 90.0,
              "label": "Rebalance cadence (days)",
              "description": "How often the portfolio gets auto-rebalanced toward target allocation.",
              "synonyms": "rebalance interval",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "name",
                  "variant": "caption",
                  "label": "Name"
                },
                {
                  "variant": "caption",
                  "name": "ownerAccountId",
                  "label": "Owner"
                },
                {
                  "name": "currentValueUSD",
                  "variant": "caption",
                  "label": "Value (USD)"
                },
                {
                  "label": "Drift (bps)",
                  "variant": "caption",
                  "name": "driftBps"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "name": "lastRebalancedAt",
                  "label": "Last Rebalanced",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Portfolio entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "driftThresholdBps": {
              "type": "number",
              "default": 500.0,
              "label": "Drift threshold (bps)",
              "description": "Maximum drift from target allocation before triggering rebalance.",
              "synonyms": "drift band, rebalance trigger",
              "tier": "domain"
            },
            "cashBufferPct": {
              "type": "number",
              "default": 5.0,
              "label": "Cash buffer (%)",
              "description": "Minimum percentage held in cash for liquidity needs and rebalancing.",
              "synonyms": "cash reserve",
              "tier": "domain"
            },
            "taxLotMethod": {
              "type": "string",
              "default": "FIFO",
              "label": "Tax lot method",
              "description": "Cost-basis accounting method when selling shares.",
              "synonyms": "lot accounting, cost basis",
              "tier": "domain",
              "values": [
                "FIFO",
                "LIFO",
                "HIFO",
                "specific-lot"
              ]
            },
            "title": {
              "type": "string",
              "default": "Portfolios",
              "label": "Section title",
              "description": "Heading shown above the portfolio list",
              "tier": "presentation"
