{
  "name": "std-trial",
  "version": "1.0.0",
  "description": "std-trial — subscription trial countdown with auto-convert at expiry. Owns a Trial entity; CONVERT flips status to converted and stamps convertedAt, EXPIRE flips to expired, CANCEL flips to cancelled. Persists results back to the row and emits TrialUpdated / TrialConverted for downstream listeners.",
  "orbitals": [
    {
      "name": "TrialOrbital",
      "entity": {
        "name": "Trial",
        "collection": "trials",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "startedAt",
            "type": "string"
          },
          {
            "name": "expiresAt",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "converted",
              "expired",
              "cancelled"
            ]
          },
          {
            "name": "convertedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TrialManage",
          "category": "interaction",
          "linkedEntity": "Trial",
          "emits": [
            {
              "event": "CONVERT",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "convertedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EXPIRE",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Trial]"
                }
              ]
            },
            {
              "event": "TrialLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialConverted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "converting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TrialLoaded",
                "name": "Trial loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Trial]"
                  }
                ]
              },
              {
                "key": "TrialLoadFailed",
                "name": "Trial load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONVERT",
                "name": "Convert",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "convertedAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "EXPIRE",
                "name": "Expire",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialUpdated",
                "name": "Trial updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialConverted",
                "name": "Trial converted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading trials…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TrialLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": {
                            "title": "Free trial",
                            "body": "Try every feature for fourteen days. No credit card needed."
                          },
                          "type": "about-page-template"
                        },
                        {
                          "value": 9.0,
                          "color": "primary",
                          "showPercentage": false,
                          "label": "Trial day nine of fourteen",
                          "max": 14.0,
                          "type": "progress-bar"
                        },
                        {
                          "back": {
                            "align": "center",
                            "direction": "vertical",
                            "gap": "sm",
                            "children": [
                              {
                                "type": "typography",
                                "content": "Upgrade soon",
                                "variant": "h4"
                              },
                              {
                                "content": "Convert to keep your data and unlock unlimited usage.",
                                "type": "typography",
                                "variant": "caption"
                              }
                            ],
                            "className": "p-6",
                            "type": "stack"
                          },
                          "height": "h-48",
                          "front": {
                            "direction": "vertical",
                            "gap": "sm",
                            "type": "stack",
                            "align": "center",
                            "className": "p-6",
                            "children": [
                              {
                                "name": "sparkles",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "content": "Your trial",
                                "variant": "h4"
                              },
                              {
                                "content": "Hover or tap to see what's next",
                                "variant": "caption",
                                "color": "muted",
                                "type": "typography"
                              }
                            ]
                          },
                          "type": "flip-card"
                        },
                        {
                          "duration": 600.0,
                          "type": "animated-reveal",
                          "children": [
                            {
                              "message": "Convert your trial today to keep your current usage tier.",
                              "variant": "info",
                              "title": "Lock in your plan",
                              "type": "alert"
                            }
                          ],
                          "animation": "fade-up",
                          "trigger": "scroll"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "CONVERT",
                              "label": "Convert",
                              "icon": "check",
                              "variant": "primary"
                            },
                            {
                              "icon": "clock",
                              "label": "Expire",
                              "variant": "secondary",
                              "event": "EXPIRE"
                            },
                            {
                              "variant": "danger",
                              "label": "Cancel",
                              "icon": "x",
                              "event": "CANCEL"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "customerId",
                              "label": "Customer",
                              "variant": "caption"
                            },
                            {
                              "label": "Plan",
                              "variant": "caption",
                              "name": "planId"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "name": "startedAt",
                              "variant": "caption",
                              "label": "Started"
                            },
                            {
                              "name": "expiresAt",
                              "label": "Expires",
                              "variant": "caption"
                            },
                            {
                              "name": "convertedAt",
                              "variant": "caption",
                              "label": "Converted"
                            },
                            {
                              "label": "Notified",
                              "variant": "caption",
                              "name": "notifiedAt"
                            }
                          ],
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TrialLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "converting",
                "event": "CONVERT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "converted"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialConverted",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Converting trial…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EXPIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "expired"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialUpdated",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TrialUpdated",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "converting",
                "to": "loading",
                "event": "TrialConverted",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Trials"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TrialManagePage",
          "path": "/trials/manage",
          "traits": [
            {
              "ref": "TrialManage"
            }
          ]
        }
      ]
    }
  ]
}