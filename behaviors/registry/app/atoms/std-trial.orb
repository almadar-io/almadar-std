{
  "name": "std-trial",
  "version": "1.1.0",
  "description": "std-trial — subscription trial countdown with auto-convert at expiry. Lists trials in `browsing`; opens detail in `viewing_single` with Convert / Expire / Cancel actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "TrialOrbital",
      "entity": {
        "name": "Trial",
        "collection": "trials",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "startedAt",
            "type": "string"
          },
          {
            "name": "expiresAt",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "converted",
              "expired",
              "cancelled"
            ]
          },
          {
            "name": "convertedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TrialManage",
          "category": "interaction",
          "linkedEntity": "Trial",
          "emits": [
            {
              "event": "OPEN_TRIAL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CONVERT",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "convertedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EXPIRE",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Trial]"
                }
              ]
            },
            {
              "event": "TrialLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TrialLoaded",
                "name": "Trial loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Trial]"
                  }
                ]
              },
              {
                "key": "TrialLoadFailed",
                "name": "Trial load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TRIAL",
                "name": "Open Trial",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "CONVERT",
                "name": "Convert",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "convertedAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "EXPIRE",
                "name": "Expire",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading trials…"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TrialLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "clock",
                              "label": "Active trials",
                              "value": "@payload.data.length",
                              "type": "stat-display"
                            },
                            {
                              "value": "42%",
                              "type": "stat-display",
                              "label": "Conversion rate",
                              "icon": "trending-up"
                            },
                            {
                              "value": "18",
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "Expiring 7d"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "label": "Converted this mo",
                              "value": "31"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TrialLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TRIAL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "clock",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.customerId",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Plan",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.planId",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Subscription",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.subscriptionId"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Started",
                              "value": "@entity.startedAt",
                              "icon": "calendar",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.expiresAt",
                              "icon": "calendar-clock",
                              "label": "Expires"
                            },
                            {
                              "icon": "check-circle",
                              "type": "stat-display",
                              "value": "@entity.convertedAt",
                              "label": "Converted"
                            },
                            {
                              "value": "@entity.notifiedAt",
                              "type": "stat-display",
                              "label": "Notified",
                              "icon": "bell"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "action": "CONVERT",
                              "variant": "primary",
                              "actionPayload": {
                                "convertedAt": "@entity.expiresAt",
                                "trialId": "@entity.id",
                                "row": "@entity"
                              },
                              "type": "button",
                              "label": "Convert"
                            },
                            {
                              "variant": "secondary",
                              "action": "EXPIRE",
                              "actionPayload": {
                                "trialId": "@entity.id",
                                "row": "@entity"
                              },
                              "type": "button",
                              "label": "Expire"
                            },
                            {
                              "action": "CANCEL",
                              "variant": "danger",
                              "label": "Cancel",
                              "type": "button",
                              "actionPayload": {
                                "trialId": "@entity.id",
                                "row": "@entity"
                              }
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling trial…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading trials…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CONVERT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Converting trial…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EXPIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Expiring trial…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Cancelling trial…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "customerId",
                  "label": "Customer",
                  "variant": "caption"
                },
                {
                  "label": "Plan",
                  "name": "planId",
                  "variant": "caption"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "variant": "caption",
                  "name": "startedAt",
                  "label": "Started"
                },
                {
                  "label": "Expires",
                  "variant": "caption",
                  "name": "expiresAt"
                },
                {
                  "label": "Converted",
                  "variant": "caption",
                  "name": "convertedAt"
                },
                {
                  "label": "Notified",
                  "variant": "caption",
                  "name": "notifiedAt"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Trial entity",
              "items": {
                "type": "object"
              }
            },
            "title": {
              "type": "string",
              "default": "Trials",
              "label": "Section title",
              "description": "Heading shown above the trial subscriptions list"
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_TRIAL",
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "variant": "danger",
                  "icon": "x",
                  "event": "CANCEL",
                  "label": "Cancel"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each trial row",
              "items": {
                "type": "object"
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TrialManagePage",
          "path": "/trials/manage",
          "traits": [
            {
              "ref": "TrialManage"
            }
          ]
        }
      ]
    }
  ]
}