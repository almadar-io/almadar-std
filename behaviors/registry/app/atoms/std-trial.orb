{
  "name": "std-trial",
  "version": "1.2.0",
  "description": "std-trial — subscription trial countdown with Convert / Expire / Cancel actions. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs.",
  "orbitals": [
    {
      "name": "TrialOrbital",
      "entity": {
        "name": "Trial",
        "collection": "trials",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "startedAt",
            "type": "string"
          },
          {
            "name": "expiresAt",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "converted",
              "expired",
              "cancelled"
            ]
          },
          {
            "name": "convertedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TrialManage",
          "category": "interaction",
          "linkedEntity": "Trial",
          "emits": [
            {
              "event": "OPEN_TRIAL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CONVERT",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "convertedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EXPIRE",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Trial]"
                }
              ]
            },
            {
              "event": "TrialLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TrialLoaded",
                "name": "Trial loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Trial]"
                  }
                ]
              },
              {
                "key": "TrialLoadFailed",
                "name": "Trial load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TRIAL",
                "name": "Open Trial",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TrialUpdated",
                "name": "Trial updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialUpdateFailed",
                "name": "Trial update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "CONVERT",
                "name": "Convert",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "convertedAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "EXPIRE",
                "name": "Expire",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading trials…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TrialLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "clock",
                              "type": "stat-display",
                              "label": "Active trials"
                            },
                            {
                              "label": "Conversion rate",
                              "icon": "trending-up",
                              "value": "42%",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Expiring 7d",
                              "value": "18",
                              "icon": "alert-triangle"
                            },
                            {
                              "label": "Converted this mo",
                              "type": "stat-display",
                              "value": "31",
                              "icon": "check-circle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "gap": "sm",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TrialLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TRIAL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.customerId",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Plan",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.planId"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Subscription",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.subscriptionId"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "calendar",
                              "label": "Started",
                              "value": "@entity.startedAt",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.expiresAt",
                              "type": "stat-display",
                              "label": "Expires",
                              "icon": "calendar-clock"
                            },
                            {
                              "icon": "check-circle",
                              "value": "@entity.convertedAt",
                              "type": "stat-display",
                              "label": "Converted"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.notifiedAt",
                              "label": "Notified",
                              "icon": "bell"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "action": "CONVERT",
                              "label": "Convert",
                              "actionPayload": {
                                "convertedAt": "@entity.expiresAt",
                                "row": "@entity",
                                "trialId": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "trialId": "@entity.id"
                              },
                              "label": "Expire",
                              "action": "EXPIRE",
                              "variant": "secondary"
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Cancel",
                              "action": "CANCEL",
                              "actionPayload": {
                                "row": "@entity",
                                "trialId": "@entity.id"
                              }
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Cancelling trial…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialUpdated",
                        "failure": "TrialUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating trial status…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TrialUpdated",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TrialUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading trials…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CONVERT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Converting trial…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EXPIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Expiring trial…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Cancelling trial…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "label": "Open",
                  "event": "OPEN_TRIAL",
                  "variant": "primary"
                },
                {
                  "icon": "x",
                  "label": "Cancel",
                  "event": "CANCEL",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each trial row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Customer",
                  "name": "customerId",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Plan",
                  "name": "planId"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "name": "startedAt",
                  "label": "Started",
                  "variant": "caption"
                },
                {
                  "label": "Expires",
                  "variant": "caption",
                  "name": "expiresAt"
                },
                {
                  "variant": "caption",
                  "label": "Converted",
                  "name": "convertedAt"
                },
                {
                  "name": "notifiedAt",
                  "variant": "caption",
                  "label": "Notified"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Trial entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "healthScoreThresholdAlert": {
              "type": "number",
              "default": 30.0,
              "label": "Health score threshold",
              "description": "Trial users below this engagement score get flagged for CSM outreach. Declarative; wire via sibling std-notify.",
              "tier": "customization"
            },
            "renewalReminderDaysBefore": {
              "type": "[number]",
              "default": [
                7.0,
                3.0,
                1.0
              ],
              "label": "Trial reminder days-before",
              "description": "Days before expiresAt to send conversion reminders. Declarative; wire via sibling std-reminder-scheduler.",
              "tier": "customization",
              "items": {
                "type": "number"
              }
            },
            "archiveInactiveAfterDays": {
              "type": "number",
              "default": 90.0,
              "label": "Archive inactive after (days)",
              "description": "Days post-expiration before trial record is archived. Declarative; wire via sibling std-lifecycle.",
              "tier": "advanced"
            },
            "title": {
              "type": "string",
              "default": "Trials",
              "label": "Section title",
              "description": "Heading shown above the trial subscriptions list",
              "tier": "customization"
            },
            "consentTrackingEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Track consent",
              "description": "Whether to record marketing consent during trial signup. Declarative.",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TrialManagePage",
          "path": "/trials/manage",
          "traits": [
            {
              "ref": "TrialManage"
            }
          ]
        }
      ]
    }
  ]
}