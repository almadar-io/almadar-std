{
  "name": "std-vehicle",
  "version": "1.0.0",
  "description": "std-vehicle — fleet vehicle primitive. Lists vehicles in `browsing` with fleet stats + map view; opens vehicle detail in `viewing_single` (VIN, plate, make/model, odometer, status, driver) with Assign Driver / Maintenance / Retire actions.",
  "orbitals": [
    {
      "name": "VehicleOrbital",
      "entity": {
        "name": "Vehicle",
        "collection": "vehicles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vin",
            "type": "string",
            "required": true
          },
          {
            "name": "licensePlate",
            "type": "string",
            "required": true
          },
          {
            "name": "make",
            "type": "string",
            "default": ""
          },
          {
            "name": "model",
            "type": "string",
            "default": ""
          },
          {
            "name": "year",
            "type": "number",
            "default": 2020.0
          },
          {
            "name": "vehicleType",
            "type": "string",
            "default": "car",
            "values": [
              "car",
              "truck",
              "van",
              "trailer",
              "motorcycle"
            ]
          },
          {
            "name": "odometer",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "fuelType",
            "type": "string",
            "default": "gasoline",
            "values": [
              "gasoline",
              "diesel",
              "electric",
              "hybrid"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "maintenance",
              "retired",
              "in-transit"
            ]
          },
          {
            "name": "assignedDriverId",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "VehicleFleet",
          "category": "interaction",
          "linkedEntity": "Vehicle",
          "emits": [
            {
              "event": "OPEN_VEHICLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vin",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.licensePlate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.make",
                  "type": "string"
                },
                {
                  "name": "row.model",
                  "type": "string"
                },
                {
                  "name": "row.year",
                  "type": "number"
                },
                {
                  "name": "row.vehicleType",
                  "type": "string"
                },
                {
                  "name": "row.odometer",
                  "type": "number"
                },
                {
                  "name": "row.fuelType",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedDriverId",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VEHICLE"
            },
            {
              "event": "ASSIGN_DRIVER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_MAINTENANCE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RETIRE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VehicleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Vehicle]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "VehicleLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VehicleLoaded",
                "name": "Vehicle loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Vehicle]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "VehicleLoadFailed",
                "name": "Vehicle load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_VEHICLE",
                "name": "Open Vehicle",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Vehicle"
                  }
                ]
              },
              {
                "key": "RETIRE",
                "name": "Retire",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VEHICLE",
                "name": "Close Vehicle"
              },
              {
                "key": "ASSIGN_DRIVER",
                "name": "Assign Driver",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_MAINTENANCE",
                "name": "Mark Maintenance",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "success": "VehicleLoaded",
                        "failure": "VehicleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading vehicles…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "VehicleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "truck"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total vehicles",
                              "icon": "truck"
                            },
                            {
                              "value": "18",
                              "type": "stat-display",
                              "label": "Active",
                              "icon": "check-circle"
                            },
                            {
                              "label": "In maintenance",
                              "value": "3",
                              "icon": "wrench",
                              "type": "stat-display"
                            },
                            {
                              "icon": "gauge",
                              "value": "62,401 mi",
                              "label": "Avg odometer",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "height": "240px",
                          "markers": [],
                          "zoom": 10.0,
                          "type": "map-view"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "event": "OPEN_VEHICLE",
                              "variant": "primary",
                              "icon": "arrow-right",
                              "label": "Open"
                            },
                            {
                              "label": "Retire",
                              "event": "RETIRE",
                              "variant": "danger"
                            }
                          ],
                          "fields": [
                            {
                              "name": "licensePlate",
                              "label": "Plate",
                              "variant": "caption"
                            },
                            {
                              "name": "make",
                              "variant": "caption",
                              "label": "Make"
                            },
                            {
                              "name": "model",
                              "label": "Model",
                              "variant": "caption"
                            },
                            {
                              "label": "Year",
                              "name": "year",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "vehicleType",
                              "label": "Type"
                            },
                            {
                              "name": "odometer",
                              "variant": "caption",
                              "label": "Odometer"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "VehicleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_VEHICLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vin",
                    "@payload.row.vin"
                  ],
                  [
                    "set",
                    "@entity.licensePlate",
                    "@payload.row.licensePlate"
                  ],
                  [
                    "set",
                    "@entity.make",
                    "@payload.row.make"
                  ],
                  [
                    "set",
                    "@entity.model",
                    "@payload.row.model"
                  ],
                  [
                    "set",
                    "@entity.year",
                    "@payload.row.year"
                  ],
                  [
                    "set",
                    "@entity.vehicleType",
                    "@payload.row.vehicleType"
                  ],
                  [
                    "set",
                    "@entity.odometer",
                    "@payload.row.odometer"
                  ],
                  [
                    "set",
                    "@entity.fuelType",
                    "@payload.row.fuelType"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.assignedDriverId",
                    "@payload.row.assignedDriverId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CLOSE_VEHICLE"
                            },
                            {
                              "type": "icon",
                              "name": "truck"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.licensePlate",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "VIN"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.vin",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Make / Model"
                                },
                                {
                                  "content": "@entity.make",
                                  "variant": "body",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.model",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Driver",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.assignedDriverId",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "gauge",
                              "type": "stat-display",
                              "value": "@entity.odometer",
                              "label": "Odometer"
                            },
                            {
                              "icon": "calendar",
                              "label": "Year",
                              "value": "@entity.year",
                              "type": "stat-display"
                            },
                            {
                              "icon": "tag",
                              "type": "stat-display",
                              "value": "@entity.vehicleType",
                              "label": "Type"
                            },
                            {
                              "value": "@entity.fuelType",
                              "icon": "droplet",
                              "type": "stat-display",
                              "label": "Fuel"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "ASSIGN_DRIVER",
                              "type": "button",
                              "label": "Assign Driver",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Mark Maintenance",
                              "action": "MARK_MAINTENANCE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger",
                              "type": "button",
                              "label": "Retire",
                              "action": "RETIRE"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RETIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "success": "VehicleLoaded",
                        "failure": "VehicleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Retiring vehicle…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VEHICLE",
                "effects": [
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "failure": "VehicleLoadFailed",
                        "success": "VehicleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading vehicles…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN_DRIVER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "success": "VehicleLoaded",
                        "failure": "VehicleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Assigning driver…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_MAINTENANCE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "failure": "VehicleLoadFailed",
                        "success": "VehicleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Updating vehicle…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RETIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "success": "VehicleLoaded",
                        "failure": "VehicleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Retiring vehicle…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "success": "VehicleLoaded",
                        "failure": "VehicleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Fleet"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "VehiclePage",
          "path": "/vehicles",
          "traits": [
            {
              "ref": "VehicleFleet"
            }
          ]
        }
      ]
    }
  ]
}
