{
  "name": "std-vendor-onboarding",
  "version": "1.0.0",
  "description": "std-vendor-onboarding — marketplace vendor multi-step KYC + bank-link wizard with identity-doc upload",
  "orbitals": [
    {
      "name": "VendorOnboardingOrbital",
      "entity": {
        "name": "Vendor",
        "collection": "vendors",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "businessName",
            "type": "string",
            "required": true
          },
          {
            "name": "legalName",
            "type": "string"
          },
          {
            "name": "ein",
            "type": "string"
          },
          {
            "name": "bankRoutingMasked",
            "type": "string"
          },
          {
            "name": "bankAcctMasked",
            "type": "string"
          },
          {
            "name": "identityDocUrl",
            "type": "string"
          },
          {
            "name": "currentStep",
            "type": "string",
            "default": "business-info",
            "values": [
              "business-info",
              "tax-id",
              "bank-link",
              "identity-verify",
              "review",
              "submitted"
            ]
          },
          {
            "name": "submittedAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "VendorOnboard",
          "category": "interaction",
          "linkedEntity": "Vendor",
          "emits": [
            {
              "event": "NEXT_STEP",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                },
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ]
            },
            {
              "event": "BACK_STEP",
              "payloadSchema": [
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ]
            },
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "submittedAt",
                  "type": "string"
                },
                {
                  "name": "currentStep",
                  "type": "number"
                },
                {
                  "name": "totalSteps",
                  "type": "number"
                }
              ]
            },
            {
              "event": "UPLOAD_IDENTITY",
              "payloadSchema": [
                {
                  "name": "url",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VendorLoaded",
              "description": "Fired when the vendor record finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Vendor]"
                }
              ]
            },
            {
              "event": "VendorLoadFailed",
              "description": "Fired when the vendor record fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "VendorUpdated",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "VendorPersistor"
              }
            },
            {
              "event": "VendorSubmitted",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "VendorPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "business-info"
              },
              {
                "name": "tax-id"
              },
              {
                "name": "bank-link"
              },
              {
                "name": "identity-verify"
              },
              {
                "name": "review"
              },
              {
                "name": "submitted"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VendorLoaded",
                "name": "Vendor loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Vendor]"
                  }
                ]
              },
              {
                "key": "VendorLoadFailed",
                "name": "Vendor load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "NEXT_STEP",
                "name": "Next Step",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  },
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "BACK_STEP",
                "name": "Back Step",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "UPLOAD_IDENTITY",
                "name": "Upload Identity",
                "payloadSchema": [
                  {
                    "name": "url",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "submittedAt",
                    "type": "string"
                  },
                  {
                    "name": "currentStep",
                    "type": "number"
                  },
                  {
                    "name": "totalSteps",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vendor",
                    {
                      "emit": {
                        "failure": "VendorLoadFailed",
                        "success": "VendorLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading vendor application…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "business-info",
                "event": "VendorLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-2xl mx-auto w-full",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Vendor Onboarding",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "currentStep": 0.0,
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "businessName",
                            "legalName"
                          ],
                          "mode": "create",
                          "submitEvent": "NEXT_STEP",
                          "type": "form-section",
                          "cancelEvent": "INIT"
                        },
                        {
                          "onNext": "NEXT_STEP",
                          "currentStep": 0.0,
                          "totalSteps": 5.0,
                          "showNext": true,
                          "showBack": false,
                          "showComplete": false,
                          "type": "wizard-navigation"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "VendorLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "business-info",
                "to": "tax-id",
                "event": "NEXT_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.businessName",
                    "@payload.data.businessName"
                  ],
                  [
                    "set",
                    "@entity.legalName",
                    "@payload.data.legalName"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    "tax-id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "max-w-2xl mx-auto w-full",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Tax ID"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "wizard-progress",
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ],
                          "currentStep": 1.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "ein"
                          ],
                          "mode": "edit",
                          "entity": "@entity",
                          "submitEvent": "NEXT_STEP",
                          "cancelEvent": "BACK_STEP",
                          "type": "form-section"
                        },
                        {
                          "currentStep": 1.0,
                          "type": "wizard-navigation",
                          "showComplete": false,
                          "onNext": "NEXT_STEP",
                          "totalSteps": 5.0,
                          "showBack": true,
                          "onBack": "BACK_STEP",
                          "showNext": true
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "tax-id",
                "to": "bank-link",
                "event": "NEXT_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.ein",
                    "@payload.data.ein"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    "bank-link"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-2xl mx-auto w-full",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "type": "typography",
                              "content": "Bank Link",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ],
                          "type": "wizard-progress",
                          "currentStep": 2.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "fields": [
                            "bankRoutingMasked",
                            "bankAcctMasked"
                          ],
                          "submitEvent": "NEXT_STEP",
                          "mode": "edit",
                          "entity": "@entity",
                          "cancelEvent": "BACK_STEP"
                        },
                        {
                          "totalSteps": 5.0,
                          "showNext": true,
                          "onNext": "NEXT_STEP",
                          "type": "wizard-navigation",
                          "currentStep": 2.0,
                          "showComplete": false,
                          "showBack": true,
                          "onBack": "BACK_STEP"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "tax-id",
                "to": "business-info",
                "event": "BACK_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "business-info"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "user"
                            },
                            {
                              "content": "Business Info",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 0.0,
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "businessName",
                            "legalName"
                          ],
                          "type": "form-section",
                          "entity": "@entity",
                          "submitEvent": "NEXT_STEP",
                          "cancelEvent": "INIT",
                          "mode": "edit"
                        },
                        {
                          "showBack": false,
                          "totalSteps": 5.0,
                          "showNext": true,
                          "type": "wizard-navigation",
                          "currentStep": 0.0,
                          "showComplete": false,
                          "onNext": "NEXT_STEP"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-2xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "bank-link",
                "to": "identity-verify",
                "event": "NEXT_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.bankRoutingMasked",
                    "@payload.data.bankRoutingMasked"
                  ],
                  [
                    "set",
                    "@entity.bankAcctMasked",
                    "@payload.data.bankAcctMasked"
                  ],
                  [
                    "set",
                    "@entity.currentStep",
                    "identity-verify"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "type": "typography",
                              "content": "Identity Verification",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 3.0,
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Upload a government-issued ID to verify your identity.",
                          "color": "muted",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "maxSize": 10485760.0,
                          "action": "UPLOAD_IDENTITY",
                          "accept": "image/*",
                          "icon": "credit-card",
                          "description": "or click to browse",
                          "type": "upload-drop-zone",
                          "label": "Drop ID document here",
                          "maxFiles": 2.0
                        },
                        {
                          "showNext": true,
                          "type": "wizard-navigation",
                          "totalSteps": 5.0,
                          "showBack": true,
                          "onNext": "NEXT_STEP",
                          "showComplete": false,
                          "onBack": "BACK_STEP",
                          "currentStep": 3.0
                        }
                      ],
                      "className": "max-w-2xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "bank-link",
                "to": "tax-id",
                "event": "BACK_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "tax-id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "max-w-2xl mx-auto w-full",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "content": "Tax ID",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ],
                          "currentStep": 1.0,
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "ein"
                          ],
                          "submitEvent": "NEXT_STEP",
                          "entity": "@entity",
                          "type": "form-section",
                          "mode": "edit",
                          "cancelEvent": "BACK_STEP"
                        },
                        {
                          "onNext": "NEXT_STEP",
                          "type": "wizard-navigation",
                          "showNext": true,
                          "showComplete": false,
                          "showBack": true,
                          "onBack": "BACK_STEP",
                          "totalSteps": 5.0,
                          "currentStep": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "identity-verify",
                "to": "identity-verify",
                "event": "UPLOAD_IDENTITY",
                "effects": [
                  [
                    "set",
                    "@entity.identityDocUrl",
                    "@payload.url"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "max-w-2xl mx-auto w-full",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Identity Verification",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 3.0,
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Identity document uploaded.",
                          "variant": "success"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Document URL",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.identityDocUrl",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "showNext": true,
                          "onBack": "BACK_STEP",
                          "totalSteps": 5.0,
                          "onNext": "NEXT_STEP",
                          "currentStep": 3.0,
                          "type": "wizard-navigation",
                          "showBack": true,
                          "showComplete": false
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "identity-verify",
                "to": "review",
                "event": "NEXT_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "review"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "type": "typography",
                              "content": "Review",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "currentStep": 4.0,
                          "type": "wizard-progress",
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Business Name",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.businessName"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Legal Name",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.legalName",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "EIN",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.ein",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Bank Routing",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.bankRoutingMasked",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "content": "Bank Account",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.bankAcctMasked",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Identity Doc"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.identityDocUrl"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "user",
                              "value": "@entity.businessName",
                              "label": "Business"
                            },
                            {
                              "label": "EIN",
                              "icon": "credit-card",
                              "value": "@entity.ein",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "onBack": "BACK_STEP",
                          "totalSteps": 5.0,
                          "showComplete": true,
                          "showNext": false,
                          "type": "wizard-navigation",
                          "currentStep": 4.0,
                          "onComplete": "SUBMIT",
                          "showBack": true
                        }
                      ],
                      "className": "max-w-2xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "identity-verify",
                "to": "bank-link",
                "event": "BACK_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "bank-link"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-2xl mx-auto w-full",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Bank Link",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ],
                          "currentStep": 2.0,
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "cancelEvent": "BACK_STEP",
                          "entity": "@entity",
                          "submitEvent": "NEXT_STEP",
                          "mode": "edit",
                          "fields": [
                            "bankRoutingMasked",
                            "bankAcctMasked"
                          ]
                        },
                        {
                          "onBack": "BACK_STEP",
                          "onNext": "NEXT_STEP",
                          "showBack": true,
                          "showComplete": false,
                          "totalSteps": 5.0,
                          "currentStep": 2.0,
                          "showNext": true,
                          "type": "wizard-navigation"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "submitted",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "submitted"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.submittedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-2xl mx-auto w-full py-12",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon",
                          "color": "success"
                        },
                        {
                          "content": "Application Submitted",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "content": "Thanks. We will review your vendor application and email you within 2 business days.",
                          "type": "typography",
                          "variant": "body"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "identity-verify",
                "event": "BACK_STEP",
                "effects": [
                  [
                    "set",
                    "@entity.currentStep",
                    "identity-verify"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "variant": "h3",
                              "content": "Identity Verification",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "steps": [
                            "Business",
                            "Tax ID",
                            "Bank",
                            "Identity",
                            "Review"
                          ],
                          "type": "wizard-progress",
                          "currentStep": 3.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "upload-drop-zone",
                          "maxFiles": 2.0,
                          "label": "Drop ID document here",
                          "maxSize": 10485760.0,
                          "description": "or click to browse",
                          "icon": "credit-card",
                          "action": "UPLOAD_IDENTITY",
                          "accept": "image/*"
                        },
                        {
                          "type": "wizard-navigation",
                          "onNext": "NEXT_STEP",
                          "showNext": true,
                          "totalSteps": 5.0,
                          "showBack": true,
                          "onBack": "BACK_STEP",
                          "showComplete": false,
                          "currentStep": 3.0
                        }
                      ],
                      "type": "stack",
                      "className": "max-w-2xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vendor",
                    {
                      "emit": {
                        "failure": "VendorLoadFailed",
                        "success": "VendorLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vendor",
                    {
                      "emit": {
                        "success": "VendorLoaded",
                        "failure": "VendorLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "VendorPersistor",
          "category": "lifecycle",
          "linkedEntity": "Vendor",
          "emits": [
            {
              "event": "VendorUpdated",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VendorUpdateFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VendorSubmitted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VendorSubmitFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "NEXT_STEP",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "VendorOnboard"
              }
            },
            {
              "event": "SUBMIT",
              "triggers": "DO_SUBMIT",
              "source": {
                "kind": "trait",
                "trait": "VendorOnboard"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Vendor",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_SUBMIT",
                "name": "Do Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Vendor",
                    "required": true
                  }
                ]
              },
              {
                "key": "VendorUpdated",
                "name": "Vendor updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VendorUpdateFailed",
                "name": "Vendor update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VendorSubmitted",
                "name": "Vendor submitted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VendorSubmitFailed",
                "name": "Vendor submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Vendor",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "VendorUpdated",
                        "failure": "VendorUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_SUBMIT",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Vendor",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "VendorSubmitted",
                        "failure": "VendorSubmitFailed"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "VendorOnboardingPage",
          "path": "/vendor-onboarding",
          "traits": [
            {
              "ref": "VendorOnboard"
            },
            {
              "ref": "VendorPersistor"
            }
          ]
        }
      ]
    }
  ]
}