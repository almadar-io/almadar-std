{
  "name": "std-recurring-charge",
  "version": "1.1.0",
  "description": "std-recurring-charge — subscription cycle clock. Lists subscriptions in `browsing`; opens detail in `viewing_single` with Charge / Cancel actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "SubscriptionOrbital",
      "entity": {
        "name": "Subscription",
        "collection": "subscriptions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "trial",
              "past-due",
              "cancelled",
              "paused"
            ]
          },
          {
            "name": "amount",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "interval",
            "type": "string",
            "default": "monthly",
            "values": [
              "monthly",
              "yearly"
            ]
          },
          {
            "name": "currentPeriodStart",
            "type": "string"
          },
          {
            "name": "currentPeriodEnd",
            "type": "string"
          },
          {
            "name": "nextBillingAt",
            "type": "string"
          },
          {
            "name": "attemptCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastChargeAt",
            "type": "string"
          },
          {
            "name": "cancelledAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SubscriptionManage",
          "category": "interaction",
          "linkedEntity": "Subscription",
          "emits": [
            {
              "event": "OPEN_SUBSCRIPTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.interval",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodStart",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodEnd",
                  "type": "string"
                },
                {
                  "name": "row.nextBillingAt",
                  "type": "string"
                },
                {
                  "name": "row.attemptCount",
                  "type": "number"
                },
                {
                  "name": "row.lastChargeAt",
                  "type": "string"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CHARGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SubscriptionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Subscription]"
                }
              ]
            },
            {
              "event": "SubscriptionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SubscriptionLoaded",
                "name": "Subscription loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Subscription]"
                  }
                ]
              },
              {
                "key": "SubscriptionLoadFailed",
                "name": "Subscription load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SUBSCRIPTION",
                "name": "Open Subscription",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "CHARGE",
                "name": "Charge",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading subscriptions…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SubscriptionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total subscriptions",
                              "icon": "repeat",
                              "value": "@payload.data.length"
                            },
                            {
                              "value": "248",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "label": "Active"
                            },
                            {
                              "label": "MRR",
                              "value": "$18,400",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "value": "7",
                              "type": "stat-display",
                              "icon": "alert-triangle",
                              "label": "Past due"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SubscriptionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SUBSCRIPTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    "@payload.row.attemptCount"
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.row.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.customerId"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "default"
                            },
                            {
                              "label": "@entity.interval",
                              "variant": "primary",
                              "type": "badge"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Plan",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.planId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Currency",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.currency"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "dollar-sign",
                              "label": "Amount",
                              "type": "stat-display",
                              "value": "@entity.amount"
                            },
                            {
                              "type": "stat-display",
                              "label": "Retries",
                              "value": "@entity.attemptCount",
                              "icon": "rotate-cw"
                            },
                            {
                              "value": "@entity.nextBillingAt",
                              "icon": "calendar",
                              "label": "Next bill",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Last charge",
                              "value": "@entity.lastChargeAt",
                              "icon": "credit-card"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "action": "CHARGE",
                              "label": "Charge",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "label": "Cancel",
                              "action": "CANCEL",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CHARGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Charging subscription…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "success": "SubscriptionLoaded",
                        "failure": "SubscriptionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Cancelling subscription…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading subscriptions…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CHARGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Charging subscription…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Cancelling subscription…",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "success": "SubscriptionLoaded",
                        "failure": "SubscriptionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "Customer",
                  "variant": "caption",
                  "name": "customerId"
                },
                {
                  "variant": "caption",
                  "name": "planId",
                  "label": "Plan"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "name": "amount",
                  "label": "Amount"
                },
                {
                  "name": "interval",
                  "variant": "badge",
                  "label": "Interval"
                },
                {
                  "variant": "caption",
                  "name": "nextBillingAt",
                  "label": "Next Bill"
                },
                {
                  "label": "Retries",
                  "name": "attemptCount",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Subscription entity",
              "items": {
                "type": "object"
              }
            },
            "maxRetries": {
              "type": "number",
              "default": 4.0,
              "label": "Max retry attempts",
              "description": "How many times a failed charge retries before going past-due"
            },
            "title": {
              "type": "string",
              "default": "Subscriptions",
              "label": "Section title",
              "description": "Heading shown above the subscription list"
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_SUBSCRIPTION",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "event": "CANCEL",
                  "variant": "danger",
                  "label": "Cancel"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each subscription row",
              "items": {
                "type": "object"
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SubscriptionManagePage",
          "path": "/subscriptions/manage",
          "traits": [
            {
              "ref": "SubscriptionManage"
            }
          ]
        }
      ]
    }
  ]
}