{
  "name": "std-recurring-charge",
  "version": "1.0.0",
  "description": "std-recurring-charge — subscription cycle clock with retry policy and inline proration math. Owns a Subscription entity; CHARGE invokes the stripe-charge service, PRORATE adjusts amount inline by daysIntoPeriod, CANCEL flips status. Persists results back to the row and emits SubscriptionUpdated for downstream listeners.",
  "orbitals": [
    {
      "name": "SubscriptionOrbital",
      "entity": {
        "name": "Subscription",
        "collection": "subscriptions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "trial",
              "past-due",
              "cancelled",
              "paused"
            ]
          },
          {
            "name": "amount",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "interval",
            "type": "string",
            "default": "monthly",
            "values": [
              "monthly",
              "yearly"
            ]
          },
          {
            "name": "currentPeriodStart",
            "type": "string"
          },
          {
            "name": "currentPeriodEnd",
            "type": "string"
          },
          {
            "name": "nextBillingAt",
            "type": "string"
          },
          {
            "name": "attemptCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastChargeAt",
            "type": "string"
          },
          {
            "name": "cancelledAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SubscriptionManage",
          "category": "interaction",
          "linkedEntity": "Subscription",
          "emits": [
            {
              "event": "CHARGE",
              "payloadSchema": [
                {
                  "name": "subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.interval",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodStart",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodEnd",
                  "type": "string"
                },
                {
                  "name": "row.nextBillingAt",
                  "type": "string"
                },
                {
                  "name": "row.attemptCount",
                  "type": "number"
                },
                {
                  "name": "row.lastChargeAt",
                  "type": "string"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PRORATE",
              "payloadSchema": [
                {
                  "name": "subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "newPlanId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "daysIntoPeriod",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.interval",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodStart",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodEnd",
                  "type": "string"
                },
                {
                  "name": "row.nextBillingAt",
                  "type": "string"
                },
                {
                  "name": "row.attemptCount",
                  "type": "number"
                },
                {
                  "name": "row.lastChargeAt",
                  "type": "string"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "cancelledAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.interval",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodStart",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodEnd",
                  "type": "string"
                },
                {
                  "name": "row.nextBillingAt",
                  "type": "string"
                },
                {
                  "name": "row.attemptCount",
                  "type": "number"
                },
                {
                  "name": "row.lastChargeAt",
                  "type": "string"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SubscriptionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Subscription]"
                }
              ]
            },
            {
              "event": "SubscriptionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChargeSucceeded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.interval",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodStart",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodEnd",
                  "type": "string"
                },
                {
                  "name": "row.nextBillingAt",
                  "type": "string"
                },
                {
                  "name": "row.attemptCount",
                  "type": "number"
                },
                {
                  "name": "row.lastChargeAt",
                  "type": "string"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChargeFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SubscriptionUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.interval",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodStart",
                  "type": "string"
                },
                {
                  "name": "row.currentPeriodEnd",
                  "type": "string"
                },
                {
                  "name": "row.nextBillingAt",
                  "type": "string"
                },
                {
                  "name": "row.attemptCount",
                  "type": "number"
                },
                {
                  "name": "row.lastChargeAt",
                  "type": "string"
                },
                {
                  "name": "row.cancelledAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "charging"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SubscriptionLoaded",
                "name": "Subscription loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Subscription]"
                  }
                ]
              },
              {
                "key": "SubscriptionLoadFailed",
                "name": "Subscription load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHARGE",
                "name": "Charge",
                "payloadSchema": [
                  {
                    "name": "subscriptionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "PRORATE",
                "name": "Prorate",
                "payloadSchema": [
                  {
                    "name": "subscriptionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newPlanId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "daysIntoPeriod",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "subscriptionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "cancelledAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "SubscriptionUpdated",
                "name": "Subscription updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "ChargeSucceeded",
                "name": "Charge succeeded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "ChargeFailed",
                "name": "Charge failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading subscriptions…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SubscriptionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "items": [
                            {
                              "href": "/billing",
                              "label": "Billing"
                            },
                            {
                              "href": "/plans",
                              "label": "Plans"
                            },
                            {
                              "label": "@config.title"
                            }
                          ],
                          "type": "breadcrumb"
                        },
                        {
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "pricing-grid",
                          "plans": [
                            {
                              "name": "Starter",
                              "description": "For solo accounts getting started",
                              "features": [
                                "Ten thousand events",
                                "Email support",
                                "One seat"
                              ],
                              "action": {
                                "label": "Choose Starter",
                                "href": "#"
                              },
                              "price": "$9"
                            },
                            {
                              "description": "For growing teams who need headroom",
                              "name": "Team",
                              "features": [
                                "Hundred thousand events",
                                "Priority support",
                                "Ten seats"
                              ],
                              "action": {
                                "label": "Choose Team",
                                "href": "#"
                              },
                              "price": "$29",
                              "highlighted": true
                            },
                            {
                              "name": "Scale",
                              "features": [
                                "One million events",
                                "Round the clock support",
                                "Unlimited seats"
                              ],
                              "action": {
                                "label": "Choose Scale",
                                "href": "#"
                              },
                              "description": "High-volume usage with SLA",
                              "price": "$99"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "max": 100.0,
                              "variant": "linear",
                              "type": "meter",
                              "showValue": true,
                              "label": "Usage this period",
                              "min": 0.0,
                              "unit": "%",
                              "value": 68.0
                            },
                            {
                              "variant": "segmented",
                              "value": 4.0,
                              "segments": 4.0,
                              "max": 4.0,
                              "label": "Retries",
                              "type": "meter",
                              "showValue": true,
                              "min": 0.0
                            }
                          ]
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "primary",
                              "icon": "credit-card",
                              "label": "Charge",
                              "event": "CHARGE"
                            },
                            {
                              "icon": "calculator",
                              "event": "PRORATE",
                              "label": "Prorate",
                              "variant": "secondary"
                            },
                            {
                              "label": "Cancel",
                              "variant": "danger",
                              "icon": "x",
                              "event": "CANCEL"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "customerId",
                              "label": "Customer",
                              "variant": "caption"
                            },
                            {
                              "label": "Plan",
                              "variant": "caption",
                              "name": "planId"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "variant": "caption",
                              "label": "Amount",
                              "name": "amount"
                            },
                            {
                              "variant": "caption",
                              "name": "currency",
                              "label": "Currency"
                            },
                            {
                              "name": "interval",
                              "label": "Interval",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "label": "Next Bill",
                              "name": "nextBillingAt"
                            },
                            {
                              "label": "Retries",
                              "variant": "caption",
                              "name": "attemptCount"
                            }
                          ],
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SubscriptionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "charging",
                "event": "CHARGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    "@payload.row.attemptCount"
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.row.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "call-service",
                    "stripe-charge",
                    "charge",
                    {
                      "subscriptionId": "@payload.subscriptionId",
                      "amount": "@entity.amount",
                      "currency": "@entity.currency"
                    },
                    {
                      "emit": {
                        "success": "ChargeSucceeded",
                        "failure": "ChargeFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Charging subscription…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PRORATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.newPlanId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    [
                      "*",
                      "@payload.row.amount",
                      [
                        "-",
                        1.0,
                        [
                          "/",
                          "@payload.daysIntoPeriod",
                          30.0
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    "@payload.row.attemptCount"
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.row.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "success": "SubscriptionUpdated",
                        "failure": "ChargeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    "@payload.row.attemptCount"
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "success": "SubscriptionUpdated",
                        "failure": "ChargeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SubscriptionUpdated",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Subscription updated"
                    }
                  ]
                ]
              },
              {
                "from": "charging",
                "to": "loading",
                "event": "ChargeSucceeded",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.row.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ChargeFailed",
                        "success": "SubscriptionUpdated"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "charging",
                "to": "browsing",
                "event": "ChargeFailed",
                "effects": [
                  [
                    "set",
                    "@entity.attemptCount",
                    [
                      "+",
                      "@entity.attemptCount",
                      1.0
                    ]
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ChargeFailed",
                        "success": "SubscriptionUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "success": "SubscriptionLoaded",
                        "failure": "SubscriptionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Subscriptions"
            },
            "maxRetries": {
              "type": "number",
              "default": 4.0
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SubscriptionManagePage",
          "path": "/subscriptions/manage",
          "traits": [
            {
              "ref": "SubscriptionManage"
            }
          ]
        }
      ]
    }
  ]
}
