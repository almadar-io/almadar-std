{
  "name": "std-reorder-rule",
  "version": "1.1.0",
  "description": "std-reorder-rule — automatic stock-replenishment rule per SKU/location. Lists rules in `browsing`; opens detail in `viewing_single` with Enable / Disable actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ReorderRuleOrbital",
      "entity": {
        "name": "ReorderRule",
        "collection": "reorderrules",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "required": true
          },
          {
            "name": "locationId",
            "type": "string",
            "default": ""
          },
          {
            "name": "thresholdQty",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reorderQty",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "vendor",
            "type": "string",
            "default": ""
          },
          {
            "name": "leadTimeDays",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          }
        ]
      },
      "traits": [
        {
          "name": "ReorderRuleManager",
          "category": "interaction",
          "linkedEntity": "ReorderRule",
          "emits": [
            {
              "event": "OPEN_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sku",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.locationId",
                  "type": "string"
                },
                {
                  "name": "row.thresholdQty",
                  "type": "number"
                },
                {
                  "name": "row.reorderQty",
                  "type": "number"
                },
                {
                  "name": "row.vendor",
                  "type": "string"
                },
                {
                  "name": "row.leadTimeDays",
                  "type": "number"
                },
                {
                  "name": "row.isActive",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ENABLE_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DISABLE_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ReorderRuleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ReorderRule]"
                }
              ]
            },
            {
              "event": "ReorderRuleLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReorderRuleLoaded",
                "name": "ReorderRule loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ReorderRule]"
                  }
                ]
              },
              {
                "key": "ReorderRuleLoadFailed",
                "name": "ReorderRule load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RULE",
                "name": "Open Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ReorderRule"
                  }
                ]
              },
              {
                "key": "ENABLE_RULE",
                "name": "Enable Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DISABLE_RULE",
                "name": "Disable Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "failure": "ReorderRuleLoadFailed",
                        "success": "ReorderRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading reorder rules…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ReorderRuleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "repeat"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total rules",
                              "icon": "repeat",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Active",
                              "type": "stat-display",
                              "value": "47"
                            },
                            {
                              "icon": "zap",
                              "type": "stat-display",
                              "value": "9",
                              "label": "Triggered today"
                            },
                            {
                              "icon": "clock",
                              "type": "stat-display",
                              "value": "6.4d",
                              "label": "Avg lead time"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReorderRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.sku",
                    "@payload.row.sku"
                  ],
                  [
                    "set",
                    "@entity.locationId",
                    "@payload.row.locationId"
                  ],
                  [
                    "set",
                    "@entity.thresholdQty",
                    "@payload.row.thresholdQty"
                  ],
                  [
                    "set",
                    "@entity.reorderQty",
                    "@payload.row.reorderQty"
                  ],
                  [
                    "set",
                    "@entity.vendor",
                    "@payload.row.vendor"
                  ],
                  [
                    "set",
                    "@entity.leadTimeDays",
                    "@payload.row.leadTimeDays"
                  ],
                  [
                    "set",
                    "@entity.isActive",
                    "@payload.row.isActive"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "repeat"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.sku"
                            },
                            {
                              "label": "Active",
                              "variant": "success",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Location",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.locationId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Vendor",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.vendor",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "Threshold",
                              "value": "@entity.thresholdQty"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.reorderQty",
                              "icon": "package",
                              "label": "Reorder qty"
                            },
                            {
                              "label": "Lead time (d)",
                              "icon": "clock",
                              "type": "stat-display",
                              "value": "@entity.leadTimeDays"
                            }
                          ],
                          "cols": 3.0
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Enable",
                              "type": "button",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "ENABLE_RULE"
                            },
                            {
                              "action": "DISABLE_RULE",
                              "label": "Disable",
                              "variant": "danger",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ]
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ENABLE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "failure": "ReorderRuleLoadFailed",
                        "success": "ReorderRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Enabling rule…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DISABLE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "failure": "ReorderRuleLoadFailed",
                        "success": "ReorderRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Disabling rule…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "success": "ReorderRuleLoaded",
                        "failure": "ReorderRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading reorder rules…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ENABLE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "failure": "ReorderRuleLoadFailed",
                        "success": "ReorderRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Enabling rule…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DISABLE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "success": "ReorderRuleLoaded",
                        "failure": "ReorderRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Disabling rule…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "failure": "ReorderRuleLoadFailed",
                        "success": "ReorderRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Reorder Rules",
              "label": "Section title",
              "description": "Heading shown above the stock reorder rule list"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "SKU",
                  "variant": "caption",
                  "name": "sku"
                },
                {
                  "label": "Location",
                  "name": "locationId",
                  "variant": "caption"
                },
                {
                  "name": "thresholdQty",
                  "variant": "caption",
                  "label": "Threshold"
                },
                {
                  "name": "reorderQty",
                  "label": "Reorder Qty",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "vendor",
                  "label": "Vendor"
                },
                {
                  "name": "leadTimeDays",
                  "label": "Lead (d)",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Reorder Rule entity",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_RULE",
                  "icon": "arrow-right",
                  "variant": "primary"
                },
                {
                  "label": "Disable",
                  "event": "DISABLE_RULE",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each rule row",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReorderRulePage",
          "path": "/reorder-rules",
          "traits": [
            {
              "ref": "ReorderRuleManager"
            }
          ]
        }
      ]
    }
  ]
}