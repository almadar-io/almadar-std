{
  "name": "std-approval-chain",
  "version": "1.0.0",
  "description": "std-approval-chain — domain-specific 3-step approval workflow. Composes std-step-flow with persisted ApprovalRequest entity carrying domain fields (requestType, amount, requester, approver fields per step). Lights up std-legal-case, std-ap-bill, std-change-order, std-application (hr-portal) — each rebinds std-step-flow + adds its own request entity.",
  "orbitals": [
    {
      "name": "ApprovalChainOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-step-flow",
          "as": "Flow"
        }
      ],
      "entity": {
        "name": "ApprovalRequest",
        "collection": "approval_requests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestType",
            "type": "string",
            "default": "expense",
            "values": [
              "expense",
              "purchase",
              "leave",
              "policy",
              "contract"
            ]
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "requester",
            "type": "string",
            "default": ""
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "Flow.traits.StepFlowReview",
          "name": "ApprovalReview",
          "linkedEntity": "ApprovalRequest",
          "config": {
            "step1Label": "Manager Review",
            "step2Key": "finance",
            "step1Key": "manager",
            "step1Icon": "user-check",
            "step2Label": "Finance Approval",
            "step1Desc": "Direct manager reviews the request and verifies budget impact",
            "title": "Approval Request",
            "step2Icon": "calculator",
            "step3Label": "Executive Sign-off",
            "step3Desc": "Final executive approval before commitment",
            "step3Icon": "shield-check",
            "step3Key": "executive",
            "step2Desc": "Finance team checks compliance with company policy"
          }
        }
      ],
      "pages": [
        {
          "name": "ApprovalChainPage",
          "path": "/approval-chain",
          "traits": [
            {
              "ref": "ApprovalReview"
            }
          ]
        }
      ]
    }
  ]
}
