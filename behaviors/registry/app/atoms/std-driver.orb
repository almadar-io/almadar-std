{
  "name": "std-driver",
  "version": "1.1.0",
  "description": "std-driver — fleet driver primitive tracking license info, hire date, status, assigned vehicle. Lists drivers in `browsing`; opens detail in `viewing_single` with Suspend / Reinstate / Terminate / Assign Vehicle actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "DriverOrbital",
      "entity": {
        "name": "Driver",
        "collection": "drivers",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "licenseNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "licenseClass",
            "type": "string",
            "default": "C",
            "values": [
              "A",
              "B",
              "C",
              "CDL-A",
              "CDL-B",
              "CDL-C"
            ]
          },
          {
            "name": "licenseExpiresAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "hiredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "on-leave",
              "terminated",
              "suspended"
            ]
          },
          {
            "name": "assignedVehicleId",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "DriverRoster",
          "category": "interaction",
          "linkedEntity": "Driver",
          "emits": [
            {
              "event": "OPEN_DRIVER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.licenseNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.licenseClass",
                  "type": "string"
                },
                {
                  "name": "row.licenseExpiresAt",
                  "type": "string"
                },
                {
                  "name": "row.hiredAt",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedVehicleId",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ASSIGN_VEHICLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SUSPEND",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REINSTATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TERMINATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DriverLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Driver]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "DriverLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DriverLoaded",
                "name": "Driver loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Driver]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "DriverLoadFailed",
                "name": "Driver load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_DRIVER",
                "name": "Open Driver",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Driver"
                  }
                ]
              },
              {
                "key": "SUSPEND",
                "name": "Suspend",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ASSIGN_VEHICLE",
                "name": "Assign Vehicle",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REINSTATE",
                "name": "Reinstate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TERMINATE",
                "name": "Terminate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "success": "DriverLoaded",
                        "failure": "DriverLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading drivers…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DriverLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "users",
                              "value": "@payload.data.length",
                              "label": "Total drivers"
                            },
                            {
                              "label": "Active",
                              "value": "24",
                              "type": "stat-display",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "value": "3",
                              "label": "On leave",
                              "icon": "pause-circle"
                            },
                            {
                              "label": "License expiring 30d",
                              "type": "stat-display",
                              "value": "4",
                              "icon": "alert-triangle"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DriverLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_DRIVER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.licenseNumber",
                    "@payload.row.licenseNumber"
                  ],
                  [
                    "set",
                    "@entity.licenseClass",
                    "@payload.row.licenseClass"
                  ],
                  [
                    "set",
                    "@entity.licenseExpiresAt",
                    "@payload.row.licenseExpiresAt"
                  ],
                  [
                    "set",
                    "@entity.hiredAt",
                    "@payload.row.hiredAt"
                  ],
                  [
                    "set",
                    "@entity.phone",
                    "@payload.row.phone"
                  ],
                  [
                    "set",
                    "@entity.email",
                    "@payload.row.email"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.assignedVehicleId",
                    "@payload.row.assignedVehicleId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.name"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.licenseClass",
                              "variant": "primary"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "License #"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.licenseNumber"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Phone",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.phone",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Email"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.email",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Vehicle"
                                },
                                {
                                  "content": "@entity.assignedVehicleId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "calendar",
                              "value": "@entity.hiredAt",
                              "label": "Hired"
                            },
                            {
                              "label": "License expires",
                              "type": "stat-display",
                              "value": "@entity.licenseExpiresAt",
                              "icon": "calendar-x"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "action": "ASSIGN_VEHICLE",
                              "type": "button",
                              "variant": "primary",
                              "label": "Assign Vehicle",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Suspend",
                              "action": "SUSPEND",
                              "variant": "danger"
                            },
                            {
                              "type": "button",
                              "label": "Reinstate",
                              "action": "REINSTATE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "secondary"
                            },
                            {
                              "variant": "danger",
                              "type": "button",
                              "action": "TERMINATE",
                              "label": "Terminate",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "failure": "DriverLoadFailed",
                        "success": "DriverLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Suspending driver…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "success": "DriverLoaded",
                        "failure": "DriverLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading drivers…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN_VEHICLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "success": "DriverLoaded",
                        "failure": "DriverLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Assigning vehicle…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "success": "DriverLoaded",
                        "failure": "DriverLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Suspending driver…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REINSTATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "failure": "DriverLoadFailed",
                        "success": "DriverLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Reinstating driver…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TERMINATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "success": "DriverLoaded",
                        "failure": "DriverLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Terminating driver…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "failure": "DriverLoadFailed",
                        "success": "DriverLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_DRIVER",
                  "label": "Open"
                },
                {
                  "variant": "danger",
                  "event": "SUSPEND",
                  "label": "Suspend"
                }
              ]
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "name",
                  "label": "Name",
                  "variant": "caption"
                },
                {
                  "label": "License",
                  "name": "licenseNumber",
                  "variant": "caption"
                },
                {
                  "label": "Class",
                  "variant": "badge",
                  "name": "licenseClass"
                },
                {
                  "name": "licenseExpiresAt",
                  "label": "Expires",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "label": "Vehicle",
                  "variant": "caption",
                  "name": "assignedVehicleId"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Drivers"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DriverPage",
          "path": "/drivers",
          "traits": [
            {
              "ref": "DriverRoster"
            }
          ]
        }
      ]
    }
  ]
}
