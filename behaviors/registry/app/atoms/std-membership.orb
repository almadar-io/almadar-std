{
  "name": "std-membership",
  "version": "1.2.0",
  "description": "std-membership — gym/club membership with tier, renewal, freeze, cancel. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs.",
  "orbitals": [
    {
      "name": "MembershipOrbital",
      "entity": {
        "name": "Membership",
        "collection": "memberships",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "memberId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberName",
            "type": "string",
            "default": ""
          },
          {
            "name": "tier",
            "type": "string",
            "default": "basic",
            "values": [
              "basic",
              "standard",
              "premium",
              "vip"
            ]
          },
          {
            "name": "monthlyDues",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "renewalDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "frozen",
              "cancelled",
              "expired"
            ]
          },
          {
            "name": "accessLevel",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MembershipDirectory",
          "category": "interaction",
          "capabilities": [
            "membership"
          ],
          "linkedEntity": "Membership",
          "emits": [
            {
              "event": "OPEN_MEMBERSHIP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberName",
                  "type": "string"
                },
                {
                  "name": "row.tier",
                  "type": "string"
                },
                {
                  "name": "row.monthlyDues",
                  "type": "number"
                },
                {
                  "name": "row.startDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.renewalDate",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.accessLevel",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_MEMBERSHIP"
            },
            {
              "event": "UPGRADE_TIER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FREEZE_MEMBERSHIP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_MEMBERSHIP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MembershipLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Membership]"
                }
              ]
            },
            {
              "event": "MembershipLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MembershipUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.memberName",
                  "type": "string"
                },
                {
                  "name": "row.tier",
                  "type": "string"
                },
                {
                  "name": "row.monthlyDues",
                  "type": "number"
                },
                {
                  "name": "row.startDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.renewalDate",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.accessLevel",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MembershipUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MembershipLoaded",
                "name": "Membership loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Membership]"
                  }
                ]
              },
              {
                "key": "MembershipLoadFailed",
                "name": "Membership load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_MEMBERSHIP",
                "name": "Open Membership",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Membership"
                  }
                ]
              },
              {
                "key": "CANCEL_MEMBERSHIP",
                "name": "Cancel Membership",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MembershipUpdated",
                "name": "Membership updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Membership"
                  }
                ]
              },
              {
                "key": "MembershipUpdateFailed",
                "name": "Membership update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_MEMBERSHIP",
                "name": "Close Membership"
              },
              {
                "key": "UPGRADE_TIER",
                "name": "Upgrade Tier",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FREEZE_MEMBERSHIP",
                "name": "Freeze Membership",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading memberships…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MembershipLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "credit-card",
                              "type": "stat-display",
                              "label": "Total memberships"
                            },
                            {
                              "type": "stat-display",
                              "value": "112",
                              "icon": "check-circle",
                              "label": "Active"
                            },
                            {
                              "type": "stat-display",
                              "icon": "pause-circle",
                              "label": "Frozen",
                              "value": "8"
                            },
                            {
                              "label": "MRR",
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "value": "$14,820"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MembershipLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_MEMBERSHIP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.memberId",
                    "@payload.row.memberId"
                  ],
                  [
                    "set",
                    "@entity.memberName",
                    "@payload.row.memberName"
                  ],
                  [
                    "set",
                    "@entity.tier",
                    "@payload.row.tier"
                  ],
                  [
                    "set",
                    "@entity.monthlyDues",
                    "@payload.row.monthlyDues"
                  ],
                  [
                    "set",
                    "@entity.startDate",
                    "@payload.row.startDate"
                  ],
                  [
                    "set",
                    "@entity.renewalDate",
                    "@payload.row.renewalDate"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.accessLevel",
                    "@payload.row.accessLevel"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "button",
                              "action": "CLOSE_MEMBERSHIP",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "content": "@entity.memberName",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.tier",
                              "variant": "primary"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Access level",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.accessLevel",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Notes",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "icon": "dollar-sign",
                              "label": "Monthly dues",
                              "type": "stat-display",
                              "value": "@entity.monthlyDues"
                            },
                            {
                              "label": "Started",
                              "icon": "calendar",
                              "value": "@entity.startDate",
                              "type": "stat-display"
                            },
                            {
                              "icon": "refresh-cw",
                              "type": "stat-display",
                              "label": "Renews",
                              "value": "@entity.renewalDate"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Upgrade Tier",
                              "action": "UPGRADE_TIER"
                            },
                            {
                              "action": "FREEZE_MEMBERSHIP",
                              "label": "Freeze",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "secondary"
                            },
                            {
                              "action": "CANCEL_MEMBERSHIP",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Cancel"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_MEMBERSHIP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Cancelling membership…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Membership",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MembershipUpdateFailed",
                        "success": "MembershipUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating membership status…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MembershipUpdated",
                "effects": [
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MembershipUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_MEMBERSHIP",
                "effects": [
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "failure": "MembershipLoadFailed",
                        "success": "MembershipLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading memberships…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "UPGRADE_TIER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Upgrading tier…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "FREEZE_MEMBERSHIP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Freezing membership…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_MEMBERSHIP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Cancelling membership…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "failure": "MembershipLoadFailed",
                        "success": "MembershipLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "healthScoreThresholdAlert": {
              "type": "number",
              "default": 50.0,
              "label": "Health score threshold",
              "description": "Members below this engagement score get flagged for win-back outreach. Declarative; wire via sibling std-notify.",
              "tier": "customization"
            },
            "renewalReminderDaysBefore": {
              "type": "[number]",
              "default": [
                30.0,
                14.0,
                7.0
              ],
              "label": "Renewal reminder days-before",
              "description": "Days before renewalDate to send renewal reminders. Declarative; wire via sibling std-reminder-scheduler.",
              "tier": "customization",
              "items": {
                "type": "number"
              }
            },
            "archiveInactiveAfterDays": {
              "type": "number",
              "default": 365.0,
              "label": "Archive inactive after (days)",
              "description": "Days after cancellation/expiry before membership record is archived. Declarative; wire via sibling std-lifecycle.",
              "tier": "advanced"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_MEMBERSHIP",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "event": "CANCEL_MEMBERSHIP",
                  "label": "Cancel",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each row",
