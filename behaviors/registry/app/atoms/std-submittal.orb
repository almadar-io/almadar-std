{
  "name": "std-submittal",
  "version": "1.2.0",
  "description": "std-submittal — construction submittal lifecycle. Listens for SET_STATUS so std-lifecycle can auto-escalate SLA breaches. Exposes Service/Operations knobs (responseTimeMinutes, resolutionSLAHours, …).",
  "orbitals": [
    {
      "name": "SubmittalOrbital",
      "entity": {
        "name": "Submittal",
        "collection": "submittals",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "submittalNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "specSection",
            "type": "string",
            "default": ""
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "contractor",
            "type": "string",
            "default": ""
          },
          {
            "name": "reviewer",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "in-review",
              "approved",
              "rejected",
              "revise-resubmit"
            ]
          },
          {
            "name": "revisionNumber",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "reviewedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "comments",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SubmittalReview",
          "category": "interaction",
          "linkedEntity": "Submittal",
          "emits": [
            {
              "event": "OPEN_SUBMITTAL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.submittalNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.specSection",
                  "type": "string"
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.contractor",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.revisionNumber",
                  "type": "number"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.comments",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "APPROVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REQUEST_REVISION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SubmittalLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Submittal]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "SubmittalLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SubmittalLoaded",
                "name": "Submittal loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Submittal]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "SubmittalLoadFailed",
                "name": "Submittal load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SUBMITTAL",
                "name": "Open Submittal",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Submittal"
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_REVISION",
                "name": "Request Revision",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading submittals…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SubmittalLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Total submittals",
                              "icon": "file-text",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "search",
                              "value": "18",
                              "label": "In review"
                            },
                            {
                              "label": "Approved",
                              "type": "stat-display",
                              "value": "62",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "label": "Revise & resubmit",
                              "value": "7",
                              "icon": "rotate-cw"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SubmittalLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SUBMITTAL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.submittalNumber",
                    "@payload.row.submittalNumber"
                  ],
                  [
                    "set",
                    "@entity.specSection",
                    "@payload.row.specSection"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.contractor",
                    "@payload.row.contractor"
                  ],
                  [
                    "set",
                    "@entity.reviewer",
                    "@payload.row.reviewer"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.revisionNumber",
                    "@payload.row.revisionNumber"
                  ],
                  [
                    "set",
                    "@entity.submittedAt",
                    "@payload.row.submittedAt"
                  ],
                  [
                    "set",
                    "@entity.reviewedAt",
                    "@payload.row.reviewedAt"
                  ],
                  [
                    "set",
                    "@entity.comments",
                    "@payload.row.comments"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "content": "@entity.title",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "default",
                              "label": "@entity.status",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Number"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.submittalNumber"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Spec section",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.specSection",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Contractor",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.contractor"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Reviewer",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.reviewer"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "content": "Comments",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.comments"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.revisionNumber",
                              "type": "stat-display",
                              "icon": "rotate-cw",
                              "label": "Revision"
                            },
                            {
                              "icon": "calendar",
                              "value": "@entity.submittedAt",
                              "type": "stat-display",
                              "label": "Submitted"
                            },
                            {
                              "label": "Reviewed",
                              "type": "stat-display",
                              "value": "@entity.reviewedAt",
                              "icon": "calendar-check"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Approve",
                              "action": "APPROVE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "action": "REJECT",
                              "label": "Reject",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "action": "REQUEST_REVISION",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Revise",
                              "variant": "secondary"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Delete",
                              "action": "REQUEST_DELETE",
                              "variant": "danger",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Deleting submittal…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Submittal",
                    "@entity",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating submittal status…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "failure": "SubmittalLoadFailed",
                        "success": "SubmittalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading submittals…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Approving submittal…"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Rejecting submittal…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_REVISION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "failure": "SubmittalLoadFailed",
                        "success": "SubmittalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Requesting revision…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "failure": "SubmittalLoadFailed",
                        "success": "SubmittalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Deleting submittal…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "failure": "SubmittalLoadFailed",
                        "success": "SubmittalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "responseTimeMinutes": {
              "type": "number",
              "default": 1440.0,
              "label": "Response time SLA (min)",
              "description": "Target minutes from submittal received to first acknowledgement (default 1 day).",
              "tier": "essential"
            },
            "customerVisibleStatuses": {
              "type": "[string]",
              "default": [
                "submitted",
                "in-review",
                "approved",
                "rejected",
                "revise-resubmit"
              ],
              "label": "Customer-visible statuses",
              "description": "Subset of statuses contractors see in their portal.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "serviceAreaRadius": {
              "type": "number",
              "default": 0.0,
              "label": "Service area radius (mi)",
              "description": "Project-site distance limit for assignable reviewers. Zero = no restriction.",
              "tier": "customization"
            },
            "dispatchStrategy": {
              "type": "string",
              "default": "manual",
              "label": "Dispatch strategy",
              "description": "How reviewers are assigned to incoming submittals.",
              "tier": "customization",
              "values": [
                "nearest",
                "round-robin",
                "manual"
              ]
            },
            "skillsRequired": {
              "type": "[string]",
              "default": [],
              "label": "Required skills",
              "description": "Discipline tags a reviewer must hold (e.g. 'structural', 'mep', 'arch').",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_SUBMITTAL"
                },
                {
                  "variant": "danger",
                  "label": "Delete",
                  "event": "REQUEST_DELETE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each submittal row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "serviceZones": {
              "type": "[string]",
              "default": [],
              "label": "Service zones",
              "description": "Named project zones for routing submittals to the right reviewer pool.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "resolutionSLAHours": {
              "type": "number",
              "default": 240.0,
              "label": "Resolution SLA (hours)",
              "description": "Target hours from receipt to approved/rejected (default 10 business days). Compose std-lifecycle to escalate.",
              "tier": "essential"
            },
            "escalationThresholdHours": {
              "type": "number",
              "default": 336.0,
              "label": "Escalation threshold (hours)",
              "description": "Hours after which a stalled submittal auto-escalates (default 14 days).",
              "tier": "customization"
            },
            "requirePhotoOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require photo on complete",
              "description": "Block APPROVE unless a marked-up reviewer image is attached.",
              "tier": "customization"
            },
            "requireSignatureOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require reviewer signature on complete",
              "description": "Block APPROVE unless reviewer signature is captured (compose std-signature-capture).",
              "tier": "customization"
            },
            "title": {
              "type": "string",
              "default": "Submittals",
              "label": "Section title",
              "description": "Heading shown above the submittal review list",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "submittalNumber",
                  "variant": "caption",
                  "label": "Number"
                },
                {
                  "name": "specSection",
                  "variant": "caption",
                  "label": "Spec Section"
                },
                {
                  "name": "title",
                  "label": "Title",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Contractor",
                  "name": "contractor"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "name": "revisionNumber",
                  "variant": "caption",
                  "label": "Rev"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Submittal entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SubmittalPage",
          "path": "/submittals",
          "traits": [
