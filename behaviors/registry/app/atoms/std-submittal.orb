{
  "name": "std-submittal",
  "version": "1.0.0",
  "description": "std-submittal — construction submittal primitive tracking material/equipment samples reviewed and approved before installation.",
  "orbitals": [
    {
      "name": "SubmittalOrbital",
      "entity": {
        "name": "Submittal",
        "collection": "submittals",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "submittalNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "specSection",
            "type": "string",
            "default": ""
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "contractor",
            "type": "string",
            "default": ""
          },
          {
            "name": "reviewer",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "in-review",
              "approved",
              "rejected",
              "revise-resubmit"
            ]
          },
          {
            "name": "revisionNumber",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "reviewedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "comments",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SubmittalReview",
          "category": "interaction",
          "linkedEntity": "Submittal",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.submittalNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.specSection",
                  "type": "string"
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.contractor",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.revisionNumber",
                  "type": "number"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.comments",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.submittalNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.specSection",
                  "type": "string"
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.contractor",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.revisionNumber",
                  "type": "number"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.comments",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.submittalNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.specSection",
                  "type": "string"
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.contractor",
                  "type": "string"
                },
                {
                  "name": "row.reviewer",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.revisionNumber",
                  "type": "number"
                },
                {
                  "name": "row.submittedAt",
                  "type": "string"
                },
                {
                  "name": "row.reviewedAt",
                  "type": "string"
                },
                {
                  "name": "row.comments",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SubmittalLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Submittal]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "SubmittalLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SubmittalLoaded",
                "name": "Submittal loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Submittal]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "SubmittalLoadFailed",
                "name": "Submittal load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "APPROVE",
                "name": "Approve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_REVISION",
                "name": "Request Revision",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading submittals…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "SubmittalLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "name": "file-text",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "@config.title",
                                      "variant": "h3"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center"
                                },
                                {
                                  "type": "button",
                                  "actionPayload": {
                                    "source": "header"
                                  },
                                  "label": "New Submittal",
                                  "variant": "primary",
                                  "action": "CREATE"
                                }
                              ],
                              "justify": "between",
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "type": "split-pane",
                              "left": {
                                "type": "file-tree",
                                "tree": [
                                  {
                                    "name": "01 - General",
                                    "path": "01 - General",
                                    "type": "dir",
                                    "children": [
                                      {
                                        "type": "file",
                                        "path": "Cover Sheet.pdf",
                                        "name": "Cover Sheet.pdf"
                                      },
                                      {
                                        "type": "file",
                                        "name": "Schedule.pdf",
                                        "path": "Schedule.pdf"
                                      }
                                    ]
                                  },
                                  {
                                    "name": "03 - Concrete",
                                    "path": "03 - Concrete",
                                    "children": [
                                      {
                                        "type": "file",
                                        "name": "Mix Design.pdf",
                                        "path": "03 - Concrete/Mix Design.pdf"
                                      },
                                      {
                                        "path": "03 - Concrete/Rebar Shop Drawings.pdf",
                                        "name": "Rebar Shop Drawings.pdf",
                                        "type": "file"
                                      }
                                    ],
                                    "type": "dir"
                                  },
                                  {
                                    "path": "05 - Metals",
                                    "children": [
                                      {
                                        "path": "05 - Metals/Structural Steel.pdf",
                                        "name": "Structural Steel.pdf",
                                        "type": "file"
                                      }
                                    ],
                                    "name": "05 - Metals",
                                    "type": "dir"
                                  }
                                ]
                              },
                              "right": {
                                "type": "stack",
                                "children": [
                                  {
                                    "gap": "md",
                                    "ratio": "1:1",
                                    "type": "split",
                                    "children": [
                                      {
                                        "type": "stack",
                                        "children": [
                                          {
                                            "content": "WBS hierarchy",
                                            "type": "typography",
                                            "variant": "caption"
                                          }
                                        ],
                                        "direction": "vertical",
                                        "gap": "sm"
                                      },
                                      {
                                        "gap": "sm",
                                        "direction": "vertical",
                                        "children": [
                                          {
                                            "type": "typography",
                                            "content": "Review status",
                                            "variant": "caption"
                                          }
                                        ],
                                        "type": "stack"
                                      }
                                    ]
                                  },
                                  {
                                    "size": "sm",
                                    "type": "spacer"
                                  },
                                  {
                                    "type": "upload-drop-zone",
                                    "description": "Shop drawings, product data, samples",
                                    "maxFiles": 8.0,
                                    "label": "Drop submittal attachments here",
                                    "maxSize": 20971520.0,
                                    "icon": "paperclip",
                                    "accept": "application/pdf,image/*"
                                  }
                                ],
                                "gap": "md",
                                "direction": "vertical"
                              }
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "variant": "h4",
                              "content": "Engineering Diagram",
                              "type": "typography"
                            },
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "primary",
                                  "connectionDensity": 0.5,
                                  "type": "svg-mesh",
                                  "nodes": 5.0,
                                  "radius": 30.0,
                                  "cy": 60.0,
                                  "cx": 80.0
                                },
                                {
                                  "x": 200.0,
                                  "color": "secondary",
                                  "branches": 4.0,
                                  "y": 60.0,
                                  "type": "svg-branch"
                                },
                                {
                                  "type": "svg-connection",
                                  "color": "muted",
                                  "x2": 200.0,
                                  "y2": 60.0,
                                  "y1": 60.0,
                                  "x1": 40.0
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "fields": [
                                {
                                  "name": "submittalNumber",
                                  "variant": "caption",
                                  "label": "Number"
                                },
                                {
                                  "variant": "caption",
                                  "label": "Spec Section",
                                  "name": "specSection"
                                },
                                {
                                  "variant": "caption",
                                  "label": "Title",
                                  "name": "title"
                                },
                                {
                                  "label": "Contractor",
                                  "name": "contractor",
                                  "variant": "caption"
                                },
                                {
                                  "name": "status",
                                  "label": "Status",
                                  "variant": "badge"
                                },
                                {
                                  "variant": "caption",
                                  "name": "revisionNumber",
                                  "label": "Rev"
                                }
                              ],
                              "entity": "@payload.data",
                              "gap": "sm",
                              "itemActions": [
                                {
                                  "label": "View",
                                  "variant": "ghost",
                                  "event": "VIEW"
                                },
                                {
                                  "variant": "secondary",
                                  "event": "EDIT",
                                  "label": "Edit"
                                },
                                {
                                  "event": "APPROVE",
                                  "label": "Approve",
                                  "variant": "primary"
                                },
                                {
                                  "variant": "danger",
                                  "label": "Reject",
                                  "event": "REJECT"
                                },
                                {
                                  "label": "Revise",
                                  "variant": "secondary",
                                  "event": "REQUEST_REVISION"
                                },
                                {
                                  "event": "REQUEST_DELETE",
                                  "variant": "ghost",
                                  "label": "Delete"
                                }
                              ],
                              "type": "data-grid",
                              "cols": 1.0
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SubmittalLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "SUBMIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Submittal submitted for review",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "APPROVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Submittal approved",
                      "variant": "success",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "Submittal rejected",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_REVISION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Revision requested",
                      "variant": "warning",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Creating new submittal"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "success": "SubmittalLoaded",
                        "failure": "SubmittalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Searching submittals",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "FILTER_STATUS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Filtering by status"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Viewing submittal",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Editing submittal",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Delete requested",
                      "type": "alert",
                      "variant": "warning"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Submittal",
                    {
                      "emit": {
                        "failure": "SubmittalLoadFailed",
                        "success": "SubmittalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Submittals"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SubmittalPage",
          "path": "/submittals",
          "traits": [
            {
              "ref": "SubmittalReview"
            }
          ]
        }
      ]
    }
  ]
}
