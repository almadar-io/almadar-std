{
  "name": "std-runbook",
  "version": "1.0.0",
  "description": "std-runbook — operational runbook lifecycle (draft → active → deprecated) with auto-execute policy + approval gates + rollback.",
  "orbitals": [
    {
      "name": "RunbookOrbital",
      "entity": {
        "name": "Runbook",
        "collection": "runbooks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "triggerEvent",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "deprecated"
            ]
          },
          {
            "name": "stepsJson",
            "type": "string",
            "default": "[]"
          },
          {
            "name": "lastExecutedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "executionCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RunbookManage",
          "category": "interaction",
          "linkedEntity": "Runbook",
          "emits": [
            {
              "event": "OPEN_RUNBOOK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.lastExecutedAt",
                  "type": "string"
                },
                {
                  "name": "row.executionCount",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "EXECUTE_RUNBOOK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.lastExecutedAt",
                  "type": "string"
                },
                {
                  "name": "row.executionCount",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ACTIVATE_RUNBOOK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.lastExecutedAt",
                  "type": "string"
                },
                {
                  "name": "row.executionCount",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DEPRECATE_RUNBOOK",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.triggerEvent",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.stepsJson",
                  "type": "string"
                },
                {
                  "name": "row.lastExecutedAt",
                  "type": "string"
                },
                {
                  "name": "row.executionCount",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RunbookLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Runbook]"
                }
              ]
            },
            {
              "event": "RunbookLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RunbookLoaded",
                "name": "Runbook loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Runbook]"
                  }
                ]
              },
              {
                "key": "RunbookLoadFailed",
                "name": "Runbook load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RUNBOOK",
                "name": "Open Runbook",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Runbook"
                  }
                ]
              },
              {
                "key": "EXECUTE_RUNBOOK",
                "name": "Execute Runbook",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Runbook"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ACTIVATE_RUNBOOK",
                "name": "Activate Runbook",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Runbook"
                  }
                ]
              },
              {
                "key": "DEPRECATE_RUNBOOK",
                "name": "Deprecate Runbook",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Runbook"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "success": "RunbookLoaded",
                        "failure": "RunbookLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading runbooks…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RunbookLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "book-open",
                              "type": "stat-display",
                              "label": "Total runbooks",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "label": "Active",
                              "value": "12"
                            },
                            {
                              "value": "4",
                              "type": "stat-display",
                              "label": "Executed today",
                              "icon": "play"
                            },
                            {
                              "value": "1",
                              "label": "Failed runs",
                              "icon": "alert-triangle",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RunbookLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RUNBOOK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.triggerEvent",
                    "@payload.row.triggerEvent"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.stepsJson",
                    "@payload.row.stepsJson"
                  ],
                  [
                    "set",
                    "@entity.lastExecutedAt",
                    "@payload.row.lastExecutedAt"
                  ],
                  [
                    "set",
                    "@entity.executionCount",
                    "@payload.row.executionCount"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button"
                            },
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.title",
                              "type": "typography"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Trigger"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.triggerEvent"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Description",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.description",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Runs",
                              "value": "@entity.executionCount",
                              "icon": "play"
                            },
                            {
                              "value": "@entity.lastExecutedAt",
                              "icon": "calendar",
                              "label": "Last run",
                              "type": "stat-display"
                            },
                            {
                              "icon": "calendar-plus",
                              "label": "Created",
                              "value": "@entity.createdAt",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "type": "button",
                              "label": "Execute",
                              "action": "EXECUTE_RUNBOOK"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "action": "ACTIVATE_RUNBOOK",
                              "label": "Activate",
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "type": "button",
                              "action": "DEPRECATE_RUNBOOK",
                              "label": "Deprecate",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "EXECUTE_RUNBOOK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "success": "RunbookLoaded",
                        "failure": "RunbookLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Executing runbook…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Runbook",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RunbookLoadFailed",
                        "success": "RunbookLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Updating runbook status…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "failure": "RunbookLoadFailed",
                        "success": "RunbookLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading runbooks…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EXECUTE_RUNBOOK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "failure": "RunbookLoadFailed",
                        "success": "RunbookLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Executing runbook…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACTIVATE_RUNBOOK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "success": "RunbookLoaded",
                        "failure": "RunbookLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Activating runbook…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DEPRECATE_RUNBOOK",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "success": "RunbookLoaded",
                        "failure": "RunbookLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Deprecating runbook…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Runbook",
                    {
                      "emit": {
                        "success": "RunbookLoaded",
                        "failure": "RunbookLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "title",
                  "label": "Title"
                },
                {
                  "label": "Trigger",
                  "name": "triggerEvent",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "variant": "caption",
                  "label": "Runs",
                  "name": "executionCount"
                },
                {
                  "label": "Last run",
                  "name": "lastExecutedAt",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Runbook entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "variant": "primary",
                  "event": "OPEN_RUNBOOK",
                  "icon": "arrow-right"
                },
                {
                  "variant": "secondary",
                  "event": "EXECUTE_RUNBOOK",
                  "label": "Execute",
                  "icon": "play"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each runbook row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "triggersOn": {
              "type": "[string]",
              "default": [],
              "label": "Trigger events",
              "description": "Alert/incident kinds that auto-suggest this runbook (e.g. 'high-cpu', 'db-connection-failed').",
              "synonyms": "alert types, triggering conditions",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "default": "Runbooks",
              "label": "Section title",
              "description": "Heading shown above the operational runbooks list",
              "tier": "presentation"
            },
            "autoExecutePolicy": {
              "type": "string",
              "default": "never",
              "label": "Auto-execute policy",
              "description": "Whether the runbook auto-runs on trigger or requires human action.",
              "synonyms": "automation level, execution mode",
              "tier": "domain",
              "values": [
                "never",
                "dry-run-first",
                "approve-then-execute",
                "always"
              ]
            },
            "approvalRequiredAbove": {
              "type": "string",
              "default": "medium",
              "label": "Approval required above",
              "description": "Severity at or above which manual approval is required before auto-execute.",
              "tier": "domain",
              "values": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            },
            "rollbackOnFailure": {
              "type": "boolean",
              "default": true,
              "label": "Auto-rollback on failure",
              "description": "When true, automatically run the rollback steps if any step fails.",
              "synonyms": "auto-revert, undo on error",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
