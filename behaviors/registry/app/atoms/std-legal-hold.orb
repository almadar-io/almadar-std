{
  "name": "std-legal-hold",
  "version": "1.0.0",
  "description": "std-legal-hold — legal hold trigger, duration, and release approval; companion to std-matter and std-court-deadline.",
  "orbitals": [
    {
      "name": "LegalHoldOrbital",
      "entity": {
        "name": "LegalHold",
        "collection": "legal_holds",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterId",
            "type": "string",
            "default": ""
          },
          {
            "name": "triggeredBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "triggeredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "expectedReleaseAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "expiring",
              "released",
              "extended"
            ]
          },
          {
            "name": "affectedEntities",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "LegalHoldPipeline",
          "category": "interaction",
          "linkedEntity": "LegalHold",
          "emits": [
            {
              "event": "OPEN_HOLD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterId",
                  "type": "string"
                },
                {
                  "name": "row.triggeredBy",
                  "type": "string"
                },
                {
                  "name": "row.triggeredAt",
                  "type": "string"
                },
                {
                  "name": "row.expectedReleaseAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.affectedEntities",
                  "type": "[string]"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "EXTEND_HOLD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterId",
                  "type": "string"
                },
                {
                  "name": "row.triggeredBy",
                  "type": "string"
                },
                {
                  "name": "row.triggeredAt",
                  "type": "string"
                },
                {
                  "name": "row.expectedReleaseAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.affectedEntities",
                  "type": "[string]"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RELEASE_HOLD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterId",
                  "type": "string"
                },
                {
                  "name": "row.triggeredBy",
                  "type": "string"
                },
                {
                  "name": "row.triggeredAt",
                  "type": "string"
                },
                {
                  "name": "row.expectedReleaseAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.affectedEntities",
                  "type": "[string]"
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LegalHoldLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[LegalHold]"
                }
              ]
            },
            {
              "event": "LegalHoldLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LegalHoldLoaded",
                "name": "LegalHold loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[LegalHold]"
                  }
                ]
              },
              {
                "key": "LegalHoldLoadFailed",
                "name": "LegalHold load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_HOLD",
                "name": "Open Hold",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "LegalHold"
                  }
                ]
              },
              {
                "key": "RELEASE_HOLD",
                "name": "Release Hold",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "EXTEND_HOLD",
                "name": "Extend Hold",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LegalHold",
                    {
                      "emit": {
                        "failure": "LegalHoldLoadFailed",
                        "success": "LegalHoldLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading legal holds…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LegalHoldLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total holds",
                              "icon": "lock",
                              "value": "@payload.data.length",
                              "type": "stat-display"
                            },
                            {
                              "label": "Active",
                              "type": "stat-display",
                              "icon": "shield",
                              "value": "23"
                            },
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "4",
                              "label": "Expiring soon"
                            },
                            {
                              "type": "stat-display",
                              "icon": "unlock",
                              "value": "12",
                              "label": "Released YTD"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LegalHoldLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_HOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.matterId",
                    "@payload.row.matterId"
                  ],
                  [
                    "set",
                    "@entity.triggeredBy",
                    "@payload.row.triggeredBy"
                  ],
                  [
                    "set",
                    "@entity.triggeredAt",
                    "@payload.row.triggeredAt"
                  ],
                  [
                    "set",
                    "@entity.expectedReleaseAt",
                    "@payload.row.expectedReleaseAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.matterId",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Trigger",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.triggeredBy"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "content": "Description",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.description",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Started",
                              "value": "@entity.triggeredAt"
                            },
                            {
                              "label": "Expected Release",
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.expectedReleaseAt"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "label": "Extend",
                              "action": "EXTEND_HOLD",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "RELEASE_HOLD",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Release",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RELEASE_HOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LegalHold",
                    {
                      "emit": {
                        "failure": "LegalHoldLoadFailed",
                        "success": "LegalHoldLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Releasing hold…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "LegalHold",
                    {
                      "emit": {
                        "failure": "LegalHoldLoadFailed",
                        "success": "LegalHoldLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading legal holds…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EXTEND_HOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LegalHold",
                    {
                      "emit": {
                        "success": "LegalHoldLoaded",
                        "failure": "LegalHoldLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Extending hold…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RELEASE_HOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "LegalHold",
                    {
                      "emit": {
                        "success": "LegalHoldLoaded",
                        "failure": "LegalHoldLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Releasing hold…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LegalHold",
                    {
                      "emit": {
                        "success": "LegalHoldLoaded",
                        "failure": "LegalHoldLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "releaseApprovalRoles": {
              "type": "[string]",
              "default": [
                "general-counsel",
                "compliance-officer"
              ],
              "label": "Release approval roles",
              "description": "Roles required to approve hold release. Compose std-approval-gate for the workflow.",
              "synonyms": "release approvers",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "triggeredBy": {
              "type": "string",
              "default": "litigation",
              "label": "Trigger type",
              "description": "Reason the legal hold was instituted.",
              "synonyms": "hold reason, basis",
              "tier": "domain",
              "values": [
                "litigation",
                "regulatory-inquiry",
                "internal-investigation",
                "audit"
              ]
            },
            "holdDurationDays": {
              "type": "number",
              "default": 365.0,
              "label": "Default hold duration (days)",
              "description": "Initial hold period before release-eligibility review.",
              "synonyms": "retention period, hold length",
              "tier": "domain"
            },
            "notifyRolesOnHold": {
              "type": "[string]",
              "default": [
                "records-manager",
                "it-admin"
              ],
              "label": "Notify on hold (roles)",
              "description": "Roles paged when a new hold activates. Compose std-notify-on-event for delivery.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "matterId",
                  "label": "Matter"
                },
                {
                  "label": "Trigger",
                  "variant": "caption",
                  "name": "triggeredBy"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "name": "triggeredAt",
                  "variant": "caption",
                  "label": "Started"
                },
                {
                  "variant": "caption",
                  "name": "expectedReleaseAt",
                  "label": "Releases"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the LegalHold entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_HOLD"
                },
                {
                  "variant": "danger",
                  "event": "RELEASE_HOLD",
                  "label": "Release"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each legal hold row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Legal Holds",
              "label": "Section title",
              "description": "Heading shown above the legal hold list",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LegalHoldPage",
          "path": "/legal-holds",
          "traits": [
            {
              "ref": "LegalHoldPipeline"
            }
          ]
        }
      ]
    }
  ]
}