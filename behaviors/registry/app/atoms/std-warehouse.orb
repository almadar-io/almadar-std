{
  "name": "std-warehouse",
  "version": "1.1.0",
  "description": "std-warehouse — physical or logical storage location. Lists warehouses in `browsing`; opens a warehouse detail view (name, code, address, type, active flag, total SKU count) in `viewing_single`. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "WarehouseOrbital",
      "entity": {
        "name": "Warehouse",
        "collection": "warehouses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "default": ""
          },
          {
            "name": "address",
            "type": "string",
            "default": ""
          },
          {
            "name": "type",
            "type": "string",
            "default": "warehouse",
            "values": [
              "warehouse",
              "store",
              "transit"
            ]
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "totalSkus",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "WarehouseDirectory",
          "category": "interaction",
          "linkedEntity": "Warehouse",
          "emits": [
            {
              "event": "OPEN_WAREHOUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.code",
                  "type": "string"
                },
                {
                  "name": "row.address",
                  "type": "string"
                },
                {
                  "name": "row.type",
                  "type": "string"
                },
                {
                  "name": "row.isActive",
                  "type": "boolean"
                },
                {
                  "name": "row.totalSkus",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_WAREHOUSE"
            },
            {
              "event": "WarehouseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Warehouse]"
                }
              ]
            },
            {
              "event": "WarehouseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WarehouseLoaded",
                "name": "Warehouse loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Warehouse]"
                  }
                ]
              },
              {
                "key": "WarehouseLoadFailed",
                "name": "Warehouse load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_WAREHOUSE",
                "name": "Open Warehouse",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Warehouse"
                  }
                ]
              },
              {
                "key": "CLOSE_WAREHOUSE",
                "name": "Close Warehouse"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "failure": "WarehouseLoadFailed",
                        "success": "WarehouseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "size": "md",
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading locations…",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WarehouseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "warehouse",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Total locations",
                              "type": "stat-display",
                              "icon": "warehouse"
                            },
                            {
                              "label": "Active",
                              "icon": "check-circle",
                              "value": "12",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Total SKUs",
                              "value": "48,392",
                              "icon": "package"
                            },
                            {
                              "label": "Avg utilization",
                              "icon": "bar-chart",
                              "type": "stat-display",
                              "value": "73%"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WarehouseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_WAREHOUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.code",
                    "@payload.row.code"
                  ],
                  [
                    "set",
                    "@entity.address",
                    "@payload.row.address"
                  ],
                  [
                    "set",
                    "@entity.type",
                    "@payload.row.type"
                  ],
                  [
                    "set",
                    "@entity.isActive",
                    "@payload.row.isActive"
                  ],
                  [
                    "set",
                    "@entity.totalSkus",
                    "@payload.row.totalSkus"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_WAREHOUSE"
                            },
                            {
                              "name": "warehouse",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.name"
                            },
                            {
                              "label": "@entity.type",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Code"
                                },
                                {
                                  "content": "@entity.code",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Address"
                                },
                                {
                                  "content": "@entity.address",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.totalSkus",
                              "icon": "package",
                              "type": "stat-display",
                              "label": "Total SKUs"
                            },
                            {
                              "type": "stat-display",
                              "icon": "tag",
                              "label": "Type",
                              "value": "@entity.type"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_WAREHOUSE",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "success": "WarehouseLoaded",
                        "failure": "WarehouseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "size": "md",
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading locations…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "failure": "WarehouseLoadFailed",
                        "success": "WarehouseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "variant": "primary",
                  "icon": "arrow-right",
                  "event": "OPEN_WAREHOUSE",
                  "label": "Open"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each location row",
              "items": {
                "type": "object"
              }
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "Code",
                  "variant": "caption",
                  "name": "code"
                },
                {
                  "label": "Name",
                  "name": "name",
                  "variant": "caption"
                },
                {
                  "name": "type",
                  "variant": "badge",
                  "label": "Type"
                },
                {
                  "variant": "caption",
                  "name": "totalSkus",
                  "label": "SKUs"
                },
                {
                  "variant": "badge",
                  "label": "Active",
                  "name": "isActive"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Warehouse entity",
              "items": {
                "type": "object"
              }
            },
            "title": {
              "type": "string",
              "default": "Locations",
              "label": "Section title",
              "description": "Heading shown above the storage locations list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WarehousePage",
          "path": "/warehouses",
          "traits": [
            {
              "ref": "WarehouseDirectory"
            }
          ]
        }
      ]
    }
  ]
}