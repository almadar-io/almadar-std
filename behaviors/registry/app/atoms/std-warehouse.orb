{
  "name": "std-warehouse",
  "version": "1.0.0",
  "description": "std-warehouse — physical or logical storage location where stock lives. Used by inventory and retail to scope stock counts.",
  "orbitals": [
    {
      "name": "WarehouseOrbital",
      "entity": {
        "name": "Warehouse",
        "collection": "warehouses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "default": ""
          },
          {
            "name": "address",
            "type": "string",
            "default": ""
          },
          {
            "name": "type",
            "type": "string",
            "default": "warehouse",
            "values": [
              "warehouse",
              "store",
              "transit"
            ]
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "totalSkus",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "WarehouseDirectory",
          "category": "interaction",
          "linkedEntity": "Warehouse",
          "emits": [
            {
              "event": "OPEN_WAREHOUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WarehouseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Warehouse]"
                }
              ]
            },
            {
              "event": "WarehouseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WarehouseLoaded",
                "name": "Warehouse loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Warehouse]"
                  }
                ]
              },
              {
                "key": "WarehouseLoadFailed",
                "name": "Warehouse load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_WAREHOUSE",
                "name": "Open Warehouse",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "success": "WarehouseLoaded",
                        "failure": "WarehouseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading locations…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WarehouseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "warehouse",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "activeTab": "warehouses",
                          "type": "tabs",
                          "items": [
                            {
                              "id": "warehouses",
                              "label": "Warehouses"
                            },
                            {
                              "label": "Bins",
                              "id": "bins"
                            },
                            {
                              "id": "zones",
                              "label": "Zones"
                            }
                          ]
                        },
                        {
                          "cells": [
                            {
                              "content": {
                                "color": "text-emerald-400",
                                "value": 0.0,
                                "size": "md",
                                "type": "resource-counter",
                                "icon": "package",
                                "label": "Total SKUs",
                                "max": 10000.0
                              }
                            },
                            {
                              "content": {
                                "icon": "boxes",
                                "size": "md",
                                "max": 500.0,
                                "label": "Pallets",
                                "type": "resource-counter",
                                "value": 320.0,
                                "color": "text-blue-400"
                              }
                            },
                            {
                              "content": {
                                "type": "enemy-plate",
                                "health": 4.0,
                                "level": 1.0,
                                "effects": [
                                  {
                                    "label": "Below reorder",
                                    "icon": "alert-triangle"
                                  }
                                ],
                                "name": "Low-stock alert: SKU-4421",
                                "maxHealth": 100.0
                              }
                            }
                          ],
                          "type": "dashboard-grid"
                        },
                        {
                          "gap": "sm",
                          "cols": 4.0,
                          "type": "grid",
                          "children": [
                            {
                              "quantity": 12.0,
                              "empty": false,
                              "type": "item-slot",
                              "rarity": "common",
                              "selected": false,
                              "label": "Bin A-01",
                              "icon": "package",
                              "size": "md"
                            },
                            {
                              "empty": false,
                              "rarity": "uncommon",
                              "label": "Bin A-02",
                              "type": "item-slot",
                              "size": "md",
                              "icon": "package",
                              "quantity": 8.0,
                              "selected": false
                            },
                            {
                              "empty": true,
                              "size": "md",
                              "label": "Bin A-03",
                              "icon": "package",
                              "selected": false,
                              "rarity": "common",
                              "quantity": 0.0,
                              "type": "item-slot"
                            },
                            {
                              "type": "item-slot",
                              "size": "md",
                              "label": "Bin A-04",
                              "selected": true,
                              "empty": false,
                              "icon": "package",
                              "rarity": "rare",
                              "quantity": 3.0
                            }
                          ]
                        },
                        {
                          "type": "powerup-slots",
                          "active": [
                            {
                              "id": "fastpick",
                              "label": "Fast Pick",
                              "icon": "zap"
                            },
                            {
                              "id": "scan",
                              "icon": "scan",
                              "label": "Auto Scan"
                            }
                          ],
                          "maxSlots": 4.0
                        },
                        {
                          "canCraft": true,
                          "type": "crafting-recipe",
                          "output": {
                            "label": "Kit 01",
                            "icon": "box",
                            "id": "kit-01",
                            "quantity": 1.0
                          },
                          "inputs": [
                            {
                              "label": "Part A",
                              "quantity": 2.0,
                              "icon": "package",
                              "id": "sku-100"
                            },
                            {
                              "quantity": 1.0,
                              "icon": "package",
                              "id": "sku-200",
                              "label": "Part B"
                            }
                          ]
                        },
                        {
                          "tree": [
                            {
                              "name": "Warehouse 01",
                              "children": [
                                {
                                  "name": "Aisle A",
                                  "path": "/wh01/a",
                                  "type": "folder",
                                  "children": [
                                    {
                                      "name": "Bin A-01",
                                      "path": "/wh01/a/01",
                                      "type": "file"
                                    },
                                    {
                                      "type": "file",
                                      "path": "/wh01/a/02",
                                      "name": "Bin A-02"
                                    }
                                  ]
                                },
                                {
                                  "name": "Aisle B",
                                  "children": [
                                    {
                                      "name": "Bin B-01",
                                      "type": "file",
                                      "path": "/wh01/b/01"
                                    }
                                  ],
                                  "type": "folder",
                                  "path": "/wh01/b"
                                }
                              ],
                              "path": "/wh01",
                              "type": "folder"
                            }
                          ],
                          "indent": 16.0,
                          "type": "file-tree"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Code",
                              "name": "code"
                            },
                            {
                              "label": "Name",
                              "variant": "caption",
                              "name": "name"
                            },
                            {
                              "variant": "badge",
                              "label": "Type",
                              "name": "type"
                            },
                            {
                              "name": "totalSkus",
                              "variant": "caption",
                              "label": "SKUs"
                            },
                            {
                              "label": "Active",
                              "variant": "badge",
                              "name": "isActive"
                            }
                          ],
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "OPEN_WAREHOUSE",
                              "label": "Open",
                              "variant": "primary",
                              "icon": "arrow-right"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WarehouseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "OPEN_WAREHOUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Opened location",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "failure": "WarehouseLoadFailed",
                        "success": "WarehouseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Locations"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WarehousePage",
          "path": "/warehouses",
          "traits": [
            {
              "ref": "WarehouseDirectory"
            }
          ]
        }
      ]
    }
  ]
}