{
  "name": "std-segment",
  "version": "1.0.0",
  "description": "std-segment — contact segment primitive. Defines a filter criteria for grouping contacts (e.g. 'new signups in last 30 days'). Used by marketing campaigns for targeting.",
  "orbitals": [
    {
      "name": "SegmentOrbital",
      "entity": {
        "name": "Segment",
        "collection": "segments",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "criteria",
            "type": "string",
            "default": ""
          },
          {
            "name": "memberCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastUpdated",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SegmentSegment",
          "category": "interaction",
          "linkedEntity": "Segment",
          "emits": [
            {
              "event": "RECALCULATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SegmentLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Segment]"
                }
              ]
            },
            {
              "event": "SegmentLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SegmentRecalculated",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "memberCount",
                  "type": "number"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "calculating"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SegmentLoaded",
                "name": "Segment loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Segment]"
                  }
                ]
              },
              {
                "key": "SegmentLoadFailed",
                "name": "Segment load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RECALCULATE",
                "name": "Recalculate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SegmentRecalculated",
                "name": "Segment recalculated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "memberCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "failure": "SegmentLoadFailed",
                        "success": "SegmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading segments…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SegmentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "opacity": 0.12,
                          "type": "geometric-pattern",
                          "variant": "khatam"
                        },
                        {
                          "type": "edge-decoration",
                          "side": "left",
                          "opacity": 0.2
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "gradient-divider",
                          "color": "primary"
                        },
                        {
                          "type": "tag-cloud",
                          "tags": [
                            {
                              "label": "New Signups"
                            },
                            {
                              "label": "High Value"
                            },
                            {
                              "label": "Churn Risk"
                            },
                            {
                              "label": "Active 30d"
                            },
                            {
                              "label": "Dormant"
                            },
                            {
                              "label": "VIP"
                            },
                            {
                              "label": "Trial"
                            },
                            {
                              "label": "Enterprise"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "name": "description",
                              "label": "Description",
                              "variant": "caption"
                            },
                            {
                              "name": "memberCount",
                              "variant": "badge",
                              "label": "Members"
                            },
                            {
                              "variant": "caption",
                              "label": "Updated",
                              "name": "lastUpdated"
                            }
                          ],
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Recalculate",
                              "event": "RECALCULATE",
                              "variant": "ghost"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SegmentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "calculating",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Recalculating segment…"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "calculating",
                "to": "browsing",
                "event": "SegmentRecalculated",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Segment recalculated"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "success": "SegmentLoaded",
                        "failure": "SegmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Segments"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SegmentPage",
          "path": "/segments",
          "traits": [
            {
              "ref": "SegmentSegment"
            }
          ]
        }
      ]
    }
  ]
}
