{
  "name": "std-segment",
  "version": "1.2.0",
  "description": "std-segment — contact segment primitive grouping contacts by criteria with Recalculate action. Exposes CRM-pattern knobs (health-score threshold, reminder cadence, archive policy, consent).",
  "orbitals": [
    {
      "name": "SegmentOrbital",
      "entity": {
        "name": "Segment",
        "collection": "segments",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "criteria",
            "type": "string",
            "default": ""
          },
          {
            "name": "memberCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastUpdated",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SegmentSegment",
          "category": "interaction",
          "linkedEntity": "Segment",
          "emits": [
            {
              "event": "OPEN_SEGMENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.criteria",
                  "type": "string"
                },
                {
                  "name": "row.memberCount",
                  "type": "number"
                },
                {
                  "name": "row.lastUpdated",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "RECALCULATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SegmentLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Segment]"
                }
              ]
            },
            {
              "event": "SegmentLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SegmentLoaded",
                "name": "Segment loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Segment]"
                  }
                ]
              },
              {
                "key": "SegmentLoadFailed",
                "name": "Segment load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_SEGMENT",
                "name": "Open Segment",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Segment"
                  }
                ]
              },
              {
                "key": "RECALCULATE",
                "name": "Recalculate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "success": "SegmentLoaded",
                        "failure": "SegmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading segments…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SegmentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "icon": "users",
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total segments"
                            },
                            {
                              "label": "Active members",
                              "value": "12,480",
                              "icon": "user-check",
                              "type": "stat-display"
                            },
                            {
                              "icon": "bar-chart",
                              "type": "stat-display",
                              "label": "Avg size",
                              "value": "1,560"
                            },
                            {
                              "type": "stat-display",
                              "label": "Updated 24h",
                              "value": "8",
                              "icon": "refresh-cw"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "cols": 1.0
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SegmentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_SEGMENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.criteria",
                    "@payload.row.criteria"
                  ],
                  [
                    "set",
                    "@entity.memberCount",
                    "@payload.row.memberCount"
                  ],
                  [
                    "set",
                    "@entity.lastUpdated",
                    "@payload.row.lastUpdated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.memberCount",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Description",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.description",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Criteria",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.criteria"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "users",
                              "type": "stat-display",
                              "value": "@entity.memberCount",
                              "label": "Members"
                            },
                            {
                              "icon": "calendar",
                              "label": "Last updated",
                              "value": "@entity.lastUpdated",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Recalculate",
                              "action": "RECALCULATE",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary"
                            }
                          ],
                          "align": "center"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "failure": "SegmentLoadFailed",
                        "success": "SegmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Recalculating segment…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "success": "SegmentLoaded",
                        "failure": "SegmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading segments…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "failure": "SegmentLoadFailed",
                        "success": "SegmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Recalculating segment…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Segment",
                    {
                      "emit": {
                        "success": "SegmentLoaded",
                        "failure": "SegmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Segments",
              "label": "Section title",
              "description": "Heading shown above the segment list",
              "tier": "presentation"
            },
            "archiveInactiveAfterDays": {
              "type": "number",
              "default": 365.0,
              "label": "Archive inactive after (days)",
              "description": "Days a segment may go unrecalculated before being archived. Declarative; wire via sibling std-lifecycle.",
              "tier": "domain"
            },
            "consentTrackingEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Track consent",
              "description": "Whether membership in this segment honors recorded consent. Declarative.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_SEGMENT"
                },
                {
                  "event": "RECALCULATE",
                  "variant": "danger",
                  "label": "Recalculate"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each segment row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Name",
                  "variant": "caption",
                  "name": "name"
                },
                {
                  "name": "description",
                  "variant": "caption",
                  "label": "Description"
                },
                {
                  "name": "memberCount",
                  "label": "Members",
                  "variant": "badge"
                },
                {
                  "label": "Updated",
                  "name": "lastUpdated",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Segment entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "healthScoreThresholdAlert": {
              "type": "number",
              "default": 50.0,
              "label": "Health score threshold",
              "description": "Trigger alert when segment-average health score drops below this. Declarative; wire via sibling std-notify.",
              "tier": "domain"
            },
            "renewalReminderDaysBefore": {
              "type": "[number]",
              "default": [
                30.0,
                7.0
              ],
              "label": "Reminder cadence (days)",
              "description": "Days ahead of any segment-wide deadline to send reminders. Declarative; wire via sibling std-reminder-scheduler.",
              "tier": "domain",
              "items": {
                "type": "number"
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SegmentPage",
          "path": "/segments",
          "traits": [
            {
              "ref": "SegmentSegment"
            }
          ]
        }
      ]
    }
  ]
}