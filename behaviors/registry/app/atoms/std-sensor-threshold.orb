{
  "name": "std-sensor-threshold",
  "version": "1.0.0",
  "description": "std-sensor-threshold — sensor alert bands with dwell/hysteresis; sibling to std-telematics-event for IoT monitoring.",
  "orbitals": [
    {
      "name": "SensorThresholdOrbital",
      "entity": {
        "name": "SensorThreshold",
        "collection": "sensor_thresholds",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sensorId",
            "type": "string",
            "required": true
          },
          {
            "name": "metric",
            "type": "string",
            "default": ""
          },
          {
            "name": "warningLow",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "warningHigh",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "criticalLow",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "criticalHigh",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "muted",
              "archived"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "SensorThresholdManage",
          "category": "interaction",
          "linkedEntity": "SensorThreshold",
          "emits": [
            {
              "event": "OPEN_THRESHOLD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sensorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.metric",
                  "type": "string"
                },
                {
                  "name": "row.warningLow",
                  "type": "number"
                },
                {
                  "name": "row.warningHigh",
                  "type": "number"
                },
                {
                  "name": "row.criticalLow",
                  "type": "number"
                },
                {
                  "name": "row.criticalHigh",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "MUTE_THRESHOLD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sensorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.metric",
                  "type": "string"
                },
                {
                  "name": "row.warningLow",
                  "type": "number"
                },
                {
                  "name": "row.warningHigh",
                  "type": "number"
                },
                {
                  "name": "row.criticalLow",
                  "type": "number"
                },
                {
                  "name": "row.criticalHigh",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARCHIVE_THRESHOLD",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sensorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.metric",
                  "type": "string"
                },
                {
                  "name": "row.warningLow",
                  "type": "number"
                },
                {
                  "name": "row.warningHigh",
                  "type": "number"
                },
                {
                  "name": "row.criticalLow",
                  "type": "number"
                },
                {
                  "name": "row.criticalHigh",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SensorThresholdLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[SensorThreshold]"
                }
              ]
            },
            {
              "event": "SensorThresholdLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SensorThresholdLoaded",
                "name": "SensorThreshold loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SensorThreshold]"
                  }
                ]
              },
              {
                "key": "SensorThresholdLoadFailed",
                "name": "SensorThreshold load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_THRESHOLD",
                "name": "Open Threshold",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "SensorThreshold"
                  }
                ]
              },
              {
                "key": "MUTE_THRESHOLD",
                "name": "Mute Threshold",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ARCHIVE_THRESHOLD",
                "name": "Archive Threshold",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SensorThreshold",
                    {
                      "emit": {
                        "success": "SensorThresholdLoaded",
                        "failure": "SensorThresholdLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading thresholds…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SensorThresholdLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total thresholds",
                              "value": "@payload.data.length",
                              "icon": "activity"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Active",
                              "value": "42",
                              "type": "stat-display"
                            },
                            {
                              "label": "Muted",
                              "value": "3",
                              "type": "stat-display",
                              "icon": "bell-off"
                            },
                            {
                              "label": "Firing now",
                              "value": "1",
                              "type": "stat-display",
                              "icon": "alert-triangle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "gap": "sm",
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SensorThresholdLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_THRESHOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.sensorId",
                    "@payload.row.sensorId"
                  ],
                  [
                    "set",
                    "@entity.metric",
                    "@payload.row.metric"
                  ],
                  [
                    "set",
                    "@entity.warningLow",
                    "@payload.row.warningLow"
                  ],
                  [
                    "set",
                    "@entity.warningHigh",
                    "@payload.row.warningHigh"
                  ],
                  [
                    "set",
                    "@entity.criticalLow",
                    "@payload.row.criticalLow"
                  ],
                  [
                    "set",
                    "@entity.criticalHigh",
                    "@payload.row.criticalHigh"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.sensorId"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Metric",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.metric"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Warn high"
                                },
                                {
                                  "content": "@entity.warningHigh",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Crit high"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.criticalHigh"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "variant": "secondary",
                              "type": "button",
                              "action": "MUTE_THRESHOLD",
                              "label": "Mute",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "variant": "danger",
                              "action": "ARCHIVE_THRESHOLD",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Archive"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MUTE_THRESHOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "SensorThreshold",
                    {
                      "emit": {
                        "success": "SensorThresholdLoaded",
                        "failure": "SensorThresholdLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Muting threshold…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "SensorThreshold",
                    {
                      "emit": {
                        "failure": "SensorThresholdLoadFailed",
                        "success": "SensorThresholdLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading thresholds…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MUTE_THRESHOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "SensorThreshold",
                    {
                      "emit": {
                        "success": "SensorThresholdLoaded",
                        "failure": "SensorThresholdLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Muting threshold…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE_THRESHOLD",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "SensorThreshold",
                    {
                      "emit": {
                        "success": "SensorThresholdLoaded",
                        "failure": "SensorThresholdLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Archiving threshold…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SensorThreshold",
                    {
                      "emit": {
                        "success": "SensorThresholdLoaded",
                        "failure": "SensorThresholdLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "hysteresisPct": {
              "type": "number",
              "default": 5.0,
              "label": "Hysteresis (%)",
              "description": "Percentage the value must drop below the band before reset (prevents flapping).",
              "synonyms": "deadband, recovery margin",
              "tier": "domain"
            },
            "dwellTimeSeconds": {
              "type": "number",
              "default": 30.0,
              "label": "Dwell time (seconds)",
              "description": "Seconds the metric must remain outside the band before an alert fires (debounce).",
              "synonyms": "debounce window, sustain time",
              "tier": "domain"
            },
            "escalationRoles": {
              "type": "[string]",
              "default": [
                "oncall-l1",
                "oncall-l2"
              ],
              "label": "Escalation roles",
              "description": "Roles paged on critical-band alerts. Compose std-notify-on-event for delivery.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "sensorId",
                  "label": "Sensor"
                },
                {
                  "name": "metric",
                  "label": "Metric",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "warningHigh",
                  "label": "Warn"
                },
                {
                  "variant": "caption",
                  "name": "criticalHigh",
                  "label": "Crit"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Sensor Threshold entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_THRESHOLD",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "event": "MUTE_THRESHOLD",
                  "variant": "secondary",
                  "label": "Mute"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each threshold row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "thresholdBands": {
              "type": "[ThresholdBand]",
              "default": [
                {
                  "low": 0.0,
                  "high": 70.0,
                  "band": "warning"
                },
                {
                  "high": 100.0,
                  "low": 70.0,
                  "band": "critical"
                }
              ],
              "label": "Threshold bands",
              "description": "Alert bands per metric; values outside [low, high] for each band fire alerts of that severity.",
              "synonyms": "alert bands, alarm zones",
              "tier": "domain",
              "items": {
                "type": "object",
                "properties": {
                  "low": {
                    "name": "low",
                    "type": "number",
                    "required": true
                  },
                  "high": {
                    "name": "high",
                    "type": "number",
                    "required": true
                  },
                  "band": {
                    "name": "band",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Sensor Thresholds",
              "label": "Section title",
              "description": "Heading shown above the sensor thresholds list",
              "tier": "presentation"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SensorThresholdPage",
          "path": "/sensor-thresholds",
          "traits": [
            {
              "ref": "SensorThresholdManage"
            }
          ]
        }
      ]
    }
  ]
}