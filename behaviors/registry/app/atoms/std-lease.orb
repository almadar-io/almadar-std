{
  "name": "std-lease",
  "version": "1.1.0",
  "description": "std-lease — owner-side lease records that tie tenants to property units with dates, monthly rent, and lifecycle status (pending/active/expired/terminated). Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "LeaseOrbital",
      "entity": {
        "name": "Lease",
        "collection": "leases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "unitId",
            "type": "string",
            "default": ""
          },
          {
            "name": "unitLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "endDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "monthlyRent",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "active",
              "expired",
              "terminated",
              "pending"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "LeaseManager",
          "category": "interaction",
          "linkedEntity": "Lease",
          "emits": [
            {
              "event": "OPEN_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantName",
                  "type": "string"
                },
                {
                  "name": "row.unitId",
                  "type": "string"
                },
                {
                  "name": "row.unitLabel",
                  "type": "string"
                },
                {
                  "name": "row.startDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.endDate",
                  "type": "string"
                },
                {
                  "name": "row.monthlyRent",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "RENEW_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TERMINATE_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "LeaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Lease]"
                }
              ]
            },
            {
              "event": "LeaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LeaseLoaded",
                "name": "Lease loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Lease]"
                  }
                ]
              },
              {
                "key": "LeaseLoadFailed",
                "name": "Lease load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_LEASE",
                "name": "Open Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Lease"
                  }
                ]
              },
              {
                "key": "TERMINATE_LEASE",
                "name": "Terminate Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "RENEW_LEASE",
                "name": "Renew Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "failure": "LeaseLoadFailed",
                        "success": "LeaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading leases…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LeaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "label": "Total leases",
                              "icon": "file-text"
                            },
                            {
                              "type": "stat-display",
                              "icon": "check-circle",
                              "value": "86",
                              "label": "Active"
                            },
                            {
                              "value": "11",
                              "type": "stat-display",
                              "icon": "alert-triangle",
                              "label": "Expiring 60d"
                            },
                            {
                              "label": "Monthly revenue",
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "value": "$184,200"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LeaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.tenantId",
                    "@payload.row.tenantId"
                  ],
                  [
                    "set",
                    "@entity.tenantName",
                    "@payload.row.tenantName"
                  ],
                  [
                    "set",
                    "@entity.unitId",
                    "@payload.row.unitId"
                  ],
                  [
                    "set",
                    "@entity.unitLabel",
                    "@payload.row.unitLabel"
                  ],
                  [
                    "set",
                    "@entity.startDate",
                    "@payload.row.startDate"
                  ],
                  [
                    "set",
                    "@entity.endDate",
                    "@payload.row.endDate"
                  ],
                  [
                    "set",
                    "@entity.monthlyRent",
                    "@payload.row.monthlyRent"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Back",
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.tenantName",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "variant": "default",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Unit",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.unitLabel"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Tenant ID",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.tenantId"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Notes",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.notes",
                                  "variant": "body"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "label": "Monthly rent",
                              "value": "@entity.monthlyRent",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.startDate",
                              "label": "Start",
                              "type": "stat-display",
                              "icon": "calendar"
                            },
                            {
                              "value": "@entity.endDate",
                              "label": "End",
                              "type": "stat-display",
                              "icon": "calendar-x"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "RENEW_LEASE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Renew Lease"
                            },
                            {
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Terminate",
                              "type": "button",
                              "action": "TERMINATE_LEASE"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TERMINATE_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Terminating lease…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "failure": "LeaseLoadFailed",
                        "success": "LeaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading leases…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RENEW_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Renewing lease…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TERMINATE_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Terminating lease…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Tenant",
                  "variant": "caption",
                  "name": "tenantName"
                },
                {
                  "variant": "caption",
                  "label": "Unit",
                  "name": "unitLabel"
                },
                {
                  "variant": "caption",
                  "name": "startDate",
                  "label": "Start"
                },
                {
                  "name": "endDate",
                  "label": "End",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "monthlyRent",
                  "label": "Monthly Rent"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Lease entity",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_LEASE",
                  "variant": "primary",
                  "icon": "arrow-right"
                },
                {
                  "label": "Terminate",
                  "event": "TERMINATE_LEASE",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each lease row",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Leases",
              "label": "Section title",
              "description": "Heading shown above the lease list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LeasePage",
          "path": "/leases",
          "traits": [
            {
              "ref": "LeaseManager"
            }
          ]
        }
      ]
    }
  ]
}