{
  "name": "std-lease",
  "version": "1.0.0",
  "description": "std-lease — owner-side lease records that tie tenants to property units with dates, monthly rent, and lifecycle status (pending/active/expired/terminated).",
  "orbitals": [
    {
      "name": "LeaseOrbital",
      "entity": {
        "name": "Lease",
        "collection": "leases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "unitId",
            "type": "string",
            "default": ""
          },
          {
            "name": "unitLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "endDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "monthlyRent",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "active",
              "expired",
              "terminated",
              "pending"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "LeaseManager",
          "category": "interaction",
          "linkedEntity": "Lease",
          "emits": [
            {
              "event": "RENEW_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TERMINATE_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "LeaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Lease]"
                }
              ]
            },
            {
              "event": "LeaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LeaseLoaded",
                "name": "Lease loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Lease]"
                  }
                ]
              },
              {
                "key": "LeaseLoadFailed",
                "name": "Lease load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RENEW_LEASE",
                "name": "Renew Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TERMINATE_LEASE",
                "name": "Terminate Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading leases…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LeaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "geometric-pattern",
                          "color": "primary",
                          "variant": "star8",
                          "opacity": 0.05,
                          "mode": "background"
                        },
                        {
                          "type": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-text"
                                },
                                {
                                  "type": "typography",
                                  "content": "@config.title",
                                  "variant": "h3"
                                },
                                {
                                  "type": "badge",
                                  "label": "Active",
                                  "variant": "success"
                                }
                              ],
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "lg",
                          "type": "split",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "items": [
                                    {
                                      "title": "Lease Term",
                                      "id": "term",
                                      "content": "Start to end dates, renewal options, notice period."
                                    },
                                    {
                                      "title": "Rent & Fees",
                                      "content": "Monthly rent, security deposit, late fees.",
                                      "id": "rent"
                                    },
                                    {
                                      "content": "Tenant responsibilities, owner obligations, restrictions.",
                                      "id": "terms",
                                      "title": "Terms & Conditions"
                                    }
                                  ],
                                  "type": "accordion"
                                },
                                {
                                  "selected": "current",
                                  "type": "date-range-selector",
                                  "options": [
                                    {
                                      "label": "Current Term",
                                      "value": "current"
                                    },
                                    {
                                      "label": "Renewal Period",
                                      "value": "next"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "direction": "vertical",
                              "gap": "md",
                              "children": [
                                {
                                  "title": "Property photos",
                                  "columns": 2.0,
                                  "type": "media-gallery",
                                  "items": [
                                    {
                                      "id": "Property",
                                      "src": "https://picsum.photos/seed/lease1/800/600",
                                      "type": "image",
                                      "alt": "Property"
                                    },
                                    {
                                      "alt": "Property",
                                      "id": "Property",
                                      "type": "image",
                                      "src": "https://picsum.photos/seed/lease2/800/600"
                                    },
                                    {
                                      "alt": "Property",
                                      "id": "Property",
                                      "type": "image",
                                      "src": "https://picsum.photos/seed/lease3/800/600"
                                    },
                                    {
                                      "id": "Property",
                                      "src": "https://picsum.photos/seed/lease4/800/600",
                                      "alt": "Property",
                                      "type": "image"
                                    }
                                  ]
                                },
                                {
                                  "showArrows": true,
                                  "showDots": true,
                                  "type": "carousel",
                                  "items": [
                                    {
                                      "alt": "Photo 1",
                                      "src": "https://picsum.photos/seed/lease1/1200/800"
                                    },
                                    {
                                      "src": "https://picsum.photos/seed/lease2/1200/800",
                                      "alt": "Photo 2"
                                    },
                                    {
                                      "src": "https://picsum.photos/seed/lease3/1200/800",
                                      "alt": "Photo 3"
                                    }
                                  ]
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "ratio": "1:1"
                        },
                        {
                          "currentIndex": 0.0,
                          "type": "lightbox",
                          "showCounter": true,
                          "images": [
                            {
                              "src": "https://picsum.photos/seed/lease1/1200/800",
                              "alt": "Property",
                              "caption": "Property"
                            }
                          ],
                          "isOpen": false
                        },
                        {
                          "itemActions": [
                            {
                              "event": "RENEW_LEASE",
                              "variant": "primary",
                              "label": "Renew"
                            },
                            {
                              "variant": "danger",
                              "event": "TERMINATE_LEASE",
                              "label": "Terminate"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "tenantName",
                              "label": "Tenant"
                            },
                            {
                              "label": "Unit",
                              "name": "unitLabel",
                              "variant": "caption"
                            },
                            {
                              "name": "startDate",
                              "label": "Start",
                              "variant": "caption"
                            },
                            {
                              "name": "endDate",
                              "label": "End",
                              "variant": "caption"
                            },
                            {
                              "name": "monthlyRent",
                              "variant": "caption",
                              "label": "Monthly Rent"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LeaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RENEW_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Lease renewal requested",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TERMINATE_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Lease termination requested",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "failure": "LeaseLoadFailed",
                        "success": "LeaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Leases"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LeasePage",
          "path": "/leases",
          "traits": [
            {
              "ref": "LeaseManager"
            }
          ]
        }
      ]
    }
  ]
}
