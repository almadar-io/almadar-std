{
  "name": "std-maintenance-request",
  "version": "1.0.0",
  "description": "std-maintenance-request — tenant-submitted request lifecycle (open → scheduled → in_progress → completed). Request-flow primitive (distinct from work-order's dispatch-flow).",
  "orbitals": [
    {
      "name": "MaintenanceRequestOrbital",
      "entity": {
        "name": "MaintenanceRequest",
        "collection": "maintenancerequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "unitId",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "default": ""
          },
          {
            "name": "requesterName",
            "type": "string",
            "default": ""
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "urgent"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "scheduled",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MaintenanceRequestQueue",
          "category": "interaction",
          "linkedEntity": "MaintenanceRequest",
          "emits": [
            {
              "event": "SCHEDULE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "scheduledAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPLETE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "completedAt",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MaintenanceRequest]"
                }
              ]
            },
            {
              "event": "MaintenanceRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MaintenanceRequestLoaded",
                "name": "MaintenanceRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MaintenanceRequest]"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestLoadFailed",
                "name": "MaintenanceRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SCHEDULE_REQUEST",
                "name": "Schedule Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "scheduledAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "COMPLETE_REQUEST",
                "name": "Complete Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "completedAt",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "CANCEL_REQUEST",
                "name": "Cancel Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestUpdated",
                "name": "MaintenanceRequest updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestUpdateFailed",
                "name": "MaintenanceRequest update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading maintenance requests…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MaintenanceRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "justify": "between",
                          "direction": "horizontal",
                          "children": [
                            {
                              "align": "center",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "wrench",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h3",
                                  "content": "@config.title"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "popover",
                              "content": {
                                "children": [
                                  {
                                    "content": "Quick filters",
                                    "type": "typography",
                                    "variant": "caption"
                                  },
                                  {
                                    "type": "button",
                                    "action": "INIT",
                                    "label": "Refresh",
                                    "variant": "ghost"
                                  }
                                ],
                                "type": "stack",
                                "direction": "vertical",
                                "gap": "sm"
                              },
                              "position": "bottom",
                              "trigger": "click",
                              "children": {
                                "type": "button",
                                "action": "INIT",
                                "variant": "secondary",
                                "label": "Filters",
                                "icon": "filter"
                              }
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "rightActions": [
                            {
                              "event": "CANCEL_REQUEST",
                              "variant": "danger",
                              "label": "Cancel"
                            }
                          ],
                          "threshold": 80.0,
                          "children": {
                            "type": "stack",
                            "direction": "horizontal",
                            "align": "center",
                            "children": [
                              {
                                "type": "icon",
                                "name": "wrench"
                              },
                              {
                                "type": "typography",
                                "content": "Swipe a request row for quick actions",
                                "variant": "body"
                              }
                            ],
                            "gap": "md"
                          },
                          "leftActions": [
                            {
                              "label": "Schedule",
                              "event": "SCHEDULE_REQUEST",
                              "variant": "primary"
                            }
                          ],
                          "type": "swipeable-row"
                        },
                        {
                          "fields": [
                            {
                              "label": "Unit",
                              "variant": "caption",
                              "name": "unitId"
                            },
                            {
                              "variant": "caption",
                              "label": "Requester",
                              "name": "requesterName"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "name": "priority",
                              "variant": "badge",
                              "label": "Priority"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "name": "requestedAt",
                              "label": "Requested",
                              "variant": "caption"
                            }
                          ],
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "label": "Schedule",
                              "event": "SCHEDULE_REQUEST",
                              "icon": "calendar",
                              "variant": "primary"
                            },
                            {
                              "label": "Complete",
                              "event": "COMPLETE_REQUEST",
                              "variant": "primary",
                              "icon": "check"
                            },
                            {
                              "icon": "x",
                              "label": "Cancel",
                              "variant": "danger",
                              "event": "CANCEL_REQUEST"
                            }
                          ]
                        },
                        {
                          "action": "INIT",
                          "type": "floating-action-button",
                          "icon": "plus"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MaintenanceRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SCHEDULE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "scheduled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestUpdateFailed",
                        "success": "MaintenanceRequestUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "COMPLETE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.completedAt",
                    "@payload.completedAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "MaintenanceRequestUpdated",
                        "failure": "MaintenanceRequestUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "MaintenanceRequestUpdated",
                        "failure": "MaintenanceRequestUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MaintenanceRequestUpdated",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "success": "MaintenanceRequestLoaded",
                        "failure": "MaintenanceRequestLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MaintenanceRequestUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "success": "MaintenanceRequestLoaded",
                        "failure": "MaintenanceRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Maintenance Requests"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MaintenanceRequestPage",
          "path": "/maintenance",
          "traits": [
            {
              "ref": "MaintenanceRequestQueue"
            }
          ]
        }
      ]
    }
  ]
}
