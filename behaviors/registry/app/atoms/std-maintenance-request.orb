{
  "name": "std-maintenance-request",
  "version": "1.2.0",
  "description": "std-maintenance-request — tenant request lifecycle. Listens for SET_STATUS so std-lifecycle can auto-escalate. Exposes Scheduling + Service knobs (bookingWindowDays, responseTimeMinutes, resolutionSLAHours, …).",
  "orbitals": [
    {
      "name": "MaintenanceRequestOrbital",
      "entity": {
        "name": "MaintenanceRequest",
        "collection": "maintenancerequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "unitId",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "default": ""
          },
          {
            "name": "requesterName",
            "type": "string",
            "default": ""
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "urgent"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "scheduled",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MaintenanceRequestQueue",
          "category": "interaction",
          "linkedEntity": "MaintenanceRequest",
          "emits": [
            {
              "event": "OPEN_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SCHEDULE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "scheduledAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPLETE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "completedAt",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MaintenanceRequest]"
                }
              ]
            },
            {
              "event": "MaintenanceRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MaintenanceRequestLoaded",
                "name": "MaintenanceRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MaintenanceRequest]"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestLoadFailed",
                "name": "MaintenanceRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_REQUEST",
                "name": "Open Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "CANCEL_REQUEST",
                "name": "Cancel Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestUpdated",
                "name": "MaintenanceRequest updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestUpdateFailed",
                "name": "MaintenanceRequest update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SCHEDULE_REQUEST",
                "name": "Schedule Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "scheduledAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "COMPLETE_REQUEST",
                "name": "Complete Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "completedAt",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading maintenance requests…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MaintenanceRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "wrench",
                              "label": "Open requests"
                            },
                            {
                              "value": "5",
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "Urgent"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Scheduled",
                              "value": "18"
                            },
                            {
                              "label": "Avg resolve (hr)",
                              "icon": "clock",
                              "value": "32",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MaintenanceRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.unitId",
                    "@payload.row.unitId"
                  ],
                  [
                    "set",
                    "@entity.tenantId",
                    "@payload.row.tenantId"
                  ],
                  [
                    "set",
                    "@entity.requesterName",
                    "@payload.row.requesterName"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.row.priority"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.assignedTo",
                    "@payload.row.assignedTo"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "@payload.row.requestedAt"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.row.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.completedAt",
                    "@payload.row.completedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.unitId"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.priority"
                            },
                            {
                              "variant": "default",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Requester"
                                },
                                {
                                  "content": "@entity.requesterName",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Description"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.description"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Assigned to",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.assignedTo",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Notes",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.requestedAt",
                              "type": "stat-display",
                              "icon": "calendar",
                              "label": "Requested"
                            },
                            {
                              "label": "Scheduled",
                              "icon": "calendar-clock",
                              "value": "@entity.scheduledAt",
                              "type": "stat-display"
                            },
                            {
                              "icon": "calendar-check",
                              "value": "@entity.completedAt",
                              "label": "Completed",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "SCHEDULE_REQUEST",
                              "actionPayload": {
                                "id": "@entity.id",
                                "scheduledAt": "now"
                              },
                              "label": "Schedule"
                            },
                            {
                              "action": "COMPLETE_REQUEST",
                              "variant": "primary",
                              "type": "button",
                              "actionPayload": {
                                "completedAt": "now",
                                "id": "@entity.id"
                              },
                              "label": "Complete"
                            },
                            {
                              "label": "Cancel",
                              "variant": "danger",
                              "action": "CANCEL_REQUEST",
                              "type": "button",
                              "actionPayload": {
                                "notes": "cancelled by user",
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestUpdateFailed",
                        "success": "MaintenanceRequestUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling request…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MaintenanceRequestUpdated",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MaintenanceRequestUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestUpdateFailed",
                        "success": "MaintenanceRequestUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating request status…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading maintenance requests…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SCHEDULE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "scheduled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestUpdateFailed",
                        "success": "MaintenanceRequestUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Scheduling request…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "COMPLETE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.completedAt",
                    "@payload.completedAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "MaintenanceRequestUpdated",
                        "failure": "MaintenanceRequestUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Completing request…",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "MaintenanceRequestUpdated",
                        "failure": "MaintenanceRequestUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Cancelling request…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "responseTimeMinutes": {
              "type": "number",
              "default": 240.0,
              "label": "Response time SLA (min)",
              "description": "Target time from request open to first acknowledgement.",
              "tier": "domain"
            },
            "customerVisibleStatuses": {
              "type": "[string]",
              "default": [
                "scheduled",
                "in_progress",
                "completed"
              ],
              "label": "Customer-visible statuses",
              "description": "Subset of statuses tenants see in their portal. Internal statuses are filtered.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_REQUEST",
                  "icon": "arrow-right",
                  "variant": "primary"
                },
                {
                  "icon": "x",
                  "variant": "danger",
                  "label": "Cancel",
                  "event": "CANCEL_REQUEST"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each request row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "resolutionSLAHours": {
              "type": "number",
              "default": 48.0,
              "label": "Resolution SLA (hours)",
              "description": "Target time from request open to completed. Compose std-lifecycle to auto-escalate.",
              "tier": "domain"
            },
            "leadTimeMinutes": {
              "type": "number",
              "default": 120.0,
              "label": "Lead time (minutes)",
              "description": "Minimum minutes before scheduledAt that a new visit can be booked.",
              "tier": "domain"
            },
            "blackoutDates": {
              "type": "[string]",
              "default": [],
              "label": "Blackout dates",
              "description": "ISO dates blocked from scheduling. Compose std-lifecycle to enforce.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "requirePhotoOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require photo on complete",
              "description": "Block COMPLETE_REQUEST unless a completion photo is attached.",
              "tier": "domain"
            },
            "skillsRequired": {
              "type": "[string]",
              "default": [],
              "label": "Required skills",
              "description": "Capability tags a tech must have (e.g. 'plumbing', 'electrical', 'hvac').",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 12.0,
              "label": "Reschedule window (hours)",
              "description": "Hours before scheduledAt during which the tenant can self-reschedule.",
              "tier": "domain"
            },
            "noShowGracePeriodMinutes": {
              "type": "number",
              "default": 30.0,
              "label": "No-show grace (minutes)",
              "description": "Minutes after scheduledAt before the request flags no_show. Wire via std-lifecycle.",
              "tier": "domain"
            },
            "cancellationPolicy": {
              "type": "string",
              "default": "free",
              "label": "Cancellation policy",
              "description": "Fee treatment when a visit is cancelled inside the reschedule window.",
              "tier": "domain",
              "values": [
                "free",
                "partial-refund",
                "no-refund"
              ]
            },
            "bookingHours": {
              "type": "string",
              "default": "08:00-18:00",
              "label": "Booking hours",
              "description": "Daily window during which maintenance visits can be scheduled (HH:MM-HH:MM).",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "unitId",
                  "label": "Unit"
                },
                {
                  "variant": "caption",
                  "name": "requesterName",
                  "label": "Requester"
                },
                {
                  "variant": "caption",
                  "name": "description",
                  "label": "Description"
                },
                {
                  "variant": "badge",
                  "name": "priority",
                  "label": "Priority"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                },
                {
                  "label": "Requested",
                  "name": "requestedAt",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Maintenance Request entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Maintenance Requests",
              "label": "Section title",
              "description": "Heading shown above the maintenance request queue",
              "tier": "presentation"
            },
            "bookingWindowDays": {
              "type": "number",
              "default": 30.0,
              "label": "Booking window (days)",
              "description": "How far in advance tenants can schedule maintenance visits.",
              "tier": "domain"
            },
            "serviceAreaRadius": {
              "type": "number",
              "default": 25.0,
              "label": "Service area radius (mi)",
              "description": "Maximum distance from the property hub for tech dispatch eligibility.",
              "tier": "domain"
            },
            "serviceZones": {
              "type": "[string]",
              "default": [],
              "label": "Service zones",
              "description": "Named geographic zones for dispatch grouping.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "maxReschedules": {
              "type": "number",
              "default": 2.0,
              "label": "Max reschedules",
              "description": "Hard cap on reschedule count per request.",
              "tier": "domain"
            },
            "escalationThresholdHours": {
              "type": "number",
              "default": 72.0,
              "label": "Escalation threshold (hours)",
              "description": "Hours after which an unresolved request auto-escalates. Compose std-lifecycle for wiring.",
              "tier": "domain"
            },
            "requireSignatureOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require tenant signature on complete",
              "description": "Block COMPLETE_REQUEST unless tenant signature is captured (compose std-signature-capture).",
              "tier": "domain"
            },
            "dispatchStrategy": {
              "type": "string",
              "default": "nearest",
              "label": "Dispatch strategy",
              "description": "How techs are assigned to a maintenance request.",
              "tier": "domain",
              "values": [
                "nearest",
                "round-robin",
                "manual"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MaintenanceRequestPage",
