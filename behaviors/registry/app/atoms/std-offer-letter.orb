{
  "name": "std-offer-letter",
  "version": "1.0.0",
  "description": "std-offer-letter — formal job offer primitive. Owns an OfferLetter entity (applicant, position, salary, start date, acceptance status). Browses offers in a data-grid with Send / Revoke actions.",
  "orbitals": [
    {
      "name": "OfferLetterOrbital",
      "entity": {
        "name": "OfferLetter",
        "collection": "offerletters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "position",
            "type": "string",
            "default": ""
          },
          {
            "name": "salary",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "startDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "accepted",
              "rejected",
              "expired"
            ]
          },
          {
            "name": "expiresAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "OfferLetterFlow",
          "category": "interaction",
          "linkedEntity": "OfferLetter",
          "emits": [
            {
              "event": "SEND_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVOKE_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "OfferLetterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[OfferLetter]"
                }
              ]
            },
            {
              "event": "OfferLetterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OfferLetterLoaded",
                "name": "OfferLetter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[OfferLetter]"
                  }
                ]
              },
              {
                "key": "OfferLetterLoadFailed",
                "name": "OfferLetter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEND_OFFER",
                "name": "Send Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVOKE_OFFER",
                "name": "Revoke Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading offer letters…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "OfferLetterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Send",
                              "variant": "primary",
                              "event": "SEND_OFFER"
                            },
                            {
                              "variant": "danger",
                              "label": "Revoke",
                              "event": "REVOKE_OFFER"
                            }
                          ],
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Applicant",
                              "name": "applicantName",
                              "variant": "caption"
                            },
                            {
                              "label": "Position",
                              "name": "position",
                              "variant": "caption"
                            },
                            {
                              "name": "salary",
                              "label": "Salary",
                              "variant": "caption"
                            },
                            {
                              "name": "startDate",
                              "label": "Start Date",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "OfferLetterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEND_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Offer sent",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REVOKE_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Offer revoked",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Offer Letters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "OfferLetterPage",
          "path": "/offers",
          "traits": [
            {
              "ref": "OfferLetterFlow"
            }
          ]
        }
      ]
    }
  ]
}
