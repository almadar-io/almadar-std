{
  "name": "std-offer-letter",
  "version": "1.2.0",
  "description": "std-offer-letter — formal job offer lifecycle. Listens for SET_STATUS so std-lifecycle can auto-expire offers past expiresAt. Exposes HR knobs (backgroundCheckRequired, eVerifyRequired, anonymizeOnRejection, …).",
  "orbitals": [
    {
      "name": "OfferLetterOrbital",
      "entity": {
        "name": "OfferLetter",
        "collection": "offerletters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "position",
            "type": "string",
            "default": ""
          },
          {
            "name": "salary",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "startDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "accepted",
              "rejected",
              "expired"
            ]
          },
          {
            "name": "expiresAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "OfferLetterFlow",
          "category": "interaction",
          "linkedEntity": "OfferLetter",
          "emits": [
            {
              "event": "OPEN_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string"
                },
                {
                  "name": "row.position",
                  "type": "string"
                },
                {
                  "name": "row.salary",
                  "type": "number"
                },
                {
                  "name": "row.startDate",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "SEND_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVOKE_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "OfferLetterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[OfferLetter]"
                }
              ]
            },
            {
              "event": "OfferLetterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OfferLetterLoaded",
                "name": "OfferLetter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[OfferLetter]"
                  }
                ]
              },
              {
                "key": "OfferLetterLoadFailed",
                "name": "OfferLetter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_OFFER",
                "name": "Open Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "OfferLetter"
                  }
                ]
              },
              {
                "key": "REVOKE_OFFER",
                "name": "Revoke Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "SEND_OFFER",
                "name": "Send Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading offer letters…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "OfferLetterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total offers",
                              "icon": "file-text"
                            },
                            {
                              "icon": "send",
                              "type": "stat-display",
                              "label": "Sent",
                              "value": "23"
                            },
                            {
                              "value": "14",
                              "type": "stat-display",
                              "label": "Accepted",
                              "icon": "check-circle"
                            },
                            {
                              "value": "61%",
                              "label": "Acceptance rate",
                              "icon": "trending-up",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "OfferLetterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.applicantId",
                    "@payload.row.applicantId"
                  ],
                  [
                    "set",
                    "@entity.applicantName",
                    "@payload.row.applicantName"
                  ],
                  [
                    "set",
                    "@entity.position",
                    "@payload.row.position"
                  ],
                  [
                    "set",
                    "@entity.salary",
                    "@payload.row.salary"
                  ],
                  [
                    "set",
                    "@entity.startDate",
                    "@payload.row.startDate"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.applicantName"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Position"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.position"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Applicant ID",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.applicantId"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Notes",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "icon": "dollar-sign",
                              "value": "@entity.salary",
                              "type": "stat-display",
                              "label": "Salary"
                            },
                            {
                              "type": "stat-display",
                              "icon": "calendar",
                              "value": "@entity.startDate",
                              "label": "Start date"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.expiresAt",
                              "label": "Expires",
                              "icon": "calendar-x"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "action": "SEND_OFFER",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "label": "Send Offer",
                              "variant": "primary"
                            },
                            {
                              "label": "Revoke",
                              "variant": "danger",
                              "action": "REVOKE_OFFER",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REVOKE_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Revoking offer…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "OfferLetter",
                    "@entity",
                    {
                      "emit": {
                        "failure": "OfferLetterLoadFailed",
                        "success": "OfferLetterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Updating offer status…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "failure": "OfferLetterLoadFailed",
                        "success": "OfferLetterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading offer letters…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SEND_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Sending offer…"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REVOKE_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Revoking offer…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "name": "applicantName",
                  "label": "Applicant"
                },
                {
                  "name": "position",
                  "variant": "caption",
                  "label": "Position"
                },
                {
                  "label": "Salary",
                  "name": "salary",
                  "variant": "caption"
                },
                {
                  "name": "startDate",
                  "label": "Start Date",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "name": "status",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Offer Letter entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "eVerifyRequired": {
              "type": "boolean",
              "default": false,
              "label": "E-Verify required",
              "description": "US I-9 / E-Verify gate. Block ACCEPT until verification passes.",
              "tier": "customization"
            },
            "i9DocumentsRequired": {
              "type": "boolean",
              "default": true,
              "label": "I-9 documents required",
              "description": "Require I-9 supporting documents at the accepted transition.",
              "tier": "customization"
            },
            "anonymizeOnRejection": {
              "type": "boolean",
              "default": false,
              "label": "Anonymize on rejection",
              "description": "When true, scrub applicant PII on rejected/revoked. Pair with std-data-erasure.",
              "tier": "customization"
            },
            "equalOpportunityTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Equal opportunity tracking",
              "description": "Capture demographic data separately for EEO reporting (sibling collection).",
              "tier": "advanced"
            },
            "retentionAfterRejectionDays": {
              "type": "number",
              "default": 1825.0,
              "label": "Retention after rejection (days)",
              "description": "Days to keep rejected/revoked offers. Default 1825 (5 years) covers most EEOC + IRS retention.",
              "tier": "advanced"
            },
            "title": {
              "type": "string",
              "default": "Offer Letters",
              "label": "Section title",
              "description": "Heading shown above the offer letters list",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "variant": "primary",
                  "event": "OPEN_OFFER",
                  "icon": "arrow-right"
                },
                {
                  "variant": "danger",
                  "label": "Revoke",
                  "event": "REVOKE_OFFER"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each offer row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "backgroundCheckRequired": {
              "type": "boolean",
              "default": true,
              "label": "Background check required",
              "description": "Block SEND_OFFER until a background check is on file.",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "OfferLetterPage",
          "path": "/offers",
          "traits": [
            {
              "ref": "OfferLetterFlow"
            }
          ]
        }
      ]
    }
  ]
}