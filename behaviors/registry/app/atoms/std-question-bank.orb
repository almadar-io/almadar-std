{
  "name": "std-question-bank",
  "version": "1.1.0",
  "description": "std-question-bank — typed question library for surveys. Lists questions in `browsing`; opens detail in `viewing_single` with Update / Delete actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "QuestionBankOrbital",
      "entity": {
        "name": "Question",
        "collection": "questions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "label",
            "type": "string",
            "required": true
          },
          {
            "name": "kind",
            "type": "string",
            "default": "text",
            "values": [
              "single",
              "multi",
              "text",
              "likert",
              "matrix",
              "number",
              "date"
            ]
          },
          {
            "name": "optionsJson",
            "type": "string"
          },
          {
            "name": "required",
            "type": "boolean",
            "default": false
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "surveyId",
            "type": "string"
          },
          {
            "name": "order",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "QuestionManage",
          "category": "interaction",
          "linkedEntity": "Question",
          "emits": [
            {
              "event": "OPEN_QUESTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.label",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.surveyId",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "UPDATE_QUESTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE_QUESTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "QuestionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Question]"
                }
              ]
            },
            {
              "event": "QuestionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "QuestionLoaded",
                "name": "Question loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Question]"
                  }
                ]
              },
              {
                "key": "QuestionLoadFailed",
                "name": "Question load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_QUESTION",
                "name": "Open Question",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Question"
                  }
                ]
              },
              {
                "key": "UPDATE_QUESTION",
                "name": "Update Question",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE_QUESTION",
                "name": "Delete Question",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "failure": "QuestionLoadFailed",
                        "success": "QuestionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading questions…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "QuestionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total questions",
                              "value": "@payload.data.length",
                              "icon": "list-checks"
                            },
                            {
                              "label": "Required",
                              "type": "stat-display",
                              "icon": "alert-circle",
                              "value": "18"
                            },
                            {
                              "icon": "clipboard-list",
                              "value": "6",
                              "label": "Surveys",
                              "type": "stat-display"
                            },
                            {
                              "value": "9",
                              "type": "stat-display",
                              "icon": "tag",
                              "label": "Categories"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0,
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "QuestionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.label",
                    "@payload.row.label"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.optionsJson",
                    "@payload.row.optionsJson"
                  ],
                  [
                    "set",
                    "@entity.required",
                    "@payload.row.required"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.surveyId",
                    "@payload.row.surveyId"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "list-checks"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.label"
                            },
                            {
                              "label": "@entity.kind",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Category",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.category",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Survey",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.surveyId",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Options"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.optionsJson",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Kind",
                              "value": "@entity.kind",
                              "icon": "tag"
                            },
                            {
                              "type": "stat-display",
                              "label": "Order",
                              "icon": "hash",
                              "value": "@entity.order"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "UPDATE_QUESTION",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Update"
                            },
                            {
                              "label": "Delete",
                              "type": "button",
                              "action": "DELETE_QUESTION",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UPDATE_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "failure": "QuestionLoadFailed",
                        "success": "QuestionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Updating question…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DELETE_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Deleting question…",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading questions…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "UPDATE_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating question…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DELETE_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Deleting question…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "failure": "QuestionLoadFailed",
                        "success": "QuestionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_QUESTION"
                },
                {
                  "variant": "danger",
                  "event": "DELETE_QUESTION",
                  "label": "Delete"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each question row",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "label",
                  "label": "Question",
                  "variant": "caption"
                },
                {
                  "label": "Type",
                  "name": "kind",
                  "variant": "badge"
                },
                {
                  "name": "category",
                  "label": "Category",
                  "variant": "caption"
                },
                {
                  "label": "Survey",
                  "name": "surveyId",
                  "variant": "caption"
                },
                {
                  "label": "Order",
                  "name": "order",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Question entity",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Question Bank",
              "label": "Section title",
              "description": "Heading shown above the survey question library"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "QuestionManagePage",
          "path": "/questions/manage",
          "traits": [
            {
              "ref": "QuestionManage"
            }
          ]
        }
      ]
    }
  ]
}