{
  "name": "std-question-bank",
  "version": "1.0.0",
  "description": "std-question-bank — typed question library for surveys. Owns a Question entity (label + kind + options + required + category + surveyId + order). QuestionManage loads questions on INIT, renders them in a data-grid with Edit / Delete actions plus a Create button, and persists add/update/delete via explicit ADD_QUESTION / UPDATE_QUESTION / DELETE_QUESTION events.",
  "orbitals": [
    {
      "name": "QuestionBankOrbital",
      "entity": {
        "name": "Question",
        "collection": "questions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "label",
            "type": "string",
            "required": true
          },
          {
            "name": "kind",
            "type": "string",
            "default": "text",
            "values": [
              "single",
              "multi",
              "text",
              "likert",
              "matrix",
              "number",
              "date"
            ]
          },
          {
            "name": "optionsJson",
            "type": "string"
          },
          {
            "name": "required",
            "type": "boolean",
            "default": false
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "surveyId",
            "type": "string"
          },
          {
            "name": "order",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "QuestionManage",
          "category": "interaction",
          "linkedEntity": "Question",
          "emits": [
            {
              "event": "ADD_QUESTION",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE_QUESTION",
              "payloadSchema": [
                {
                  "name": "questionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.label",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.surveyId",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE_QUESTION",
              "payloadSchema": [
                {
                  "name": "questionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.label",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.surveyId",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "QuestionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Question]"
                }
              ]
            },
            {
              "event": "QuestionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QuestionAdded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.label",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.surveyId",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "QuestionUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.label",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.optionsJson",
                  "type": "string"
                },
                {
                  "name": "row.required",
                  "type": "boolean"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.surveyId",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                }
              ]
            },
            {
              "event": "QuestionDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "QuestionLoaded",
                "name": "Question loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Question]"
                  }
                ]
              },
              {
                "key": "QuestionLoadFailed",
                "name": "Question load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADD_QUESTION",
                "name": "Add Question",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE_QUESTION",
                "name": "Update Question",
                "payloadSchema": [
                  {
                    "name": "questionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Question"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE_QUESTION",
                "name": "Delete Question",
                "payloadSchema": [
                  {
                    "name": "questionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Question"
                  }
                ]
              },
              {
                "key": "QuestionAdded",
                "name": "Question added",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Question"
                  }
                ]
              },
              {
                "key": "QuestionUpdated",
                "name": "Question updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Question"
                  }
                ]
              },
              {
                "key": "QuestionDeleted",
                "name": "Question deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading questions…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "QuestionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "list-checks"
                                },
                                {
                                  "content": "@config.title",
                                  "variant": "h3",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "label": "Add Question",
                              "action": "ADD_QUESTION",
                              "type": "button",
                              "variant": "primary",
                              "icon": "plus"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "icon": "edit",
                              "event": "UPDATE_QUESTION",
                              "label": "Edit",
                              "variant": "ghost"
                            },
                            {
                              "event": "DELETE_QUESTION",
                              "label": "Delete",
                              "variant": "danger",
                              "icon": "trash"
                            }
                          ],
                          "fields": [
                            {
                              "label": "Question",
                              "variant": "h4",
                              "name": "label"
                            },
                            {
                              "name": "kind",
                              "label": "Type",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "category",
                              "label": "Category"
                            },
                            {
                              "name": "required",
                              "label": "Required",
                              "variant": "badge"
                            },
                            {
                              "name": "order",
                              "variant": "caption",
                              "label": "Order"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "QuestionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "ADD_QUESTION",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Question",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "QuestionAdded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "UPDATE_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.questionId"
                  ],
                  [
                    "set",
                    "@entity.label",
                    "@payload.row.label"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.optionsJson",
                    "@payload.row.optionsJson"
                  ],
                  [
                    "set",
                    "@entity.required",
                    "@payload.row.required"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.surveyId",
                    "@payload.row.surveyId"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.row.order"
                  ],
                  [
                    "persist",
                    "update",
                    "Question",
                    "@entity",
                    {
                      "emit": {
                        "success": "QuestionUpdated",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "DELETE_QUESTION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.questionId"
                  ],
                  [
                    "persist",
                    "delete",
                    "Question",
                    "@entity.id",
                    {
                      "emit": {
                        "failure": "QuestionLoadFailed",
                        "success": "QuestionDeleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "QuestionAdded",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "QuestionUpdated",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "QuestionDeleted",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "QuestionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "QuestionAdded",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "QuestionUpdated",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "QuestionDeleted",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "QuestionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Question",
                    {
                      "emit": {
                        "success": "QuestionLoaded",
                        "failure": "QuestionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Question Bank"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "QuestionManagePage",
          "path": "/questions/manage",
          "traits": [
            {
              "ref": "QuestionManage"
            }
          ]
        }
      ]
    }
  ]
}
