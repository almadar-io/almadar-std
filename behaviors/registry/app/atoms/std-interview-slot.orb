{
  "name": "std-interview-slot",
  "version": "1.1.0",
  "description": "std-interview-slot — scheduled interview between an applicant and one or more interviewers, with date/time, format, and status. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "InterviewSlotOrbital",
      "entity": {
        "name": "InterviewSlot",
        "collection": "interviewslots",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "format",
            "type": "string",
            "default": "video",
            "values": [
              "phone",
              "video",
              "onsite"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "scheduled",
            "values": [
              "scheduled",
              "completed",
              "cancelled",
              "no_show"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "InterviewSlotSchedule",
          "category": "interaction",
          "linkedEntity": "InterviewSlot",
          "emits": [
            {
              "event": "OPEN_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string"
                },
                {
                  "name": "row.interviewerName",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.durationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.format",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "COMPLETE_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "InterviewSlotLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[InterviewSlot]"
                }
              ]
            },
            {
              "event": "InterviewSlotLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InterviewSlotLoaded",
                "name": "InterviewSlot loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[InterviewSlot]"
                  }
                ]
              },
              {
                "key": "InterviewSlotLoadFailed",
                "name": "InterviewSlot load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_INTERVIEW",
                "name": "Open Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "InterviewSlot"
                  }
                ]
              },
              {
                "key": "CANCEL_INTERVIEW",
                "name": "Cancel Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "COMPLETE_INTERVIEW",
                "name": "Complete Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading interviews…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InterviewSlotLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "calendar"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Scheduled",
                              "icon": "calendar",
                              "value": "@payload.data.length",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "9",
                              "label": "Today",
                              "icon": "clock"
                            },
                            {
                              "type": "stat-display",
                              "label": "Completed this week",
                              "value": "37",
                              "icon": "check-circle"
                            },
                            {
                              "value": "6%",
                              "label": "No-show rate",
                              "type": "stat-display",
                              "icon": "alert-triangle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0,
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InterviewSlotLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.applicantId",
                    "@payload.row.applicantId"
                  ],
                  [
                    "set",
                    "@entity.applicantName",
                    "@payload.row.applicantName"
                  ],
                  [
                    "set",
                    "@entity.interviewerName",
                    "@payload.row.interviewerName"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.row.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.durationMinutes",
                    "@payload.row.durationMinutes"
                  ],
                  [
                    "set",
                    "@entity.format",
                    "@payload.row.format"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.applicantName"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.format",
                              "type": "badge"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Interviewer"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.interviewerName",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Applicant ID",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.applicantId",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Notes",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.scheduledAt",
                              "label": "Scheduled",
                              "type": "stat-display",
                              "icon": "calendar"
                            },
                            {
                              "icon": "clock",
                              "type": "stat-display",
                              "label": "Duration (min)",
                              "value": "@entity.durationMinutes"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "children": [
                            {
                              "action": "COMPLETE_INTERVIEW",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Complete",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "label": "Cancel",
                              "variant": "danger",
                              "action": "CANCEL_INTERVIEW",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Cancelling interview…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "failure": "InterviewSlotLoadFailed",
                        "success": "InterviewSlotLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading interviews…"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "COMPLETE_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Completing interview…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Cancelling interview…"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "failure": "InterviewSlotLoadFailed",
                        "success": "InterviewSlotLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Interviews"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "applicantName",
                  "label": "Applicant",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Interviewer",
                  "name": "interviewerName"
                },
                {
                  "label": "Scheduled",
                  "variant": "caption",
                  "name": "scheduledAt"
                },
                {
                  "name": "format",
                  "variant": "badge",
                  "label": "Format"
                },
                {
                  "label": "Status",
                  "name": "status",
                  "variant": "badge"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_INTERVIEW",
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "event": "CANCEL_INTERVIEW",
                  "variant": "danger",
                  "label": "Cancel"
                }
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "InterviewSlotPage",
          "path": "/interviews",
          "traits": [
            {
              "ref": "InterviewSlotSchedule"
            }
          ]
        }
      ]
    }
  ]
}
