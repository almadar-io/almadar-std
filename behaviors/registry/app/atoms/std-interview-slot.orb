{
  "name": "std-interview-slot",
  "version": "1.2.0",
  "description": "std-interview-slot — scheduled interview between applicant and interviewers. Listens for SET_STATUS so sibling std-lifecycle can drive automated transitions. Exposes Scheduling/Booking + HR knobs (bookingWindowDays, leadTimeMinutes, backgroundCheckRequired, …).",
  "orbitals": [
    {
      "name": "InterviewSlotOrbital",
      "entity": {
        "name": "InterviewSlot",
        "collection": "interviewslots",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "default": 60.0
          },
          {
            "name": "format",
            "type": "string",
            "default": "video",
            "values": [
              "phone",
              "video",
              "onsite"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "scheduled",
            "values": [
              "scheduled",
              "completed",
              "cancelled",
              "no_show"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "InterviewSlotSchedule",
          "category": "interaction",
          "linkedEntity": "InterviewSlot",
          "emits": [
            {
              "event": "OPEN_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.applicantName",
                  "type": "string"
                },
                {
                  "name": "row.interviewerName",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.durationMinutes",
                  "type": "number"
                },
                {
                  "name": "row.format",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "COMPLETE_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "InterviewSlotLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[InterviewSlot]"
                }
              ]
            },
            {
              "event": "InterviewSlotLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InterviewSlotLoaded",
                "name": "InterviewSlot loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[InterviewSlot]"
                  }
                ]
              },
              {
                "key": "InterviewSlotLoadFailed",
                "name": "InterviewSlot load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_INTERVIEW",
                "name": "Open Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "InterviewSlot"
                  }
                ]
              },
              {
                "key": "CANCEL_INTERVIEW",
                "name": "Cancel Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "COMPLETE_INTERVIEW",
                "name": "Complete Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading interviews…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InterviewSlotLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "calendar",
                              "label": "Scheduled",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "value": "9",
                              "label": "Today"
                            },
                            {
                              "label": "Completed this week",
                              "icon": "check-circle",
                              "value": "37",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "icon": "alert-triangle",
                              "value": "6%",
                              "label": "No-show rate"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InterviewSlotLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.applicantId",
                    "@payload.row.applicantId"
                  ],
                  [
                    "set",
                    "@entity.applicantName",
                    "@payload.row.applicantName"
                  ],
                  [
                    "set",
                    "@entity.interviewerName",
                    "@payload.row.interviewerName"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.row.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.durationMinutes",
                    "@payload.row.durationMinutes"
                  ],
                  [
                    "set",
                    "@entity.format",
                    "@payload.row.format"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "calendar"
                            },
                            {
                              "content": "@entity.applicantName",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.format",
                              "type": "badge"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Interviewer",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.interviewerName"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Applicant ID",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.applicantId",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Notes"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Scheduled",
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "@entity.scheduledAt"
                            },
                            {
                              "value": "@entity.durationMinutes",
                              "label": "Duration (min)",
                              "icon": "clock",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 2.0,
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Complete",
                              "variant": "primary",
                              "action": "COMPLETE_INTERVIEW",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Cancel",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "CANCEL_INTERVIEW"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Cancelling interview…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "InterviewSlot",
                    "@entity",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Updating interview status…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading interviews…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "COMPLETE_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Completing interview…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Cancelling interview…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "success": "InterviewSlotLoaded",
                        "failure": "InterviewSlotLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "bookingHours": {
              "type": "string",
              "default": "09:00-17:00",
              "label": "Booking hours",
              "description": "Daily window during which interviews can be scheduled (HH:MM-HH:MM).",
              "tier": "domain"
            },
            "cancellationPolicy": {
              "type": "string",
              "default": "free",
              "label": "Cancellation policy",
              "description": "Refund treatment when a slot is cancelled inside the reschedule window.",
              "tier": "domain",
              "values": [
                "free",
                "partial-refund",
                "no-refund"
              ]
            },
            "rescheduleWindowHours": {
              "type": "number",
              "default": 24.0,
              "label": "Reschedule window (hours)",
              "description": "Hours before scheduledAt during which the applicant can self-reschedule.",
              "tier": "domain"
            },
            "i9DocumentsRequired": {
              "type": "boolean",
              "default": false,
              "label": "I-9 documents required",
              "description": "Require I-9 supporting documents before accepting an offer downstream.",
              "tier": "domain"
            },
            "backgroundCheckRequired": {
              "type": "boolean",
              "default": false,
              "label": "Background check required",
              "description": "Block COMPLETE_INTERVIEW until a background check is on file.",
              "tier": "domain"
            },
            "equalOpportunityTrackingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Equal opportunity tracking",
              "description": "Capture demographic data separately for EEO reporting (sibling collection).",
              "tier": "domain"
            },
            "bookingWindowDays": {
              "type": "number",
              "default": 30.0,
              "label": "Booking window (days)",
              "description": "How far in advance applicants can schedule interviews.",
              "tier": "domain"
            },
            "noShowGracePeriodMinutes": {
              "type": "number",
              "default": 15.0,
              "label": "No-show grace (minutes)",
              "description": "Minutes after scheduledAt before the slot auto-marks no_show. Wire via std-lifecycle.",
              "tier": "domain"
            },
            "anonymizeOnRejection": {
              "type": "boolean",
              "default": false,
              "label": "Anonymize on rejection",
              "description": "When true, scrub applicant PII on rejection. Pair with std-data-erasure.",
              "tier": "domain"
            },
            "retentionAfterRejectionDays": {
              "type": "number",
              "default": 730.0,
              "label": "Retention after rejection (days)",
              "description": "Days to keep rejected interview records. Default 730 (2 years) EEOC typical.",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Applicant",
                  "variant": "caption",
                  "name": "applicantName"
                },
                {
                  "label": "Interviewer",
                  "variant": "caption",
                  "name": "interviewerName"
                },
                {
                  "name": "scheduledAt",
                  "variant": "caption",
                  "label": "Scheduled"
                },
                {
                  "variant": "badge",
                  "name": "format",
                  "label": "Format"
                },
                {
                  "name": "status",
                  "variant": "badge",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Interview Slot entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "event": "OPEN_INTERVIEW",
                  "variant": "primary"
                },
                {
                  "label": "Cancel",
                  "event": "CANCEL_INTERVIEW",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each interview row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "blackoutDates": {
              "type": "[string]",
              "default": [],
              "label": "Blackout dates",
              "description": "ISO dates blocked from booking (e.g. holidays). Compose std-lifecycle to enforce.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
