{
  "name": "std-receipt",
  "version": "1.2.0",
  "description": "std-receipt — receipt primitive with Email / Reprint actions. Exposes Financial-pattern knobs (currency, taxStrategy, jurisdiction, retention).",
  "orbitals": [
    {
      "name": "ReceiptOrbital",
      "entity": {
        "name": "Receipt",
        "collection": "receipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientName",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientEmail",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionId",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionType",
            "type": "string",
            "default": "purchase",
            "values": [
              "purchase",
              "refund",
              "donation",
              "service"
            ]
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lineItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "issuedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "ReceiptIssuer",
          "category": "interaction",
          "linkedEntity": "Receipt",
          "emits": [
            {
              "event": "OPEN_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.receiptNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.recipientName",
                  "type": "string"
                },
                {
                  "name": "row.recipientEmail",
                  "type": "string"
                },
                {
                  "name": "row.transactionId",
                  "type": "string"
                },
                {
                  "name": "row.transactionType",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.isEmailed",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "EMAIL_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REPRINT_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ReceiptLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Receipt]"
                }
              ]
            },
            {
              "event": "ReceiptLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReceiptLoaded",
                "name": "Receipt loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Receipt]"
                  }
                ]
              },
              {
                "key": "ReceiptLoadFailed",
                "name": "Receipt load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RECEIPT",
                "name": "Open Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Receipt"
                  }
                ]
              },
              {
                "key": "EMAIL_RECEIPT",
                "name": "Email Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REPRINT_RECEIPT",
                "name": "Reprint Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "failure": "ReceiptLoadFailed",
                        "success": "ReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading receipts…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ReceiptLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "receipt",
                              "type": "stat-display",
                              "label": "Total receipts"
                            },
                            {
                              "value": "23",
                              "label": "Issued today",
                              "type": "stat-display",
                              "icon": "calendar"
                            },
                            {
                              "label": "Revenue",
                              "icon": "dollar-sign",
                              "value": "$12,840",
                              "type": "stat-display"
                            },
                            {
                              "icon": "mail",
                              "value": "92%",
                              "type": "stat-display",
                              "label": "Emailed"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm",
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReceiptLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.receiptNumber",
                    "@payload.row.receiptNumber"
                  ],
                  [
                    "set",
                    "@entity.recipientName",
                    "@payload.row.recipientName"
                  ],
                  [
                    "set",
                    "@entity.recipientEmail",
                    "@payload.row.recipientEmail"
                  ],
                  [
                    "set",
                    "@entity.transactionId",
                    "@payload.row.transactionId"
                  ],
                  [
                    "set",
                    "@entity.transactionType",
                    "@payload.row.transactionType"
                  ],
                  [
                    "set",
                    "@entity.subtotal",
                    "@payload.row.subtotal"
                  ],
                  [
                    "set",
                    "@entity.tax",
                    "@payload.row.tax"
                  ],
                  [
                    "set",
                    "@entity.total",
                    "@payload.row.total"
                  ],
                  [
                    "set",
                    "@entity.lineItemsJson",
                    "@payload.row.lineItemsJson"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "@payload.row.issuedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "type": "icon",
                              "name": "receipt"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.receiptNumber",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.transactionType",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "children": [
                                {
                                  "content": "Recipient",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.recipientName",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Email",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.recipientEmail"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Transaction"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.transactionId",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.subtotal",
                              "icon": "dollar-sign",
                              "label": "Subtotal"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.tax",
                              "label": "Tax",
                              "icon": "percent"
                            },
                            {
                              "type": "stat-display",
                              "label": "Total",
                              "icon": "dollar-sign",
                              "value": "@entity.total"
                            },
                            {
                              "label": "Issued",
                              "type": "stat-display",
                              "value": "@entity.issuedAt",
                              "icon": "calendar"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "action": "EMAIL_RECEIPT",
                              "variant": "primary",
                              "label": "Email",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            },
                            {
                              "label": "Reprint",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "secondary",
                              "type": "button",
                              "action": "REPRINT_RECEIPT"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "failure": "ReceiptLoadFailed",
                        "success": "ReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Emailing receipt…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REPRINT_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Reprinting receipt…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "failure": "ReceiptLoadFailed",
                        "success": "ReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading receipts…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "failure": "ReceiptLoadFailed",
                        "success": "ReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Emailing receipt…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REPRINT_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Reprinting receipt…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Receipts",
              "label": "Section title",
              "description": "Heading shown above the receipts list",
              "tier": "presentation"
            },
            "lateFeePolicy": {
              "type": "string",
              "default": "none",
              "label": "Late fee policy",
              "description": "Rarely applies to receipts. Declarative; wiring deferred.",
              "tier": "domain",
              "values": [
                "none",
                "flat",
                "percent"
              ]
            },
            "currency": {
              "type": "string",
              "default": "USD",
              "label": "Default currency",
              "description": "ISO 4217 currency code (USD, EUR, GBP, …) for receipt amounts.",
              "tier": "domain"
            },
            "retentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Retention (years)",
              "description": "Years to keep receipts for compliance.",
              "tier": "domain"
            },
            "complianceJurisdiction": {
              "type": "string",
              "default": "",
              "label": "Compliance jurisdiction",
              "description": "Drives receipt format + tax rules per locale: 'US-CA', 'EU-DE', 'UK', etc. Declarative.",
              "tier": "domain"
            },
            "gracePeriodDays": {
              "type": "number",
              "default": 0.0,
              "label": "Grace period (days)",
              "description": "Days a receipt is considered editable before locked. Declarative.",
              "tier": "domain"
            },
            "taxStrategy": {
              "type": "string",
              "default": "exclusive",
              "label": "Tax strategy",
              "description": "inclusive = tax baked into line items; exclusive = tax added on top; none = no tax.",
              "tier": "domain",
              "values": [
                "inclusive",
                "exclusive",
                "none"
              ]
            },
            "lateFeeAmount": {
              "type": "number",
              "default": 0.0,
              "label": "Late fee amount",
              "description": "Flat cash amount or percentage (per lateFeePolicy).",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Receipt #",
                  "variant": "caption",
                  "name": "receiptNumber"
                },
                {
                  "name": "recipientName",
                  "label": "Recipient",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "label": "Type",
                  "name": "transactionType"
                },
                {
                  "name": "total",
                  "variant": "caption",
                  "label": "Total"
                },
                {
                  "name": "issuedAt",
                  "label": "Issued",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Receipt entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_RECEIPT",
                  "variant": "primary",
                  "label": "Open"
                },
                {
                  "variant": "danger",
                  "event": "REPRINT_RECEIPT",
                  "label": "Reprint"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each receipt row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "roundingMode": {
              "type": "string",
              "default": "half-up",
              "label": "Rounding mode",
              "description": "Sub-cent rounding behavior for receipt totals.",
              "tier": "domain",
              "values": [
                "bankers",
                "half-up",
                "down"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReceiptPage",
          "path": "/receipts",
          "traits": [
            {
              "ref": "ReceiptIssuer"
            }
          ]
        }
      ]
    }
  ]
}