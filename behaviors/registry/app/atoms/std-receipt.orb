{
  "name": "std-receipt",
  "version": "1.1.0",
  "description": "std-receipt — receipt primitive. Lists receipts in `browsing`; opens detail in `viewing_single` with Email / Reprint actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ReceiptOrbital",
      "entity": {
        "name": "Receipt",
        "collection": "receipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientName",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientEmail",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionId",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionType",
            "type": "string",
            "default": "purchase",
            "values": [
              "purchase",
              "refund",
              "donation",
              "service"
            ]
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lineItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "issuedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "ReceiptIssuer",
          "category": "interaction",
          "linkedEntity": "Receipt",
          "emits": [
            {
              "event": "OPEN_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.receiptNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.recipientName",
                  "type": "string"
                },
                {
                  "name": "row.recipientEmail",
                  "type": "string"
                },
                {
                  "name": "row.transactionId",
                  "type": "string"
                },
                {
                  "name": "row.transactionType",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.isEmailed",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "EMAIL_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REPRINT_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ReceiptLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Receipt]"
                }
              ]
            },
            {
              "event": "ReceiptLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReceiptLoaded",
                "name": "Receipt loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Receipt]"
                  }
                ]
              },
              {
                "key": "ReceiptLoadFailed",
                "name": "Receipt load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RECEIPT",
                "name": "Open Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Receipt"
                  }
                ]
              },
              {
                "key": "EMAIL_RECEIPT",
                "name": "Email Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REPRINT_RECEIPT",
                "name": "Reprint Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading receipts…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ReceiptLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "receipt",
                              "label": "Total receipts",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "label": "Issued today",
                              "icon": "calendar",
                              "type": "stat-display",
                              "value": "23"
                            },
                            {
                              "value": "$12,840",
                              "type": "stat-display",
                              "icon": "dollar-sign",
                              "label": "Revenue"
                            },
                            {
                              "value": "92%",
                              "label": "Emailed",
                              "type": "stat-display",
                              "icon": "mail"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReceiptLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.receiptNumber",
                    "@payload.row.receiptNumber"
                  ],
                  [
                    "set",
                    "@entity.recipientName",
                    "@payload.row.recipientName"
                  ],
                  [
                    "set",
                    "@entity.recipientEmail",
                    "@payload.row.recipientEmail"
                  ],
                  [
                    "set",
                    "@entity.transactionId",
                    "@payload.row.transactionId"
                  ],
                  [
                    "set",
                    "@entity.transactionType",
                    "@payload.row.transactionType"
                  ],
                  [
                    "set",
                    "@entity.subtotal",
                    "@payload.row.subtotal"
                  ],
                  [
                    "set",
                    "@entity.tax",
                    "@payload.row.tax"
                  ],
                  [
                    "set",
                    "@entity.total",
                    "@payload.row.total"
                  ],
                  [
                    "set",
                    "@entity.lineItemsJson",
                    "@payload.row.lineItemsJson"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "@payload.row.issuedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "receipt"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.receiptNumber",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.transactionType",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Recipient",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.recipientName",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Email"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.recipientEmail"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Transaction"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.transactionId",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Subtotal",
                              "value": "@entity.subtotal",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "icon": "percent",
                              "value": "@entity.tax",
                              "type": "stat-display",
                              "label": "Tax"
                            },
                            {
                              "value": "@entity.total",
                              "label": "Total",
                              "icon": "dollar-sign",
                              "type": "stat-display"
                            },
                            {
                              "label": "Issued",
                              "icon": "calendar",
                              "value": "@entity.issuedAt",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Email",
                              "action": "EMAIL_RECEIPT",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "action": "REPRINT_RECEIPT",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Reprint",
                              "variant": "secondary"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Emailing receipt…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REPRINT_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Reprinting receipt…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading receipts…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Emailing receipt…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REPRINT_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Reprinting receipt…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Receipts"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "label": "Receipt #",
                  "variant": "caption",
                  "name": "receiptNumber"
                },
                {
                  "name": "recipientName",
                  "label": "Recipient",
                  "variant": "caption"
                },
                {
                  "name": "transactionType",
                  "label": "Type",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "label": "Total",
                  "name": "total"
                },
                {
                  "name": "issuedAt",
                  "label": "Issued",
                  "variant": "caption"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "label": "Open",
                  "variant": "primary",
                  "event": "OPEN_RECEIPT",
                  "icon": "arrow-right"
                },
                {
                  "variant": "danger",
                  "event": "REPRINT_RECEIPT",
                  "label": "Reprint"
                }
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReceiptPage",
          "path": "/receipts",
          "traits": [
            {
              "ref": "ReceiptIssuer"
            }
          ]
        }
      ]
    }
  ]
}
