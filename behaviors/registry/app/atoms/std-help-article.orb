{
  "name": "std-help-article",
  "version": "1.1.0",
  "description": "std-help-article — Public help center article primitive with title, body, category, view count, and published/draft status. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "HelpArticleOrbital",
      "entity": {
        "name": "HelpArticle",
        "collection": "helparticles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "summary",
            "type": "string",
            "default": ""
          },
          {
            "name": "categoryId",
            "type": "string",
            "default": ""
          },
          {
            "name": "categoryName",
            "type": "string",
            "default": ""
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "archived",
              "needs-update"
            ]
          },
          {
            "name": "viewCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "helpfulCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "notHelpfulCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "publishedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HelpArticleManage",
          "category": "interaction",
          "linkedEntity": "HelpArticle",
          "emits": [
            {
              "event": "OPEN_ARTICLE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.body",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.categoryId",
                  "type": "string"
                },
                {
                  "name": "row.categoryName",
                  "type": "string"
                },
                {
                  "name": "row.author",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.viewCount",
                  "type": "number"
                },
                {
                  "name": "row.helpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.notHelpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.publishedAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ARCHIVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "HelpArticleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HelpArticle]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HelpArticleLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HelpArticleLoaded",
                "name": "HelpArticle loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HelpArticle]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HelpArticleLoadFailed",
                "name": "HelpArticle load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ARTICLE",
                "name": "Open Article",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "HelpArticle"
                  }
                ]
              },
              {
                "key": "ARCHIVE",
                "name": "Archive",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading help articles…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "HelpArticleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total articles",
                              "icon": "book-open",
                              "value": "@payload.data.length"
                            },
                            {
                              "value": "184",
                              "type": "stat-display",
                              "label": "Published",
                              "icon": "check-circle"
                            },
                            {
                              "value": "12",
                              "icon": "edit",
                              "type": "stat-display",
                              "label": "Drafts"
                            },
                            {
                              "type": "stat-display",
                              "label": "Avg helpful rate",
                              "value": "87%",
                              "icon": "thumbs-up"
                            }
                          ],
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HelpArticleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.message",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ARTICLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.slug",
                    "@payload.row.slug"
                  ],
                  [
                    "set",
                    "@entity.summary",
                    "@payload.row.summary"
                  ],
                  [
                    "set",
                    "@entity.categoryName",
                    "@payload.row.categoryName"
                  ],
                  [
                    "set",
                    "@entity.author",
                    "@payload.row.author"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.viewCount",
                    "@payload.row.viewCount"
                  ],
                  [
                    "set",
                    "@entity.helpfulCount",
                    "@payload.row.helpfulCount"
                  ],
                  [
                    "set",
                    "@entity.notHelpfulCount",
                    "@payload.row.notHelpfulCount"
                  ],
                  [
                    "set",
                    "@entity.publishedAt",
                    "@payload.row.publishedAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.title",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Slug"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.slug",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Category",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.categoryName"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Author",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.author"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Summary",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.summary",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "eye",
                              "value": "@entity.viewCount",
                              "type": "stat-display",
                              "label": "Views"
                            },
                            {
                              "type": "stat-display",
                              "icon": "thumbs-up",
                              "label": "Helpful",
                              "value": "@entity.helpfulCount"
                            },
                            {
                              "value": "@entity.notHelpfulCount",
                              "type": "stat-display",
                              "label": "Not helpful",
                              "icon": "thumbs-down"
                            },
                            {
                              "label": "Published",
                              "value": "@entity.publishedAt",
                              "type": "stat-display",
                              "icon": "calendar"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Publish",
                              "type": "button",
                              "action": "PUBLISH"
                            },
                            {
                              "variant": "danger",
                              "type": "button",
                              "label": "Archive",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "action": "ARCHIVE"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ARCHIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "failure": "HelpArticleLoadFailed",
                        "success": "HelpArticleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Archiving article…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "failure": "HelpArticleLoadFailed",
                        "success": "HelpArticleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading help articles…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Publishing article…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Archiving article…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Help Articles"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "name": "title",
                  "label": "Title"
                },
                {
                  "name": "slug",
                  "label": "Slug",
                  "variant": "caption"
                },
                {
                  "name": "categoryName",
                  "label": "Category",
                  "variant": "caption"
                },
                {
                  "label": "Author",
                  "name": "author",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "label": "Views",
                  "variant": "caption",
                  "name": "viewCount"
                },
                {
                  "variant": "caption",
                  "label": "Published",
                  "name": "publishedAt"
                }
              ]
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_ARTICLE",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "variant": "danger",
                  "label": "Archive",
                  "event": "ARCHIVE"
                }
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HelpArticlePage",
          "path": "/help-articles",
          "traits": [
            {
              "ref": "HelpArticleManage"
            }
          ]
        }
      ]
    }
  ]
}
