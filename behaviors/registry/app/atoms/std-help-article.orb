{
  "name": "std-help-article",
  "version": "1.0.0",
  "description": "std-help-article — Public help center article primitive with title, body, category, view count, and published/draft status.",
  "orbitals": [
    {
      "name": "HelpArticleOrbital",
      "entity": {
        "name": "HelpArticle",
        "collection": "helparticles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "summary",
            "type": "string",
            "default": ""
          },
          {
            "name": "categoryId",
            "type": "string",
            "default": ""
          },
          {
            "name": "categoryName",
            "type": "string",
            "default": ""
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "archived",
              "needs-update"
            ]
          },
          {
            "name": "viewCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "helpfulCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "notHelpfulCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "publishedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HelpArticleManage",
          "category": "interaction",
          "linkedEntity": "HelpArticle",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.body",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.categoryId",
                  "type": "string"
                },
                {
                  "name": "row.categoryName",
                  "type": "string"
                },
                {
                  "name": "row.author",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.viewCount",
                  "type": "number"
                },
                {
                  "name": "row.helpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.notHelpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.publishedAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARCHIVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.body",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.categoryId",
                  "type": "string"
                },
                {
                  "name": "row.categoryName",
                  "type": "string"
                },
                {
                  "name": "row.author",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.viewCount",
                  "type": "number"
                },
                {
                  "name": "row.helpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.notHelpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.publishedAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HelpArticleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HelpArticle]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HelpArticleLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HelpArticleLoaded",
                "name": "HelpArticle loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HelpArticle]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HelpArticleLoadFailed",
                "name": "HelpArticle load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_CATEGORY",
                "name": "Filter Category",
                "payloadSchema": [
                  {
                    "name": "categoryId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARCHIVE",
                "name": "Archive",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading help articles…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "HelpArticleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "entity": "HelpArticle",
                          "type": "hero-organism"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            },
                            {
                              "action": "CREATE",
                              "variant": "primary",
                              "type": "button",
                              "label": "New Article"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "doc-breadcrumb",
                          "items": [
                            {
                              "label": "Help Center"
                            },
                            {
                              "label": "Articles"
                            },
                            {
                              "label": "@config.title"
                            }
                          ]
                        },
                        {
                          "placeholder": "Search articles…",
                          "type": "doc-search"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "items": [
                                {
                                  "label": "Getting Started",
                                  "href": "#getting-started",
                                  "id": "getting-started"
                                },
                                {
                                  "id": "billing",
                                  "label": "Billing",
                                  "href": "#billing"
                                },
                                {
                                  "id": "api",
                                  "label": "API Reference",
                                  "href": "#api"
                                },
                                {
                                  "href": "#troubleshooting",
                                  "label": "Troubleshooting",
                                  "id": "troubleshooting"
                                }
                              ],
                              "type": "doc-sidebar"
                            },
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "article-section",
                                  "title": "Overview",
                                  "children": [
                                    {
                                      "content": "These articles cover everything from setup to advanced workflows.",
                                      "direction": "ltr",
                                      "type": "content-renderer"
                                    }
                                  ]
                                },
                                {
                                  "tabs": [
                                    {
                                      "content": {
                                        "content": "Most-viewed help articles this week.",
                                        "type": "typography"
                                      },
                                      "id": "popular",
                                      "label": "Popular"
                                    },
                                    {
                                      "id": "recent",
                                      "content": {
                                        "content": "Freshly revised guidance.",
                                        "type": "typography"
                                      },
                                      "label": "Recently Updated"
                                    },
                                    {
                                      "content": {
                                        "content": "Articles still in review.",
                                        "type": "typography"
                                      },
                                      "id": "drafts",
                                      "label": "Drafts"
                                    }
                                  ],
                                  "defaultTab": "popular",
                                  "type": "tabbed-container"
                                },
                                {
                                  "type": "book-viewer",
                                  "entity": "@payload.data"
                                },
                                {
                                  "type": "case-study-card",
                                  "title": "How Acme reduced support volume 40%",
                                  "category": "Customer Story",
                                  "href": "/help-articles/case-study-acme",
                                  "linkLabel": "Read case study",
                                  "description": "A walkthrough of the self-serve content strategy that cut inbound tickets."
                                },
                                {
                                  "entity": "HelpArticle",
                                  "type": "case-study-organism"
                                },
                                {
                                  "entity": "HelpArticle",
                                  "type": "step-flow-organism"
                                },
                                {
                                  "features": [
                                    {
                                      "type": "feature",
                                      "id": "search",
                                      "label": "Smart Search"
                                    },
                                    {
                                      "label": "Tag Index",
                                      "type": "feature",
                                      "id": "tags"
                                    },
                                    {
                                      "type": "feature",
                                      "label": "Helpfulness Voting",
                                      "id": "feedback"
                                    }
                                  ],
                                  "type": "feature-renderer-3d"
                                }
                              ],
                              "gap": "md"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW",
                              "variant": "secondary"
                            },
                            {
                              "label": "Edit",
                              "variant": "secondary",
                              "event": "EDIT"
                            },
                            {
                              "event": "PUBLISH",
                              "variant": "primary",
                              "label": "Publish"
                            },
                            {
                              "event": "ARCHIVE",
                              "label": "Archive",
                              "variant": "ghost"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "name": "slug",
                              "label": "Slug",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "categoryName",
                              "label": "Category"
                            },
                            {
                              "label": "Author",
                              "name": "author",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "name": "viewCount",
                              "label": "Views",
                              "variant": "caption"
                            },
                            {
                              "name": "helpfulCount",
                              "variant": "caption",
                              "label": "Helpful"
                            },
                            {
                              "variant": "caption",
                              "name": "publishedAt",
                              "label": "Published"
                            }
                          ],
                          "gap": "sm",
                          "cols": 1.0
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HelpArticleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.message",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "failure": "HelpArticleLoadFailed",
                        "success": "HelpArticleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Refreshing help articles…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Searching help articles…"
                        }
                      ],
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_STATUS",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Filtering help articles…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_CATEGORY",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Filtering help articles…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Creating new help article",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Viewing help article"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Editing help article"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Article published"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "ARCHIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Article archived",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Delete requested",
                      "type": "alert",
                      "variant": "warning"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Help Articles"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HelpArticlePage",
          "path": "/help-articles",
          "traits": [
            {
              "ref": "HelpArticleManage"
            }
          ]
        }
      ]
    }
  ]
}