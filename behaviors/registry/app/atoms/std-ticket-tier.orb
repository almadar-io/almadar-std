{
  "name": "std-ticket-tier",
  "version": "1.2.0",
  "description": "std-ticket-tier — event ticket pricing tiers (VIP, general, early-bird) with quantity tracking. Listens for SET_STATUS so std-lifecycle can drive transitions (sold-out / closed). Exposes Restaurant/POS + Financial knobs (currency, tipPresets, taxStrategy, …).",
  "orbitals": [
    {
      "name": "TicketTierOrbital",
      "entity": {
        "name": "TicketTier",
        "collection": "tickettiers",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "eventId",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "quantityTotal",
            "type": "number",
            "required": true
          },
          {
            "name": "quantitySold",
            "type": "number",
            "required": true,
            "default": 0.0
          },
          {
            "name": "availableFrom",
            "type": "string"
          },
          {
            "name": "availableUntil",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "available",
            "values": [
              "available",
              "sold-out",
              "closed"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "TicketTierManage",
          "category": "interaction",
          "linkedEntity": "TicketTier",
          "emits": [
            {
              "event": "OPEN_TIER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "SELL",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "qty",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TicketTier]"
                }
              ]
            },
            {
              "event": "TicketTierLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TicketTierLoaded",
                "name": "TicketTier loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TicketTier]"
                  }
                ]
              },
              {
                "key": "TicketTierLoadFailed",
                "name": "TicketTier load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TIER",
                "name": "Open Tier",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELL",
                "name": "Sell",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "qty",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TicketTierUpdated",
                "name": "TicketTier updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierUpdateFailed",
                "name": "TicketTier update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading ticket tiers…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TicketTierLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "ticket"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Total tiers",
                              "icon": "ticket",
                              "type": "stat-display"
                            },
                            {
                              "icon": "dollar-sign",
                              "label": "Gross sales",
                              "value": "$184,200",
                              "type": "stat-display"
                            },
                            {
                              "label": "Sold seats",
                              "icon": "users",
                              "type": "stat-display",
                              "value": "2,840"
                            },
                            {
                              "type": "stat-display",
                              "icon": "trending-up",
                              "value": "73%",
                              "label": "Sell-through"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TicketTierLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TIER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    "@payload.row.quantitySold"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "ticket"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "primary"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Event",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.eventId"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Available from",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.availableFrom",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Available until",
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.availableUntil",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Price",
                              "value": "@entity.price",
                              "icon": "dollar-sign"
                            },
                            {
                              "type": "stat-display",
                              "icon": "globe",
                              "value": "@entity.currency",
                              "label": "Currency"
                            },
                            {
                              "label": "Total seats",
                              "type": "stat-display",
                              "icon": "users",
                              "value": "@entity.quantityTotal"
                            },
                            {
                              "label": "Sold",
                              "type": "stat-display",
                              "value": "@entity.quantitySold",
                              "icon": "check-circle"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "align": "center",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Update",
                              "action": "UPDATE",
                              "variant": "primary",
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "data": {},
                                "tierId": "@entity.id"
                              }
                            },
                            {
                              "variant": "secondary",
                              "actionPayload": {
                                "qty": 1.0,
                                "tierId": "@entity.id",
                                "row": "@entity"
                              },
                              "label": "Sell",
                              "action": "SELL",
                              "type": "button"
                            },
                            {
                              "action": "CLOSE",
                              "actionPayload": {
                                "tierId": "@entity.id",
                                "row": "@entity"
                              },
                              "variant": "danger",
                              "label": "Close",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating tier…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SELL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Selling tickets…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Closing tier…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "success": "TicketTierUpdated",
                        "failure": "TicketTierUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Updating tier status…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierUpdated",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TicketTierUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading ticket tiers…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Updating tier…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SELL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Selling tickets…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Closing tier…"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "retentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Retention (years)",
              "description": "Years to keep ticket-tier records for accounting compliance.",
              "tier": "domain"
            },
            "tableTurnoverTargetMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "Table turnover target (min)",
              "description": "Used for seated/VIP tier pacing. v1.2 declarative.",
              "tier": "domain"
            },
            "currency": {
              "type": "string",
              "default": "USD",
              "label": "Default currency",
              "description": "ISO 4217 currency code (USD, EUR, GBP, …) for new tier rows.",
              "tier": "domain"
            },
            "lateFeeAmount": {
              "type": "number",
              "default": 0.0,
              "label": "Late fee amount",
              "description": "Flat cash amount or percentage (per lateFeePolicy).",
              "tier": "domain"
            },
            "lateFeePolicy": {
              "type": "string",
              "default": "none",
              "label": "Late fee policy",
              "description": "Penalty applied to late ticket purchases. v1.2 declarative.",
              "tier": "domain",
              "values": [
                "none",
                "flat",
                "percent"
              ]
            },
            "kitchenAutoFire": {
              "type": "boolean",
              "default": false,
              "label": "Kitchen auto-fire",
              "description": "Auto-fire concession orders bound to ticket tiers.",
              "tier": "domain"
            },
            "tipPresets": {
              "type": "[number]",
              "default": [
                0.0
              ],
              "label": "Tip presets (%)",
              "description": "Tip percentages exposed at ticket checkout (often 0 for events).",
              "tier": "domain",
              "items": {
                "type": "number"
              }
            },
            "roundingMode": {
              "type": "string",
              "default": "half-up",
              "label": "Rounding mode",
              "description": "Sub-cent rounding behavior on totals.",
              "tier": "domain",
              "values": [
                "bankers",
                "half-up",
                "down"
              ]
            },
            "allowSplitChecks": {
              "type": "boolean",
              "default": false,
              "label": "Allow split checks",
              "description": "Permit splitting a multi-ticket order across multiple payments.",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Ticket Tiers",
              "label": "Section title",
              "description": "Heading shown above the ticket pricing tiers",
              "tier": "presentation"
            },
            "serviceCharge": {
              "type": "number",
              "default": 0.0,
              "label": "Service charge (%)",
              "description": "Service-charge percentage applied to tier purchases.",
              "tier": "domain"
            },
            "gracePeriodDays": {
              "type": "number",
              "default": 0.0,
              "label": "Grace period (days)",
              "description": "Days after availability ends before the tier flips to closed.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "event": "OPEN_TIER",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "label": "Close",
                  "variant": "danger",
                  "event": "CLOSE",
                  "icon": "x"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each tier row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "complianceJurisdiction": {
              "type": "string",
              "default": "",
              "label": "Compliance jurisdiction",
              "description": "Drives ticket-tax + reporting rules per locale ('US-CA', 'EU-DE', …). v1.2 declarative.",
              "tier": "domain"
            },
            "coursingEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Coursing enabled",
              "description": "Track ordered courses when tier purchases include meals.",
              "tier": "domain"
            },
            "allergenWarningsEnabled": {
              "type": "boolean",
              "default": true,
              "label": "Allergen warnings",
              "description": "Surface allergen warnings on bundled food/drink items.",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "badge",
                  "label": "Tier",
                  "name": "name"
                },
                {
                  "label": "Price",
                  "name": "price",
                  "variant": "caption"
                },
                {
                  "name": "currency",
                  "variant": "badge",
                  "label": "Currency"
                },
                {
                  "name": "quantityTotal",
                  "label": "Total",
                  "variant": "caption"
                },
                {
                  "label": "Sold",
                  "variant": "caption",
                  "name": "quantitySold"
                },
                {
                  "name": "status",
                  "variant": "badge",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Ticket Tier entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "taxStrategy": {
              "type": "string",
              "default": "exclusive",
              "label": "Tax strategy",
              "description": "How tax is applied to tier prices: inclusive / exclusive / none.",
              "tier": "domain",
              "values": [
                "inclusive",
                "exclusive",
                "none"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TicketTierManagePage",
          "path": "/tickettiers/manage",
          "traits": [
            {
              "ref": "TicketTierManage"
            }
          ]
        }
      ]
    }
  ]
}