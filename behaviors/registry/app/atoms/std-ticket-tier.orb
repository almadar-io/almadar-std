{
  "name": "std-ticket-tier",
  "version": "1.1.0",
  "description": "std-ticket-tier — event ticket pricing tiers (VIP, general, early-bird) with quantity tracking. Lists tiers in `browsing`; opens detail in `viewing_single` with Update / Sell / Close actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "TicketTierOrbital",
      "entity": {
        "name": "TicketTier",
        "collection": "tickettiers",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "eventId",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "quantityTotal",
            "type": "number",
            "required": true
          },
          {
            "name": "quantitySold",
            "type": "number",
            "required": true,
            "default": 0.0
          },
          {
            "name": "availableFrom",
            "type": "string"
          },
          {
            "name": "availableUntil",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "available",
            "values": [
              "available",
              "sold-out",
              "closed"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "TicketTierManage",
          "category": "interaction",
          "linkedEntity": "TicketTier",
          "emits": [
            {
              "event": "OPEN_TIER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "SELL",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "qty",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TicketTier]"
                }
              ]
            },
            {
              "event": "TicketTierLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TicketTierLoaded",
                "name": "TicketTier loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TicketTier]"
                  }
                ]
              },
              {
                "key": "TicketTierLoadFailed",
                "name": "TicketTier load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TIER",
                "name": "Open Tier",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELL",
                "name": "Sell",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "qty",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading ticket tiers…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TicketTierLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "ticket",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total tiers",
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "icon": "ticket"
                            },
                            {
                              "type": "stat-display",
                              "value": "$184,200",
                              "icon": "dollar-sign",
                              "label": "Gross sales"
                            },
                            {
                              "value": "2,840",
                              "icon": "users",
                              "type": "stat-display",
                              "label": "Sold seats"
                            },
                            {
                              "value": "73%",
                              "type": "stat-display",
                              "label": "Sell-through",
                              "icon": "trending-up"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TicketTierLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TIER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    "@payload.row.quantitySold"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "ticket"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.name"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.status"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Event",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.eventId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Available from"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.availableFrom"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Available until",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.availableUntil"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.price",
                              "type": "stat-display",
                              "label": "Price",
                              "icon": "dollar-sign"
                            },
                            {
                              "value": "@entity.currency",
                              "icon": "globe",
                              "type": "stat-display",
                              "label": "Currency"
                            },
                            {
                              "value": "@entity.quantityTotal",
                              "type": "stat-display",
                              "label": "Total seats",
                              "icon": "users"
                            },
                            {
                              "type": "stat-display",
                              "label": "Sold",
                              "value": "@entity.quantitySold",
                              "icon": "check-circle"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Update",
                              "action": "UPDATE",
                              "type": "button",
                              "variant": "primary",
                              "actionPayload": {
                                "tierId": "@entity.id",
                                "row": "@entity",
                                "data": {}
                              }
                            },
                            {
                              "label": "Sell",
                              "type": "button",
                              "action": "SELL",
                              "variant": "secondary",
                              "actionPayload": {
                                "row": "@entity",
                                "qty": 1.0,
                                "tierId": "@entity.id"
                              }
                            },
                            {
                              "label": "Close",
                              "action": "CLOSE",
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "tierId": "@entity.id"
                              },
                              "variant": "danger"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Updating tier…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SELL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Selling tickets…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Closing tier…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading ticket tiers…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Updating tier…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SELL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Selling tickets…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Closing tier…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "name",
                  "variant": "badge",
                  "label": "Tier"
                },
                {
                  "label": "Price",
                  "name": "price",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "label": "Currency",
                  "name": "currency"
                },
                {
                  "name": "quantityTotal",
                  "label": "Total",
                  "variant": "caption"
                },
                {
                  "label": "Sold",
                  "variant": "caption",
                  "name": "quantitySold"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Ticket Tier entity",
              "items": {
                "type": "object"
              }
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_TIER",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "label": "Close",
                  "icon": "x",
                  "event": "CLOSE",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each tier row",
              "items": {
                "type": "object"
              }
            },
            "title": {
              "type": "string",
              "default": "Ticket Tiers",
              "label": "Section title",
              "description": "Heading shown above the ticket pricing tiers"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TicketTierManagePage",
          "path": "/tickettiers/manage",
          "traits": [
            {
              "ref": "TicketTierManage"
            }
          ]
        }
      ]
    }
  ]
}