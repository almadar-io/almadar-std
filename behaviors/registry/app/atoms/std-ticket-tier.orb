{
  "name": "std-ticket-tier",
  "version": "1.0.0",
  "description": "std-ticket-tier — event ticket pricing tiers (VIP, general, early-bird) with quantity tracking. Owns a TicketTier entity (price, quantityTotal, quantitySold, status) and a single manage trait that loads tiers, browses them in a data-grid with Create / Update / Sell / Close actions, and persists each verdict back to the row.",
  "orbitals": [
    {
      "name": "TicketTierOrbital",
      "entity": {
        "name": "TicketTier",
        "collection": "tickettiers",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "eventId",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "quantityTotal",
            "type": "number",
            "required": true
          },
          {
            "name": "quantitySold",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "availableFrom",
            "type": "string"
          },
          {
            "name": "availableUntil",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "available",
            "values": [
              "available",
              "sold-out",
              "closed"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "TicketTierManage",
          "category": "interaction",
          "linkedEntity": "TicketTier",
          "emits": [
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "SELL",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "qty",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "tierId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TicketTier]"
                }
              ]
            },
            {
              "event": "TicketTierLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierSold",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierClosed",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.quantityTotal",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.quantitySold",
                  "type": "number"
                },
                {
                  "name": "row.availableFrom",
                  "type": "string"
                },
                {
                  "name": "row.availableUntil",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketTierWriteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TicketTierLoaded",
                "name": "TicketTier loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TicketTier]"
                  }
                ]
              },
              {
                "key": "TicketTierLoadFailed",
                "name": "TicketTier load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELL",
                "name": "Sell",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "qty",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierCreated",
                "name": "TicketTier created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierUpdated",
                "name": "TicketTier updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierSold",
                "name": "TicketTier sold",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierClosed",
                "name": "TicketTier closed",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierWriteFailed",
                "name": "TicketTier write failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading ticket tiers…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TicketTierLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "ticket"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "UPDATE",
                              "variant": "secondary",
                              "label": "Update",
                              "icon": "edit"
                            },
                            {
                              "label": "Sell",
                              "icon": "shopping-cart",
                              "variant": "primary",
                              "event": "SELL"
                            },
                            {
                              "label": "Close",
                              "icon": "x",
                              "event": "CLOSE",
                              "variant": "danger"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Tier",
                              "name": "name",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "price",
                              "label": "Price"
                            },
                            {
                              "name": "currency",
                              "variant": "badge",
                              "label": "Currency"
                            },
                            {
                              "name": "quantityTotal",
                              "label": "Total",
                              "variant": "caption"
                            },
                            {
                              "name": "quantitySold",
                              "label": "Sold",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "cols": 1.0
                        },
                        {
                          "variant": "primary",
                          "icon": "plus",
                          "type": "button",
                          "label": "New Tier",
                          "action": "CREATE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TicketTierLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "TicketTier",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TicketTierCreated",
                        "failure": "TicketTierWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    "@payload.row.quantitySold"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TicketTierWriteFailed",
                        "success": "TicketTierUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SELL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    [
                      "+",
                      "@payload.row.quantitySold",
                      "@payload.qty"
                    ]
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    [
                      "if",
                      [
                        ">=",
                        "@entity.quantitySold",
                        "@entity.quantityTotal"
                      ],
                      "sold-out",
                      "available"
                    ]
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "success": "TicketTierSold",
                        "failure": "TicketTierWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    "@payload.row.quantitySold"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "closed"
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TicketTierWriteFailed",
                        "success": "TicketTierClosed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierCreated",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierUpdated",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierSold",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierClosed",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TicketTierWriteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Ticket Tiers"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TicketTierManagePage",
          "path": "/tickettiers/manage",
          "traits": [
            {
              "ref": "TicketTierManage"
            }
          ]
        }
      ]
    }
  ]
}
