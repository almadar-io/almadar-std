{
  "name": "std-technician-dispatch",
  "version": "1.1.0",
  "description": "std-technician-dispatch — dispatch board for field technicians. Lists technicians in `browsing`; opens detail in `viewing_single` with Assign / Accept / Reject / Toggle Availability actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "TechnicianDispatchOrbital",
      "entity": {
        "name": "Technician",
        "collection": "technicians",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "phone",
            "type": "string"
          },
          {
            "name": "skills",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "available",
            "type": "boolean",
            "default": true
          },
          {
            "name": "currentOrderId",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "lastSeenAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TechnicianDispatch",
          "category": "interaction",
          "linkedEntity": "Technician",
          "emits": [
            {
              "event": "OPEN_TECHNICIAN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.skills",
                  "type": "[string]"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.currentOrderId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.lastSeenAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ASSIGN",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "orderId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ACCEPT",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TOGGLE_AVAILABLE",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "available",
                  "type": "boolean",
                  "required": true
                }
              ]
            },
            {
              "event": "TechnicianLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Technician]"
                }
              ]
            },
            {
              "event": "TechnicianLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TechnicianUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.skills",
                  "type": "[string]"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.currentOrderId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.lastSeenAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TechnicianUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssignmentAccepted",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AssignmentRejected",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TechnicianLoaded",
                "name": "Technician loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Technician]"
                  }
                ]
              },
              {
                "key": "TechnicianLoadFailed",
                "name": "Technician load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TECHNICIAN",
                "name": "Open Technician",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Technician"
                  }
                ]
              },
              {
                "key": "ASSIGN",
                "name": "Assign",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "orderId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ACCEPT",
                "name": "Accept",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOGGLE_AVAILABLE",
                "name": "Toggle Available",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "available",
                    "type": "boolean",
                    "required": true
                  }
                ]
              },
              {
                "key": "TechnicianUpdated",
                "name": "Technician updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Technician"
                  }
                ]
              },
              {
                "key": "TechnicianUpdateFailed",
                "name": "Technician update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssignmentAccepted",
                "name": "Assignment accepted",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "AssignmentRejected",
                "name": "Assignment rejected",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading technicians…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TechnicianLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "hard-hat",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "users",
                              "label": "Total technicians",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Available now",
                              "value": "18",
                              "icon": "check-circle"
                            },
                            {
                              "value": "9",
                              "type": "stat-display",
                              "label": "On assignment",
                              "icon": "navigation"
                            },
                            {
                              "type": "stat-display",
                              "icon": "clock",
                              "label": "Avg response",
                              "value": "12m"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "gap": "sm",
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TechnicianLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TECHNICIAN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.phone",
                    "@payload.row.phone"
                  ],
                  [
                    "set",
                    "@entity.skills",
                    "@payload.row.skills"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.row.available"
                  ],
                  [
                    "set",
                    "@entity.currentOrderId",
                    "@payload.row.currentOrderId"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.row.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.row.lng"
                  ],
                  [
                    "set",
                    "@entity.lastSeenAt",
                    "@payload.row.lastSeenAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "label": "Back",
                              "type": "button"
                            },
                            {
                              "name": "hard-hat",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "variant": "primary",
                              "label": "@entity.lastSeenAt"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Phone",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.phone",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "content": "Current order",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.currentOrderId"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Last seen",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.lastSeenAt",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Latitude",
                              "value": "@entity.lat",
                              "icon": "map-pin"
                            },
                            {
                              "label": "Longitude",
                              "icon": "map-pin",
                              "type": "stat-display",
                              "value": "@entity.lng"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "action": "ASSIGN",
                              "variant": "primary",
                              "actionPayload": {
                                "technicianId": "@entity.id",
                                "orderId": "@entity.currentOrderId"
                              },
                              "type": "button",
                              "label": "Assign"
                            },
                            {
                              "variant": "secondary",
                              "actionPayload": {
                                "technicianId": "@entity.id"
                              },
                              "type": "button",
                              "label": "Accept",
                              "action": "ACCEPT"
                            },
                            {
                              "variant": "danger",
                              "actionPayload": {
                                "technicianId": "@entity.id"
                              },
                              "type": "button",
                              "label": "Reject",
                              "action": "REJECT"
                            },
                            {
                              "action": "TOGGLE_AVAILABLE",
                              "actionPayload": {
                                "technicianId": "@entity.id",
                                "available": false
                              },
                              "label": "Toggle Available",
                              "type": "button",
                              "variant": "secondary"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Assigning technician…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ACCEPT",
                "effects": [
                  [
                    "emit",
                    "AssignmentAccepted",
                    {
                      "technicianId": "@payload.technicianId"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "emit",
                    "AssignmentRejected",
                    {
                      "technicianId": "@payload.technicianId"
                    }
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Releasing technician…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TOGGLE_AVAILABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.available"
                  ],
                  [
                    "persist",
                    "update",
                    "Technician",
                    "@entity",
                    {
                      "emit": {
                        "success": "TechnicianUpdated",
                        "failure": "TechnicianUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Updating availability…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TechnicianUpdated",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TechnicianUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "AssignmentAccepted"
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "AssignmentRejected"
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading technicians…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Assigning technician…",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACCEPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Confirming assignment…",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Releasing technician…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TOGGLE_AVAILABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Updating availability…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "name": "name",
                  "label": "Technician",
                  "variant": "body"
                },
                {
                  "variant": "caption",
                  "label": "Skills",
                  "name": "skills"
                },
                {
                  "label": "Available",
                  "name": "available",
                  "variant": "badge"
                },
                {
                  "label": "Current Order",
                  "name": "currentOrderId",
                  "variant": "caption"
                },
                {
                  "label": "Last Seen",
                  "name": "lastSeenAt",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Technician entity"
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_TECHNICIAN",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "label": "Assign",
                  "variant": "danger",
                  "event": "ASSIGN"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each technician row"
            },
            "title": {
              "type": "string",
              "default": "Dispatch Board",
              "label": "Section title",
              "description": "Heading shown above the technician dispatch board"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TechnicianDispatchPage",
          "path": "/technicians/dispatch",
          "traits": [
            {
              "ref": "TechnicianDispatch"
            }
          ]
        }
      ]
    }
  ]
}
