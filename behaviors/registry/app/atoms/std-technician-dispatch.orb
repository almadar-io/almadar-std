{
  "name": "std-technician-dispatch",
  "version": "1.2.0",
  "description": "std-technician-dispatch — dispatch board for field technicians. Exposes Service/Operations knobs (serviceAreaRadius, dispatchStrategy, responseTimeMinutes, …).",
  "orbitals": [
    {
      "name": "TechnicianDispatchOrbital",
      "entity": {
        "name": "Technician",
        "collection": "technicians",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "phone",
            "type": "string"
          },
          {
            "name": "skills",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "available",
            "type": "boolean",
            "default": true
          },
          {
            "name": "currentOrderId",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "lastSeenAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TechnicianDispatch",
          "category": "interaction",
          "linkedEntity": "Technician",
          "emits": [
            {
              "event": "OPEN_TECHNICIAN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.skills",
                  "type": "[string]"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.currentOrderId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.lastSeenAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ASSIGN",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "orderId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ACCEPT",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REJECT",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TOGGLE_AVAILABLE",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "available",
                  "type": "boolean",
                  "required": true
                }
              ]
            },
            {
              "event": "TechnicianLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Technician]"
                }
              ]
            },
            {
              "event": "TechnicianLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TechnicianUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.skills",
                  "type": "[string]"
                },
                {
                  "name": "row.available",
                  "type": "boolean"
                },
                {
                  "name": "row.currentOrderId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.lastSeenAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TechnicianUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AssignmentAccepted",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AssignmentRejected",
              "payloadSchema": [
                {
                  "name": "technicianId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TechnicianLoaded",
                "name": "Technician loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Technician]"
                  }
                ]
              },
              {
                "key": "TechnicianLoadFailed",
                "name": "Technician load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TECHNICIAN",
                "name": "Open Technician",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Technician"
                  }
                ]
              },
              {
                "key": "ASSIGN",
                "name": "Assign",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "orderId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ACCEPT",
                "name": "Accept",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT",
                "name": "Reject",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOGGLE_AVAILABLE",
                "name": "Toggle Available",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "available",
                    "type": "boolean",
                    "required": true
                  }
                ]
              },
              {
                "key": "TechnicianUpdated",
                "name": "Technician updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Technician"
                  }
                ]
              },
              {
                "key": "TechnicianUpdateFailed",
                "name": "Technician update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AssignmentAccepted",
                "name": "Assignment accepted",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "AssignmentRejected",
                "name": "Assignment rejected",
                "payloadSchema": [
                  {
                    "name": "technicianId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading technicians…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TechnicianLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "hard-hat",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "users",
                              "label": "Total technicians",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "value": "18",
                              "label": "Available now",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "icon": "navigation",
                              "label": "On assignment",
                              "value": "9"
                            },
                            {
                              "type": "stat-display",
                              "value": "12m",
                              "label": "Avg response",
                              "icon": "clock"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "cols": 1.0
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TechnicianLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TECHNICIAN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.phone",
                    "@payload.row.phone"
                  ],
                  [
                    "set",
                    "@entity.skills",
                    "@payload.row.skills"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.row.available"
                  ],
                  [
                    "set",
                    "@entity.currentOrderId",
                    "@payload.row.currentOrderId"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.row.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.row.lng"
                  ],
                  [
                    "set",
                    "@entity.lastSeenAt",
                    "@payload.row.lastSeenAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "hard-hat"
                            },
                            {
                              "content": "@entity.name",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.lastSeenAt"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Phone",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.phone",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Current order"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.currentOrderId",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Last seen",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.lastSeenAt",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "icon": "map-pin",
                              "type": "stat-display",
                              "value": "@entity.lat",
                              "label": "Latitude"
                            },
                            {
                              "type": "stat-display",
                              "icon": "map-pin",
                              "label": "Longitude",
                              "value": "@entity.lng"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "ASSIGN",
                              "variant": "primary",
                              "actionPayload": {
                                "orderId": "@entity.currentOrderId",
                                "technicianId": "@entity.id"
                              },
                              "label": "Assign",
                              "type": "button"
                            },
                            {
                              "actionPayload": {
                                "technicianId": "@entity.id"
                              },
                              "action": "ACCEPT",
                              "label": "Accept",
                              "variant": "secondary",
                              "type": "button"
                            },
                            {
                              "label": "Reject",
                              "variant": "danger",
                              "type": "button",
                              "action": "REJECT",
                              "actionPayload": {
                                "technicianId": "@entity.id"
                              }
                            },
                            {
                              "action": "TOGGLE_AVAILABLE",
                              "label": "Toggle Available",
                              "variant": "secondary",
                              "type": "button",
                              "actionPayload": {
                                "technicianId": "@entity.id",
                                "available": false
                              }
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Assigning technician…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ACCEPT",
                "effects": [
                  [
                    "emit",
                    "AssignmentAccepted",
                    {
                      "technicianId": "@payload.technicianId"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "emit",
                    "AssignmentRejected",
                    {
                      "technicianId": "@payload.technicianId"
                    }
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Releasing technician…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TOGGLE_AVAILABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "set",
                    "@entity.available",
                    "@payload.available"
                  ],
                  [
                    "persist",
                    "update",
                    "Technician",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TechnicianUpdateFailed",
                        "success": "TechnicianUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Updating availability…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TechnicianUpdated",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TechnicianUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "AssignmentAccepted"
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "AssignmentRejected"
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading technicians…",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Assigning technician…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACCEPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Confirming assignment…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Releasing technician…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TOGGLE_AVAILABLE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.technicianId"
                  ],
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "failure": "TechnicianLoadFailed",
                        "success": "TechnicianLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Updating availability…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Technician",
                    {
                      "emit": {
                        "success": "TechnicianLoaded",
                        "failure": "TechnicianLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "name",
                  "label": "Technician",
                  "variant": "body"
                },
                {
                  "label": "Skills",
                  "variant": "caption",
                  "name": "skills"
                },
                {
                  "variant": "badge",
                  "name": "available",
                  "label": "Available"
                },
                {
                  "variant": "caption",
                  "name": "currentOrderId",
                  "label": "Current Order"
                },
                {
                  "label": "Last Seen",
                  "variant": "caption",
                  "name": "lastSeenAt"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Technician entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "dispatchStrategy": {
              "type": "string",
              "default": "nearest",
              "label": "Dispatch strategy",
              "description": "How techs are selected: nearest, round-robin, or manual pick.",
              "tier": "domain",
              "values": [
                "nearest",
                "round-robin",
                "manual"
              ]
            },
            "requirePhotoOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require photo on complete",
              "description": "Block job completion until the tech attaches a completion photo.",
              "tier": "domain"
            },
            "requireSignatureOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require customer signature on complete",
              "description": "Block completion unless customer signature is captured (compose std-signature-capture).",
              "tier": "domain"
            },
            "serviceZones": {
              "type": "[string]",
              "default": [],
              "label": "Service zones",
              "description": "Named geographic zones for dispatch grouping. Empty = no zone restriction.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "skillsRequired": {
              "type": "[string]",
              "default": [],
              "label": "Required skills",
              "description": "Capability tags a tech must hold to be eligible for the queue.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "default": "Dispatch Board",
              "label": "Section title",
              "description": "Heading shown above the technician dispatch board",
              "tier": "presentation"
            },
            "customerVisibleStatuses": {
              "type": "[string]",
              "default": [
                "available",
                "en-route",
                "on-site"
              ],
              "label": "Customer-visible statuses",
              "description": "Subset of tech statuses surfaced in the customer tracking view.",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_TECHNICIAN",
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary"
                },
                {
                  "event": "ASSIGN",
                  "variant": "danger",
                  "label": "Assign"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each technician row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "escalationThresholdHours": {
              "type": "number",
              "default": 12.0,
              "label": "Escalation threshold (hours)",
              "description": "Hours after which an unacknowledged dispatch auto-escalates.",
              "tier": "domain"
            },
            "serviceAreaRadius": {
              "type": "number",
              "default": 50.0,
              "label": "Service area radius (mi)",
              "description": "Maximum distance from a tech's home base for dispatch eligibility.",
              "tier": "domain"
            },
            "responseTimeMinutes": {
              "type": "number",
              "default": 30.0,
              "label": "Response time SLA (min)",
              "description": "Target minutes from dispatch to tech acknowledgement.",
              "tier": "domain"
            },
            "resolutionSLAHours": {
              "type": "number",
              "default": 8.0,
              "label": "Resolution SLA (hours)",
              "description": "Target hours from dispatch to job completion. Compose std-lifecycle to auto-escalate.",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TechnicianDispatchPage",
          "path": "/technicians/dispatch",
          "traits": [
            {
              "ref": "TechnicianDispatch"
            }
          ]
        }
      ]
    }
  ]
}