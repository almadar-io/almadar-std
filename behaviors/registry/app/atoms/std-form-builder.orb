            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT_QUESTIONS_JSON",
                "name": "Edit Questions Json",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
