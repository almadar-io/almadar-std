                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "QuestionsSaveFailed",
                        "success": "SurveyHydrated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "list-checks",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "action": "EDIT_QUESTIONS_JSON",
