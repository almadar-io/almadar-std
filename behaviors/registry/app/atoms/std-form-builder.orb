              },
              {
                "key": "SAVE_QUESTIONS",
                "name": "Save Questions"
              },
              {
                "key": "SurveyHydrated",
                "name": "Survey hydrated",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "QuestionsChanged",
                "name": "Questions changed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "QuestionsSaveFailed",
                "name": "Questions save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
