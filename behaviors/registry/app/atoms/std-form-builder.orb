                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "QuestionsChanged",
                        "failure": "QuestionsSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SurveyHydrated"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QuestionsChanged"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QuestionsSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
