                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "resolutionSLAHours": {
              "type": "number",
              "default": 24.0,
              "label": "Resolution SLA (hours)",
              "description": "Target hours from ticket created to resolved.",
              "synonyms": "time to resolve",
              "tier": "domain"
            },
            "categories": {
