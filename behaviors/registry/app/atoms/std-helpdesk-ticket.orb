                },
                {
                  "label": "Close",
                  "variant": "danger",
                  "icon": "x",
                  "event": "CLOSE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each ticket row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "autoCloseInactiveDays": {
              "type": "number",
              "default": 7.0,
              "label": "Auto-close inactive (days)",
              "description": "Days a 'resolved' ticket stays open for re-open before auto-closing.",
              "tier": "domain"
            },
            "slaTier": {
              "type": "string",
              "default": "silver",
              "label": "SLA tier",
              "description": "Service-level tier from the customer's contract",
              "synonyms": "service level, support tier, plan",
              "tier": "domain",
              "values": [
                "bronze",
                "silver",
                "gold",
                "platinum"
              ]
            },
            "responseTimeMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "First-response SLA (min)",
              "description": "Target minutes from ticket created to first agent reply.",
              "synonyms": "first reply time, response time",
              "tier": "domain"
            },
            "escalationMatrix": {
              "type": "[string]",
              "default": [
                "L1",
                "L2",
                "manager"
              ],
              "label": "Escalation matrix",
              "description": "Ordered roles a ticket escalates through when SLA breaches.",
              "synonyms": "escalation roles, escalation chain",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "default": "Tickets",
              "label": "Section title",
              "description": "Heading shown above the helpdesk tickets list",
              "tier": "presentation"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
