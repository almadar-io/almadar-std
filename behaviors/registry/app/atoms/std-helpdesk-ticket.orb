{
  "name": "std-helpdesk-ticket",
  "version": "1.0.0",
  "description": "std-helpdesk-ticket — support ticket lifecycle (new → open → pending → resolved → closed). Listens for SET_STATUS so siblings can drive automated transitions. Exposes Helpdesk-pattern knobs (slaTier, severity, response/resolution SLA, escalationMatrix, routingStrategy, …).",
  "orbitals": [
    {
      "name": "TicketOrbital",
      "entity": {
        "name": "Ticket",
        "collection": "tickets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "requester",
            "type": "string",
            "required": true
          },
          {
            "name": "assignedTo",
            "type": "string"
          },
          {
            "name": "priority",
            "type": "string",
            "default": "normal",
            "values": [
              "low",
              "normal",
              "high",
              "urgent"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "new",
            "values": [
              "new",
              "open",
              "pending",
              "resolved",
              "closed"
            ]
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "firstReplyAt",
            "type": "string"
          },
          {
            "name": "resolvedAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TicketManage",
          "category": "interaction",
          "linkedEntity": "Ticket",
          "emits": [
            {
              "event": "OPEN_TICKET",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requester",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.firstReplyAt",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REPLY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requester",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.firstReplyAt",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ASSIGN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "assignedTo",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requester",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.firstReplyAt",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requester",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.firstReplyAt",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.requester",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.firstReplyAt",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Ticket]"
                }
              ]
            },
            {
              "event": "TicketLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TicketLoaded",
                "name": "Ticket loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Ticket]"
                  }
                ]
              },
              {
                "key": "TicketLoadFailed",
                "name": "Ticket load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TICKET",
                "name": "Open Ticket",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "REPLY",
                "name": "Reply",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "ASSIGN",
                "name": "Assign",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "assignedTo",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading tickets…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TicketLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "life-buoy"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "life-buoy",
                              "label": "Total tickets",
                              "type": "stat-display"
                            },
                            {
                              "value": "9",
                              "icon": "alert-triangle",
                              "label": "Urgent open",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Pending",
                              "icon": "clock",
                              "value": "14"
                            },
                            {
                              "icon": "check-circle",
                              "value": "47",
                              "label": "Resolved today",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TicketLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TICKET",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.subject",
                    "@payload.row.subject"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.requester",
                    "@payload.row.requester"
                  ],
                  [
                    "set",
                    "@entity.assignedTo",
                    "@payload.row.assignedTo"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.row.priority"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.category",
                    "@payload.row.category"
                  ],
                  [
                    "set",
                    "@entity.firstReplyAt",
                    "@payload.row.firstReplyAt"
                  ],
                  [
                    "set",
                    "@entity.resolvedAt",
                    "@payload.row.resolvedAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "life-buoy"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.subject",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "type": "badge",
                              "label": "@entity.priority"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Requester",
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.requester",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Category",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.category"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Assigned to",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.assignedTo",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Description",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.description"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 3.0,
                          "children": [
                            {
                              "value": "@entity.firstReplyAt",
                              "icon": "message-circle",
                              "label": "First reply",
                              "type": "stat-display"
                            },
                            {
                              "icon": "check",
                              "type": "stat-display",
                              "label": "Resolved",
                              "value": "@entity.resolvedAt"
                            },
                            {
                              "label": "Created",
                              "type": "stat-display",
                              "value": "@entity.createdAt",
                              "icon": "calendar-plus"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Reply",
                              "action": "REPLY",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              }
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id",
                                "assignedTo": "@entity.assignedTo",
                                "row": "@entity"
                              },
                              "variant": "secondary",
                              "action": "ASSIGN",
                              "label": "Assign"
                            },
                            {
                              "variant": "secondary",
                              "action": "ESCALATE",
                              "label": "Escalate",
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "label": "Close",
                              "variant": "danger",
                              "action": "CLOSE"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Closing ticket…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Ticket",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TicketLoadFailed",
                        "success": "TicketLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Updating ticket status…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "failure": "TicketLoadFailed",
                        "success": "TicketLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading tickets…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REPLY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Sending reply…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Assigning ticket…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Escalating ticket…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Closing ticket…"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "csatSurveySentAfterDays": {
              "type": "number",
              "default": 1.0,
              "label": "CSAT survey delay (days)",
              "description": "Days after resolution before the satisfaction survey is sent. 0 = immediate.",
              "synonyms": "customer satisfaction, survey delay",
              "tier": "domain"
            },
            "routingStrategy": {
              "type": "string",
              "default": "skills",
              "label": "Routing strategy",
              "description": "How new tickets are assigned to agents.",
              "synonyms": "assignment strategy, dispatch",
              "tier": "domain",
              "values": [
                "round-robin",
                "skills",
                "manual",
                "load-balanced"
              ]
            },
            "severity": {
              "type": "string",
              "default": "medium",
              "label": "Severity",
              "description": "Default severity for new tickets when not explicitly classified.",
              "synonyms": "impact, urgency",
              "tier": "domain",
              "values": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            },
            "firstReplyDeadline": {
              "type": "number",
              "default": 60.0,
              "label": "First-reply deadline (min)",
              "description": "Hard deadline that triggers escalation if no agent has replied.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_TICKET",
