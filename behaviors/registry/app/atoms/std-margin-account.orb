{
  "name": "std-margin-account",
  "version": "1.0.0",
  "description": "std-margin-account — margin account leverage and call thresholds for trading apps.",
  "orbitals": [
    {
      "name": "MarginAccountOrbital",
      "entity": {
        "name": "MarginAccount",
        "collection": "margin_accounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "accountHolderId",
            "type": "string",
            "required": true
          },
          {
            "name": "equityUSD",
            "type": "number"
          },
          {
            "name": "marginUsedUSD",
            "type": "number"
          },
          {
            "name": "marginAvailableUSD",
            "type": "number"
          },
          {
            "name": "status",
            "type": "string",
            "default": "good-standing",
            "values": [
              "good-standing",
              "warning",
              "margin-call",
              "liquidated"
            ]
          },
          {
            "name": "lastCallAt",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "MarginAccountManage",
          "category": "interaction",
          "linkedEntity": "MarginAccount",
          "emits": [
            {
              "event": "OPEN_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.accountHolderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.equityUSD",
                  "type": "number"
                },
                {
                  "name": "row.marginUsedUSD",
                  "type": "number"
                },
                {
                  "name": "row.marginAvailableUSD",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastCallAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ISSUE_CALL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.accountHolderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.equityUSD",
                  "type": "number"
                },
                {
                  "name": "row.marginUsedUSD",
                  "type": "number"
                },
                {
                  "name": "row.marginAvailableUSD",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastCallAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LIQUIDATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.accountHolderId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.equityUSD",
                  "type": "number"
                },
                {
                  "name": "row.marginUsedUSD",
                  "type": "number"
                },
                {
                  "name": "row.marginAvailableUSD",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.lastCallAt",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MarginAccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MarginAccount]"
                }
              ]
            },
            {
              "event": "MarginAccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MarginAccountLoaded",
                "name": "MarginAccount loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MarginAccount]"
                  }
                ]
              },
              {
                "key": "MarginAccountLoadFailed",
                "name": "MarginAccount load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ACCOUNT",
                "name": "Open Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MarginAccount"
                  }
                ]
              },
              {
                "key": "ISSUE_CALL",
                "name": "Issue Call",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MarginAccount"
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "LIQUIDATE",
                "name": "Liquidate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MarginAccount"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MarginAccount",
                    {
                      "emit": {
                        "success": "MarginAccountLoaded",
                        "failure": "MarginAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading margin accounts…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MarginAccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "trending-up",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total accounts",
                              "value": "@payload.data.length",
                              "icon": "trending-up"
                            },
                            {
                              "value": "184",
                              "icon": "check-circle",
                              "label": "Good standing",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "12",
                              "label": "Warning",
                              "icon": "alert-triangle"
                            },
                            {
                              "icon": "phone",
                              "type": "stat-display",
                              "label": "Margin calls",
                              "value": "3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "cols": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MarginAccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.accountHolderId",
                    "@payload.row.accountHolderId"
                  ],
                  [
                    "set",
                    "@entity.equityUSD",
                    "@payload.row.equityUSD"
                  ],
                  [
                    "set",
                    "@entity.marginUsedUSD",
                    "@payload.row.marginUsedUSD"
                  ],
                  [
                    "set",
                    "@entity.marginAvailableUSD",
                    "@payload.row.marginAvailableUSD"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.lastCallAt",
                    "@payload.row.lastCallAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button"
                            },
                            {
                              "name": "trending-up",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.accountHolderId",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Equity",
                              "icon": "dollar-sign",
                              "value": "@entity.equityUSD"
                            },
                            {
                              "label": "Margin Used",
                              "value": "@entity.marginUsedUSD",
                              "type": "stat-display",
                              "icon": "dollar-sign"
                            },
                            {
                              "type": "stat-display",
                              "label": "Margin Available",
                              "value": "@entity.marginAvailableUSD",
                              "icon": "dollar-sign"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Last Call",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.lastCallAt",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Created",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.createdAt"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Issue Call",
                              "action": "ISSUE_CALL",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "danger"
                            },
                            {
                              "type": "button",
                              "label": "Liquidate",
                              "action": "LIQUIDATE",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ISSUE_CALL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MarginAccount",
                    {
                      "emit": {
                        "success": "MarginAccountLoaded",
                        "failure": "MarginAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Issuing margin call…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "MarginAccount",
                    {
                      "emit": {
                        "failure": "MarginAccountLoadFailed",
                        "success": "MarginAccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading margin accounts…",
                          "color": "muted"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ISSUE_CALL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MarginAccount",
                    {
                      "emit": {
                        "success": "MarginAccountLoaded",
                        "failure": "MarginAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Issuing margin call…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "LIQUIDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "MarginAccount",
                    {
                      "emit": {
                        "failure": "MarginAccountLoadFailed",
                        "success": "MarginAccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Liquidating positions…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MarginAccount",
                    {
                      "emit": {
                        "failure": "MarginAccountLoadFailed",
                        "success": "MarginAccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Margin Accounts",
              "label": "Section title",
              "description": "Heading shown above the margin account list",
              "tier": "presentation"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Holder",
                  "name": "accountHolderId",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Equity",
                  "name": "equityUSD"
                },
                {
                  "name": "marginUsedUSD",
                  "variant": "caption",
                  "label": "Used"
                },
                {
                  "name": "marginAvailableUSD",
                  "label": "Available",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "name": "lastCallAt",
                  "label": "Last Call"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the MarginAccount entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "icon": "arrow-right",
                  "event": "OPEN_ACCOUNT",
                  "label": "Open"
                },
                {
                  "label": "Issue Call",
                  "event": "ISSUE_CALL",
                  "variant": "danger",
                  "icon": "alert-triangle"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each margin account row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "marginCallThresholdPct": {
              "type": "number",
              "default": 30.0,
              "label": "Margin call threshold (%)",
              "description": "Equity percentage at which margin call is issued.",
              "synonyms": "maintenance margin",
              "tier": "domain"
            },
            "marginLeverage": {
              "type": "string",
              "default": "2x",
              "label": "Margin leverage",
              "description": "Maximum leverage ratio permitted (regulatory + risk-appetite driven).",
              "synonyms": "leverage ratio, max leverage",
              "tier": "domain",
              "values": [
                "2x",
                "4x",
                "10x",
                "20x"
              ]
            },
            "forcedLiquidationThresholdPct": {
              "type": "number",
              "default": 20.0,
              "label": "Forced liquidation threshold (%)",
              "description": "Equity percentage at which positions are auto-liquidated to cover the loan.",
              "synonyms": "liquidation trigger",
              "tier": "domain"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MarginAccountManagePage",
          "path": "/margin-accounts/manage",
          "traits": [
            {
              "ref": "MarginAccountManage"
            }
          ]
        }
      ]
    }
  ]
}