{
  "name": "std-matter",
  "version": "1.0.0",
  "description": "std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference.",
  "orbitals": [
    {
      "name": "MatterOrbital",
      "entity": {
        "name": "Matter",
        "collection": "matters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "clientName",
            "type": "string",
            "required": true
          },
          {
            "name": "practiceArea",
            "type": "string",
            "default": "other",
            "values": [
              "litigation",
              "transactional",
              "regulatory",
              "ip",
              "immigration",
              "family",
              "other"
            ]
          },
          {
            "name": "leadAttorney",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "active",
              "on_hold",
              "closed",
              "archived"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "closedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MatterDocket",
          "category": "interaction",
          "linkedEntity": "Matter",
          "emits": [
            {
              "event": "CLOSE_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HOLD_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REOPEN_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MatterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Matter]"
                }
              ]
            },
            {
              "event": "MatterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MatterLoaded",
                "name": "Matter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Matter]"
                  }
                ]
              },
              {
                "key": "MatterLoadFailed",
                "name": "Matter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_MATTER",
                "name": "Close Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HOLD_MATTER",
                "name": "Hold Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REOPEN_MATTER",
                "name": "Reopen Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading matters…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MatterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "breadcrumb",
                          "items": [
                            {
                              "label": "Court"
                            },
                            {
                              "label": "Cases"
                            },
                            {
                              "label": "Matter"
                            }
                          ]
                        },
                        {
                          "currentStep": 1.0,
                          "type": "wizard-progress",
                          "steps": [
                            {
                              "id": "intake",
                              "title": "Intake"
                            },
                            {
                              "id": "discovery",
                              "title": "Discovery"
                            },
                            {
                              "id": "pretrial",
                              "title": "Pre-Trial"
                            },
                            {
                              "title": "Trial",
                              "id": "trial"
                            },
                            {
                              "id": "closed",
                              "title": "Closed"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "scale"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "tree": [
                                {
                                  "name": "Pleadings",
                                  "type": "dir",
                                  "path": "Pleadings",
                                  "children": [
                                    {
                                      "path": "Complaint.pdf",
                                      "name": "Complaint.pdf",
                                      "type": "file"
                                    },
                                    {
                                      "path": "Answer.pdf",
                                      "name": "Answer.pdf",
                                      "type": "file"
                                    }
                                  ]
                                },
                                {
                                  "children": [
                                    {
                                      "name": "Interrogatories.pdf",
                                      "path": "Discovery/Interrogatories.pdf",
                                      "type": "file"
                                    },
                                    {
                                      "type": "dir",
                                      "name": "Depositions",
                                      "children": [
                                        {
                                          "name": "Smith.pdf",
                                          "path": "Discovery/Depositions/Smith.pdf",
                                          "type": "file"
                                        }
                                      ],
                                      "path": "Discovery/Depositions"
                                    }
                                  ],
                                  "type": "dir",
                                  "name": "Discovery",
                                  "path": "Discovery"
                                },
                                {
                                  "name": "Motions",
                                  "path": "Motions",
                                  "type": "dir",
                                  "children": [
                                    {
                                      "name": "Motion-to-Dismiss.pdf",
                                      "path": "Motions/Motion-to-Dismiss.pdf",
                                      "type": "file"
                                    }
                                  ]
                                }
                              ],
                              "type": "file-tree"
                            },
                            {
                              "children": [
                                {
                                  "type": "accordion",
                                  "items": [
                                    {
                                      "id": "facts",
                                      "title": "Facts of the Case",
                                      "content": "Plaintiff alleges breach of contract dated 2025-08-01."
                                    },
                                    {
                                      "title": "Legal Issues",
                                      "id": "issues",
                                      "content": "Material breach, damages calculation, statute of limitations."
                                    },
                                    {
                                      "id": "strategy",
                                      "title": "Strategy",
                                      "content": "Motion practice followed by summary judgment."
                                    }
                                  ]
                                },
                                {
                                  "type": "law-reference-tooltip",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "content": "Rule 12(b)(6) motion pending"
                                    }
                                  ],
                                  "reference": {
                                    "clause": "Failure to State a Claim",
                                    "law": "FRCP",
                                    "article": "12(b)(6)"
                                  },
                                  "position": "top"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "title": "Complaint.pdf",
                          "showToolbar": true,
                          "totalPages": 24.0,
                          "type": "document-viewer",
                          "src": "/docs/complaint.pdf",
                          "currentPage": 1.0,
                          "documentType": "pdf"
                        },
                        {
                          "next": {
                            "href": "#next",
                            "label": "Next Page"
                          },
                          "type": "doc-pagination",
                          "prev": {
                            "label": "Previous Page",
                            "href": "#prev"
                          }
                        },
                        {
                          "activeQuestId": "answer-due",
                          "type": "quest-tracker",
                          "quests": [
                            {
                              "progress": 0.0,
                              "id": "answer-due",
                              "title": "File Answer",
                              "maxProgress": 1.0,
                              "active": true
                            },
                            {
                              "maxProgress": 1.0,
                              "progress": 0.0,
                              "title": "Discovery Cutoff",
                              "id": "discovery-cutoff"
                            },
                            {
                              "id": "pretrial-brief",
                              "progress": 0.0,
                              "title": "Pretrial Brief",
                              "maxProgress": 1.0
                            }
                          ]
                        },
                        {
                          "direction": "ltr",
                          "type": "content-renderer",
                          "content": "Status conference scheduled. All parties to appear. Discovery is ongoing."
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Matter #",
                              "name": "matterNumber"
                            },
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "label": "Client",
                              "name": "clientName",
                              "variant": "caption"
                            },
                            {
                              "label": "Practice",
                              "variant": "badge",
                              "name": "practiceArea"
                            },
                            {
                              "variant": "caption",
                              "name": "leadAttorney",
                              "label": "Lead"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "cols": 1.0,
                          "gap": "sm",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "CLOSE_MATTER",
                              "label": "Close",
                              "variant": "primary"
                            },
                            {
                              "event": "HOLD_MATTER",
                              "label": "Hold",
                              "variant": "ghost"
                            },
                            {
                              "event": "REOPEN_MATTER",
                              "variant": "ghost",
                              "label": "Reopen"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MatterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CLOSE_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Matter closed",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "HOLD_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Matter on hold",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REOPEN_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Matter reopened"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Matters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MatterPage",
          "path": "/matters",
          "traits": [
            {
              "ref": "MatterDocket"
            }
          ]
        }
      ]
    }
  ]
}
