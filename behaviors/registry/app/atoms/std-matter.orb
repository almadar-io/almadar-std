{
  "name": "std-matter",
  "version": "1.0.0",
  "description": "std-matter — legal matter primitive: a single case (litigation, contract review, immigration filing) with client, status, lead attorney. Lists matters in `browsing`; opens matter detail in `viewing_single` with Close / Hold / Reopen actions.",
  "orbitals": [
    {
      "name": "MatterOrbital",
      "entity": {
        "name": "Matter",
        "collection": "matters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "clientName",
            "type": "string",
            "required": true
          },
          {
            "name": "practiceArea",
            "type": "string",
            "default": "other",
            "values": [
              "litigation",
              "transactional",
              "regulatory",
              "ip",
              "immigration",
              "family",
              "other"
            ]
          },
          {
            "name": "leadAttorney",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "active",
              "on_hold",
              "closed",
              "archived"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "closedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MatterDocket",
          "category": "interaction",
          "linkedEntity": "Matter",
          "emits": [
            {
              "event": "OPEN_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "CLOSE_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "HOLD_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REOPEN_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MatterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Matter]"
                }
              ]
            },
            {
              "event": "MatterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MatterLoaded",
                "name": "Matter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Matter]"
                  }
                ]
              },
              {
                "key": "MatterLoadFailed",
                "name": "Matter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_MATTER",
                "name": "Open Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Matter"
                  }
                ]
              },
              {
                "key": "CLOSE_MATTER",
                "name": "Close Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "HOLD_MATTER",
                "name": "Hold Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REOPEN_MATTER",
                "name": "Reopen Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading matters…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MatterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "scale"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Total matters",
                              "type": "stat-display",
                              "icon": "scale"
                            },
                            {
                              "label": "Active",
                              "value": "34",
                              "type": "stat-display",
                              "icon": "play-circle"
                            },
                            {
                              "value": "6",
                              "icon": "pause-circle",
                              "type": "stat-display",
                              "label": "On hold"
                            },
                            {
                              "type": "stat-display",
                              "label": "Closed this month",
                              "icon": "check-circle",
                              "value": "12"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "icon": "arrow-right",
                              "variant": "primary",
                              "label": "Open",
                              "event": "OPEN_MATTER"
                            },
                            {
                              "label": "Close",
                              "event": "CLOSE_MATTER",
                              "variant": "danger"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "matterNumber",
                              "label": "Matter #"
                            },
                            {
                              "variant": "caption",
                              "label": "Title",
                              "name": "title"
                            },
                            {
                              "label": "Client",
                              "name": "clientName",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "practiceArea",
                              "label": "Practice"
                            },
                            {
                              "variant": "caption",
                              "name": "leadAttorney",
                              "label": "Lead"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MatterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.matterNumber",
                    "@payload.row.matterNumber"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.clientName",
                    "@payload.row.clientName"
                  ],
                  [
                    "set",
                    "@entity.practiceArea",
                    "@payload.row.practiceArea"
                  ],
                  [
                    "set",
                    "@entity.leadAttorney",
                    "@payload.row.leadAttorney"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.openedAt",
                    "@payload.row.openedAt"
                  ],
                  [
                    "set",
                    "@entity.closedAt",
                    "@payload.row.closedAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "scale"
                            },
                            {
                              "content": "@entity.title",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.practiceArea",
                              "variant": "primary",
                              "type": "badge"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Matter #",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.matterNumber"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Client",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.clientName"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Lead attorney",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.leadAttorney",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Notes",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.openedAt",
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Opened"
                            },
                            {
                              "icon": "calendar-check",
                              "type": "stat-display",
                              "value": "@entity.closedAt",
                              "label": "Closed"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_MATTER",
                              "label": "Close Matter",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "danger"
                            },
                            {
                              "type": "button",
                              "label": "Hold",
                              "variant": "secondary",
                              "action": "HOLD_MATTER",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Reopen",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary",
                              "action": "REOPEN_MATTER"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Closing matter…"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading matters…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Closing matter…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "HOLD_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Putting matter on hold…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REOPEN_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Reopening matter…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Matters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MatterPage",
          "path": "/matters",
          "traits": [
            {
              "ref": "MatterDocket"
            }
          ]
        }
      ]
    }
  ]
}
