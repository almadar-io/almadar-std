{
  "name": "std-matter",
  "version": "1.0.0",
  "description": "std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference.",
  "orbitals": [
    {
      "name": "MatterOrbital",
      "entity": {
        "name": "Matter",
        "collection": "matters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "clientName",
            "type": "string",
            "required": true
          },
          {
            "name": "practiceArea",
            "type": "string",
            "default": "other",
            "values": [
              "litigation",
              "transactional",
              "regulatory",
              "ip",
              "immigration",
              "family",
              "other"
            ]
          },
          {
            "name": "leadAttorney",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "active",
              "on_hold",
              "closed",
              "archived"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "closedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MatterDocket",
          "category": "interaction",
          "linkedEntity": "Matter",
          "emits": [
            {
              "event": "CLOSE_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HOLD_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REOPEN_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MatterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Matter]"
                }
              ]
            },
            {
              "event": "MatterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MatterLoaded",
                "name": "Matter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Matter]"
                  }
                ]
              },
              {
                "key": "MatterLoadFailed",
                "name": "Matter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_MATTER",
                "name": "Close Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HOLD_MATTER",
                "name": "Hold Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REOPEN_MATTER",
                "name": "Reopen Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading matters…",
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MatterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "entity": {
                            "id": "matter-overview",
                            "subtitle": "Litigation, contracts, and regulatory cases",
                            "title": "Matter Overview"
                          },
                          "type": "feature-detail-page-template"
                        },
                        {
                          "type": "breadcrumb",
                          "items": [
                            {
                              "label": "Court"
                            },
                            {
                              "label": "Cases"
                            },
                            {
                              "label": "Matter"
                            }
                          ]
                        },
                        {
                          "currentStep": 1.0,
                          "steps": [
                            {
                              "id": "intake",
                              "label": "Intake"
                            },
                            {
                              "label": "Discovery",
                              "id": "discovery"
                            },
                            {
                              "label": "Pre-Trial",
                              "id": "pretrial"
                            },
                            {
                              "id": "trial",
                              "label": "Trial"
                            },
                            {
                              "id": "closed",
                              "label": "Closed"
                            }
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "scale"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "tree": [
                                {
                                  "name": "Pleadings",
                                  "children": [
                                    {
                                      "name": "Complaint.pdf"
                                    },
                                    {
                                      "name": "Answer.pdf"
                                    }
                                  ]
                                },
                                {
                                  "name": "Discovery",
                                  "children": [
                                    {
                                      "name": "Interrogatories.pdf"
                                    },
                                    {
                                      "name": "Depositions",
                                      "children": [
                                        {
                                          "name": "Smith.pdf"
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "children": [
                                    {
                                      "name": "Motion-to-Dismiss.pdf"
                                    }
                                  ],
                                  "name": "Motions"
                                }
                              ],
                              "type": "file-tree"
                            },
                            {
                              "direction": "vertical",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "accordion",
                                  "items": [
                                    {
                                      "id": "facts",
                                      "title": "Facts of the Case",
                                      "content": "Plaintiff alleges breach of contract dated 2025-08-01."
                                    },
                                    {
                                      "id": "issues",
                                      "title": "Legal Issues",
                                      "content": "Material breach, damages calculation, statute of limitations."
                                    },
                                    {
                                      "title": "Strategy",
                                      "content": "Motion practice followed by summary judgment.",
                                      "id": "strategy"
                                    }
                                  ]
                                },
                                {
                                  "position": "top",
                                  "children": [
                                    {
                                      "content": "Rule 12(b)(6) motion pending",
                                      "type": "typography"
                                    }
                                  ],
                                  "type": "law-reference-tooltip",
                                  "reference": {
                                    "title": "Failure to State a Claim",
                                    "citation": "Fed. R. Civ. P. 12(b)(6)"
                                  }
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "document-viewer",
                          "src": "/docs/complaint.pdf",
                          "documentType": "pdf",
                          "title": "Complaint.pdf",
                          "showToolbar": true,
                          "totalPages": 24.0,
                          "currentPage": 1.0
                        },
                        {
                          "type": "doc-pagination",
                          "prev": {
                            "action": "DOC_PREV",
                            "label": "Previous Page"
                          },
                          "next": {
                            "action": "DOC_NEXT",
                            "label": "Next Page"
                          }
                        },
                        {
                          "quests": [
                            {
                              "status": "active",
                              "title": "File Answer",
                              "id": "answer-due",
                              "deadline": "2026-06-15"
                            },
                            {
                              "status": "pending",
                              "id": "discovery-cutoff",
                              "deadline": "2026-08-01",
                              "title": "Discovery Cutoff"
                            },
                            {
                              "title": "Pretrial Brief",
                              "status": "pending",
                              "deadline": "2026-09-15",
                              "id": "pretrial-brief"
                            }
                          ],
                          "type": "quest-tracker",
                          "activeQuestId": "answer-due"
                        },
                        {
                          "data": {
                            "current": "discovery",
                            "initial": "intake",
                            "states": [
                              "intake",
                              "discovery",
                              "pretrial",
                              "trial",
                              "closed"
                            ]
                          },
                          "type": "behavior-view"
                        },
                        {
                          "features": [
                            {
                              "type": "venue",
                              "id": "courthouse",
                              "label": "Superior Court"
                            },
                            {
                              "type": "person",
                              "id": "judge",
                              "label": "Hon. J. Carter"
                            },
                            {
                              "id": "opposing",
                              "type": "party",
                              "label": "Opposing Counsel"
                            }
                          ],
                          "type": "feature-renderer"
                        },
                        {
                          "type": "content-renderer",
                          "content": "Status conference scheduled. All parties to appear. Discovery is ongoing.",
                          "direction": "ltr"
                        },
                        {
                          "cols": 1.0,
                          "gap": "sm",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "CLOSE_MATTER",
                              "label": "Close",
                              "variant": "primary"
                            },
                            {
                              "event": "HOLD_MATTER",
                              "variant": "ghost",
                              "label": "Hold"
                            },
                            {
                              "label": "Reopen",
                              "variant": "ghost",
                              "event": "REOPEN_MATTER"
                            }
                          ],
                          "fields": [
                            {
                              "name": "matterNumber",
                              "label": "Matter #",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "title",
                              "label": "Title"
                            },
                            {
                              "variant": "caption",
                              "name": "clientName",
                              "label": "Client"
                            },
                            {
                              "name": "practiceArea",
                              "variant": "badge",
                              "label": "Practice"
                            },
                            {
                              "variant": "caption",
                              "label": "Lead",
                              "name": "leadAttorney"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MatterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CLOSE_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Matter closed"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "HOLD_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Matter on hold"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REOPEN_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Matter reopened",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Matters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MatterPage",
          "path": "/matters",
          "traits": [
            {
              "ref": "MatterDocket"
            }
          ]
        }
      ]
    }
  ]
}