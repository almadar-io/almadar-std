{
  "name": "std-matter",
  "version": "1.0.0",
  "description": "std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference.",
  "orbitals": [
    {
      "name": "MatterOrbital",
      "entity": {
        "name": "Matter",
        "collection": "matters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "clientName",
            "type": "string",
            "required": true
          },
          {
            "name": "practiceArea",
            "type": "string",
            "default": "other",
            "values": [
              "litigation",
              "transactional",
              "regulatory",
              "ip",
              "immigration",
              "family",
              "other"
            ]
          },
          {
            "name": "leadAttorney",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "active",
              "on_hold",
              "closed",
              "archived"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "closedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MatterDocket",
          "category": "interaction",
          "linkedEntity": "Matter",
          "emits": [
            {
              "event": "CLOSE_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HOLD_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REOPEN_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MatterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Matter]"
                }
              ]
            },
            {
              "event": "MatterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MatterLoaded",
                "name": "Matter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Matter]"
                  }
                ]
              },
              {
                "key": "MatterLoadFailed",
                "name": "Matter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_MATTER",
                "name": "Close Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HOLD_MATTER",
                "name": "Hold Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REOPEN_MATTER",
                "name": "Reopen Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading matters…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MatterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "scale"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "gap": "sm",
                          "fields": [
                            {
                              "name": "matterNumber",
                              "label": "Matter #",
                              "variant": "caption"
                            },
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "clientName",
                              "label": "Client"
                            },
                            {
                              "name": "practiceArea",
                              "label": "Practice",
                              "variant": "badge"
                            },
                            {
                              "name": "leadAttorney",
                              "variant": "caption",
                              "label": "Lead"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "CLOSE_MATTER",
                              "label": "Close"
                            },
                            {
                              "label": "Hold",
                              "variant": "ghost",
                              "event": "HOLD_MATTER"
                            },
                            {
                              "label": "Reopen",
                              "event": "REOPEN_MATTER",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MatterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CLOSE_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Matter closed",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "HOLD_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Matter on hold",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REOPEN_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Matter reopened"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Matters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MatterPage",
          "path": "/matters",
          "traits": [
            {
              "ref": "MatterDocket"
            }
          ]
        }
      ]
    }
  ]
}
