{
  "name": "std-moderation-rule",
  "version": "1.0.0",
  "description": "std-moderation-rule — content moderation policy layer over std-mod-queue with thresholds, auto-actions, appeal + escalation.",
  "orbitals": [
    {
      "name": "ModerationRuleOrbital",
      "entity": {
        "name": "ModerationRule",
        "collection": "moderation_rules",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "appliesTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "priority",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "testing",
              "archived"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ModerationRuleManage",
          "category": "interaction",
          "linkedEntity": "ModerationRule",
          "emits": [
            {
              "event": "OPEN_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.appliesTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "TEST_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.appliesTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARCHIVE_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.appliesTo",
                  "type": "string"
                },
                {
                  "name": "row.priority",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModerationRuleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ModerationRule]"
                }
              ]
            },
            {
              "event": "ModerationRuleLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ModerationRuleLoaded",
                "name": "ModerationRule loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ModerationRule]"
                  }
                ]
              },
              {
                "key": "ModerationRuleLoadFailed",
                "name": "ModerationRule load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RULE",
                "name": "Open Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ModerationRule"
                  }
                ]
              },
              {
                "key": "ARCHIVE_RULE",
                "name": "Archive Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "TEST_RULE",
                "name": "Test Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModerationRule",
                    {
                      "emit": {
                        "failure": "ModerationRuleLoadFailed",
                        "success": "ModerationRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading moderation rules…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ModerationRuleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "shield",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "shield",
                              "label": "Total rules",
                              "value": "@payload.data.length"
                            },
                            {
                              "type": "stat-display",
                              "value": "23",
                              "label": "Active",
                              "icon": "check-circle"
                            },
                            {
                              "type": "stat-display",
                              "label": "Actions today",
                              "value": "112",
                              "icon": "alert-octagon"
                            },
                            {
                              "type": "stat-display",
                              "label": "Appeals open",
                              "value": "7",
                              "icon": "message-circle"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ModerationRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.appliesTo",
                    "@payload.row.appliesTo"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.row.priority"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "shield"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "variant": "primary",
                              "label": "@entity.status",
                              "type": "badge"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Applies to",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.appliesTo",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Description"
                                },
                                {
                                  "content": "@entity.description",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Priority"
                                },
                                {
                                  "content": "@entity.priority",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "secondary",
                              "label": "Test",
                              "type": "button",
                              "action": "TEST_RULE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "ARCHIVE_RULE",
                              "variant": "danger",
                              "label": "Archive",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ARCHIVE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ModerationRule",
                    {
                      "emit": {
                        "success": "ModerationRuleLoaded",
                        "failure": "ModerationRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Archiving rule…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ModerationRule",
                    {
                      "emit": {
                        "success": "ModerationRuleLoaded",
                        "failure": "ModerationRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading moderation rules…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TEST_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ModerationRule",
                    {
                      "emit": {
                        "success": "ModerationRuleLoaded",
                        "failure": "ModerationRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Testing rule…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ModerationRule",
                    {
                      "emit": {
                        "failure": "ModerationRuleLoadFailed",
                        "success": "ModerationRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Archiving rule…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ModerationRule",
                    {
                      "emit": {
                        "failure": "ModerationRuleLoadFailed",
                        "success": "ModerationRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "repeatOffenderEscalation": {
              "type": "string",
              "default": "tempban",
              "label": "Repeat-offender escalation",
              "description": "Action for users who triggered this rule N times in a rolling window.",
              "synonyms": "recidivism policy",
              "tier": "domain",
              "values": [
                "warn",
                "tempban",
                "ban"
              ]
            },
            "title": {
              "type": "string",
              "default": "Moderation Rules",
              "label": "Section title",
              "description": "Heading shown above the moderation rules list",
              "tier": "presentation"
            },
            "appealWindowHours": {
              "type": "number",
              "default": 48.0,
              "label": "Appeal window (hours)",
              "description": "Hours a user has to appeal an enforcement action before it becomes permanent.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "event": "OPEN_RULE",
                  "variant": "primary",
                  "label": "Open",
                  "icon": "arrow-right"
                },
                {
                  "label": "Archive",
                  "variant": "danger",
                  "event": "ARCHIVE_RULE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each rule row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Rule",
                  "variant": "caption",
                  "name": "name"
                },
                {
                  "label": "Applies to",
                  "name": "appliesTo",
                  "variant": "caption"
                },
                {
                  "label": "Priority",
                  "variant": "caption",
                  "name": "priority"
                },
                {
                  "name": "status",
                  "variant": "badge",
                  "label": "Status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Moderation Rule entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "humanReviewThreshold": {
              "type": "number",
              "default": 0.6,
              "label": "Human review threshold",
              "description": "Toxicity score above which content goes to human review queue instead of auto-action. 0 = always human review; 1 = never.",
              "synonyms": "review queue threshold",
              "tier": "domain"
            },
            "toxicityThreshold": {
              "type": "number",
              "default": 0.85,
              "label": "Toxicity threshold (0-1)",
              "description": "Confidence score above which content is flagged. Lower = more aggressive moderation.",
              "synonyms": "abuse threshold, content sensitivity",
              "tier": "domain"
            },
            "autoAction": {
              "type": "string",
              "default": "flag",
              "label": "Auto action",
              "description": "What to do when the rule fires.",
              "synonyms": "moderation action, enforcement",
              "tier": "domain",
              "values": [
                "flag",
                "hide",
                "shadow-ban",
                "delete",
                "ban-user"
              ]
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ModerationRulePage",
          "path": "/moderation-rules",
          "traits": [
            {
              "ref": "ModerationRuleManage"
            }
          ]
        }
      ]
    }
  ]
}