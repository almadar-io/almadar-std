{
  "name": "std-dunning",
  "version": "1.1.0",
  "description": "std-dunning — failed-payment escalation ladder for subscriptions. Lists open dunning cases in `browsing`; opens detail in `viewing_single` with Escalate / Resolve / Suspend actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "DunningCaseOrbital",
      "entity": {
        "name": "DunningCase",
        "collection": "dunningcases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "severity",
            "type": "string",
            "default": "soft",
            "values": [
              "soft",
              "urgent",
              "final"
            ]
          },
          {
            "name": "attemptNumber",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "attemptsTotal",
            "type": "number",
            "default": 4.0
          },
          {
            "name": "failedAt",
            "type": "string"
          },
          {
            "name": "nextRetryAt",
            "type": "string"
          },
          {
            "name": "amountDue",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "resolvedAt",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "resolved",
              "suspended"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "DunningEscalate",
          "category": "interaction",
          "linkedEntity": "DunningCase",
          "emits": [
            {
              "event": "OPEN_CASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RESOLVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "SUSPEND",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DunningCaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DunningCase]"
                }
              ]
            },
            {
              "event": "DunningCaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DunningCaseLoaded",
                "name": "DunningCase loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DunningCase]"
                  }
                ]
              },
              {
                "key": "DunningCaseLoadFailed",
                "name": "DunningCase load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CASE",
                "name": "Open Case",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "SUSPEND",
                "name": "Suspend",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESOLVE",
                "name": "Resolve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading dunning cases…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DunningCaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "Open cases",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "check-circle",
                              "value": "18",
                              "type": "stat-display",
                              "label": "Recovered"
                            },
                            {
                              "type": "stat-display",
                              "icon": "ban",
                              "value": "3",
                              "label": "Suspended"
                            },
                            {
                              "type": "stat-display",
                              "value": "62%",
                              "icon": "trending-up",
                              "label": "Recovery rate"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DunningCaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    "@payload.row.severity"
                  ],
                  [
                    "set",
                    "@entity.attemptNumber",
                    "@payload.row.attemptNumber"
                  ],
                  [
                    "set",
                    "@entity.attemptsTotal",
                    "@payload.row.attemptsTotal"
                  ],
                  [
                    "set",
                    "@entity.failedAt",
                    "@payload.row.failedAt"
                  ],
                  [
                    "set",
                    "@entity.nextRetryAt",
                    "@payload.row.nextRetryAt"
                  ],
                  [
                    "set",
                    "@entity.amountDue",
                    "@payload.row.amountDue"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.resolvedAt",
                    "@payload.row.resolvedAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.subscriptionId",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.severity",
                              "variant": "primary",
                              "type": "badge"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "content": "Customer",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.customerId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Currency"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.currency"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Failed at"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.failedAt",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "content": "Next retry",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.nextRetryAt"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "dollar-sign",
                              "label": "Amount due",
                              "type": "stat-display",
                              "value": "@entity.amountDue"
                            },
                            {
                              "icon": "repeat",
                              "label": "Attempt",
                              "value": "@entity.attemptNumber",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.attemptsTotal",
                              "icon": "list",
                              "type": "stat-display",
                              "label": "Total attempts"
                            },
                            {
                              "label": "Resolved at",
                              "icon": "check-circle",
                              "type": "stat-display",
                              "value": "@entity.resolvedAt"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "label": "Escalate",
                              "variant": "primary",
                              "action": "ESCALATE",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "variant": "secondary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "RESOLVE",
                              "label": "Resolve"
                            },
                            {
                              "label": "Suspend",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "action": "SUSPEND"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Suspending service…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading dunning cases…"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Escalating case…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "RESOLVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Resolving case…"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Suspending service…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Dunning Cases",
              "label": "Section title",
              "description": "Heading shown above the failed-payment cases",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Subscription",
                  "name": "subscriptionId",
                  "variant": "caption"
                },
                {
                  "name": "customerId",
                  "label": "Customer",
                  "variant": "caption"
                },
                {
                  "label": "Severity",
                  "variant": "badge",
                  "name": "severity"
                },
                {
                  "label": "Attempt",
                  "name": "attemptNumber",
                  "variant": "caption"
                },
                {
                  "name": "amountDue",
                  "label": "Amount Due",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Dunning Case entity",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "icon": "arrow-right",
                  "label": "Open",
                  "variant": "primary",
                  "event": "OPEN_CASE"
                },
                {
                  "event": "SUSPEND",
                  "variant": "danger",
                  "icon": "ban",
                  "label": "Suspend"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each case row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DunningEscalatePage",
          "path": "/dunningcases/escalate",
          "traits": [
            {
              "ref": "DunningEscalate"
            }
          ]
        }
      ]
    }
  ]
}
