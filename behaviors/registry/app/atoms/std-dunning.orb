{
  "name": "std-dunning",
  "version": "1.0.0",
  "description": "std-dunning — failed-payment escalation ladder for subscriptions. Owns a DunningCase entity and a single trait that loads open cases, renders them in a data-grid alongside a per-case dunning-banner, and advances severity (soft -> urgent -> final -> suspend) or marks resolved.",
  "orbitals": [
    {
      "name": "DunningCaseOrbital",
      "entity": {
        "name": "DunningCase",
        "collection": "dunningcases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "severity",
            "type": "string",
            "default": "soft",
            "values": [
              "soft",
              "urgent",
              "final"
            ]
          },
          {
            "name": "attemptNumber",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "attemptsTotal",
            "type": "number",
            "default": 4.0
          },
          {
            "name": "failedAt",
            "type": "string"
          },
          {
            "name": "nextRetryAt",
            "type": "string"
          },
          {
            "name": "amountDue",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "resolvedAt",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "resolved",
              "suspended"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "DunningEscalate",
          "category": "interaction",
          "linkedEntity": "DunningCase",
          "emits": [
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESOLVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUSPEND",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DunningCase]"
                }
              ]
            },
            {
              "event": "DunningCaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceSuspended",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "escalating"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DunningCaseLoaded",
                "name": "DunningCase loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DunningCase]"
                  }
                ]
              },
              {
                "key": "DunningCaseLoadFailed",
                "name": "DunningCase load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "RESOLVE",
                "name": "Resolve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "SUSPEND",
                "name": "Suspend",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "DunningCaseUpdated",
                "name": "DunningCase updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "ServiceSuspended",
                "name": "Service suspended",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "DunningCaseUpdateFailed",
                "name": "DunningCase update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading dunning cases…"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DunningCaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "split-section",
                          "imagePosition": "right",
                          "background": "alt",
                          "title": "Collections health",
                          "bullets": [
                            "Severity ladders from soft to final",
                            "Auto-suspend at the last attempt",
                            "Resolve when payment recovers"
                          ],
                          "description": "Track recovery against open cases and route the right escalation to each customer."
                        },
                        {
                          "type": "stats-grid",
                          "stats": [
                            {
                              "value": "42",
                              "label": "Open cases"
                            },
                            {
                              "value": "18",
                              "label": "Recovered"
                            },
                            {
                              "value": "3",
                              "label": "Suspended"
                            },
                            {
                              "value": "62%",
                              "label": "Recovery rate"
                            }
                          ],
                          "columns": 4.0
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "description": "Final notice. Suspension in 2 days.",
                              "image": {
                                "alt": "Acme",
                                "src": "https://picsum.photos/seed/dun-acme/600/400"
                              },
                              "type": "showcase-card",
                              "title": "Acme Corp",
                              "badge": "Final",
                              "accentColor": "danger"
                            },
                            {
                              "type": "showcase-card",
                              "description": "Urgent — second retry failed.",
                              "image": {
                                "alt": "Globex",
                                "src": "https://picsum.photos/seed/dun-globex/600/400"
                              },
                              "badge": "Urgent",
                              "accentColor": "warning",
                              "title": "Globex Ltd"
                            }
                          ]
                        },
                        {
                          "type": "swipeable-row",
                          "threshold": 80.0,
                          "rightActions": [
                            {
                              "event": "SUSPEND",
                              "variant": "danger",
                              "label": "Suspend"
                            }
                          ],
                          "leftActions": [
                            {
                              "label": "Resolve",
                              "event": "RESOLVE",
                              "variant": "primary"
                            }
                          ],
                          "children": {
                            "children": [
                              {
                                "type": "icon",
                                "name": "alert-triangle"
                              },
                              {
                                "content": "Swipe a case row for quick actions",
                                "variant": "body",
                                "type": "typography"
                              }
                            ],
                            "align": "center",
                            "direction": "horizontal",
                            "gap": "md",
                            "type": "stack"
                          }
                        },
                        {
                          "gap": "sm",
                          "fields": [
                            {
                              "label": "Subscription",
                              "name": "subscriptionId",
                              "variant": "caption"
                            },
                            {
                              "label": "Customer",
                              "variant": "caption",
                              "name": "customerId"
                            },
                            {
                              "variant": "badge",
                              "name": "severity",
                              "label": "Severity"
                            },
                            {
                              "label": "Attempt",
                              "variant": "caption",
                              "name": "attemptNumber"
                            },
                            {
                              "variant": "caption",
                              "name": "amountDue",
                              "label": "Amount Due"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "cols": 1.0,
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "event": "ESCALATE",
                              "variant": "primary",
                              "label": "Escalate",
                              "icon": "arrow-up"
                            },
                            {
                              "icon": "check",
                              "variant": "secondary",
                              "label": "Resolve",
                              "event": "RESOLVE"
                            },
                            {
                              "label": "Suspend",
                              "icon": "ban",
                              "variant": "danger",
                              "event": "SUSPEND"
                            }
                          ],
                          "entity": "@payload.data"
                        },
                        {
                          "width": "md",
                          "position": "right",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Selected case"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "Use the grid actions to escalate, resolve, or suspend."
                                }
                              ],
                              "gap": "sm"
                            }
                          ],
                          "isOpen": false,
                          "title": "Case detail",
                          "type": "drawer"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DunningCaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    [
                      "cond",
                      [
                        "=",
                        "@payload.row.severity",
                        "soft"
                      ],
                      "urgent",
                      [
                        "=",
                        "@payload.row.severity",
                        "urgent"
                      ],
                      "final",
                      "final"
                    ]
                  ],
                  [
                    "set",
                    "@entity.attemptNumber",
                    [
                      "+",
                      "@payload.row.attemptNumber",
                      1.0
                    ]
                  ],
                  [
                    "set",
                    "@entity.attemptsTotal",
                    "@payload.row.attemptsTotal"
                  ],
                  [
                    "set",
                    "@entity.failedAt",
                    "@payload.row.failedAt"
                  ],
                  [
                    "set",
                    "@entity.nextRetryAt",
                    "@payload.row.nextRetryAt"
                  ],
                  [
                    "set",
                    "@entity.amountDue",
                    "@payload.row.amountDue"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Attempt @entity.attemptNumber of @entity.attemptsTotal — amount @entity.amountDue @entity.currency. Next retry @entity.nextRetryAt.",
                      "variant": "warning",
                      "title": "Payment failed",
                      "dismissible": false
                    }
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "success": "DunningCaseUpdated",
                        "failure": "DunningCaseUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "RESOLVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "resolved"
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DunningCaseUpdateFailed",
                        "success": "DunningCaseUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "suspended"
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "success": "ServiceSuspended",
                        "failure": "DunningCaseUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "loading",
                "event": "DunningCaseUpdated",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "loading",
                "event": "ServiceSuspended",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "browsing",
                "event": "DunningCaseUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Dunning Cases"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DunningEscalatePage",
          "path": "/dunningcases/escalate",
          "traits": [
            {
              "ref": "DunningEscalate"
            }
          ]
        }
      ]
    }
  ]
}
