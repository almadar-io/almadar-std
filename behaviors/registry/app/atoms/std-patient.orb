{
  "name": "std-patient",
  "version": "1.0.0",
  "description": "std-patient — patient record management with PHI handling, consent gating, and status lifecycle. Listens for SET_STATUS so std-lifecycle can drive transitions.",
  "orbitals": [
    {
      "name": "PatientOrbital",
      "entity": {
        "name": "Patient",
        "collection": "patients",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "firstName",
            "type": "string",
            "required": true
          },
          {
            "name": "lastName",
            "type": "string",
            "required": true
          },
          {
            "name": "dateOfBirth",
            "type": "string",
            "default": ""
          },
          {
            "name": "consentType",
            "type": "string",
            "default": "standard",
            "values": [
              "standard",
              "research",
              "parental",
              "minor"
            ]
          },
          {
            "name": "mrn",
            "type": "string",
            "default": ""
          },
          {
            "name": "primaryProvider",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "deceased"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "PatientManage",
          "category": "interaction",
          "linkedEntity": "Patient",
          "emits": [
            {
              "event": "OPEN_PATIENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.firstName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.lastName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dateOfBirth",
                  "type": "string"
                },
                {
                  "name": "row.consentType",
                  "type": "string"
                },
                {
                  "name": "row.mrn",
                  "type": "string"
                },
                {
                  "name": "row.primaryProvider",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "DEACTIVATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PatientLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Patient]"
                }
              ]
            },
            {
              "event": "PatientLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.firstName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.lastName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.dateOfBirth",
                  "type": "string"
                },
                {
                  "name": "row.consentType",
                  "type": "string"
                },
                {
                  "name": "row.mrn",
                  "type": "string"
                },
                {
                  "name": "row.primaryProvider",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PatientUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PatientLoaded",
                "name": "Patient loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Patient]"
                  }
                ]
              },
              {
                "key": "PatientLoadFailed",
                "name": "Patient load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_PATIENT",
                "name": "Open Patient",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Patient"
                  }
                ]
              },
              {
                "key": "DEACTIVATE",
                "name": "Deactivate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PatientUpdated",
                "name": "Patient updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Patient"
                  }
                ]
              },
              {
                "key": "PatientUpdateFailed",
                "name": "Patient update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Patient",
                    {
                      "emit": {
                        "success": "PatientLoaded",
                        "failure": "PatientLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading patients…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PatientLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "children": [
                            {
                              "icon": "users",
                              "type": "stat-display",
                              "value": "@payload.data.length",
                              "label": "Total patients"
                            },
                            {
                              "type": "stat-display",
                              "value": "0",
                              "icon": "check-circle",
                              "label": "Active"
                            },
                            {
                              "label": "New this month",
                              "type": "stat-display",
                              "value": "0",
                              "icon": "user-plus"
                            },
                            {
                              "icon": "alert-triangle",
                              "type": "stat-display",
                              "label": "Pending consent",
                              "value": "0"
                            }
                          ],
                          "cols": 4.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PatientLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_PATIENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.firstName",
                    "@payload.row.firstName"
                  ],
                  [
                    "set",
                    "@entity.lastName",
                    "@payload.row.lastName"
                  ],
                  [
                    "set",
                    "@entity.dateOfBirth",
                    "@payload.row.dateOfBirth"
                  ],
                  [
                    "set",
                    "@entity.consentType",
                    "@payload.row.consentType"
                  ],
                  [
                    "set",
                    "@entity.mrn",
                    "@payload.row.mrn"
                  ],
                  [
                    "set",
                    "@entity.primaryProvider",
                    "@payload.row.primaryProvider"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "user"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.firstName",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "primary"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "MRN"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.mrn"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Date of birth",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.dateOfBirth",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Provider",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.primaryProvider"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Consent"
                                },
                                {
                                  "content": "@entity.consentType",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "variant": "danger",
                              "action": "DEACTIVATE",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Deactivate"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "DEACTIVATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "inactive"
                  ],
                  [
                    "persist",
                    "update",
                    "Patient",
                    "@entity",
                    {
                      "emit": {
                        "failure": "PatientUpdateFailed",
                        "success": "PatientUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Deactivating patient…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PatientUpdated",
                "effects": [
                  [
                    "fetch",
                    "Patient",
                    {
                      "emit": {
                        "success": "PatientLoaded",
                        "failure": "PatientLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PatientUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "Patient",
                    "@entity",
                    {
                      "emit": {
                        "failure": "PatientUpdateFailed",
                        "success": "PatientUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Updating patient status…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Patient",
                    {
                      "emit": {
                        "failure": "PatientLoadFailed",
                        "success": "PatientLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading patients…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "DEACTIVATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "inactive"
                  ],
                  [
                    "persist",
                    "update",
                    "Patient",
                    "@entity",
                    {
                      "emit": {
                        "success": "PatientUpdated",
                        "failure": "PatientUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Deactivating patient…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Patient",
                    {
                      "emit": {
                        "success": "PatientLoaded",
                        "failure": "PatientLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "breakGlassRolesAllowed": {
              "type": "[string]",
              "default": [
                "emergency-physician",
                "oncall-attending"
              ],
              "label": "Break-glass roles",
              "description": "Roles permitted to override consent in emergencies; always audited.",
              "synonyms": "emergency override, BTG access",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_PATIENT"
                },
                {
                  "variant": "danger",
                  "label": "Deactivate",
                  "icon": "x",
                  "event": "DEACTIVATE"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each patient row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "mrnFormat": {
              "type": "string",
              "default": "MRN-####-####",
              "label": "MRN format pattern",
              "description": "Display format for the medical record number; # = digit.",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "First name",
                  "name": "firstName",
                  "variant": "caption"
                },
                {
                  "name": "lastName",
                  "variant": "caption",
                  "label": "Last name"
                },
                {
                  "name": "mrn",
                  "label": "MRN",
                  "variant": "caption"
                },
                {
                  "name": "primaryProvider",
                  "label": "Provider",
                  "variant": "caption"
                },
                {
                  "name": "consentType",
                  "label": "Consent",
                  "variant": "badge"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Patient entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "defaultRecordRetentionYears": {
              "type": "number",
              "default": 7.0,
              "label": "Record retention (years)",
              "description": "Years to retain a closed patient record before deletion (compose std-lifecycle + std-data-erasure).",
              "tier": "domain"
            },
            "consentTypesRequired": {
              "type": "[string]",
              "default": [
                "hipaa",
                "treatment"
              ],
              "label": "Consent types required",
              "description": "Required consent forms before patient enters active status. Compose std-audit-capture for logging.",
              "synonyms": "consent forms, authorization, signed agreements",
              "tier": "domain",
              "items": {
                "type": "string"
              }
            },
            "phiDisclosureLogRequired": {
              "type": "boolean",
              "default": true,
              "label": "Log PHI disclosures",
              "description": "Record every disclosure of protected health information for HIPAA audit.",
              "synonyms": "audit log, HIPAA log",
              "tier": "domain"
            },
            "parentalConsentMinorThresholdYears": {
              "type": "number",
              "default": 18.0,
              "label": "Parental consent age (years)",
              "description": "Below this age, parental consent is required in addition to the patient's own.",
              "synonyms": "minor age, adult of majority",
              "tier": "domain"
            },
            "dependentLinkagePolicy": {
