{
  "name": "std-donation-receipt",
  "version": "1.0.0",
  "description": "std-donation-receipt — tax-deductible donation receipt atom. Owns a DonationReceipt entity with IRS-compliance fields (taxYear, taxDeductible, nonprofitEin). Browses receipts in a data-grid with Email / Void actions.",
  "orbitals": [
    {
      "name": "DonationReceiptOrbital",
      "entity": {
        "name": "DonationReceipt",
        "collection": "donationreceipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "donorId",
            "type": "string",
            "required": true
          },
          {
            "name": "donorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "campaignId",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "donationDate",
            "type": "string",
            "required": true
          },
          {
            "name": "taxYear",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "taxDeductible",
            "type": "boolean",
            "default": true
          },
          {
            "name": "nonprofitEin",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "DonationReceiptIssuer",
          "category": "interaction",
          "linkedEntity": "DonationReceipt",
          "emits": [
            {
              "event": "EMAIL_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DonationReceiptLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DonationReceipt]"
                }
              ]
            },
            {
              "event": "DonationReceiptLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DonationReceiptLoaded",
                "name": "DonationReceipt loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DonationReceipt]"
                  }
                ]
              },
              {
                "key": "DonationReceiptLoadFailed",
                "name": "DonationReceipt load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EMAIL_RECEIPT",
                "name": "Email Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VOID_RECEIPT",
                "name": "Void Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "success": "DonationReceiptLoaded",
                        "failure": "DonationReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading donation receipts…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DonationReceiptLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "receipt"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "stats-grid",
                          "stats": [
                            {
                              "label": "Receipts issued",
                              "value": "1,248"
                            },
                            {
                              "value": "$482,300",
                              "label": "Total deductible"
                            },
                            {
                              "value": "2025",
                              "label": "Tax year"
                            },
                            {
                              "label": "Emailed",
                              "value": "94%"
                            }
                          ],
                          "columns": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": [
                            {
                              "name": "receiptNumber",
                              "variant": "caption",
                              "label": "Receipt #"
                            },
                            {
                              "label": "Donor",
                              "name": "donorName",
                              "variant": "caption"
                            },
                            {
                              "name": "amount",
                              "label": "Amount",
                              "variant": "caption"
                            },
                            {
                              "label": "Date",
                              "variant": "caption",
                              "name": "donationDate"
                            },
                            {
                              "name": "taxYear",
                              "label": "Tax Year",
                              "variant": "caption"
                            },
                            {
                              "name": "isEmailed",
                              "variant": "badge",
                              "label": "Emailed"
                            }
                          ],
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Email",
                              "variant": "primary",
                              "event": "EMAIL_RECEIPT"
                            },
                            {
                              "label": "Void",
                              "event": "VOID_RECEIPT",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DonationReceiptLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Receipt emailed",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VOID_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Receipt voided",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "failure": "DonationReceiptLoadFailed",
                        "success": "DonationReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Donation Receipts"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DonationReceiptPage",
          "path": "/donation-receipts",
          "traits": [
            {
              "ref": "DonationReceiptIssuer"
            }
          ]
        }
      ]
    }
  ]
}