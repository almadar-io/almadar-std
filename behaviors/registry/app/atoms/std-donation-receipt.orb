{
  "name": "std-donation-receipt",
  "version": "1.1.0",
  "description": "std-donation-receipt — tax-deductible donation receipt with IRS-compliance fields (taxYear, taxDeductible, nonprofitEin). Lists receipts in `browsing`; opens detail in `viewing_single` with Email / Void actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "DonationReceiptOrbital",
      "entity": {
        "name": "DonationReceipt",
        "collection": "donationreceipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "donorId",
            "type": "string",
            "required": true
          },
          {
            "name": "donorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "campaignId",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "donationDate",
            "type": "string",
            "required": true
          },
          {
            "name": "taxYear",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "taxDeductible",
            "type": "boolean",
            "default": true
          },
          {
            "name": "nonprofitEin",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "DonationReceiptIssuer",
          "category": "interaction",
          "linkedEntity": "DonationReceipt",
          "emits": [
            {
              "event": "OPEN_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.receiptNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.donorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.donorName",
                  "type": "string"
                },
                {
                  "name": "row.campaignId",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.donationDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.taxYear",
                  "type": "number"
                },
                {
                  "name": "row.taxDeductible",
                  "type": "boolean"
                },
                {
                  "name": "row.nonprofitEin",
                  "type": "string"
                },
                {
                  "name": "row.isEmailed",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "EMAIL_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DonationReceiptLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DonationReceipt]"
                }
              ]
            },
            {
              "event": "DonationReceiptLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DonationReceiptLoaded",
                "name": "DonationReceipt loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DonationReceipt]"
                  }
                ]
              },
              {
                "key": "DonationReceiptLoadFailed",
                "name": "DonationReceipt load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_RECEIPT",
                "name": "Open Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DonationReceipt"
                  }
                ]
              },
              {
                "key": "VOID_RECEIPT",
                "name": "Void Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "EMAIL_RECEIPT",
                "name": "Email Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "failure": "DonationReceiptLoadFailed",
                        "success": "DonationReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading donation receipts…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DonationReceiptLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@config.title",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "label": "Receipts",
                              "icon": "receipt",
                              "type": "stat-display"
                            },
                            {
                              "value": "$482,300",
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "label": "Total deductible"
                            },
                            {
                              "value": "2025",
                              "type": "stat-display",
                              "label": "Tax year",
                              "icon": "calendar"
                            },
                            {
                              "icon": "send",
                              "label": "Emailed",
                              "type": "stat-display",
                              "value": "94%"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DonationReceiptLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.receiptNumber",
                    "@payload.row.receiptNumber"
                  ],
                  [
                    "set",
                    "@entity.donorId",
                    "@payload.row.donorId"
                  ],
                  [
                    "set",
                    "@entity.donorName",
                    "@payload.row.donorName"
                  ],
                  [
                    "set",
                    "@entity.campaignId",
                    "@payload.row.campaignId"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.donationDate",
                    "@payload.row.donationDate"
                  ],
                  [
                    "set",
                    "@entity.taxYear",
                    "@payload.row.taxYear"
                  ],
                  [
                    "set",
                    "@entity.nonprofitEin",
                    "@payload.row.nonprofitEin"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "content": "@entity.receiptNumber",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Donor",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.donorName",
                                  "variant": "body"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Donor ID",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.donorId",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Campaign"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.campaignId"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Nonprofit EIN",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.nonprofitEin"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Amount",
                              "value": "@entity.amount",
                              "icon": "dollar-sign"
                            },
                            {
                              "label": "Date",
                              "type": "stat-display",
                              "icon": "calendar",
                              "value": "@entity.donationDate"
                            },
                            {
                              "icon": "file-text",
                              "label": "Tax year",
                              "type": "stat-display",
                              "value": "@entity.taxYear"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Email Receipt",
                              "action": "EMAIL_RECEIPT",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "VOID_RECEIPT",
                              "label": "Void",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "VOID_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "success": "DonationReceiptLoaded",
                        "failure": "DonationReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Voiding receipt…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "success": "DonationReceiptLoaded",
                        "failure": "DonationReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading receipts…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "failure": "DonationReceiptLoadFailed",
                        "success": "DonationReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Emailing receipt…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VOID_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "success": "DonationReceiptLoaded",
                        "failure": "DonationReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Voiding receipt…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "success": "DonationReceiptLoaded",
                        "failure": "DonationReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_RECEIPT",
                  "icon": "arrow-right",
                  "variant": "primary"
                },
                {
                  "variant": "danger",
                  "label": "Void",
                  "event": "VOID_RECEIPT"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each receipt row",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Donation Receipts",
              "label": "Section title",
              "description": "Heading shown above the tax receipt list"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Receipt #",
                  "name": "receiptNumber",
                  "variant": "caption"
                },
                {
                  "name": "donorName",
                  "label": "Donor",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Amount",
                  "name": "amount"
                },
                {
                  "variant": "caption",
                  "label": "Date",
                  "name": "donationDate"
                },
                {
                  "variant": "caption",
                  "name": "taxYear",
                  "label": "Tax Year"
                },
                {
                  "label": "Emailed",
                  "name": "isEmailed",
                  "variant": "badge"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Donation Receipt entity",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DonationReceiptPage",
          "path": "/donation-receipts",
          "traits": [
            {
              "ref": "DonationReceiptIssuer"
            }
          ]
        }
      ]
    }
  ]
}