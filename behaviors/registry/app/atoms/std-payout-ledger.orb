{
  "name": "std-payout-ledger",
  "version": "1.0.0",
  "description": "std-payout-ledger — marketplace vendor payout atom. Owns a Payout entity and a single trait that loads payout history into a data-grid alongside a balance-summary stat strip, requests stripe withdrawals, and marks rows paid.",
  "orbitals": [
    {
      "name": "PayoutOrbital",
      "entity": {
        "name": "Payout",
        "collection": "payouts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vendorId",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "processing",
              "paid",
              "failed"
            ]
          },
          {
            "name": "bankAccountMasked",
            "type": "string"
          },
          {
            "name": "requestedAt",
            "type": "string"
          },
          {
            "name": "paidAt",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PayoutLedger",
          "category": "interaction",
          "linkedEntity": "Payout",
          "emits": [
            {
              "event": "REQUEST_WITHDRAW",
              "payloadSchema": [
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "vendorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.bankAccountMasked",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_PAID",
              "payloadSchema": [
                {
                  "name": "payoutId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.bankAccountMasked",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PayoutLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Payout]"
                }
              ]
            },
            {
              "event": "PayoutLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PayoutUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.bankAccountMasked",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PayoutWithdrawn",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.bankAccountMasked",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PayoutWithdrawFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "withdrawing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PayoutLoaded",
                "name": "Payout loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Payout]"
                  }
                ]
              },
              {
                "key": "PayoutLoadFailed",
                "name": "Payout load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REQUEST_WITHDRAW",
                "name": "Request Withdraw",
                "payloadSchema": [
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "vendorId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Payout"
                  }
                ]
              },
              {
                "key": "MARK_PAID",
                "name": "Mark Paid",
                "payloadSchema": [
                  {
                    "name": "payoutId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Payout"
                  }
                ]
              },
              {
                "key": "PayoutUpdated",
                "name": "Payout updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Payout"
                  }
                ]
              },
              {
                "key": "PayoutWithdrawn",
                "name": "Payout withdrawn",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Payout"
                  }
                ]
              },
              {
                "key": "PayoutWithdrawFailed",
                "name": "Payout withdraw failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "success": "PayoutLoaded",
                        "failure": "PayoutLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading payouts…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PayoutLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "wallet"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Pending",
                              "format": "currency",
                              "value": 0.0,
                              "type": "stat-display",
                              "icon": "clock",
                              "variant": "warning"
                            },
                            {
                              "value": 0.0,
                              "variant": "success",
                              "format": "currency",
                              "type": "stat-display",
                              "label": "Paid",
                              "icon": "check-circle"
                            },
                            {
                              "format": "currency",
                              "variant": "info",
                              "value": "@config.minimumWithdrawal",
                              "type": "stat-display",
                              "label": "Minimum Withdrawal",
                              "icon": "dollar-sign"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "cols": 1.0,
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "vendorId",
                              "label": "Vendor"
                            },
                            {
                              "name": "amount",
                              "label": "Amount",
                              "variant": "caption"
                            },
                            {
                              "label": "Currency",
                              "name": "currency",
                              "variant": "badge"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "label": "Bank",
                              "variant": "caption",
                              "name": "bankAccountMasked"
                            },
                            {
                              "name": "requestedAt",
                              "variant": "caption",
                              "label": "Requested"
                            }
                          ],
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Withdraw",
                              "event": "REQUEST_WITHDRAW",
                              "variant": "primary",
                              "icon": "send"
                            },
                            {
                              "event": "MARK_PAID",
                              "icon": "check",
                              "variant": "secondary",
                              "label": "Mark Paid"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PayoutLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "withdrawing",
                "event": "REQUEST_WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vendorId",
                    "@payload.vendorId"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "processing"
                  ],
                  [
                    "set",
                    "@entity.bankAccountMasked",
                    "@payload.row.bankAccountMasked"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "Payout",
                    "@entity",
                    {
                      "emit": {
                        "failure": "PayoutWithdrawFailed",
                        "success": "PayoutUpdated"
                      }
                    }
                  ],
                  [
                    "call-service",
                    "stripe-payout",
                    "create",
                    {
                      "amount": "@payload.amount",
                      "currency": "@entity.currency",
                      "vendorId": "@payload.vendorId"
                    },
                    {
                      "emit": {
                        "failure": "PayoutWithdrawFailed",
                        "success": "PayoutWithdrawn"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.payoutId"
                  ],
                  [
                    "set",
                    "@entity.vendorId",
                    "@payload.row.vendorId"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.bankAccountMasked",
                    "@payload.row.bankAccountMasked"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "@payload.row.requestedAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "paid"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "Payout",
                    "@entity",
                    {
                      "emit": {
                        "success": "PayoutUpdated",
                        "failure": "PayoutWithdrawFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PayoutUpdated",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "success": "PayoutLoaded",
                        "failure": "PayoutLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PayoutWithdrawn",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PayoutWithdrawFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "withdrawing",
                "to": "loading",
                "event": "PayoutWithdrawn",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "withdrawing",
                "to": "loading",
                "event": "PayoutUpdated",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "success": "PayoutLoaded",
                        "failure": "PayoutLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "withdrawing",
                "to": "browsing",
                "event": "PayoutWithdrawFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Payouts"
            },
            "minimumWithdrawal": {
              "type": "number",
              "default": 50.0
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PayoutLedgerPage",
          "path": "/payouts/ledger",
          "traits": [
            {
              "ref": "PayoutLedger"
            }
          ]
        }
      ]
    }
  ]
}
