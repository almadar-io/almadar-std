{
  "name": "std-payout-ledger",
  "version": "1.1.0",
  "description": "std-payout-ledger — marketplace vendor payout atom. Lists payouts in `browsing`; opens detail in `viewing_single` with Withdraw / Mark Paid actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "PayoutOrbital",
      "entity": {
        "name": "Payout",
        "collection": "payouts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vendorId",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "processing",
              "paid",
              "failed"
            ]
          },
          {
            "name": "bankAccountMasked",
            "type": "string"
          },
          {
            "name": "requestedAt",
            "type": "string"
          },
          {
            "name": "paidAt",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PayoutLedger",
          "category": "interaction",
          "linkedEntity": "Payout",
          "emits": [
            {
              "event": "OPEN_PAYOUT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vendorId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.amount",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.bankAccountMasked",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "REQUEST_WITHDRAW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_PAID",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PayoutLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Payout]"
                }
              ]
            },
            {
              "event": "PayoutLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PayoutLoaded",
                "name": "Payout loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Payout]"
                  }
                ]
              },
              {
                "key": "PayoutLoadFailed",
                "name": "Payout load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_PAYOUT",
                "name": "Open Payout",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Payout"
                  }
                ]
              },
              {
                "key": "REQUEST_WITHDRAW",
                "name": "Request Withdraw",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_PAID",
                "name": "Mark Paid",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "success": "PayoutLoaded",
                        "failure": "PayoutLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading payouts…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PayoutLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "wallet"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "icon": "wallet",
                              "label": "Total payouts",
                              "value": "@payload.data.length"
                            },
                            {
                              "icon": "clock",
                              "label": "Pending",
                              "value": "12",
                              "type": "stat-display"
                            },
                            {
                              "label": "Paid this month",
                              "icon": "check-circle",
                              "value": "$48,200",
                              "type": "stat-display"
                            },
                            {
                              "value": "@config.minimumWithdrawal",
                              "type": "stat-display",
                              "icon": "dollar-sign",
                              "label": "Minimum"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "type": "data-grid"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PayoutLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_PAYOUT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vendorId",
                    "@payload.row.vendorId"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.bankAccountMasked",
                    "@payload.row.bankAccountMasked"
                  ],
                  [
                    "set",
                    "@entity.requestedAt",
                    "@payload.row.requestedAt"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "@payload.row.paidAt"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "name": "wallet",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.vendorId",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "default"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Bank"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.bankAccountMasked"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Notes",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.notes",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Amount",
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "value": "@entity.amount"
                            },
                            {
                              "icon": "calendar",
                              "type": "stat-display",
                              "label": "Requested",
                              "value": "@entity.requestedAt"
                            },
                            {
                              "type": "stat-display",
                              "label": "Paid",
                              "value": "@entity.paidAt",
                              "icon": "check-circle"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Withdraw",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "variant": "primary",
                              "action": "REQUEST_WITHDRAW"
                            },
                            {
                              "action": "MARK_PAID",
                              "type": "button",
                              "label": "Mark Paid",
                              "variant": "secondary",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REQUEST_WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Requesting withdrawal…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "success": "PayoutLoaded",
                        "failure": "PayoutLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Marking paid…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "success": "PayoutLoaded",
                        "failure": "PayoutLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading payouts…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REQUEST_WITHDRAW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Requesting withdrawal…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Marking paid…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Payout",
                    {
                      "emit": {
                        "failure": "PayoutLoadFailed",
                        "success": "PayoutLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "minimumWithdrawal": {
              "type": "number",
              "default": 50.0,
              "label": "Minimum withdrawal",
              "description": "Smallest amount a vendor can request to cash out"
            },
            "itemActions": {
              "type": "[object]",
              "default": [
                {
                  "event": "OPEN_PAYOUT",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "label": "Open"
                },
                {
                  "event": "REQUEST_WITHDRAW",
                  "variant": "danger",
                  "label": "Withdraw"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each payout row",
              "items": {
                "type": "object"
              }
            },
            "title": {
              "type": "string",
              "default": "Payouts",
              "label": "Section title",
              "description": "Heading shown above the vendor payout ledger"
            },
            "fields": {
              "type": "[object]",
              "default": [
                {
                  "variant": "caption",
                  "name": "vendorId",
                  "label": "Vendor"
                },
                {
                  "name": "amount",
                  "variant": "caption",
                  "label": "Amount"
                },
                {
                  "variant": "badge",
                  "label": "Currency",
                  "name": "currency"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "variant": "caption",
                  "label": "Bank",
                  "name": "bankAccountMasked"
                },
                {
                  "label": "Requested",
                  "name": "requestedAt",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Payout entity",
              "items": {
                "type": "object"
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PayoutLedgerPage",
          "path": "/payouts/ledger",
          "traits": [
            {
              "ref": "PayoutLedger"
            }
          ]
        }
      ]
    }
  ]
}