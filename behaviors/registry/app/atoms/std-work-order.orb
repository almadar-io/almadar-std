                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
