{
  "name": "std-work-order",
  "version": "1.2.0",
  "description": "std-work-order — field-service work order lifecycle (created → assigned → en-route → on-site → completed). Lists work orders in `browsing`; opens detail in `viewing_single` with Assign / Travel / Arrive / Complete / Cancel actions. Listens for SET_STATUS so sibling std-lifecycle can drive automated transitions (e.g. en-route → completed on SLA breach). Exposes Service/Operations-pattern knobs (serviceAreaRadius, dispatchStrategy, SLA hours, …).",
  "orbitals": [
    {
      "name": "WorkOrderOrbital",
      "entity": {
        "name": "WorkOrder",
        "collection": "workorders",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "required": true
          },
          {
            "name": "serviceType",
            "type": "string",
            "required": true
          },
          {
            "name": "address",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "string",
            "default": "normal",
            "values": [
              "low",
              "normal",
              "high",
              "urgent"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "created",
            "values": [
              "created",
              "assigned",
              "en-route",
              "on-site",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "assignedTo",
            "type": "string"
          },
          {
            "name": "scheduledAt",
            "type": "string"
          },
          {
            "name": "etaMinutes",
            "type": "number"
          },
          {
            "name": "notes",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WorkOrderManage",
          "category": "interaction",
          "linkedEntity": "WorkOrder",
          "emits": [
            {
              "event": "OPEN_ORDER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.serviceType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.address",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.etaMinutes",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ASSIGN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "assignedTo",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.serviceType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.address",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.etaMinutes",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "START_TRAVEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "etaMinutes",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.serviceType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.address",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.etaMinutes",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARRIVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.serviceType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.address",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.etaMinutes",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPLETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.serviceType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.address",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.etaMinutes",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.serviceType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.address",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.etaMinutes",
                  "type": "number"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WorkOrderLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[WorkOrder]"
                }
              ]
            },
            {
              "event": "WorkOrderLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WorkOrderLoaded",
                "name": "WorkOrder loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WorkOrder]"
                  }
                ]
              },
              {
                "key": "WorkOrderLoadFailed",
                "name": "WorkOrder load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_ORDER",
                "name": "Open Order",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WorkOrder"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "WorkOrder"
                  }
                ]
              },
              {
                "key": "SET_STATUS",
                "name": "Set Status",
                "payloadSchema": [
                  {
                    "name": "entityId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "newStatus",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ASSIGN",
                "name": "Assign",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "assignedTo",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WorkOrder"
                  }
                ]
              },
              {
                "key": "START_TRAVEL",
                "name": "Start Travel",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "etaMinutes",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WorkOrder"
                  }
                ]
              },
              {
                "key": "ARRIVE",
                "name": "Arrive",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WorkOrder"
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "WorkOrder"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "success": "WorkOrderLoaded",
                        "failure": "WorkOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading work orders…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WorkOrderLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clipboard-list"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total orders",
                              "value": "@payload.data.length",
                              "icon": "clipboard-list"
                            },
                            {
                              "type": "stat-display",
                              "label": "Urgent open",
                              "icon": "alert-triangle",
                              "value": "9"
                            },
                            {
                              "icon": "navigation",
                              "type": "stat-display",
                              "label": "En route",
                              "value": "14"
                            },
                            {
                              "label": "Completed today",
                              "icon": "check-circle",
                              "value": "47",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "type": "data-grid",
                          "gap": "sm",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WorkOrderLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_ORDER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerName",
                    "@payload.row.customerName"
                  ],
                  [
                    "set",
                    "@entity.serviceType",
                    "@payload.row.serviceType"
                  ],
                  [
                    "set",
                    "@entity.address",
                    "@payload.row.address"
                  ],
                  [
                    "set",
                    "@entity.priority",
                    "@payload.row.priority"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.assignedTo",
                    "@payload.row.assignedTo"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.row.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.etaMinutes",
                    "@payload.row.etaMinutes"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "type": "button",
                              "action": "CLOSE_VIEW"
                            },
                            {
                              "type": "icon",
                              "name": "clipboard-list"
                            },
                            {
                              "content": "@entity.customerName",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "label": "@entity.priority",
                              "type": "badge",
                              "variant": "primary"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "default"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Service",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.serviceType"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Address"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.address",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Assigned to",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.assignedTo",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "content": "Notes",
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "icon": "clock",
                              "label": "ETA (min)",
                              "type": "stat-display",
                              "value": "@entity.etaMinutes"
                            },
                            {
                              "icon": "calendar",
                              "value": "@entity.scheduledAt",
                              "label": "Scheduled",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Created",
                              "value": "@entity.createdAt",
                              "icon": "calendar-plus"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "ASSIGN",
                              "actionPayload": {
                                "assignedTo": "@entity.assignedTo",
                                "row": "@entity",
                                "id": "@entity.id"
                              },
                              "type": "button",
                              "variant": "primary",
                              "label": "Assign"
                            },
                            {
                              "variant": "secondary",
                              "label": "Start Travel",
                              "type": "button",
                              "action": "START_TRAVEL",
                              "actionPayload": {
                                "row": "@entity",
                                "etaMinutes": 0.0,
                                "id": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "label": "Arrive",
                              "actionPayload": {
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "variant": "secondary",
                              "action": "ARRIVE"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "actionPayload": {
                                "notes": "@entity.notes",
                                "id": "@entity.id",
                                "row": "@entity"
                              },
                              "action": "COMPLETE",
                              "label": "Complete"
                            },
                            {
                              "type": "button",
                              "action": "CANCEL",
                              "variant": "danger",
                              "label": "Cancel",
                              "actionPayload": {
                                "row": "@entity",
                                "id": "@entity.id",
                                "notes": "@entity.notes"
                              }
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Cancelling order…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SET_STATUS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entityId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.newStatus"
                  ],
                  [
                    "persist",
                    "update",
                    "WorkOrder",
                    "@entity",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Updating order status…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "success": "WorkOrderLoaded",
                        "failure": "WorkOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading work orders…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Assigning order…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "START_TRAVEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Starting travel…",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARRIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Arriving on site…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "success": "WorkOrderLoaded",
                        "failure": "WorkOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Completing order…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "success": "WorkOrderLoaded",
                        "failure": "WorkOrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Cancelling order…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "variant": "caption",
                  "label": "Customer",
                  "name": "customerName"
                },
                {
                  "name": "serviceType",
                  "label": "Service",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "address",
                  "label": "Address"
                },
                {
                  "label": "Priority",
                  "name": "priority",
                  "variant": "badge"
                },
                {
                  "label": "Status",
                  "variant": "badge",
                  "name": "status"
                },
                {
                  "name": "assignedTo",
                  "label": "Assigned",
                  "variant": "caption"
                },
                {
                  "label": "ETA (min)",
                  "variant": "caption",
                  "name": "etaMinutes"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Work Order entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Work Orders",
              "label": "Section title",
              "description": "Heading shown above the field service work orders",
              "tier": "customization"
            },
            "serviceAreaRadius": {
              "type": "number",
              "default": 50.0,
              "label": "Service area radius (mi)",
              "description": "Maximum distance from the service hub for dispatch eligibility.",
              "tier": "customization"
            },
            "dispatchStrategy": {
              "type": "string",
              "default": "nearest",
              "label": "Dispatch strategy",
              "description": "How techs are assigned: nearest = closest available, round-robin = even distribution, manual = dispatcher picks.",
              "tier": "customization",
              "values": [
                "nearest",
                "round-robin",
                "manual"
              ]
            },
            "escalationThresholdHours": {
              "type": "number",
              "default": 48.0,
              "label": "Escalation threshold (hours)",
              "description": "Hours after which an open order auto-escalates to escalationRoles. Compose std-lifecycle for wiring.",
              "tier": "customization"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_ORDER",
                  "icon": "arrow-right",
                  "label": "Open"
                },
                {
                  "variant": "danger",
                  "event": "CANCEL",
                  "label": "Cancel",
                  "icon": "x"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each work order row",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "skillsRequired": {
              "type": "[string]",
              "default": [],
              "label": "Required skills",
              "description": "Capability tags a tech must have to be assigned (e.g. 'plumbing', 'electrical', 'hvac').",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "responseTimeMinutes": {
              "type": "number",
              "default": 60.0,
              "label": "Response time SLA (min)",
              "description": "Target time from order created to first response (assigned + acknowledged). Drives SLA dashboards and escalation.",
              "tier": "essential"
            },
            "customerVisibleStatuses": {
              "type": "[string]",
              "default": [
                "assigned",
                "en-route",
                "completed"
              ],
              "label": "Customer-visible statuses",
              "description": "Subset of statuses the customer can see in their tracking view. Internal-only statuses are filtered.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "requirePhotoOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require photo on complete",
              "description": "Block COMPLETE action unless a completion photo is attached.",
              "tier": "customization"
            },
            "serviceZones": {
              "type": "[string]",
              "default": [],
              "label": "Service zones",
              "description": "Named geographic zones for dispatch grouping. Empty = no zone restriction.",
              "tier": "customization",
              "items": {
                "type": "string"
              }
            },
            "resolutionSLAHours": {
              "type": "number",
              "default": 24.0,
              "label": "Resolution SLA (hours)",
              "description": "Target time from order created to completed. Compose sibling std-lifecycle to auto-escalate at threshold.",
              "tier": "essential"
            },
            "requireSignatureOnComplete": {
              "type": "boolean",
              "default": false,
              "label": "Require customer signature on complete",
              "description": "Block COMPLETE action unless customer signature is captured (compose std-signature-capture).",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WorkOrderManagePage",
          "path": "/workorders/manage",
          "traits": [
            {
              "ref": "WorkOrderManage"
            }
          ]
        }
      ]
    }
  ]
