                "event": "ARRIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "success": "WorkOrderLoaded",
                        "failure": "WorkOrderLoadFailed"
