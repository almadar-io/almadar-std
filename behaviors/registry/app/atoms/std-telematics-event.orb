{
  "name": "std-telematics-event",
  "version": "1.0.0",
  "description": "std-telematics-event — read-only per-vehicle telemetry stream from GPS/OBD-II devices. Lists events in `browsing`; opens event detail in `viewing_single` with Acknowledge action.",
  "orbitals": [
    {
      "name": "TelematicsEventOrbital",
      "entity": {
        "name": "TelematicsEvent",
        "collection": "telematicsevents",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vehicleId",
            "type": "string",
            "required": true
          },
          {
            "name": "eventType",
            "type": "string",
            "default": "speeding",
            "values": [
              "hard-brake",
              "speeding",
              "idle",
              "harsh-acceleration",
              "geofence-violation",
              "engine-fault",
              "low-fuel"
            ]
          },
          {
            "name": "severity",
            "type": "string",
            "default": "info",
            "values": [
              "info",
              "warning",
              "critical"
            ]
          },
          {
            "name": "speed",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "locationLat",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "locationLng",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "occurredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledged",
            "type": "boolean",
            "default": false
          },
          {
            "name": "acknowledgedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledgedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TelematicsEventStream",
          "category": "interaction",
          "linkedEntity": "TelematicsEvent",
          "emits": [
            {
              "event": "OPEN_EVENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vehicleId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventType",
                  "type": "string"
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.speed",
                  "type": "number"
                },
                {
                  "name": "row.locationLat",
                  "type": "number"
                },
                {
                  "name": "row.locationLng",
                  "type": "number"
                },
                {
                  "name": "row.occurredAt",
                  "type": "string"
                },
                {
                  "name": "row.acknowledged",
                  "type": "boolean"
                },
                {
                  "name": "row.acknowledgedBy",
                  "type": "string"
                },
                {
                  "name": "row.acknowledgedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ACKNOWLEDGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TelematicsEventLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TelematicsEvent]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TelematicsEventLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TelematicsEventLoaded",
                "name": "TelematicsEvent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TelematicsEvent]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TelematicsEventLoadFailed",
                "name": "TelematicsEvent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_EVENT",
                "name": "Open Event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TelematicsEvent"
                  }
                ]
              },
              {
                "key": "ACKNOWLEDGE",
                "name": "Acknowledge",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading telematics events…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TelematicsEventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "activity"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "activity",
                              "label": "Events 24h",
                              "type": "stat-display",
                              "value": "@payload.data.length"
                            },
                            {
                              "value": "3",
                              "icon": "alert-triangle",
                              "label": "Critical",
                              "type": "stat-display"
                            },
                            {
                              "icon": "bell",
                              "value": "12",
                              "type": "stat-display",
                              "label": "Unacked"
                            },
                            {
                              "icon": "gauge",
                              "type": "stat-display",
                              "label": "Most common",
                              "value": "speeding"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "vehicleId",
                              "label": "Vehicle"
                            },
                            {
                              "name": "eventType",
                              "label": "Type",
                              "variant": "badge"
                            },
                            {
                              "name": "severity",
                              "label": "Severity",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "label": "Speed",
                              "name": "speed"
                            },
                            {
                              "label": "Occurred",
                              "name": "occurredAt",
                              "variant": "caption"
                            },
                            {
                              "label": "Ack",
                              "name": "acknowledged",
                              "variant": "badge"
                            }
                          ],
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "icon": "arrow-right",
                              "label": "Open",
                              "variant": "primary",
                              "event": "OPEN_EVENT"
                            },
                            {
                              "variant": "secondary",
                              "label": "Acknowledge",
                              "event": "ACKNOWLEDGE"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TelematicsEventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_EVENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vehicleId",
                    "@payload.row.vehicleId"
                  ],
                  [
                    "set",
                    "@entity.eventType",
                    "@payload.row.eventType"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    "@payload.row.severity"
                  ],
                  [
                    "set",
                    "@entity.speed",
                    "@payload.row.speed"
                  ],
                  [
                    "set",
                    "@entity.locationLat",
                    "@payload.row.locationLat"
                  ],
                  [
                    "set",
                    "@entity.locationLng",
                    "@payload.row.locationLng"
                  ],
                  [
                    "set",
                    "@entity.occurredAt",
                    "@payload.row.occurredAt"
                  ],
                  [
                    "set",
                    "@entity.acknowledgedBy",
                    "@payload.row.acknowledgedBy"
                  ],
                  [
                    "set",
                    "@entity.acknowledgedAt",
                    "@payload.row.acknowledgedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "label": "Back"
                            },
                            {
                              "type": "icon",
                              "name": "activity"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.eventType",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "variant": "default",
                              "label": "@entity.severity"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Vehicle",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.vehicleId"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Acknowledged by"
                                },
                                {
                                  "content": "@entity.acknowledgedBy",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Speed",
                              "type": "stat-display",
                              "icon": "gauge",
                              "value": "@entity.speed"
                            },
                            {
                              "type": "stat-display",
                              "icon": "map-pin",
                              "value": "@entity.locationLat",
                              "label": "Lat"
                            },
                            {
                              "value": "@entity.locationLng",
                              "type": "stat-display",
                              "icon": "map-pin",
                              "label": "Lng"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Acknowledge",
                              "type": "button",
                              "action": "ACKNOWLEDGE"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ACKNOWLEDGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Acknowledging event…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading events…"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACKNOWLEDGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Acknowledging event…",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Telematics Events"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TelematicsEventPage",
          "path": "/telematics-events",
          "traits": [
            {
              "ref": "TelematicsEventStream"
            }
          ]
        }
      ]
    }
  ]
}
