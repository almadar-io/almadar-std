{
  "name": "std-telematics-event",
  "version": "1.2.0",
  "description": "std-telematics-event — read-only per-vehicle telemetry stream (GPS/OBD-II). Lists events, detail offers Acknowledge. Exposes Inventory/Logistics knobs (defaultWarehouse, hazmatEnabled, …) for the questionnaire.",
  "orbitals": [
    {
      "name": "TelematicsEventOrbital",
      "entity": {
        "name": "TelematicsEvent",
        "collection": "telematicsevents",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vehicleId",
            "type": "string",
            "required": true
          },
          {
            "name": "eventType",
            "type": "string",
            "default": "speeding",
            "values": [
              "hard-brake",
              "speeding",
              "idle",
              "harsh-acceleration",
              "geofence-violation",
              "engine-fault",
              "low-fuel"
            ]
          },
          {
            "name": "severity",
            "type": "string",
            "default": "info",
            "values": [
              "info",
              "warning",
              "critical"
            ]
          },
          {
            "name": "speed",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "locationLat",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "locationLng",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "occurredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledged",
            "type": "boolean",
            "default": false
          },
          {
            "name": "acknowledgedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledgedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TelematicsEventStream",
          "category": "interaction",
          "linkedEntity": "TelematicsEvent",
          "emits": [
            {
              "event": "OPEN_EVENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vehicleId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventType",
                  "type": "string"
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.speed",
                  "type": "number"
                },
                {
                  "name": "row.locationLat",
                  "type": "number"
                },
                {
                  "name": "row.locationLng",
                  "type": "number"
                },
                {
                  "name": "row.occurredAt",
                  "type": "string"
                },
                {
                  "name": "row.acknowledged",
                  "type": "boolean"
                },
                {
                  "name": "row.acknowledgedBy",
                  "type": "string"
                },
                {
                  "name": "row.acknowledgedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ACKNOWLEDGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TelematicsEventLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TelematicsEvent]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TelematicsEventLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TelematicsEventLoaded",
                "name": "TelematicsEvent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TelematicsEvent]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TelematicsEventLoadFailed",
                "name": "TelematicsEvent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_EVENT",
                "name": "Open Event",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TelematicsEvent"
                  }
                ]
              },
              {
                "key": "ACKNOWLEDGE",
                "name": "Acknowledge",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading telematics events…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TelematicsEventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "activity"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "cols": 4.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@payload.data.length",
                              "icon": "activity",
                              "label": "Events 24h",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Critical",
                              "value": "3",
                              "icon": "alert-triangle"
                            },
                            {
                              "icon": "bell",
                              "type": "stat-display",
                              "label": "Unacked",
                              "value": "12"
                            },
                            {
                              "value": "speeding",
                              "label": "Most common",
                              "icon": "gauge",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "fields": "@config.fields",
                          "itemActions": "@config.itemActions",
                          "type": "data-grid"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TelematicsEventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_EVENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.vehicleId",
                    "@payload.row.vehicleId"
                  ],
                  [
                    "set",
                    "@entity.eventType",
                    "@payload.row.eventType"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    "@payload.row.severity"
                  ],
                  [
                    "set",
                    "@entity.speed",
                    "@payload.row.speed"
                  ],
                  [
                    "set",
                    "@entity.locationLat",
                    "@payload.row.locationLat"
                  ],
                  [
                    "set",
                    "@entity.locationLng",
                    "@payload.row.locationLng"
                  ],
                  [
                    "set",
                    "@entity.occurredAt",
                    "@payload.row.occurredAt"
                  ],
                  [
                    "set",
                    "@entity.acknowledgedBy",
                    "@payload.row.acknowledgedBy"
                  ],
                  [
                    "set",
                    "@entity.acknowledgedAt",
                    "@payload.row.acknowledgedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Back",
                              "variant": "ghost",
                              "action": "CLOSE_VIEW",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "activity"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.eventType",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.severity",
                              "variant": "default",
                              "type": "badge"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Vehicle"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.vehicleId",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Acknowledged by",
                                  "variant": "caption",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.acknowledgedBy",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 3.0,
                          "children": [
                            {
                              "icon": "gauge",
                              "type": "stat-display",
                              "label": "Speed",
                              "value": "@entity.speed"
                            },
                            {
                              "value": "@entity.locationLat",
                              "icon": "map-pin",
                              "label": "Lat",
                              "type": "stat-display"
                            },
                            {
                              "label": "Lng",
                              "type": "stat-display",
                              "value": "@entity.locationLng",
                              "icon": "map-pin"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "label": "Acknowledge",
                              "action": "ACKNOWLEDGE",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ACKNOWLEDGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Acknowledging event…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading events…",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ACKNOWLEDGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Acknowledging event…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "multiLocationEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Multi-location",
              "description": "Source vehicles across multiple depots.",
              "tier": "customization"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Vehicle",
                  "name": "vehicleId",
                  "variant": "caption"
                },
                {
                  "name": "eventType",
                  "label": "Type",
                  "variant": "badge"
                },
                {
                  "name": "severity",
                  "label": "Severity",
                  "variant": "badge"
                },
                {
                  "label": "Speed",
                  "variant": "caption",
                  "name": "speed"
                },
                {
                  "name": "occurredAt",
                  "label": "Occurred",
                  "variant": "caption"
                },
                {
                  "variant": "badge",
                  "name": "acknowledged",
                  "label": "Ack"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Telematics Event entity",
              "tier": "advanced",
              "items": {
                "type": "object",
                "properties": {
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "icon": "arrow-right",
                  "variant": "primary",
                  "event": "OPEN_EVENT"
                },
                {
                  "event": "ACKNOWLEDGE",
                  "variant": "secondary",
                  "label": "Acknowledge"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each telemetry event",
              "tier": "customization",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "cycleCountFrequencyDays": {
              "type": "number",
              "default": 30.0,
              "label": "Cycle count cadence (days)",
              "description": "Days between scheduled fleet cycle counts triggered off telematics. v1.2 declarative.",
              "tier": "advanced"
            },
            "defaultWarehouse": {
              "type": "string",
              "default": "",
              "label": "Default depot / warehouse",
              "description": "Depot that owns these vehicles by default. Used by downstream alerting.",
              "tier": "customization"
            },
            "hazmatEnabled": {
              "type": "boolean",
              "default": false,
              "label": "Hazmat tracking",
              "description": "Surface hazmat-relevant telematics events distinctly.",
              "tier": "advanced"
            },
            "title": {
              "type": "string",
              "default": "Telematics Events",
              "label": "Section title",
              "description": "Heading shown above the vehicle telemetry stream",
              "tier": "customization"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TelematicsEventPage",
          "path": "/telematics-events",
          "traits": [
            {
              "ref": "TelematicsEventStream"
            }
          ]
        }
      ]
    }
  ]
}