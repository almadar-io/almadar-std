{
  "name": "std-donor",
  "version": "1.0.0",
  "description": "std-donor — donor primitive: person or organization that has donated to a nonprofit, with lifetime giving total and contact info.",
  "orbitals": [
    {
      "name": "DonorOrbital",
      "entity": {
        "name": "Donor",
        "collection": "donors",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "donorType",
            "type": "string",
            "default": "individual",
            "values": [
              "individual",
              "organization",
              "foundation",
              "anonymous"
            ]
          },
          {
            "name": "lifetimeAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "firstDonationAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastDonationAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "preferredCampaign",
            "type": "string",
            "default": ""
          },
          {
            "name": "isRecurring",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "DonorRoster",
          "category": "interaction",
          "linkedEntity": "Donor",
          "emits": [
            {
              "event": "THANK_DONOR",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.donorType",
                  "type": "string"
                },
                {
                  "name": "row.lifetimeAmount",
                  "type": "number"
                },
                {
                  "name": "row.firstDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.lastDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.preferredCampaign",
                  "type": "string"
                },
                {
                  "name": "row.isRecurring",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "SOLICIT_DONOR",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.donorType",
                  "type": "string"
                },
                {
                  "name": "row.lifetimeAmount",
                  "type": "number"
                },
                {
                  "name": "row.firstDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.lastDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.preferredCampaign",
                  "type": "string"
                },
                {
                  "name": "row.isRecurring",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "DonorLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Donor]"
                }
              ]
            },
            {
              "event": "DonorLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DonorLoaded",
                "name": "Donor loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Donor]"
                  }
                ]
              },
              {
                "key": "DonorLoadFailed",
                "name": "Donor load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "THANK_DONOR",
                "name": "Thank Donor",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SOLICIT_DONOR",
                "name": "Solicit Donor",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Donor",
                    {
                      "emit": {
                        "success": "DonorLoaded",
                        "failure": "DonorLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading donors…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DonorLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "heart-handshake",
                              "type": "icon"
                            },
                            {
                              "content": "@config.title",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "avatar",
                              "name": "Top donor",
                              "src": "https://i.pravatar.cc/64?u=top-donor"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "front": {
                                "type": "team-card",
                                "bio": "Gives monthly since 2020",
                                "name": "Sarah Johnson",
                                "avatar": "https://i.pravatar.cc/120?u=sarah",
                                "role": "Top recurring donor"
                              },
                              "back": {
                                "direction": "vertical",
                                "children": [
                                  {
                                    "variant": "h4",
                                    "content": "Lifetime giving",
                                    "type": "typography"
                                  },
                                  {
                                    "variant": "body",
                                    "content": "$24,500 across 48 gifts",
                                    "type": "typography"
                                  }
                                ],
                                "type": "stack",
                                "gap": "sm"
                              },
                              "type": "flip-card"
                            },
                            {
                              "bio": "Leads our regional volunteer corps",
                              "role": "Field coordinator",
                              "type": "team-card",
                              "avatar": "https://i.pravatar.cc/120?u=lead",
                              "name": "Volunteer Team Lead"
                            }
                          ]
                        },
                        {
                          "type": "team-organism",
                          "data": [
                            {
                              "id": "t1",
                              "role": "Recurring donor",
                              "bio": "Monthly gifts since 2020",
                              "avatar": "https://i.pravatar.cc/120?u=sarah",
                              "name": "Sarah Johnson"
                            },
                            {
                              "id": "t2",
                              "role": "Major gift donor",
                              "name": "Daniel Park",
                              "bio": "Capital campaign supporter",
                              "avatar": "https://i.pravatar.cc/120?u=daniel"
                            },
                            {
                              "id": "t3",
                              "avatar": "https://i.pravatar.cc/120?u=aisha",
                              "name": "Aisha Rahman",
                              "role": "Volunteer",
                              "bio": "Event volunteer + board advisor"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "THANK_DONOR",
                              "label": "Thank",
                              "variant": "primary"
                            },
                            {
                              "variant": "ghost",
                              "event": "SOLICIT_DONOR",
                              "label": "Solicit"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "name": "email",
                              "variant": "caption",
                              "label": "Email"
                            },
                            {
                              "label": "Type",
                              "variant": "badge",
                              "name": "donorType"
                            },
                            {
                              "label": "Lifetime",
                              "name": "lifetimeAmount",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "lastDonationAt",
                              "label": "Last Gift"
                            }
                          ],
                          "cols": 1.0,
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DonorLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "THANK_DONOR",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Thank-you sent",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SOLICIT_DONOR",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Solicitation queued"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Donor",
                    {
                      "emit": {
                        "failure": "DonorLoadFailed",
                        "success": "DonorLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Donors"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DonorPage",
          "path": "/donors",
          "traits": [
            {
              "ref": "DonorRoster"
            }
          ]
        }
      ]
    }
  ]
}