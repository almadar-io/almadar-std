{
  "name": "std-help-category",
  "version": "1.1.0",
  "description": "std-help-category — Help center category directory grouping articles into sections like Getting Started, Billing, API Reference. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "HelpCategoryOrbital",
      "entity": {
        "name": "HelpCategory",
        "collection": "helpcategories",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "icon",
            "type": "string",
            "default": "folder"
          },
          {
            "name": "sortOrder",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "articleCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "published",
              "draft",
              "archived"
            ]
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HelpCategoryDirectory",
          "category": "interaction",
          "linkedEntity": "HelpCategory",
          "emits": [
            {
              "event": "OPEN_CATEGORY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.icon",
                  "type": "string"
                },
                {
                  "name": "row.sortOrder",
                  "type": "number"
                },
                {
                  "name": "row.articleCount",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ARCHIVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "HelpCategoryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HelpCategory]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HelpCategoryLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HelpCategoryLoaded",
                "name": "HelpCategory loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HelpCategory]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HelpCategoryLoadFailed",
                "name": "HelpCategory load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_CATEGORY",
                "name": "Open Category",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "HelpCategory"
                  }
                ]
              },
              {
                "key": "ARCHIVE",
                "name": "Archive",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpCategory",
                    {
                      "emit": {
                        "failure": "HelpCategoryLoadFailed",
                        "success": "HelpCategoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading help categories…",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "HelpCategoryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "folder"
                            },
                            {
                              "variant": "h3",
                              "content": "@config.title",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 4.0,
                          "children": [
                            {
                              "label": "Total categories",
                              "value": "@payload.data.length",
                              "type": "stat-display",
                              "icon": "folder"
                            },
                            {
                              "label": "Published",
                              "type": "stat-display",
                              "value": "18",
                              "icon": "check-circle"
                            },
                            {
                              "label": "Articles",
                              "type": "stat-display",
                              "icon": "book-open",
                              "value": "246"
                            },
                            {
                              "icon": "bar-chart",
                              "type": "stat-display",
                              "label": "Avg per category",
                              "value": "13"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HelpCategoryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.message",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_CATEGORY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.slug",
                    "@payload.row.slug"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.icon",
                    "@payload.row.icon"
                  ],
                  [
                    "set",
                    "@entity.sortOrder",
                    "@payload.row.sortOrder"
                  ],
                  [
                    "set",
                    "@entity.articleCount",
                    "@payload.row.articleCount"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "type": "icon",
                              "name": "folder"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.name"
                            },
                            {
                              "variant": "default",
                              "label": "@entity.status",
                              "type": "badge"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "content": "Slug",
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.slug",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "content": "Description",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.description",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "content": "Icon",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.icon",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Articles",
                              "icon": "book-open",
                              "value": "@entity.articleCount",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Sort order",
                              "value": "@entity.sortOrder",
                              "icon": "list-ordered"
                            },
                            {
                              "value": "@entity.updatedAt",
                              "type": "stat-display",
                              "label": "Updated",
                              "icon": "calendar"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 3.0
                        },
                        {
                          "children": [
                            {
                              "label": "Publish",
                              "type": "button",
                              "variant": "primary",
                              "action": "PUBLISH",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Archive",
                              "action": "ARCHIVE"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ARCHIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HelpCategory",
                    {
                      "emit": {
                        "success": "HelpCategoryLoaded",
                        "failure": "HelpCategoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Archiving category…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "HelpCategory",
                    {
                      "emit": {
                        "success": "HelpCategoryLoaded",
                        "failure": "HelpCategoryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading help categories…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HelpCategory",
                    {
                      "emit": {
                        "failure": "HelpCategoryLoadFailed",
                        "success": "HelpCategoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Publishing category…"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "HelpCategory",
                    {
                      "emit": {
                        "failure": "HelpCategoryLoadFailed",
                        "success": "HelpCategoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Archiving category…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpCategory",
                    {
                      "emit": {
                        "failure": "HelpCategoryLoadFailed",
                        "success": "HelpCategoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Help Categories",
              "label": "Section title",
              "description": "Heading shown above the help center categories"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Name",
                  "variant": "caption",
                  "name": "name"
                },
                {
                  "name": "slug",
                  "label": "Slug",
                  "variant": "caption"
                },
                {
                  "label": "Articles",
                  "name": "articleCount",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "label": "Order",
                  "name": "sortOrder"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                },
                {
                  "name": "updatedAt",
                  "label": "Updated",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Help Category entity",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "event": "OPEN_CATEGORY",
                  "icon": "arrow-right",
                  "label": "Open"
                },
                {
                  "event": "ARCHIVE",
                  "label": "Archive",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each category row",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HelpCategoryPage",
          "path": "/help-categories",
          "traits": [
            {
              "ref": "HelpCategoryDirectory"
            }
          ]
        }
      ]
    }
  ]
}