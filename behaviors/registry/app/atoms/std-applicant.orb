{
  "name": "std-applicant",
  "version": "1.1.0",
  "description": "std-applicant — job applicant primitive tracking a person who applied to a job, their pipeline stage, and basic info. Lists applicants in `browsing`; opens applicant detail in `viewing_single` with Advance / Reject actions. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "ApplicantOrbital",
      "entity": {
        "name": "Applicant",
        "collection": "applicants",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "jobId",
            "type": "string",
            "default": ""
          },
          {
            "name": "resumeUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "stage",
            "type": "string",
            "default": "applied",
            "values": [
              "applied",
              "screening",
              "interview",
              "offer",
              "hired",
              "rejected"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "appliedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApplicantPipeline",
          "category": "interaction",
          "linkedEntity": "Applicant",
          "emits": [
            {
              "event": "OPEN_APPLICANT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.stage",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.appliedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ADVANCE_STAGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.stage",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.appliedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT_APPLICANT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.stage",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.appliedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicantLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Applicant]"
                }
              ]
            },
            {
              "event": "ApplicantLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApplicantLoaded",
                "name": "Applicant loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Applicant]"
                  }
                ]
              },
              {
                "key": "ApplicantLoadFailed",
                "name": "Applicant load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_APPLICANT",
                "name": "Open Applicant",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Applicant"
                  }
                ]
              },
              {
                "key": "REJECT_APPLICANT",
                "name": "Reject Applicant",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              },
              {
                "key": "ADVANCE_STAGE",
                "name": "Advance Stage",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "failure": "ApplicantLoadFailed",
                        "success": "ApplicantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading applicants…",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApplicantLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "users",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "icon": "users",
                              "type": "stat-display",
                              "label": "Total applicants",
                              "value": "@payload.data.length"
                            },
                            {
                              "label": "In interview",
                              "type": "stat-display",
                              "value": "18",
                              "icon": "message-square"
                            },
                            {
                              "value": "5",
                              "icon": "send",
                              "type": "stat-display",
                              "label": "Offers out"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Hired this month",
                              "type": "stat-display",
                              "value": "9"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1.0,
                          "gap": "sm",
                          "itemActions": "@config.itemActions",
                          "fields": "@config.fields"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApplicantLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_APPLICANT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.email",
                    "@payload.row.email"
                  ],
                  [
                    "set",
                    "@entity.phone",
                    "@payload.row.phone"
                  ],
                  [
                    "set",
                    "@entity.jobId",
                    "@payload.row.jobId"
                  ],
                  [
                    "set",
                    "@entity.resumeUrl",
                    "@payload.row.resumeUrl"
                  ],
                  [
                    "set",
                    "@entity.stage",
                    "@payload.row.stage"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "set",
                    "@entity.appliedAt",
                    "@payload.row.appliedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back",
                              "type": "button",
                              "action": "CLOSE_VIEW",
                              "variant": "ghost"
                            },
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.stage",
                              "type": "badge",
                              "variant": "primary"
                            }
                          ],
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "color": "muted",
                                  "type": "typography",
                                  "content": "Email"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.email"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Phone"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.phone"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Job"
                                },
                                {
                                  "content": "@entity.jobId",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Notes",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.notes"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.appliedAt",
                              "type": "stat-display",
                              "icon": "calendar",
                              "label": "Applied"
                            },
                            {
                              "label": "Resume",
                              "icon": "file-text",
                              "type": "stat-display",
                              "value": "@entity.resumeUrl"
                            }
                          ]
                        },
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "action": "ADVANCE_STAGE",
                              "type": "button",
                              "variant": "primary",
                              "label": "Advance Stage",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "label": "Reject",
                              "variant": "danger",
                              "action": "REJECT_APPLICANT",
                              "type": "button",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "REJECT_APPLICANT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "failure": "ApplicantLoadFailed",
                        "success": "ApplicantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Rejecting applicant…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "failure": "ApplicantLoadFailed",
                        "success": "ApplicantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading applicants…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ADVANCE_STAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "success": "ApplicantLoaded",
                        "failure": "ApplicantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Advancing applicant…",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "REJECT_APPLICANT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "success": "ApplicantLoaded",
                        "failure": "ApplicantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Rejecting applicant…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "success": "ApplicantLoaded",
                        "failure": "ApplicantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "name",
                  "variant": "caption",
                  "label": "Name"
                },
                {
                  "label": "Email",
                  "variant": "caption",
                  "name": "email"
                },
                {
                  "variant": "caption",
                  "name": "jobId",
                  "label": "Job"
                },
                {
                  "label": "Stage",
                  "name": "stage",
                  "variant": "badge"
                },
                {
                  "label": "Applied",
                  "name": "appliedAt",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Applicant entity",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "label": "Open",
                  "event": "OPEN_APPLICANT",
                  "variant": "primary",
                  "icon": "arrow-right"
                },
                {
                  "variant": "danger",
                  "event": "REJECT_APPLICANT",
                  "label": "Reject"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each applicant row",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Applicants",
              "label": "Section title",
              "description": "Heading shown above the applicant pipeline"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApplicantPage",
          "path": "/applicants",
          "traits": [
            {
              "ref": "ApplicantPipeline"
            }
          ]
        }
      ]
    }
  ]
}