{
  "name": "std-applicant",
  "version": "1.0.0",
  "description": "std-applicant — job applicant primitive tracking a person who applied to a job, their current pipeline stage, and basic info.",
  "orbitals": [
    {
      "name": "ApplicantOrbital",
      "entity": {
        "name": "Applicant",
        "collection": "applicants",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "jobId",
            "type": "string",
            "default": ""
          },
          {
            "name": "resumeUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "stage",
            "type": "string",
            "default": "applied",
            "values": [
              "applied",
              "screening",
              "interview",
              "offer",
              "hired",
              "rejected"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "appliedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ApplicantPipeline",
          "category": "interaction",
          "linkedEntity": "Applicant",
          "emits": [
            {
              "event": "ADVANCE_STAGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.stage",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.appliedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REJECT_APPLICANT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.jobId",
                  "type": "string"
                },
                {
                  "name": "row.resumeUrl",
                  "type": "string"
                },
                {
                  "name": "row.stage",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.appliedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ApplicantLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Applicant]"
                }
              ]
            },
            {
              "event": "ApplicantLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApplicantLoaded",
                "name": "Applicant loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Applicant]"
                  }
                ]
              },
              {
                "key": "ApplicantLoadFailed",
                "name": "Applicant load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ADVANCE_STAGE",
                "name": "Advance Stage",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REJECT_APPLICANT",
                "name": "Reject Applicant",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "failure": "ApplicantLoadFailed",
                        "success": "ApplicantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading applicants…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ApplicantLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Name",
                              "variant": "caption",
                              "name": "name"
                            },
                            {
                              "variant": "caption",
                              "label": "Email",
                              "name": "email"
                            },
                            {
                              "name": "jobId",
                              "label": "Job",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Stage",
                              "name": "stage"
                            },
                            {
                              "label": "Applied",
                              "name": "appliedAt",
                              "variant": "caption"
                            }
                          ],
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "Advance",
                              "event": "ADVANCE_STAGE",
                              "variant": "primary"
                            },
                            {
                              "label": "Reject",
                              "variant": "danger",
                              "event": "REJECT_APPLICANT"
                            }
                          ],
                          "cols": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApplicantLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ADVANCE_STAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Applicant advanced",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REJECT_APPLICANT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Applicant rejected",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Applicant",
                    {
                      "emit": {
                        "success": "ApplicantLoaded",
                        "failure": "ApplicantLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Applicants"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ApplicantPage",
          "path": "/applicants",
          "traits": [
            {
              "ref": "ApplicantPipeline"
            }
          ]
        }
      ]
    }
  ]
}
