{
  "name": "std-conversation-policy",
  "version": "1.0.0",
  "description": "std-conversation-policy — chat/realtime governance: retention, e2ee, moderation mode, edit/delete windows.",
  "orbitals": [
    {
      "name": "ConversationPolicyOrbital",
      "entity": {
        "name": "ConversationPolicy",
        "collection": "conversation_policies",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "appliesTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "archived"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ConversationPolicyManage",
          "category": "interaction",
          "linkedEntity": "ConversationPolicy",
          "emits": [
            {
              "event": "OPEN_POLICY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.appliesTo",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_VIEW"
            },
            {
              "event": "ARCHIVE_POLICY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.appliesTo",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConversationPolicyLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ConversationPolicy]"
                }
              ]
            },
            {
              "event": "ConversationPolicyLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ConversationPolicyLoaded",
                "name": "ConversationPolicy loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ConversationPolicy]"
                  }
                ]
              },
              {
                "key": "ConversationPolicyLoadFailed",
                "name": "ConversationPolicy load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_POLICY",
                "name": "Open Policy",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ConversationPolicy"
                  }
                ]
              },
              {
                "key": "ARCHIVE_POLICY",
                "name": "Archive Policy",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_VIEW",
                "name": "Close View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConversationPolicy",
                    {
                      "emit": {
                        "success": "ConversationPolicyLoaded",
                        "failure": "ConversationPolicyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading conversation policies…"
                        }
                      ],
                      "className": "py-12",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ConversationPolicyLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-square"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "children": [
                            {
                              "label": "Total policies",
                              "value": "@payload.data.length",
                              "icon": "message-square",
                              "type": "stat-display"
                            },
                            {
                              "label": "Active",
                              "value": "8",
                              "type": "stat-display",
                              "icon": "check-circle"
                            },
                            {
                              "icon": "lock",
                              "label": "E2EE channels",
                              "type": "stat-display",
                              "value": "3"
                            },
                            {
                              "label": "Archived",
                              "value": "2",
                              "type": "stat-display",
                              "icon": "archive"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 4.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "fields": "@config.fields",
                          "entity": "@payload.data",
                          "itemActions": "@config.itemActions",
                          "cols": 1.0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ConversationPolicyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_POLICY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.appliesTo",
                    "@payload.row.appliesTo"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "action": "CLOSE_VIEW",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Back"
                            },
                            {
                              "name": "message-square",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "h3"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.status",
                              "variant": "primary"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Applies to",
                                  "color": "muted"
                                },
                                {
                                  "content": "@entity.appliesTo",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Description",
                                  "type": "typography"
                                },
                                {
                                  "variant": "body",
                                  "content": "@entity.description",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Archive",
                              "action": "ARCHIVE_POLICY",
                              "type": "button",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "ARCHIVE_POLICY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ConversationPolicy",
                    {
                      "emit": {
                        "success": "ConversationPolicyLoaded",
                        "failure": "ConversationPolicyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Archiving policy…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_VIEW",
                "effects": [
                  [
                    "fetch",
                    "ConversationPolicy",
                    {
                      "emit": {
                        "failure": "ConversationPolicyLoadFailed",
                        "success": "ConversationPolicyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading conversation policies…"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "ARCHIVE_POLICY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "ConversationPolicy",
                    {
                      "emit": {
                        "failure": "ConversationPolicyLoadFailed",
                        "success": "ConversationPolicyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Archiving policy…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ConversationPolicy",
                    {
                      "emit": {
                        "success": "ConversationPolicyLoaded",
                        "failure": "ConversationPolicyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "e2eeRequired": {
              "type": "boolean",
              "default": false,
              "label": "E2EE required",
              "description": "When true, conversations must be end-to-end encrypted.",
              "synonyms": "end-to-end encryption, encrypted chat",
              "tier": "domain"
            },
            "title": {
              "type": "string",
              "default": "Conversation Policies",
              "label": "Section title",
              "description": "Heading shown above the conversation policies list",
              "tier": "presentation"
            },
            "editWindowMinutes": {
              "type": "number",
              "default": 15.0,
              "label": "Edit window (minutes)",
              "description": "Minutes after send a user can edit a message. 0 = no editing.",
              "tier": "domain"
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "event": "OPEN_POLICY",
                  "icon": "arrow-right"
                },
                {
                  "event": "ARCHIVE_POLICY",
                  "label": "Archive",
                  "variant": "danger"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each policy row",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "retentionDays": {
              "type": "number",
              "default": 365.0,
              "label": "Message retention (days)",
              "description": "Days to keep messages before lifecycle deletion. Compose std-data-erasure for cleanup.",
              "synonyms": "history retention",
              "tier": "domain"
            },
            "moderationMode": {
              "type": "string",
              "default": "post-hoc",
              "label": "Moderation mode",
              "description": "post-hoc = scan after send; pre-publish = scan before send (delay); human-only = no AI scan.",
              "tier": "domain",
              "values": [
                "off",
                "post-hoc",
                "pre-publish",
                "human-only"
              ]
            },
            "deleteWindowMinutes": {
              "type": "number",
              "default": 1440.0,
              "label": "Delete window (minutes)",
              "description": "Minutes after send a user can delete a message. 0 = no deletion. 1440 = 24 hours.",
              "tier": "domain"
            },
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "label": "Policy",
                  "variant": "caption",
                  "name": "name"
                },
                {
                  "name": "appliesTo",
                  "label": "Applies to",
                  "variant": "caption"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "variant": "badge"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Conversation Policy entity",
              "tier": "presentation",
              "items": {
                "type": "object",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  }
                }
              }
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ConversationPolicyPage",
          "path": "/conversation-policies",
          "traits": [
            {
              "ref": "ConversationPolicyManage"
            }
          ]
        }
      ]
    }
  ]
}