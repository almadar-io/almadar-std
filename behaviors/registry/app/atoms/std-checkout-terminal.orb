{
  "name": "std-checkout-terminal",
  "version": "1.1.0",
  "description": "std-checkout-terminal — retail POS checkout terminal sessions. Lists open sessions in `browsing`; opens a read-only session detail view (terminal, cashier, status, totals, payment method) in `viewing_single`. Tender / Void / Open are the only interactions; post-action transitions re-fetch the list. Agents tune the list shape via `config.fields` + `config.itemActions`.",
  "orbitals": [
    {
      "name": "CheckoutSessionOrbital",
      "entity": {
        "name": "CheckoutSession",
        "collection": "checkoutsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "terminalId",
            "type": "string",
            "required": true
          },
          {
            "name": "cashierId",
            "type": "string",
            "default": ""
          },
          {
            "name": "cashierName",
            "type": "string",
            "default": ""
          },
          {
            "name": "cartItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "paymentMethod",
            "type": "string",
            "default": "card",
            "values": [
              "cash",
              "card",
              "gift_card",
              "split"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "paying",
              "completed",
              "voided"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CheckoutSessionTerminal",
          "category": "interaction",
          "linkedEntity": "CheckoutSession",
          "emits": [
            {
              "event": "OPEN_TERMINAL",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.terminalId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.cashierId",
                  "type": "string"
                },
                {
                  "name": "row.cashierName",
                  "type": "string"
                },
                {
                  "name": "row.cartItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.paymentMethod",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CLOSE_TERMINAL"
            },
            {
              "event": "TENDER_PAYMENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_SESSION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckoutSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CheckoutSession]"
                }
              ]
            },
            {
              "event": "CheckoutSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing_single"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckoutSessionLoaded",
                "name": "CheckoutSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CheckoutSession]"
                  }
                ]
              },
              {
                "key": "CheckoutSessionLoadFailed",
                "name": "CheckoutSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_TERMINAL",
                "name": "Open Terminal",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "CheckoutSession"
                  }
                ]
              },
              {
                "key": "VOID_SESSION",
                "name": "Void Session",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE_TERMINAL",
                "name": "Close Terminal"
              },
              {
                "key": "TENDER_PAYMENT",
                "name": "Tender Payment",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "success": "CheckoutSessionLoaded",
                        "failure": "CheckoutSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner",
                          "size": "md"
                        },
                        {
                          "content": "Loading terminals…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CheckoutSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "content": "@config.title",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": "@config.itemActions",
                          "entity": "@payload.data",
                          "fields": "@config.fields",
                          "cols": 1.0,
                          "gap": "sm",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckoutSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing_single",
                "event": "OPEN_TERMINAL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.terminalId",
                    "@payload.row.terminalId"
                  ],
                  [
                    "set",
                    "@entity.cashierName",
                    "@payload.row.cashierName"
                  ],
                  [
                    "set",
                    "@entity.subtotal",
                    "@payload.row.subtotal"
                  ],
                  [
                    "set",
                    "@entity.tax",
                    "@payload.row.tax"
                  ],
                  [
                    "set",
                    "@entity.total",
                    "@payload.row.total"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.paymentMethod",
                    "@payload.row.paymentMethod"
                  ],
                  [
                    "set",
                    "@entity.openedAt",
                    "@payload.row.openedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "CLOSE_TERMINAL",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Back"
                            },
                            {
                              "type": "typography",
                              "content": "Session detail",
                              "variant": "h3"
                            },
                            {
                              "label": "@entity.status",
                              "variant": "default",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Terminal",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.terminalId"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Cashier",
                                  "color": "muted",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.cashierName",
                                  "variant": "body"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "typography",
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Opened"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.openedAt"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Payment method"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.paymentMethod"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "resource-bar",
                          "size": "md",
                          "resources": [
                            {
                              "label": "Subtotal",
                              "icon": "wallet",
                              "value": "@entity.subtotal"
                            },
                            {
                              "label": "Tax",
                              "value": "@entity.tax",
                              "icon": "percent"
                            },
                            {
                              "label": "Total",
                              "icon": "credit-card",
                              "value": "@entity.total"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "label": "Tender Payment",
                              "type": "button",
                              "action": "TENDER_PAYMENT",
                              "variant": "primary",
                              "actionPayload": {
                                "id": "@entity.id"
                              }
                            },
                            {
                              "action": "VOID_SESSION",
                              "actionPayload": {
                                "id": "@entity.id"
                              },
                              "label": "Void Session",
                              "type": "button",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "VOID_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "success": "CheckoutSessionLoaded",
                        "failure": "CheckoutSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner",
                          "size": "md"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Voiding session…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "CLOSE_TERMINAL",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "success": "CheckoutSessionLoaded",
                        "failure": "CheckoutSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "size": "md",
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading terminals…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "TENDER_PAYMENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "failure": "CheckoutSessionLoadFailed",
                        "success": "CheckoutSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Tendering payment…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing_single",
                "to": "loading",
                "event": "VOID_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "success": "CheckoutSessionLoaded",
                        "failure": "CheckoutSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner",
                          "size": "md"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Voiding session…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "failure": "CheckoutSessionLoadFailed",
                        "success": "CheckoutSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[FieldSpec]",
              "default": [
                {
                  "name": "terminalId",
                  "label": "Terminal",
                  "variant": "caption"
                },
                {
                  "variant": "caption",
                  "name": "cashierName",
                  "label": "Cashier"
                },
                {
                  "variant": "badge",
                  "label": "Status",
                  "name": "status"
                },
                {
                  "name": "total",
                  "variant": "caption",
                  "label": "Total"
                },
                {
                  "name": "openedAt",
                  "label": "Opened",
                  "variant": "caption"
                }
              ],
              "label": "Columns to show",
              "description": "Each column maps to one field on the Checkout Session entity",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": false
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "format": {
                    "name": "format",
                    "type": "string",
                    "required": false
                  },
                  "header": {
                    "name": "header",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": true
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "itemActions": {
              "type": "[ItemAction]",
              "default": [
                {
                  "variant": "primary",
                  "label": "Open",
                  "event": "OPEN_TERMINAL"
                },
                {
                  "variant": "danger",
                  "label": "Void",
                  "event": "VOID_SESSION"
                }
              ],
              "label": "Row actions",
              "description": "Buttons users can click on each terminal row",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "event": {
                    "name": "event",
                    "type": "string",
                    "required": true
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Terminals",
              "label": "Section title",
              "description": "Heading shown above the checkout terminals list"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CheckoutSessionPage",
          "path": "/terminals",
          "traits": [
            {
              "ref": "CheckoutSessionTerminal"
            }
          ]
        }
      ]
    }
  ]
}