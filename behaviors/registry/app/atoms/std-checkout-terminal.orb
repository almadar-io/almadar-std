{
  "name": "std-checkout-terminal",
  "version": "1.0.0",
  "description": "std-checkout-terminal — retail POS checkout terminal. Owns a CheckoutSession entity (one row per active register session) and a single terminal trait that loads open sessions, renders cart + total + status in a data-grid, and supports tender / void session actions.",
  "orbitals": [
    {
      "name": "CheckoutSessionOrbital",
      "entity": {
        "name": "CheckoutSession",
        "collection": "checkoutsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "terminalId",
            "type": "string",
            "required": true
          },
          {
            "name": "cashierId",
            "type": "string",
            "default": ""
          },
          {
            "name": "cashierName",
            "type": "string",
            "default": ""
          },
          {
            "name": "cartItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "paymentMethod",
            "type": "string",
            "default": "card",
            "values": [
              "cash",
              "card",
              "gift_card",
              "split"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "paying",
              "completed",
              "voided"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CheckoutSessionTerminal",
          "category": "interaction",
          "linkedEntity": "CheckoutSession",
          "emits": [
            {
              "event": "TENDER_PAYMENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_SESSION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckoutSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CheckoutSession]"
                }
              ]
            },
            {
              "event": "CheckoutSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckoutSessionLoaded",
                "name": "CheckoutSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CheckoutSession]"
                  }
                ]
              },
              {
                "key": "CheckoutSessionLoadFailed",
                "name": "CheckoutSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TENDER_PAYMENT",
                "name": "Tender Payment",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VOID_SESSION",
                "name": "Void Session",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "success": "CheckoutSessionLoaded",
                        "failure": "CheckoutSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner",
                          "size": "md"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading terminals…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CheckoutSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@config.title"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "items": [
                            {
                              "src": "https://picsum.photos/seed/feat1/800/300",
                              "alt": "Featured promo",
                              "caption": "Buy 2 get 1 free"
                            },
                            {
                              "alt": "Seasonal sale",
                              "caption": "Holiday bundle 20% off",
                              "src": "https://picsum.photos/seed/feat2/800/300"
                            },
                            {
                              "caption": "Just landed in store",
                              "alt": "New arrival",
                              "src": "https://picsum.photos/seed/feat3/800/300"
                            }
                          ],
                          "autoPlayInterval": 5000.0,
                          "type": "carousel",
                          "showDots": true,
                          "autoPlay": true,
                          "showArrows": true,
                          "loop": true
                        },
                        {
                          "plans": [
                            {
                              "action": {
                                "href": "#tender",
                                "label": "Add"
                              },
                              "price": "$4.99",
                              "features": [
                                "Standard pricing"
                              ],
                              "description": "One item",
                              "name": "Single"
                            },
                            {
                              "action": {
                                "href": "#tender",
                                "label": "Add"
                              },
                              "features": [
                                "10% off",
                                "Free wrap"
                              ],
                              "highlighted": true,
                              "price": "$12.99",
                              "description": "Three items",
                              "name": "Bundle"
                            },
                            {
                              "name": "Family",
                              "action": {
                                "label": "Add",
                                "href": "#tender"
                              },
                              "price": "$24.99",
                              "description": "Six items",
                              "features": [
                                "20% off",
                                "Free wrap",
                                "Priority pickup"
                              ]
                            }
                          ],
                          "type": "pricing-grid"
                        },
                        {
                          "align": "center",
                          "children": [
                            {
                              "color": "muted",
                              "variant": "caption",
                              "type": "typography",
                              "content": "Qty"
                            },
                            {
                              "value": 1.0,
                              "size": "md",
                              "min": 1.0,
                              "max": 99.0,
                              "step": 1.0,
                              "type": "number-stepper",
                              "action": "TENDER_PAYMENT"
                            },
                            {
                              "size": "md",
                              "multiplier": 2.0,
                              "combo": 3.0,
                              "streak": 5.0,
                              "type": "combo-counter"
                            },
                            {
                              "size": "md",
                              "type": "resource-bar",
                              "resources": [
                                {
                                  "value": 42.5,
                                  "id": "subtotal",
                                  "icon": "wallet",
                                  "label": "Subtotal"
                                },
                                {
                                  "value": 3.4,
                                  "id": "tax",
                                  "icon": "percent",
                                  "label": "Tax"
                                },
                                {
                                  "id": "total",
                                  "label": "Total",
                                  "icon": "credit-card",
                                  "value": 45.9
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "label": "Tender",
                              "variant": "primary",
                              "icon": "credit-card",
                              "type": "action-button",
                              "size": "md",
                              "hotkey": "T"
                            },
                            {
                              "index": 1.0,
                              "text": "Cash",
                              "type": "choice-button"
                            },
                            {
                              "selected": true,
                              "type": "choice-button",
                              "index": 2.0,
                              "text": "Card"
                            },
                            {
                              "text": "Gift",
                              "type": "choice-button",
                              "index": 3.0
                            },
                            {
                              "variant": "secondary",
                              "type": "control-button",
                              "shape": "round",
                              "label": "Hold",
                              "icon": "pause",
                              "size": "md"
                            },
                            {
                              "includeDiagonals": false,
                              "size": "md",
                              "type": "d-pad"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "label": "Cashier actions",
                          "type": "action-palette",
                          "allowDuplicates": true,
                          "size": "md",
                          "actions": [
                            {
                              "category": "promo",
                              "id": "discount",
                              "label": "Discount"
                            },
                            {
                              "label": "Refund",
                              "category": "ops",
                              "id": "refund"
                            },
                            {
                              "id": "void",
                              "label": "Void",
                              "category": "ops"
                            },
                            {
                              "id": "split",
                              "category": "tender",
                              "label": "Split"
                            }
                          ]
                        },
                        {
                          "isOpen": true,
                          "position": "right",
                          "width": "w-96",
                          "onClose": "VOID_SESSION",
                          "closeEvent": "VOID_SESSION",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "h4",
                                  "content": "Items in cart"
                                },
                                {
                                  "type": "typography",
                                  "content": "Cart side panel preview",
                                  "color": "muted",
                                  "variant": "caption"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ],
                          "title": "Cart",
                          "type": "side-panel"
                        },
                        {
                          "variant": "success",
                          "title": "Payment ready",
                          "type": "toast-slot",
                          "duration": 4000.0
                        },
                        {
                          "variant": "primary",
                          "position": "bottom-right",
                          "type": "floating-action-button",
                          "label": "Quick sale",
                          "action": "TENDER_PAYMENT",
                          "icon": "zap"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "terminalId",
                              "label": "Terminal",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "cashierName",
                              "label": "Cashier"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "label": "Total",
                              "name": "total"
                            },
                            {
                              "label": "Opened",
                              "variant": "caption",
                              "name": "openedAt"
                            }
                          ],
                          "entity": "@payload.data",
                          "cols": 1.0,
                          "itemActions": [
                            {
                              "event": "TENDER_PAYMENT",
                              "label": "Tender",
                              "variant": "primary"
                            },
                            {
                              "label": "Void",
                              "event": "VOID_SESSION",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckoutSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TENDER_PAYMENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Payment tendered",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VOID_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Session voided",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "success": "CheckoutSessionLoaded",
                        "failure": "CheckoutSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Terminals"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CheckoutSessionPage",
          "path": "/terminals",
          "traits": [
            {
              "ref": "CheckoutSessionTerminal"
            }
          ]
        }
      ]
    }
  ]
}