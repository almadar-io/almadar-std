{
  "name": "std-customer-success",
  "version": "1.0.0",
  "description": "Customer Success: account portfolio, health scores, NPS surveys, and renewal risk for CSMs. Pick for SaaS customer success teams.",
  "orbitals": [
    {
      "name": "CustomerAccountOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-nps-survey",
          "as": "NpsSurvey"
        },
        {
          "from": "std/behaviors/std-health-score",
          "as": "HealthScore"
        },
        {
          "from": "std/behaviors/std-renewal-risk",
          "as": "RenewalRisk"
        }
      ],
      "entity": {
        "name": "CsAccount",
        "collection": "csaccounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "plan",
            "type": "string",
            "default": "trial",
            "values": [
              "trial",
              "starter",
              "growth",
              "enterprise"
            ]
          },
          {
            "name": "arrAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "onboarding",
            "values": [
              "onboarding",
              "healthy",
              "at-risk",
              "churned",
              "renewed"
            ]
          },
          {
            "name": "csm",
            "type": "string",
            "default": ""
          },
          {
            "name": "renewalDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "signedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "CsAccountAppLayout",
          "config": {
            "navItems": [
              {
                "icon": "users",
                "href": "/cs-accounts",
                "label": "Accounts"
              },
              {
                "href": "/health-scores",
                "icon": "activity",
                "label": "Health Scores"
              },
              {
                "label": "NPS",
                "icon": "message-square",
                "href": "/nps-surveys"
              },
              {
                "icon": "alert-triangle",
                "label": "Renewal Risks",
                "href": "/renewal-risks"
              }
            ],
            "contentTrait": "@trait.CsAccountCatalog",
            "appName": "Customer Success",
            "notifications": [],
            "searchEvent": "CS_ACCOUNT_SEARCH",
            "notificationClickEvent": "CS_ACCOUNT_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "CS_ACCOUNT_SEARCH",
            "NOTIFY_CLICK": "CS_ACCOUNT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "CsAccountCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CS_ACCOUNT_SEARCH",
              "triggers": "CS_ACCOUNT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "CsAccountAppLayout"
              }
            },
            {
              "event": "CS_ACCOUNT_NOTIFICATIONS_OPEN",
              "triggers": "CS_ACCOUNT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "CsAccountAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CS_ACCOUNT_SEARCH",
                "name": "Cs Account Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CS_ACCOUNT_NOTIFICATIONS_OPEN",
                "name": "Cs Account Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "users",
                                  "type": "icon"
                                },
                                {
                                  "content": "Accounts",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "children": [
                                {
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "icon": "plus",
                                  "type": "button",
                                  "label": "New Account"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "children": [
                            "@trait.CsAccountSearch",
                            "@trait.CsAccountFilter"
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        "@trait.CsAccountStats",
                        "@trait.CsAccountGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.CsAccountBrowseList"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CS_ACCOUNT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CS_ACCOUNT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "variant": "h3",
                          "content": "No notifications",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "You're all caught up."
                        },
                        {
                          "label": "Back to accounts",
                          "type": "button",
                          "action": "INIT",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "CsAccountSearch",
          "config": {
            "placeholder": "Search accounts…",
            "event": "CS_ACCOUNT_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "CsAccountFilter",
          "config": {
            "event": "CS_ACCOUNT_FILTER",
            "filters": [
              {
                "label": "Plan",
                "options": [
                  "trial",
                  "starter",
                  "growth",
                  "enterprise"
                ],
                "field": "plan",
                "filterType": "select"
              },
              {
                "label": "Status",
                "options": [
                  "onboarding",
                  "healthy",
                  "at-risk",
                  "churned",
                  "renewed"
                ],
                "filterType": "select",
                "field": "status"
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "CsAccountStats",
          "config": {
            "title": "Customer Success",
            "metrics": [
              {
                "label": "Total",
                "icon": "users",
                "variant": "primary",
                "format": "number",
                "aggregation": "count"
              },
              {
                "aggregation": "count",
                "label": "Healthy",
                "icon": "check-circle",
                "format": "number",
                "variant": "success",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "healthy"
                  ]
                ]
              },
              {
                "format": "number",
                "label": "At Risk",
                "icon": "alert-triangle",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "at-risk"
                  ]
                ],
                "aggregation": "count",
                "variant": "warning"
              },
              {
                "aggregation": "sum",
                "label": "Total ARR",
                "format": "number",
                "field": "arrAmount",
                "icon": "dollar-sign",
                "variant": "info"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "CsAccountBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "CsAccountGraphs",
          "config": {
            "title": "Accounts by Plan",
            "categoryField": "plan",
            "chartType": "bar",
            "aggregation": "count",
            "height": 240.0,
            "subtitle": "Portfolio composition across subscription plans",
            "showLegend": false
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "CsAccountBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "CsAccountBrowseList",
          "linkedEntity": "CsAccount",
          "config": {
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "event": "DELETE",
                "variant": "danger",
                "label": "Delete"
              }
            ],
            "cols": 1.0,
            "fields": [
              {
                "icon": "users",
                "variant": "h3",
                "name": "name"
              },
              {
                "name": "plan",
                "variant": "badge"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "name": "csm",
                "variant": "caption"
              },
              {
                "name": "arrAmount",
                "variant": "caption"
              },
              {
                "variant": "caption",
                "name": "renewalDate"
              }
            ],
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "CsAccountSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "CsAccountFilter"
              }
            },
            {
              "event": "CS_ACCOUNT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CsAccountPersistor"
              }
            },
            {
              "event": "CS_ACCOUNT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CsAccountPersistor"
              }
            },
            {
              "event": "CS_ACCOUNT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CsAccountPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CsAccountCreate",
          "linkedEntity": "CsAccount",
          "config": {
            "icon": "plus-circle",
            "fields": [
              "name",
              "plan",
              "status",
              "csm",
              "arrAmount",
              "renewalDate",
              "signedAt"
            ],
            "mode": "create",
            "title": "New Account"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "CsAccountCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CsAccountEdit",
          "linkedEntity": "CsAccount",
          "config": {
            "mode": "edit",
            "icon": "edit",
            "fields": [
              "name",
              "plan",
              "status",
              "csm",
              "arrAmount",
              "renewalDate",
              "signedAt"
            ],
            "title": "Edit Account"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "CsAccountBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CsAccountView",
          "linkedEntity": "CsAccount",
          "config": {
            "fields": [
              "name",
              "plan",
              "status",
              "csm",
              "arrAmount",
              "renewalDate",
              "signedAt"
            ],
            "mode": "edit",
            "title": "View Account",
            "icon": "eye"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "CsAccountBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CsAccountDelete",
          "linkedEntity": "CsAccount",
          "config": {
            "title": "Delete Account",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "CsAccountBrowseList"
              }
            }
          ]
        },
        {
          "name": "CsAccountPersistor",
          "category": "lifecycle",
          "linkedEntity": "CsAccount",
          "emits": [
            {
              "event": "CS_ACCOUNT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CS_ACCOUNT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CS_ACCOUNT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "CsAccountCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "CsAccountEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "CsAccountDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CS_ACCOUNT_CREATED",
                "name": "Cs Account Created"
              },
              {
                "key": "CS_ACCOUNT_UPDATED",
                "name": "Cs Account Updated"
              },
              {
                "key": "CS_ACCOUNT_DELETED",
                "name": "Cs Account Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "CsAccount",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CS_ACCOUNT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "CsAccount",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CS_ACCOUNT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CsAccount",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "CS_ACCOUNT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "HealthScore.traits.HealthScoreDashboard",
          "name": "CsAccountHealthScores",
          "config": {
            "title": "Customer Health Scores"
          }
        },
        {
          "ref": "NpsSurvey.traits.NpsSurveyTracker",
          "name": "CsAccountNpsSurveys",
          "config": {
            "title": "NPS Surveys"
          }
        },
        {
          "ref": "RenewalRisk.traits.RenewalRiskWatch",
          "name": "CsAccountRenewalRisks",
          "config": {
            "title": "Renewal Risk"
          }
        }
      ],
      "pages": [
        {
          "name": "CsAccountsPage",
          "path": "/cs-accounts",
          "traits": [
            {
              "ref": "CsAccountAppLayout"
            },
            {
              "ref": "CsAccountCatalog"
            },
            {
              "ref": "CsAccountSearch"
            },
            {
              "ref": "CsAccountFilter"
            },
            {
              "ref": "CsAccountStats"
            },
            {
              "ref": "CsAccountGraphs"
            },
            {
              "ref": "CsAccountBrowseList"
            },
            {
              "ref": "CsAccountCreate"
            },
            {
              "ref": "CsAccountEdit"
            },
            {
              "ref": "CsAccountView"
            },
            {
              "ref": "CsAccountDelete"
            },
            {
              "ref": "CsAccountPersistor"
            }
          ]
        },
        {
          "name": "CsAccountHealthScoresPage",
          "path": "/health-scores",
          "traits": [
            {
              "ref": "CsAccountAppLayout"
            },
            {
              "ref": "CsAccountHealthScores"
            }
          ]
        },
        {
          "name": "CsAccountNpsSurveysPage",
          "path": "/nps-surveys",
          "traits": [
            {
              "ref": "CsAccountAppLayout"
            },
            {
              "ref": "CsAccountNpsSurveys"
            }
          ]
        },
        {
          "name": "CsAccountRenewalRisksPage",
          "path": "/renewal-risks",
          "traits": [
            {
              "ref": "CsAccountAppLayout"
            },
            {
              "ref": "CsAccountRenewalRisks"
            }
          ]
        }
      ]
    }
  ]
}