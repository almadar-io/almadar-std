{
  "name": "std-social-feed",
  "version": "2.0.0",
  "description": "Social feed: posts with images, likes, and threaded comments. Pick for Twitter/Instagram-style timelines.",
  "orbitals": [
    {
      "name": "PostOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-storage",
          "as": "Storage"
        },
        {
          "from": "std/behaviors/std-mod-queue",
          "as": "ModQueue"
        },
        {
          "from": "std/behaviors/std-notify-on-event",
          "as": "Notify"
        },
        {
          "from": "std/behaviors/std-data-erasure",
          "as": "Erasure"
        }
      ],
      "entity": {
        "name": "Post",
        "collection": "posts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "author",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "image",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "likes",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tag",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "PostAppLayout",
          "config": {
            "notificationClickEvent": "POST_NOTIFICATIONS_OPEN",
            "appName": "SocialFeed",
            "contentTrait": "@trait.FeedCatalog",
            "searchEvent": "POST_SEARCH",
            "navItems": [
              {
                "href": "/feed",
                "label": "Feed",
                "icon": "rss"
              },
              {
                "label": "Comments",
                "href": "/comments",
                "icon": "message-circle"
              }
            ],
            "notifications": []
          },
          "events": {
            "NOTIFY_CLICK": "POST_NOTIFICATIONS_OPEN",
            "SEARCH": "POST_SEARCH"
          }
        },
        {
          "name": "FeedCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "POST_SEARCH",
              "triggers": "POST_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "PostAppLayout"
              }
            },
            {
              "event": "POST_NOTIFICATIONS_OPEN",
              "triggers": "POST_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "PostAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "POST_SEARCH",
                "name": "Post Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "POST_NOTIFICATIONS_OPEN",
                "name": "Post Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "rss"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Feed"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "button",
                                  "label": "New Post",
                                  "icon": "plus",
                                  "variant": "primary",
                                  "action": "CREATE"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            "@trait.PostSearch"
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        "@trait.PostStats",
                        {
                          "type": "divider"
                        },
                        "@trait.PostBrowseList"
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "POST_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "POST_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "You're all caught up.",
                          "color": "muted"
                        },
                        {
                          "label": "Back to feed",
                          "variant": "ghost",
                          "type": "button",
                          "action": "INIT"
                        }
                      ],
                      "className": "py-8",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "PostSearch",
          "config": {
            "event": "POST_SEARCH",
            "placeholder": "Search posts…"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "PostStats",
          "config": {
            "metrics": [
              {
                "format": "number",
                "label": "Total Posts",
                "aggregation": "count",
                "variant": "primary",
                "icon": "rss"
              },
              {
                "aggregation": "count",
                "label": "Today",
                "icon": "calendar",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.timestamp",
                    "today"
                  ]
                ],
                "variant": "info"
              }
            ],
            "title": "Feed"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "PostBrowseList",
          "linkedEntity": "Post",
          "config": {
            "imageField": "image",
            "variant": "card",
            "cols": 1.0,
            "gap": "md",
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "variant": "ghost",
                "event": "EDIT",
                "label": "Edit"
              },
              {
                "variant": "danger",
                "label": "Delete",
                "event": "DELETE"
              }
            ],
            "fields": [
              {
                "name": "author",
                "variant": "h4",
                "icon": "user"
              },
              {
                "name": "content",
                "variant": "body"
              },
              {
                "name": "timestamp",
                "variant": "caption",
                "format": "date"
              },
              {
                "format": "number",
                "variant": "badge",
                "name": "likes"
              }
            ]
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "PostSearch"
              }
            },
            {
              "event": "POST_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PostPersistor"
              }
            },
            {
              "event": "POST_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PostPersistor"
              }
            },
            {
              "event": "POST_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PostPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PostCreate",
          "linkedEntity": "Post",
          "config": {
            "title": "New Post",
            "icon": "plus-circle",
            "mode": "create",
            "fields": [
              "author",
              "content",
              "image",
              "tag"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "FeedCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PostEdit",
          "linkedEntity": "Post",
          "config": {
            "fields": [
              "author",
              "content",
              "image",
              "tag"
            ],
            "icon": "edit",
            "title": "Edit Post",
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PostView",
          "linkedEntity": "Post",
          "config": {
            "fields": [
              "author",
              "content",
              "image",
              "tag",
              "likes"
            ],
            "title": "View Post",
            "mode": "edit",
            "icon": "eye"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "PostDeleteConfirm",
          "linkedEntity": "Post",
          "config": {
            "title": "Delete Post",
            "icon": "alert-triangle",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Storage.traits.ServiceStorageStorage",
          "name": "PostImageUpload",
          "config": {
            "allowedMimeTypes": [
              "image/png",
              "image/jpeg",
              "image/gif",
              "image/webp"
            ],
            "acl": "public",
            "uiTrait": "@trait.PostImageUploadForm",
            "bucket": "social-feed-images",
            "maxSize": 10485760.0
          }
        },
        {
          "name": "PostImageUploadForm",
          "category": "interaction",
          "emits": [
            {
              "event": "UPLOAD",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                },
                {
                  "name": "file",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Attach an image"
                        },
                        {
                          "inputType": "text",
                          "placeholder": "Choose image…",
                          "type": "input"
                        },
                        {
                          "icon": "upload",
                          "label": "Upload",
                          "type": "button",
                          "action": "UPLOAD",
                          "variant": "ghost"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PostPersistor",
          "category": "lifecycle",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "POST_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "POST_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "POST_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "PostCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "PostEdit"
              }
            },
            {
              "event": "DO_UPDATE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "PostLikeTracker"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "PostDeleteConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "POST_CREATED",
                "name": "Post Created"
              },
              {
                "key": "POST_UPDATED",
                "name": "Post Updated"
              },
              {
                "key": "POST_DELETED",
                "name": "Post Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Post",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "POST_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Post",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "POST_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Post",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "POST_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PostLikeTracker",
          "category": "interaction",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "DO_UPDATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LIKE",
                "name": "Like",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.likes",
                    0.0
                  ],
                  [
                    "fetch",
                    "Post"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "sm",
                      "children": [
                        {
                          "variant": "ghost",
                          "icon": "heart",
                          "type": "button",
                          "label": "Like",
                          "action": "LIKE"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "@entity.likes"
                        }
                      ],
                      "direction": "horizontal"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "LIKE",
                "effects": [
                  [
                    "set",
                    "@entity.likes",
                    "@payload.data.likes"
                  ],
                  [
                    "emit",
                    "DO_UPDATE",
                    {
                      "data": "@payload.data"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "ModQueue.traits.ModQueueItemReview",
          "name": "PostModQueue",
          "config": {
            "title": "Flagged Posts",
            "autoEscalateThreshold": 3.0
          }
        },
        {
          "ref": "Notify.traits.NotifyOnEventListener",
          "name": "PostFlaggedNotifier",
          "config": {
            "severity": "warning",
            "suppressionList": [],
            "recipients": [],
            "listensFor": [
              "PostFlagged"
            ],
            "template": "A post has been flagged for review",
            "notifyChannel": "in-app"
          },
          "events": {
            "EventOccurred": "PostFlagged"
          }
        },
        {
          "ref": "Erasure.traits.ErasureWorkflow",
          "name": "PostErasure",
          "config": {
            "targetEntity": "Post",
            "gracePeriodDays": 30.0,
            "anonymizeVsDelete": "anonymize",
            "piiFields": [
              "author",
              "content"
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "FeedPage",
          "path": "/feed",
          "traits": [
            {
              "ref": "PostAppLayout"
            },
            {
              "ref": "FeedCatalog"
            },
            {
              "ref": "PostSearch"
            },
            {
              "ref": "PostStats"
            },
            {
              "ref": "PostBrowseList"
            },
            {
              "ref": "PostCreate"
            },
            {
              "ref": "PostEdit"
            },
            {
              "ref": "PostView"
            },
            {
              "ref": "PostDeleteConfirm"
            },
            {
              "ref": "PostImageUpload"
            },
            {
              "ref": "PostImageUploadForm"
            },
            {
              "ref": "PostPersistor"
            },
            {
              "ref": "PostLikeTracker"
            },
            {
              "ref": "PostModQueue"
            },
            {
              "ref": "PostFlaggedNotifier"
            },
            {
              "ref": "PostErasure"
            }
          ]
        }
      ]
    },
    {
      "name": "CommentOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Comment",
        "collection": "comments",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "postId",
            "type": "string",
            "required": true
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "CommentAppLayout",
          "linkedEntity": "Comment",
          "config": {
            "searchEvent": "COMMENT_SEARCH",
            "notifications": [],
            "notificationClickEvent": "COMMENT_NOTIFICATIONS_OPEN",
            "appName": "SocialFeed",
            "contentTrait": "@trait.CommentDisplay",
            "navItems": [
              {
                "href": "/feed",
                "label": "Feed",
                "icon": "rss"
              },
              {
                "icon": "message-circle",
                "label": "Comments",
                "href": "/comments"
              }
            ]
          },
          "events": {
            "SEARCH": "COMMENT_SEARCH",
            "NOTIFY_CLICK": "COMMENT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "CommentDisplay",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "COMMENT_SEARCH",
              "triggers": "COMMENT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "CommentAppLayout"
              }
            },
            {
              "event": "COMMENT_NOTIFICATIONS_OPEN",
              "triggers": "COMMENT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "CommentAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMMENT_SEARCH",
                "name": "Comment Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMMENT_NOTIFICATIONS_OPEN",
                "name": "Comment Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Comments"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "action": "CREATE",
                                  "icon": "edit",
                                  "type": "button",
                                  "variant": "primary",
                                  "label": "New Comment"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.CommentBrowseList"
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "COMMENT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "COMMENT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "You're all caught up."
                        },
                        {
                          "type": "button",
                          "action": "INIT",
                          "label": "Back to comments",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "CommentBrowseList",
          "linkedEntity": "Comment",
          "config": {
            "gap": "sm",
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "label": "Delete",
                "variant": "danger",
                "event": "DELETE"
              }
            ],
            "fields": [
              {
                "variant": "h4",
                "icon": "user",
                "name": "author"
              },
              {
                "name": "body",
                "variant": "body"
              },
              {
                "format": "date",
                "name": "createdAt",
                "variant": "caption"
              }
            ],
            "variant": "card",
            "cols": 1.0
          },
          "listens": [
            {
              "event": "COMMENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CommentPersistor"
              }
            },
            {
              "event": "COMMENT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CommentPersistor"
              }
            },
            {
              "event": "COMMENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CommentPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CommentCreate",
          "linkedEntity": "Comment",
          "config": {
            "title": "New Comment",
            "fields": [
              "postId",
              "author",
              "body"
            ],
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "CommentDisplay"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CommentEdit",
          "linkedEntity": "Comment",
          "config": {
            "title": "Edit Comment",
            "icon": "edit",
            "mode": "edit",
            "fields": [
              "postId",
              "author",
              "body"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "CommentBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CommentView",
          "linkedEntity": "Comment",
          "config": {
            "mode": "edit",
            "title": "View Comment",
            "icon": "eye",
            "fields": [
              "postId",
              "author",
              "body",
              "createdAt"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "CommentBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CommentDeleteConfirm",
          "linkedEntity": "Comment",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "title": "Delete Comment",
            "confirmLabel": "Delete",
            "icon": "alert-triangle"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "CommentBrowseList"
              }
            }
          ]
        },
        {
          "name": "CommentPersistor",
          "category": "lifecycle",
          "linkedEntity": "Comment",
          "emits": [
            {
              "event": "COMMENT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMMENT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMMENT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "CommentCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "CommentEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "CommentDeleteConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMMENT_CREATED",
                "name": "Comment Created"
              },
              {
                "key": "COMMENT_UPDATED",
                "name": "Comment Updated"
              },
              {
                "key": "COMMENT_DELETED",
                "name": "Comment Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Comment",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "COMMENT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Comment",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "COMMENT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Comment",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "COMMENT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Comments",
          "path": "/comments",
          "traits": [
            {
              "ref": "CommentAppLayout"
            },
            {
              "ref": "CommentDisplay"
            },
            {
              "ref": "CommentBrowseList"
            },
            {
              "ref": "CommentCreate"
            },
            {
              "ref": "CommentEdit"
            },
            {
              "ref": "CommentView"
            },
            {
              "ref": "CommentDeleteConfirm"
            },
            {
              "ref": "CommentPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ModerationRuleFromStdOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-moderation-rule",
          "as": "Rules"
        }
      ],
      "entity": {
        "name": "ModerationRule",
        "collection": "moderation_rules",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "appliesTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "priority",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "testing",
              "archived"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ModerationRuleFromStdAppLayout",
          "linkedEntity": "ModerationRule",
          "config": {
            "appName": "SocialFeed",
            "contentTrait": "@trait.ModerationRuleFromStdManageBlock",
            "notificationClickEvent": "MODERATION_RULE_NOTIFICATIONS_OPEN",
            "searchEvent": "MODERATION_RULE_SEARCH",
            "notifications": [],
            "navItems": [
              {
                "href": "/feed",
                "label": "Feed",
                "icon": "rss"
              },
              {
                "icon": "message-circle",
                "label": "Comments",
                "href": "/comments"
              },
              {
                "label": "Moderation Rules",
                "href": "/moderation-rules",
                "icon": "shield-alert"
              }
            ]
          },
          "events": {
            "NOTIFY_CLICK": "MODERATION_RULE_NOTIFICATIONS_OPEN",
            "SEARCH": "MODERATION_RULE_SEARCH"
          }
        },
        {
          "ref": "Rules.traits.ModerationRuleManage",
          "name": "ModerationRuleFromStdManageBlock",
          "linkedEntity": "ModerationRule",
          "config": {
            "title": "Moderation Rules"
          }
        }
      ],
      "pages": [
        {
          "name": "ModerationRuleFromStdPage",
          "path": "/moderation-rules",
          "traits": [
            {
              "ref": "ModerationRuleFromStdAppLayout"
            },
            {
              "ref": "ModerationRuleFromStdManageBlock"
            }
          ]
        }
      ]
    }
  ]
}