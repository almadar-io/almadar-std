{
  "name": "std-social-feed",
  "version": "2.0.0",
  "description": "Social feed: posts with images, likes, and threaded comments. Pick for Twitter/Instagram-style timelines.",
  "orbitals": [
    {
      "name": "PostOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-storage",
          "as": "Storage"
        }
      ],
      "entity": {
        "name": "Post",
        "collection": "posts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "author",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "image",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "likes",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tag",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "PostAppLayout",
          "config": {
            "notifications": [],
            "notificationClickEvent": "POST_NOTIFICATIONS_OPEN",
            "searchEvent": "POST_SEARCH",
            "navItems": [
              {
                "label": "Feed",
                "icon": "rss",
                "href": "/feed"
              },
              {
                "href": "/comments",
                "icon": "message-circle",
                "label": "Comments"
              }
            ],
            "contentTrait": "@trait.FeedCatalog",
            "appName": "SocialFeed"
          },
          "events": {
            "SEARCH": "POST_SEARCH",
            "NOTIFY_CLICK": "POST_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "FeedCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "POST_SEARCH",
              "triggers": "POST_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "PostAppLayout"
              }
            },
            {
              "event": "POST_NOTIFICATIONS_OPEN",
              "triggers": "POST_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "PostAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "POST_SEARCH",
                "name": "Post Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "POST_NOTIFICATIONS_OPEN",
                "name": "Post Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "rss",
                                  "type": "icon"
                                },
                                {
                                  "content": "Feed",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "action": "CREATE",
                                  "icon": "plus",
                                  "variant": "primary",
                                  "type": "button",
                                  "label": "New Post"
                                }
                              ]
                            }
                          ],
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.PostSearch"
                          ],
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        "@trait.PostStats",
                        {
                          "type": "divider"
                        },
                        "@trait.PostBrowseList"
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "POST_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "POST_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "You're all caught up.",
                          "variant": "caption"
                        },
                        {
                          "type": "button",
                          "label": "Back to feed",
                          "action": "INIT",
                          "variant": "ghost"
                        }
                      ],
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "PostSearch",
          "config": {
            "event": "POST_SEARCH",
            "placeholder": "Search posts…"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "PostStats",
          "config": {
            "metrics": [
              {
                "format": "number",
                "icon": "rss",
                "aggregation": "count",
                "label": "Total Posts",
                "variant": "primary"
              },
              {
                "format": "number",
                "label": "Today",
                "aggregation": "count",
                "variant": "info",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.timestamp",
                    "today"
                  ]
                ],
                "icon": "calendar"
              },
              {
                "variant": "default",
                "format": "text",
                "aggregation": "mode",
                "label": "Top Author",
                "field": "author",
                "icon": "user"
              },
              {
                "icon": "hash",
                "field": "tag",
                "aggregation": "mode",
                "format": "text",
                "label": "Top Tag",
                "variant": "warning"
              }
            ],
            "title": "Feed"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "PostBrowseList",
          "linkedEntity": "Post",
          "config": {
            "fields": [
              {
                "name": "author",
                "icon": "user",
                "variant": "h4"
              },
              {
                "variant": "body",
                "name": "content"
              },
              {
                "variant": "caption",
                "format": "date",
                "name": "timestamp"
              },
              {
                "format": "number",
                "name": "likes",
                "variant": "badge"
              }
            ],
            "cols": 1.0,
            "imageField": "image",
            "gap": "md",
            "variant": "card",
            "itemActions": [
              {
                "variant": "ghost",
                "event": "VIEW",
                "label": "View"
              },
              {
                "label": "Edit",
                "event": "EDIT",
                "variant": "ghost"
              },
              {
                "variant": "danger",
                "label": "Delete",
                "event": "DELETE"
              }
            ]
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "PostSearch"
              }
            },
            {
              "event": "POST_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PostPersistor"
              }
            },
            {
              "event": "POST_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PostPersistor"
              }
            },
            {
              "event": "POST_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PostPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PostCreate",
          "linkedEntity": "Post",
          "config": {
            "title": "New Post",
            "mode": "create",
            "fields": [
              "author",
              "content",
              "image",
              "tag"
            ],
            "icon": "plus-circle"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "FeedCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PostEdit",
          "linkedEntity": "Post",
          "config": {
            "icon": "edit",
            "mode": "edit",
            "title": "Edit Post",
            "fields": [
              "author",
              "content",
              "image",
              "tag"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PostView",
          "linkedEntity": "Post",
          "config": {
            "title": "View Post",
            "icon": "eye",
            "mode": "edit",
            "fields": [
              "author",
              "content",
              "image",
              "tag",
              "likes"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "PostDeleteConfirm",
          "linkedEntity": "Post",
          "config": {
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "title": "Delete Post",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "PostBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Storage.traits.ServiceStorageStorage",
          "name": "PostImageUpload",
          "config": {
            "allowedMimeTypes": [
              "image/png",
              "image/jpeg",
              "image/gif",
              "image/webp"
            ],
            "maxSize": 10485760.0,
            "uiTrait": "@trait.PostImageUploadForm",
            "acl": "public",
            "bucket": "social-feed-images"
          }
        },
        {
          "name": "PostImageUploadForm",
          "category": "interaction",
          "emits": [
            {
              "event": "UPLOAD",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                },
                {
                  "name": "file",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Attach an image"
                        },
                        {
                          "type": "input",
                          "placeholder": "Choose image…",
                          "inputType": "text"
                        },
                        {
                          "icon": "upload",
                          "type": "button",
                          "action": "UPLOAD",
                          "label": "Upload",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PostPersistor",
          "category": "lifecycle",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "POST_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "POST_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "POST_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "PostCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "PostEdit"
              }
            },
            {
              "event": "DO_UPDATE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "PostLikeTracker"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "PostDeleteConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "POST_CREATED",
                "name": "Post Created"
              },
              {
                "key": "POST_UPDATED",
                "name": "Post Updated"
              },
              {
                "key": "POST_DELETED",
                "name": "Post Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Post",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "POST_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Post",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "POST_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Post",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "POST_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PostLikeTracker",
          "category": "interaction",
          "linkedEntity": "Post",
          "emits": [
            {
              "event": "DO_UPDATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LIKE",
                "name": "Like",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.likes",
                    0.0
                  ],
                  [
                    "fetch",
                    "Post"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "icon": "heart",
                          "label": "Like",
                          "type": "button",
                          "action": "LIKE",
                          "variant": "ghost"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "@entity.likes"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "LIKE",
                "effects": [
                  [
                    "set",
                    "@entity.likes",
                    "@payload.data.likes"
                  ],
                  [
                    "emit",
                    "DO_UPDATE",
                    {
                      "data": "@payload.data"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FeedPage",
          "path": "/feed",
          "traits": [
            {
              "ref": "PostAppLayout"
            },
            {
              "ref": "FeedCatalog"
            },
            {
              "ref": "PostSearch"
            },
            {
              "ref": "PostStats"
            },
            {
              "ref": "PostBrowseList"
            },
            {
              "ref": "PostCreate"
            },
            {
              "ref": "PostEdit"
            },
            {
              "ref": "PostView"
            },
            {
              "ref": "PostDeleteConfirm"
            },
            {
              "ref": "PostImageUpload"
            },
            {
              "ref": "PostImageUploadForm"
            },
            {
              "ref": "PostPersistor"
            },
            {
              "ref": "PostLikeTracker"
            }
          ]
        }
      ]
    },
    {
      "name": "CommentOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Comment",
        "collection": "comments",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "postId",
            "type": "string",
            "required": true
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "CommentAppLayout",
          "linkedEntity": "Comment",
          "config": {
            "notifications": [],
            "appName": "SocialFeed",
            "contentTrait": "@trait.CommentDisplay",
            "searchEvent": "COMMENT_SEARCH",
            "navItems": [
              {
                "icon": "rss",
                "href": "/feed",
                "label": "Feed"
              },
              {
                "href": "/comments",
                "label": "Comments",
                "icon": "message-circle"
              }
            ],
            "notificationClickEvent": "COMMENT_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "COMMENT_SEARCH",
            "NOTIFY_CLICK": "COMMENT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "CommentDisplay",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "COMMENT_SEARCH",
              "triggers": "COMMENT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "CommentAppLayout"
              }
            },
            {
              "event": "COMMENT_NOTIFICATIONS_OPEN",
              "triggers": "COMMENT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "CommentAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMMENT_SEARCH",
                "name": "Comment Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMMENT_NOTIFICATIONS_OPEN",
                "name": "Comment Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Comments",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "action": "CREATE",
                                  "label": "New Comment",
                                  "variant": "primary",
                                  "icon": "edit",
                                  "type": "button"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.CommentBrowseList"
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "className": "max-w-5xl mx-auto w-full",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "COMMENT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "COMMENT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "variant": "h3",
                          "content": "No notifications",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "You're all caught up.",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "label": "Back to comments",
                          "type": "button",
                          "variant": "ghost",
                          "action": "INIT"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "CommentBrowseList",
          "linkedEntity": "Comment",
          "config": {
            "fields": [
              {
                "icon": "user",
                "variant": "h4",
                "name": "author"
              },
              {
                "name": "body",
                "variant": "body"
              },
              {
                "format": "date",
                "variant": "caption",
                "name": "createdAt"
              }
            ],
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "variant": "ghost",
                "label": "Edit",
                "event": "EDIT"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "cols": 1.0,
            "gap": "sm",
            "variant": "card"
          },
          "listens": [
            {
              "event": "COMMENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CommentPersistor"
              }
            },
            {
              "event": "COMMENT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CommentPersistor"
              }
            },
            {
              "event": "COMMENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "CommentPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CommentCreate",
          "linkedEntity": "Comment",
          "config": {
            "fields": [
              "postId",
              "author",
              "body"
            ],
            "title": "New Comment",
            "mode": "create",
            "icon": "plus-circle"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "CommentDisplay"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CommentEdit",
          "linkedEntity": "Comment",
          "config": {
            "fields": [
              "postId",
              "author",
              "body"
            ],
            "mode": "edit",
            "icon": "edit",
            "title": "Edit Comment"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "CommentBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "CommentView",
          "linkedEntity": "Comment",
          "config": {
            "fields": [
              "postId",
              "author",
              "body",
              "createdAt"
            ],
            "icon": "eye",
            "mode": "edit",
            "title": "View Comment"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "CommentBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "CommentDeleteConfirm",
          "linkedEntity": "Comment",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Comment",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "CommentBrowseList"
              }
            }
          ]
        },
        {
          "name": "CommentPersistor",
          "category": "lifecycle",
          "linkedEntity": "Comment",
          "emits": [
            {
              "event": "COMMENT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMMENT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMMENT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "CommentCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "CommentEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "CommentDeleteConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMMENT_CREATED",
                "name": "Comment Created"
              },
              {
                "key": "COMMENT_UPDATED",
                "name": "Comment Updated"
              },
              {
                "key": "COMMENT_DELETED",
                "name": "Comment Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Comment",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "COMMENT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Comment",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "COMMENT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Comment",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "COMMENT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Comments",
          "path": "/comments",
          "traits": [
            {
              "ref": "CommentAppLayout"
            },
            {
              "ref": "CommentDisplay"
            },
            {
              "ref": "CommentBrowseList"
            },
            {
              "ref": "CommentCreate"
            },
            {
              "ref": "CommentEdit"
            },
            {
              "ref": "CommentView"
            },
            {
              "ref": "CommentDeleteConfirm"
            },
            {
              "ref": "CommentPersistor"
            }
          ]
        }
      ]
    }
  ]
}
