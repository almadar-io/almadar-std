                              "action": "CONFIRM_DELETE",
                              "variant": "danger",
                              "label": "Delete",
                              "type": "button",
                              "icon": "check"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Ticket",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "TicketDeleteFailed",
                        "success": "TicketDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Ticket"
                  ],
                  [
                    "emit",
                    "TICKET_DELETED"
                  ]
