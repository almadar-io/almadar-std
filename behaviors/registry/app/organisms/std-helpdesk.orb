                "name": "Close"
              },
              {
                "key": "TICKET_DELETED",
                "name": "Ticket Deleted"
              },
              {
                "key": "TicketDeleteFailed",
                "name": "Ticket delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
