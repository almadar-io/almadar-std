{
  "name": "std-helpdesk",
  "version": "1.0.0",
  "description": "std-helpdesk as a Function",
  "orbitals": [
    {
      "name": "TicketOrbital",
      "entity": {
        "name": "Ticket",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "in-progress",
              "resolved",
              "closed"
            ]
          },
          {
            "name": "assignee",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TicketBrowse",
          "category": "interaction",
          "linkedEntity": "Ticket",
          "emits": [
            {
              "event": "ASSIGN",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketLoaded",
              "description": "Fired when Ticket finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Ticket]"
                }
              ]
            },
            {
              "event": "TicketLoadFailed",
              "description": "Fired when Ticket fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ResponseSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ResponseSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TICKET_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TicketCreate"
              }
            },
            {
              "event": "TICKET_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TicketEdit"
              }
            },
            {
              "event": "TICKET_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TicketDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TicketLoaded",
                "name": "Ticket loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Ticket]"
                  }
                ]
              },
              {
                "key": "TicketLoadFailed",
                "name": "Ticket load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ASSIGN",
                "name": "Assign"
              },
              {
                "key": "TicketSaved",
                "name": "Ticket saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketSaveFailed",
                "name": "Ticket save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketUpdated",
                "name": "Ticket updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketUpdateFailed",
                "name": "Ticket update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketDeleted",
                "name": "Ticket deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketDeleteFailed",
                "name": "Ticket delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ResponseSaved",
                "name": "Response saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ResponseSaveFailed",
                "name": "Response save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "failure": "TicketLoadFailed",
                        "success": "TicketLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading…"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TicketLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Helpdesk",
                      "navItems": [
                        {
                          "icon": "inbox",
                          "href": "/tickets",
                          "label": "Tickets"
                        },
                        {
                          "label": "Responses",
                          "href": "/responses",
                          "icon": "message-circle"
                        },
                        {
                          "label": "Metrics",
                          "icon": "layout-list",
                          "href": "/metrics"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "name": "inbox",
                                      "type": "icon"
                                    },
                                    {
                                      "content": "Tickets",
                                      "variant": "h2",
                                      "type": "typography"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm",
                                  "align": "center"
                                },
                                {
                                  "children": [
                                    {
                                      "label": "New Ticket",
                                      "icon": "plus",
                                      "action": "CREATE",
                                      "variant": "primary",
                                      "type": "button"
                                    }
                                  ],
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "gap": "sm"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "cols": 1.0,
                              "children": [
                                {
                                  "icon": "inbox",
                                  "label": "Open Tickets",
                                  "value": "@entity",
                                  "type": "stat-display"
                                }
                              ],
                              "type": "simple-grid"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "entity": "@payload.data",
                              "fields": [],
                              "variant": "card",
                              "gap": "sm",
                              "type": "data-list",
                              "itemActions": [
                                {
                                  "label": "View",
                                  "event": "VIEW",
                                  "variant": "ghost"
                                },
                                {
                                  "label": "Edit",
                                  "event": "EDIT",
                                  "variant": "ghost"
                                },
                                {
                                  "label": "Delete",
                                  "variant": "danger",
                                  "event": "DELETE"
                                }
                              ],
                              "columns": [
                                {
                                  "icon": "inbox",
                                  "variant": "h3",
                                  "name": "subject"
                                },
                                {
                                  "name": "priority",
                                  "variant": "badge"
                                },
                                {
                                  "name": "status",
                                  "variant": "badge"
                                },
                                {
                                  "variant": "body",
                                  "name": "assignee"
                                },
                                {
                                  "variant": "caption",
                                  "name": "description"
                                }
                              ]
                            }
                          ],
                          "gap": "lg"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TicketLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load ticket"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error",
                          "variant": "body"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TicketCreate",
          "category": "interaction",
          "linkedEntity": "Ticket",
          "emits": [
            {
              "event": "TICKET_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketLoadFailed",
              "description": "Fired when Ticket fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketLoaded",
              "description": "Fired when Ticket finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Ticket]"
                }
              ]
            },
            {
              "event": "TicketSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TICKET_CREATED",
                "name": "Ticket Created"
              },
              {
                "key": "TicketLoadFailed",
                "name": "Ticket load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketLoaded",
                "name": "Ticket loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Ticket]"
                  }
                ]
              },
              {
                "key": "TicketSaveFailed",
                "name": "Ticket save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketSaved",
                "name": "Ticket saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Ticket"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Ticket",
                    {
                      "emit": {
                        "success": "TicketLoaded",
                        "failure": "TicketLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Create Ticket"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "fields": [
                            "subject",
                            "description",
                            "priority",
                            "status",
                            "assignee"
                          ],
                          "type": "form-section"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Ticket",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "TicketSaveFailed",
                        "success": "TicketSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "TICKET_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "TicketEdit",
          "category": "interaction",
          "linkedEntity": "Ticket",
          "emits": [
            {
              "event": "TICKET_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketLoadFailed",
              "description": "Fired when Ticket fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketLoaded",
              "description": "Fired when Ticket finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Ticket]"
                }
              ]
            },
            {
              "event": "TicketUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TicketUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Ticket"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TICKET_UPDATED",
                "name": "Ticket Updated"
              },
              {
                "key": "TicketLoadFailed",
                "name": "Ticket load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketLoaded",
                "name": "Ticket loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Ticket]"
                  }
                ]
              },
              {
                "key": "TicketUpdateFailed",
                "name": "Ticket update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TicketUpdated",
                "name": "Ticket updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Ticket"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Ticket",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "TicketLoadFailed",
                        "success": "TicketLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "variant": "h3",
                              "content": "Edit Ticket",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "submitEvent": "SAVE",
                          "type": "form-section",
                          "mode": "edit",
                          "entity": "@payload.row",
                          "fields": [
                            "subject",
                            "description",
                            "priority",
                            "status",
                            "assignee"
                          ]
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
