                              "value": 22.0
                            },
                            {
                              "date": "Jun",
                              "value": 30.0
                            }
                          ],
                          "type": "line-chart"
                        },
                        {
                          "type": "chart-legend",
                          "items": [
                            {
                              "color": "primary",
                              "label": "Current"
                            },
                            {
                              "color": "muted",
                              "label": "Previous"
                            }
                          ]
                        },
                        {
                          "type": "graph-view",
                          "height": 200.0,
                          "nodes": [
                            {
                              "label": "Start",
                              "id": "a"
                            },
                            {
                              "label": "Process",
                              "id": "b"
                            },
                            {
                              "label": "End",
                              "id": "c"
                            }
                          ],
                          "edges": [
                            {
                              "source": "a",
                              "target": "b"
                            },
                            {
                              "target": "c",
                              "source": "b"
                            }
                          ],
                          "width": 400.0
                        }
                      ]
                    }
                  ]
                ]
              },
