                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "bell"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "DeviceAlert",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "md",
                                  "align": "center"
                                },
                                {
                                  "label": "Circuit Closed",
                                  "status": "online",
