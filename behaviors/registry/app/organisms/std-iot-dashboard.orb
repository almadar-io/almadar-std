{
  "name": "std-iot-dashboard",
  "version": "2.0.0",
  "description": "IoT dashboard: devices, sensor readings, and alerts. Pick for connected-device monitoring.",
  "orbitals": [
    {
      "name": "SensorReadingOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "SensorReading",
        "collection": "sensorreadings",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sensorId",
            "type": "string",
            "required": true
          },
          {
            "name": "value",
            "type": "number",
            "required": true
          },
          {
            "name": "unit",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "type",
            "type": "string",
            "default": ""
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "name": "SensorCatalog",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "thermometer",
                                  "type": "icon"
                                },
                                {
                                  "content": "Sensor Readings",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "sm",
                              "align": "center",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.SensorStats",
                        "@trait.SensorGraphs",
                        {
                          "min": 0.0,
                          "value": "@entity.value",
                          "type": "meter",
                          "max": "@entity.threshold",
                          "label": "Latest reading vs threshold"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.SensorBrowseList"
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "SensorStats",
          "config": {
            "title": "Sensors",
            "metrics": [
              {
                "aggregation": "count",
                "format": "number",
                "icon": "activity",
                "label": "Active Sensors",
                "variant": "primary",
                "filter": [
                  "fn",
                  "row",
                  [
                    "!=",
                    "@row.sensorId",
                    ""
                  ]
                ]
              },
              {
                "label": "Avg Reading",
                "aggregation": "average",
                "field": "value",
                "variant": "success",
                "icon": "trending-up",
                "format": "number"
              },
              {
                "label": "Anomalies",
                "aggregation": "count",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    ">",
                    "@row.value",
                    "@row.threshold"
                  ]
                ],
                "variant": "warning",
                "icon": "alert-triangle"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "SensorBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "SensorGraphs",
          "config": {
            "chartType": "line",
            "title": "Readings over time",
            "dateField": "timestamp",
            "valueField": "value",
            "height": 240.0,
            "subtitle": "Sensor values across time",
            "showLegend": true
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "SensorBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "SensorBrowseList",
          "linkedEntity": "SensorReading",
          "config": {
            "gap": "sm",
            "fields": [
              {
                "icon": "thermometer",
                "variant": "h4",
                "name": "sensorId",
                "label": "Sensor"
              },
              {
                "label": "Type",
                "name": "type",
                "variant": "badge"
              },
              {
                "label": "Value",
                "variant": "h4",
                "format": "number",
                "name": "value"
              },
              {
                "label": "Unit",
                "name": "unit",
                "variant": "caption"
              },
              {
                "name": "timestamp",
                "format": "date",
                "label": "Timestamp",
                "variant": "caption"
              }
            ],
            "cols": 1.0
          }
        }
      ],
      "pages": [
        {
          "name": "SensorsPage",
          "path": "/sensors",
          "traits": [
            {
              "ref": "SensorCatalog"
            },
            {
              "ref": "SensorStats"
            },
            {
              "ref": "SensorGraphs"
            },
            {
              "ref": "SensorBrowseList"
            }
          ]
        }
      ]
    },
    {
      "name": "DeviceOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Device",
        "collection": "devices",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "type",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "offline",
            "values": [
              "online",
              "offline",
              "maintenance"
            ]
          },
          {
            "name": "lastSeen",
            "type": "datetime"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "DeviceAppLayout",
          "config": {
            "notifications": [],
            "appName": "IoT Dashboard",
            "contentTrait": "@trait.DeviceCatalog",
            "notificationClickEvent": "DEVICE_NOTIFICATIONS_OPEN",
            "navItems": [
              {
                "label": "Sensors",
                "href": "/sensors",
                "icon": "layout-list"
              },
              {
                "icon": "cpu",
                "href": "/devices",
                "label": "Devices"
              },
              {
                "label": "Alerts",
                "href": "/alerts",
                "icon": "bell"
              }
            ],
            "searchEvent": "DEVICE_SEARCH"
          },
          "events": {
            "SEARCH": "DEVICE_SEARCH",
            "NOTIFY_CLICK": "DEVICE_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "DeviceCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DEVICE_SEARCH",
              "triggers": "DEVICE_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "DeviceAppLayout"
              }
            },
            {
              "event": "DEVICE_NOTIFICATIONS_OPEN",
              "triggers": "DEVICE_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "DeviceAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DEVICE_SEARCH",
                "name": "Device Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DEVICE_NOTIFICATIONS_OPEN",
                "name": "Device Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "cpu",
                                  "type": "icon"
                                },
                                {
                                  "content": "Devices",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "children": [
                                {
                                  "type": "button",
                                  "label": "Create Device",
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "icon": "plus"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            "@trait.DeviceSearch",
                            "@trait.DeviceFilter"
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.DeviceBrowseList"
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "DEVICE_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "DEVICE_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-8",
                      "align": "center",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "content": "You're all caught up.",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "label": "Back",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "DeviceSearch",
          "config": {
            "event": "DEVICE_SEARCH",
            "placeholder": "Search devices…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "DeviceFilter",
          "config": {
            "filters": [
              {
                "field": "status",
                "filterType": "select",
                "label": "Status",
                "options": [
                  "online",
                  "offline",
                  "maintenance"
                ]
              },
              {
                "options": [
                  "sensor",
                  "gateway",
                  "actuator",
                  "controller"
                ],
                "label": "Type",
                "field": "type",
                "filterType": "select"
              }
            ],
            "event": "DEVICE_FILTER"
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "DeviceBrowseList",
          "linkedEntity": "Device",
          "config": {
            "fields": [
              {
                "name": "name",
                "variant": "h3",
                "icon": "cpu"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "name": "type",
                "variant": "body"
              },
              {
                "format": "date",
                "name": "lastSeen",
                "label": "Last Seen",
                "variant": "caption"
              }
            ],
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "event": "EDIT",
                "label": "Edit",
                "variant": "ghost"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "gap": "md",
            "cols": 3.0
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "DeviceSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "DeviceFilter"
              }
            },
            {
              "event": "DEVICE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DevicePersistor"
              }
            },
            {
              "event": "DEVICE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DevicePersistor"
              }
            },
            {
              "event": "DEVICE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DevicePersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "DeviceCreate",
          "linkedEntity": "Device",
          "config": {
            "fields": [
              "name",
              "type",
              "status",
              "lastSeen"
            ],
            "title": "Create Device",
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "DeviceCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "DeviceEdit",
          "linkedEntity": "Device",
          "config": {
            "title": "Edit Device",
            "mode": "edit",
            "fields": [
              "name",
              "type",
              "status",
              "lastSeen"
            ],
            "icon": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "DeviceBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "DeviceView",
          "linkedEntity": "Device",
          "config": {
            "fields": [
              "name",
              "type",
              "status",
              "lastSeen"
            ],
            "icon": "eye",
            "title": "View Device",
            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "DeviceBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "DeviceDelete",
          "linkedEntity": "Device",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "title": "Delete Device"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "DeviceBrowseList"
              }
            }
          ]
        },
        {
          "name": "DevicePersistor",
          "category": "lifecycle",
          "linkedEntity": "Device",
          "emits": [
            {
              "event": "DEVICE_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DEVICE_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DEVICE_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "DeviceCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "DeviceEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "DeviceDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DEVICE_CREATED",
                "name": "Device Created"
              },
              {
                "key": "DEVICE_UPDATED",
                "name": "Device Updated"
              },
              {
                "key": "DEVICE_DELETED",
                "name": "Device Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Device",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "DEVICE_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Device",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "DEVICE_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Device",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "DEVICE_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Devices",
          "path": "/devices",
          "traits": [
            {
              "ref": "DeviceAppLayout"
            },
            {
              "ref": "DeviceCatalog"
            },
            {
              "ref": "DeviceSearch"
            },
            {
              "ref": "DeviceFilter"
            },
            {
              "ref": "DeviceBrowseList"
            },
            {
              "ref": "DeviceCreate"
            },
            {
              "ref": "DeviceEdit"
            },
            {
              "ref": "DeviceView"
            },
            {
              "ref": "DeviceDelete"
            },
            {
              "ref": "DevicePersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "DeviceAlertOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-email",
          "as": "Email"
        }
      ],
      "entity": {
        "name": "DeviceAlert",
        "collection": "devicealerts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "deviceId",
            "type": "string",
            "required": true
          },
          {
            "name": "severity",
            "type": "string",
            "default": "info",
            "values": [
              "info",
              "warning",
              "critical"
            ]
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledged",
            "type": "boolean",
            "default": false
          },
          {
            "name": "failureCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "successCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AlertCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "bell",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Alerts",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "button",
                                  "variant": "primary",
                                  "icon": "plus",
                                  "action": "CREATE",
                                  "label": "New Alert"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.AlertBrowseList",
                        {
                          "type": "divider"
                        },
                        "@trait.DeviceAlertCircuitBreaker"
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "AlertBrowseList",
          "linkedEntity": "DeviceAlert",
          "config": {
            "gap": "sm",
            "cols": 1.0,
            "fields": [
              {
                "variant": "h4",
                "label": "Device",
                "icon": "cpu",
                "name": "deviceId"
              },
              {
                "label": "Severity",
                "variant": "badge",
                "name": "severity"
              },
              {
                "label": "Message",
                "name": "message",
                "variant": "body"
              },
              {
                "name": "acknowledged",
                "variant": "badge",
                "label": "Acknowledged",
                "format": "boolean"
              }
            ],
            "itemActions": [
              {
                "event": "VIEW",
                "variant": "ghost",
                "label": "View"
              },
              {
                "variant": "ghost",
                "label": "Edit",
                "event": "EDIT"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ]
          },
          "listens": [
            {
              "event": "ALERT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            },
            {
              "event": "ALERT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            },
            {
              "event": "ALERT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "AlertCreate",
          "linkedEntity": "DeviceAlert",
          "config": {
            "mode": "create",
            "fields": [
              "deviceId",
              "severity",
              "message",
              "acknowledged"
            ],
            "icon": "plus-circle",
            "title": "New Alert"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "AlertCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "AlertEdit",
          "linkedEntity": "DeviceAlert",
          "config": {
            "title": "Edit Alert",
            "fields": [
              "deviceId",
              "severity",
              "message",
              "acknowledged"
            ],
            "icon": "edit",
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "AlertBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "AlertView",
          "linkedEntity": "DeviceAlert",
          "config": {
            "mode": "edit",
            "fields": [
              "deviceId",
              "severity",
              "message",
              "acknowledged"
            ],
            "icon": "eye",
            "title": "View Alert"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "AlertBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "AlertDelete",
          "linkedEntity": "DeviceAlert",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "title": "Delete Alert"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "AlertBrowseList"
              }
            }
          ]
        },
        {
          "name": "AlertPersistor",
          "category": "lifecycle",
          "linkedEntity": "DeviceAlert",
          "emits": [
            {
              "event": "ALERT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ALERT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ALERT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "AlertCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "AlertEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "AlertDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ALERT_CREATED",
                "name": "Alert Created"
              },
              {
                "key": "ALERT_UPDATED",
                "name": "Alert Updated"
              },
              {
                "key": "ALERT_DELETED",
                "name": "Alert Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "DeviceAlert",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ALERT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "DeviceAlert",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ALERT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "DeviceAlert",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ALERT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "AlertEmailNotice",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Critical alerts auto-notify on-call ops via email."
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Email.traits.ServiceEmailEmail",
          "name": "AlertEmail",
          "config": {
            "recipient": "ops@example.com",
            "subject": "Critical alert raised",
            "sender": "alerts@example.com",
            "body": "A critical alert was raised on a device. Investigate immediately.",
            "uiTrait": "@trait.AlertEmailNotice"
          },
          "listens": [
            {
              "event": "ALERT_CREATED",
              "triggers": "SEND",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            }
          ]
        },
        {
          "name": "DeviceAlertCircuitBreaker",
          "category": "interaction",
          "linkedEntity": "DeviceAlert",
          "emits": [
            {
              "event": "DeviceAlertLoaded",
              "description": "Fired when DeviceAlert finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DeviceAlert]"
                }
              ]
            },
            {
              "event": "DeviceAlertLoadFailed",
              "description": "Fired when DeviceAlert fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              },
              {
                "name": "halfOpen"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FAILURE",
                "name": "Failure"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "TIMEOUT",
                "name": "Timeout"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "DeviceAlertLoaded",
                "name": "DeviceAlert loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DeviceAlert]"
                  }
                ]
              },
              {
                "key": "DeviceAlertLoadFailed",
                "name": "DeviceAlert load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.failureCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.successCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.threshold",
                    0.0
                  ],
                  [
                    "fetch",
                    "DeviceAlert",
                    {
                      "emit": {
                        "success": "DeviceAlertLoaded",
                        "failure": "DeviceAlertLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h3",
                                  "content": "Circuit Breaker"
                                }
                              ],
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "label": "Closed",
                              "pulse": false,
                              "type": "status-dot",
                              "status": "online"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "justify": "between"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed."
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "value": "@entity.failureCount",
                          "min": 0.0,
                          "max": "@entity.threshold",
                          "type": "meter"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Circuit Breaker",
                                  "variant": "h3",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "status-dot",
                              "status": "critical",
                              "label": "Open",
                              "pulse": true
                            }
                          ]
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures."
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.successCount",
                              "label": "Successes"
                            }
                          ],
                          "cols": 2.0
                        },
                        {
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "min": 0.0
                        },
                        {
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "label": "Reset",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "shield-check",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Circuit Breaker",
                                  "variant": "h3"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center"
                            },
                            {
                              "status": "online",
                              "label": "Closed",
                              "pulse": false,
                              "type": "status-dot"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Service is healthy."
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "min": 0.0,
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "max": "@entity.threshold"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "halfOpen",
                "event": "TIMEOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "content": "Circuit Breaker",
                                  "variant": "h3",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "label": "Half-Open",
                              "status": "warning",
                              "pulse": true
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "variant": "warning",
                          "message": "Testing recovery. Limited requests allowed.",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "variant": "h3",
                                  "type": "typography",
                                  "content": "Circuit Breaker"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "md"
                            },
                            {
                              "type": "status-dot",
                              "status": "online",
                              "pulse": false,
                              "label": "Closed"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "message": "Service is healthy.",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "max": "@entity.threshold",
                          "min": 0.0,
                          "type": "meter",
                          "value": "@entity.failureCount"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "shield-check",
                                  "type": "icon"
                                },
                                {
                                  "content": "Circuit Breaker",
                                  "type": "typography",
                                  "variant": "h3"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "md"
                            },
                            {
                              "pulse": false,
                              "status": "online",
                              "type": "status-dot",
                              "label": "Closed"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy.",
                          "variant": "success"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "value": "@entity.failureCount",
                              "label": "Failures",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.successCount",
                              "label": "Successes",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "meter",
                          "value": "@entity.failureCount",
                          "min": 0.0,
                          "max": "@entity.threshold"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "alert-triangle"
                                },
                                {
                                  "content": "Circuit Breaker",
                                  "type": "typography",
                                  "variant": "h3"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "status": "critical",
                              "pulse": true,
                              "type": "status-dot",
                              "label": "Open"
                            }
                          ]
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "Circuit is open."
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "type": "meter",
                          "min": 0.0
                        },
                        {
                          "action": "RESET",
                          "label": "Reset",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "type": "typography",
                                  "content": "Circuit Breaker",
                                  "variant": "h3"
                                }
                              ]
                            },
                            {
                              "pulse": false,
                              "label": "Closed",
                              "status": "online",
                              "type": "status-dot"
                            }
                          ],
                          "align": "center",
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Service is healthy."
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.failureCount",
                              "label": "Failures"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "max": "@entity.threshold",
                          "type": "meter",
                          "min": 0.0,
                          "value": "@entity.failureCount"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Alerts",
          "path": "/alerts",
          "traits": [
            {
              "ref": "AlertCatalog"
            },
            {
              "ref": "AlertBrowseList"
            },
            {
              "ref": "AlertCreate"
            },
            {
              "ref": "AlertEdit"
            },
            {
              "ref": "AlertView"
            },
            {
              "ref": "AlertDelete"
            },
            {
              "ref": "AlertPersistor"
            },
            {
              "ref": "AlertEmail"
            },
            {
              "ref": "AlertEmailNotice"
            },
            {
              "ref": "DeviceAlertCircuitBreaker"
            }
          ]
        }
      ]
    }
  ]
}
