              "event": "DEVICE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DeviceCreate"
              }
            },
            {
              "event": "DEVICE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DeviceEdit"
              }
            },
            {
              "event": "DEVICE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "DeviceDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
