                          "children": [
                            {
                              "align": "center",
                              "justify": "between",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "gap": "md",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "bell"
                                    },
                                    {
                                      "type": "typography",
                                      "variant": "h2",
                                      "content": "DeviceAlert"
                                    }
                                  ]
                                },
                                {
                                  "pulse": false,
                                  "type": "status-dot",
                                  "status": "online",
                                  "label": "Circuit Closed"
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "variant": "success",
                              "message": "Service is healthy. All requests are being processed.",
                              "type": "alert"
                            },
                            {
                              "cols": 2.0,
                              "children": [
                                {
                                  "value": "@entity.failureCount",
                                  "label": "Failures",
                                  "type": "stat-display"
                                },
                                {
                                  "type": "stat-display",
                                  "label": "Successes",
                                  "value": "@entity.successCount"
                                }
                              ],
                              "type": "simple-grid"
                            },
                            {
                              "value": "@entity.failureCount",
                              "min": 0.0,
                              "type": "meter",
                              "max": "@entity.threshold"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Alerts",
          "path": "/alerts",
          "traits": [
            {
              "ref": "DeviceAlertCircuitBreaker"
            }
          ]
        }
      ]
    }
  ]
}
