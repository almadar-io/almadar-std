            {
              "event": "DeviceLoaded",
              "description": "Fired when Device finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Device]"
                }
              ]
            },
            {
              "event": "DeviceLoadFailed",
              "description": "Fired when Device fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
