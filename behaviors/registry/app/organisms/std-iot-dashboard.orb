                            {
                              "action": "CANCEL",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Cancel"
                            },
                            {
                              "action": "CONFIRM_DELETE",
                              "type": "button",
                              "label": "Delete",
                              "icon": "check",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Device",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "DeviceDeleteFailed",
                        "success": "DeviceDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Device",
                    {
                      "emit": {
                        "failure": "DeviceLoadFailed",
                        "success": "DeviceLoaded"
                      }
                    }
                  ],
                  [
                    "emit",
                    "DEVICE_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Device",
                    {
                      "emit": {
                        "failure": "DeviceLoadFailed",
                        "success": "DeviceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Device",
                    {
                      "emit": {
                        "failure": "DeviceLoadFailed",
                        "success": "DeviceLoaded"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
