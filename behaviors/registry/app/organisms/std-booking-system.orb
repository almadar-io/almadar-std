                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.customerName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.summary",
                    ""
                  ],
                  [
                    "set",
                    "@entity.notes",
                    ""
                  ],
                  [
                    "set",
                    "@entity.providerName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.status",
                    ""
                  ],
                  [
                    "set",
                    "@entity.time",
                    ""
                  ],
                  [
                    "fetch",
                    "Appointment",
                    {
                      "emit": {
                        "success": "AppointmentLoaded",
                        "failure": "AppointmentLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Appointment",
                    {
                      "emit": {
                        "failure": "AppointmentLoadFailed",
                        "success": "AppointmentLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.summary"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Provider"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.providerName"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
