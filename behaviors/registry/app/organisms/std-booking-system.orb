                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "AppointmentLoaded",
                "name": "Appointment loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Appointment]"
                  }
                ]
              },
              {
                "key": "AppointmentLoadFailed",
                "name": "Appointment load failed",
                "payloadSchema": [
