                  ]
                ]
              },
              {
                "from": "refreshing",
                "to": "displaying",
                "event": "ScheduleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "clock",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Schedule Overview"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "variant": "secondary",
                              "label": "Refresh",
                              "action": "REFRESH",
                              "icon": "refresh-cw",
                              "type": "button"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 4.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Total Bookings",
                              "value": "@entity.totalBookings",
                              "icon": "calendar"
                            },
                            {
                              "icon": "check-circle",
                              "label": "Confirmed Today",
                              "type": "stat-display",
                              "value": "@entity.confirmedToday"
                            },
                            {
                              "label": "Pending",
                              "value": "@entity.pendingBookings",
                              "type": "stat-display",
                              "icon": "clock"
                            },
                            {
                              "value": "@entity.availableSlots",
                              "type": "stat-display",
                              "label": "Available Slots",
                              "icon": "calendar-plus"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "calendar-grid"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "refreshing",
                "to": "displaying",
                "event": "ScheduleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to refresh schedule",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "action": "REFRESH",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Schedule",
          "path": "/schedule",
          "traits": [
            {
              "ref": "ScheduleAppLayout"
            },
            {
              "ref": "ScheduleDisplay"
            }
          ]
        }
      ]
    }
  ]
}
