                "key": "APPOINTMENT_CREATED",
                "name": "Appointment Created"
              },
              {
                "key": "AppointmentLoadFailed",
                "name": "Appointment load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
