                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Appointment]"
                  }
                ]
              },
              {
                "key": "AppointmentSaveFailed",
                "name": "Appointment save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AppointmentSaved",
                "name": "Appointment saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Appointment",
                    {
                      "emit": {
                        "failure": "AppointmentLoadFailed",
                        "success": "AppointmentLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Appointment",
                    {
                      "emit": {
                        "success": "AppointmentLoaded",
                        "failure": "AppointmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
