                    "set",
                    "@entity.email",
                    ""
                  ],
                  [
                    "set",
                    "@entity.phone",
                    ""
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.notes",
                    ""
                  ],
                  [
                    "set",
                    "@entity.depositAmount",
                    50.0
                  ],
                  [
                    "set",
                    "@entity.status",
                    "draft"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-xl mx-auto w-full",
                      "children": [
                        {
                          "variant": "h2",
                          "content": "Book Appointment",
                          "type": "typography"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 0.0,
                          "steps": [
                            "Select Provider",
                            "Select Time",
                            "Your Details",
                            "Payment",
                            "Confirmation"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Select Provider",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "form-section",
                          "mode": "create",
                          "submitLabel": "Continue",
                          "submitEvent": "NEXT",
                          "fields": [
                            {
                              "required": true,
                              "name": "providerName",
                              "min": 2.0
                            }
                          ],
                          "showCancel": false
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
