                "effects": [
                  [
                    "fetch",
                    "Provider",
                    {
                      "emit": {
                        "success": "ProviderLoaded",
                        "failure": "ProviderLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Provider",
                    {
                      "id": "@payload.id",
                      "emit": {
