                              "label": "Delete",
                              "variant": "danger",
                              "type": "button",
                              "icon": "check"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "end"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Provider",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "success": "ProviderDeleted",
                        "failure": "ProviderDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
