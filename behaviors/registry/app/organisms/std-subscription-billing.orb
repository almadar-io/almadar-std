{
  "name": "std-subscription-billing",
  "version": "1.0.0",
  "description": "Subscription billing: plans browser with stats + graphs, embedded recurring-charge + trial managers, modal/confirm CRUD over plans, invoices browser, dunning queue.",
  "orbitals": [
    {
      "name": "SubscriptionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-recurring-charge",
          "as": "Recurring"
        },
        {
          "from": "std/behaviors/std-trial",
          "as": "Trial"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        }
      ],
      "entity": {
        "name": "Plan",
        "collection": "plans",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "interval",
            "type": "string",
            "default": "monthly",
            "values": [
              "monthly",
              "yearly"
            ]
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "trialDays",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "archived"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "PlanAppLayout",
          "config": {
            "notificationClickEvent": "PLAN_NOTIFICATIONS_OPEN",
            "navItems": [
              {
                "label": "Plans",
                "icon": "credit-card",
                "href": "/plans"
              },
              {
                "label": "Invoices",
                "href": "/invoices",
                "icon": "receipt"
              },
              {
                "label": "Dunning",
                "href": "/dunning",
                "icon": "alert-triangle"
              }
            ],
            "searchEvent": "PLAN_SEARCH",
            "notifications": [],
            "contentTrait": "@trait.PlanCatalog",
            "appName": "Subscription Billing"
          },
          "events": {
            "SEARCH": "PLAN_SEARCH",
            "NOTIFY_CLICK": "PLAN_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "PlanCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PLAN_SEARCH",
              "triggers": "PLAN_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "PlanAppLayout"
              }
            },
            {
              "event": "PLAN_NOTIFICATIONS_OPEN",
              "triggers": "PLAN_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "PlanAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAN_SEARCH",
                "name": "Plan Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAN_NOTIFICATIONS_OPEN",
                "name": "Plan Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "credit-card",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Plans"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "type": "button",
                                  "variant": "primary",
                                  "icon": "plus",
                                  "label": "New Plan",
                                  "action": "CREATE"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "children": [
                            "@trait.PlanSearch",
                            "@trait.PlanFilter"
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        "@trait.PlanStats",
                        "@trait.PlanGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.PlanBrowseList",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Active Subscriptions",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.PlanSubscriptionManage",
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Trials",
                          "type": "typography"
                        },
                        "@trait.PlanTrialManage"
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "PLAN_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "PLAN_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "content": "You're all caught up.",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "label": "Back to plans",
                          "action": "INIT"
                        }
                      ],
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "PlanSearch",
          "config": {
            "placeholder": "Search plans…",
            "event": "PLAN_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "PlanFilter",
          "config": {
            "event": "PLAN_FILTER",
            "filters": [
              {
                "label": "Interval",
                "filterType": "select",
                "field": "interval",
                "options": [
                  "monthly",
                  "yearly"
                ]
              },
              {
                "field": "status",
                "label": "Status",
                "filterType": "select",
                "options": [
                  "active",
                  "archived"
                ]
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "PlanStats",
          "config": {
            "metrics": [
              {
                "icon": "credit-card",
                "aggregation": "count",
                "label": "Total",
                "variant": "primary",
                "format": "number"
              },
              {
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ],
                "label": "Active",
                "variant": "success",
                "icon": "check-circle",
                "aggregation": "count",
                "format": "number"
              },
              {
                "label": "Archived",
                "aggregation": "count",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "archived"
                  ]
                ],
                "variant": "warning",
                "icon": "archive"
              }
            ],
            "title": "Plans"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "PlanBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "PlanGraphs",
          "config": {
            "subtitle": "Monthly vs yearly distribution",
            "title": "Plans by Interval",
            "categoryField": "interval",
            "aggregation": "count",
            "chartType": "bar",
            "height": 240.0,
            "showLegend": false
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "PlanBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "PlanBrowseList",
          "linkedEntity": "Plan",
          "config": {
            "fields": [
              {
                "icon": "credit-card",
                "name": "name",
                "variant": "h3"
              },
              {
                "variant": "caption",
                "name": "description"
              },
              {
                "name": "interval",
                "variant": "badge"
              },
              {
                "variant": "body",
                "name": "amount"
              },
              {
                "name": "currency",
                "variant": "badge"
              },
              {
                "name": "status",
                "variant": "badge"
              }
            ],
            "cols": 1.0,
            "gap": "sm",
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "label": "Edit",
                "variant": "ghost",
                "event": "EDIT"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ]
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "PlanSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "PlanFilter"
              }
            },
            {
              "event": "PLAN_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PlanPersistor"
              }
            },
            {
              "event": "PLAN_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PlanPersistor"
              }
            },
            {
              "event": "PLAN_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PlanPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PlanCreate",
          "linkedEntity": "Plan",
          "config": {
            "fields": [
              "name",
              "description",
              "interval",
              "amount",
              "currency",
              "trialDays",
              "status"
            ],
            "title": "New Plan",
            "mode": "create",
            "icon": "plus-circle"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "PlanCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PlanEdit",
          "linkedEntity": "Plan",
          "config": {
            "icon": "edit",
            "title": "Edit Plan",
            "fields": [
              "name",
              "description",
              "interval",
              "amount",
              "currency",
              "trialDays",
              "status"
            ],
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "PlanBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PlanView",
          "linkedEntity": "Plan",
          "config": {
            "icon": "eye",
            "mode": "edit",
            "fields": [
              "name",
              "description",
              "interval",
              "amount",
              "currency",
              "trialDays",
              "status"
            ],
            "title": "View Plan"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "PlanBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "PlanDelete",
          "linkedEntity": "Plan",
          "config": {
            "title": "Delete Plan",
            "icon": "alert-triangle",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "PlanBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Recurring.traits.SubscriptionManage",
          "name": "PlanSubscriptionManage",
          "config": {
            "title": "Active Subscriptions",
            "maxRetries": 4.0
          }
        },
        {
          "ref": "Trial.traits.TrialManage",
          "name": "PlanTrialManage",
          "config": {
            "title": "Trials"
          }
        },
        {
          "name": "PlanPersistor",
          "category": "lifecycle",
          "linkedEntity": "Plan",
          "emits": [
            {
              "event": "PLAN_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PLAN_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PLAN_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "PlanCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "PlanEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "PlanDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PLAN_CREATED",
                "name": "Plan Created"
              },
              {
                "key": "PLAN_UPDATED",
                "name": "Plan Updated"
              },
              {
                "key": "PLAN_DELETED",
                "name": "Plan Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Plan",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PLAN_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Plan",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PLAN_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Plan",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "PLAN_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PlansPage",
          "path": "/plans",
          "traits": [
            {
              "ref": "PlanAppLayout"
            },
            {
              "ref": "PlanCatalog"
            },
            {
              "ref": "PlanSearch"
            },
            {
              "ref": "PlanFilter"
            },
            {
              "ref": "PlanStats"
            },
            {
              "ref": "PlanGraphs"
            },
            {
              "ref": "PlanBrowseList"
            },
            {
              "ref": "PlanCreate"
            },
            {
              "ref": "PlanEdit"
            },
            {
              "ref": "PlanView"
            },
            {
              "ref": "PlanDelete"
            },
            {
              "ref": "PlanSubscriptionManage"
            },
            {
              "ref": "PlanTrialManage"
            },
            {
              "ref": "PlanPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "InvoiceOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-invoice",
          "as": "Inv"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "InvoiceNote",
        "collection": "invoicenotes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "invoiceId",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "InvoiceAppLayout",
          "config": {
            "contentTrait": "@trait.InvoiceCatalog",
            "searchEvent": "INVOICE_SEARCH",
            "appName": "Subscription Billing",
            "notifications": [],
            "navItems": [
              {
                "label": "Plans",
                "href": "/plans",
                "icon": "credit-card"
              },
              {
                "href": "/invoices",
                "icon": "receipt",
                "label": "Invoices"
              },
              {
                "label": "Dunning",
                "icon": "alert-triangle",
                "href": "/dunning"
              }
            ],
            "notificationClickEvent": "INVOICE_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "INVOICE_SEARCH",
            "NOTIFY_CLICK": "INVOICE_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "InvoiceCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "INVOICE_SEARCH",
              "triggers": "INVOICE_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "InvoiceAppLayout"
              }
            },
            {
              "event": "INVOICE_NOTIFICATIONS_OPEN",
              "triggers": "INVOICE_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "InvoiceAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "INVOICE_SEARCH",
                "name": "Invoice Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
