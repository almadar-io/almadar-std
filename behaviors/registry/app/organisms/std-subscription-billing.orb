              }
            },
            {
              "event": "DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "InvoiceNoteBrowseList"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
