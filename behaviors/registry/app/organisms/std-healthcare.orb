{
  "name": "std-healthcare",
  "version": "2.0.0",
  "description": "Healthcare clinic: patients, appointments, intake forms, prescriptions, dashboard. Composed from std atoms (Browse/Modal/Confirmation/Search/Filter/Stats/Graphs/Calendar) with email + SMS + storage services.",
  "orbitals": [
    {
      "name": "PatientOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-service-storage",
          "as": "Storage"
        }
      ],
      "entity": {
        "name": "Patient",
        "collection": "patients",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "firstName",
            "type": "string",
            "required": true
          },
          {
            "name": "lastName",
            "type": "string",
            "required": true
          },
          {
            "name": "dateOfBirth",
            "type": "datetime",
            "required": true
          },
          {
            "name": "phone",
            "type": "string"
          },
          {
            "name": "insuranceId",
            "type": "string"
          },
          {
            "name": "email",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "discharged"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "PatientAppLayout",
          "config": {
            "contentTrait": "@trait.PatientCatalog",
            "appName": "HealthcareApp",
            "navItems": [
              {
                "href": "/patients",
                "label": "Patients",
                "icon": "user-plus"
              },
              {
                "icon": "calendar",
                "label": "Appointments",
                "href": "/appointments"
              },
              {
                "href": "/intake",
                "label": "Intake",
                "icon": "layout-list"
              },
              {
                "label": "Prescriptions",
                "icon": "pill",
                "href": "/prescriptions"
              },
              {
                "href": "/dashboard",
                "icon": "layout-dashboard",
                "label": "Dashboard"
              }
            ],
            "searchEvent": "PATIENT_SEARCH",
            "notifications": [],
            "notificationClickEvent": "PATIENT_NOTIFICATIONS_OPEN"
          },
          "events": {
            "NOTIFY_CLICK": "PATIENT_NOTIFICATIONS_OPEN",
            "SEARCH": "PATIENT_SEARCH"
          }
        },
        {
          "name": "PatientCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PATIENT_SEARCH",
              "triggers": "PATIENT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "PatientAppLayout"
              }
            },
            {
              "event": "PATIENT_NOTIFICATIONS_OPEN",
              "triggers": "PATIENT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "PatientAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PATIENT_SEARCH",
                "name": "Patient Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PATIENT_NOTIFICATIONS_OPEN",
                "name": "Patient Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "user-plus"
                                },
                                {
                                  "type": "typography",
                                  "content": "Patients",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "variant": "primary",
                                  "action": "CREATE",
                                  "label": "New Patient",
                                  "type": "button",
                                  "icon": "plus"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "gap": "md",
                          "justify": "between",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.PatientSearch",
                            "@trait.PatientFilter"
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        "@trait.PatientStats",
                        "@trait.PatientGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.PatientBrowseList"
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "PATIENT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "PATIENT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-8",
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "type": "typography",
                          "content": "No notifications",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "You're all caught up.",
                          "type": "typography"
                        },
                        {
                          "action": "INIT",
                          "label": "Back to patients",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "PatientSearch",
          "config": {
            "placeholder": "Search patients by name…",
            "event": "SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "PatientFilter",
          "config": {
            "event": "FILTER",
            "filters": [
              {
                "label": "Status",
                "filterType": "select",
                "field": "status",
                "options": [
                  "active",
                  "inactive",
                  "discharged"
                ]
              },
              {
                "field": "insuranceId",
                "options": [
                  "aetna",
                  "bcbs",
                  "cigna",
                  "uhc"
                ],
                "label": "Insurance",
                "filterType": "select"
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "PatientStats",
          "config": {
            "title": "Patient Overview",
            "metrics": [
              {
                "icon": "users",
                "variant": "primary",
                "aggregation": "count",
                "label": "Total Patients",
                "format": "number"
              },
              {
                "aggregation": "count",
                "format": "number",
                "icon": "check-circle",
                "label": "Active",
                "variant": "success",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ]
              },
              {
                "variant": "info",
                "format": "number",
                "aggregation": "count",
                "label": "New This Month",
                "icon": "user-plus"
              },
              {
                "label": "By Insurance",
                "variant": "default",
                "format": "number",
                "aggregation": "count",
                "icon": "shield"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "PatientBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "PatientGraphs",
          "config": {
            "title": "Patients by Insurance",
            "aggregation": "count",
            "height": 280.0,
            "showLegend": true,
            "subtitle": "Distribution across providers",
            "chartType": "pie",
            "categoryField": "insuranceId"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "PatientBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "PatientBrowseList",
          "linkedEntity": "Patient",
          "config": {
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "label": "Edit",
                "event": "EDIT",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "variant": "danger",
                "label": "Delete"
              }
            ],
            "fields": [
              {
                "variant": "h3",
                "label": "Name",
                "name": "firstName",
                "icon": "user"
              },
              {
                "name": "lastName",
                "variant": "body"
              },
              {
                "name": "dateOfBirth",
                "variant": "caption",
                "format": "date",
                "label": "DOB"
              },
              {
                "name": "insuranceId",
                "label": "Insurance",
                "variant": "badge"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "variant": "caption",
                "name": "email"
              }
            ],
            "gap": "sm"
          },
          "listens": [
            {
              "event": "PATIENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PatientCreate"
              }
            },
            {
              "event": "PATIENT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PatientEdit"
              }
            },
            {
              "event": "PATIENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PatientDelete"
              }
            },
            {
              "event": "INTAKE_SUBMITTED",
              "triggers": "INIT",
              "source": {
                "kind": "orbital",
                "orbital": "IntakeFormOrbital",
                "trait": "IntakeFormWizard"
              }
            },
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "PatientSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "PatientFilter"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PatientCreate",
          "linkedEntity": "Patient",
          "config": {
            "icon": "plus-circle",
            "fields": [
              "firstName",
              "lastName",
              "dateOfBirth",
              "phone",
              "email",
              "insuranceId",
              "status"
            ],
            "mode": "create",
            "title": "Create Patient"
          },
          "events": {
            "SAVE": "PATIENT_CREATED",
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "PatientCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PatientEdit",
          "linkedEntity": "Patient",
          "config": {
            "mode": "edit",
            "icon": "edit",
            "fields": [
              "firstName",
              "lastName",
              "dateOfBirth",
              "phone",
              "email",
              "insuranceId",
              "status"
            ],
            "title": "Edit Patient"
          },
          "events": {
            "SAVE": "PATIENT_UPDATED",
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "PatientBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "PatientView",
          "linkedEntity": "Patient",
          "config": {
            "icon": "eye",
            "mode": "edit",
            "fields": [
              "firstName",
              "lastName",
              "dateOfBirth",
              "phone",
              "email",
              "insuranceId",
              "status"
            ],
            "title": "Patient Details"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "PatientBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "PatientDelete",
          "linkedEntity": "Patient",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "title": "Delete Patient",
            "confirmLabel": "Delete",
            "icon": "alert-triangle"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "PATIENT_DELETED"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "PatientBrowseList"
              }
            }
          ]
        },
        {
          "name": "PatientPersistor",
          "category": "lifecycle",
          "linkedEntity": "Patient",
          "emits": [
            {
              "event": "PATIENT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PATIENT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PATIENT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PATIENT_CREATED",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "PatientCreate"
              }
            },
            {
              "event": "PATIENT_UPDATED",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "PatientEdit"
              }
            },
            {
              "event": "PATIENT_DELETED",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "PatientDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Patient",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Patient",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PATIENT_CREATED",
                "name": "Patient Created"
              },
              {
                "key": "PATIENT_UPDATED",
                "name": "Patient Updated"
              },
              {
                "key": "PATIENT_DELETED",
                "name": "Patient Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Patient",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PATIENT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Patient",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PATIENT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Patient",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "PATIENT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "PatientDocumentUpload",
          "category": "interaction",
          "emits": [
            {
              "event": "DocumentUploaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentUploadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              },
              {
                "name": "uploading"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "file",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DocumentUploaded",
                "name": "Document uploaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DocumentUploadFailed",
                "name": "Document upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "paperclip",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Upload Medical Record"
                            }
                          ],
                          "align": "center",
                          "gap": "sm"
                        },
                        {
                          "inputType": "text",
                          "type": "input",
                          "placeholder": "Choose file path…"
                        },
                        {
                          "label": "Upload",
                          "action": "UPLOAD",
                          "icon": "upload",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "file": "@payload.file",
                      "maxSize": 10485760.0,
                      "acl": "private",
                      "bucket": "patient-records"
                    },
                    {
                      "emit": {
                        "success": "DocumentUploaded",
                        "failure": "DocumentUploadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Uploading…",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "ready",
                "event": "DocumentUploaded",
                "effects": [
                  [
                    "notify",
                    "success",
                    "Document uploaded"
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "ready",
                "event": "DocumentUploadFailed",
                "effects": [
                  [
                    "notify",
                    "error",
                    "Upload failed"
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PatientsPage",
          "path": "/patients",
          "traits": [
            {
              "ref": "PatientAppLayout"
            },
            {
              "ref": "PatientCatalog"
            },
            {
              "ref": "PatientSearch"
            },
            {
              "ref": "PatientFilter"
            },
            {
              "ref": "PatientStats"
            },
            {
              "ref": "PatientGraphs"
            },
            {
              "ref": "PatientBrowseList"
            },
            {
              "ref": "PatientCreate"
            },
            {
              "ref": "PatientEdit"
            },
