        {
          "name": "PrescriptionView",
          "category": "interaction",
          "linkedEntity": "Prescription",
          "emits": [
            {
              "event": "CLOSE"
            },
            {
              "event": "PrescriptionLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
