                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "Drug"
                                },
                                {
                                  "content": "@entity.medication",
                                  "type": "typography",
                                  "variant": "h4"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Dose",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.dosage",
                                  "variant": "h4"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "content": "Frequency",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.frequency",
                                  "variant": "h4"
                                }
                              ],
                              "gap": "xs",
                              "type": "stack",
                              "direction": "vertical"
                            }
                          ],
                          "cols": 3.0,
                          "type": "simple-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Patient",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.patientName",
                              "variant": "body"
