{
  "name": "std-forum",
  "version": "1.0.0",
  "description": "Forum: community Q&A with threaded replies, voting, flagging, tags, and a moderator queue. Pick for Stack Overflow / Reddit / Discourse style sites.",
  "orbitals": [
    {
      "name": "QuestionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        },
        {
          "from": "std/behaviors/std-vote",
          "as": "Vote"
        },
        {
          "from": "std/behaviors/std-tag-taxonomy",
          "as": "Tags"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        }
      ],
      "entity": {
        "name": "Question",
        "collection": "questions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "authorId",
            "type": "string",
            "default": ""
          },
          {
            "name": "authorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "tag",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "answered",
              "closed"
            ]
          },
          {
            "name": "voteCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "replyCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "QuestionAppLayout",
          "config": {
            "searchEvent": "QUESTION_SEARCH",
            "notificationClickEvent": "QUESTION_NOTIFICATIONS_OPEN",
            "appName": "Forum",
            "navItems": [
              {
                "icon": "help-circle",
                "label": "Questions",
                "href": "/questions"
              },
              {
                "label": "Categories",
                "href": "/questions",
                "icon": "tag"
              },
              {
                "href": "/moderation",
                "icon": "shield-alert",
                "label": "Moderation"
              }
            ],
            "contentTrait": "@trait.QuestionCatalog",
            "notifications": []
          },
          "events": {
            "SEARCH": "QUESTION_SEARCH",
            "NOTIFY_CLICK": "QUESTION_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "QuestionCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "QUESTION_SEARCH",
              "triggers": "QUESTION_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "QuestionAppLayout"
              }
            },
            {
              "event": "QUESTION_NOTIFICATIONS_OPEN",
              "triggers": "QUESTION_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "QuestionAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "QUESTION_SEARCH",
                "name": "Question Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "QUESTION_NOTIFICATIONS_OPEN",
                "name": "Question Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "name": "help-circle",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Questions"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "icon": "plus",
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "type": "button",
                                  "label": "Ask Question"
                                }
                              ]
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            "@trait.QuestionSearch",
                            "@trait.QuestionFilter"
                          ],
                          "align": "center"
                        },
                        "@trait.QuestionStats",
                        {
                          "type": "divider"
                        },
                        "@trait.QuestionTagTree",
                        {
                          "type": "divider"
                        },
                        "@trait.QuestionBrowseList"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "QUESTION_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "QUESTION_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-8",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "You're all caught up.",
                          "type": "typography"
                        },
                        {
                          "label": "Back to questions",
                          "variant": "ghost",
                          "action": "INIT",
                          "type": "button"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "QuestionSearch",
          "config": {
            "placeholder": "Search questions…",
            "event": "QUESTION_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "QuestionFilter",
          "config": {
            "filters": [
              {
                "options": [
                  "open",
                  "answered",
                  "closed"
                ],
                "field": "status",
                "filterType": "select",
                "label": "Status"
              },
              {
                "filterType": "select",
                "label": "Tag",
                "field": "tag",
                "options": []
              }
            ],
            "event": "QUESTION_FILTER"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "QuestionStats",
          "config": {
            "title": "Questions",
            "metrics": [
              {
                "aggregation": "count",
                "variant": "primary",
                "label": "Total",
                "format": "number",
                "icon": "help-circle"
              },
              {
                "variant": "warning",
                "label": "Open",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "open"
                  ]
                ],
                "format": "number",
                "aggregation": "count",
                "icon": "circle"
              },
              {
                "label": "Answered",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "answered"
                  ]
                ],
                "variant": "success",
                "aggregation": "count",
                "icon": "check-circle"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "QuestionBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Tags.traits.TagBrowse",
          "name": "QuestionTagTree",
          "config": {
            "title": "Categories",
            "allowEdit": false
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "QuestionBrowseList",
          "linkedEntity": "Question",
          "config": {
            "gap": "sm",
            "fields": [
              {
                "name": "title",
                "icon": "help-circle",
                "variant": "h3"
              },
              {
                "name": "authorName",
                "variant": "body"
              },
              {
                "variant": "badge",
                "name": "tag"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "name": "voteCount",
                "variant": "caption",
                "format": "number"
              },
              {
                "variant": "caption",
                "format": "number",
                "name": "replyCount"
              }
            ],
            "cols": 1.0,
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "label": "Edit",
                "variant": "ghost",
                "event": "EDIT"
              },
              {
                "event": "DELETE",
                "variant": "danger",
                "label": "Delete"
              }
            ],
            "variant": "card"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "QuestionSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "QuestionFilter"
              }
            },
            {
              "event": "QUESTION_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "QuestionPersistor"
              }
            },
            {
              "event": "QUESTION_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "QuestionPersistor"
              }
            },
            {
              "event": "QUESTION_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "QuestionPersistor"
              }
            }
          ]
        },
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "QuestionThread",
          "config": {
            "flat": false,
            "threadRootId": ""
          }
        },
        {
          "ref": "Vote.traits.VoteCast",
          "name": "QuestionVote",
          "config": {
            "allowDown": true
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "QuestionCreate",
          "linkedEntity": "Question",
          "config": {
            "fields": [
              "title",
              "body",
              "authorName",
              "tag",
              "status"
            ],
            "title": "Ask Question",
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "QuestionCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "QuestionEdit",
          "linkedEntity": "Question",
          "config": {
            "title": "Edit Question",
            "icon": "edit",
            "mode": "edit",
            "fields": [
              "title",
              "body",
              "authorName",
              "tag",
              "status"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "QuestionBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "QuestionView",
          "linkedEntity": "Question",
          "config": {
            "icon": "eye",
            "title": "View Question",
            "mode": "edit",
            "fields": [
              "title",
              "body",
              "authorName",
              "tag",
              "status",
              "voteCount",
              "replyCount"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "QuestionBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "QuestionDeleteConfirm",
          "linkedEntity": "Question",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Question",
            "alertMessage": "This action cannot be undone. The question and all its replies will be removed.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "QuestionBrowseList"
              }
            }
          ]
        },
        {
          "name": "QuestionPersistor",
          "category": "lifecycle",
          "linkedEntity": "Question",
          "emits": [
            {
              "event": "QUESTION_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QUESTION_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QUESTION_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "QuestionCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "QuestionEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "QuestionDeleteConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "QUESTION_CREATED",
                "name": "Question Created"
              },
              {
                "key": "QUESTION_UPDATED",
                "name": "Question Updated"
              },
              {
                "key": "QUESTION_DELETED",
                "name": "Question Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Question",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "QUESTION_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Question",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "QUESTION_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Question",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "QUESTION_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "QuestionsPage",
          "path": "/questions",
          "traits": [
            {
              "ref": "QuestionAppLayout"
            },
            {
              "ref": "QuestionCatalog"
            },
            {
              "ref": "QuestionSearch"
            },
            {
              "ref": "QuestionFilter"
            },
            {
              "ref": "QuestionStats"
            },
            {
              "ref": "QuestionTagTree"
            },
            {
              "ref": "QuestionBrowseList"
            },
            {
              "ref": "QuestionThread"
            },
            {
              "ref": "QuestionVote"
            },
            {
              "ref": "QuestionCreate"
            },
            {
              "ref": "QuestionEdit"
            },
            {
              "ref": "QuestionView"
            },
            {
              "ref": "QuestionDeleteConfirm"
            },
            {
              "ref": "QuestionPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ModQueueOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-mod-queue",
          "as": "ModQueue"
        },
        {
          "from": "std/behaviors/std-flag",
          "as": "Flag"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "ModerationDecision",
        "collection": "moderationdecisions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "verdict",
            "type": "string",
            "default": "approved",
            "values": [
              "approved",
              "rejected",
              "escalated"
            ]
          },
          {
            "name": "reviewerId",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ModerationAppLayout",
          "config": {
            "appName": "Forum",
            "notificationClickEvent": "MODERATION_NOTIFICATIONS_OPEN",
            "searchEvent": "MODERATION_SEARCH",
            "contentTrait": "@trait.ModerationDisplay",
            "navItems": [
              {
                "label": "Questions",
                "href": "/questions",
                "icon": "help-circle"
              },
              {
                "label": "Categories",
                "href": "/questions",
                "icon": "tag"
              },
              {
                "label": "Moderation",
                "href": "/moderation",
                "icon": "shield-alert"
              }
            ],
            "notifications": []
          },
          "events": {
            "SEARCH": "MODERATION_SEARCH",
            "NOTIFY_CLICK": "MODERATION_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "ModerationDisplay",
          "category": "interaction",
          "listens": [
            {
              "event": "MODERATION_SEARCH",
              "triggers": "MODERATION_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ModerationAppLayout"
              }
            },
            {
              "event": "MODERATION_NOTIFICATIONS_OPEN",
              "triggers": "MODERATION_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ModerationAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MODERATION_SEARCH",
                "name": "Moderation Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MODERATION_NOTIFICATIONS_OPEN",
                "name": "Moderation Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "shield-alert"
                            },
                            {
                              "content": "Moderation Queue",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ModerationQueue",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Recent Flags",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.ModerationFlagBrowse",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Recorded Decisions",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.ModerationDecisionBrowse"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "MODERATION_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "MODERATION_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-8",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "You're all caught up."
                        },
                        {
                          "action": "INIT",
                          "type": "button",
                          "label": "Back to moderation",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "ModQueue.traits.ModQueueItemReview",
          "name": "ModerationQueue",
          "config": {
            "autoEscalateThreshold": 5.0,
            "title": "Pending Reports"
          }
        },
        {
          "ref": "Flag.traits.FlagReport",
          "name": "ModerationFlagBrowse",
          "config": {
            "reasons": [
              "spam",
              "abuse",
              "off-topic",
              "misinformation",
              "nsfw",
              "other"
            ],
            "title": "Latest reports"
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ModerationDecisionBrowse",
          "linkedEntity": "ModerationDecision",
          "config": {
            "gap": "sm",
            "fields": [
              {
                "name": "targetType",
                "variant": "badge",
                "label": "Target"
              },
              {
                "label": "Verdict",
                "name": "verdict",
                "variant": "badge"
              },
              {
                "name": "reviewerId",
                "label": "Reviewer",
                "variant": "caption"
              },
              {
                "name": "notes",
                "label": "Notes",
                "variant": "body"
              },
              {
                "format": "date",
                "variant": "caption",
                "label": "When",
                "name": "createdAt"
              }
            ],
            "itemActions": [
              {
                "label": "Revert",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "cols": 1.0
          },
          "listens": [
            {
              "event": "DECISION_RECORDED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ModerationPersistor"
              }
            },
            {
              "event": "DECISION_REVERTED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ModerationPersistor"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ModerationRevertConfirm",
          "linkedEntity": "ModerationDecision",
          "config": {
            "icon": "rotate-ccw",
            "alertMessage": "This will undo the recorded moderation verdict.",
            "title": "Revert Decision",
            "confirmLabel": "Revert"
          },
          "events": {
            "REQUEST": "REVERT",
            "CONFIRM": "CONFIRM_REVERT"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "REVERT",
              "source": {
                "kind": "trait",
                "trait": "ModerationDecisionBrowse"
              }
            }
          ]
        },
        {
          "name": "ModerationPersistor",
          "category": "lifecycle",
          "linkedEntity": "ModerationDecision",
          "emits": [
            {
              "event": "DECISION_RECORDED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DECISION_REVERTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ModQueueItemReviewed",
              "triggers": "DO_RECORD",
              "source": {
                "kind": "trait",
                "trait": "ModerationQueue"
              }
            },
            {
              "event": "CONFIRM_REVERT",
              "triggers": "DO_REVERT",
              "source": {
                "kind": "trait",
                "trait": "ModerationRevertConfirm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_RECORD",
                "name": "Do Record",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_REVERT",
                "name": "Do Revert",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DECISION_RECORDED",
                "name": "Decision Recorded"
              },
              {
                "key": "DECISION_REVERTED",
                "name": "Decision Reverted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_RECORD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ModerationDecision",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "DECISION_RECORDED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_REVERT",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "ModerationDecision",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "DECISION_REVERTED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ModerationPage",
          "path": "/moderation",
          "traits": [
            {
              "ref": "ModerationAppLayout"
            },
            {
              "ref": "ModerationDisplay"
            },
            {
              "ref": "ModerationQueue"
            },
            {
              "ref": "ModerationFlagBrowse"
            },
            {
              "ref": "ModerationDecisionBrowse"
            },
            {
              "ref": "ModerationRevertConfirm"
            },
            {
              "ref": "ModerationPersistor"
            }
          ]
        }
      ]
    }
  ]
}