{
  "name": "std-project-manager",
  "version": "2.0.0",
  "description": "Project manager: tasks with stats/graphs/calendar, sprints with planning, and burndown metrics. Pick for agile/scrum-style PM tools.",
  "orbitals": [
    {
      "name": "TaskOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-calendar",
          "as": "Calendar"
        },
        {
          "from": "std/behaviors/std-selection",
          "as": "Selection"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Task",
        "collection": "tasks",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignee",
            "type": "string",
            "default": ""
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "todo",
            "values": [
              "todo",
              "in-progress",
              "review",
              "done"
            ]
          },
          {
            "name": "sprint",
            "type": "string",
            "default": ""
          },
          {
            "name": "storyPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "dueDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "TaskAppLayout",
          "config": {
            "notifications": [],
            "navItems": [
              {
                "href": "/tasks",
                "icon": "list-todo",
                "label": "Tasks"
              },
              {
                "icon": "zap",
                "label": "Sprints",
                "href": "/sprints"
              },
              {
                "label": "Burndown",
                "icon": "trending-down",
                "href": "/burndown"
              }
            ],
            "appName": "ProjectManagerApp",
            "notificationClickEvent": "TASK_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.TaskCatalog",
            "searchEvent": "TASK_SEARCH"
          },
          "events": {
            "NOTIFY_CLICK": "TASK_NOTIFICATIONS_OPEN",
            "SEARCH": "TASK_SEARCH"
          }
        },
        {
          "name": "TaskCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TASK_SEARCH",
              "triggers": "TASK_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "TaskAppLayout"
              }
            },
            {
              "event": "TASK_NOTIFICATIONS_OPEN",
              "triggers": "TASK_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "TaskAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TASK_SEARCH",
                "name": "Task Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TASK_NOTIFICATIONS_OPEN",
                "name": "Task Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "name": "list-todo",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Tasks"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "icon": "plus",
                                  "type": "button",
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "label": "New Task"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal"
                            }
                          ],
                          "gap": "md",
                          "justify": "between",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.TaskSearch",
                            "@trait.TaskFilter"
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center"
                        },
                        "@trait.TaskStats",
                        "@trait.TaskGraphs",
                        "@trait.TaskCalendar",
                        {
                          "type": "divider"
                        },
                        "@trait.TaskBrowseList"
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "TASK_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "TASK_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "content": "No notifications",
                          "variant": "h3"
                        },
                        {
                          "content": "You're all caught up.",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "label": "Back to tasks",
                          "variant": "ghost",
                          "action": "INIT"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "TaskSearch",
          "config": {
            "placeholder": "Search tasks…",
            "event": "TASK_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "TaskFilter",
          "config": {
            "filters": [
              {
                "options": [
                  "todo",
                  "in-progress",
                  "review",
                  "done"
                ],
                "label": "Status",
                "field": "status",
                "filterType": "select"
              },
              {
                "field": "assignee",
                "label": "Assignee",
                "filterType": "text"
              },
              {
                "label": "Priority",
                "filterType": "select",
                "field": "priority",
                "options": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              {
                "field": "sprint",
                "label": "Sprint",
                "filterType": "text"
              }
            ],
            "event": "TASK_FILTER"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "TaskStats",
          "config": {
            "metrics": [
              {
                "icon": "list-todo",
                "variant": "primary",
                "aggregation": "count",
                "format": "number",
                "label": "Total"
              },
              {
                "label": "Todo",
                "variant": "default",
                "icon": "circle",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "todo"
                  ]
                ],
                "aggregation": "count",
                "format": "number"
              },
              {
                "format": "number",
                "aggregation": "count",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "in-progress"
                  ]
                ],
                "icon": "loader",
                "label": "In Progress",
                "variant": "warning"
              },
              {
                "variant": "success",
                "label": "Done",
                "aggregation": "count",
                "icon": "check-circle",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "done"
                  ]
                ],
                "format": "number"
              },
              {
                "label": "Critical",
                "icon": "alert-octagon",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.priority",
                    "critical"
                  ]
                ],
                "aggregation": "count",
                "variant": "error"
              }
            ],
            "title": "Tasks"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "TaskBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "TaskGraphs",
          "config": {
            "title": "Tasks by Status",
            "chartType": "bar",
            "aggregation": "count",
            "categoryField": "status",
            "height": 240.0,
            "subtitle": "Workload distribution across status buckets",
            "showLegend": false
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "TaskBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Calendar.traits.CalendarEventCalendar",
          "name": "TaskCalendar",
          "linkedEntity": "Task",
          "config": {
            "dateField": "dueDate",
            "titleField": "title",
            "colorField": "priority"
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "TaskBrowseList",
          "linkedEntity": "Task",
          "config": {
            "fields": [
              {
                "icon": "list-todo",
                "variant": "h3",
                "name": "title"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "name": "assignee",
                "variant": "body"
              },
              {
                "variant": "badge",
                "name": "priority"
              },
              {
                "variant": "caption",
                "format": "date",
                "name": "dueDate",
                "label": "Due"
              }
            ],
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "label": "Edit",
                "event": "EDIT",
                "variant": "ghost"
              },
              {
                "variant": "danger",
                "label": "Delete",
                "event": "DELETE"
              }
            ],
            "gap": "sm",
            "cols": 1.0
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "TaskSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "TaskFilter"
              }
            },
            {
              "event": "TASK_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TaskPersistor"
              }
            },
            {
              "event": "TASK_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TaskPersistor"
              }
            },
            {
              "event": "TASK_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TaskPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "TaskCreate",
          "linkedEntity": "Task",
          "config": {
            "fields": [
              "title",
              "description",
              "assignee",
              "priority",
              "status",
              "sprint",
              "storyPoints",
              "dueDate"
            ],
            "icon": "plus-circle",
            "title": "New Task",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "TaskCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "TaskEdit",
          "linkedEntity": "Task",
          "config": {
            "icon": "edit",
            "title": "Edit Task",
            "mode": "edit",
            "fields": [
              "title",
              "description",
              "assignee",
              "priority",
              "status",
              "sprint",
              "storyPoints",
              "dueDate"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "TaskBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "TaskView",
          "linkedEntity": "Task",
          "config": {
            "title": "View Task",
            "mode": "edit",
            "icon": "eye",
            "fields": [
              "title",
              "description",
              "assignee",
              "priority",
              "status",
              "sprint",
              "storyPoints",
              "dueDate"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "TaskBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "TaskDelete",
          "linkedEntity": "Task",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "title": "Delete Task",
            "confirmLabel": "Delete",
            "icon": "alert-triangle"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "TaskBrowseList"
              }
            }
          ]
        },
        {
          "name": "TaskPersistor",
          "category": "lifecycle",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "TASK_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TASK_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TASK_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "TaskCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "TaskEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "TaskDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TASK_CREATED",
                "name": "Task Created"
              },
              {
                "key": "TASK_UPDATED",
                "name": "Task Updated"
              },
              {
                "key": "TASK_DELETED",
                "name": "Task Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Task",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TASK_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Task",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TASK_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Task",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "TASK_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TasksPage",
          "path": "/tasks",
          "traits": [
            {
              "ref": "TaskAppLayout"
            },
            {
              "ref": "TaskCatalog"
            },
            {
              "ref": "TaskSearch"
            },
            {
              "ref": "TaskFilter"
            },
            {
              "ref": "TaskStats"
            },
            {
              "ref": "TaskGraphs"
            },
            {
              "ref": "TaskCalendar"
            },
            {
              "ref": "TaskBrowseList"
            },
            {
              "ref": "TaskCreate"
            },
            {
              "ref": "TaskEdit"
            },
            {
              "ref": "TaskView"
            },
            {
              "ref": "TaskDelete"
            },
            {
              "ref": "TaskPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "SprintOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Sprint",
        "collection": "sprints",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "endDate",
            "type": "string",
            "required": true
          },
          {
            "name": "goal",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "planning",
            "values": [
              "planning",
              "active",
              "completed"
            ]
          },
          {
            "name": "taskCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "SprintAppLayout",
          "linkedEntity": "Sprint",
          "config": {
            "notificationClickEvent": "SPRINT_NOTIFICATIONS_OPEN",
            "navItems": [
              {
                "href": "/tasks",
                "label": "Tasks",
                "icon": "list-todo"
              },
              {
                "href": "/sprints",
                "label": "Sprints",
                "icon": "zap"
              },
              {
                "icon": "trending-down",
                "label": "Burndown",
                "href": "/burndown"
              }
            ],
            "searchEvent": "SPRINT_SEARCH",
            "appName": "ProjectManagerApp",
            "contentTrait": "@trait.SprintCatalog",
            "notifications": []
          },
          "events": {
            "SEARCH": "SPRINT_SEARCH",
            "NOTIFY_CLICK": "SPRINT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "SprintCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "zap"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Sprints"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "New Sprint",
                                  "variant": "primary",
                                  "type": "button",
                                  "icon": "plus",
                                  "action": "CREATE"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.SprintBrowseList"
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "SprintBrowseList",
          "linkedEntity": "Sprint",
          "config": {
            "gap": "sm",
            "cols": 1.0,
            "fields": [
              {
                "name": "name",
                "variant": "h3",
                "icon": "zap"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "name": "goal",
                "variant": "body"
              },
              {
                "variant": "caption",
                "label": "Start",
                "name": "startDate",
                "format": "date"
              },
              {
                "name": "endDate",
                "format": "date",
                "label": "End",
                "variant": "caption"
              },
              {
                "name": "taskCount",
                "variant": "body",
                "format": "number",
                "label": "Tasks"
              }
            ],
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ]
          },
          "listens": [
            {
              "event": "SPRINT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SprintPersistor"
              }
            },
            {
              "event": "SPRINT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SprintPersistor"
              }
            },
            {
              "event": "SPRINT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SprintPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SprintCreate",
          "linkedEntity": "Sprint",
          "config": {
            "icon": "plus-circle",
            "mode": "create",
            "title": "New Sprint",
            "fields": [
              "name",
              "startDate",
              "endDate",
              "goal",
              "status",
              "taskCount"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "SprintCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SprintEdit",
          "linkedEntity": "Sprint",
          "config": {
            "icon": "edit",
            "title": "Edit Sprint",
            "mode": "edit",
            "fields": [
              "name",
              "startDate",
              "endDate",
              "goal",
              "status",
              "taskCount"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "SprintBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SprintView",
          "linkedEntity": "Sprint",
          "config": {
            "fields": [
              "name",
              "startDate",
              "endDate",
              "goal",
              "status",
              "taskCount"
            ],
            "icon": "eye",
            "mode": "edit",
            "title": "View Sprint"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "SprintBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "SprintDelete",
          "linkedEntity": "Sprint",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete",
            "icon": "alert-triangle",
            "title": "Delete Sprint"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "SprintBrowseList"
              }
            }
          ]
        },
        {
          "name": "SprintPersistor",
          "category": "lifecycle",
          "linkedEntity": "Sprint",
          "emits": [
            {
              "event": "SPRINT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SPRINT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SPRINT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "SprintCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "SprintEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "SprintDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SPRINT_CREATED",
                "name": "Sprint Created"
              },
              {
                "key": "SPRINT_UPDATED",
                "name": "Sprint Updated"
              },
              {
                "key": "SPRINT_DELETED",
                "name": "Sprint Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Sprint",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SPRINT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Sprint",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SPRINT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Sprint",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "SPRINT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Sprints",
          "path": "/sprints",
          "traits": [
            {
              "ref": "SprintAppLayout"
            },
            {
              "ref": "SprintCatalog"
            },
            {
              "ref": "SprintBrowseList"
            },
            {
              "ref": "SprintCreate"
            },
            {
              "ref": "SprintEdit"
            },
            {
              "ref": "SprintView"
            },
            {
              "ref": "SprintDelete"
            },
            {
              "ref": "SprintPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "BurndownOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        }
      ],
      "entity": {
        "name": "Burndown",
        "persistence": "singleton",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "totalPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "completedPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "remainingPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "velocity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "daysRemaining",
            "type": "number",
            "default": 0.0
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "BurndownAppLayout",
          "linkedEntity": "Burndown",
          "config": {
            "appName": "ProjectManagerApp",
            "navItems": [
              {
                "label": "Tasks",
                "icon": "list-todo",
                "href": "/tasks"
              },
              {
                "href": "/sprints",
                "label": "Sprints",
                "icon": "zap"
              },
              {
                "icon": "trending-down",
                "href": "/burndown",
                "label": "Burndown"
              }
            ],
            "contentTrait": "@trait.BurndownDisplay",
            "searchEvent": "BURNDOWN_SEARCH",
            "notifications": [],
            "notificationClickEvent": "BURNDOWN_NOTIFICATIONS_OPEN"
          },
          "events": {
            "NOTIFY_CLICK": "BURNDOWN_NOTIFICATIONS_OPEN",
            "SEARCH": "BURNDOWN_SEARCH"
          }
        },
        {
          "name": "BurndownDisplay",
          "category": "interaction",
          "linkedEntity": "Burndown",
          "emits": [
            {
              "event": "BurndownLoaded",
              "description": "Fired when Burndown finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Burndown]"
                }
              ]
            },
            {
              "event": "BurndownLoadFailed",
              "description": "Fired when Burndown fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SPRINT_UPDATED",
              "triggers": "REFRESH",
              "source": {
                "kind": "orbital",
                "orbital": "SprintOrbital",
                "trait": "SprintPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "BurndownLoaded",
                "name": "Burndown loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Burndown]"
                  }
                ]
              },
              {
                "key": "BurndownLoadFailed",
                "name": "Burndown load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.totalPoints",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.completedPoints",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.remainingPoints",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.velocity",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.daysRemaining",
                    0.0
                  ],
                  [
                    "fetch",
                    "Burndown",
                    {
                      "emit": {
                        "success": "BurndownLoaded",
                        "failure": "BurndownLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "className": "max-w-6xl mx-auto w-full",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "trending-down"
                            },
                            {
                              "content": "Burndown",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.totalPoints",
                              "type": "stat-display",
                              "label": "Total Points",
                              "icon": "target"
                            },
                            {
                              "icon": "check-circle",
                              "value": "@entity.completedPoints",
                              "label": "Completed",
                              "type": "stat-display"
                            },
                            {
                              "value": "@entity.remainingPoints",
                              "icon": "circle",
                              "type": "stat-display",
                              "label": "Remaining"
                            },
                            {
                              "type": "stat-display",
                              "label": "Velocity",
                              "icon": "zap",
                              "value": "@entity.velocity"
                            },
                            {
                              "icon": "calendar",
                              "value": "@entity.daysRemaining",
                              "type": "stat-display",
                              "label": "Days Remaining"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 5.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "line-chart",
                          "data": [
                            {
                              "date": "Day 1",
                              "value": 100.0
                            },
                            {
                              "date": "Day 2",
                              "value": 92.0
                            },
                            {
                              "value": 85.0,
                              "date": "Day 3"
                            },
                            {
                              "date": "Day 4",
                              "value": 70.0
                            },
                            {
                              "value": 60.0,
                              "date": "Day 5"
                            },
                            {
                              "value": 45.0,
                              "date": "Day 6"
                            },
                            {
                              "date": "Day 7",
                              "value": 30.0
                            },
                            {
                              "value": 15.0,
                              "date": "Day 8"
                            }
                          ]
                        },
                        {
                          "items": [
                            {
                              "label": "Remaining points",
                              "color": "primary"
                            },
                            {
                              "label": "Ideal burndown",
                              "color": "muted"
                            }
                          ],
                          "type": "chart-legend"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Refresh",
                              "type": "button",
                              "action": "REFRESH",
                              "icon": "refresh-cw",
                              "variant": "secondary"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "justify": "end"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "displaying",
                "to": "displaying",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "Burndown",
                    {
                      "emit": {
                        "failure": "BurndownLoadFailed",
                        "success": "BurndownLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "displaying",
                "to": "displaying",
                "event": "BurndownLoaded"
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Burndown",
          "path": "/burndown",
          "traits": [
            {
              "ref": "BurndownAppLayout"
            },
            {
              "ref": "BurndownDisplay"
            }
          ]
        }
      ]
    }
  ]
}