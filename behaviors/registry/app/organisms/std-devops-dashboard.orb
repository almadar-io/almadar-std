{
  "name": "std-devops-dashboard",
  "version": "2.0.0",
  "description": "DevOps dashboard: services, alerts, logs, system metrics. Pick for SRE/observability.",
  "orbitals": [
    {
      "name": "ServiceNodeOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "ServiceNode",
        "collection": "servicenodes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "healthy",
            "values": [
              "healthy",
              "degraded",
              "down"
            ]
          },
          {
            "name": "region",
            "type": "string",
            "default": ""
          },
          {
            "name": "url",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastChecked",
            "type": "datetime"
          },
          {
            "name": "failureCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "successCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 5.0
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ServiceNodeAppLayout",
          "config": {
            "searchEvent": "SERVICE_SEARCH",
            "appName": "DevOps Dashboard",
            "contentTrait": "@trait.ServiceNodeCatalog",
            "notifications": [],
            "navItems": [
              {
                "icon": "server",
                "label": "Services",
                "href": "/services"
              },
              {
                "href": "/alerts",
                "label": "Alerts",
                "icon": "bell"
              },
              {
                "icon": "terminal",
                "href": "/logs",
                "label": "Logs"
              },
              {
                "label": "Metrics",
                "icon": "layout-list",
                "href": "/metrics"
              }
            ],
            "notificationClickEvent": "SERVICE_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "SERVICE_SEARCH",
            "NOTIFY_CLICK": "SERVICE_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "ServiceNodeCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SERVICE_SEARCH",
              "triggers": "SERVICE_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeAppLayout"
              }
            },
            {
              "event": "SERVICE_NOTIFICATIONS_OPEN",
              "triggers": "SERVICE_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SERVICE_SEARCH",
                "name": "Service Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SERVICE_NOTIFICATIONS_OPEN",
                "name": "Service Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "server"
                                },
                                {
                                  "content": "Services",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "children": [
                                {
                                  "variant": "primary",
                                  "icon": "plus",
                                  "action": "CREATE",
                                  "type": "button",
                                  "label": "Register Service"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            "@trait.ServiceNodeSearch",
                            "@trait.ServiceNodeFilter"
                          ]
                        },
                        "@trait.ServiceNodeStats",
                        "@trait.ServiceNodeGraphs",
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "status": "online",
                              "label": "Healthy",
                              "pulse": false,
                              "type": "status-dot"
                            },
                            {
                              "type": "status-dot",
                              "status": "warning",
                              "label": "Degraded",
                              "pulse": false
                            },
                            {
                              "type": "status-dot",
                              "status": "critical",
                              "pulse": true,
                              "label": "Down"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        "@trait.ServiceNodeBrowseList",
                        {
                          "type": "divider"
                        },
                        "@trait.ServiceNodeCircuitBreaker"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SERVICE_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SERVICE_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "type": "typography",
                          "content": "No notifications",
                          "variant": "h3"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "You're all caught up."
                        },
                        {
                          "type": "button",
                          "action": "INIT",
                          "label": "Back to services",
                          "variant": "ghost"
                        }
                      ],
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ServiceNodeSearch",
          "config": {
            "event": "SERVICE_SEARCH",
            "placeholder": "Search services…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "ServiceNodeFilter",
          "config": {
            "filters": [
              {
                "label": "Status",
                "filterType": "select",
                "field": "status",
                "options": [
                  "healthy",
                  "degraded",
                  "down"
                ]
              },
              {
                "label": "Region",
                "filterType": "select",
                "field": "region",
                "options": [
                  "us-east",
                  "us-west",
                  "eu-central",
                  "ap-south"
                ]
              }
            ],
            "event": "SERVICE_FILTER"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "ServiceNodeStats",
          "config": {
            "metrics": [
              {
                "icon": "server",
                "aggregation": "count",
                "label": "Total",
                "variant": "primary",
                "format": "number"
              },
              {
                "label": "Healthy",
                "icon": "check-circle",
                "aggregation": "count",
                "variant": "success",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "healthy"
                  ]
                ]
              },
              {
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "degraded"
                  ]
                ],
                "aggregation": "count",
                "icon": "alert-circle",
                "variant": "warning",
                "label": "Degraded",
                "format": "number"
              },
              {
                "icon": "alert-triangle",
                "aggregation": "count",
                "format": "number",
                "variant": "danger",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "down"
                  ]
                ],
                "label": "Down"
              }
            ],
            "title": "Services"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "ServiceNodeGraphs",
          "config": {
            "chartType": "pie",
            "categoryField": "status",
            "height": 240.0,
            "aggregation": "count",
            "showLegend": true,
            "title": "Services by Status",
            "subtitle": "Health distribution across the fleet"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ServiceNodeBrowseList",
          "linkedEntity": "ServiceNode",
          "config": {
            "cols": 1.0,
            "fields": [
              {
                "icon": "server",
                "name": "name",
                "variant": "h4"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "variant": "body",
                "name": "region"
              },
              {
                "name": "lastChecked",
                "variant": "caption",
                "format": "date"
              }
            ],
            "gap": "sm",
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "label": "Delete",
                "variant": "danger",
                "event": "DELETE"
              }
            ]
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeFilter"
              }
            },
            {
              "event": "SERVICE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodePersistor"
              }
            },
            {
              "event": "SERVICE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodePersistor"
              }
            },
            {
              "event": "SERVICE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodePersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ServiceNodeCreate",
          "linkedEntity": "ServiceNode",
          "config": {
            "mode": "create",
            "fields": [
              "name",
              "status",
              "region",
              "url",
              "threshold"
            ],
            "icon": "plus-circle",
            "title": "Register Service"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ServiceNodeEdit",
          "linkedEntity": "ServiceNode",
          "config": {
            "mode": "edit",
            "icon": "edit",
            "fields": [
              "name",
              "status",
              "region",
              "url",
              "threshold"
            ],
            "title": "Edit Service"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ServiceNodeView",
          "linkedEntity": "ServiceNode",
          "config": {
            "title": "View Service",
            "icon": "eye",
            "mode": "edit",
            "fields": [
              "name",
              "status",
              "region",
              "url",
              "lastChecked",
              "failureCount",
              "successCount",
              "threshold"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ServiceNodeDelete",
          "linkedEntity": "ServiceNode",
          "config": {
            "confirmLabel": "Delete",
            "alertMessage": "This action cannot be undone.",
            "title": "Delete Service",
            "icon": "alert-triangle"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeBrowseList"
              }
            }
          ]
        },
        {
          "name": "ServiceNodePersistor",
          "category": "lifecycle",
          "linkedEntity": "ServiceNode",
          "emits": [
            {
              "event": "SERVICE_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SERVICE_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SERVICE_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ServiceNodeDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SERVICE_CREATED",
                "name": "Service Created"
              },
              {
                "key": "SERVICE_UPDATED",
                "name": "Service Updated"
              },
              {
                "key": "SERVICE_DELETED",
                "name": "Service Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ServiceNode",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SERVICE_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "ServiceNode",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SERVICE_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "ServiceNode",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "SERVICE_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceNodeCircuitBreaker",
          "category": "interaction",
          "linkedEntity": "ServiceNode",
          "emits": [
            {
              "event": "ServiceNodeLoaded",
              "description": "Fired when ServiceNode finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ServiceNode]"
                }
              ]
            },
            {
              "event": "ServiceNodeLoadFailed",
              "description": "Fired when ServiceNode fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              },
              {
                "name": "halfOpen"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FAILURE",
                "name": "Failure"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "TIMEOUT",
                "name": "Timeout"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceNodeLoaded",
                "name": "ServiceNode loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ServiceNode]"
                  }
                ]
              },
              {
                "key": "ServiceNodeLoadFailed",
                "name": "ServiceNode load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.failureCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.successCount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.threshold",
                    5.0
                  ],
                  [
                    "fetch",
                    "ServiceNode",
                    {
                      "emit": {
                        "success": "ServiceNodeLoaded",
                        "failure": "ServiceNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "type": "typography",
                                  "content": "Circuit Breaker",
                                  "variant": "h3"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "label": "Circuit Closed",
                              "status": "online",
                              "type": "status-dot",
                              "pulse": false
                            }
                          ]
                        },
                        {
                          "type": "alert",
                          "message": "All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "max": "@entity.threshold",
                          "min": 0.0,
                          "type": "meter",
                          "value": "@entity.failureCount"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Circuit Breaker",
                                  "variant": "h3"
                                }
                              ],
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "status": "critical",
                              "pulse": true,
                              "type": "status-dot",
                              "label": "Circuit Open"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0.0
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "label": "Reset",
                          "action": "RESET",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "type": "typography",
                                  "content": "Circuit Breaker",
                                  "variant": "h3"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "pulse": false,
                              "status": "online",
                              "label": "Circuit Closed"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "All requests are being processed."
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2.0,
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ]
                        },
                        {
                          "value": "@entity.failureCount",
                          "min": 0.0,
                          "type": "meter",
                          "max": "@entity.threshold"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "halfOpen",
                "event": "TIMEOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h3",
                                  "content": "Circuit Breaker"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "pulse": true,
                              "type": "status-dot",
                              "label": "Half-Open",
                              "status": "warning"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "variant": "warning",
                          "type": "alert",
                          "message": "Testing recovery. Limited requests are being allowed through."
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.failureCount",
                              "type": "stat-display",
                              "label": "Failures"
                            },
                            {
                              "value": "@entity.successCount",
                              "type": "stat-display",
                              "label": "Successes"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "variant": "h3",
                                  "type": "typography",
                                  "content": "Circuit Breaker"
                                }
                              ]
                            },
                            {
                              "label": "Circuit Closed",
                              "type": "status-dot",
                              "pulse": false,
                              "status": "online"
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "alert",
                          "message": "All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2.0
                        },
                        {
                          "min": 0.0,
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "type": "meter"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield-check"
                                },
                                {
                                  "content": "Circuit Breaker",
                                  "type": "typography",
                                  "variant": "h3"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "pulse": false,
                              "type": "status-dot",
                              "label": "Circuit Closed",
                              "status": "online"
                            }
                          ],
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "alert",
                          "message": "All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "cols": 2.0,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ]
                        },
                        {
                          "min": 0.0,
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "type": "meter"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "alert-triangle"
                                },
                                {
                                  "variant": "h3",
                                  "content": "Circuit Breaker",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "label": "Circuit Open",
                              "pulse": true,
                              "type": "status-dot",
                              "status": "critical"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between"
                        },
                        {
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "cols": 2.0,
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid"
                        },
                        {
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "max": "@entity.threshold",
                          "min": 0.0
                        },
                        {
                          "label": "Reset",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "ghost",
                          "action": "RESET"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "shield-check",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h3",
                                  "content": "Circuit Breaker"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center"
                            },
                            {
                              "pulse": false,
                              "label": "Circuit Closed",
                              "type": "status-dot",
                              "status": "online"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "variant": "success",
                          "message": "All requests are being processed.",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "type": "stat-display",
                              "label": "Failures",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "value": "@entity.successCount"
                            }
                          ],
                          "cols": 2.0
                        },
                        {
                          "min": 0.0,
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ServicesPage",
          "path": "/services",
          "traits": [
            {
              "ref": "ServiceNodeAppLayout"
            },
            {
              "ref": "ServiceNodeCatalog"
            },
            {
              "ref": "ServiceNodeSearch"
            },
            {
              "ref": "ServiceNodeFilter"
            },
            {
              "ref": "ServiceNodeStats"
            },
            {
              "ref": "ServiceNodeGraphs"
            },
            {
              "ref": "ServiceNodeBrowseList"
            },
            {
              "ref": "ServiceNodeCreate"
            },
            {
              "ref": "ServiceNodeEdit"
            },
            {
              "ref": "ServiceNodeView"
            },
            {
              "ref": "ServiceNodeDelete"
            },
            {
              "ref": "ServiceNodePersistor"
            },
            {
              "ref": "ServiceNodeCircuitBreaker"
            }
          ]
        }
      ]
    },
    {
      "name": "AlertMetricOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-email",
          "as": "Email"
        }
      ],
      "entity": {
        "name": "AlertMetric",
        "collection": "alertmetrics",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "severity",
            "type": "string",
            "default": "info",
            "values": [
              "info",
              "warning",
              "critical"
            ]
          },
          {
            "name": "message",
            "type": "string",
            "required": true
          },
          {
            "name": "timestamp",
            "type": "datetime"
          },
          {
            "name": "source",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AlertCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "bell",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Alerts",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "children": [
                                {
                                  "label": "New Alert",
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "type": "button",
                                  "icon": "plus"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.AlertBrowseList"
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "AlertBrowseList",
          "linkedEntity": "AlertMetric",
          "config": {
            "itemActions": [
              {
                "label": "View",
                "variant": "ghost",
                "event": "VIEW"
              },
              {
                "variant": "ghost",
                "event": "EDIT",
                "label": "Edit"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ],
            "fields": [
              {
                "variant": "badge",
                "name": "severity"
              },
              {
                "variant": "h4",
                "name": "message",
                "icon": "alert-triangle"
              },
              {
                "name": "source",
                "variant": "body"
              },
              {
                "variant": "caption",
                "format": "date",
                "name": "timestamp"
              }
            ],
            "cols": 1.0,
            "gap": "sm"
          },
          "listens": [
            {
              "event": "ALERT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            },
            {
              "event": "ALERT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            },
            {
              "event": "ALERT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "AlertCreate",
          "linkedEntity": "AlertMetric",
          "config": {
            "mode": "create",
            "fields": [
              "severity",
              "message",
              "source",
              "timestamp"
            ],
            "icon": "plus-circle",
            "title": "New Alert"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "AlertCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "AlertEdit",
          "linkedEntity": "AlertMetric",
          "config": {
            "fields": [
              "severity",
              "message",
              "source",
              "timestamp"
            ],
            "title": "Edit Alert",
            "mode": "edit",
            "icon": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "AlertBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "AlertView",
          "linkedEntity": "AlertMetric",
          "config": {
            "title": "View Alert",
            "fields": [
              "severity",
              "message",
              "source",
              "timestamp"
            ],
            "icon": "eye",
            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "AlertBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "AlertDelete",
          "linkedEntity": "AlertMetric",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Alert",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "AlertBrowseList"
              }
            }
          ]
        },
        {
          "name": "AlertPersistor",
          "category": "lifecycle",
          "linkedEntity": "AlertMetric",
          "emits": [
            {
              "event": "ALERT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ALERT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ALERT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "AlertCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "AlertEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "AlertDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ALERT_CREATED",
                "name": "Alert Created"
              },
              {
                "key": "ALERT_UPDATED",
                "name": "Alert Updated"
              },
              {
                "key": "ALERT_DELETED",
                "name": "Alert Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AlertMetric",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ALERT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AlertMetric",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ALERT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AlertMetric",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ALERT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "AlertEmail",
          "category": "lifecycle",
          "linkedEntity": "AlertMetric",
          "listens": [
            {
              "event": "ALERT_CREATED",
              "triggers": "ALERT_TRIGGERED",
              "source": {
                "kind": "trait",
                "trait": "AlertPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ALERT_TRIGGERED",
                "name": "Alert Triggered",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "severity",
                    "type": "string"
                  },
                  {
                    "name": "recipient",
                    "type": "string"
                  },
                  {
                    "name": "subject",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ALERT_TRIGGERED",
                "guard": [
                  "=",
                  "@payload.severity",
                  "critical"
                ],
                "effects": [
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "body": "@payload.body",
                      "sender": "alerts@example.com",
                      "subject": "@payload.subject",
                      "recipient": "@payload.recipient"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AlertsPage",
          "path": "/alerts",
          "traits": [
            {
              "ref": "AlertCatalog"
            },
            {
              "ref": "AlertBrowseList"
            },
            {
              "ref": "AlertCreate"
            },
            {
              "ref": "AlertEdit"
            },
            {
              "ref": "AlertView"
            },
            {
              "ref": "AlertDelete"
            },
            {
              "ref": "AlertPersistor"
            },
            {
              "ref": "AlertEmail"
            }
          ]
        }
      ]
    },
    {
      "name": "LogEntryOrbital",
