                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "content": "Connect to live market data.",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "type": "button",
                          "label": "Start Stream",
