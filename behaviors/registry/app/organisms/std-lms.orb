                          "currentStep": 3.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "info",
                          "message": "Please confirm your enrollment.",
                          "type": "alert"
                        },
                        {
                          "gap": "sm",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "justify": "between",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Student",
                                  "variant": "caption"
                                },
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@entity.studentName"
                                }
                              ]
                            },
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Email",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@entity.email"
                                }
                              ],
                              "justify": "between"
                            },
                            {
                              "children": [
                                {
                                  "content": "Course",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "content": "@entity.courseId",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "justify": "between",
                              "direction": "horizontal",
                              "gap": "md"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "action": "PREV",
                              "icon": "arrow-left",
                              "label": "Back",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "action": "COMPLETE",
                              "label": "Enroll",
                              "variant": "primary",
                              "icon": "check"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "courseSelection",
                "event": "PREV",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "variant": "h2",
                          "content": "Course Enrollment",
                          "type": "typography"
                        },
                        {
                          "currentStep": 1.0,
                          "type": "wizard-progress",
                          "steps": [
                            "Student Info",
                            "Course Selection",
                            "Review",
                            "Confirm"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Course Selection"
                        },
                        {
                          "submitEvent": "NEXT",
                          "type": "form-section",
                          "fields": [
                            {
                              "name": "courseId",
                              "required": true
                            }
                          ],
                          "entity": "@entity",
                          "cancelEvent": "PREV",
                          "submitLabel": "Continue",
                          "mode": "edit",
                          "cancelLabel": "Back"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirm",
                "to": "complete",
                "event": "COMPLETE",
                "guard": [
                  "and",
                  "@entity.studentName",
                  "@entity.email",
                  "@entity.courseId"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "active"
                  ],
                  [
                    "persist",
                    "create",
                    "Enrollment",
                    "@entity",
                    {
                      "emit": {
                        "success": "EnrollmentSaved",
                        "failure": "EnrollmentSaveFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENROLLED",
                    {
                      "courseId": "@entity.courseId",
                      "id": "@entity.id"
                    }
                  ],
                  [
                    "notify",
                    "success",
                    "Enrollment confirmed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Enrolled!",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "You have been enrolled in the course.",
                          "color": "muted"
                        },
                        {
                          "action": "RESTART",
                          "type": "button",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "label": "Enroll another student"
                        }
                      ],
                      "align": "center",
                      "className": "max-w-xl mx-auto w-full py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirm",
                "to": "review",
                "event": "PREV",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "className": "max-w-xl mx-auto w-full",
                      "children": [
                        {
                          "variant": "h2",
                          "content": "Course Enrollment",
                          "type": "typography"
                        },
                        {
                          "type": "wizard-progress",
                          "steps": [
                            "Student Info",
                            "Course Selection",
                            "Review",
                            "Confirm"
                          ],
                          "currentStep": 2.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Review",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "label": "Back",
                              "icon": "arrow-left",
                              "action": "PREV",
                              "variant": "ghost"
                            },
                            {
                              "type": "button",
                              "action": "NEXT",
                              "icon": "arrow-right",
                              "variant": "primary",
                              "label": "Continue"
                            }
                          ],
                          "type": "stack",
                          "justify": "between"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "studentInfo",
                "event": "RESTART",
                "effects": [
                  [
                    "set",
                    "@entity.studentName",
                    ""
                  ],
                  [
                    "set",
                    "@entity.email",
                    ""
                  ],
                  [
                    "set",
                    "@entity.courseId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.enrolledAt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.status",
                    "pending"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "className": "max-w-xl mx-auto w-full",
                      "children": [
                        {
                          "variant": "h2",
                          "content": "Course Enrollment",
                          "type": "typography"
                        },
                        {
                          "currentStep": 0.0,
                          "steps": [
                            "Student Info",
                            "Course Selection",
                            "Review",
                            "Confirm"
                          ],
                          "type": "wizard-progress"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Student Info"
                        },
                        {
                          "submitLabel": "Continue",
                          "showCancel": false,
                          "fields": [
                            {
                              "required": true,
                              "min": 2.0,
                              "name": "studentName"
                            },
                            {
                              "name": "email",
                              "type": "email",
                              "required": true
                            }
                          ],
                          "mode": "create",
                          "type": "form-section",
                          "submitEvent": "NEXT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Enroll",
          "path": "/enroll",
          "traits": [
            {
              "ref": "EnrollmentAppLayout"
            },
            {
              "ref": "EnrollmentWizard"
            }
          ]
        }
      ]
    },
    {
      "name": "ProgressOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Progress",
        "collection": "progresses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "courseName",
            "type": "string",
            "default": ""
          },
          {
            "name": "week",
            "type": "string",
            "default": ""
          },
          {
            "name": "lessonsCompleted",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalLessons",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "completionPct",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "timeSpent",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "streak",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastActivity",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ProgressAppLayout",
          "linkedEntity": "Progress",
          "config": {
            "notificationClickEvent": "PROGRESS_NOTIFICATIONS_OPEN",
            "appName": "LMS",
            "contentTrait": "@trait.ProgressDisplay",
            "navItems": [
              {
                "icon": "graduation-cap",
                "label": "Courses",
                "href": "/courses"
              },
              {
                "label": "Enroll",
                "href": "/enroll",
                "icon": "user-plus"
              },
              {
                "href": "/progress",
                "icon": "trending-up",
                "label": "Progress"
              }
            ],
            "searchEvent": "PROGRESS_SEARCH",
            "topBarActions": [],
            "notifications": []
          },
          "events": {
            "SEARCH": "PROGRESS_SEARCH",
            "NOTIFY_CLICK": "PROGRESS_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "ProgressDisplay",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-5xl mx-auto w-full",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "trending-up"
                            },
                            {
                              "content": "Progress",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ProgressStats",
                        "@trait.ProgressGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.ProgressBrowseList"
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ProgressStats",
          "category": "interaction",
          "linkedEntity": "Progress",
          "emits": [
            {
              "event": "ProgressLoaded",
              "description": "Fired when Progress finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Progress]"
                }
              ]
            },
            {
              "event": "ProgressLoadFailed",
              "description": "Fired when Progress fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ProgressLoaded",
                "name": "Progress loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Progress]"
                  }
                ]
              },
              {
                "key": "ProgressLoadFailed",
                "name": "Progress load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Progress",
                    {
                      "emit": {
                        "failure": "ProgressLoadFailed",
                        "success": "ProgressLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "label": "Completion %",
                          "variant": "success",
                          "format": "percent",
                          "icon": "check-circle",
                          "value": 0.0,
                          "type": "stat-display"
                        },
                        {
                          "format": "number",
                          "value": 0.0,
                          "variant": "info",
                          "type": "stat-display",
                          "label": "Time Spent",
                          "icon": "clock",
                          "suffix": "h"
                        },
                        {
                          "variant": "default",
                          "type": "stat-display",
                          "value": 0.0,
                          "icon": "list",
                          "format": "number",
                          "label": "Lessons Remaining"
                        },
                        {
                          "type": "stat-display",
                          "format": "number",
                          "label": "Streak",
                          "value": 0.0,
                          "variant": "warning",
                          "suffix": "d",
                          "icon": "flame"
                        }
                      ],
                      "type": "simple-grid",
                      "cols": 4.0,
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ProgressLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "cols": 4.0,
                      "type": "simple-grid",
                      "children": [
                        {
                          "type": "stat-display",
                          "label": "Completion %",
                          "variant": "success",
                          "value": 0.0,
                          "format": "percent",
                          "icon": "check-circle"
                        },
                        {
                          "variant": "info",
                          "format": "number",
                          "suffix": "h",
                          "value": 0.0,
                          "label": "Time Spent",
                          "type": "stat-display",
                          "icon": "clock"
                        },
                        {
                          "variant": "default",
                          "format": "number",
                          "type": "stat-display",
                          "label": "Lessons Remaining",
                          "value": 0.0,
                          "icon": "list"
                        },
                        {
                          "variant": "warning",
                          "type": "stat-display",
                          "suffix": "d",
                          "icon": "flame",
                          "label": "Streak",
                          "value": 0.0,
                          "format": "number"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProgressGraphs",
          "category": "interaction",
          "linkedEntity": "Progress",
          "emits": [
            {
              "event": "ProgressLoaded",
              "description": "Fired when Progress finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Progress]"
                }
              ]
            },
            {
              "event": "ProgressLoadFailed",
              "description": "Fired when Progress fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ProgressLoaded",
                "name": "Progress loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Progress]"
                  }
                ]
              },
              {
                "key": "ProgressLoadFailed",
                "name": "Progress load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Progress",
                    {
                      "emit": {
                        "failure": "ProgressLoadFailed",
                        "success": "ProgressLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Progress over time",
                      "chartType": "line",
                      "data": [],
                      "subtitle": "Average completion % per week",
                      "type": "chart",
                      "height": 280.0,
                      "showLegend": true
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ProgressLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showLegend": true,
                      "data": [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "row",
                          {
                            "value": [
                              "object/get",
                              "@row",
                              "completionPct",
                              0.0
                            ],
                            "label": [
                              "object/get",
                              "@row",
                              "courseName",
                              ""
                            ]
                          }
                        ]
                      ],
                      "title": "Progress over time",
                      "chartType": "line",
                      "type": "chart",
                      "subtitle": "Average completion % per week",
                      "height": 280.0
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ProgressBrowseList",
          "linkedEntity": "Progress",
          "config": {
            "gap": "sm",
            "fields": [
              {
                "label": "Course",
                "name": "courseName",
                "variant": "h4",
                "icon": "book-open"
              },
              {
                "name": "completionPct",
                "label": "Completion",
                "variant": "badge",
                "format": "percent"
              },
              {
                "label": "Lessons Completed",
                "variant": "body",
                "name": "lessonsCompleted"
              },
              {
                "label": "Total Lessons",
                "name": "totalLessons",
                "variant": "body"
              },
              {
                "variant": "caption",
                "format": "date",
                "label": "Last Activity",
                "name": "lastActivity"
              }
            ],
            "itemActions": [],
            "cols": 1.0
          },
          "listens": [
            {
              "event": "ENROLLED",
              "triggers": "INIT",
              "source": {
                "kind": "orbital",
                "orbital": "EnrollmentOrbital",
                "trait": "EnrollmentWizard"
              }
            }
          ]
        },
        {
          "name": "ProgressItemSink",
          "category": "lifecycle",
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ProgressBrowseList"
              }
            },
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ProgressBrowseList"
              }
            },
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ProgressBrowseList"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Progress"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Progress"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Progress"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "VIEW"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DELETE"
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Progress",
          "path": "/progress",
          "traits": [
            {
              "ref": "ProgressAppLayout"
            },
            {
              "ref": "ProgressDisplay"
            },
            {
              "ref": "ProgressStats"
            },
            {
              "ref": "ProgressGraphs"
            },
            {
              "ref": "ProgressBrowseList"
            },
            {
              "ref": "ProgressItemSink"
            }
          ]
        }
      ]
    }
  ]
}