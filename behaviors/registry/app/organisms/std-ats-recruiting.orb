{
  "name": "std-ats-recruiting",
  "version": "1.0.0",
  "description": "ATS recruiting: job openings catalog, applicant intake pipeline, interview scheduling, and offer letters. Pick for hiring/talent apps.",
  "orbitals": [
    {
      "name": "JobOpeningOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "JobOpening",
        "collection": "jobopenings",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "department",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "closed",
              "draft"
            ]
          },
          {
            "name": "location",
            "type": "string",
            "default": ""
          },
          {
            "name": "hiringManager",
            "type": "string",
            "default": ""
          },
          {
            "name": "headcount",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "JobOpeningAppLayout",
          "config": {
            "contentTrait": "@trait.JobOpeningCatalog",
            "notificationClickEvent": "JOB_OPENING_NOTIFICATIONS_OPEN",
            "appName": "ATSRecruiting",
            "navItems": [
              {
                "icon": "briefcase",
                "href": "/openings",
                "label": "Openings"
              },
              {
                "label": "Pipeline",
                "icon": "user-plus",
                "href": "/pipeline"
              },
              {
                "href": "/interviews",
                "icon": "calendar",
                "label": "Interviews"
              },
              {
                "href": "/offers",
                "icon": "file-text",
                "label": "Offers"
              }
            ],
            "searchEvent": "JOB_OPENING_SEARCH",
            "notifications": []
          },
          "events": {
            "SEARCH": "JOB_OPENING_SEARCH",
            "NOTIFY_CLICK": "JOB_OPENING_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "JobOpeningCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "JOB_OPENING_SEARCH",
              "triggers": "JOB_OPENING_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningAppLayout"
              }
            },
            {
              "event": "JOB_OPENING_NOTIFICATIONS_OPEN",
              "triggers": "JOB_OPENING_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "JOB_OPENING_SEARCH",
                "name": "Job Opening Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "JOB_OPENING_NOTIFICATIONS_OPEN",
                "name": "Job Opening Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "briefcase"
                                },
                                {
                                  "content": "Job Openings",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "action": "CREATE",
                                  "label": "New Opening",
                                  "type": "button",
                                  "variant": "primary",
                                  "icon": "plus"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            "@trait.JobOpeningSearch",
                            "@trait.JobOpeningFilter"
                          ],
                          "type": "stack",
                          "gap": "md",
                          "align": "center"
                        },
                        "@trait.JobOpeningStats",
                        "@trait.JobOpeningGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.JobOpeningBrowseList"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "JOB_OPENING_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "JOB_OPENING_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "You're all caught up.",
                          "variant": "caption"
                        },
                        {
                          "variant": "ghost",
                          "type": "button",
                          "label": "Back to openings",
                          "action": "INIT"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "JobOpeningSearch",
          "config": {
            "event": "JOB_OPENING_SEARCH",
            "placeholder": "Search openings…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "JobOpeningFilter",
          "config": {
            "filters": [
              {
                "label": "Status",
                "field": "status",
                "options": [
                  "open",
                  "closed",
                  "draft"
                ],
                "filterType": "select"
              },
              {
                "field": "department",
                "label": "Department",
                "options": [
                  "engineering",
                  "design",
                  "marketing",
                  "sales",
                  "hr",
                  "finance",
                  "operations"
                ],
                "filterType": "select"
              }
            ],
            "event": "JOB_OPENING_FILTER"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "JobOpeningStats",
          "config": {
            "metrics": [
              {
                "label": "Total",
                "variant": "primary",
                "format": "number",
                "aggregation": "count",
                "icon": "briefcase"
              },
              {
                "format": "number",
                "aggregation": "count",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "open"
                  ]
                ],
                "label": "Open",
                "icon": "circle",
                "variant": "success"
              },
              {
                "icon": "edit",
                "label": "Drafts",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "draft"
                  ]
                ],
                "variant": "warning",
                "format": "number",
                "aggregation": "count"
              },
              {
                "variant": "primary",
                "icon": "users",
                "format": "number",
                "aggregation": "sum",
                "field": "headcount",
                "label": "Seats"
              }
            ],
            "title": "Openings"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "JobOpeningGraphs",
          "config": {
            "height": 240.0,
            "chartType": "bar",
            "aggregation": "count",
            "subtitle": "Headcount distribution across teams",
            "title": "Openings by Department",
            "categoryField": "department",
            "showLegend": false
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "JobOpeningBrowseList",
          "linkedEntity": "JobOpening",
          "config": {
            "itemActions": [
              {
                "label": "View",
                "variant": "ghost",
                "event": "VIEW"
              },
              {
                "event": "EDIT",
                "label": "Edit",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "variant": "danger",
                "label": "Delete"
              }
            ],
            "cols": 1.0,
            "fields": [
              {
                "name": "title",
                "variant": "h3",
                "icon": "briefcase"
              },
              {
                "name": "department",
                "variant": "badge"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "name": "location",
                "variant": "body"
              },
              {
                "variant": "caption",
                "name": "hiringManager"
              },
              {
                "name": "headcount",
                "variant": "caption"
              }
            ],
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningFilter"
              }
            },
            {
              "event": "JOB_OPENING_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningPersistor"
              }
            },
            {
              "event": "JOB_OPENING_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningPersistor"
              }
            },
            {
              "event": "JOB_OPENING_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "JobOpeningCreate",
          "linkedEntity": "JobOpening",
          "config": {
            "title": "New Opening",
            "mode": "create",
            "icon": "plus-circle",
            "fields": [
              "title",
              "department",
              "status",
              "location",
              "hiringManager",
              "headcount"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "JobOpeningEdit",
          "linkedEntity": "JobOpening",
          "config": {
            "icon": "edit",
            "title": "Edit Opening",
            "mode": "edit",
            "fields": [
              "title",
              "department",
              "status",
              "location",
              "hiringManager",
              "headcount"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "JobOpeningView",
          "linkedEntity": "JobOpening",
          "config": {
            "mode": "edit",
            "title": "View Opening",
            "icon": "eye",
            "fields": [
              "title",
              "department",
              "status",
              "location",
              "hiringManager",
              "headcount"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "JobOpeningDelete",
          "linkedEntity": "JobOpening",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "title": "Delete Opening"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningBrowseList"
              }
            }
          ]
        },
        {
          "name": "JobOpeningPersistor",
          "category": "lifecycle",
          "linkedEntity": "JobOpening",
          "emits": [
            {
              "event": "JOB_OPENING_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "JOB_OPENING_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "JOB_OPENING_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "JobOpeningDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "JOB_OPENING_CREATED",
                "name": "Job Opening Created"
              },
              {
                "key": "JOB_OPENING_UPDATED",
                "name": "Job Opening Updated"
              },
              {
                "key": "JOB_OPENING_DELETED",
                "name": "Job Opening Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "JobOpening",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "JOB_OPENING_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "JobOpening",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "JOB_OPENING_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "JobOpening",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "JOB_OPENING_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "OpeningsPage",
          "path": "/openings",
          "traits": [
            {
              "ref": "JobOpeningAppLayout"
            },
            {
              "ref": "JobOpeningCatalog"
            },
            {
              "ref": "JobOpeningSearch"
            },
            {
              "ref": "JobOpeningFilter"
            },
            {
              "ref": "JobOpeningStats"
            },
            {
              "ref": "JobOpeningGraphs"
            },
            {
              "ref": "JobOpeningBrowseList"
            },
            {
              "ref": "JobOpeningCreate"
            },
            {
              "ref": "JobOpeningEdit"
            },
            {
              "ref": "JobOpeningView"
            },
            {
              "ref": "JobOpeningDelete"
            },
            {
              "ref": "JobOpeningPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ApplicantPipelineOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-applicant-form",
          "as": "ApplicantForm"
        }
      ],
      "entity": {
        "name": "ApplicationIntake",
        "collection": "applicationintakes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantEmail",
            "type": "string",
            "default": ""
          },
          {
            "name": "applicantPhone",
            "type": "string",
            "default": ""
          },
          {
            "name": "jobId",
            "type": "string",
            "default": ""
          },
          {
            "name": "resumeUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "firstInterviewAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewFormat",
            "type": "string",
            "default": "video",
            "values": [
              "phone",
              "video",
              "onsite"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "submitted",
              "interviewing",
              "completed"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ApplicantPipelineAppLayout",
          "config": {
            "navItems": [
              {
                "label": "Openings",
                "href": "/openings",
                "icon": "briefcase"
              },
              {
                "href": "/pipeline",
                "label": "Pipeline",
                "icon": "user-plus"
              },
              {
                "icon": "calendar",
                "label": "Interviews",
                "href": "/interviews"
              },
              {
                "label": "Offers",
                "href": "/offers",
                "icon": "file-text"
              }
            ],
            "contentTrait": "@trait.PipelineIntakeBrowse",
            "searchEvent": "PIPELINE_SEARCH",
            "notifications": [],
            "appName": "ATSRecruiting",
            "notificationClickEvent": "PIPELINE_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "PIPELINE_SEARCH",
            "NOTIFY_CLICK": "PIPELINE_NOTIFICATIONS_OPEN"
          }
        },
        {
          "ref": "ApplicantForm.traits.ApplicationIntakeBrowse",
          "name": "PipelineIntakeBrowse",
          "linkedEntity": "ApplicationIntake",
          "listens": [
            {
              "event": "INTAKE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineIntakePersistor"
              }
            },
            {
              "event": "INTAKE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineIntakePersistor"
              }
            },
            {
              "event": "INTAKE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "PipelineIntakePersistor"
              }
            }
          ]
        },
        {
          "ref": "ApplicantForm.traits.ApplicationIntakeCreate",
