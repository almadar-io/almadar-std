        },
        {
          "from": "std/behaviors/std-applicant",
          "as": "Applicant"
        }
      ],
      "entity": {
        "name": "Applicant",
        "collection": "applicants",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "jobId",
            "type": "string",
            "default": ""
          },
          {
            "name": "resumeUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "stage",
            "type": "string",
            "default": "applied",
            "values": [
              "applied",
              "screening",
              "interview",
              "offer",
              "hired",
              "rejected"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "appliedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
