                "icon": "credit-card"
              },
              {
                "icon": "receipt",
                "href": "/receipts",
                "label": "Receipts"
              },
              {
                "href": "/customers",
                "label": "Customers",
                "icon": "users"
              }
            ],
            "appName": "Retail POS",
            "searchEvent": "RECEIPT_SEARCH",
            "contentTrait": "@trait.ReceiptLedger",
            "notifications": [],
            "notificationClickEvent": "RECEIPT_NOTIFICATIONS_OPEN"
          },
          "events": {
            "NOTIFY_CLICK": "RECEIPT_NOTIFICATIONS_OPEN",
            "SEARCH": "RECEIPT_SEARCH"
          }
