{
  "name": "std-retail-pos",
  "version": "1.0.0",
  "description": "Retail POS: sales ledger, checkout terminal, receipts, and customer accounts. Pick for general non-restaurant retail.",
  "orbitals": [
    {
      "name": "SaleOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Sale",
        "collection": "sales",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "in-progress",
            "values": [
              "in-progress",
              "completed",
              "refunded",
              "voided"
            ]
          },
          {
            "name": "paymentMethod",
            "type": "string",
            "default": "card",
            "values": [
              "cash",
              "card",
              "check",
              "digital"
            ]
          },
          {
            "name": "customerId",
            "type": "string",
            "default": ""
          },
          {
            "name": "cashierId",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "SaleAppLayout",
          "config": {
            "notifications": [],
            "notificationClickEvent": "SALE_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.SaleCatalog",
            "navItems": [
              {
                "href": "/sales",
                "icon": "shopping-bag",
                "label": "Sales"
              },
              {
                "href": "/checkout",
                "icon": "credit-card",
                "label": "Checkout"
              },
              {
                "icon": "receipt",
                "label": "Receipts",
                "href": "/receipts"
              },
              {
                "icon": "users",
                "label": "Customers",
                "href": "/customers"
              }
            ],
            "appName": "Retail POS",
            "searchEvent": "SALE_SEARCH"
          },
          "events": {
            "SEARCH": "SALE_SEARCH",
            "NOTIFY_CLICK": "SALE_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "SaleCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SALE_SEARCH",
              "triggers": "SALE_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "SaleAppLayout"
              }
            },
            {
              "event": "SALE_NOTIFICATIONS_OPEN",
              "triggers": "SALE_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "SaleAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SALE_SEARCH",
                "name": "Sale Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SALE_NOTIFICATIONS_OPEN",
                "name": "Sale Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "shopping-bag",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Sales",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center",
                              "type": "stack",
                              "gap": "sm"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "icon": "plus",
                                  "action": "CREATE",
                                  "type": "button",
                                  "variant": "primary",
                                  "label": "New Sale"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.SaleSearch",
                            "@trait.SaleFilter"
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        "@trait.SaleStats",
                        "@trait.SaleGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.SaleBrowseList"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SALE_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SALE_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-8",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "You're all caught up.",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "label": "Back to sales",
                          "action": "INIT"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "SaleSearch",
          "config": {
            "placeholder": "Search sales…",
            "event": "SALE_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "SaleFilter",
          "config": {
            "event": "SALE_FILTER",
            "filters": [
              {
                "filterType": "select",
                "field": "status",
                "label": "Status",
                "options": [
                  "in-progress",
                  "completed",
                  "refunded",
                  "voided"
                ]
              },
              {
                "options": [
                  "cash",
                  "card",
                  "check",
                  "digital"
                ],
                "label": "Payment",
                "filterType": "select",
                "field": "paymentMethod"
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "SaleStats",
          "config": {
            "metrics": [
              {
                "label": "Total",
                "icon": "shopping-bag",
                "aggregation": "count",
                "format": "number",
                "variant": "primary"
              },
              {
                "label": "Completed",
                "icon": "check-circle",
                "variant": "success",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "completed"
                  ]
                ],
                "format": "number",
                "aggregation": "count"
              },
              {
                "field": "total",
                "icon": "dollar-sign",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "completed"
                  ]
                ],
                "aggregation": "sum",
                "format": "currency",
                "label": "Revenue",
                "variant": "info"
              }
            ],
            "title": "Sales"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "SaleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "SaleGraphs",
          "config": {
            "height": 240.0,
            "showLegend": false,
            "categoryField": "paymentMethod",
            "subtitle": "Volume across payment types",
            "chartType": "bar",
            "title": "Sales by Payment Method",
            "aggregation": "count"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "SaleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "SaleBrowseList",
          "linkedEntity": "Sale",
          "config": {
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "label": "Edit",
                "variant": "ghost",
                "event": "EDIT"
              },
              {
                "label": "Delete",
                "variant": "danger",
                "event": "DELETE"
              }
            ],
            "gap": "sm",
            "fields": [
              {
                "icon": "shopping-bag",
                "name": "id",
                "variant": "h4"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "variant": "badge",
                "name": "paymentMethod"
              },
              {
                "name": "total",
                "variant": "caption"
              },
              {
                "variant": "caption",
                "name": "completedAt"
              }
            ],
            "cols": 1.0
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "SaleSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "SaleFilter"
              }
            },
            {
              "event": "SALE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SalePersistor"
              }
            },
            {
              "event": "SALE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SalePersistor"
              }
            },
            {
              "event": "SALE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SalePersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SaleCreate",
          "linkedEntity": "Sale",
          "config": {
            "fields": [
              "total",
              "status",
              "paymentMethod",
              "customerId",
              "cashierId"
            ],
            "icon": "plus-circle",
            "title": "New Sale",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "SaleCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SaleEdit",
          "linkedEntity": "Sale",
          "config": {
            "title": "Edit Sale",
            "icon": "edit",
            "mode": "edit",
            "fields": [
              "total",
              "status",
              "paymentMethod",
              "customerId",
              "cashierId",
              "completedAt"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "SaleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SaleView",
          "linkedEntity": "Sale",
          "config": {
            "title": "View Sale",
            "mode": "edit",
            "fields": [
              "total",
              "status",
              "paymentMethod",
              "customerId",
              "cashierId",
              "completedAt"
            ],
            "icon": "eye"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "SaleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "SaleDelete",
          "linkedEntity": "Sale",
          "config": {
            "confirmLabel": "Delete",
            "icon": "alert-triangle",
            "title": "Delete Sale",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "SaleBrowseList"
              }
            }
          ]
        },
        {
          "name": "SalePersistor",
          "category": "lifecycle",
          "linkedEntity": "Sale",
          "emits": [
            {
              "event": "SALE_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SALE_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SALE_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "SaleCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "SaleEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "SaleDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SALE_CREATED",
                "name": "Sale Created"
              },
              {
                "key": "SALE_UPDATED",
                "name": "Sale Updated"
              },
              {
                "key": "SALE_DELETED",
                "name": "Sale Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Sale",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SALE_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Sale",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SALE_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Sale",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "SALE_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SalesPage",
          "path": "/sales",
          "traits": [
            {
              "ref": "SaleAppLayout"
            },
            {
              "ref": "SaleCatalog"
            },
            {
              "ref": "SaleSearch"
            },
            {
              "ref": "SaleFilter"
            },
            {
              "ref": "SaleStats"
            },
            {
              "ref": "SaleGraphs"
            },
            {
              "ref": "SaleBrowseList"
            },
            {
              "ref": "SaleCreate"
            },
            {
              "ref": "SaleEdit"
            },
            {
              "ref": "SaleView"
            },
            {
              "ref": "SaleDelete"
            },
            {
              "ref": "SalePersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "CheckoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-checkout-terminal",
          "as": "CheckoutTerminal"
        }
      ],
      "entity": {
        "name": "CheckoutSession",
        "collection": "checkoutsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "terminalId",
            "type": "string",
            "required": true
          },
          {
            "name": "cashierId",
            "type": "string",
            "default": ""
          },
          {
            "name": "cashierName",
            "type": "string",
            "default": ""
          },
          {
            "name": "cartItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "paymentMethod",
            "type": "string",
            "default": "card",
            "values": [
              "cash",
              "card",
              "gift_card",
              "split"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "paying",
              "completed",
              "voided"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "CheckoutAppLayout",
          "config": {
            "appName": "Retail POS",
            "navItems": [
              {
                "icon": "shopping-bag",
                "label": "Sales",
                "href": "/sales"
              },
              {
                "label": "Checkout",
                "href": "/checkout",
                "icon": "credit-card"
              },
              {
                "icon": "receipt",
                "href": "/receipts",
                "label": "Receipts"
              },
              {
                "href": "/customers",
                "label": "Customers",
                "icon": "users"
              }
            ],
            "notificationClickEvent": "CHECKOUT_NOTIFICATIONS_OPEN",
            "notifications": [],
            "searchEvent": "CHECKOUT_SEARCH",
            "contentTrait": "@trait.CheckoutTerminalBoard"
          },
          "events": {
            "NOTIFY_CLICK": "CHECKOUT_NOTIFICATIONS_OPEN",
            "SEARCH": "CHECKOUT_SEARCH"
          }
        },
        {
          "ref": "CheckoutTerminal.traits.CheckoutSessionTerminal",
          "name": "CheckoutTerminalBoard",
          "config": {
            "title": "Open Terminals"
          }
        }
      ],
      "pages": [
        {
          "name": "CheckoutPage",
          "path": "/checkout",
          "traits": [
            {
              "ref": "CheckoutAppLayout"
            },
            {
              "ref": "CheckoutTerminalBoard"
            }
          ]
        }
      ]
    },
    {
      "name": "ReceiptOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-receipt",
          "as": "Receipt"
        }
      ],
      "entity": {
        "name": "Receipt",
        "collection": "receipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientName",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientEmail",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionId",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionType",
            "type": "string",
            "default": "purchase",
            "values": [
              "purchase",
              "refund",
              "donation",
              "service"
            ]
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lineItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "issuedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ReceiptAppLayout",
          "config": {
