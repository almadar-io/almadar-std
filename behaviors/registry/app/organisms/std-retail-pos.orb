      ]
    },
    {
      "name": "CustomerOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-customer-account",
          "as": "CustomerAccount"
        }
      ],
      "entity": {
        "name": "CustomerAccount",
        "collection": "customeraccounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "loyaltyPoints",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "storeCreditAmount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalSpent",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "joinedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastVisitAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "banned"
            ]
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "CustomerAppLayout",
          "config": {
            "notifications": [],
            "contentTrait": "@trait.CustomerDirectory",
            "appName": "Retail POS",
            "searchEvent": "CUSTOMER_SEARCH",
            "notificationClickEvent": "CUSTOMER_NOTIFICATIONS_OPEN",
            "navItems": [
              {
                "href": "/sales",
                "icon": "shopping-bag",
                "label": "Sales"
              },
              {
                "label": "Checkout",
                "icon": "credit-card",
                "href": "/checkout"
              },
              {
                "icon": "receipt",
                "href": "/receipts",
                "label": "Receipts"
              },
              {
                "icon": "users",
                "label": "Customers",
                "href": "/customers"
              }
            ]
          },
          "events": {
            "SEARCH": "CUSTOMER_SEARCH",
            "NOTIFY_CLICK": "CUSTOMER_NOTIFICATIONS_OPEN"
          }
        },
        {
