                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "error",
                          "message": "This action cannot be undone.",
                          "type": "alert"
                        },
                        {
                          "justify": "end",
                          "type": "stack",
