              {
                "key": "DEAL_CREATED",
                "name": "Deal Created"
              },
              {
                "key": "DealLoadFailed",
                "name": "Deal load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
