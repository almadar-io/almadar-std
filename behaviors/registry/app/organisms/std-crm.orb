{
  "name": "std-crm",
  "version": "2.0.0",
  "description": "CRM: contacts, deals, sales pipelines, and notes. Pick for B2B sales tracking.",
  "orbitals": [
    {
      "name": "ContactOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-email",
          "as": "Email"
        }
      ],
      "entity": {
        "name": "Contact",
        "collection": "contacts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "company",
            "type": "string",
            "default": ""
          },
          {
            "name": "industry",
            "type": "string",
            "default": ""
          },
          {
            "name": "lifecycleStage",
            "type": "string",
            "default": "lead",
            "values": [
              "lead",
              "mql",
              "sql",
              "customer"
            ]
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ContactAppLayout",
          "config": {
            "contentTrait": "@trait.ContactCatalog",
            "searchEvent": "CONTACT_SEARCH",
            "notificationClickEvent": "CONTACT_NOTIFICATIONS_OPEN",
            "notifications": [],
            "navItems": [
              {
                "label": "Contacts",
                "icon": "users",
                "href": "/contacts"
              },
              {
                "href": "/deals",
                "icon": "briefcase",
                "label": "Deals"
              },
              {
                "label": "Pipeline",
                "icon": "bar-chart-2",
                "href": "/pipeline"
              },
              {
                "href": "/notes",
                "icon": "file-text",
                "label": "Notes"
              }
            ],
            "appName": "CRM"
          },
          "events": {
            "NOTIFY_CLICK": "CONTACT_NOTIFICATIONS_OPEN",
            "SEARCH": "CONTACT_SEARCH"
          }
        },
        {
          "name": "ContactCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CONTACT_SEARCH",
              "triggers": "CONTACT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ContactAppLayout"
              }
            },
            {
              "event": "CONTACT_NOTIFICATIONS_OPEN",
              "triggers": "CONTACT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ContactAppLayout"
              }
            },
            {
              "event": "ContactEmailSent",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactEmailSend"
              }
            },
            {
              "event": "ContactEmailFailed",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactEmailSend"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CONTACT_SEARCH",
                "name": "Contact Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONTACT_NOTIFICATIONS_OPEN",
                "name": "Contact Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "user",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Contacts"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "icon": "plus",
                                  "type": "button",
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "label": "New Contact"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            "@trait.ContactSearch",
                            "@trait.ContactFilter"
                          ],
                          "direction": "horizontal"
                        },
                        "@trait.ContactStats",
                        "@trait.ContactGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.ContactBrowseList"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CONTACT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CONTACT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-8",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "No notifications"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "You're all caught up."
                        },
                        {
                          "variant": "ghost",
                          "type": "button",
                          "label": "Back to contacts",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ContactSearch",
          "config": {
            "event": "CONTACT_SEARCH",
            "placeholder": "Search contacts…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "ContactFilter",
          "config": {
            "event": "CONTACT_FILTER",
            "filters": [
              {
                "filterType": "select",
                "field": "industry",
                "options": [
                  "technology",
                  "finance",
                  "healthcare",
                  "retail",
                  "manufacturing",
                  "other"
                ],
                "label": "Industry"
              },
              {
                "options": [
                  "lead",
                  "mql",
                  "sql",
                  "customer"
                ],
                "field": "lifecycleStage",
                "label": "Lifecycle Stage",
                "filterType": "select"
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "ContactStats",
          "config": {
            "title": "Contacts",
            "metrics": [
              {
                "label": "Total",
                "icon": "users",
                "aggregation": "count",
                "variant": "primary",
                "format": "number"
              },
              {
                "aggregation": "count",
                "variant": "warning",
                "format": "number",
                "label": "Hot Leads",
                "icon": "flame",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.lifecycleStage",
                    "sql"
                  ]
                ]
              },
              {
                "icon": "check-circle",
                "aggregation": "count",
                "variant": "success",
                "label": "Customers",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.lifecycleStage",
                    "customer"
                  ]
                ]
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "ContactGraphs",
          "config": {
            "aggregation": "count",
            "subtitle": "Funnel breakdown",
            "categoryField": "lifecycleStage",
            "chartType": "pie",
            "showLegend": true,
            "height": 240.0,
            "title": "Contacts by Lifecycle Stage"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ContactBrowseList",
          "linkedEntity": "Contact",
          "config": {
            "variant": "card",
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "label": "Edit",
                "variant": "ghost",
                "event": "EDIT"
              },
              {
                "variant": "danger",
                "event": "DELETE",
                "label": "Delete"
              }
            ],
            "cols": 1.0,
            "fields": [
              {
                "name": "name",
                "variant": "h3",
                "icon": "user"
              },
              {
                "name": "industry",
                "variant": "badge"
              },
              {
                "name": "lifecycleStage",
                "variant": "badge"
              },
              {
                "variant": "caption",
                "name": "email"
              },
              {
                "variant": "caption",
                "name": "phone"
              }
            ],
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "ContactSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "ContactFilter"
              }
            },
            {
              "event": "CONTACT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              }
            },
            {
              "event": "CONTACT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              }
            },
            {
              "event": "CONTACT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ContactPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ContactCreate",
          "linkedEntity": "Contact",
          "config": {
            "fields": [
              "name",
              "company",
              "industry",
              "lifecycleStage",
              "email",
              "phone"
            ],
            "title": "New Contact",
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ContactCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ContactEdit",
          "linkedEntity": "Contact",
          "config": {
            "icon": "edit",
            "mode": "edit",
            "title": "Edit Contact",
            "fields": [
              "name",
              "company",
              "industry",
              "lifecycleStage",
              "email",
              "phone"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ContactView",
          "linkedEntity": "Contact",
          "config": {
            "mode": "edit",
            "icon": "eye",
            "fields": [
              "name",
              "company",
              "industry",
              "lifecycleStage",
              "email",
              "phone"
            ],
            "title": "View Contact"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ContactDelete",
          "linkedEntity": "Contact",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Contact",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ContactBrowseList"
              }
            }
          ]
        },
        {
          "name": "ContactPersistor",
          "category": "lifecycle",
          "linkedEntity": "Contact",
          "emits": [
            {
              "event": "CONTACT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CONTACT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CONTACT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ContactCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ContactEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ContactDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONTACT_CREATED",
                "name": "Contact Created"
              },
              {
                "key": "CONTACT_UPDATED",
                "name": "Contact Updated"
              },
              {
                "key": "CONTACT_DELETED",
                "name": "Contact Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Contact",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CONTACT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Contact",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CONTACT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Contact",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "CONTACT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ContactEmailSend",
          "category": "interaction",
          "emits": [
            {
              "event": "ContactEmailSent",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ContactEmailFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_EMAIL",
                "name": "Send Email",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ContactEmailSent",
                "name": "Contact email sent",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ContactEmailFailed",
                "name": "Contact email failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "sm",
                      "children": [
                        {
                          "icon": "mail",
                          "label": "Email Contact",
                          "type": "button",
                          "action": "SEND_EMAIL",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "horizontal"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "SEND_EMAIL",
                "effects": [
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "subject": "Hello from CRM",
                      "recipient": "contact@example.com",
                      "sender": "noreply@crm.example",
                      "body": "Reaching out from your account team."
                    },
                    {
                      "emit": {
                        "failure": "ContactEmailFailed",
                        "success": "ContactEmailSent"
                      }
                    }
                  ],
                  [
                    "notify",
                    "info",
                    "Email sent"
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ContactsPage",
          "path": "/contacts",
          "traits": [
            {
              "ref": "ContactAppLayout"
            },
            {
              "ref": "ContactCatalog"
            },
            {
              "ref": "ContactSearch"
            },
            {
              "ref": "ContactFilter"
            },
            {
              "ref": "ContactStats"
            },
            {
              "ref": "ContactGraphs"
            },
            {
              "ref": "ContactBrowseList"
            },
            {
              "ref": "ContactCreate"
            },
            {
              "ref": "ContactEdit"
            },
            {
              "ref": "ContactView"
            },
            {
              "ref": "ContactDelete"
            },
            {
              "ref": "ContactPersistor"
            },
            {
              "ref": "ContactEmailSend"
            }
          ]
        }
      ]
    },
    {
      "name": "DealOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Deal",
        "collection": "deals",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "contactId",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "stage",
            "type": "string",
            "default": "prospecting",
            "values": [
              "prospecting",
              "qualified",
              "proposal",
              "negotiation",
              "won",
              "lost"
            ]
          },
          {
            "name": "closedAt",
