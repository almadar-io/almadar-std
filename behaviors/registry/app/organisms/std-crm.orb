                              "type": "typography",
                              "content": "@entity.subject",
                              "variant": "body"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Body",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.body"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Author"
                            },
                            {
                              "content": "@entity.author",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Created At",
                              "type": "typography"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.createdAt"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "justify": "end",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "variant": "ghost",
                              "label": "Close",
                              "action": "CLOSE"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Notes",
          "path": "/notes",
          "traits": [
            {
              "ref": "NoteBrowse"
            },
            {
              "ref": "NoteCompose"
            },
            {
              "ref": "NoteView"
            }
          ]
        }
      ]
    }
  ]
}
