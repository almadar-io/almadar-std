                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Deal",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "DealSaved",
                        "failure": "DealSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "DEAL_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
