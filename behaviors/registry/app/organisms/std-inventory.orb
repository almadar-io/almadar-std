{
  "name": "std-inventory",
  "version": "1.0.0",
  "description": "Inventory: SKU catalog, multi-location stock levels, warehouse management, reorder rules, and adjustment history. Pick for ops/supply-chain apps.",
  "orbitals": [
    {
      "name": "InventoryItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stock-adjustment",
          "as": "StockAdjustment"
        },
        {
          "from": "std/behaviors/std-stock-level",
          "as": "StockLevel"
        },
        {
          "from": "std/behaviors/std-warehouse",
          "as": "Warehouse"
        },
        {
          "from": "std/behaviors/std-reorder-rule",
          "as": "ReorderRule"
        }
      ],
      "entity": {
        "name": "InventoryItem",
        "collection": "inventoryitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "category",
            "type": "string",
            "default": ""
          },
          {
            "name": "defaultUnitCost",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "discontinued",
              "draft"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "InventoryAppLayout",
          "config": {
            "appName": "Inventory Management",
            "notifications": [],
            "navItems": [
              {
                "icon": "package",
                "href": "/inventory",
                "label": "Items"
              },
              {
                "label": "Stock Levels",
                "href": "/stock-levels",
                "icon": "package"
              },
              {
                "label": "Warehouses",
                "icon": "warehouse",
                "href": "/warehouses"
              },
              {
                "href": "/reorder-rules",
                "icon": "refresh-ccw",
                "label": "Reorder Rules"
              },
              {
                "href": "/adjustments",
                "label": "Adjustments",
                "icon": "edit"
              }
            ],
            "notificationClickEvent": "INVENTORY_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.InventoryCatalog",
            "searchEvent": "INVENTORY_SEARCH"
          },
          "events": {
            "SEARCH": "INVENTORY_SEARCH",
            "NOTIFY_CLICK": "INVENTORY_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "InventoryCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "INVENTORY_SEARCH",
              "triggers": "INVENTORY_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "InventoryAppLayout"
              }
            },
            {
              "event": "INVENTORY_NOTIFICATIONS_OPEN",
              "triggers": "INVENTORY_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "InventoryAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "INVENTORY_SEARCH",
                "name": "Inventory Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INVENTORY_NOTIFICATIONS_OPEN",
                "name": "Inventory Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "package",
                                  "type": "icon"
                                },
                                {
                                  "content": "Inventory Items",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "icon": "plus",
                                  "action": "CREATE",
                                  "label": "New Item",
                                  "variant": "primary",
                                  "type": "button"
                                }
                              ],
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "gap": "md",
                          "children": [
                            "@trait.InventorySearch",
                            "@trait.InventoryFilter"
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        "@trait.InventoryStats",
                        "@trait.InventoryGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.InventoryBrowseList"
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "INVENTORY_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "INVENTORY_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-8",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "You're all caught up.",
                          "type": "typography"
                        },
                        {
                          "variant": "ghost",
                          "label": "Back to inventory",
                          "type": "button",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "InventorySearch",
          "config": {
            "event": "INVENTORY_SEARCH",
            "placeholder": "Search SKUs, names, categories…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "InventoryFilter",
          "config": {
            "filters": [
              {
                "field": "status",
                "options": [
                  "active",
                  "discontinued",
                  "draft"
                ],
                "filterType": "select",
                "label": "Status"
              }
            ],
            "event": "INVENTORY_FILTER"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "InventoryStats",
          "config": {
            "title": "Inventory",
            "metrics": [
              {
                "icon": "package",
                "label": "Total SKUs",
                "aggregation": "count",
                "variant": "primary",
                "format": "number"
              },
              {
                "variant": "success",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ],
                "icon": "check-circle",
                "label": "Active",
                "format": "number",
                "aggregation": "count"
              },
              {
                "aggregation": "count",
                "icon": "circle-off",
                "variant": "warning",
                "format": "number",
                "label": "Discontinued",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "discontinued"
                  ]
                ]
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "InventoryBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "InventoryGraphs",
          "config": {
            "categoryField": "category",
            "aggregation": "count",
            "height": 240.0,
            "subtitle": "SKU distribution across categories",
            "title": "Items by Category",
            "chartType": "bar",
            "showLegend": false
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "InventoryBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "InventoryBrowseList",
          "linkedEntity": "InventoryItem",
          "config": {
            "fields": [
              {
                "name": "sku",
                "variant": "h4",
                "icon": "tag"
              },
              {
                "variant": "body",
                "name": "name"
              },
              {
                "name": "category",
                "variant": "caption"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "name": "defaultUnitCost",
                "variant": "caption"
              }
            ],
            "itemActions": [
              {
                "label": "View",
                "variant": "ghost",
                "event": "VIEW"
              },
              {
                "event": "EDIT",
                "label": "Edit",
                "variant": "ghost"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "cols": 1.0,
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "InventorySearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "InventoryFilter"
              }
            },
            {
              "event": "INVENTORY_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryPersistor"
              }
            },
            {
              "event": "INVENTORY_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryPersistor"
              }
            },
            {
              "event": "INVENTORY_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InventoryCreate",
          "linkedEntity": "InventoryItem",
          "config": {
            "mode": "create",
            "icon": "plus-circle",
            "title": "New Item",
            "fields": [
              "sku",
              "name",
              "category",
              "defaultUnitCost",
              "status"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "InventoryCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InventoryEdit",
          "linkedEntity": "InventoryItem",
          "config": {
            "fields": [
              "sku",
              "name",
              "category",
              "defaultUnitCost",
              "status"
            ],
            "icon": "edit",
            "title": "Edit Item",
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "InventoryBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InventoryView",
          "linkedEntity": "InventoryItem",
          "config": {
            "mode": "edit",
            "title": "View Item",
            "fields": [
              "sku",
              "name",
              "category",
              "defaultUnitCost",
              "status"
            ],
            "icon": "eye"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "InventoryBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "InventoryDelete",
          "linkedEntity": "InventoryItem",
          "config": {
            "icon": "alert-triangle",
            "alertMessage": "This action cannot be undone.",
            "title": "Delete Item",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "InventoryBrowseList"
              }
            }
          ]
        },
        {
          "name": "InventoryPersistor",
          "category": "lifecycle",
          "linkedEntity": "InventoryItem",
          "emits": [
            {
              "event": "INVENTORY_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "INVENTORY_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "INVENTORY_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "InventoryCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "InventoryEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "InventoryDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INVENTORY_CREATED",
                "name": "Inventory Created"
              },
              {
                "key": "INVENTORY_UPDATED",
                "name": "Inventory Updated"
              },
              {
                "key": "INVENTORY_DELETED",
                "name": "Inventory Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "InventoryItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "INVENTORY_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "InventoryItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "INVENTORY_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "InventoryItem",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "INVENTORY_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InventoryPage",
          "path": "/inventory",
          "traits": [
            {
              "ref": "InventoryAppLayout"
            },
            {
              "ref": "InventoryCatalog"
            },
            {
              "ref": "InventorySearch"
            },
            {
              "ref": "InventoryFilter"
            },
            {
              "ref": "InventoryStats"
            },
            {
              "ref": "InventoryGraphs"
            },
            {
              "ref": "InventoryBrowseList"
            },
            {
              "ref": "InventoryCreate"
            },
            {
              "ref": "InventoryEdit"
            },
            {
              "ref": "InventoryView"
            },
            {
              "ref": "InventoryDelete"
            },
            {
              "ref": "InventoryPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "StockLevelPanelOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-stock-level",
          "as": "StockLevel"
        }
      ],
      "entity": {
        "name": "StockLevel",
        "collection": "stocklevels",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "required": true
          },
          {
            "name": "productName",
            "type": "string",
            "default": ""
          },
          {
            "name": "locationId",
            "type": "string",
            "default": ""
          },
          {
            "name": "onHand",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reserved",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reorderPoint",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lastCounted",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "StockLevelAppLayout",
          "config": {
            "contentTrait": "@trait.StockLevelPanel",
            "appName": "Inventory Management",
            "notificationClickEvent": "STOCK_LEVEL_NOTIFICATIONS_OPEN",
            "navItems": [
              {
                "href": "/inventory",
                "icon": "package",
                "label": "Items"
              },
              {
                "label": "Stock Levels",
                "icon": "package",
                "href": "/stock-levels"
              },
              {
                "href": "/warehouses",
                "label": "Warehouses",
                "icon": "warehouse"
              },
              {
                "icon": "refresh-ccw",
                "label": "Reorder Rules",
                "href": "/reorder-rules"
              },
              {
                "icon": "edit",
                "label": "Adjustments",
                "href": "/adjustments"
              }
            ],
            "searchEvent": "STOCK_LEVEL_SEARCH",
            "notifications": []
          },
          "events": {
            "SEARCH": "STOCK_LEVEL_SEARCH",
            "NOTIFY_CLICK": "STOCK_LEVEL_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "StockLevelPanel",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "package"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Stock Levels"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.StockLevelView"
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "StockLevel.traits.StockLevelLedger",
          "name": "StockLevelView",
          "config": {
            "title": "Stock Levels"
          }
        }
      ],
      "pages": [
        {
          "name": "StockLevelsPage",
          "path": "/stock-levels",
          "traits": [
            {
              "ref": "StockLevelAppLayout"
            },
            {
              "ref": "StockLevelPanel"
            },
            {
              "ref": "StockLevelView"
            }
          ]
