              }
            },
            {
              "event": "ORDER_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "OrderPersistor"
              }
            },
            {
              "event": "ORDER_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "OrderPersistor"
              }
