{
  "name": "std-marketplace",
  "version": "1.0.0",
  "description": "Marketplace: vendors list products, buyers leave star ratings, admin reviews flagged listings.",
  "orbitals": [
    {
      "name": "VendorOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-payout-ledger",
          "as": "Payout"
        }
      ],
      "entity": {
        "name": "Vendor",
        "collection": "vendors",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "businessName",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "active",
              "pending",
              "suspended",
              "closed"
            ]
          },
          {
            "name": "totalSales",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "rating",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "VendorAppLayout",
          "config": {
            "contentTrait": "@trait.VendorCatalog",
            "notificationClickEvent": "VENDOR_NOTIFICATIONS_OPEN",
            "searchEvent": "VENDOR_SEARCH",
            "notifications": [],
            "navItems": [
              {
                "label": "Vendors",
                "href": "/vendors",
                "icon": "store"
              },
              {
                "href": "/listings",
                "label": "Listings",
                "icon": "package"
              },
              {
                "label": "Orders",
                "icon": "shopping-cart",
                "href": "/orders"
              }
            ],
            "appName": "Marketplace"
          },
          "events": {
            "SEARCH": "VENDOR_SEARCH",
            "NOTIFY_CLICK": "VENDOR_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "VendorCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "VENDOR_SEARCH",
              "triggers": "VENDOR_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "VendorAppLayout"
              }
            },
            {
              "event": "VENDOR_NOTIFICATIONS_OPEN",
              "triggers": "VENDOR_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "VendorAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VENDOR_SEARCH",
                "name": "Vendor Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VENDOR_NOTIFICATIONS_OPEN",
                "name": "Vendor Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "store",
                                  "type": "icon"
                                },
                                {
                                  "content": "Vendors",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "action": "CREATE",
                                  "type": "button",
                                  "icon": "plus",
                                  "variant": "primary",
                                  "label": "New Vendor"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.VendorBrowseList",
                        {
                          "type": "divider"
                        },
                        "@trait.VendorPayoutLedger"
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "VENDOR_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "VENDOR_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "content": "You're all caught up.",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "label": "Back to vendors",
                          "type": "button",
                          "action": "INIT",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "VendorBrowseList",
          "linkedEntity": "Vendor",
          "config": {
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              },
              {
                "event": "EDIT",
                "label": "Edit",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ],
            "gap": "sm",
            "cols": 1.0,
            "fields": [
              {
                "icon": "store",
                "name": "name",
                "variant": "h3"
              },
              {
                "variant": "body",
                "name": "businessName"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "format": "currency",
                "name": "totalSales",
                "variant": "caption"
              },
              {
                "name": "rating",
                "variant": "caption"
              }
            ]
          },
          "listens": [
            {
              "event": "VENDOR_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "VendorPersistor"
              }
            },
            {
              "event": "VENDOR_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "VendorPersistor"
              }
            },
            {
              "event": "VENDOR_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "VendorPersistor"
              }
            }
          ]
        },
        {
          "ref": "Payout.traits.PayoutLedger",
          "name": "VendorPayoutLedger",
          "config": {
            "title": "Vendor Payouts",
            "minimumWithdrawal": 50.0
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "VendorCreate",
          "linkedEntity": "Vendor",
          "config": {
            "mode": "create",
            "icon": "plus-circle",
            "title": "New Vendor",
            "fields": [
              "name",
              "businessName",
              "status",
              "totalSales",
              "rating"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "VendorCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "VendorEdit",
          "linkedEntity": "Vendor",
          "config": {
            "fields": [
              "name",
              "businessName",
              "status",
              "totalSales",
              "rating"
            ],
            "title": "Edit Vendor",
            "mode": "edit",
            "icon": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "VendorBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "VendorView",
          "linkedEntity": "Vendor",
          "config": {
            "icon": "eye",
            "fields": [
              "name",
              "businessName",
              "status",
              "totalSales",
              "rating"
            ],
            "mode": "edit",
            "title": "View Vendor"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "VendorBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "VendorDelete",
          "linkedEntity": "Vendor",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "title": "Delete Vendor",
            "icon": "alert-triangle",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "VendorBrowseList"
              }
            }
          ]
        },
        {
          "name": "VendorPersistor",
          "category": "lifecycle",
          "linkedEntity": "Vendor",
          "emits": [
            {
              "event": "VENDOR_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VENDOR_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VENDOR_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "VendorCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "VendorEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "VendorDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VENDOR_CREATED",
                "name": "Vendor Created"
              },
              {
                "key": "VENDOR_UPDATED",
                "name": "Vendor Updated"
              },
              {
                "key": "VENDOR_DELETED",
                "name": "Vendor Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Vendor",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "VENDOR_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Vendor",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "VENDOR_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Vendor",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "VENDOR_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "VendorsPage",
          "path": "/vendors",
          "traits": [
            {
              "ref": "VendorAppLayout"
            },
            {
              "ref": "VendorCatalog"
            },
            {
              "ref": "VendorBrowseList"
            },
            {
              "ref": "VendorPayoutLedger"
            },
            {
              "ref": "VendorCreate"
            },
            {
              "ref": "VendorEdit"
            },
            {
              "ref": "VendorView"
            },
            {
              "ref": "VendorDelete"
            },
            {
              "ref": "VendorPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ListingOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-image-upload-multi",
          "as": "ImageUpload"
        },
        {
          "from": "std/behaviors/std-rating-review",
          "as": "RatingReview"
        },
        {
          "from": "std/behaviors/std-mod-queue",
          "as": "ModQueue"
        },
        {
          "from": "std/behaviors/std-flag",
          "as": "Flag"
        },
        {
          "from": "std/behaviors/std-tag-taxonomy",
          "as": "TagTaxonomy"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Listing",
        "collection": "listings",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vendorId",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "images",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "sold",
              "removed"
            ]
          },
          {
            "name": "tags",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "ratingAverage",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "reviewCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ListingAppLayout",
          "config": {
            "navItems": [
              {
                "label": "Vendors",
                "href": "/vendors",
                "icon": "store"
              },
              {
                "label": "Listings",
                "href": "/listings",
                "icon": "package"
              },
              {
                "icon": "shopping-cart",
                "href": "/orders",
                "label": "Orders"
              }
            ],
            "notificationClickEvent": "LISTING_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.ListingCatalog",
            "searchEvent": "LISTING_SEARCH",
            "notifications": [],
            "appName": "Marketplace"
          },
          "events": {
            "NOTIFY_CLICK": "LISTING_NOTIFICATIONS_OPEN",
            "SEARCH": "LISTING_SEARCH"
          }
        },
        {
          "name": "ListingCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LISTING_SEARCH",
              "triggers": "LISTING_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ListingAppLayout"
              }
            },
            {
              "event": "LISTING_NOTIFICATIONS_OPEN",
              "triggers": "LISTING_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ListingAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LISTING_SEARCH",
                "name": "Listing Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LISTING_NOTIFICATIONS_OPEN",
                "name": "Listing Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "package"
                                },
                                {
                                  "content": "Listings",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "variant": "primary",
                                  "type": "button",
                                  "label": "New Listing",
                                  "icon": "plus",
                                  "action": "CREATE"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            "@trait.ListingSearch",
                            "@trait.ListingFilter"
                          ]
                        },
                        "@trait.ListingStats",
                        "@trait.ListingTags",
                        {
                          "type": "divider"
                        },
                        "@trait.ListingBrowseList",
                        {
                          "type": "divider"
                        },
                        "@trait.ListingImages",
                        {
                          "type": "divider"
                        },
                        "@trait.ListingRating",
                        {
                          "type": "divider"
                        },
                        "@trait.ListingFlag",
                        {
                          "type": "divider"
                        },
                        "@trait.ListingModQueue"
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "LISTING_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "LISTING_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-8",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "variant": "h3",
                          "content": "No notifications",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "You're all caught up.",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "action": "INIT",
                          "label": "Back to listings"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ListingSearch",
          "config": {
            "event": "LISTING_SEARCH",
            "placeholder": "Search listings…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "ListingFilter",
          "config": {
            "event": "LISTING_FILTER",
            "filters": [
              {
                "field": "status",
                "label": "Status",
                "options": [
                  "draft",
                  "active",
                  "sold",
                  "removed"
                ],
                "filterType": "select"
              },
              {
                "label": "Currency",
                "field": "currency",
                "filterType": "select",
                "options": [
                  "USD",
                  "EUR",
                  "GBP"
                ]
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "ListingStats",
          "config": {
            "metrics": [
              {
                "icon": "package",
                "format": "number",
                "label": "Total",
                "aggregation": "count",
                "variant": "primary"
              },
              {
                "aggregation": "count",
                "label": "Active",
                "variant": "success",
                "icon": "check-circle",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ]
              },
              {
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "draft"
                  ]
                ],
                "label": "Draft",
                "icon": "edit",
                "aggregation": "count",
                "variant": "warning"
              }
            ],
            "title": "Listings"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowseList"
              }
            }
          ]
        },
        {
          "ref": "TagTaxonomy.traits.TagBrowse",
          "name": "ListingTags",
          "config": {
            "title": "Categories",
            "allowEdit": false
          }
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ListingBrowseList",
          "linkedEntity": "Listing",
          "config": {
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "variant": "ghost",
                "label": "Edit",
                "event": "EDIT"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ],
            "cols": 1.0,
            "fields": [
              {
                "icon": "package",
                "name": "title",
                "variant": "h3"
              },
              {
                "name": "price",
                "variant": "h4",
                "format": "currency"
              },
              {
                "variant": "badge",
                "name": "currency"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "name": "ratingAverage",
                "variant": "caption"
              },
              {
                "variant": "caption",
                "name": "reviewCount"
              },
              {
                "name": "description",
                "variant": "caption"
              }
            ],
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "ListingSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "ListingFilter"
              }
            },
            {
              "event": "LISTING_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListingPersistor"
              }
            },
            {
              "event": "LISTING_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListingPersistor"
              }
            },
            {
              "event": "LISTING_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListingPersistor"
              }
            }
          ]
        },
        {
          "ref": "ImageUpload.traits.UploadedImageUpload",
          "name": "ListingImages",
          "config": {
            "maxImages": 10.0,
            "maxBytesPerImage": 10485760.0,
            "accept": "image/*",
            "title": "Listing Images"
          }
        },
        {
          "ref": "RatingReview.traits.RatingReviewSubmit",
          "name": "ListingRating",
          "config": {
            "allowComment": true,
            "allowPhotos": false,
            "maxStars": 5.0,
            "title": "Rate this listing",
            "submitEvent": "SUBMIT_REVIEW"
          }
        },
        {
          "ref": "Flag.traits.FlagReport",
          "name": "ListingFlag",
          "config": {
            "reasons": [
              "spam",
              "abuse",
              "off-topic",
              "misinformation",
              "nsfw",
              "other"
            ],
            "title": "Report listing"
          }
        },
        {
          "ref": "ModQueue.traits.ModQueueItemReview",
          "name": "ListingModQueue",
          "config": {
            "autoEscalateThreshold": 5.0,
            "title": "Listing Moderation Queue"
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListingCreate",
          "linkedEntity": "Listing",
          "config": {
            "mode": "create",
            "fields": [
              "vendorId",
              "title",
              "description",
              "price",
              "currency",
              "status"
            ],
            "icon": "plus-circle",
            "title": "New Listing"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListingCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListingEdit",
          "linkedEntity": "Listing",
          "config": {
            "mode": "edit",
            "fields": [
              "vendorId",
              "title",
              "description",
              "price",
              "currency",
              "status"
            ],
            "title": "Edit Listing",
            "icon": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListingView",
          "linkedEntity": "Listing",
          "config": {
            "title": "View Listing",
            "fields": [
              "vendorId",
              "title",
              "description",
              "price",
              "currency",
              "status"
            ],
            "mode": "edit",
            "icon": "eye"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ListingDelete",
          "linkedEntity": "Listing",
          "config": {
            "title": "Delete Listing",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowseList"
              }
            }
          ]
        },
        {
          "name": "ListingPersistor",
          "category": "lifecycle",
          "linkedEntity": "Listing",
          "emits": [
            {
              "event": "LISTING_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LISTING_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LISTING_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListingCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ListingEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListingDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LISTING_CREATED",
                "name": "Listing Created"
              },
              {
                "key": "LISTING_UPDATED",
                "name": "Listing Updated"
              },
              {
                "key": "LISTING_DELETED",
                "name": "Listing Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Listing",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "LISTING_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Listing",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "LISTING_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Listing",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "LISTING_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ListingsPage",
          "path": "/listings",
          "traits": [
            {
              "ref": "ListingAppLayout"
            },
            {
              "ref": "ListingCatalog"
            },
            {
              "ref": "ListingSearch"
            },
            {
              "ref": "ListingFilter"
            },
            {
              "ref": "ListingStats"
            },
            {
              "ref": "ListingTags"
            },
            {
              "ref": "ListingBrowseList"
            },
            {
              "ref": "ListingImages"
            },
            {
              "ref": "ListingRating"
            },
            {
              "ref": "ListingFlag"
            },
            {
              "ref": "ListingModQueue"
            },
            {
              "ref": "ListingCreate"
            },
            {
              "ref": "ListingEdit"
            },
            {
              "ref": "ListingView"
            },
            {
              "ref": "ListingDelete"
            },
            {
              "ref": "ListingPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "OrderOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-cart",
          "as": "Cart"
        }
      ],
      "entity": {
        "name": "Order",
        "collection": "orders",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "buyerId",
            "type": "string",
            "required": true
          },
          {
            "name": "listingId",
            "type": "string",
            "required": true
          },
          {
            "name": "quantity",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "totalAmount",
            "type": "number",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "paid",
              "shipped",
              "delivered",
              "refunded"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "OrderAppLayout",
          "config": {
            "notifications": [],
            "notificationClickEvent": "ORDER_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.OrderCatalog",
            "searchEvent": "ORDER_SEARCH",
            "appName": "Marketplace",
            "navItems": [
              {
                "label": "Vendors",
                "href": "/vendors",
                "icon": "store"
              },
              {
                "label": "Listings",
                "icon": "package",
                "href": "/listings"
              },
              {
                "label": "Orders",
                "href": "/orders",
                "icon": "shopping-cart"
              }
            ]
          },
          "events": {
            "NOTIFY_CLICK": "ORDER_NOTIFICATIONS_OPEN",
            "SEARCH": "ORDER_SEARCH"
          }
        },
        {
          "name": "OrderCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ORDER_SEARCH",
              "triggers": "ORDER_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "OrderAppLayout"
              }
            },
            {
              "event": "ORDER_NOTIFICATIONS_OPEN",
              "triggers": "ORDER_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "OrderAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ORDER_SEARCH",
                "name": "Order Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ORDER_NOTIFICATIONS_OPEN",
                "name": "Order Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "shopping-cart",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Orders"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "icon": "plus",
                                  "action": "CREATE",
                                  "type": "button",
                                  "label": "New Order",
                                  "variant": "primary"
                                }
                              ],
                              "type": "stack",
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.OrderBrowseList",
                        {
                          "type": "divider"
                        },
                        "@trait.OrderCart"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "ORDER_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "ORDER_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "No notifications"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "You're all caught up.",
                          "variant": "caption"
                        },
                        {
                          "type": "button",
                          "label": "Back to orders",
                          "action": "INIT",
                          "variant": "ghost"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "OrderBrowseList",
          "linkedEntity": "Order",
          "config": {
            "gap": "sm",
            "fields": [
              {
                "variant": "caption",
                "name": "buyerId"
              },
              {
                "variant": "caption",
                "name": "listingId"
              },
              {
                "name": "quantity",
                "variant": "caption"
              },
              {
                "name": "totalAmount",
                "variant": "h4",
                "format": "currency"
              },
              {
                "name": "status",
                "variant": "badge"
              }
            ],
            "cols": 1.0,
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "event": "DELETE",
                "variant": "danger",
                "label": "Delete"
              }
            ]
          },
          "listens": [
            {
              "event": "ORDER_CREATED",
