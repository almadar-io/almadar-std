            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "OrderBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "OrderDelete",
          "linkedEntity": "Order",
          "config": {
            "title": "Delete Order",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "OrderBrowseList"
              }
            }
          ]
        },
        {
          "name": "OrderPersistor",
          "category": "lifecycle",
          "linkedEntity": "Order",
          "emits": [
            {
              "event": "ORDER_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ORDER_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ORDER_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "OrderCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "OrderEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "OrderDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ORDER_CREATED",
                "name": "Order Created"
              },
              {
                "key": "ORDER_UPDATED",
                "name": "Order Updated"
              },
              {
                "key": "ORDER_DELETED",
                "name": "Order Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Order",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ORDER_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ORDER_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Order",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ORDER_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "OrdersPage",
          "path": "/orders",
          "traits": [
            {
              "ref": "OrderAppLayout"
            },
            {
              "ref": "OrderCatalog"
            },
            {
              "ref": "OrderBrowseList"
            },
            {
              "ref": "OrderCart"
            },
            {
              "ref": "OrderCartAdd"
            },
            {
              "ref": "OrderCartRemove"
            },
            {
              "ref": "OrderCartPersistor"
            },
            {
              "ref": "OrderCreate"
            },
            {
              "ref": "OrderEdit"
            },
            {
              "ref": "OrderView"
            },
            {
              "ref": "OrderDelete"
            },
            {
              "ref": "OrderPersistor"
            }
          ]
        }
      ]
    }
  ]
}
