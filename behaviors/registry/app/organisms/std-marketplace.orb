        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "OrderView",
          "linkedEntity": "Order",
          "config": {
            "fields": [
              "buyerId",
              "listingId",
              "quantity",
              "totalAmount",
              "status"
            ],
