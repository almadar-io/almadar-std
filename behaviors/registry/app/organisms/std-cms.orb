{
  "name": "std-cms",
  "version": "2.0.0",
  "description": "CMS: articles, media assets, categories. Pick for editorial/publishing platforms.",
  "orbitals": [
    {
      "name": "ArticleOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-storage",
          "as": "Storage"
        }
      ],
      "entity": {
        "name": "Article",
        "collection": "articles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "author",
            "type": "string"
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "review",
              "published",
              "archived"
            ]
          },
          {
            "name": "publishedAt",
            "type": "datetime"
          },
          {
            "name": "heroImage",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ArticleAppLayout",
          "config": {
            "notifications": [],
            "navItems": [
              {
                "label": "CMS Hub",
                "icon": "layout-grid",
                "href": "/cms-hub"
              },
              {
                "label": "Articles",
                "icon": "file-text",
                "href": "/articles"
              },
              {
                "label": "Media",
                "icon": "image",
                "href": "/media"
              },
              {
                "href": "/categories",
                "icon": "folder",
                "label": "Categories"
              }
            ],
            "notificationClickEvent": "ARTICLE_NOTIFICATIONS_OPEN",
            "appName": "CmsApp",
            "searchEvent": "ARTICLE_SEARCH",
            "contentTrait": "@trait.ArticleCatalog"
          },
          "events": {
            "NOTIFY_CLICK": "ARTICLE_NOTIFICATIONS_OPEN",
            "SEARCH": "ARTICLE_SEARCH"
          }
        },
        {
          "name": "ArticleCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ARTICLE_SEARCH",
              "triggers": "ARTICLE_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ArticleAppLayout"
              }
            },
            {
              "event": "ARTICLE_NOTIFICATIONS_OPEN",
              "triggers": "ARTICLE_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ArticleAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ARTICLE_SEARCH",
                "name": "Article Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ARTICLE_NOTIFICATIONS_OPEN",
                "name": "Article Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-text"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Articles"
                                }
                              ],
                              "gap": "sm"
                            },
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "icon": "plus",
                                  "label": "Create Article",
                                  "action": "CREATE",
                                  "type": "button",
                                  "variant": "primary"
                                }
                              ]
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            "@trait.ArticleSearch",
                            "@trait.ArticleFilter"
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        "@trait.ArticleStats",
                        "@trait.ArticleGraphs",
                        "@trait.ArticleBrowseList"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "ARTICLE_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "ARTICLE_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "No notifications"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "You're all caught up."
                        },
                        {
                          "label": "Back to articles",
                          "action": "INIT",
                          "variant": "ghost",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-8"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ArticleBrowseList",
          "linkedEntity": "Article",
          "config": {
            "imageField": "heroImage",
            "fields": [
              {
                "icon": "file-text",
                "variant": "h3",
                "name": "title"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "name": "author",
                "variant": "caption"
              },
              {
                "name": "category",
                "variant": "badge"
              },
              {
                "name": "publishedAt",
                "variant": "caption"
              }
            ],
            "itemActions": [
              {
                "event": "VIEW",
                "variant": "ghost",
                "label": "View"
              },
              {
                "label": "Edit",
                "event": "EDIT",
                "variant": "ghost"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "gap": "sm",
            "cols": 1.0,
            "variant": "card"
          },
          "listens": [
            {
              "event": "ARTICLE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticlePersistor"
              }
            },
            {
              "event": "ARTICLE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticlePersistor"
              }
            },
            {
              "event": "ARTICLE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticlePersistor"
              }
            }
          ]
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ArticleSearch",
          "config": {
            "placeholder": "Search articles...",
            "searchEvent": "ARTICLE_SEARCH"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "ArticleFilter",
          "config": {
            "facets": [
              {
                "label": "Status",
                "field": "status",
                "values": [
                  "draft",
                  "published",
                  "archived"
                ]
              },
              {
                "values": [],
                "label": "Category",
                "field": "category"
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "ArticleStats",
          "config": {
            "metrics": [
              {
                "label": "Total",
                "aggregation": "count"
              },
              {
                "aggregation": "count",
                "label": "Published",
                "filter": {
                  "status": "published"
                }
              },
              {
                "aggregation": "count",
                "filter": {
                  "status": "draft"
                },
                "label": "Drafts"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ArticleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "ArticleGraphs",
          "config": {
            "categoryField": "status",
            "title": "Articles by Status",
            "chartType": "pie"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ArticleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ArticleCreate",
          "linkedEntity": "Article",
          "config": {
            "fields": [
              "title",
              "slug",
              "content",
              "author",
              "category",
              "status",
              "publishedAt",
              "heroImage"
            ],
            "mode": "create",
            "icon": "plus-circle",
            "title": "Create Article"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ArticleCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ArticleEdit",
          "linkedEntity": "Article",
          "config": {
            "mode": "edit",
            "icon": "edit",
            "title": "Edit Article",
            "fields": [
              "title",
              "slug",
              "content",
              "author",
              "category",
              "status",
              "publishedAt",
              "heroImage"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ArticleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ArticleView",
          "linkedEntity": "Article",
          "config": {
            "fields": [
              "title",
              "slug",
              "content",
              "author",
              "category",
              "status",
              "publishedAt",
              "heroImage"
            ],
            "title": "View Article",
            "icon": "eye",
            "mode": "view"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ArticleBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ArticleDelete",
          "linkedEntity": "Article",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "confirmLabel": "Delete",
            "title": "Delete Article"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ArticleBrowseList"
              }
            }
          ]
        },
        {
          "name": "ArticleHeroImageUpload",
          "category": "interaction",
          "emits": [
            {
              "event": "ArticleHeroUploaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "url",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleHeroUploadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UPLOAD",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                },
                {
                  "name": "file",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  },
                  {
                    "name": "file",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ArticleHeroUploaded",
                "name": "Article hero uploaded"
              },
              {
                "key": "ArticleHeroUploadFailed",
                "name": "Article hero upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "placeholder": "Paste hero image URL...",
                          "type": "input",
                          "inputType": "text"
                        },
                        {
                          "action": "UPLOAD",
                          "type": "button",
                          "variant": "secondary",
                          "icon": "upload",
                          "label": "Upload Hero"
                        }
                      ],
                      "gap": "sm",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "UPLOAD",
                "effects": [
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "file": "@payload.file",
                      "bucket": "articles",
                      "acl": "public"
                    },
                    {
                      "emit": {
                        "success": "ArticleHeroUploaded",
                        "failure": "ArticleHeroUploadFailed"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ArticlePersistor",
          "category": "lifecycle",
          "linkedEntity": "Article",
          "emits": [
            {
              "event": "ARTICLE_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARTICLE_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARTICLE_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ArticleCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ArticleEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ArticleDelete"
              }
            },
            {
              "event": "ArticleHeroUploaded",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticleHeroImageUpload"
              }
            },
            {
              "event": "ArticleHeroUploadFailed",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ArticleHeroImageUpload"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ARTICLE_CREATED",
                "name": "Article Created"
              },
              {
                "key": "ARTICLE_UPDATED",
                "name": "Article Updated"
              },
              {
                "key": "ARTICLE_DELETED",
                "name": "Article Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Article",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ARTICLE_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Article",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ARTICLE_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Article",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ARTICLE_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ArticlesPage",
          "path": "/articles",
          "traits": [
            {
              "ref": "ArticleAppLayout"
            },
            {
              "ref": "ArticleCatalog"
            },
            {
              "ref": "ArticleBrowseList"
            },
            {
              "ref": "ArticleSearch"
            },
            {
              "ref": "ArticleFilter"
            },
            {
              "ref": "ArticleStats"
            },
            {
              "ref": "ArticleGraphs"
            },
            {
              "ref": "ArticleHeroImageUpload"
            },
            {
              "ref": "ArticleCreate"
            },
            {
              "ref": "ArticleEdit"
            },
            {
              "ref": "ArticleView"
            },
            {
              "ref": "ArticleDelete"
            },
            {
              "ref": "ArticlePersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "MediaAssetOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-gallery",
          "as": "Gallery"
        },
        {
          "from": "std/behaviors/std-service-storage",
          "as": "Storage"
        }
      ],
      "entity": {
        "name": "MediaAsset",
        "collection": "mediaassets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "altText",
            "type": "string"
          },
          {
            "name": "type",
            "type": "string"
          },
          {
            "name": "url",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "MediaAssetAppLayout",
          "linkedEntity": "MediaAsset",
          "config": {
            "navItems": [
              {
                "icon": "layout-grid",
                "label": "CMS Hub",
                "href": "/cms-hub"
              },
              {
                "href": "/articles",
                "label": "Articles",
                "icon": "file-text"
              },
              {
                "href": "/media",
                "label": "Media",
                "icon": "image"
              },
              {
                "icon": "folder",
                "label": "Categories",
                "href": "/categories"
              }
            ],
            "contentTrait": "@trait.MediaCatalog",
            "searchEvent": "MEDIA_SEARCH",
            "notifications": [],
            "notificationClickEvent": "MEDIA_NOTIFICATIONS_OPEN",
            "appName": "CmsApp"
          },
          "events": {
            "SEARCH": "MEDIA_SEARCH",
            "NOTIFY_CLICK": "MEDIA_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "MediaCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "CmsApp",
                      "navItems": [
                        {
                          "icon": "layout-grid",
                          "label": "CMS Hub",
                          "href": "/cms-hub"
                        },
                        {
                          "icon": "file-text",
                          "label": "Articles",
                          "href": "/articles"
                        },
                        {
                          "label": "Media",
                          "href": "/media",
                          "icon": "image"
                        },
                        {
                          "icon": "folder",
                          "label": "Categories",
                          "href": "/categories"
                        }
                      ],
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "justify": "between",
                              "align": "center",
                              "gap": "md",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "image"
                                    },
                                    {
                                      "variant": "h2",
                                      "content": "Media Library",
                                      "type": "typography"
                                    }
                                  ],
                                  "gap": "sm"
                                },
                                {
                                  "children": [
                                    {
                                      "type": "button",
                                      "action": "CREATE",
                                      "variant": "secondary",
                                      "icon": "plus",
                                      "label": "Create MediaAsset"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal"
                                }
                              ]
                            },
                            {
                              "type": "divider"
                            },
                            "@trait.MediaUpload",
                            "@trait.MediaAssetGallery"
                          ],
                          "gap": "lg",
                          "direction": "vertical",
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full"
                        }
                      ],
                      "type": "dashboard-layout"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Gallery.traits.GalleryItemGallery",
          "name": "MediaAssetGallery",
          "linkedEntity": "MediaAsset",
          "config": {
            "imageField": "url",
            "gap": "md",
            "cols": 4.0,
            "titleField": "name"
          },
          "listens": [
            {
              "event": "MEDIA_UPLOADED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "MediaUpload"
              }
            },
            {
              "event": "MEDIA_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "MediaPersistor"
              }
            }
          ]
        },
        {
          "name": "MediaUpload",
          "category": "interaction",
          "emits": [
            {
              "event": "MEDIA_UPLOADED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "url",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StorageUploaded",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "url",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MediaSaved",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MediaUploadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UPLOAD",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                },
                {
                  "name": "file",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "uploading"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  },
                  {
                    "name": "file",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StorageUploaded",
                "name": "Storage uploaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "url",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MediaUploadFailed",
                "name": "Media upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEDIA_UPLOADED",
                "name": "Media Uploaded"
              },
              {
                "key": "MediaSaved",
                "name": "Media saved"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "sm",
                      "children": [
                        {
                          "inputType": "text",
                          "placeholder": "Paste file URL...",
                          "type": "input"
                        },
                        {
                          "action": "UPLOAD",
                          "label": "Upload File",
                          "type": "button",
                          "variant": "primary",
                          "icon": "upload"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "acl": "public",
                      "bucket": "media",
                      "file": "@payload.file"
                    },
                    {
                      "emit": {
                        "failure": "MediaUploadFailed",
                        "success": "StorageUploaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Uploading file to storage.",
                      "type": "loading-state",
                      "title": "Uploading..."
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "idle",
                "event": "StorageUploaded",
                "effects": [
                  [
                    "persist",
                    "create",
                    "MediaAsset",
                    {
                      "url": "@payload.url",
                      "type": "image",
                      "name": "@payload.id"
                    },
                    {
                      "emit": {
                        "success": "MediaSaved",
                        "failure": "MediaUploadFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "MEDIA_UPLOADED",
                    {
                      "url": "@payload.url",
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "sm",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "message": "Upload complete.",
                          "variant": "success"
                        },
                        {
                          "variant": "ghost",
                          "label": "Upload Another",
                          "type": "button",
                          "action": "INIT"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "idle",
                "event": "MediaUploadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "onRetry": "INIT",
                      "type": "error-state",
                      "title": "Upload Failed"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "MediaAssetCreate",
          "linkedEntity": "MediaAsset",
          "config": {
            "title": "Add Media Asset",
            "fields": [
              "name",
              "altText",
              "type",
              "url"
            ],
            "icon": "plus-circle",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "MediaCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "MediaAssetView",
          "linkedEntity": "MediaAsset",
          "config": {
            "icon": "eye",
            "mode": "view",
            "fields": [
              "name",
              "altText",
              "type",
              "url"
            ],
            "title": "View Media Asset"
          },
          "events": {
            "OPEN": "VIEW"
          }
        },
        {
          "name": "MediaPersistor",
          "category": "lifecycle",
          "linkedEntity": "MediaAsset",
          "emits": [
            {
              "event": "MEDIA_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "MediaAssetCreate"
              }
            },
            {
              "event": "MediaSaved",
              "triggers": "MediaSaved",
              "source": {
                "kind": "trait",
                "trait": "MediaUpload"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "MediaSaved",
                "name": "Media saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEDIA_CREATED",
                "name": "Media Created"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "MediaAsset",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "MEDIA_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "MediaSaved"
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MediaPage",
          "path": "/media",
          "traits": [
            {
              "ref": "MediaAssetAppLayout"
            },
            {
              "ref": "MediaCatalog"
            },
            {
              "ref": "MediaAssetGallery"
            },
            {
              "ref": "MediaUpload"
            },
            {
              "ref": "MediaAssetCreate"
            },
            {
              "ref": "MediaAssetView"
            },
            {
              "ref": "MediaPersistor"
            }
          ]
        }
      ]
    },
    {
