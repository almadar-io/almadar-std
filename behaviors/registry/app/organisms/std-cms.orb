                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ArticleLoadFailed",
              "description": "Fired when Article fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
