                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Employee",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "EmployeeUpdated",
                        "failure": "EmployeeUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
