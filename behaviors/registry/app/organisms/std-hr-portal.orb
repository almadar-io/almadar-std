{
  "name": "std-hr-portal",
  "version": "1.0.0",
  "description": "std-hr-portal as a Function",
  "orbitals": [
    {
      "name": "EmployeeOrbital",
      "entity": {
        "name": "Employee",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "default": ""
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "department",
            "type": "string",
            "default": ""
          },
          {
            "name": "role",
            "type": "string",
            "default": ""
          },
          {
            "name": "startDate",
            "type": "datetime",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "EmployeeBrowse",
          "category": "interaction",
          "linkedEntity": "Employee",
          "emits": [
            {
              "event": "ONBOARD",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeLoaded",
              "description": "Fired when Employee finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Employee]"
                }
              ]
            },
            {
              "event": "EmployeeLoadFailed",
              "description": "Fired when Employee fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OnboardingSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OnboardingSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TimeOffSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TimeOffSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TimeOffUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TimeOffUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TimeOffDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TimeOffDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "EMPLOYEE_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EmployeeCreate"
              }
            },
            {
              "event": "EMPLOYEE_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EmployeeEdit"
              }
            },
            {
              "event": "EMPLOYEE_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EmployeeDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EmployeeLoaded",
                "name": "Employee loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Employee]"
                  }
                ]
              },
              {
                "key": "EmployeeLoadFailed",
                "name": "Employee load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ONBOARD",
                "name": "Onboard"
              },
              {
                "key": "EmployeeSaved",
                "name": "Employee saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeSaveFailed",
                "name": "Employee save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeUpdated",
                "name": "Employee updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeUpdateFailed",
                "name": "Employee update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeDeleted",
                "name": "Employee deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeDeleteFailed",
                "name": "Employee delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OnboardingSaved",
                "name": "Onboarding saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OnboardingSaveFailed",
                "name": "Onboarding save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffSaved",
                "name": "Time off saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffSaveFailed",
                "name": "Time off save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffUpdated",
                "name": "Time off updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffUpdateFailed",
                "name": "Time off update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffDeleted",
                "name": "Time off deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffDeleteFailed",
                "name": "Time off delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Employee"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Employee"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Employee"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Employee",
                    {
                      "emit": {
                        "success": "EmployeeLoaded",
                        "failure": "EmployeeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading…",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EmployeeLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "align": "center",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "name": "users",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Employees",
                                      "variant": "h2"
                                    }
                                  ],
                                  "type": "stack",
                                  "gap": "sm"
                                },
                                {
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "icon": "plus",
                                      "type": "button",
                                      "label": "Add Employee",
                                      "action": "CREATE",
                                      "variant": "primary"
                                    }
                                  ]
                                }
                              ],
                              "justify": "between"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "columns": [
                                {
                                  "icon": "user",
                                  "name": "name",
                                  "variant": "h3"
                                },
                                {
                                  "name": "department",
                                  "variant": "badge"
                                },
                                {
                                  "variant": "body",
                                  "name": "role"
                                },
                                {
                                  "variant": "caption",
                                  "name": "email"
                                },
                                {
                                  "name": "startDate",
                                  "format": "date",
                                  "label": "Joined",
                                  "variant": "caption"
                                }
                              ],
                              "fields": [],
                              "type": "data-list",
                              "entity": "@payload.data",
                              "itemActions": [
                                {
                                  "variant": "ghost",
                                  "event": "VIEW",
                                  "label": "View"
                                },
                                {
                                  "variant": "ghost",
                                  "label": "Edit",
                                  "event": "EDIT"
                                },
                                {
                                  "variant": "danger",
                                  "label": "Delete",
                                  "event": "DELETE"
                                }
                              ],
                              "variant": "card",
                              "gap": "sm"
                            }
                          ],
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full"
                        }
                      ],
                      "appName": "HRPortal",
                      "navItems": [
                        {
                          "href": "/employees",
                          "icon": "users",
                          "label": "Employees"
                        },
                        {
                          "icon": "layout-list",
                          "label": "Onboarding",
                          "href": "/onboarding"
                        },
                        {
                          "label": "Time Off",
                          "icon": "calendar",
                          "href": "/timeoff"
                        },
                        {
                          "icon": "layout-list",
                          "label": "Org Chart",
                          "href": "/org-chart"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EmployeeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load employee"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "label": "Retry",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "EmployeeCreate",
          "category": "interaction",
          "linkedEntity": "Employee",
          "emits": [
            {
              "event": "EMPLOYEE_CREATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeLoadFailed",
              "description": "Fired when Employee fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeLoaded",
              "description": "Fired when Employee finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Employee]"
                }
              ]
            },
            {
              "event": "EmployeeSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "EMPLOYEE_CREATED",
                "name": "Employee Created"
              },
              {
                "key": "EmployeeLoadFailed",
                "name": "Employee load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeLoaded",
                "name": "Employee loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Employee]"
                  }
                ]
              },
              {
                "key": "EmployeeSaveFailed",
                "name": "Employee save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeSaved",
                "name": "Employee saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Employee"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Employee",
                    {
                      "emit": {
                        "success": "EmployeeLoaded",
                        "failure": "EmployeeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "type": "typography",
                              "content": "New Employee",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SAVE",
                          "type": "form-section",
                          "fields": [
                            "name",
                            "email",
                            "department",
                            "role",
                            "startDate"
                          ],
                          "mode": "create",
                          "cancelEvent": "CLOSE"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Employee",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "EmployeeSaved",
                        "failure": "EmployeeSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "EMPLOYEE_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "EmployeeEdit",
          "category": "interaction",
          "linkedEntity": "Employee",
          "emits": [
            {
              "event": "EMPLOYEE_UPDATED",
              "scope": "external",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeLoadFailed",
              "description": "Fired when Employee fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeLoaded",
              "description": "Fired when Employee finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Employee]"
                }
              ]
            },
            {
              "event": "EmployeeUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmployeeUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Employee"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "EMPLOYEE_UPDATED",
                "name": "Employee Updated"
              },
              {
                "key": "EmployeeLoadFailed",
                "name": "Employee load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmployeeLoaded",
                "name": "Employee loaded",
                "payload": [
                  {
                    "name": "data",
