                              "variant": "h3",
                              "type": "typography",
                              "content": "Edit Employee"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.row",
                          "submitEvent": "SAVE",
