                "name": "Time Off Deleted"
              },
              {
                "key": "TimeOffDeleteFailed",
                "name": "TimeOff delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TimeOffDeleted",
                "name": "TimeOff deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
