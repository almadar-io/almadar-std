{
  "name": "std-survey",
  "version": "1.0.0",
  "description": "Survey: Typeform-style builder with dynamic questions, skip-logic, response collection, and analytics.",
  "orbitals": [
    {
      "name": "SurveyOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-question-bank",
          "as": "QuestionBank"
        },
        {
          "from": "std/behaviors/std-branching-logic",
          "as": "Branching"
        },
        {
          "from": "std/behaviors/std-form-advanced",
          "as": "FormAdvanced"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        }
      ],
      "entity": {
        "name": "Survey",
        "collection": "surveys",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "closed"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "SurveyAppLayout",
          "config": {
            "notificationClickEvent": "SURVEY_NOTIFICATIONS_OPEN",
            "appName": "Surveys",
            "searchEvent": "SURVEY_SEARCH",
            "navItems": [
              {
                "label": "Surveys",
                "icon": "list-checks",
                "href": "/surveys"
              },
              {
                "href": "/responses",
                "icon": "inbox",
                "label": "Responses"
              }
            ],
            "contentTrait": "@trait.SurveyCatalog",
            "notifications": []
          },
          "events": {
            "SEARCH": "SURVEY_SEARCH",
            "NOTIFY_CLICK": "SURVEY_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "SurveyCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SURVEY_SEARCH",
              "triggers": "SURVEY_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "SurveyAppLayout"
              }
            },
            {
              "event": "SURVEY_NOTIFICATIONS_OPEN",
              "triggers": "SURVEY_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "SurveyAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SURVEY_SEARCH",
                "name": "Survey Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SURVEY_NOTIFICATIONS_OPEN",
                "name": "Survey Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "list-checks"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Surveys",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "button",
                                  "label": "New Survey",
                                  "icon": "plus",
                                  "variant": "primary",
                                  "action": "CREATE"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.SurveySearch",
                        "@trait.SurveyStats",
                        "@trait.SurveyGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.SurveyBrowseList",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Question Bank",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.SurveyQuestionBank",
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Skip Logic",
                          "type": "typography"
                        },
                        "@trait.SurveyBranching",
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Survey Preview"
                        },
                        "@trait.SurveyPreviewForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SURVEY_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SURVEY_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "You're all caught up."
                        },
                        {
                          "variant": "ghost",
                          "type": "button",
                          "label": "Back to surveys",
                          "action": "INIT"
                        }
                      ],
                      "className": "py-8",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "SurveySearch",
          "config": {
            "event": "SURVEY_SEARCH",
            "placeholder": "Search surveys…"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "SurveyStats",
          "config": {
            "metrics": [
              {
                "format": "number",
                "aggregation": "count",
                "label": "Total",
                "icon": "list-checks",
                "variant": "primary"
              },
              {
                "aggregation": "count",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "draft"
                  ]
                ],
                "variant": "warning",
                "format": "number",
                "icon": "edit",
                "label": "Draft"
              },
              {
                "aggregation": "count",
                "format": "number",
                "variant": "success",
                "label": "Published",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "published"
                  ]
                ],
                "icon": "check-circle"
              }
            ],
            "title": "Surveys"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "SurveyBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "SurveyGraphs",
          "config": {
            "subtitle": "Distribution across lifecycle states",
            "aggregation": "count",
            "chartType": "bar",
            "title": "Surveys by Status",
            "categoryField": "status",
            "height": 240.0,
            "showLegend": false
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "SurveyBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "SurveyBrowseList",
          "linkedEntity": "Survey",
          "config": {
            "itemActions": [
              {
                "event": "VIEW",
                "variant": "ghost",
                "label": "View"
              },
              {
                "label": "Edit",
                "variant": "ghost",
                "event": "EDIT"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ],
            "fields": [
              {
                "name": "title",
                "variant": "h3",
                "icon": "list-checks"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "name": "description",
                "variant": "caption"
              },
              {
                "variant": "caption",
                "format": "date",
                "name": "createdAt"
              }
            ],
            "cols": 1.0,
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "SurveySearch"
              }
            },
            {
              "event": "SURVEY_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyPersistor"
              }
            },
            {
              "event": "SURVEY_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyPersistor"
              }
            },
            {
              "event": "SURVEY_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyPersistor"
              }
            }
          ]
        },
        {
          "ref": "QuestionBank.traits.QuestionManage",
          "name": "SurveyQuestionBank",
          "config": {
            "title": "Question Bank"
          }
        },
        {
          "ref": "Branching.traits.BranchingRuleManage",
          "name": "SurveyBranching",
          "config": {
            "title": "Skip Logic Rules"
          }
        },
        {
          "ref": "FormAdvanced.traits.FormEntryFormAdvanced",
          "name": "SurveyPreviewForm"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SurveyCreate",
          "linkedEntity": "Survey",
          "config": {
            "icon": "plus-circle",
            "fields": [
              "title",
              "description",
              "status"
            ],
            "title": "New Survey",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "SurveyCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SurveyEdit",
          "linkedEntity": "Survey",
          "config": {
            "title": "Edit Survey",
            "mode": "edit",
            "icon": "edit",
            "fields": [
              "title",
              "description",
              "status"
            ]
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "SurveyView",
          "linkedEntity": "Survey",
          "config": {
            "fields": [
              "title",
              "description",
              "status"
            ],
            "title": "View Survey",
            "icon": "eye",
            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "SurveyBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "SurveyDelete",
          "linkedEntity": "Survey",
          "config": {
            "confirmLabel": "Delete",
            "title": "Delete Survey",
            "icon": "alert-triangle",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "SurveyBrowseList"
              }
            }
          ]
        },
        {
          "name": "SurveyPersistor",
          "category": "lifecycle",
          "linkedEntity": "Survey",
          "emits": [
            {
              "event": "SURVEY_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SURVEY_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SURVEY_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "SurveyCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "SurveyEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "SurveyDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SURVEY_CREATED",
                "name": "Survey Created"
              },
              {
                "key": "SURVEY_UPDATED",
                "name": "Survey Updated"
              },
              {
                "key": "SURVEY_DELETED",
                "name": "Survey Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Survey",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SURVEY_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SURVEY_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Survey",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "SURVEY_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SurveysPage",
          "path": "/surveys",
          "traits": [
            {
              "ref": "SurveyAppLayout"
            },
            {
              "ref": "SurveyCatalog"
            },
            {
              "ref": "SurveySearch"
            },
            {
              "ref": "SurveyStats"
            },
            {
              "ref": "SurveyGraphs"
            },
            {
              "ref": "SurveyBrowseList"
            },
            {
              "ref": "SurveyQuestionBank"
            },
            {
              "ref": "SurveyBranching"
            },
            {
              "ref": "SurveyPreviewForm"
            },
            {
              "ref": "SurveyCreate"
            },
            {
              "ref": "SurveyEdit"
            },
            {
              "ref": "SurveyView"
            },
            {
              "ref": "SurveyDelete"
            },
            {
              "ref": "SurveyPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ResponseOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-response-collector",
          "as": "Collector"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Response",
        "collection": "responses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "surveyId",
            "type": "string",
            "required": true
          },
          {
            "name": "respondentId",
            "type": "string",
            "required": true
          },
          {
            "name": "questionId",
            "type": "string",
            "required": true
          },
          {
            "name": "answerJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "submittedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ResponseAppLayout",
          "config": {
            "notifications": [],
            "searchEvent": "RESPONSE_SEARCH",
            "navItems": [
              {
                "icon": "list-checks",
                "href": "/surveys",
                "label": "Surveys"
              },
              {
                "icon": "inbox",
                "href": "/responses",
                "label": "Responses"
              }
            ],
            "appName": "Surveys",
            "notificationClickEvent": "RESPONSE_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.ResponseDashboard"
          },
          "events": {
            "NOTIFY_CLICK": "RESPONSE_NOTIFICATIONS_OPEN",
            "SEARCH": "RESPONSE_SEARCH"
          }
        },
        {
          "name": "ResponseDashboard",
          "category": "interaction",
          "listens": [
            {
              "event": "RESPONSE_SEARCH",
              "triggers": "RESPONSE_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ResponseAppLayout"
              }
            },
            {
              "event": "RESPONSE_NOTIFICATIONS_OPEN",
              "triggers": "RESPONSE_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ResponseAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RESPONSE_SEARCH",
                "name": "Response Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESPONSE_NOTIFICATIONS_OPEN",
                "name": "Response Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "inbox"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Responses"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Submit a response",
                          "type": "typography"
                        },
                        "@trait.ResponseCollect",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "All responses",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.ResponseBrowseList"
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "RESPONSE_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
