                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "You're all caught up."
                        },
                        {
                          "label": "Back to responses",
                          "action": "INIT",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
