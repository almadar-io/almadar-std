                    "@entity.level",
                    1.0
                  ],
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "fetch",
                    "EventChallenge",
                    {
                      "emit": {
                        "success": "EventChallengeLoaded",
                        "failure": "EventChallengeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "appName": "Coding Academy",
                      "children": [
                        {
                          "type": "game-menu",
                          "title": "Event Handler Challenge",
                          "menuItems": [
                            {
                              "label": "Start",
                              "event": "START",
                              "variant": "primary"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "stats": [
                                {
                                  "value": "@entity.score",
                                  "label": "Score"
                                },
                                {
                                  "label": "Level",
                                  "value": "@entity.level"
                                }
                              ],
                              "type": "game-hud"
                            },
                            {
                              "type": "card",
                              "children": [
                                {
                                  "gap": "md",
                                  "align": "center",
                                  "direction": "vertical",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "typography",
                                      "variant": "h3",
                                      "content": "Event Handler Challenge"
                                    },
                                    {
                                      "content": "Wire the event handlers to fire on the right triggers.",
                                      "type": "typography",
                                      "variant": "body",
                                      "color": "muted"
                                    },
                                    {
                                      "icon": "check",
                                      "action": "COMPLETE",
                                      "type": "button",
                                      "variant": "primary",
                                      "label": "Complete"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack"
                        }
                      ],
                      "appName": "Coding Academy",
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Coding Academy",
                      "showTopBar": true,
                      "children": [
                        {
                          "type": "game-over-screen",
                          "title": "Well Done!",
                          "menuItems": [
                            {
                              "variant": "primary",
                              "label": "Play Again",
                              "event": "RESTART"
                            }
                          ]
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "title": "Event Handler Challenge",
                          "menuItems": [
                            {
                              "event": "START",
                              "label": "Start",
                              "variant": "primary"
                            }
                          ],
                          "type": "game-menu"
                        }
                      ],
                      "appName": "Coding Academy",
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Events",
          "path": "/events",
          "traits": [
            {
              "ref": "EventChallengeEventHandlerGame"
            }
          ]
        }
      ]
    },
    {
      "name": "StudentProgressOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        }
      ],
      "entity": {
        "name": "StudentProgress",
        "collection": "studentprogresses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "student",
            "type": "string",
            "default": ""
          },
          {
            "name": "lessonsCompleted",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "avgScore",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "streak",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "totalTimeMinutes",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "progressPct",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "day",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastActiveAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "StudentProgressAppLayout",
          "config": {
            "notificationClickEvent": "STUDENT_PROGRESS_NOTIFICATIONS_OPEN",
            "appName": "Coding Academy",
            "contentTrait": "@trait.StudentProgressCatalog",
            "searchEvent": "STUDENT_PROGRESS_SEARCH",
            "notifications": [],
            "navItems": [
              {
                "label": "Sequencer",
                "href": "/sequencer",
                "icon": "list-ordered"
              },
              {
                "icon": "wrench",
                "label": "Builder",
                "href": "/builder"
              },
              {
                "label": "Events",
                "href": "/events",
                "icon": "zap"
              },
              {
                "label": "Progress",
                "href": "/progress",
                "icon": "trending-up"
              }
            ]
          },
          "events": {
            "SEARCH": "STUDENT_PROGRESS_SEARCH",
            "NOTIFY_CLICK": "STUDENT_PROGRESS_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "StudentProgressCatalog",
          "category": "interaction",
          "listens": [
            {
              "event": "STUDENT_PROGRESS_SEARCH",
              "triggers": "STUDENT_PROGRESS_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressAppLayout"
              }
            },
            {
              "event": "STUDENT_PROGRESS_NOTIFICATIONS_OPEN",
              "triggers": "STUDENT_PROGRESS_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "STUDENT_PROGRESS_SEARCH",
                "name": "Student Progress Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "STUDENT_PROGRESS_NOTIFICATIONS_OPEN",
                "name": "Student Progress Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "trending-up",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Progress",
                                  "type": "typography"
                                }
                              ],
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.StudentProgressStats",
                        "@trait.StudentProgressGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.StudentProgressBrowseList"
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "STUDENT_PROGRESS_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "STUDENT_PROGRESS_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-8",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "You're all caught up."
                        },
                        {
                          "action": "INIT",
                          "type": "button",
                          "variant": "ghost",
                          "label": "Back to progress"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "StudentProgressStats",
          "config": {
            "title": "Student Progress",
            "metrics": [
              {
                "field": "lessonsCompleted",
                "icon": "check-circle",
                "variant": "success",
                "aggregation": "sum",
                "label": "Lessons Completed",
                "format": "number"
              },
              {
                "label": "Average Score",
                "icon": "star",
                "format": "number",
                "variant": "primary",
                "field": "avgScore",
                "aggregation": "avg"
              },
              {
                "format": "number",
                "label": "Streak",
                "field": "streak",
                "icon": "flame",
                "variant": "warning",
                "suffix": "d",
                "aggregation": "max"
              },
              {
                "icon": "clock",
                "format": "number",
                "variant": "info",
                "suffix": "m",
                "label": "Total Time",
                "aggregation": "sum",
                "field": "totalTimeMinutes"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "StudentProgressGraphs",
          "config": {
            "title": "Progress over time",
            "chartType": "line",
            "valueField": "progressPct",
            "showLegend": true,
            "dateField": "day",
            "height": 280.0,
            "subtitle": "Daily progress %"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "StudentProgressBrowseList",
          "linkedEntity": "StudentProgress",
          "config": {
            "gap": "sm",
            "itemActions": [
              {
                "label": "View",
                "variant": "ghost",
                "event": "VIEW"
              },
              {
                "variant": "ghost",
                "label": "Edit",
                "event": "EDIT"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "cols": 1.0,
            "fields": [
              {
                "label": "Student",
                "icon": "user",
                "name": "student",
                "variant": "h4"
              },
              {
                "name": "lessonsCompleted",
                "label": "Lessons Completed",
                "variant": "body"
              },
              {
                "variant": "badge",
                "name": "avgScore",
                "label": "Avg Score"
              },
              {
                "name": "streak",
                "label": "Streak",
                "variant": "body"
              },
              {
                "format": "date",
                "name": "lastActiveAt",
                "variant": "caption",
                "label": "Last Active"
              }
            ]
          },
          "listens": [
            {
              "event": "PROGRESS_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressPersistor"
              }
            },
            {
              "event": "PROGRESS_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "StudentProgressView",
          "linkedEntity": "StudentProgress",
          "config": {
            "fields": [
              "student",
              "lessonsCompleted",
              "avgScore",
              "streak",
              "totalTimeMinutes",
              "progressPct",
              "lastActiveAt"
            ],
            "icon": "eye",
            "title": "View Progress",
            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "StudentProgressEdit",
          "linkedEntity": "StudentProgress",
          "config": {
            "mode": "edit",
            "icon": "edit",
            "fields": [
              "student",
              "lessonsCompleted",
              "avgScore",
              "streak",
              "totalTimeMinutes",
              "progressPct",
              "lastActiveAt"
            ],
            "title": "Edit Progress"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "StudentProgressDelete",
          "linkedEntity": "StudentProgress",
          "config": {
            "title": "Delete Progress",
            "icon": "alert-triangle",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressBrowseList"
              }
            }
          ]
        },
        {
          "name": "StudentProgressPersistor",
          "category": "lifecycle",
          "linkedEntity": "StudentProgress",
          "emits": [
            {
              "event": "PROGRESS_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PROGRESS_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "StudentProgressDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PROGRESS_UPDATED",
                "name": "Progress Updated"
              },
              {
                "key": "PROGRESS_DELETED",
                "name": "Progress Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "StudentProgress",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PROGRESS_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "StudentProgress",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "PROGRESS_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Progress",
          "path": "/progress",
          "traits": [
            {
              "ref": "StudentProgressAppLayout"
            },
            {
              "ref": "StudentProgressCatalog"
            },
            {
              "ref": "StudentProgressStats"
            },
            {
              "ref": "StudentProgressGraphs"
            },
            {
              "ref": "StudentProgressBrowseList"
            },
            {
              "ref": "StudentProgressView"
            },
            {
              "ref": "StudentProgressEdit"
            },
            {
              "ref": "StudentProgressDelete"
            },
            {
              "ref": "StudentProgressPersistor"
            }
          ]
        }
      ]
    }
  ]
}