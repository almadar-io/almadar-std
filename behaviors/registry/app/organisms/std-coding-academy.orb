                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              },
              {
                "name": "refreshing"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOADED",
                "name": "Loaded"
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "REFRESHED",
                "name": "Refreshed"
              },
              {
                "key": "StudentProgressLoaded",
                "name": "StudentProgress loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "totalLessons",
                    "type": "number"
                  },
                  {
                    "name": "completedLessons",
                    "type": "number"
                  },
                  {
                    "name": "averageScore",
                    "type": "number"
                  },
                  {
                    "name": "streak",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "StudentProgressLoadFailed",
                "name": "StudentProgress load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StudentProgress",
                    {
                      "emit": {
                        "failure": "StudentProgressLoadFailed",
                        "success": "StudentProgressLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Coding Academy",
                      "showTopBar": true,
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "vertical",
                              "children": [
                                {
