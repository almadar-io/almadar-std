{
  "name": "std-event-ticketing",
  "version": "1.0.0",
  "description": "Event ticketing: organizers create events with VIP / general / early-bird tiers, attendees buy tickets, gate staff scan QR at door, waitlist auto-promotes when tickets free up. Pick for Eventbrite-style apps.",
  "orbitals": [
    {
      "name": "EventOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-event",
          "as": "Event"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-calendar",
          "as": "Calendar"
        }
      ],
      "entity": {
        "name": "EventRow",
        "collection": "events",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "venue",
            "type": "string",
            "default": ""
          },
          {
            "name": "startsAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "endsAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "capacity",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "sold-out",
              "cancelled"
            ]
          },
          {
            "name": "organizerId",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "EventAppLayout",
          "config": {
            "searchEvent": "EVENT_SEARCH",
            "appName": "EventTicketing",
            "navItems": [
              {
                "icon": "calendar",
                "label": "Events",
                "href": "/events"
              },
              {
                "label": "Tickets",
                "href": "/tickets",
                "icon": "ticket"
              },
              {
                "href": "/checkin",
                "label": "Check-in",
                "icon": "qr-code"
              },
              {
                "label": "Waitlist",
                "icon": "users",
                "href": "/waitlist"
              }
            ],
            "notifications": [],
            "contentTrait": "@trait.EventCatalog",
            "notificationClickEvent": "EVENT_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "EVENT_SEARCH",
            "NOTIFY_CLICK": "EVENT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "EventCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "EVENT_SEARCH",
              "triggers": "EVENT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "EventAppLayout"
              }
            },
            {
              "event": "EVENT_NOTIFICATIONS_OPEN",
              "triggers": "EVENT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "EventAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EVENT_SEARCH",
                "name": "Event Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EVENT_NOTIFICATIONS_OPEN",
                "name": "Event Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "calendar"
                                },
                                {
                                  "type": "typography",
                                  "content": "Events",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "children": [
                                {
                                  "type": "button",
                                  "variant": "primary",
                                  "action": "CREATE",
                                  "label": "New Event",
                                  "icon": "plus"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            "@trait.EventSearch",
                            "@trait.EventFilter"
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        "@trait.EventStats",
                        {
                          "type": "divider"
                        },
                        "@trait.EventCalendarView",
                        {
                          "type": "divider"
                        },
                        "@trait.EventBrowseList",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Advanced Event Admin",
                          "type": "typography",
                          "variant": "h3"
                        },
                        "@trait.EventAdvancedAdmin"
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "EVENT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "EVENT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "No notifications"
                        },
                        {
                          "content": "You're all caught up.",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        },
                        {
                          "action": "INIT",
                          "label": "Back to events",
                          "variant": "ghost",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "className": "py-8",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "EventSearch",
          "config": {
            "event": "EVENT_SEARCH",
            "placeholder": "Search events…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "EventFilter",
          "config": {
            "event": "EVENT_FILTER",
            "filters": [
              {
                "label": "Status",
                "options": [
                  "draft",
                  "published",
                  "sold-out",
                  "cancelled"
                ],
                "field": "status",
                "filterType": "select"
              }
            ]
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "EventStats",
          "config": {
            "title": "Events",
            "metrics": [
              {
                "label": "Total",
                "icon": "calendar",
                "variant": "primary",
                "format": "number",
                "aggregation": "count"
              },
              {
                "variant": "success",
                "aggregation": "count",
                "format": "number",
                "label": "Published",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "published"
                  ]
                ],
                "icon": "send"
              },
              {
                "aggregation": "count",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "sold-out"
                  ]
                ],
                "label": "Sold Out",
                "icon": "check-circle",
                "variant": "warning"
              },
              {
                "variant": "info",
                "format": "number",
                "icon": "users",
                "field": "capacity",
                "label": "Capacity",
                "aggregation": "sum"
              }
            ]
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "EventBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "EventBrowseList",
          "linkedEntity": "EventRow",
          "config": {
            "fields": [
              {
                "variant": "h3",
                "icon": "calendar",
                "name": "name"
              },
              {
                "variant": "body",
                "name": "venue"
              },
              {
                "name": "startsAt",
                "format": "date",
                "variant": "caption"
              },
              {
                "format": "date",
                "name": "endsAt",
                "variant": "caption"
              },
              {
                "name": "capacity",
                "variant": "body",
                "format": "number"
              },
              {
                "name": "status",
                "variant": "badge"
              }
            ],
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "variant": "danger",
                "event": "DELETE",
                "label": "Delete"
              }
            ],
            "gap": "sm",
            "cols": 1.0
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "EventSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "EventFilter"
              }
            },
            {
              "event": "EVENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EventPersistor"
              }
            },
            {
              "event": "EVENT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EventPersistor"
              }
            },
            {
              "event": "EVENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EventPersistor"
              }
            }
          ]
        },
        {
          "ref": "Calendar.traits.CalendarEventCalendar",
          "name": "EventCalendarView",
          "linkedEntity": "EventRow",
          "config": {
            "title": "Event Calendar"
          },
          "listens": [
            {
              "event": "EVENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EventPersistor"
              }
            },
            {
              "event": "EVENT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EventPersistor"
              }
            },
            {
              "event": "EVENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "EventPersistor"
              }
            }
          ]
        },
        {
          "ref": "Event.traits.EventManage",
          "name": "EventAdvancedAdmin",
          "linkedEntity": "EventRow",
          "config": {
            "title": "Lifecycle Admin"
          }
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "EventCreate",
          "linkedEntity": "EventRow",
          "config": {
            "title": "New Event",
            "icon": "plus-circle",
            "mode": "create",
            "fields": [
              "name",
              "description",
              "venue",
              "startsAt",
              "endsAt",
              "capacity",
              "status",
              "organizerId"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "EventCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "EventEdit",
          "linkedEntity": "EventRow",
          "config": {
            "fields": [
              "name",
              "description",
              "venue",
              "startsAt",
              "endsAt",
              "capacity",
              "status",
              "organizerId"
            ],
            "icon": "edit",
            "title": "Edit Event",
            "mode": "edit"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "EventBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "EventView",
          "linkedEntity": "EventRow",
          "config": {
            "mode": "edit",
            "fields": [
              "name",
              "description",
              "venue",
              "startsAt",
              "endsAt",
              "capacity",
              "status",
              "organizerId"
            ],
            "icon": "eye",
            "title": "View Event"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "EventBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "EventDelete",
          "linkedEntity": "EventRow",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Event",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "CONFIRM": "CONFIRM_DELETE",
            "REQUEST": "DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "EventBrowseList"
              }
            }
          ]
        },
        {
          "name": "EventPersistor",
          "category": "lifecycle",
          "linkedEntity": "EventRow",
          "emits": [
            {
              "event": "EVENT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EVENT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EVENT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "EventCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "EventEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "EventDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EVENT_CREATED",
                "name": "Event Created"
              },
              {
                "key": "EVENT_UPDATED",
                "name": "Event Updated"
              },
              {
                "key": "EVENT_DELETED",
                "name": "Event Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "EventRow",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "EVENT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "EventRow",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "EVENT_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "EventRow",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "EVENT_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "EventsPage",
          "path": "/events",
          "traits": [
            {
              "ref": "EventAppLayout"
            },
            {
              "ref": "EventCatalog"
            },
            {
              "ref": "EventSearch"
            },
            {
              "ref": "EventFilter"
            },
            {
              "ref": "EventStats"
            },
            {
              "ref": "EventBrowseList"
            },
            {
              "ref": "EventCalendarView"
            },
            {
              "ref": "EventAdvancedAdmin"
            },
            {
              "ref": "EventCreate"
            },
            {
              "ref": "EventEdit"
            },
            {
              "ref": "EventView"
            },
            {
              "ref": "EventDelete"
            },
            {
              "ref": "EventPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "TicketOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-ticket-tier",
          "as": "TierAtom"
        },
        {
          "from": "std/behaviors/std-cart",
          "as": "Cart"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Ticket",
        "collection": "tickets",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "eventId",
            "type": "string",
            "required": true
          },
          {
            "name": "tierId",
            "type": "string",
            "required": true
          },
          {
            "name": "holderName",
            "type": "string",
            "required": true
          },
          {
            "name": "holderEmail",
            "type": "string",
            "required": true
          },
          {
            "name": "qrCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "paid",
              "scanned",
              "refunded",
              "cancelled"
            ]
          },
          {
            "name": "purchasedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "TicketAppLayout",
          "config": {
            "contentTrait": "@trait.TicketShop",
            "notifications": [],
            "notificationClickEvent": "TICKET_NOTIFICATIONS_OPEN",
            "appName": "EventTicketing",
            "searchEvent": "TICKET_SEARCH",
            "navItems": [
              {
                "label": "Events",
                "icon": "calendar",
                "href": "/events"
              },
              {
                "label": "Tickets",
                "icon": "ticket",
                "href": "/tickets"
              },
              {
                "href": "/checkin",
                "icon": "qr-code",
                "label": "Check-in"
              },
              {
                "icon": "users",
                "label": "Waitlist",
                "href": "/waitlist"
              }
            ]
          },
          "events": {
            "NOTIFY_CLICK": "TICKET_NOTIFICATIONS_OPEN",
            "SEARCH": "TICKET_SEARCH"
          }
        },
        {
          "name": "TicketShop",
          "category": "interaction",
          "emits": [
            {
              "event": "ISSUE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TICKET_SEARCH",
              "triggers": "TICKET_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "TicketAppLayout"
              }
            },
            {
              "event": "TICKET_NOTIFICATIONS_OPEN",
              "triggers": "TICKET_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "TicketAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TICKET_SEARCH",
                "name": "Ticket Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TICKET_NOTIFICATIONS_OPEN",
                "name": "Ticket Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ISSUE",
                "name": "Issue"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "ticket"
                                },
                                {
                                  "type": "typography",
                                  "content": "Tickets",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "sm",
                              "align": "center",
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "action": "ISSUE",
                                  "type": "button",
                                  "variant": "primary",
                                  "icon": "plus",
                                  "label": "Issue Ticket"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Available Tiers",
                          "variant": "h3",
                          "type": "typography"
                        },
                        "@trait.TicketTierShop",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Your Cart",
                          "variant": "h3",
                          "type": "typography"
                        },
                        "@trait.TicketCart",
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Tickets Issued",
                          "variant": "h3",
                          "type": "typography"
                        },
                        "@trait.TicketBrowseList"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "TICKET_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "TICKET_NOTIFICATIONS_OPEN"
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "TierAtom.traits.TicketTierManage",
          "name": "TicketTierShop",
          "config": {
            "title": "Choose Your Tier"
          }
        },
        {
          "ref": "Cart.traits.CartItemCartBrowse",
          "name": "TicketCart"
        },
        {
          "ref": "Cart.traits.CartItemAddItem",
          "name": "TicketCartAddItem"
        },
