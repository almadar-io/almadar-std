          "ref": "Cart.traits.CartItemRemoveConfirm",
          "name": "TicketCartRemoveItem"
        },
        {
          "ref": "Cart.traits.CartItemPersistor",
          "name": "TicketCartPersistor"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "TicketBrowseList",
          "linkedEntity": "Ticket",
          "config": {
            "itemActions": [
              {
                "label": "View",
                "event": "VIEW",
                "variant": "ghost"
              }
            ],
            "gap": "sm",
            "cols": 1.0,
            "fields": [
              {
                "name": "holderName",
                "variant": "h4",
                "icon": "ticket"
              },
              {
                "name": "holderEmail",
                "variant": "caption"
              },
              {
                "name": "tierId",
                "variant": "badge"
              },
              {
                "variant": "body",
                "name": "qrCode"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "format": "date",
                "name": "purchasedAt",
                "variant": "caption"
              }
            ]
          },
          "listens": [
            {
              "event": "TICKET_ISSUED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "TicketPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "TicketIssueModal",
          "linkedEntity": "Ticket",
          "config": {
            "icon": "plus-circle",
            "fields": [
              "eventId",
              "tierId",
              "holderName",
              "holderEmail",
              "status"
            ],
            "mode": "create",
            "title": "Issue Ticket"
          },
          "events": {
            "OPEN": "ISSUE"
          },
          "listens": [
            {
              "event": "ISSUE",
              "triggers": "ISSUE",
              "source": {
                "kind": "trait",
                "trait": "TicketShop"
              }
            }
          ]
        },
        {
          "name": "TicketPersistor",
          "category": "lifecycle",
          "linkedEntity": "Ticket",
          "emits": [
            {
              "event": "TICKET_ISSUED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_ISSUE",
              "source": {
                "kind": "trait",
                "trait": "TicketIssueModal"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_ISSUE",
                "name": "Do Issue",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "TICKET_ISSUED",
                "name": "Ticket Issued"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_ISSUE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Ticket",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TICKET_ISSUED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TicketsPage",
