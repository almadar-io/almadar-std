{
  "name": "std-embedded-dashboard",
  "version": "1.4.0",
  "description": "Use for any analytics/BI dashboard (KPIs + charts + filters + export). Every preset tile and every layout slot is config-driven; callers can swap chart types, fields, aggregations, sort, drill events, tile layout, nav, and toolbar/filter wiring without touching the .orb. DefaultDataSource fetches the (rebindable) entity and emits ITEMS_LOADED — chart traits consume it via the bus, so rebinding entityName threads through the actual data fetch.",
  "orbitals": [
    {
      "name": "DashboardOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-dashboard-grid-embedded",
          "as": "Layout"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-scatter",
          "as": "Scatter"
        },
        {
          "from": "std/behaviors/std-date-range",
          "as": "DateRange"
        },
        {
          "from": "std/behaviors/std-export",
          "as": "Export"
        }
      ],
      "entity": {
        "name": "Dashboard",
        "collection": "dashboards",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EmptyTile",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "DefaultDataSource",
          "category": "interaction",
          "linkedEntity": "Dashboard",
          "emits": [
            {
              "event": "ITEMS_LOADED",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[object]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ITEMS_LOAD_FAILED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "loaded"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DATE_RANGE_CHANGED",
                "name": "Date Range Changed",
                "payloadSchema": [
                  {
                    "name": "from",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "to",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded"
              },
              {
                "key": "ITEMS_LOAD_FAILED",
                "name": "Items Load Failed"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loaded",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Dashboard",
                    {
                      "emit": {
                        "success": "ITEMS_LOADED",
                        "failure": "ITEMS_LOAD_FAILED"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              },
              {
                "from": "loaded",
                "to": "loaded",
                "event": "DATE_RANGE_CHANGED",
                "effects": [
                  [
                    "fetch",
                    "Dashboard",
                    {
                      "emit": {
                        "failure": "ITEMS_LOAD_FAILED",
                        "success": "ITEMS_LOADED"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "DefaultKpiStats",
          "config": {
            "viewPattern": "data-grid",
            "metrics": [
              {
                "trend": 8.0,
                "format": "currency",
                "value": 142000.0,
                "trendFormat": "percent",
                "variant": "success",
                "label": "Revenue",
                "icon": "trending-up",
                "trendPolarity": "higher-is-better"
              },
              {
                "value": 11833.0,
                "label": "MRR",
                "trendPolarity": "higher-is-better",
                "trend": 5.0,
                "variant": "primary",
                "format": "currency",
                "icon": "repeat",
                "trendFormat": "percent"
              },
              {
                "value": 248.0,
                "label": "Customers",
                "icon": "users",
                "variant": "info",
                "trendPolarity": "higher-is-better",
                "trendFormat": "percent",
                "sparklineData": [
                  180.0,
                  195.0,
                  210.0,
                  220.0,
                  225.0,
                  238.0,
                  248.0
                ],
                "format": "number",
                "trend": 12.0
              },
              {
                "trend": 1.0,
                "trendPolarity": "lower-is-better",
                "variant": "warning",
                "trendFormat": "percent",
                "label": "Churn",
                "value": 2.0,
                "format": "percent",
                "icon": "trending-down"
              }
            ],
            "title": "Key Metrics"
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultRevenueChart",
          "config": {
            "aggregation": "sum",
            "subtitle": "Last 4 quarters",
            "period": "quarter",
            "showValues": false,
            "sortField": "none",
            "valueField": "revenue",
            "timeAxis": false,
            "title": "Revenue by Quarter",
            "chartType": "bar",
            "categoryField": "quarter",
            "timeField": "date",
            "height": 240.0,
            "stack": "none",
            "showLegend": false,
            "series": [],
            "viewPattern": "chart",
            "sortDir": "desc",
            "drillEvent": "REVENUE_TILE_CLICKED",
            "limit": 0.0
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultDistributionChart",
          "config": {
            "timeField": "date",
            "drillEvent": "DISTRIBUTION_TILE_CLICKED",
            "showLegend": true,
            "title": "Revenue Distribution",
            "timeAxis": false,
            "height": 240.0,
            "series": [],
            "categoryField": "segment",
            "chartType": "pie",
            "period": "month",
            "viewPattern": "chart",
            "sortDir": "desc",
            "subtitle": "By segment",
            "stack": "none",
            "sortField": "value",
            "valueField": "revenue",
            "aggregation": "sum",
            "limit": 0.0,
            "showValues": false
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultGrowthChart",
          "config": {
            "stack": "none",
            "series": [],
            "viewPattern": "chart",
            "period": "month",
            "valueField": "value",
            "chartType": "line",
            "showLegend": false,
            "showValues": false,
            "timeAxis": true,
            "timeField": "date",
            "height": 240.0,
            "sortField": "label",
            "drillEvent": "GROWTH_TILE_CLICKED",
            "title": "Growth Over Time",
            "subtitle": "Monthly trend",
            "categoryField": "month",
            "sortDir": "desc",
            "limit": 0.0,
            "aggregation": "sum"
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultTopProductsChart",
          "config": {
            "aggregation": "sum",
            "sortField": "value",
            "period": "month",
            "title": "Top Products",
            "valueField": "revenue",
            "showValues": true,
            "categoryField": "product",
            "timeField": "date",
            "stack": "none",
            "timeAxis": false,
            "series": [],
            "showLegend": false,
            "chartType": "bar",
            "limit": 5.0,
            "drillEvent": "PRODUCT_TILE_CLICKED",
            "height": 240.0,
            "viewPattern": "chart",
            "sortDir": "desc",
            "subtitle": "Top 5 by revenue"
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultAreaChart",
          "config": {
            "sortDir": "desc",
            "title": "Cumulative Sales",
            "sortField": "label",
            "valueField": "amount",
            "showLegend": false,
            "categoryField": "month",
            "chartType": "area",
            "period": "month",
            "timeField": "date",
            "series": [],
            "limit": 0.0,
            "timeAxis": true,
            "viewPattern": "chart",
            "stack": "none",
            "subtitle": "Year-to-date",
            "aggregation": "sum",
            "drillEvent": "AREA_TILE_CLICKED",
            "height": 240.0,
            "showValues": false
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultDonutChart",
          "config": {
            "viewPattern": "chart",
            "subtitle": "By marketing channel",
            "valueField": "value",
            "aggregation": "sum",
            "showLegend": true,
            "title": "Channel Mix",
            "sortDir": "desc",
            "drillEvent": "DONUT_TILE_CLICKED",
            "timeField": "date",
            "chartType": "donut",
            "series": [],
            "categoryField": "channel",
            "timeAxis": false,
            "stack": "none",
            "limit": 0.0,
            "height": 240.0,
            "period": "month",
            "showValues": false,
            "sortField": "value"
          }
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "DefaultActivityHistogram",
          "config": {
            "showLegend": false,
            "title": "Activity Distribution",
            "valueField": "count",
            "sortDir": "desc",
            "series": [],
            "showValues": false,
            "timeAxis": false,
            "stack": "none",
            "timeField": "date",
            "aggregation": "count",
            "chartType": "histogram",
            "limit": 0.0,
            "drillEvent": "HISTOGRAM_TILE_CLICKED",
            "period": "day",
            "subtitle": "Order count per bucket",
            "sortField": "label",
            "height": 240.0,
            "categoryField": "bucket",
            "viewPattern": "chart"
          }
        },
        {
          "ref": "Scatter.traits.ScatterItemPlot",
          "name": "DefaultScatter",
          "config": {
            "drillEvent": "SCATTER_TILE_CLICKED",
            "yField": "revenue",
            "title": "Spend vs Revenue",
            "height": 240.0,
            "colorField": "segment",
            "sizeField": "ltv",
            "subtitle": "Per customer",
            "xField": "spend",
            "labelField": "customer"
          }
        },
        {
          "ref": "DateRange.traits.DateRangeFilter",
          "name": "DefaultDateRange",
          "config": {
            "fromLabel": "From",
            "buttonLabel": "Date range",
            "event": "DATE_RANGE_CHANGED",
            "toLabel": "To"
          }
        },
        {
          "ref": "Export.traits.ExportMenu",
          "name": "DefaultExport",
          "config": {
            "event": "EXPORT_REQUESTED",
            "tileId": "dashboard",
            "formats": [
              {
                "format": "csv",
                "label": "CSV",
                "id": "csv"
              },
              {
                "id": "xlsx",
                "format": "xlsx",
                "label": "Excel"
              },
              {
                "format": "pdf",
                "label": "PDF",
                "id": "pdf"
              },
              {
                "id": "png",
                "format": "png",
                "label": "PNG"
              }
            ]
          }
        },
        {
          "ref": "Layout.traits.DashboardGridEmbedded",
          "name": "DashboardLayout",
          "config": {
            "tile12Trait": "@trait.EmptyTile",
            "toolbar3Trait": "@trait.EmptyTile",
            "tile8Trait": "@trait.DefaultAreaChart",
            "minTileWidth": 320.0,
            "filter2Trait": "@trait.EmptyTile",
            "tile6Trait": "@trait.DefaultTopProductsChart",
            "toolbar1Trait": "@trait.DefaultExport",
            "tile5Trait": "@trait.DefaultGrowthChart",
            "filter4Trait": "@trait.EmptyTile",
            "tile10Trait": "@trait.EmptyTile",
            "tile4Trait": "@trait.DefaultScatter",
            "tile2Trait": "@trait.DefaultRevenueChart",
            "filter3Trait": "@trait.EmptyTile",
            "tile11Trait": "@trait.EmptyTile",
            "tile3Trait": "@trait.DefaultDistributionChart",
            "filter1Trait": "@trait.DefaultDateRange",
            "tile9Trait": "@trait.DefaultActivityHistogram",
            "tile1Trait": "@trait.DefaultKpiStats",
            "toolbar2Trait": "@trait.EmptyTile",
            "tile7Trait": "@trait.DefaultDonutChart"
          }
        }
      ],
      "pages": [
        {
          "name": "DashboardPage",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardLayout"
            },
            {
              "ref": "DefaultDataSource"
            },
            {
              "ref": "DefaultKpiStats"
            },
            {
              "ref": "DefaultRevenueChart"
            },
            {
              "ref": "DefaultDistributionChart"
            },
            {
              "ref": "DefaultScatter"
            },
            {
              "ref": "DefaultGrowthChart"
            },
            {
              "ref": "DefaultTopProductsChart"
            },
            {
              "ref": "DefaultAreaChart"
            },
            {
              "ref": "DefaultDonutChart"
            },
            {
              "ref": "DefaultActivityHistogram"
            },
            {
              "ref": "DefaultDateRange"
            },
            {
              "ref": "DefaultExport"
            },
            {
              "ref": "EmptyTile"
            }
          ]
        }
      ]
    }
  ]
}