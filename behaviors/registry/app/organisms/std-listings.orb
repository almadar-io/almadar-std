{
  "name": "std-listings",
  "version": "1.0.0",
  "description": "Listings: real-estate / jobs / classifieds. Post, browse with map + filters, save searches, and inquire via flat threads.",
  "orbitals": [
    {
      "name": "ListingOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-geosearch",
          "as": "GeoSearch"
        },
        {
          "from": "std/behaviors/std-saved-search",
          "as": "SavedSearch"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-image-upload-multi",
          "as": "Images"
        },
        {
          "from": "std/behaviors/std-tag-taxonomy",
          "as": "Tags"
        },
        {
          "from": "std/behaviors/std-thread",
          "as": "Thread"
        }
      ],
      "entity": {
        "name": "Listing",
        "collection": "listings",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "location",
            "type": "string",
            "default": ""
          },
          {
            "name": "lat",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lng",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "images",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "sold",
              "expired"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ListingAppLayout",
          "config": {
            "contentTrait": "@trait.ListingCatalog",
            "navItems": [
              {
                "icon": "list",
                "label": "Browse",
                "href": "/listings"
              },
              {
                "href": "/saved",
                "icon": "bookmark",
                "label": "Saved"
              },
              {
                "href": "/inquiries",
                "icon": "message-circle",
                "label": "Inquiries"
              }
            ],
            "searchEvent": "LISTING_SEARCH",
            "appName": "Listings",
            "notifications": [],
            "notificationClickEvent": "LISTING_NOTIFICATIONS_OPEN"
          },
          "events": {
            "SEARCH": "LISTING_SEARCH",
            "NOTIFY_CLICK": "LISTING_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "ListingCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SAVE_SEARCH",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LISTING_SEARCH",
              "triggers": "LISTING_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ListingAppLayout"
              }
            },
            {
              "event": "LISTING_NOTIFICATIONS_OPEN",
              "triggers": "LISTING_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ListingAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LISTING_SEARCH",
                "name": "Listing Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LISTING_NOTIFICATIONS_OPEN",
                "name": "Listing Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "SAVE_SEARCH",
                "name": "Save Search"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "list"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Listings"
                                }
                              ],
                              "align": "center",
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "icon": "bookmark",
                                  "action": "SAVE_SEARCH",
                                  "label": "Save Search",
                                  "type": "button",
                                  "variant": "secondary"
                                },
                                {
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "icon": "plus",
                                  "type": "button",
                                  "label": "New Listing"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ListingGeoSearch",
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "start",
                          "children": [
                            "@trait.ListingFilter",
                            "@trait.ListingTags"
                          ]
                        },
                        "@trait.ListingStats",
                        {
                          "type": "divider"
                        },
                        "@trait.ListingBrowse"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "LISTING_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "LISTING_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "You're all caught up.",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "label": "Back to listings",
                          "type": "button",
                          "variant": "ghost",
                          "action": "INIT"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "GeoSearch.traits.GeoSearchResultSearch",
          "name": "ListingGeoSearch",
          "config": {
            "placeholder": "Search nearby listings…",
            "event": "LISTING_GEO_SEARCH",
            "defaultRadiusKm": 25.0
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "ListingFilter",
          "config": {
            "filters": [
              {
                "field": "status",
                "filterType": "select",
                "label": "Status",
                "options": [
                  "active",
                  "sold",
                  "expired"
                ]
              }
            ],
            "event": "LISTING_FILTER"
          }
        },
        {
          "ref": "Tags.traits.TagBrowse",
          "name": "ListingTags",
          "config": {
            "title": "Categories",
            "allowEdit": false
          }
        },
        {
          "ref": "SavedSearch.traits.SavedSearchManage",
          "name": "ListingSavedSearch",
          "config": {
            "title": "Saved Listing Searches"
          }
        },
        {
          "ref": "Images.traits.UploadedImageUpload",
          "name": "ListingImages",
          "config": {
            "title": "Listing Photos",
            "maxImages": 10.0,
            "maxBytesPerImage": 10485760.0,
            "accept": "image/*"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "ListingStats",
          "config": {
            "metrics": [
              {
                "aggregation": "count",
                "icon": "list",
                "format": "number",
                "label": "Total",
                "variant": "primary"
              },
              {
                "label": "Active",
                "icon": "check-circle",
                "aggregation": "count",
                "format": "number",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ],
                "variant": "success"
              },
              {
                "icon": "tag",
                "variant": "info",
                "format": "number",
                "aggregation": "count",
                "label": "Sold",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "sold"
                  ]
                ]
              },
              {
                "icon": "trending-up",
                "variant": "warning",
                "format": "number",
                "label": "Avg Price",
                "field": "price",
                "aggregation": "avg"
              }
            ],
            "title": "Listings"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowse"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ListingBrowse",
          "linkedEntity": "Listing",
          "config": {
            "itemActions": [
              {
                "event": "VIEW",
                "variant": "ghost",
                "label": "View"
              },
              {
                "variant": "ghost",
                "event": "EDIT",
                "label": "Edit"
              },
              {
                "variant": "secondary",
                "label": "Inquire",
                "event": "INQUIRE"
              },
              {
                "variant": "danger",
                "event": "DELETE",
                "label": "Delete"
              }
            ],
            "cols": 1.0,
            "gap": "sm",
            "fields": [
              {
                "variant": "h3",
                "name": "title",
                "icon": "list"
              },
              {
                "variant": "badge",
                "name": "price"
              },
              {
                "name": "status",
                "variant": "badge"
              },
              {
                "name": "location",
                "variant": "caption"
              },
              {
                "name": "description",
                "variant": "caption"
              }
            ]
          },
          "listens": [
            {
              "event": "GEO_SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "ListingGeoSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "ListingFilter"
              }
            },
            {
              "event": "LISTING_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListingPersistor"
              }
            },
            {
              "event": "LISTING_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListingPersistor"
              }
            },
            {
              "event": "LISTING_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListingPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListingCreate",
          "linkedEntity": "Listing",
          "config": {
            "icon": "plus-circle",
            "title": "New Listing",
            "mode": "create",
            "fields": [
              "title",
              "description",
              "price",
              "location",
              "status"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListingCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListingEdit",
          "linkedEntity": "Listing",
          "config": {
            "icon": "edit",
            "fields": [
              "title",
              "description",
              "price",
              "location",
              "status"
            ],
            "mode": "edit",
            "title": "Edit Listing"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowse"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ListingView",
          "linkedEntity": "Listing",
          "config": {
            "fields": [
              "title",
              "description",
              "price",
              "location",
              "status"
            ],
            "title": "View Listing",
            "icon": "eye",
            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowse"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ListingDelete",
          "linkedEntity": "Listing",
          "config": {
            "title": "Delete Listing",
            "icon": "alert-triangle",
            "alertMessage": "This action cannot be undone.",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListingBrowse"
              }
            }
          ]
        },
        {
          "ref": "Thread.traits.ThreadPostBrowse",
          "name": "ListingInquiryThread",
          "config": {
            "threadRootId": "",
            "flat": true
          }
        },
        {
          "name": "ListingPersistor",
          "category": "lifecycle",
          "linkedEntity": "Listing",
          "emits": [
            {
              "event": "LISTING_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LISTING_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LISTING_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListingCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ListingEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListingDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LISTING_CREATED",
                "name": "Listing Created"
              },
              {
                "key": "LISTING_UPDATED",
                "name": "Listing Updated"
              },
              {
                "key": "LISTING_DELETED",
                "name": "Listing Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Listing",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "LISTING_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Listing",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "LISTING_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Listing",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "LISTING_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ListingsPage",
          "path": "/listings",
          "traits": [
            {
              "ref": "ListingAppLayout"
            },
            {
              "ref": "ListingCatalog"
            },
            {
              "ref": "ListingGeoSearch"
            },
            {
              "ref": "ListingFilter"
            },
            {
              "ref": "ListingTags"
            },
            {
              "ref": "ListingSavedSearch"
            },
            {
              "ref": "ListingImages"
            },
            {
              "ref": "ListingStats"
            },
            {
              "ref": "ListingBrowse"
            },
            {
              "ref": "ListingCreate"
            },
            {
              "ref": "ListingEdit"
            },
            {
              "ref": "ListingView"
            },
            {
              "ref": "ListingDelete"
            },
            {
              "ref": "ListingInquiryThread"
            },
            {
              "ref": "ListingPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "InquiryOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "Inquiry",
        "collection": "inquiries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "listingId",
            "type": "string",
            "required": true
          },
          {
            "name": "fromUserId",
            "type": "string",
            "required": true
          },
          {
            "name": "toUserId",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "message",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "replied",
              "closed"
            ]
          },
          {
            "name": "createdAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "InquiryBrowse",
          "category": "interaction",
          "linkedEntity": "Inquiry",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VIEW",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.listingId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.fromUserId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.toUserId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subject",
                  "type": "string"
                },
                {
                  "name": "row.message",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InquiryLoaded",
              "description": "Fired when the inquiry collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Inquiry]"
                }
              ]
            },
            {
              "event": "InquiryLoadFailed",
              "description": "Fired when the inquiry collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "INQUIRY_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "InquiryPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InquiryLoaded",
                "name": "Inquiry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Inquiry]"
                  }
                ]
              },
              {
                "key": "InquiryLoadFailed",
                "name": "Inquiry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "VIEW",
                "name": "View"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Inquiry",
                    {
                      "emit": {
                        "success": "InquiryLoaded",
                        "failure": "InquiryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading inquiries…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InquiryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "content": "Inquiries",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "action": "CREATE",
                              "label": "New Inquiry",
                              "icon": "edit",
                              "type": "button",
                              "variant": "primary"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-list",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "subject",
                              "variant": "h4",
                              "icon": "message-circle"
                            },
                            {
                              "variant": "body",
                              "name": "message"
                            },
                            {
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "name": "createdAt",
                              "variant": "caption",
                              "format": "date"
                            }
                          ],
                          "itemActions": [
                            {
                              "label": "Open",
                              "event": "VIEW",
                              "variant": "ghost"
                            }
                          ],
                          "variant": "card"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InquiryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load inquiries",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "type": "button"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Inquiry",
                    {
                      "emit": {
                        "success": "InquiryLoaded",
                        "failure": "InquiryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Inquiry",
                    {
                      "emit": {
                        "failure": "InquiryLoadFailed",
                        "success": "InquiryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "InquiryCreate",
          "linkedEntity": "Inquiry",
          "config": {
            "mode": "create",
            "title": "New Inquiry",
            "icon": "plus-circle",
            "fields": [
              "listingId",
              "subject",
              "message",
              "fromUserId",
              "toUserId"
            ]
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "InquiryBrowse"
              }
            }
          ]
        },
        {
          "name": "InquiryPersistor",
          "category": "lifecycle",
          "linkedEntity": "Inquiry",
          "emits": [
            {
              "event": "INQUIRY_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "InquiryCreate"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "INQUIRY_CREATED",
                "name": "Inquiry Created"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Inquiry",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "INQUIRY_CREATED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "InquiriesPage",
          "path": "/inquiries",
          "traits": [
            {
              "ref": "InquiryBrowse"
            },
            {
              "ref": "InquiryCreate"
            },
            {
              "ref": "InquiryPersistor"
            }
          ]
        }
      ]
    }
  ]
}
