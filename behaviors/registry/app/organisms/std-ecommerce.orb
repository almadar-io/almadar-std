                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ProductLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "href": "/products",
                          "icon": "package",
                          "label": "Products"
                        },
                        {
                          "href": "/cart",
                          "icon": "shopping-cart",
                          "label": "Cart"
                        },
                        {
                          "label": "Checkout",
                          "icon": "credit-card",
                          "href": "/checkout"
                        },
                        {
                          "label": "Orders",
                          "href": "/orders",
                          "icon": "clipboard-list"
                        }
                      ],
                      "appName": "EcommerceApp",
                      "children": [
                        {
                          "direction": "vertical",
                          "gap": "lg",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "stack",
                                  "gap": "sm",
                                  "align": "center",
                                  "children": [
                                    {
                                      "name": "package",
                                      "type": "icon"
                                    },
                                    {
                                      "type": "typography",
                                      "content": "Products",
                                      "variant": "h2"
                                    }
                                  ],
                                  "direction": "horizontal"
                                },
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "label": "Create Product",
                                      "action": "CREATE",
                                      "variant": "primary",
                                      "icon": "plus",
                                      "type": "button"
                                    }
                                  ],
                                  "direction": "horizontal"
                                }
                              ],
                              "justify": "between",
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "gap": "md",
                              "itemActions": [
                                {
                                  "label": "View",
                                  "event": "VIEW",
                                  "variant": "ghost"
                                },
                                {
                                  "event": "EDIT",
                                  "label": "Edit",
                                  "variant": "ghost"
                                },
                                {
                                  "event": "DELETE",
                                  "label": "Delete",
                                  "variant": "danger"
                                }
                              ],
                              "type": "data-grid",
                              "entity": "@payload.data",
                              "cols": 3.0,
                              "fields": [
                                {
                                  "variant": "h3",
                                  "name": "name",
                                  "icon": "package"
                                },
                                {
                                  "variant": "badge",
                                  "name": "category"
                                },
                                {
                                  "variant": "h4",
                                  "format": "currency",
                                  "name": "price"
                                },
                                {
                                  "variant": "caption",
                                  "name": "sku"
                                },
                                {
                                  "format": "boolean",
                                  "variant": "body",
                                  "label": "In Stock",
                                  "name": "inStock"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ProductLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load product"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "variant": "primary",
                          "action": "INIT",
                          "type": "button",
                          "label": "Retry",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductCreate",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "PRODUCT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Product]"
                }
              ]
            },
            {
              "event": "ProductSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ProductBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PRODUCT_CREATED",
                "name": "Product Created"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Product]"
                  }
                ]
              },
              {
                "key": "ProductSaveFailed",
                "name": "Product save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductSaved",
                "name": "Product saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
