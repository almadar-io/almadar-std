                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Add Item",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "fields": [
                            "productName",
                            "quantity",
                            "unitPrice",
                            "totalPrice"
                          ],
                          "mode": "create",
                          "cancelEvent": "CLOSE",
                          "submitEvent": "SAVE"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
