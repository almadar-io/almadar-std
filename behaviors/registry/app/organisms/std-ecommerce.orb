                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.paymentMethod",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.orderTotal",
                  "type": "number"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
