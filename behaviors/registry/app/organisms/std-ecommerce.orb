                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.productName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.quantity",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.unitPrice",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.totalPrice",
                  "type": "number"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
