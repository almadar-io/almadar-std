            {
              "event": "CartItemLoaded",
              "description": "Fired when CartItem finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CartItem]"
                }
              ]
            },
            {
              "event": "CartItemLoadFailed",
