                              ],
                              "type": "data-grid"
                            },
                            {
                              "justify": "end",
                              "children": [
                                {
                                  "variant": "ghost",
                                  "type": "button",
                                  "label": "Back to Cart",
                                  "action": "BACK_TO_CART",
                                  "icon": "arrow-left"
                                },
                                {
                                  "icon": "check",
                                  "label": "Confirm Order",
                                  "variant": "primary",
                                  "type": "button",
                                  "action": "CONFIRM_ORDER"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "sm"
                            }
                          ]
                        }
                      ],
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "package",
                          "label": "Products",
                          "href": "/products"
                        },
                        {
                          "icon": "shopping-cart",
                          "href": "/cart",
                          "label": "Cart"
                        },
                        {
                          "icon": "credit-card",
                          "label": "Checkout",
                          "href": "/checkout"
                        },
                        {
                          "label": "Orders",
                          "href": "/orders",
                          "icon": "clipboard-list"
                        }
                      ],
                      "appName": "EcommerceApp"
                    }
                  ]
                ]
              },
              {
                "from": "checkout",
                "to": "browsing",
                "event": "BACK_TO_CART",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "checkout",
                "to": "browsing",
                "event": "CONFIRM_ORDER",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/products",
                          "icon": "package",
                          "label": "Products"
                        },
                        {
                          "label": "Cart",
                          "icon": "shopping-cart",
                          "href": "/cart"
                        },
                        {
                          "icon": "credit-card",
                          "href": "/checkout",
                          "label": "Checkout"
                        },
                        {
                          "icon": "clipboard-list",
                          "label": "Orders",
                          "href": "/orders"
                        }
                      ],
                      "children": [
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "name": "check-circle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Order Confirmed",
                              "variant": "h2"
                            },
                            {
                              "variant": "body",
                              "content": "Your order has been placed successfully.",
                              "type": "typography"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "INIT",
                              "label": "Continue Shopping"
                            }
                          ],
                          "type": "stack",
                          "gap": "lg",
                          "align": "center"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "EcommerceApp"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "CartItemAddItem",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "CartItemLoadFailed",
              "description": "Fired when CartItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemLoaded",
              "description": "Fired when CartItem finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CartItem]"
                }
              ]
            },
            {
              "event": "CartItemSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ADD_ITEM",
              "triggers": "ADD_ITEM",
              "source": {
                "kind": "trait",
                "trait": "CartItemCartBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_ITEM",
                "name": "Add Item"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CartItem]"
                  }
                ]
              },
              {
                "key": "CartItemSaveFailed",
                "name": "CartItem save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemSaved",
                "name": "CartItem saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "ADD_ITEM",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "content": "Add Item",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "productName",
                            "quantity",
                            "unitPrice",
                            "totalPrice"
                          ],
                          "type": "form-section",
                          "cancelEvent": "CLOSE",
                          "mode": "create",
                          "submitEvent": "SAVE"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "CartItem",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "CartItemSaveFailed",
                        "success": "CartItemSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "CartItemRemoveConfirm",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "emits": [
            {
              "event": "CartItemDeleteFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemDeleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemLoadFailed",
              "description": "Fired when CartItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CartItemLoaded",
              "description": "Fired when CartItem finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CartItem]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "REQUEST_REMOVE",
              "triggers": "REQUEST_REMOVE",
              "source": {
                "kind": "trait",
                "trait": "CartItemCartBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "REQUEST_REMOVE",
                "name": "Request Remove",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_REMOVE",
                "name": "Confirm Remove"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CartItemDeleteFailed",
                "name": "CartItem delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemDeleted",
                "name": "CartItem deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CartItem]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "REQUEST_REMOVE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "Remove Item",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Are you sure you want to remove this item from your cart?",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "justify": "end",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "action": "CANCEL",
                              "label": "Cancel",
                              "variant": "ghost"
                            },
                            {
                              "icon": "check",
                              "action": "CONFIRM_REMOVE",
                              "type": "button",
                              "label": "Remove",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_REMOVE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CartItem",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "success": "CartItemDeleted",
                        "failure": "CartItemDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Cart",
          "path": "/cart",
          "traits": [
            {
              "ref": "CartItemCartBrowse"
            },
            {
              "ref": "CartItemAddItem"
            }
          ]
        }
      ]
    },
    {
      "name": "CheckoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-service-stripe",
          "as": "Stripe"
        }
      ],
      "entity": {
        "name": "Checkout",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "required": true
          },
          {
            "name": "shippingAddress",
            "type": "string",
            "required": true
          },
          {
            "name": "orderTotal",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft"
          }
        ]
      },
      "traits": [
        {
          "ref": "Stripe.traits.ServiceStripeStripe",
          "name": "CheckoutPayment",
          "config": {
            "amount": 0.0,
            "currency": "usd",
            "uiTrait": "@trait.CheckoutPaymentForm",
            "metadata": {}
          },
          "listens": [
            {
              "event": "CREATE_PAYMENT",
              "triggers": "CREATE_PAYMENT",
              "source": {
                "kind": "trait",
                "trait": "CheckoutPaymentForm"
              }
            }
          ]
        },
        {
          "name": "CheckoutPaymentForm",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE_PAYMENT",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "alert",
                          "message": "Enter card details to complete your order.",
                          "variant": "info"
                        },
                        {
                          "placeholder": "Card number",
                          "inputType": "text",
                          "type": "input"
                        },
                        {
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "MM/YY",
                              "inputType": "text"
                            },
                            {
                              "inputType": "text",
                              "type": "input",
                              "placeholder": "CVC"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "action": "CREATE_PAYMENT",
                          "type": "button",
                          "variant": "primary",
                          "icon": "credit-card",
                          "label": "Pay now"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "CheckoutWizard",
          "category": "interaction",
          "linkedEntity": "Checkout",
          "emits": [
            {
              "event": "ORDER_PLACED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CheckoutSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CheckoutSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CHECKOUT_STARTED",
              "triggers": "INIT",
              "source": {
                "kind": "orbital",
                "orbital": "CartItemOrbital",
                "trait": "CartItemCartBrowse"
              }
            },
            {
              "event": "ServiceStripeStripeCompleted",
              "triggers": "PAYMENT_DONE",
              "source": {
                "kind": "trait",
                "trait": "CheckoutPayment"
              }
            },
            {
              "event": "ServiceStripeStripeFailed",
              "triggers": "PAYMENT_FAILED",
              "source": {
                "kind": "trait",
                "trait": "CheckoutPayment"
              }
            },
            {
              "event": "ServiceStripeLoaded",
              "triggers": "NOOP",
              "source": {
                "kind": "trait",
                "trait": "CheckoutPayment"
              }
            },
            {
              "event": "ServiceStripeLoadFailed",
              "triggers": "NOOP",
              "source": {
                "kind": "trait",
                "trait": "CheckoutPayment"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "step1",
                "isInitial": true
              },
              {
                "name": "step2"
              },
              {
                "name": "step3"
              },
              {
                "name": "review"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NEXT",
                "name": "Next",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PREV",
                "name": "Prev"
              },
              {
                "key": "PAYMENT_DONE",
                "name": "Payment Done",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "ORDER_PLACED",
                "name": "Order Placed"
              },
              {
                "key": "CheckoutSaved",
                "name": "Checkout saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CheckoutSaveFailed",
                "name": "Checkout save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAYMENT_FAILED",
                "name": "Payment Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "NOOP",
                "name": "Noop",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
