            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "OrderRecordBrowse",
          "category": "interaction",
          "linkedEntity": "OrderRecord",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
