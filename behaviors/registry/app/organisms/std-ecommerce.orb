                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Remove Item",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "Are you sure you want to remove this item from your cart?"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "variant": "ghost",
                              "action": "CANCEL"
                            },
                            {
                              "icon": "check",
                              "action": "CONFIRM_REMOVE",
                              "type": "button",
                              "variant": "danger",
                              "label": "Remove"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_REMOVE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CartItem",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "success": "CartItemDeleted",
                        "failure": "CartItemDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
