                      "emit": {
                        "success": "CartItemLoaded",
                        "failure": "CartItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "REQUEST_REMOVE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
