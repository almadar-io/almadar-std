              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "checkout"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CartItem]"
                  }
                ]
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PROCEED_CHECKOUT",
                "name": "Proceed Checkout"
              },
              {
                "key": "BACK_TO_CART",
                "name": "Back To Cart"
              },
              {
                "key": "CONFIRM_ORDER",
                "name": "Confirm Order"
              },
              {
                "key": "CHECKOUT_STARTED",
