          },
          {
            "name": "productName",
            "type": "string",
            "required": true
          },
          {
            "name": "quantity",
            "type": "number",
            "required": true
          },
          {
            "name": "unitPrice",
            "type": "number",
            "required": true
          },
          {
            "name": "totalPrice",
            "type": "number"
          },
          {
