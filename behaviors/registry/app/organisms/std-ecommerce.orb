{
  "name": "std-ecommerce",
  "version": "1.0.0",
  "description": "std-ecommerce as a Function",
  "orbitals": [
    {
      "name": "ProductOrbital",
      "entity": {
        "name": "Product",
        "collection": "products",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "sku",
            "type": "string"
          },
          {
            "name": "inStock",
            "type": "boolean",
            "default": true
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ProductBrowse",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "ADD_TO_CART",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE"
            },
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.sku",
                  "type": "string"
                },
                {
                  "name": "row.inStock",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.sku",
                  "type": "string"
                },
                {
                  "name": "row.inStock",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.price",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.category",
                  "type": "string"
                },
                {
                  "name": "row.sku",
                  "type": "string"
                },
                {
                  "name": "row.inStock",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Product]"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductUpdated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductUpdateFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductDeleted",
