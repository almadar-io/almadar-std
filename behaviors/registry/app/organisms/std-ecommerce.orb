              "triggers": "ADD_ITEM",
              "source": {
                "kind": "trait",
                "trait": "CartItemCartBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADD_ITEM",
                "name": "Add Item"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemLoadFailed",
                "name": "CartItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemLoaded",
                "name": "CartItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CartItem]"
                  }
                ]
              },
              {
                "key": "CartItemSaveFailed",
                "name": "CartItem save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CartItemSaved",
                "name": "CartItem saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "ADD_ITEM",
                "effects": [
                  [
                    "fetch",
                    "CartItem",
                    {
                      "emit": {
                        "failure": "CartItemLoadFailed",
                        "success": "CartItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
