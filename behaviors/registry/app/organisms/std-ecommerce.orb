          {
            "name": "quantity",
            "type": "number",
            "required": true
          },
          {
            "name": "unitPrice",
            "type": "number",
            "required": true
          },
          {
            "name": "totalPrice",
            "type": "number"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CartItemCartBrowse",
          "category": "interaction",
