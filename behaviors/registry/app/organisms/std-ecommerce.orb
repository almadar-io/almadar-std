{
  "name": "std-ecommerce",
  "version": "2.0.0",
  "description": "std-ecommerce as a Function — products with images, cart icon in top bar, Stripe-backed checkout.",
  "orbitals": [
    {
      "name": "ProductOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Product",
        "collection": "products",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "imageUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "sku",
            "type": "string"
          },
          {
            "name": "inStock",
            "type": "boolean",
            "default": true
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ProductAppLayout",
          "config": {
            "searchEvent": "PRODUCT_SEARCH",
            "topBarActions": [
              {
                "event": "CART_OPEN",
                "icon": "shopping-cart",
                "label": "Cart"
              }
            ],
            "notifications": [],
            "notificationClickEvent": "PRODUCT_NOTIFICATIONS_OPEN",
            "appName": "EcommerceApp",
            "contentTrait": "@trait.ProductCatalog",
            "navItems": [
              {
                "href": "/products",
                "label": "Products",
                "icon": "package"
              },
              {
                "href": "/cart",
                "icon": "shopping-cart",
                "label": "Cart"
              },
              {
                "href": "/checkout",
                "icon": "credit-card",
                "label": "Checkout"
              },
              {
                "label": "Orders",
                "icon": "clipboard-list",
                "href": "/orders"
              }
            ]
          },
          "events": {
            "SEARCH": "PRODUCT_SEARCH",
            "NOTIFY_CLICK": "PRODUCT_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "ProductCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PRODUCT_SEARCH",
              "triggers": "PRODUCT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ProductAppLayout"
              }
            },
            {
              "event": "PRODUCT_NOTIFICATIONS_OPEN",
              "triggers": "PRODUCT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ProductAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PRODUCT_SEARCH",
                "name": "Product Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PRODUCT_NOTIFICATIONS_OPEN",
                "name": "Product Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "package",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Products"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "Create Product",
                                  "action": "CREATE",
                                  "variant": "primary",
                                  "icon": "plus",
                                  "type": "button"
                                }
                              ]
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "justify": "between",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ProductBrowseList"
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "PRODUCT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "PRODUCT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "className": "py-8",
                      "children": [
                        {
                          "name": "bell",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "No notifications"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "You're all caught up."
                        },
                        {
                          "action": "INIT",
                          "variant": "ghost",
                          "type": "button",
                          "label": "Back to products"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ProductBrowseList",
          "linkedEntity": "Product",
          "config": {
            "cols": 3.0,
            "imageField": "imageUrl",
            "gap": "md",
            "fields": [
              {
                "icon": "package",
                "variant": "h3",
                "name": "name"
              },
              {
                "name": "category",
                "variant": "badge"
              },
              {
                "format": "currency",
                "variant": "h4",
                "name": "price"
              },
              {
                "variant": "caption",
                "name": "sku"
              },
              {
                "label": "In Stock",
                "variant": "body",
                "name": "inStock",
                "format": "boolean"
              }
            ],
            "itemActions": [
              {
                "event": "VIEW",
                "variant": "ghost",
                "label": "View"
              },
              {
                "event": "EDIT",
                "label": "Edit",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "variant": "danger",
                "label": "Delete"
              }
            ]
          },
          "listens": [
            {
              "event": "PRODUCT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ProductCreate"
              }
            },
            {
              "event": "PRODUCT_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ProductEdit"
              }
            },
            {
              "event": "PRODUCT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ProductDelete"
              }
            }
          ]
        },
        {
          "name": "ProductCreate",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "PRODUCT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Product]"
                }
              ]
            },
            {
              "event": "ProductSaveFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductSaved",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ProductCatalog"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PRODUCT_CREATED",
                "name": "Product Created"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Product]"
                  }
                ]
              },
              {
                "key": "ProductSaveFailed",
                "name": "Product save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductSaved",
                "name": "Product saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Create Product"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cancelEvent": "CLOSE",
                          "submitEvent": "SAVE",
                          "mode": "create",
                          "fields": [
                            "name",
                            "description",
                            "price",
                            "category",
                            "sku",
                            "inStock"
                          ],
                          "type": "form-section"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Product",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ProductSaved",
                        "failure": "ProductSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "PRODUCT_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductEdit",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "PRODUCT_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Product]"
                }
              ]
            },
            {
              "event": "ProductUpdateFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductUpdated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ProductView"
              }
            },
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ProductBrowseList"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Product"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PRODUCT_UPDATED",
                "name": "Product Updated"
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Product]"
                  }
                ]
              },
              {
                "key": "ProductUpdateFailed",
                "name": "Product update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductUpdated",
                "name": "Product updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Edit Product"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "entity": "@payload.row",
                          "fields": [
                            "name",
                            "description",
                            "price",
                            "category",
                            "sku",
                            "inStock"
                          ],
                          "mode": "edit",
                          "type": "form-section"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Product",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "ProductUpdateFailed",
                        "success": "ProductUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "PRODUCT_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductView",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Product]"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ProductBrowseList"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Product]"
                  }
                ]
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.description",
                    ""
                  ],
                  [
                    "set",
                    "@entity.inStock",
                    true
                  ],
                  [
                    "set",
                    "@entity.name",
                    ""
                  ],
                  [
                    "set",
                    "@entity.price",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.sku",
                    ""
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "content": "Name",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.name"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Description",
                              "type": "typography"
                            },
                            {
                              "content": "@entity.description",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Price",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.price"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "content": "Category",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "content": "@entity.category",
                              "type": "typography",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Sku",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.sku"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "In Stock"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.inStock"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "justify": "end",
                          "children": [
                            {
                              "action": "EDIT",
                              "label": "Edit",
                              "type": "button",
                              "variant": "primary",
                              "icon": "edit"
                            },
                            {
                              "label": "Close",
                              "action": "CLOSE",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductDelete",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
            {
              "event": "PRODUCT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductDeleteFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductDeleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoadFailed",
              "description": "Fired when Product fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ProductLoaded",
              "description": "Fired when Product finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Product]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ProductBrowseList"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "PRODUCT_DELETED",
                "name": "Product Deleted"
              },
              {
                "key": "ProductDeleteFailed",
                "name": "Product delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductDeleted",
                "name": "Product deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Product]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "variant": "h3",
                              "content": "Delete Product",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "error",
                          "message": "This action cannot be undone.",
                          "type": "alert"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "label": "Cancel",
                              "action": "CANCEL",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "icon": "check",
                              "type": "button",
                              "variant": "danger",
                              "label": "Delete",
                              "action": "CONFIRM_DELETE"
                            }
                          ],
                          "justify": "end",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Product",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "ProductDeleteFailed",
                        "success": "ProductDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "PRODUCT_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ProductsPage",
          "path": "/products",
          "traits": [
            {
              "ref": "ProductAppLayout"
            },
            {
              "ref": "ProductCatalog"
            },
            {
              "ref": "ProductBrowseList"
            },
            {
              "ref": "ProductCreate"
            },
            {
              "ref": "ProductEdit"
            },
            {
              "ref": "ProductView"
            },
            {
              "ref": "ProductDelete"
            }
          ]
        }
      ]
    },
    {
      "name": "CartItemOrbital",
      "entity": {
        "name": "CartItem",
        "collection": "cartitems",
