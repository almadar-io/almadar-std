                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "OrderRecordDelete",
          "category": "interaction",
          "linkedEntity": "OrderRecord",
          "emits": [
            {
              "event": "ORDER_RECORD_DELETED"
            },
            {
              "event": "OrderRecordDeleteFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderRecordDeleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderRecordLoadFailed",
              "description": "Fired when OrderRecord fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderRecordLoaded",
              "description": "Fired when OrderRecord finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[OrderRecord]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "OrderRecordBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ORDER_RECORD_DELETED",
                "name": "Order Record Deleted"
              },
              {
                "key": "OrderRecordDeleteFailed",
                "name": "OrderRecord delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderRecordDeleted",
                "name": "OrderRecord deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderRecordLoadFailed",
                "name": "OrderRecord load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderRecordLoaded",
                "name": "OrderRecord loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[OrderRecord]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OrderRecord",
                    {
                      "emit": {
                        "success": "OrderRecordLoaded",
                        "failure": "OrderRecordLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "OrderRecord",
                    {
                      "emit": {
                        "success": "OrderRecordLoaded",
                        "failure": "OrderRecordLoadFailed"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "Delete OrderRecord",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "This action cannot be undone.",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "action": "CANCEL",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Cancel"
                            },
                            {
                              "action": "CONFIRM_DELETE",
                              "icon": "check",
                              "label": "Delete",
                              "type": "button",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "OrderRecord",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "success": "OrderRecordDeleted",
                        "failure": "OrderRecordDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "OrderRecord",
                    {
                      "emit": {
                        "failure": "OrderRecordLoadFailed",
                        "success": "OrderRecordLoaded"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ORDER_RECORD_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "OrderRecord",
                    {
                      "emit": {
                        "failure": "OrderRecordLoadFailed",
                        "success": "OrderRecordLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "OrderRecord",
                    {
                      "emit": {
                        "failure": "OrderRecordLoadFailed",
                        "success": "OrderRecordLoaded"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Orders",
          "path": "/orders",
          "traits": [
            {
              "ref": "OrderRecordBrowse"
            },
            {
              "ref": "OrderRecordCreate"
            },
            {
              "ref": "OrderRecordEdit"
            },
            {
              "ref": "OrderRecordView"
            },
            {
              "ref": "OrderRecordDelete"
            }
          ]
        }
      ]
    }
  ]
}
