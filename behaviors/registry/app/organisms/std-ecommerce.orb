            {
              "event": "REQUEST_REMOVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.productName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.quantity",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.unitPrice",
                  "type": "number",
                  "required": true
                },
                {
