    {
      "name": "DriverPanelOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-driver",
          "as": "Driver"
        }
      ],
      "entity": {
        "name": "Driver",
        "collection": "drivers",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "licenseNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "licenseClass",
            "type": "string",
            "default": "C",
            "values": [
              "A",
              "B",
              "C",
              "CDL-A",
              "CDL-B",
              "CDL-C"
            ]
          },
          {
            "name": "licenseExpiresAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "hiredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "on-leave",
              "terminated",
              "suspended"
            ]
          },
          {
            "name": "assignedVehicleId",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "DriverAppLayout",
          "config": {
            "appName": "Fleet Management",
            "navItems": [
              {
                "icon": "truck",
                "label": "Fleets",
                "href": "/fleets"
              },
              {
                "href": "/vehicles",
                "icon": "truck",
                "label": "Vehicles"
              },
              {
                "label": "Drivers",
                "href": "/drivers",
                "icon": "user"
              },
              {
                "href": "/telematics",
                "label": "Telematics",
                "icon": "activity"
              }
            ],
            "searchEvent": "DRIVER_SEARCH",
            "notifications": [],
            "notificationClickEvent": "DRIVER_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.DriverPanel"
          },
          "events": {
            "SEARCH": "DRIVER_SEARCH",
            "NOTIFY_CLICK": "DRIVER_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "DriverPanel",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "user",
                              "type": "icon"
                            },
                            {
                              "content": "Drivers",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.DriverView"
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Driver.traits.DriverRoster",
          "name": "DriverView",
          "config": {
            "title": "Driver Roster"
          }
        }
      ],
      "pages": [
        {
          "name": "DriversPage",
          "path": "/drivers",
          "traits": [
            {
              "ref": "DriverAppLayout"
            },
            {
              "ref": "DriverPanel"
            },
            {
              "ref": "DriverView"
            }
          ]
        }
      ]
    },
    {
      "name": "TelematicsEventPanelOrbital",
