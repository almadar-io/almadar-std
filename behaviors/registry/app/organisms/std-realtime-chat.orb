            },
            {
              "event": "ChannelLoaded",
              "description": "Fired when Channel finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Channel]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CHANNEL_DELETED",
                "name": "Channel Deleted"
              },
              {
                "key": "ChannelDeleteFailed",
                "name": "Channel delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelDeleted",
                "name": "Channel deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelLoadFailed",
                "name": "Channel load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelLoaded",
                "name": "Channel loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[Channel]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "Channel"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Channel",
                    {
                      "emit": {
                        "failure": "ChannelLoadFailed",
                        "success": "ChannelLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Delete Channel"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "This action cannot be undone.",
                          "variant": "error"
                        },
                        {
                          "justify": "end",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "action": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "icon": "check",
                              "label": "Delete",
                              "type": "button",
                              "action": "CONFIRM_DELETE",
                              "variant": "danger"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Channel",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "ChannelDeleteFailed",
                        "success": "ChannelDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Channel"
                  ],
                  [
                    "emit",
                    "CHANNEL_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Channel"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "ref",
                    "Channel"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
