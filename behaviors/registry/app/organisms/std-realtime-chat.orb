{
  "name": "std-realtime-chat",
  "version": "1.0.0",
  "description": "std-realtime-chat as a Function",
  "orbitals": [
    {
      "name": "ChatMessageOrbital",
      "entity": {
        "name": "ChatMessage",
        "collection": "chatmessages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sender",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "channel",
            "type": "string"
          },
          {
            "name": "timestamp",
            "type": "datetime"
          }
        ]
      },
      "traits": [
        {
          "name": "ChatMessageBrowse",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "ChatMessageLoaded",
              "description": "Fired when ChatMessage finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ChatMessage]"
                }
              ]
            },
            {
              "event": "ChatMessageLoadFailed",
              "description": "Fired when ChatMessage fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatMessageSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatMessageSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChannelSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChannelSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChannelUpdated",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChannelUpdateFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChannelDeleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChannelDeleteFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEND",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChatMessageCompose"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ChatMessageLoaded",
                "name": "ChatMessage loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ChatMessage]"
                  }
                ]
              },
              {
                "key": "ChatMessageLoadFailed",
                "name": "ChatMessage load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChatMessageSaved",
                "name": "ChatMessage saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChatMessageSaveFailed",
                "name": "ChatMessage save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelSaved",
                "name": "Channel saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelSaveFailed",
                "name": "Channel save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelUpdated",
                "name": "Channel updated",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelUpdateFailed",
                "name": "Channel update failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelDeleted",
                "name": "Channel deleted",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChannelDeleteFailed",
                "name": "Channel delete failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ChatMessage"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "success": "ChatMessageLoaded",
                        "failure": "ChatMessageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ChatMessageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "justify": "between",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "message-circle"
                                    },
                                    {
                                      "content": "Chat",
                                      "type": "typography",
                                      "variant": "h2"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "align": "center"
                                },
                                {
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "variant": "primary",
                                      "type": "button",
                                      "action": "COMPOSE",
                                      "icon": "edit",
                                      "label": "Compose"
                                    }
                                  ],
                                  "gap": "sm"
                                }
                              ],
                              "gap": "md",
                              "align": "center"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "senderField": "sender",
                              "itemActions": [
                                {
                                  "event": "VIEW",
                                  "variant": "ghost",
                                  "label": "View"
                                }
                              ],
                              "entity": "@payload.data",
                              "columns": [
                                {
                                  "variant": "h4",
                                  "name": "sender"
                                },
                                {
                                  "variant": "body",
                                  "name": "content"
                                },
                                {
                                  "format": "date",
                                  "variant": "caption",
                                  "name": "timestamp"
                                }
                              ],
                              "variant": "message",
                              "fields": [],
                              "type": "data-list",
                              "gap": "sm"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "className": "max-w-5xl mx-auto w-full",
                          "gap": "lg"
                        }
                      ],
                      "appName": "Realtime Chat",
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "icon": "layout-list",
                          "href": "/chat",
                          "label": "Chat"
                        },
                        {
                          "label": "Channels",
                          "href": "/channels",
                          "icon": "hash"
                        },
                        {
                          "href": "/online",
                          "label": "Online",
                          "icon": "layout-list"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ChatMessageLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load chatmessage",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "type": "button",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "label": "Retry"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ChatMessageCompose",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "SEND"
            },
            {
              "event": "ChatMessageLoadFailed",
              "description": "Fired when ChatMessage fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatMessageLoaded",
              "description": "Fired when ChatMessage finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ChatMessage]"
                }
              ]
            },
            {
              "event": "ChatMessageSaveFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatMessageSaved",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ChatMessageLoadFailed",
                "name": "ChatMessage load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChatMessageLoaded",
                "name": "ChatMessage loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ChatMessage]"
                  }
                ]
              },
              {
                "key": "ChatMessageSaveFailed",
                "name": "ChatMessage save failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChatMessageSaved",
                "name": "ChatMessage saved",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "ChatMessage"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "edit",
                              "type": "icon"
                            },
                            {
                              "content": "New ChatMessage",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "submitEvent": "SEND",
                          "cancelEvent": "CLOSE",
                          "mode": "create",
                          "fields": [
                            "sender",
                            "content",
                            "channel",
                            "timestamp"
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ChatMessage",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "ChatMessageSaveFailed",
                        "success": "ChatMessageSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ChatMessageView",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "ChatMessageLoaded",
              "description": "Fired when ChatMessage finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[ChatMessage]"
                }
              ]
            },
            {
              "event": "ChatMessageLoadFailed",
              "description": "Fired when ChatMessage fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payload": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ChatMessageLoaded",
                "name": "ChatMessage loaded",
                "payload": [
                  {
                    "name": "data",
                    "type": "[ChatMessage]"
                  }
                ]
              },
              {
                "key": "ChatMessageLoadFailed",
                "name": "ChatMessage load failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "ChatMessage"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "failure": "ChatMessageLoadFailed",
                        "success": "ChatMessageLoaded"
                      },
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "eye"
                            },
                            {
                              "content": "@entity.sender",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Sender",
                              "type": "typography"
                            },
                            {
                              "content": "@entity.sender",
                              "variant": "body",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "content": "Content",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "content": "@entity.content",
                              "variant": "body",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "content": "Channel",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "content": "@entity.channel",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Timestamp",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.timestamp",
                              "variant": "body"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Close",
                              "action": "CLOSE",
                              "variant": "ghost"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ChatPage",
          "path": "/chat",
          "traits": [
            {
              "ref": "ChatMessageBrowse"
            },
            {
              "ref": "ChatMessageCompose"
            },
            {
              "ref": "ChatMessageView"
            }
          ]
        }
      ]
    },
    {
      "name": "ChannelOrbital",
      "entity": {
        "name": "Channel",
        "collection": "channels",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "memberCount",
            "type": "number"
          },
          {
            "name": "isPrivate",
            "type": "boolean"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ChannelBrowse",
          "category": "interaction",
          "linkedEntity": "Channel",
          "emits": [
            {
              "event": "ChannelLoaded",
              "description": "Fired when Channel finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "data",
                  "type": "[Channel]"
                }
              ]
            },
            {
              "event": "ChannelLoadFailed",
              "description": "Fired when Channel fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CHANNEL_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChannelCreate"
