{
  "name": "std-realtime-chat",
  "version": "2.0.0",
  "description": "Realtime chat: channels, messages, presence. Pick for Slack-style team messaging.",
  "orbitals": [
    {
      "name": "ChatMessageOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        },
        {
          "from": "std/behaviors/std-service-storage",
          "as": "Storage"
        },
        {
          "from": "std/behaviors/std-service-twilio",
          "as": "Twilio"
        }
      ],
      "entity": {
        "name": "ChatMessage",
        "collection": "chatmessages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sender",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "channel",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "datetime"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ChatAppLayout",
          "config": {
            "navItems": [
              {
                "icon": "message-circle",
                "label": "Chat",
                "href": "/chat"
              },
              {
                "href": "/channels",
                "label": "Channels",
                "icon": "hash"
              },
              {
                "icon": "users",
                "href": "/online",
                "label": "Online"
              }
            ],
            "appName": "Realtime Chat",
            "searchEvent": "CHAT_SEARCH",
            "notificationClickEvent": "CHAT_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.ChatRoom",
            "notifications": []
          },
          "events": {
            "NOTIFY_CLICK": "CHAT_NOTIFICATIONS_OPEN",
            "SEARCH": "CHAT_SEARCH"
          }
        },
        {
          "name": "ChatRoom",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE_CHANNEL",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CHAT_SEARCH",
              "triggers": "CHAT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ChatAppLayout"
              }
            },
            {
              "event": "CHAT_NOTIFICATIONS_OPEN",
              "triggers": "CHAT_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "ChatAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHAT_SEARCH",
                "name": "Chat Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHAT_NOTIFICATIONS_OPEN",
                "name": "Chat Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE_CHANNEL",
                "name": "Create Channel"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "type": "typography",
                                  "content": "Chat",
                                  "variant": "h2"
                                }
                              ],
                              "align": "center",
                              "type": "stack"
                            },
                            {
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "icon": "plus",
                                  "type": "button",
                                  "label": "New Channel",
                                  "action": "CREATE_CHANNEL",
                                  "variant": "primary"
                                }
                              ],
                              "direction": "horizontal"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ChatSearch",
                        "@trait.ChatStats",
                        {
                          "type": "divider"
                        },
                        "@trait.ChatMessageBrowse"
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CHAT_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "CHAT_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "content": "No notifications",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "You're all caught up."
                        },
                        {
                          "variant": "ghost",
                          "label": "Back to chat",
                          "type": "button",
                          "action": "INIT"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "ChatSearch",
          "config": {
            "event": "CHAT_SEARCH",
            "placeholder": "Search messages…"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "ChatStats",
          "config": {
            "title": "Chat Activity",
            "metrics": [
              {
                "icon": "message-circle",
                "label": "Messages",
                "variant": "primary",
                "format": "number",
                "aggregation": "count"
              },
              {
                "aggregation": "count",
                "label": "Active Channels",
                "format": "number",
                "icon": "hash",
                "variant": "info"
              },
              {
                "aggregation": "count",
                "icon": "user",
                "variant": "success",
                "label": "Top Author",
                "format": "number"
              }
            ]
          },
          "listens": [
            {
              "event": "ChatMessageLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "ChatMessageBrowse"
              }
            }
          ]
        },
        {
          "name": "ChatMessageBrowse",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "COMPOSE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "VIEW",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sender",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.content",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.channel",
                  "type": "string"
                },
                {
                  "name": "row.timestamp",
                  "type": "datetime"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatMessageLoaded",
              "description": "Fired when ChatMessage finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ChatMessage]"
                }
              ]
            },
            {
              "event": "ChatMessageLoadFailed",
              "description": "Fired when ChatMessage fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "CHAT_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "ChatSearch"
              }
            },
            {
              "event": "MESSAGE_SAVED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChatMessagePersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHAT_SEARCH",
                "name": "Chat Search"
              },
              {
                "key": "ChatMessageLoaded",
                "name": "ChatMessage loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ChatMessage]"
                  }
                ]
              },
              {
                "key": "ChatMessageLoadFailed",
                "name": "ChatMessage load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "VIEW",
                "name": "View"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "success": "ChatMessageLoaded",
                        "failure": "ChatMessageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CHAT_SEARCH",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "emit": {
                        "failure": "ChatMessageLoadFailed",
                        "success": "ChatMessageLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ChatMessageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "senderField": "sender",
                          "type": "data-list",
                          "entity": "@payload.data",
                          "gap": "sm",
                          "variant": "message",
                          "fields": [
                            {
                              "variant": "h4",
                              "name": "sender"
                            },
                            {
                              "name": "content",
                              "variant": "body"
                            },
                            {
                              "name": "timestamp",
                              "variant": "caption",
                              "format": "date"
                            }
                          ],
                          "itemActions": [
                            {
                              "label": "View",
                              "variant": "ghost",
                              "event": "VIEW"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "label": "Compose",
                              "icon": "edit",
                              "variant": "primary",
                              "type": "button",
                              "action": "COMPOSE"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ChatMessageLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load messages",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "type": "button",
                          "label": "Retry",
                          "action": "INIT"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ChatMessageCompose",
          "linkedEntity": "ChatMessage",
          "config": {
            "icon": "edit",
            "fields": [
              "sender",
              "content",
              "channel",
              "timestamp"
            ],
            "mode": "create",
            "title": "New Message"
          },
          "events": {
            "OPEN": "COMPOSE"
          },
          "listens": [
            {
              "event": "COMPOSE",
              "triggers": "COMPOSE",
              "source": {
                "kind": "trait",
                "trait": "ChatMessageBrowse"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ChatMessageView",
          "linkedEntity": "ChatMessage",
          "config": {
            "icon": "eye",
            "fields": [
              "sender",
              "content",
              "channel",
              "timestamp"
            ],
            "title": "View Message",
            "mode": "edit"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ChatMessageBrowse"
              }
            }
          ]
        },
        {
          "name": "ChatMessagePersistor",
          "category": "lifecycle",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "MESSAGE_SAVED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ChatMessageCompose"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "MESSAGE_SAVED",
                "name": "Message Saved"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ChatMessage",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "MESSAGE_SAVED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ChatMessageAttachment",
          "category": "interaction",
          "emits": [
            {
              "event": "AttachmentUploaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "url",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AttachmentUploadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              },
              {
                "name": "uploading"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  },
                  {
                    "name": "file",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AttachmentUploaded",
                "name": "Attachment uploaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "url",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AttachmentUploadFailed",
                "name": "Attachment upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "paperclip",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Attach File"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "inputType": "text",
                          "type": "input",
                          "placeholder": "Choose file…"
                        },
                        {
                          "label": "Upload",
                          "type": "button",
                          "variant": "primary",
                          "icon": "upload",
                          "action": "UPLOAD"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "file": "@payload.file",
                      "bucket": "chat-attachments",
                      "maxSize": 10485760.0,
                      "acl": "private"
                    },
                    {
                      "emit": {
                        "success": "AttachmentUploaded",
                        "failure": "AttachmentUploadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Uploading…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "ready",
                "event": "AttachmentUploaded",
                "effects": [
                  [
                    "notify",
                    "success",
                    "Attachment uploaded"
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "ready",
                "event": "AttachmentUploadFailed",
                "effects": [
                  [
                    "notify",
                    "error",
                    "Upload failed"
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ChatSmsNotify",
          "category": "interaction",
          "emits": [
            {
              "event": "ChatSmsSent",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ChatSmsFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              },
              {
                "name": "sending"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SMS_NOTIFY",
                "name": "Sms Notify",
                "payloadSchema": [
                  {
                    "name": "recipient",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "body",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ChatSmsSent",
                "name": "Chat sms sent",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ChatSmsFailed",
                "name": "Chat sms failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "bell"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Send SMS Notify"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "action": "SMS_NOTIFY",
                          "variant": "primary",
                          "icon": "send",
                          "type": "button",
                          "label": "Send Notification"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "sending",
                "event": "SMS_NOTIFY",
                "effects": [
                  [
                    "call-service",
                    "twilio",
                    "sendSMS",
                    {
                      "recipient": "@payload.recipient",
                      "body": "@payload.body",
                      "sender": "+15551234567"
                    },
                    {
                      "emit": {
                        "failure": "ChatSmsFailed",
                        "success": "ChatSmsSent"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Sending notification…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "ready",
                "event": "ChatSmsSent",
                "effects": [
                  [
                    "notify",
                    "success",
                    "Notification sent"
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "ready",
                "event": "ChatSmsFailed",
                "effects": [
                  [
                    "notify",
                    "error",
                    "Notification failed"
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ChatPage",
          "path": "/chat",
          "traits": [
            {
              "ref": "ChatAppLayout"
            },
            {
              "ref": "ChatRoom"
            },
            {
              "ref": "ChatSearch"
            },
            {
              "ref": "ChatStats"
            },
            {
              "ref": "ChatMessageBrowse"
            },
            {
              "ref": "ChatMessageCompose"
            },
            {
              "ref": "ChatMessageView"
            },
            {
              "ref": "ChatMessagePersistor"
            },
            {
              "ref": "ChatMessageAttachment"
            },
            {
              "ref": "ChatSmsNotify"
            }
          ]
        }
      ]
    },
    {
      "name": "ChannelOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Channel",
        "collection": "channels",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "memberCount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "isPrivate",
            "type": "boolean",
            "default": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ChannelCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE_CHANNEL",
              "triggers": "CREATE",
              "source": {
                "kind": "orbital",
                "orbital": "ChatMessageOrbital",
                "trait": "ChatRoom"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "hash"
                                },
                                {
                                  "content": "Channels",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "icon": "plus",
                                  "label": "Create Channel",
                                  "variant": "primary",
                                  "type": "button",
                                  "action": "CREATE"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ChannelBrowseList"
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "ChannelBrowseList",
          "linkedEntity": "Channel",
          "config": {
            "itemActions": [
              {
                "event": "VIEW",
                "label": "View",
                "variant": "ghost"
              },
              {
                "label": "Edit",
                "variant": "ghost",
                "event": "EDIT"
              },
              {
                "label": "Delete",
                "event": "DELETE",
                "variant": "danger"
              }
            ],
            "fields": [
              {
                "variant": "h3",
                "name": "name",
                "icon": "hash"
              },
              {
                "label": "Members",
                "name": "memberCount",
                "variant": "badge",
                "format": "number"
              },
              {
                "variant": "body",
                "name": "description"
              },
              {
                "name": "isPrivate",
                "label": "Private",
                "format": "boolean",
                "variant": "body"
              }
            ],
            "cols": 1.0,
            "gap": "sm"
          },
          "listens": [
            {
              "event": "CHANNEL_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChannelPersistor"
              }
            },
            {
              "event": "CHANNEL_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChannelPersistor"
              }
            },
            {
              "event": "CHANNEL_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ChannelPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ChannelCreate",
          "linkedEntity": "Channel",
          "config": {
            "fields": [
              "name",
              "description",
              "memberCount",
              "isPrivate"
            ],
            "title": "Create Channel",
            "mode": "create",
            "icon": "plus-circle"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ChannelCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ChannelEdit",
          "linkedEntity": "Channel",
          "config": {
            "fields": [
              "name",
              "description",
              "memberCount",
              "isPrivate"
            ],
            "icon": "edit",
            "mode": "edit",
            "title": "Edit Channel"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ChannelBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "ChannelView",
          "linkedEntity": "Channel",
          "config": {
            "fields": [
              "name",
              "description",
              "memberCount",
              "isPrivate"
            ],
            "icon": "eye",
            "mode": "edit",
            "title": "View Channel"
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "ChannelBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "ChannelDelete",
          "linkedEntity": "Channel",
          "config": {
            "icon": "alert-triangle",
            "title": "Delete Channel",
            "confirmLabel": "Delete",
            "alertMessage": "This action cannot be undone."
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ChannelBrowseList"
              }
            }
          ]
        },
        {
          "name": "ChannelPersistor",
          "category": "lifecycle",
          "linkedEntity": "Channel",
          "emits": [
            {
              "event": "CHANNEL_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CHANNEL_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CHANNEL_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ChannelCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ChannelEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ChannelDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHANNEL_CREATED",
                "name": "Channel Created"
              },
              {
                "key": "CHANNEL_UPDATED",
                "name": "Channel Updated"
              },
              {
                "key": "CHANNEL_DELETED",
                "name": "Channel Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Channel",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CHANNEL_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Channel",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CHANNEL_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Channel",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "CHANNEL_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Channels",
          "path": "/channels",
          "traits": [
            {
              "ref": "ChannelCatalog"
            },
            {
              "ref": "ChannelBrowseList"
            },
            {
              "ref": "ChannelCreate"
            },
            {
              "ref": "ChannelEdit"
            },
            {
              "ref": "ChannelView"
            },
            {
              "ref": "ChannelDelete"
            },
            {
              "ref": "ChannelPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "OnlineUserOrbital",
      "entity": {
        "name": "OnlineUser",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "username",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "offline",
            "values": [
              "online",
              "away",
              "offline"
            ]
          },
          {
            "name": "lastActive",
            "type": "datetime"
          },
          {
            "name": "avatar",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "OnlineUserDisplay",
          "category": "interaction",
          "linkedEntity": "OnlineUser",
          "emits": [
            {
              "event": "OnlineUserLoaded",
              "description": "Fired when OnlineUser finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[OnlineUser]"
                }
              ]
            },
            {
              "event": "OnlineUserLoadFailed",
              "description": "Fired when OnlineUser fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "displaying"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OnlineUserLoaded",
                "name": "OnlineUser loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[OnlineUser]"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "OnlineUserLoadFailed",
                "name": "OnlineUser load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "displaying",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OnlineUser",
                    {
                      "emit": {
                        "failure": "OnlineUserLoadFailed",
                        "success": "OnlineUserLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "users",
                                  "type": "icon"
                                },
                                {
                                  "content": "Online Users",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "label": "Refresh",
                              "action": "REFRESH",
                              "icon": "refresh-cw",
                              "variant": "secondary"
                            }
                          ],
                          "justify": "between",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "spinner"
                            },
                            {
                              "variant": "caption",
                              "content": "Loading presence…",
                              "color": "muted",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical",
                          "className": "py-12",
                          "align": "center",
                          "gap": "md"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "displaying",
                "to": "displaying",
                "event": "OnlineUserLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-5xl mx-auto w-full",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "users",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Online Users"
                                }
                              ],
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "variant": "secondary",
                              "type": "button",
                              "label": "Refresh",
                              "action": "REFRESH",
                              "icon": "refresh-cw"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "gap": "sm",
                          "type": "data-list",
                          "variant": "card",
                          "fields": [
                            {
                              "variant": "h4",
                              "name": "username"
                            },
                            {
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "format": "date",
                              "name": "lastActive"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "displaying",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "OnlineUser",
                    {
                      "emit": {
                        "success": "OnlineUserLoaded",
                        "failure": "OnlineUserLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Refreshing…",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "displaying",
                "to": "displaying",
                "event": "OnlineUserLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load presence",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "variant": "primary",
                          "action": "REFRESH",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Retry"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Online",
          "path": "/online",
          "traits": [
            {
              "ref": "OnlineUserDisplay"
            }
          ]
        }
      ]
    }
  ]
}
