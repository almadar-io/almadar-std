{
  "name": "std-fitness-studio",
  "version": "1.0.0",
  "description": "Fitness studio: member directory, recurring group-class scheduling, tiered memberships, and class rosters. Pick for gym/yoga/dance studio apps (Mindbody pattern).",
  "orbitals": [
    {
      "name": "MemberOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-search",
          "as": "Search"
        },
        {
          "from": "std/behaviors/std-filter",
          "as": "Filter"
        },
        {
          "from": "std/behaviors/std-stats",
          "as": "Stats"
        },
        {
          "from": "std/behaviors/std-graphs",
          "as": "Graphs"
        },
        {
          "from": "std/behaviors/std-browse",
          "as": "Browse"
        }
      ],
      "entity": {
        "name": "Member",
        "collection": "members",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "joinedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "membershipTier",
            "type": "string",
            "default": "basic",
            "values": [
              "basic",
              "premium",
              "unlimited"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "paused",
              "cancelled"
            ]
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "MemberAppLayout",
          "config": {
            "appName": "Fitness Studio",
            "notifications": [],
            "notificationClickEvent": "MEMBER_NOTIFICATIONS_OPEN",
            "searchEvent": "MEMBER_SEARCH",
            "contentTrait": "@trait.MemberCatalog",
            "navItems": [
              {
                "label": "Members",
                "href": "/members",
                "icon": "users"
              },
              {
                "icon": "calendar",
                "href": "/classes",
                "label": "Classes"
              },
              {
                "href": "/memberships",
                "icon": "credit-card",
                "label": "Memberships"
              },
              {
                "label": "Rosters",
                "icon": "clipboard-list",
                "href": "/rosters"
              }
            ]
          },
          "events": {
            "SEARCH": "MEMBER_SEARCH",
            "NOTIFY_CLICK": "MEMBER_NOTIFICATIONS_OPEN"
          }
        },
        {
          "name": "MemberCatalog",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "MEMBER_SEARCH",
              "triggers": "MEMBER_SEARCH",
              "source": {
                "kind": "trait",
                "trait": "MemberAppLayout"
              }
            },
            {
              "event": "MEMBER_NOTIFICATIONS_OPEN",
              "triggers": "MEMBER_NOTIFICATIONS_OPEN",
              "source": {
                "kind": "trait",
                "trait": "MemberAppLayout"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MEMBER_SEARCH",
                "name": "Member Search",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEMBER_NOTIFICATIONS_OPEN",
                "name": "Member Notifications Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "users",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "Members",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "children": [
                                {
                                  "icon": "user-plus",
                                  "label": "New Member",
                                  "variant": "primary",
                                  "type": "button",
                                  "action": "CREATE"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ],
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            "@trait.MemberSearch",
                            "@trait.MemberFilter"
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        "@trait.MemberStats",
                        "@trait.MemberGraphs",
                        {
                          "type": "divider"
                        },
                        "@trait.MemberBrowseList"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "MEMBER_SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "MEMBER_NOTIFICATIONS_OPEN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "md",
                      "className": "py-8",
                      "children": [
                        {
                          "type": "icon",
                          "name": "bell"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "No notifications"
                        },
                        {
                          "content": "You're all caught up.",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "action": "INIT",
                          "label": "Back to members"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "Search.traits.SearchResultSearch",
          "name": "MemberSearch",
          "config": {
            "event": "MEMBER_SEARCH",
            "placeholder": "Search members…"
          }
        },
        {
          "ref": "Filter.traits.FilterTargetFilter",
          "name": "MemberFilter",
          "config": {
            "filters": [
              {
                "label": "Tier",
                "filterType": "select",
                "field": "membershipTier",
                "options": [
                  "basic",
                  "premium",
                  "unlimited"
                ]
              },
              {
                "label": "Status",
                "options": [
                  "active",
                  "paused",
                  "cancelled"
                ],
                "filterType": "select",
                "field": "status"
              }
            ],
            "event": "MEMBER_FILTER"
          }
        },
        {
          "ref": "Stats.traits.StatsItemStats",
          "name": "MemberStats",
          "config": {
            "metrics": [
              {
                "icon": "users",
                "variant": "primary",
                "aggregation": "count",
                "format": "number",
                "label": "Total"
              },
              {
                "label": "Active",
                "aggregation": "count",
                "variant": "success",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ],
                "format": "number",
                "icon": "user-check"
              },
              {
                "format": "number",
                "variant": "warning",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "paused"
                  ]
                ],
                "aggregation": "count",
                "label": "Paused",
                "icon": "pause-circle"
              },
              {
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "cancelled"
                  ]
                ],
                "variant": "danger",
                "icon": "user-x",
                "label": "Cancelled",
                "format": "number",
                "aggregation": "count"
              }
            ],
            "title": "Members"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "MemberBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Graphs.traits.GraphItemGraph",
          "name": "MemberGraphs",
          "config": {
            "chartType": "bar",
            "height": 240.0,
            "showLegend": false,
            "title": "Members by Tier",
            "categoryField": "membershipTier",
            "subtitle": "Distribution across membership tiers",
            "aggregation": "count"
          },
          "listens": [
            {
              "event": "BrowseItemLoaded",
              "triggers": "ITEMS_LOADED",
              "source": {
                "kind": "trait",
                "trait": "MemberBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Browse.traits.BrowseItemBrowse",
          "name": "MemberBrowseList",
          "linkedEntity": "Member",
          "config": {
            "fields": [
              {
                "name": "name",
                "icon": "user",
                "variant": "h4"
              },
              {
                "variant": "body",
                "name": "email"
              },
              {
                "variant": "badge",
                "name": "membershipTier"
              },
              {
                "variant": "badge",
                "name": "status"
              },
              {
                "variant": "caption",
                "name": "joinedAt"
              }
            ],
            "itemActions": [
              {
                "variant": "ghost",
                "label": "View",
                "event": "VIEW"
              },
              {
                "label": "Edit",
                "event": "EDIT",
                "variant": "ghost"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "variant": "danger"
              }
            ],
            "cols": 1.0,
            "gap": "sm"
          },
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "REFETCH_QUERY",
              "source": {
                "kind": "trait",
                "trait": "MemberSearch"
              }
            },
            {
              "event": "FILTER",
              "triggers": "REFETCH_FILTER",
              "source": {
                "kind": "trait",
                "trait": "MemberFilter"
              }
            },
            {
              "event": "MEMBER_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "MemberPersistor"
              }
            },
            {
              "event": "MEMBER_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "MemberPersistor"
              }
            },
            {
              "event": "MEMBER_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "MemberPersistor"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "MemberCreate",
          "linkedEntity": "Member",
          "config": {
            "fields": [
              "name",
              "email",
              "membershipTier",
              "status",
              "joinedAt"
            ],
            "icon": "user-plus",
            "title": "New Member",
            "mode": "create"
          },
          "events": {
            "OPEN": "CREATE"
          },
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "MemberCatalog"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "MemberEdit",
          "linkedEntity": "Member",
          "config": {
            "mode": "edit",
            "fields": [
              "name",
              "email",
              "membershipTier",
              "status",
              "joinedAt"
            ],
            "icon": "edit",
            "title": "Edit Member"
          },
          "events": {
            "OPEN": "EDIT"
          },
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "MemberBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Modal.traits.ModalRecordModal",
          "name": "MemberView",
          "linkedEntity": "Member",
          "config": {
            "mode": "edit",
            "icon": "eye",
            "title": "View Member",
            "fields": [
              "name",
              "email",
              "membershipTier",
              "status",
              "joinedAt"
            ]
          },
          "events": {
            "OPEN": "VIEW"
          },
          "listens": [
            {
              "event": "VIEW",
              "triggers": "VIEW",
              "source": {
                "kind": "trait",
                "trait": "MemberBrowseList"
              }
            }
          ]
        },
        {
          "ref": "Confirmation.traits.ConfirmActionConfirmation",
          "name": "MemberDelete",
          "linkedEntity": "Member",
          "config": {
            "alertMessage": "This action cannot be undone.",
            "icon": "alert-triangle",
            "title": "Cancel Membership",
            "confirmLabel": "Delete"
          },
          "events": {
            "REQUEST": "DELETE",
            "CONFIRM": "CONFIRM_DELETE"
          },
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "MemberBrowseList"
              }
            }
          ]
        },
        {
          "name": "MemberPersistor",
          "category": "lifecycle",
          "linkedEntity": "Member",
          "emits": [
            {
              "event": "MEMBER_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MEMBER_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MEMBER_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "MemberCreate"
              }
            },
            {
              "event": "SAVE",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "MemberEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "MemberDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MEMBER_CREATED",
                "name": "Member Created"
              },
              {
                "key": "MEMBER_UPDATED",
                "name": "Member Updated"
              },
              {
                "key": "MEMBER_DELETED",
                "name": "Member Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Member",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "MEMBER_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Member",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "MEMBER_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Member",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "MEMBER_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MembersPage",
          "path": "/members",
          "traits": [
            {
              "ref": "MemberAppLayout"
            },
            {
              "ref": "MemberCatalog"
            },
            {
              "ref": "MemberSearch"
            },
            {
              "ref": "MemberFilter"
            },
            {
              "ref": "MemberStats"
            },
            {
              "ref": "MemberGraphs"
            },
            {
              "ref": "MemberBrowseList"
            },
            {
              "ref": "MemberCreate"
            },
            {
              "ref": "MemberEdit"
            },
            {
              "ref": "MemberView"
            },
            {
              "ref": "MemberDelete"
            },
            {
              "ref": "MemberPersistor"
            }
          ]
        }
      ]
    },
    {
      "name": "ClassSessionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-class-session",
          "as": "ClassSession"
        }
      ],
      "entity": {
        "name": "ClassSessionRow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "ClassSessionAppLayout",
          "config": {
            "notifications": [],
            "navItems": [
              {
                "label": "Members",
                "href": "/members",
                "icon": "users"
              },
              {
                "icon": "calendar",
                "href": "/classes",
                "label": "Classes"
              },
              {
                "href": "/memberships",
                "icon": "credit-card",
                "label": "Memberships"
              },
              {
                "label": "Rosters",
                "icon": "clipboard-list",
                "href": "/rosters"
              }
            ],
            "appName": "Fitness Studio",
            "notificationClickEvent": "CLASS_SESSION_NOTIFICATIONS_OPEN",
            "contentTrait": "@trait.ClassSessionDisplay",
            "searchEvent": "CLASS_SESSION_SEARCH"
          },
          "events": {
            "NOTIFY_CLICK": "CLASS_SESSION_NOTIFICATIONS_OPEN",
            "SEARCH": "CLASS_SESSION_SEARCH"
          }
        },
        {
          "name": "ClassSessionDisplay",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "calendar"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Class Schedule"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Group classes for the week. Start a class to open its roster; cancel to notify enrolled members."
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.ClassSessionSchedule"
                      ],
                      "gap": "lg",
                      "className": "max-w-6xl mx-auto w-full p-4",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "ref": "ClassSession.traits.ClassSessionSchedule",
          "name": "ClassSessionSchedule",
          "config": {
            "title": "Upcoming Classes"
          }
        }
      ],
      "pages": [
        {
          "name": "ClassSessionsPage",
          "path": "/classes",
          "traits": [
            {
              "ref": "ClassSessionAppLayout"
            },
            {
              "ref": "ClassSessionDisplay"
            },
            {
              "ref": "ClassSessionSchedule"
            }
          ]
        }
      ]
    },
    {
      "name": "MembershipOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-app-layout",
          "as": "AppShell"
        },
        {
          "from": "std/behaviors/std-membership",
          "as": "Membership"
        }
      ],
      "entity": {
        "name": "MembershipRow",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "ref": "AppShell.traits.AppLayout",
          "name": "MembershipAppLayout",
          "config": {
            "searchEvent": "MEMBERSHIP_SEARCH",
            "notifications": [],
            "contentTrait": "@trait.MembershipDisplay",
            "navItems": [
              {
                "label": "Members",
