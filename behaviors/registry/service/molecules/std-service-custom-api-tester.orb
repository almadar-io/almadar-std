{
  "name": "std-service-custom-api-tester",
  "version": "1.0.0",
  "description": "std-service-custom-api-tester as a Function",
  "orbitals": [
    {
      "name": "ServiceCustomApiTesterOrbital",
      "entity": {
        "name": "ServiceCustomApiTester",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "endpoint",
            "type": "string"
          },
          {
            "name": "method",
            "type": "string",
            "default": "GET"
          },
          {
            "name": "requestBody",
            "type": "string"
          },
          {
            "name": "responseData",
            "type": "string"
          },
          {
            "name": "statusCode",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "authType",
            "type": "string",
            "default": "header"
          },
          {
            "name": "callStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCustomApiTesterApiTester",
          "category": "interaction",
          "linkedEntity": "ServiceCustomApiTester",
          "emits": [
            {
              "event": "ServiceCustomApiTesterLoaded",
              "description": "Fired when ServiceCustomApiTester finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "endpoint",
                  "type": "string"
                },
                {
                  "name": "method",
                  "type": "string"
                },
                {
                  "name": "requestBody",
                  "type": "string"
                },
                {
                  "name": "responseData",
                  "type": "string"
                },
                {
                  "name": "statusCode",
                  "type": "number"
                },
                {
                  "name": "authType",
                  "type": "string"
                },
                {
                  "name": "callStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterLoadFailed",
              "description": "Fired when ServiceCustomApiTester fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomHeaderApiCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomHeaderApiFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomBearerApiCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomBearerApiFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomQueryApiCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomQueryApiFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomNoauthApiCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomApiTesterCustomNoauthApiFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "calling"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CALL_HEADER_API",
                "name": "Call Header Api"
              },
              {
                "key": "CALL_BEARER_API",
                "name": "Call Bearer Api"
              },
              {
                "key": "CALL_QUERY_API",
                "name": "Call Query Api"
              },
              {
                "key": "CALL_NOAUTH_API",
                "name": "Call Noauth Api"
              },
              {
                "key": "API_RESPONSE",
                "name": "Api Response",
                "payload": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "statusCode",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceCustomApiTesterLoaded",
                "name": "ServiceCustomApiTester loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "endpoint",
                    "type": "string"
                  },
                  {
                    "name": "method",
                    "type": "string"
                  },
                  {
                    "name": "requestBody",
                    "type": "string"
                  },
                  {
                    "name": "responseData",
                    "type": "string"
                  },
                  {
                    "name": "statusCode",
                    "type": "number"
                  },
                  {
                    "name": "authType",
                    "type": "string"
                  },
                  {
                    "name": "callStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterLoadFailed",
                "name": "ServiceCustomApiTester load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomHeaderApiCompleted",
                "name": "ServiceCustomApiTester custom header api completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomHeaderApiFailed",
                "name": "ServiceCustomApiTester custom header api failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomBearerApiCompleted",
                "name": "ServiceCustomApiTester custom bearer api completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomBearerApiFailed",
                "name": "ServiceCustomApiTester custom bearer api failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomQueryApiCompleted",
                "name": "ServiceCustomApiTester custom query api completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomQueryApiFailed",
                "name": "ServiceCustomApiTester custom query api failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomNoauthApiCompleted",
                "name": "ServiceCustomApiTester custom noauth api completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomApiTesterCustomNoauthApiFailed",
                "name": "ServiceCustomApiTester custom noauth api failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceCustomApiTester",
                    {
                      "emit": {
                        "failure": "ServiceCustomApiTesterLoadFailed",
                        "success": "ServiceCustomApiTesterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "name": "globe",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Unified API Tester"
                        },
                        {
                          "placeholder": "/users",
                          "type": "input"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "value": "DELETE",
                              "label": "DELETE"
                            }
                          ]
                        },
                        {
                          "placeholder": "Request body (JSON)",
                          "type": "textarea"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h4",
                          "type": "typography",
                          "content": "Select Auth Type"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "label": "Header API Key",
                              "action": "CALL_HEADER_API",
                              "type": "button",
                              "icon": "key"
                            },
                            {
                              "label": "Bearer Token",
                              "type": "button",
                              "action": "CALL_BEARER_API",
                              "variant": "primary",
                              "icon": "shield"
                            },
                            {
                              "type": "button",
                              "action": "CALL_QUERY_API",
                              "label": "Query Param",
                              "variant": "primary",
                              "icon": "search"
                            },
                            {
                              "type": "button",
                              "label": "No Auth",
                              "variant": "primary",
                              "icon": "unlock",
                              "action": "CALL_NOAUTH_API"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "justify": "center"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "CALL_HEADER_API",
                "effects": [
                  [
                    "set",
                    "@entity.authType",
                    "header"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Sending request to servicecustomapitester endpoint...",
                      "title": "Calling API..."
                    }
                  ],
                  [
                    "call-service",
                    "custom-header-api",
                    "execute",
                    {
                      "method": "@entity.method",
                      "endpoint": "@entity.endpoint",
                      "body": "@entity.requestBody"
                    },
                    {
                      "emit": {
                        "success": "ServiceCustomApiTesterCustomHeaderApiCompleted",
                        "failure": "ServiceCustomApiTesterCustomHeaderApiFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "CALL_BEARER_API",
                "effects": [
                  [
                    "set",
                    "@entity.authType",
                    "bearer"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Sending request to servicecustomapitester endpoint...",
                      "title": "Calling API...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "custom-bearer-api",
                    "execute",
                    {
                      "endpoint": "@entity.endpoint",
                      "method": "@entity.method",
                      "body": "@entity.requestBody"
                    },
                    {
                      "emit": {
                        "success": "ServiceCustomApiTesterCustomBearerApiCompleted",
                        "failure": "ServiceCustomApiTesterCustomBearerApiFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "CALL_QUERY_API",
                "effects": [
                  [
                    "set",
                    "@entity.authType",
                    "query"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Calling API...",
                      "message": "Sending request to servicecustomapitester endpoint...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "custom-query-api",
                    "execute",
                    {
                      "endpoint": "@entity.endpoint",
                      "method": "@entity.method",
                      "body": "@entity.requestBody"
                    },
                    {
                      "emit": {
                        "failure": "ServiceCustomApiTesterCustomQueryApiFailed",
                        "success": "ServiceCustomApiTesterCustomQueryApiCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "CALL_NOAUTH_API",
                "effects": [
                  [
                    "set",
                    "@entity.authType",
                    "noauth"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Calling API...",
                      "message": "Sending request to servicecustomapitester endpoint...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "custom-noauth-api",
                    "execute",
                    {
                      "endpoint": "@entity.endpoint",
                      "method": "@entity.method",
                      "body": "@entity.requestBody"
                    },
                    {
                      "emit": {
                        "success": "ServiceCustomApiTesterCustomNoauthApiCompleted",
                        "failure": "ServiceCustomApiTesterCustomNoauthApiFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "complete",
                "event": "API_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.responseData",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.statusCode",
                    "@payload.statusCode"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Response"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "label": "@entity.authType",
                              "variant": "info",
                              "type": "badge"
                            },
                            {
                              "label": "@entity.statusCode",
                              "variant": "info",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "code": "@entity.responseData",
                          "language": "json",
                          "type": "code-block"
                        },
                        {
                          "type": "button",
                          "label": "New Request",
                          "action": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Request Failed",
                      "message": "@entity.error",
                      "onRetry": "RETRY",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "globe"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Unified API Tester"
                        },
                        {
                          "placeholder": "/users",
                          "type": "input"
                        },
                        {
                          "options": [
                            {
                              "value": "GET",
                              "label": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "label": "DELETE",
                              "value": "DELETE"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "placeholder": "Request body (JSON)",
                          "type": "textarea"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h4",
                          "type": "typography",
                          "content": "Select Auth Type"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "icon": "key",
                              "action": "CALL_HEADER_API",
                              "variant": "primary",
                              "type": "button",
                              "label": "Header API Key"
                            },
                            {
                              "icon": "shield",
                              "variant": "primary",
                              "action": "CALL_BEARER_API",
                              "type": "button",
                              "label": "Bearer Token"
                            },
                            {
                              "label": "Query Param",
                              "action": "CALL_QUERY_API",
                              "type": "button",
                              "variant": "primary",
                              "icon": "search"
                            },
                            {
                              "variant": "primary",
                              "action": "CALL_NOAUTH_API",
                              "type": "button",
                              "label": "No Auth",
                              "icon": "unlock"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "name": "globe",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "content": "Unified API Tester",
                          "type": "typography"
                        },
                        {
                          "placeholder": "/users",
                          "type": "input"
                        },
                        {
                          "options": [
                            {
                              "label": "GET",
                              "value": "GET"
                            },
                            {
                              "label": "POST",
                              "value": "POST"
                            },
                            {
                              "value": "PUT",
                              "label": "PUT"
                            },
                            {
                              "value": "DELETE",
                              "label": "DELETE"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "placeholder": "Request body (JSON)",
                          "type": "textarea"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h4",
                          "content": "Select Auth Type",
                          "type": "typography"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "action": "CALL_HEADER_API",
                              "label": "Header API Key",
                              "icon": "key",
                              "variant": "primary"
                            },
                            {
                              "icon": "shield",
                              "variant": "primary",
                              "label": "Bearer Token",
                              "action": "CALL_BEARER_API",
                              "type": "button"
                            },
                            {
                              "label": "Query Param",
                              "type": "button",
                              "icon": "search",
                              "variant": "primary",
                              "action": "CALL_QUERY_API"
                            },
                            {
                              "label": "No Auth",
                              "variant": "primary",
                              "icon": "unlock",
                              "type": "button",
                              "action": "CALL_NOAUTH_API"
                            }
                          ],
                          "justify": "center",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "globe"
                        },
                        {
                          "variant": "h2",
                          "content": "Unified API Tester",
                          "type": "typography"
                        },
                        {
                          "type": "input",
                          "placeholder": "/users"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "GET",
                              "label": "GET"
                            },
                            {
                              "value": "POST",
                              "label": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "label": "DELETE",
                              "value": "DELETE"
                            }
                          ]
                        },
                        {
                          "placeholder": "Request body (JSON)",
                          "type": "textarea"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Select Auth Type",
