                        {
                          "icon": "file-text",
                          "href": "/reports",
                          "label": "Reports"
                        },
                        {
                          "label": "Knowledge",
                          "href": "/knowledge",
                          "icon": "book-open"
                        }
                      ],
                      "children": [
                        {
                          "title": "Executing...",
                          "message": "Running redis operation...",
                          "type": "loading-state"
                        }
                      ],
                      "appName": "ResearchAssistant"
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "get",
                    {
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "success": "ResearchRedisCompleted",
                        "failure": "ResearchRedisFailed"
                      }
                    }
                  ]
                ]
