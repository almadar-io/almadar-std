                        }
                      ],
                      "appName": "ResearchAssistant"
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "set",
                    {
                      "value": "@entity.value",
                      "ttl": "@entity.ttl",
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "success": "ResearchRedisCompleted",
                        "failure": "ResearchRedisFailed"
                      }
                    }
                  ]
                ]
              },
