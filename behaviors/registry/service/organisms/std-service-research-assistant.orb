                                  "action": "UPLOAD_FILE",
                                  "variant": "primary",
                                  "type": "button",
                                  "label": "Upload",
                                  "icon": "upload"
                                },
                                {
                                  "variant": "secondary",
                                  "action": "DOWNLOAD_FILE",
                                  "type": "button",
                                  "label": "Download",
                                  "icon": "download"
                                },
                                {
                                  "icon": "list",
                                  "label": "List",
