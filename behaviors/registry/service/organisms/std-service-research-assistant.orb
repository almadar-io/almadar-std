                            {
                              "gap": "sm",
                              "justify": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "primary",
                                  "action": "GET_KEY",
                                  "label": "Get",
                                  "icon": "download",
                                  "type": "button"
                                },
                                {
                                  "label": "Set",
                                  "action": "SET_KEY",
                                  "variant": "primary",
                                  "icon": "upload",
                                  "type": "button"
                                },
                                {
                                  "label": "Delete",
                                  "type": "button",
                                  "action": "DELETE_KEY",
                                  "icon": "trash-2",
                                  "variant": "danger"
                                }
                              ]
                            }
                          ],
                          "type": "stack",
                          "gap": "lg",
                          "direction": "vertical"
                        }
                      ],
                      "appName": "ResearchAssistant"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "GET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "navItems": [
                        {
                          "label": "Research",
                          "href": "/research",
                          "icon": "search"
                        },
                        {
                          "label": "Cache",
                          "icon": "database",
