                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "input",
                                  "placeholder": "cache-key"
                                },
                                {
                                  "placeholder": "cache-value",
                                  "type": "input"
                                },
                                {
                                  "inputType": "number",
                                  "placeholder": "3600",
                                  "type": "input"
                                }
                              ],
                              "gap": "md"
