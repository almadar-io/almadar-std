            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ProductLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [
                        {
                          "href": "/products",
                          "label": "Products",
                          "icon": "package"
                        },
                        {
                          "href": "/login",
                          "label": "Login",
                          "icon": "layout-list"
                        },
                        {
                          "href": "/checkout",
                          "label": "Checkout",
                          "icon": "credit-card"
                        },
                        {
                          "label": "Orders",
                          "href": "/orders",
                          "icon": "clipboard-list"
                        }
                      ],
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "type": "icon",
                                      "name": "shopping-bag"
                                    },
                                    {
                                      "variant": "h2",
                                      "type": "typography",
                                      "content": "Products"
                                    }
                                  ],
                                  "gap": "sm",
                                  "type": "stack",
                                  "align": "center"
                                },
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "children": [
                                    {
                                      "type": "button",
                                      "variant": "primary",
                                      "icon": "plus",
                                      "label": "Create Product",
                                      "action": "CREATE"
                                    }
                                  ],
                                  "direction": "horizontal"
                                }
                              ],
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "between"
                            },
                            {
                              "type": "divider"
                            },
                            {
                              "itemActions": [
                                {
                                  "label": "View",
                                  "event": "VIEW",
                                  "variant": "ghost"
                                },
                                {
                                  "label": "Edit",
                                  "event": "EDIT",
                                  "variant": "ghost"
                                },
                                {
                                  "label": "Checkout",
                                  "variant": "primary",
                                  "event": "CHECKOUT"
                                },
                                {
                                  "label": "Delete",
                                  "variant": "danger",
                                  "event": "DELETE"
                                }
                              ],
                              "entity": "@payload.data",
                              "type": "data-grid",
                              "fields": [
                                {
                                  "name": "name",
                                  "label": "Name",
                                  "variant": "h4",
                                  "icon": "shopping-bag"
                                },
                                {
                                  "colorMap": {
                                    "done": "success",
                                    "cancelled": "destructive",
                                    "inactive": "neutral",
                                    "archived": "neutral",
                                    "error": "destructive",
                                    "scheduled": "warning",
                                    "completed": "success",
                                    "pending": "warning",
                                    "active": "success",
                                    "disabled": "neutral",
                                    "failed": "destructive",
                                    "draft": "warning"
                                  },
                                  "label": "Description",
                                  "name": "description",
                                  "variant": "badge"
                                },
                                {
                                  "name": "price",
                                  "variant": "caption",
                                  "label": "Price"
                                }
                              ]
                            }
                          ],
                          "gap": "lg",
                          "className": "max-w-5xl mx-auto w-full",
                          "direction": "vertical"
                        }
                      ],
                      "type": "dashboard-layout",
                      "appName": "ServiceMarketplace"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ProductLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load product",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Retry",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ProductCreate",
          "category": "interaction",
          "linkedEntity": "Product",
          "emits": [
