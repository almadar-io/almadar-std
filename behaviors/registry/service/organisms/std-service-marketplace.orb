                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon"
                            },
                            {
                              "content": "Create Order",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "form-section",
                          "fields": [
                            "productName",
                            "amount",
                            "paymentStatus",
                            "orderDate"
                          ],
                          "cancelEvent": "CLOSE",
                          "mode": "create",
                          "submitEvent": "SAVE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Order",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "OrderSaveFailed",
                        "success": "OrderSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "ORDER_CREATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
