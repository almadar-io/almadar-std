            {
              "ref": "ProductCreate"
            },
            {
              "ref": "ProductEdit"
            },
            {
              "ref": "ProductView"
            },
            {
              "ref": "ProductDelete"
            }
          ]
        }
      ]
    },
    {
      "name": "AuthSessionOrbital",
      "entity": {
        "name": "AuthSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string"
          },
          {
            "name": "authUrl",
            "type": "string"
          },
          {
            "name": "accessToken",
            "type": "string"
          },
          {
            "name": "refreshToken",
            "type": "string"
          },
          {
            "name": "authStatus",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AuthSessionOauth",
          "category": "interaction",
          "linkedEntity": "AuthSession",
          "emits": [
            {
              "event": "AuthSessionLoadFailed",
              "description": "Fired when AuthSession fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AuthSessionLoaded",
              "description": "Fired when AuthSession finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AuthSession]"
                }
              ]
            },
            {
              "event": "ProductOauthCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ProductOauthFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "unauthenticated",
                "isInitial": true
              },
              {
                "name": "authorizing"
              },
              {
                "name": "authenticated"
              },
              {
                "name": "refreshing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOGIN",
                "name": "Login"
              },
              {
                "key": "AUTH_URL_RECEIVED",
                "name": "Auth Url Received",
                "payloadSchema": [
                  {
                    "name": "authUrl",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CALLBACK",
                "name": "Callback",
                "payloadSchema": [
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TOKEN_RECEIVED",
                "name": "Token Received",
                "payloadSchema": [
                  {
                    "name": "accessToken",
                    "type": "string"
                  },
                  {
                    "name": "refreshToken",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "LOGOUT",
                "name": "Logout"
              },
              {
                "key": "TOKEN_REFRESHED",
                "name": "Token Refreshed",
                "payloadSchema": [
                  {
                    "name": "accessToken",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "AuthSessionLoadFailed",
                "name": "AuthSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AuthSessionLoaded",
                "name": "AuthSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AuthSession]"
                  }
                ]
              },
              {
                "key": "ProductOauthCompleted",
                "name": "Product oauth completed",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ProductOauthFailed",
                "name": "Product oauth failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "unauthenticated",
                "to": "unauthenticated",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    ""
                  ],
                  [
                    "fetch",
                    "AuthSession",
                    {
                      "emit": {
                        "success": "AuthSessionLoaded",
                        "failure": "AuthSessionLoadFailed"
                      }
                    }
                  ],
                  [
