    {
      "name": "OrderPaymentOrbital",
      "entity": {
        "name": "OrderPayment",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string"
          },
          {
            "name": "paymentIntentId",
            "type": "string"
          },
          {
            "name": "clientSecret",
            "type": "string"
          },
          {
            "name": "paymentStatus",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "subject",
            "type": "string"
          },
          {
            "name": "body",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "OrderPaymentPayment",
          "category": "interaction",
          "linkedEntity": "OrderPayment",
          "emits": [
            {
              "event": "SEND_RECEIPT"
            },
            {
              "event": "OrderPaymentLoadFailed",
              "description": "Fired when OrderPayment fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderPaymentLoaded",
              "description": "Fired when OrderPayment finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[OrderPayment]"
                }
              ]
            },
            {
              "event": "ProductStripeCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ProductStripeFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CHECKOUT",
              "triggers": "INIT",
              "source": {
                "kind": "orbital",
                "orbital": "ProductOrbital",
                "trait": "ProductBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "confirming"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              },
              {
                "key": "PAYMENT_CREATED",
                "name": "Payment Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "clientSecret",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAYMENT_CONFIRMED",
                "name": "Payment Confirmed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "SEND_RECEIPT",
                "name": "Send Receipt"
              },
              {
                "key": "OrderPaymentLoadFailed",
                "name": "OrderPayment load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderPaymentLoaded",
                "name": "OrderPayment loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[OrderPayment]"
                  }
                ]
              },
              {
                "key": "ProductStripeCompleted",
                "name": "Product stripe completed",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ProductStripeFailed",
                "name": "Product stripe failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.amount",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.currency",
                    ""
                  ],
                  [
                    "fetch",
                    "OrderPayment",
                    {
                      "emit": {
                        "success": "OrderPaymentLoaded",
                        "failure": "OrderPaymentLoadFailed"
