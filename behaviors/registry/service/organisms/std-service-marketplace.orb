                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ProductBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "PRODUCT_DELETED",
                "name": "Product Deleted"
              },
              {
                "key": "ProductDeleteFailed",
                "name": "Product delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductDeleted",
                "name": "Product deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoadFailed",
                "name": "Product load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ProductLoaded",
                "name": "Product loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Product]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Delete Product",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "This action cannot be undone.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "justify": "end",
                          "children": [
                            {
                              "variant": "ghost",
                              "action": "CANCEL",
                              "label": "Cancel",
                              "type": "button"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "action": "CONFIRM_DELETE",
                              "icon": "check",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Product",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "failure": "ProductDeleteFailed",
                        "success": "ProductDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "failure": "ProductLoadFailed",
                        "success": "ProductLoaded"
                      }
                    }
                  ],
                  [
                    "emit",
                    "PRODUCT_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Product",
                    {
                      "emit": {
                        "success": "ProductLoaded",
                        "failure": "ProductLoadFailed"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ProductsPage",
          "path": "/products",
          "traits": [
