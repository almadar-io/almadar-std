                      "type": "box"
                    }
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "OrderUpdated",
                        "failure": "OrderUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "emit",
                    "ORDER_UPDATED"
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
