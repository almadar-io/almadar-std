        {
          "name": "OrderDelete",
          "category": "interaction",
          "linkedEntity": "Order",
          "emits": [
            {
              "event": "ORDER_DELETED"
            },
            {
              "event": "OrderDeleteFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderDeleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderLoadFailed",
              "description": "Fired when Order fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OrderLoaded",
              "description": "Fired when Order finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Order]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "OrderBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ORDER_DELETED",
                "name": "Order Deleted"
              },
              {
                "key": "OrderDeleteFailed",
                "name": "Order delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderDeleted",
                "name": "Order deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderLoadFailed",
                "name": "Order load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OrderLoaded",
                "name": "Order loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Order]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Order",
                    {
                      "emit": {
                        "success": "OrderLoaded",
                        "failure": "OrderLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Order",
                    {
                      "id": "@payload.id",
                      "emit": {
                        "failure": "OrderLoadFailed",
                        "success": "OrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Delete Order",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "This action cannot be undone."
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "action": "CANCEL",
                              "variant": "ghost"
                            },
                            {
                              "variant": "danger",
                              "type": "button",
                              "label": "Delete",
                              "icon": "check",
                              "action": "CONFIRM_DELETE"
                            }
                          ],
                          "type": "stack",
                          "justify": "end",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Order",
                    "@entity.pendingId",
                    {
                      "emit": {
                        "success": "OrderDeleted",
                        "failure": "OrderDeleteFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Order",
                    {
                      "emit": {
                        "success": "OrderLoaded",
                        "failure": "OrderLoadFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ORDER_DELETED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Order",
                    {
                      "emit": {
                        "failure": "OrderLoadFailed",
                        "success": "OrderLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ],
                  [
                    "fetch",
                    "Order",
                    {
                      "emit": {
                        "failure": "OrderLoadFailed",
                        "success": "OrderLoaded"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Orders",
          "path": "/orders",
          "traits": [
            {
              "ref": "OrderBrowse"
            },
            {
              "ref": "OrderCreate"
            },
            {
              "ref": "OrderEdit"
            },
            {
              "ref": "OrderView"
            },
            {
              "ref": "OrderDelete"
            }
          ]
        }
      ]
    }
  ]
