{
  "name": "std-service-oauth",
  "version": "1.0.0",
  "description": "std-service-oauth as a Function",
  "orbitals": [
    {
      "name": "ServiceOauthOrbital",
      "entity": {
        "name": "ServiceOauth",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string",
            "default": "google"
          },
          {
            "name": "authUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "accessToken",
            "type": "string",
            "default": ""
          },
          {
            "name": "refreshToken",
            "type": "string",
            "default": ""
          },
          {
            "name": "authStatus",
            "type": "string",
            "default": "unauthenticated"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceOauthOauth",
          "category": "interaction",
          "linkedEntity": "ServiceOauth",
          "emits": [
            {
              "event": "ServiceOauthLoaded",
              "description": "Fired when ServiceOauth finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "provider",
                  "type": "string"
                },
                {
                  "name": "authUrl",
                  "type": "string"
                },
                {
                  "name": "accessToken",
                  "type": "string"
                },
                {
                  "name": "refreshToken",
                  "type": "string"
                },
                {
                  "name": "authStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceOauthLoadFailed",
              "description": "Fired when ServiceOauth fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceOauthOauthCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceOauthOauthFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "unauthenticated",
                "isInitial": true
              },
              {
                "name": "authorizing"
              },
              {
                "name": "authenticated"
              },
              {
                "name": "refreshing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOGIN",
                "name": "Login"
              },
              {
                "key": "AUTH_URL_RECEIVED",
                "name": "Auth Url Received",
                "payloadSchema": [
                  {
                    "name": "authUrl",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CALLBACK",
                "name": "Callback",
                "payloadSchema": [
                  {
                    "name": "code",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOKEN_RECEIVED",
                "name": "Token Received",
                "payloadSchema": [
                  {
                    "name": "accessToken",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "refreshToken",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "LOGOUT",
                "name": "Logout"
              },
              {
                "key": "TOKEN_REFRESHED",
                "name": "Token Refreshed",
                "payloadSchema": [
                  {
                    "name": "accessToken",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceOauthLoaded",
                "name": "ServiceOauth loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "provider",
                    "type": "string"
                  },
                  {
                    "name": "authUrl",
                    "type": "string"
                  },
                  {
                    "name": "accessToken",
                    "type": "string"
                  },
                  {
                    "name": "refreshToken",
                    "type": "string"
                  },
                  {
                    "name": "authStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceOauthLoadFailed",
                "name": "ServiceOauth load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceOauthOauthCompleted",
                "name": "ServiceOauth oauth completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceOauthOauthFailed",
                "name": "ServiceOauth oauth failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "unauthenticated",
                "to": "unauthenticated",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceOauth",
                    {
                      "emit": {
                        "success": "ServiceOauthLoaded",
                        "failure": "ServiceOauthLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Sign In"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "options": [
                            {
                              "label": "Google",
                              "value": "google"
                            },
                            {
                              "label": "GitHub",
                              "value": "github"
                            },
                            {
                              "label": "Microsoft",
                              "value": "microsoft"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "type": "button",
                          "icon": "log-in",
                          "label": "Login",
                          "variant": "primary",
                          "action": "LOGIN"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "unauthenticated",
                "to": "authorizing",
                "event": "LOGIN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Authorizing...",
                      "message": "Redirecting to provider for authorization.",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "authorize",
                    {
                      "provider": "@entity.provider",
                      "scopes": [
                        "openid",
                        "email"
                      ]
                    },
                    {
                      "emit": {
                        "failure": "ServiceOauthOauthFailed",
                        "success": "ServiceOauthOauthCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "authorizing",
                "event": "AUTH_URL_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.authUrl",
                    "@payload.authUrl"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "name": "external-link",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Authorization Required"
                        },
                        {
                          "content": "@entity.authUrl",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "placeholder": "Paste authorization code here",
                          "type": "input"
                        },
                        {
                          "label": "Submit",
                          "icon": "check",
                          "action": "CALLBACK",
                          "variant": "primary",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "authenticated",
                "event": "CALLBACK",
                "effects": [
                  [
                    "call-service",
                    "oauth",
                    "token",
                    {
                      "code": "@payload.code"
                    },
                    {
                      "emit": {
                        "failure": "ServiceOauthOauthFailed",
                        "success": "ServiceOauthOauthCompleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Authenticated successfully",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Refresh Token",
                              "variant": "ghost",
                              "icon": "refresh-cw",
                              "type": "button",
                              "action": "REFRESH"
                            },
                            {
                              "variant": "ghost",
                              "action": "LOGOUT",
                              "icon": "log-out",
                              "type": "button",
                              "label": "Logout"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "justify": "center"
                        }
                      ],
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "error-state",
                          "title": "Authentication Failed",
                          "message": "@entity.error",
                          "onRetry": "RETRY"
                        },
                        {
                          "type": "button",
                          "label": "Try Again",
                          "action": "RETRY",
                          "icon": "rotate-ccw",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "authenticated",
                "event": "TOKEN_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.accessToken",
                    "@payload.accessToken"
                  ],
                  [
                    "set",
                    "@entity.refreshToken",
                    "@payload.refreshToken"
                  ],
                  [
                    "set",
                    "@entity.authStatus",
                    "authenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Authenticated successfully"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "icon": "refresh-cw",
                              "type": "button",
                              "label": "Refresh Token",
                              "variant": "ghost",
                              "action": "REFRESH"
                            },
                            {
                              "icon": "log-out",
                              "type": "button",
                              "action": "LOGOUT",
                              "label": "Logout",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "refreshing",
                "event": "REFRESH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Obtaining a new access token.",
                      "title": "Refreshing token...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "refresh",
                    {
                      "refreshToken": "@entity.refreshToken"
                    },
                    {
                      "emit": {
                        "failure": "ServiceOauthOauthFailed",
                        "success": "ServiceOauthOauthCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "unauthenticated",
                "event": "LOGOUT",
                "effects": [
                  [
                    "set",
                    "@entity.authStatus",
                    "unauthenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "content": "Sign In",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "google",
                              "label": "Google"
                            },
                            {
                              "label": "GitHub",
                              "value": "github"
                            },
                            {
                              "label": "Microsoft",
                              "value": "microsoft"
                            }
                          ]
                        },
                        {
                          "label": "Login",
                          "action": "LOGIN",
                          "icon": "log-in",
                          "variant": "primary",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "refreshing",
                "to": "authenticated",
                "event": "TOKEN_REFRESHED",
                "effects": [
                  [
                    "set",
                    "@entity.accessToken",
                    "@payload.accessToken"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Authenticated successfully"
                        },
                        {
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "action": "REFRESH",
                              "label": "Refresh Token",
                              "type": "button",
                              "variant": "ghost",
                              "icon": "refresh-cw"
                            },
                            {
                              "type": "button",
                              "action": "LOGOUT",
                              "label": "Logout",
                              "variant": "ghost",
                              "icon": "log-out"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "refreshing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "error-state",
                          "message": "@entity.error",
                          "onRetry": "RETRY",
                          "title": "Authentication Failed"
                        },
                        {
                          "label": "Try Again",
                          "action": "RETRY",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "unauthenticated",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "variant": "h2",
                              "content": "Sign In",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "Google",
                              "value": "google"
                            },
                            {
                              "label": "GitHub",
                              "value": "github"
                            },
                            {
                              "label": "Microsoft",
                              "value": "microsoft"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Login",
                          "action": "LOGIN",
                          "icon": "log-in",
                          "variant": "primary"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceOauthPage",
          "path": "/serviceoauths",
          "traits": [
            {
              "ref": "ServiceOauthOauth"
            }
          ]
        }
      ]
    }
  ]
}
