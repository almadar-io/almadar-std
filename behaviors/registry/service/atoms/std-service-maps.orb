{
  "name": "std-service-maps",
  "version": "1.0.0",
  "description": "std-service-maps — Maps service for geocoding, reverse-geocoding, and distance via Mapbox/Google. Bind via `uses Maps from \"std/behaviors/std-service-maps\"` and configure `apiKey` / `provider` at the call site. Pass `uiTrait: \"@trait.YourMapsForm\"` to inject your own form; leave unset to render the atom's default geocode form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceMapsOrbital",
      "entity": {
        "name": "ServiceMaps",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "address",
            "type": "string",
            "default": ""
          },
          {
            "name": "lat",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "lng",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "formattedAddress",
            "type": "string",
            "default": ""
          },
          {
            "name": "distanceKm",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle",
            "values": [
              "idle",
              "geocoding",
              "succeeded",
              "error"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceMapsDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "GEOCODE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "address",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GEOCODE",
                "name": "Geocode"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "align": "stretch",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "map-pin"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Maps"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "Enter an address...",
                          "type": "input",
                          "inputType": "text"
                        },
                        {
                          "icon": "search",
                          "variant": "primary",
                          "action": "GEOCODE",
                          "type": "button",
                          "label": "Geocode"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceMapsMaps",
          "category": "interaction",
          "linkedEntity": "ServiceMaps",
          "emits": [
            {
              "event": "ServiceMapsLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceMapsLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GEOCODED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "lat",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "lng",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "formattedAddress",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVERSE_GEOCODED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "address",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DISTANCE_COMPUTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "distanceKm",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "GEOCODE",
              "triggers": "GEOCODE",
              "source": {
                "kind": "trait",
                "trait": "ServiceMapsDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "geocoding"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GEOCODE",
                "name": "Geocode",
                "payloadSchema": [
                  {
                    "name": "address",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVERSE_GEOCODE",
                "name": "Reverse Geocode",
                "payloadSchema": [
                  {
                    "name": "lat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "lng",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "DISTANCE",
                "name": "Distance",
                "payloadSchema": [
                  {
                    "name": "fromLat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "fromLng",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "toLat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "toLng",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "ServiceMapsLoaded",
                "name": "ServiceMaps loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceMapsLoadFailed",
                "name": "ServiceMaps load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GEOCODED",
                "name": "Geocoded",
                "payloadSchema": [
                  {
                    "name": "lat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "lng",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "formattedAddress",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVERSE_GEOCODED",
                "name": "Reverse Geocoded",
                "payloadSchema": [
                  {
                    "name": "address",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DISTANCE_COMPUTED",
                "name": "Distance Computed",
                "payloadSchema": [
                  {
                    "name": "distanceKm",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceMaps",
                    {
                      "emit": {
                        "success": "ServiceMapsLoaded",
                        "failure": "ServiceMapsLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "geocoding",
                "event": "GEOCODE",
                "effects": [
                  [
                    "set",
                    "@entity.address",
                    "@payload.address"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "geocoding"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Geocoding...",
                      "message": "Resolving address to coordinates.",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "maps",
                    "geocode",
                    {
                      "apiKey": "@config.apiKey",
                      "provider": "@config.provider",
                      "address": "@payload.address"
                    },
                    {
                      "emit": {
                        "success": "GEOCODED",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "geocoding",
                "event": "REVERSE_GEOCODE",
                "effects": [
                  [
                    "set",
                    "@entity.lat",
                    "@payload.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.lng"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "geocoding"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Resolving coordinates to address.",
                      "title": "Reverse geocoding...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "maps",
                    "reverseGeocode",
                    {
                      "lng": "@payload.lng",
                      "provider": "@config.provider",
                      "apiKey": "@config.apiKey",
                      "lat": "@payload.lat"
                    },
                    {
                      "emit": {
                        "success": "REVERSE_GEOCODED",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "geocoding",
                "event": "DISTANCE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "geocoding"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Computing distance...",
                      "message": "Calculating distance between points.",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "maps",
                    "distance",
                    {
                      "provider": "@config.provider",
                      "apiKey": "@config.apiKey",
                      "toLng": "@payload.toLng",
                      "fromLat": "@payload.fromLat",
                      "fromLng": "@payload.fromLng",
                      "toLat": "@payload.toLat"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "DISTANCE_COMPUTED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceMapsLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceMapsLoadFailed"
              },
              {
                "from": "geocoding",
                "to": "succeeded",
                "event": "GEOCODED",
                "effects": [
                  [
                    "set",
                    "@entity.lat",
                    "@payload.lat"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.lng"
                  ],
                  [
                    "set",
                    "@entity.formattedAddress",
                    "@payload.formattedAddress"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "message": "Address geocoded successfully",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@entity.formattedAddress"
                        },
                        {
                          "action": "RESET",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "New Lookup",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "geocoding",
                "to": "succeeded",
                "event": "REVERSE_GEOCODED",
                "effects": [
                  [
                    "set",
                    "@entity.address",
                    "@payload.address"
                  ],
                  [
                    "set",
                    "@entity.formattedAddress",
                    "@payload.address"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Coordinates reverse-geocoded successfully"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@entity.address"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "label": "New Lookup",
                          "action": "RESET",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "geocoding",
                "to": "succeeded",
                "event": "DISTANCE_COMPUTED",
                "effects": [
                  [
                    "set",
                    "@entity.distanceKm",
                    "@payload.distanceKm"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Distance computed successfully"
                        },
                        {
                          "content": "@entity.distanceKm",
                          "variant": "body",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "label": "New Lookup",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "RESET"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "geocoding",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Maps Request Failed",
                      "onRetry": "RETRY",
                      "message": "@entity.error",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "apiKey": {
              "type": "string",
              "default": ""
            },
            "provider": {
              "type": "string",
              "default": "mapbox"
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceMapsDefaultForm"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceMapsPage",
          "path": "/servicemaps",
          "traits": [
            {
              "ref": "ServiceMapsMaps"
            }
          ]
        }
      ]
    }
  ]
}
