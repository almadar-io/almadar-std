{
  "name": "std-service-print",
  "version": "1.0.0",
  "description": "std-service-print — Receipt / kitchen / label printer service (ESC/POS or web-print API). Bind via `uses Print from \"std/behaviors/std-service-print\"` and configure `defaultPrinter` at the call site. Pass `uiTrait: \"@trait.YourPrintForm\"` to inject your own form; leave unset to render the atom's default textarea + Print button standalone surface.",
  "orbitals": [
    {
      "name": "ServicePrintOrbital",
      "entity": {
        "name": "ServicePrint",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "printerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "kind",
            "type": "string",
            "default": "receipt",
            "values": [
              "receipt",
              "kitchen",
              "label"
            ]
          },
          {
            "name": "copies",
            "type": "number",
            "default": 1.0
          },
          {
            "name": "printJobId",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle",
            "values": [
              "idle",
              "printing",
              "succeeded",
              "error"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "ServicePrintDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "PRINT",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "printerName",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "kind",
                  "type": "string"
                },
                {
                  "name": "copies",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CHECK_STATUS",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "jobId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LIST_PRINTERS",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PRINT",
                "name": "Print"
              },
              {
                "key": "CHECK_STATUS",
                "name": "Check Status"
              },
              {
                "key": "LIST_PRINTERS",
                "name": "List Printers"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "printer"
                            },
                            {
                              "content": "Print",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "placeholder": "Printer name",
                              "type": "input"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Content to print"
                            },
                            {
                              "options": [
                                {
                                  "label": "Receipt",
                                  "value": "receipt"
                                },
                                {
                                  "value": "kitchen",
                                  "label": "Kitchen"
                                },
                                {
                                  "value": "label",
                                  "label": "Label"
                                }
                              ],
                              "type": "select"
                            }
                          ]
                        },
                        {
                          "label": "Print",
                          "variant": "primary",
                          "icon": "printer",
                          "type": "button",
                          "action": "PRINT"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServicePrintPrint",
          "category": "interaction",
          "linkedEntity": "ServicePrint",
          "emits": [
            {
              "event": "ServicePrintLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePrintLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePrintPrintQueued",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "jobId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePrintPrintFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServicePrintPrintersListed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "printers",
                  "type": "object"
                }
              ]
            },
            {
              "event": "PRINT_QUEUED",
              "payloadSchema": [
                {
                  "name": "jobId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PRINTERS_LISTED",
              "payloadSchema": [
                {
                  "name": "printers",
                  "type": "object"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "PRINT",
              "triggers": "PRINT",
              "source": {
                "kind": "trait",
                "trait": "ServicePrintDefaultForm"
              }
            },
            {
              "event": "CHECK_STATUS",
              "triggers": "CHECK_STATUS",
              "source": {
                "kind": "trait",
                "trait": "ServicePrintDefaultForm"
              }
            },
            {
              "event": "LIST_PRINTERS",
              "triggers": "LIST_PRINTERS",
              "source": {
                "kind": "trait",
                "trait": "ServicePrintDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "printing"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PRINT",
                "name": "Print",
                "payloadSchema": [
                  {
                    "name": "printerName",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "kind",
                    "type": "string"
                  },
                  {
                    "name": "copies",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "LIST_PRINTERS",
                "name": "List Printers",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHECK_STATUS",
                "name": "Check Status",
                "payloadSchema": [
                  {
                    "name": "jobId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PRINTERS_LISTED",
                "name": "Printers Listed",
                "payloadSchema": [
                  {
                    "name": "printers",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServicePrintLoaded",
                "name": "ServicePrint loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServicePrintLoadFailed",
                "name": "ServicePrint load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PRINT_QUEUED",
                "name": "Print Queued",
                "payloadSchema": [
                  {
                    "name": "jobId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServicePrintPrintQueued",
                "name": "ServicePrint print queued",
                "payloadSchema": [
                  {
                    "name": "jobId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServicePrintPrintersListed",
                "name": "ServicePrint printers listed",
                "payloadSchema": [
                  {
                    "name": "printers",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServicePrintPrintFailed",
                "name": "ServicePrint print failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.printerName",
                    "@config.defaultPrinter"
                  ],
                  [
                    "fetch",
                    "ServicePrint",
                    {
                      "emit": {
                        "success": "ServicePrintLoaded",
                        "failure": "ServicePrintLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "printing",
                "event": "PRINT",
                "effects": [
                  [
                    "set",
                    "@entity.printerName",
                    "@payload.printerName"
                  ],
                  [
                    "set",
                    "@entity.content",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.kind"
                  ],
                  [
                    "set",
                    "@entity.copies",
                    "@payload.copies"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Printing...",
                      "message": "Sending job to printer."
                    }
                  ],
                  [
                    "call-service",
                    "print",
                    "print",
                    {
                      "kind": "@entity.kind",
                      "copies": "@entity.copies",
                      "printerName": "@entity.printerName",
                      "content": "@entity.content"
                    },
                    {
                      "emit": {
                        "success": "PRINT_QUEUED",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "LIST_PRINTERS",
                "effects": [
                  [
                    "call-service",
                    "print",
                    "listPrinters",
                    {},
                    {
                      "emit": {
                        "success": "PRINTERS_LISTED",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CHECK_STATUS",
                "effects": [
                  [
                    "call-service",
                    "print",
                    "status",
                    {
                      "jobId": "@payload.jobId"
                    },
                    {
                      "emit": {
                        "success": "PRINT_QUEUED",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PRINTERS_LISTED",
                "effects": [
                  [
                    "emit",
                    "ServicePrintPrintersListed",
                    {
                      "printers": "@payload.printers"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServicePrintLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServicePrintLoadFailed"
              },
              {
                "from": "printing",
                "to": "succeeded",
                "event": "PRINT_QUEUED",
                "effects": [
                  [
                    "set",
                    "@entity.printJobId",
                    "@payload.jobId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "ServicePrintPrintQueued",
                    {
                      "jobId": "@entity.printJobId"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Print job queued!"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "color": "muted",
                          "content": "@entity.printJobId"
                        },
                        {
                          "label": "New Print",
                          "type": "button",
                          "action": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "printing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "emit",
                    "ServicePrintPrintFailed",
                    {
                      "error": "@entity.error",
                      "code": "print_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Print Failed",
                      "message": "@entity.error",
                      "type": "error-state",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "name": "printer",
                              "type": "icon"
                            },
                            {
                              "content": "Print",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "Printer name"
                            },
                            {
                              "placeholder": "Content to print",
                              "type": "textarea"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "receipt",
                                  "label": "Receipt"
                                },
                                {
                                  "value": "kitchen",
                                  "label": "Kitchen"
                                },
                                {
                                  "label": "Label",
                                  "value": "label"
                                }
                              ]
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "type": "button",
                          "action": "PRINT",
                          "icon": "printer",
                          "label": "Print",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "ServicePrintPrintQueued"
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "ServicePrintPrintersListed"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServicePrintPrintFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "printer"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Print"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "placeholder": "Printer name",
                              "type": "input"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Content to print"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "label": "Receipt",
                                  "value": "receipt"
                                },
                                {
                                  "value": "kitchen",
                                  "label": "Kitchen"
                                },
                                {
                                  "label": "Label",
                                  "value": "label"
                                }
                              ]
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "label": "Print",
                          "action": "PRINT",
                          "type": "button",
                          "variant": "primary",
                          "icon": "printer"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "printer"
                            },
                            {
                              "content": "Print",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "Printer name"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Content to print"
                            },
                            {
                              "options": [
                                {
                                  "label": "Receipt",
                                  "value": "receipt"
                                },
                                {
                                  "value": "kitchen",
                                  "label": "Kitchen"
                                },
                                {
                                  "label": "Label",
                                  "value": "label"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "icon": "printer",
                          "label": "Print",
                          "type": "button",
                          "variant": "primary",
                          "action": "PRINT"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServicePrintDefaultForm",
              "label": "Print form",
              "description": "Trait that renders the print job UI"
            },
            "defaultPrinter": {
              "type": "string",
              "default": "",
              "label": "Default printer",
              "description": "Name of the printer to send jobs to when none is chosen"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServicePrintPage",
          "path": "/serviceprints",
          "traits": [
            {
              "ref": "ServicePrintPrint"
            }
          ]
        }
      ]
    }
  ]
}