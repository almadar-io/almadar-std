{
  "name": "std-service-custom-bearer",
  "version": "2.0.0",
  "description": "std-service-custom-bearer — Bearer-token HTTP service. Bind via `uses CustomBearer from \"std/behaviors/std-service-custom-bearer\"` and configure `endpoint` / `method` / `body` / `token` at the call site. Pass `uiTrait: \"@trait.YourBearerForm\"` to inject your own request form; leave unset to render the atom's default test form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceCustomBearerOrbital",
      "entity": {
        "name": "ServiceCustomBearer",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "endpoint",
            "type": "string",
            "default": ""
          },
          {
            "name": "method",
            "type": "string",
            "default": "GET"
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "token",
            "type": "string",
            "default": ""
          },
          {
            "name": "callId",
            "type": "string",
            "default": ""
          },
          {
            "name": "statusCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCustomBearerDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "SEND",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "shield"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Bearer API Tester"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "options": [
                                {
                                  "label": "GET",
                                  "value": "GET"
                                },
                                {
                                  "label": "POST",
                                  "value": "POST"
                                },
                                {
                                  "label": "PUT",
                                  "value": "PUT"
                                },
                                {
                                  "value": "DELETE",
                                  "label": "DELETE"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "type": "input",
                              "placeholder": "/users"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "JSON request body"
                            },
                            {
                              "type": "input",
                              "inputType": "password",
                              "placeholder": "Bearer token"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "icon": "send",
                          "type": "button",
                          "label": "Send",
                          "action": "SEND",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceCustomBearerCustomBearer",
          "category": "interaction",
          "linkedEntity": "ServiceCustomBearer",
          "emits": [
            {
              "event": "ServiceCustomBearerLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomBearerLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomBearerCustomBearerCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomBearerCustomBearerFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BearerDone",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEND",
              "triggers": "SEND",
              "source": {
                "kind": "trait",
                "trait": "ServiceCustomBearerDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "calling"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "ServiceCustomBearerLoaded",
                "name": "ServiceCustomBearer loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomBearerLoadFailed",
                "name": "ServiceCustomBearer load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BearerDone",
                "name": "Bearer done",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceCustomBearerCustomBearerCompleted",
                "name": "ServiceCustomBearer custom bearer completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomBearerCustomBearerFailed",
                "name": "ServiceCustomBearer custom bearer failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.endpoint",
                    "@config.endpoint"
                  ],
                  [
                    "set",
                    "@entity.method",
                    "@config.method"
                  ],
                  [
                    "set",
                    "@entity.body",
                    "@config.body"
                  ],
                  [
                    "set",
                    "@entity.token",
                    "@config.token"
                  ],
                  [
                    "fetch",
                    "ServiceCustomBearer",
                    {
                      "emit": {
                        "success": "ServiceCustomBearerLoaded",
                        "failure": "ServiceCustomBearerLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Sending bearer-authenticated request...",
                      "title": "Calling API..."
                    }
                  ],
                  [
                    "call-service",
                    "customBearer",
                    "@config.method",
                    {
                      "body": "@config.body",
                      "token": "@config.token",
                      "endpoint": "@config.endpoint"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "BearerDone"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceCustomBearerLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceCustomBearerLoadFailed"
              },
              {
                "from": "calling",
                "to": "complete",
                "event": "BearerDone",
                "effects": [
                  [
                    "set",
                    "@entity.callId",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ServiceCustomBearerCustomBearerCompleted",
                    {
                      "id": "@payload.id",
                      "result": "@payload.result"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Request successful!",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "content": "@entity.callId",
                          "variant": "body",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "action": "RESET",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "New Request",
                          "variant": "ghost"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceCustomBearerCustomBearerFailed",
                    {
                      "error": "@entity.error",
                      "code": "bearer_call_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "onRetry": "RETRY",
                      "message": "@entity.error",
                      "title": "Request Failed"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "complete",
                "event": "ServiceCustomBearerCustomBearerCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceCustomBearerCustomBearerFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceCustomBearerDefaultForm",
              "label": "Request form",
              "description": "Trait that renders the bearer-token request UI"
            },
            "endpoint": {
              "type": "string",
              "default": "",
              "label": "API endpoint",
              "description": "URL path the bearer-authenticated HTTP request targets"
            },
            "token": {
              "type": "string",
              "default": "",
              "label": "Bearer token",
              "description": "Bearer token sent in the Authorization header"
            },
            "body": {
              "type": "string",
              "default": "",
              "label": "Request body",
              "description": "JSON body sent with non-GET requests"
            },
            "method": {
              "type": "string",
              "default": "GET",
              "label": "HTTP method",
              "description": "HTTP verb used for the request (GET, POST, PUT, DELETE)",
              "values": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceCustomBearerPage",
          "path": "/servicecustombearers",
          "traits": [
            {
              "ref": "ServiceCustomBearerCustomBearer"
            }
          ]
        }
      ]
    }
  ]
}