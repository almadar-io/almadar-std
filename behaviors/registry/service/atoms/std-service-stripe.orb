{
  "name": "std-service-stripe",
  "version": "1.0.0",
  "description": "std-service-stripe as a Function",
  "orbitals": [
    {
      "name": "ServiceStripeOrbital",
      "entity": {
        "name": "ServiceStripe",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "currency",
            "type": "string",
            "default": "usd"
          },
          {
            "name": "paymentIntentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "clientSecret",
            "type": "string",
            "default": ""
          },
          {
            "name": "paymentStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceStripeStripe",
          "category": "interaction",
          "linkedEntity": "ServiceStripe",
          "emits": [
            {
              "event": "ServiceStripeLoaded",
              "description": "Fired when ServiceStripe finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number"
                },
                {
                  "name": "currency",
                  "type": "string"
                },
                {
                  "name": "paymentIntentId",
                  "type": "string"
                },
                {
                  "name": "clientSecret",
                  "type": "string"
                },
                {
                  "name": "paymentStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStripeLoadFailed",
              "description": "Fired when ServiceStripe fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStripeStripeCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceStripeStripeFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "confirming"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              },
              {
                "key": "PAYMENT_CREATED",
                "name": "Payment Created",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "clientSecret",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAYMENT_CONFIRMED",
                "name": "Payment Confirmed"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceStripeLoaded",
                "name": "ServiceStripe loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number"
                  },
                  {
                    "name": "currency",
                    "type": "string"
                  },
                  {
                    "name": "paymentIntentId",
                    "type": "string"
                  },
                  {
                    "name": "clientSecret",
                    "type": "string"
                  },
                  {
                    "name": "paymentStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStripeLoadFailed",
                "name": "ServiceStripe load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStripeStripeCompleted",
                "name": "ServiceStripe stripe completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceStripeStripeFailed",
                "name": "ServiceStripe stripe failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceStripe",
                    {
                      "emit": {
                        "failure": "ServiceStripeLoadFailed",
                        "success": "ServiceStripeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "type": "typography",
                              "content": "Payment",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "placeholder": "0.00",
                              "type": "input",
                              "inputType": "number"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "usd",
                                  "label": "USD"
                                },
                                {
                                  "label": "EUR",
                                  "value": "eur"
                                },
                                {
                                  "value": "gbp",
                                  "label": "GBP"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "icon": "credit-card",
                          "variant": "primary",
                          "label": "Pay",
                          "type": "button",
                          "action": "CREATE_PAYMENT"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "creating",
                "event": "CREATE_PAYMENT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Creating payment...",
                      "type": "loading-state",
                      "message": "Setting up your payment intent."
                    }
                  ],
                  [
                    "call-service",
                    "stripe",
                    "createPaymentIntent",
                    {
                      "amount": "@entity.amount",
                      "currency": "@entity.currency"
                    },
                    {
                      "emit": {
                        "success": "ServiceStripeStripeCompleted",
                        "failure": "ServiceStripeStripeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "confirming",
                "event": "PAYMENT_CREATED",
                "effects": [
                  [
                    "set",
                    "@entity.paymentIntentId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.clientSecret",
                    "@payload.clientSecret"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Confirming payment...",
                      "type": "loading-state",
                      "message": "Processing your payment."
                    }
                  ],
                  [
                    "call-service",
                    "stripe",
                    "confirmPayment",
                    {
                      "paymentIntentId": "@entity.paymentIntentId"
                    },
                    {
                      "emit": {
                        "success": "ServiceStripeStripeCompleted",
                        "failure": "ServiceStripeStripeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.error",
                      "type": "error-state",
                      "title": "Payment Failed",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "succeeded",
                "event": "PAYMENT_CONFIRMED",
                "effects": [
                  [
                    "set",
                    "@entity.paymentStatus",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "success",
                          "message": "Payment successful!",
                          "type": "alert"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.paymentIntentId"
                        },
                        {
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "RESET",
                          "label": "New Payment"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "message": "@entity.error",
                      "title": "Payment Failed",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "content": "Payment",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "inputType": "number",
                              "placeholder": "0.00",
                              "type": "input"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "label": "USD",
                                  "value": "usd"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "label": "GBP",
                                  "value": "gbp"
                                }
                              ]
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "variant": "primary",
                          "label": "Pay",
                          "icon": "credit-card",
                          "type": "button",
                          "action": "CREATE_PAYMENT"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Payment",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "input",
                              "inputType": "number",
                              "placeholder": "0.00"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "usd",
                                  "label": "USD"
                                },
                                {
                                  "label": "EUR",
                                  "value": "eur"
                                },
                                {
                                  "label": "GBP",
                                  "value": "gbp"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "icon": "credit-card",
                          "label": "Pay",
                          "action": "CREATE_PAYMENT",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Payment",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "inputType": "number",
                              "type": "input",
                              "placeholder": "0.00"
                            },
                            {
                              "options": [
                                {
                                  "label": "USD",
                                  "value": "usd"
                                },
                                {
                                  "label": "EUR",
                                  "value": "eur"
                                },
                                {
                                  "label": "GBP",
                                  "value": "gbp"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "action": "CREATE_PAYMENT",
                          "label": "Pay",
                          "icon": "credit-card",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceStripePage",
          "path": "/servicestripes",
          "traits": [
            {
              "ref": "ServiceStripeStripe"
            }
          ]
        }
      ]
    }
  ]
}
