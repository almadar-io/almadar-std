{
  "name": "std-service-redis",
  "version": "2.0.0",
  "description": "std-service-redis — Redis cache service. Bind via `uses Redis from \"std/behaviors/std-service-redis\"` and configure `op` / `key` / `value` / `ttl` at the call site. Pass `uiTrait: \"@trait.YourRedisForm\"` to inject your own form; leave unset to render the atom's default form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceRedisOrbital",
      "entity": {
        "name": "ServiceRedis",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "key",
            "type": "string",
            "default": ""
          },
          {
            "name": "value",
            "type": "string",
            "default": ""
          },
          {
            "name": "ttl",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "op",
            "type": "string",
            "default": "get",
            "values": [
              "get",
              "set",
              "del"
            ]
          },
          {
            "name": "result",
            "type": "object",
            "default": {}
          },
          {
            "name": "redisStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceRedisDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "EXEC",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXEC",
                "name": "Exec"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "database"
                            },
                            {
                              "variant": "h2",
                              "content": "Redis Cache",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "vertical",
                          "gap": "md",
                          "children": [
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "get",
                                  "label": "Get"
                                },
                                {
                                  "value": "set",
                                  "label": "Set"
                                },
                                {
                                  "value": "del",
                                  "label": "Delete"
                                }
                              ]
                            },
                            {
                              "type": "input",
                              "placeholder": "cache-key"
                            },
                            {
                              "type": "input",
                              "placeholder": "cache-value"
                            },
                            {
                              "type": "input",
                              "inputType": "number",
                              "placeholder": "ttl seconds"
                            }
                          ]
                        },
                        {
                          "action": "EXEC",
                          "variant": "primary",
                          "icon": "play",
                          "label": "Execute",
                          "type": "button"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceRedisRedis",
          "category": "interaction",
          "linkedEntity": "ServiceRedis",
          "emits": [
            {
              "event": "ServiceRedisLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceRedisLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RedisDone",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceRedisRedisFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "EXEC",
              "triggers": "EXEC",
              "source": {
                "kind": "trait",
                "trait": "ServiceRedisDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXEC",
                "name": "Exec"
              },
              {
                "key": "ServiceRedisLoaded",
                "name": "ServiceRedis loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceRedisLoadFailed",
                "name": "ServiceRedis load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RedisDone",
                "name": "Redis done",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceRedisRedisFailed",
                "name": "ServiceRedis redis failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.key",
                    "@config.key"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@config.value"
                  ],
                  [
                    "set",
                    "@entity.ttl",
                    "@config.ttl"
                  ],
                  [
                    "set",
                    "@entity.op",
                    "@config.op"
                  ],
                  [
                    "fetch",
                    "ServiceRedis",
                    {
                      "emit": {
                        "success": "ServiceRedisLoaded",
                        "failure": "ServiceRedisLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "EXEC",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Running redis operation...",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "@config.op",
                    {
                      "key": "@config.key",
                      "value": "@config.value",
                      "ttl": "@config.ttl"
                    },
                    {
                      "emit": {
                        "success": "RedisDone",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceRedisLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceRedisLoadFailed"
              },
              {
                "from": "executing",
                "to": "complete",
                "event": "RedisDone",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.redisStatus",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Operation complete",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.result",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "action": "RESET",
                          "type": "button",
                          "variant": "ghost",
                          "label": "Reset",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceRedisRedisFailed",
                    {
                      "error": "@entity.error",
                      "code": "redis_op_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Redis Error",
                      "type": "error-state",
                      "message": "@entity.error",
                      "onRetry": "RESET"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "complete",
                "event": "RedisDone"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceRedisRedisFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "ttl": {
              "type": "number",
              "default": 0.0
            },
            "value": {
              "type": "string",
              "default": ""
            },
            "op": {
              "type": "string",
              "default": "get",
              "values": [
                "get",
                "set",
                "del"
              ]
            },
            "key": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceRedisDefaultForm"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceRedisPage",
          "path": "/servicerediss",
          "traits": [
            {
              "ref": "ServiceRedisRedis"
            }
          ]
        }
      ]
    }
  ]
}
