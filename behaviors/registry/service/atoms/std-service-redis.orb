{
  "name": "std-service-redis",
  "version": "1.0.0",
  "description": "std-service-redis as a Function",
  "orbitals": [
    {
      "name": "ServiceRedisOrbital",
      "entity": {
        "name": "ServiceRedis",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "key",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          },
          {
            "name": "ttl",
            "type": "number",
            "default": 3600.0
          },
          {
            "name": "result",
            "type": "string"
          },
          {
            "name": "redisStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceRedisRedis",
          "category": "interaction",
          "linkedEntity": "ServiceRedis",
          "emits": [
            {
              "event": "ServiceRedisLoaded",
              "description": "Fired when ServiceRedis finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "key",
                  "type": "string"
                },
                {
                  "name": "value",
                  "type": "string"
                },
                {
                  "name": "ttl",
                  "type": "number"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "redisStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceRedisLoadFailed",
              "description": "Fired when ServiceRedis fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceRedisRedisCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceRedisRedisFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GET_KEY",
                "name": "Get Key"
              },
              {
                "key": "SET_KEY",
                "name": "Set Key"
              },
              {
                "key": "DELETE_KEY",
                "name": "Delete Key"
              },
              {
                "key": "EXECUTED",
                "name": "Executed",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceRedisLoaded",
                "name": "ServiceRedis loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "key",
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "type": "string"
                  },
                  {
                    "name": "ttl",
                    "type": "number"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "redisStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceRedisLoadFailed",
                "name": "ServiceRedis load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceRedisRedisCompleted",
                "name": "ServiceRedis redis completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceRedisRedisFailed",
                "name": "ServiceRedis redis failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceRedis",
                    {
                      "emit": {
                        "failure": "ServiceRedisLoadFailed",
                        "success": "ServiceRedisLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "database"
                            },
                            {
                              "content": "Redis Cache",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "placeholder": "cache-key",
                              "type": "input"
                            },
                            {
                              "placeholder": "cache-value",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "3600",
                              "inputType": "number"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "action": "GET_KEY",
                              "label": "Get",
                              "variant": "primary",
                              "icon": "download"
                            },
                            {
                              "label": "Set",
                              "action": "SET_KEY",
                              "type": "button",
                              "variant": "primary",
                              "icon": "upload"
                            },
                            {
                              "type": "button",
                              "action": "DELETE_KEY",
                              "label": "Delete",
                              "icon": "trash-2",
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "GET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Executing...",
                      "message": "Running redis operation..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "get",
                    {
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "success": "ServiceRedisRedisCompleted",
                        "failure": "ServiceRedisRedisFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "SET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Running redis operation...",
                      "type": "loading-state",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "set",
                    {
                      "ttl": "@entity.ttl",
                      "key": "@entity.key",
                      "value": "@entity.value"
                    },
                    {
                      "emit": {
                        "failure": "ServiceRedisRedisFailed",
                        "success": "ServiceRedisRedisCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DELETE_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Running redis operation...",
                      "type": "loading-state",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "delete",
                    {
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "success": "ServiceRedisRedisCompleted",
                        "failure": "ServiceRedisRedisFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "complete",
                "event": "EXECUTED",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Operation complete"
                        },
                        {
                          "content": "@entity.result",
                          "color": "muted",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "variant": "ghost",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RESET",
                      "title": "Redis Error",
                      "message": "@entity.error",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "database"
                            },
                            {
                              "content": "Redis Cache",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "cache-key"
                            },
                            {
                              "placeholder": "cache-value",
                              "type": "input"
                            },
                            {
                              "inputType": "number",
                              "type": "input",
                              "placeholder": "3600"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "primary",
                              "icon": "download",
                              "label": "Get",
                              "action": "GET_KEY",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "SET_KEY",
                              "icon": "upload",
                              "label": "Set"
                            },
                            {
                              "icon": "trash-2",
                              "label": "Delete",
                              "type": "button",
                              "action": "DELETE_KEY",
                              "variant": "danger"
                            }
                          ],
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "database"
                            },
                            {
                              "type": "typography",
                              "content": "Redis Cache",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "cache-key"
                            },
                            {
                              "type": "input",
                              "placeholder": "cache-value"
                            },
                            {
                              "type": "input",
                              "placeholder": "3600",
                              "inputType": "number"
                            }
                          ],
                          "gap": "md",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Get",
                              "action": "GET_KEY",
                              "variant": "primary",
                              "type": "button",
                              "icon": "download"
                            },
                            {
                              "variant": "primary",
                              "label": "Set",
                              "action": "SET_KEY",
                              "type": "button",
                              "icon": "upload"
                            },
                            {
                              "type": "button",
                              "icon": "trash-2",
                              "action": "DELETE_KEY",
                              "variant": "danger",
                              "label": "Delete"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceRedisPage",
          "path": "/servicerediss",
          "traits": [
            {
              "ref": "ServiceRedisRedis"
            }
          ]
        }
      ]
    }
  ]
}
