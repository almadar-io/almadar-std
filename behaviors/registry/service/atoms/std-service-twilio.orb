{
  "name": "std-service-twilio",
  "version": "2.0.0",
  "description": "std-service-twilio — Twilio messaging service. Bind via `uses Twilio from \"std/behaviors/std-service-twilio\"` and configure `recipient` / `body` / `sender` / `mode` at the call site (mapped to Twilio `to`/`body`/`from`/`mode`). Pass `uiTrait: \"@trait.YourMessagingForm\"` to inject your own form; leave unset to render the atom's default test form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceTwilioOrbital",
      "entity": {
        "name": "ServiceTwilio",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "to",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "from",
            "type": "string",
            "default": ""
          },
          {
            "name": "mode",
            "type": "string",
            "default": "sms",
            "values": [
              "sms",
              "voice",
              "whatsapp"
            ]
          },
          {
            "name": "messageSid",
            "type": "string",
            "default": ""
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceTwilioDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "SEND",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "stretch",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "type": "typography",
                              "content": "Twilio Messaging",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "+1234567890",
                          "inputType": "tel",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "options": [
                            {
                              "value": "sms",
                              "label": "SMS"
                            },
                            {
                              "label": "Voice",
                              "value": "voice"
                            },
                            {
                              "label": "WhatsApp",
                              "value": "whatsapp"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "icon": "send",
                          "label": "Send",
                          "action": "SEND"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceTwilioTwilio",
          "category": "interaction",
          "linkedEntity": "ServiceTwilio",
          "emits": [
            {
              "event": "ServiceTwilioLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TwilioSent",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEND",
              "triggers": "SEND",
              "source": {
                "kind": "trait",
                "trait": "ServiceTwilioDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "ServiceTwilioLoaded",
                "name": "ServiceTwilio loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioLoadFailed",
                "name": "ServiceTwilio load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TwilioSent",
                "name": "Twilio sent",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceTwilioTwilioCompleted",
                "name": "ServiceTwilio twilio completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioTwilioFailed",
                "name": "ServiceTwilio twilio failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.to",
                    "@config.recipient"
                  ],
                  [
                    "set",
                    "@entity.body",
                    "@config.body"
                  ],
                  [
                    "set",
                    "@entity.mode",
                    "@config.mode"
                  ],
                  [
                    "fetch",
                    "ServiceTwilio",
                    {
                      "emit": {
                        "success": "ServiceTwilioLoaded",
                        "failure": "ServiceTwilioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Delivering your message.",
                      "title": "Sending message..."
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendSMS",
                    {
                      "body": "@config.body",
                      "to": "@config.recipient"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "TwilioSent"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceTwilioLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceTwilioLoadFailed"
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "TwilioSent",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.messageSid",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ServiceTwilioTwilioCompleted",
                    {
                      "id": "@entity.messageSid"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Message sent successfully",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.messageSid",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "variant": "ghost",
                          "type": "button",
                          "label": "Send Another",
                          "action": "RESET",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceTwilioTwilioFailed",
                    {
                      "error": "@entity.error",
                      "code": "send_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.error",
                      "type": "error-state",
                      "title": "Send Failed",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "sent",
                "event": "ServiceTwilioTwilioCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceTwilioTwilioFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "sender": {
              "type": "string",
              "default": ""
            },
            "recipient": {
              "type": "string",
              "default": ""
            },
            "body": {
              "type": "string",
              "default": ""
            },
            "mode": {
              "type": "string",
              "default": "sms",
              "values": [
                "sms",
                "voice",
                "whatsapp"
              ]
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceTwilioDefaultForm"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceTwilioPage",
          "path": "/servicetwilios",
          "traits": [
            {
              "ref": "ServiceTwilioTwilio"
            }
          ]
        }
      ]
    }
  ]
}
