{
  "name": "std-service-twilio",
  "version": "1.0.0",
  "description": "std-service-twilio as a Function",
  "orbitals": [
    {
      "name": "ServiceTwilioOrbital",
      "entity": {
        "name": "ServiceTwilio",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "messageBody",
            "type": "string"
          },
          {
            "name": "channel",
            "type": "string",
            "default": "sms"
          },
          {
            "name": "messageSid",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceTwilioTwilio",
          "category": "interaction",
          "linkedEntity": "ServiceTwilio",
          "emits": [
            {
              "event": "ServiceTwilioLoaded",
              "description": "Fired when ServiceTwilio finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "to",
                  "type": "string"
                },
                {
                  "name": "messageBody",
                  "type": "string"
                },
                {
                  "name": "channel",
                  "type": "string"
                },
                {
                  "name": "messageSid",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioLoadFailed",
              "description": "Fired when ServiceTwilio fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_SMS",
                "name": "Send Sms"
              },
              {
                "key": "SEND_WHATSAPP",
                "name": "Send Whatsapp"
              },
              {
                "key": "SENT",
                "name": "Sent",
                "payloadSchema": [
                  {
                    "name": "messageSid",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceTwilioLoaded",
                "name": "ServiceTwilio loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "to",
                    "type": "string"
                  },
                  {
                    "name": "messageBody",
                    "type": "string"
                  },
                  {
                    "name": "channel",
                    "type": "string"
                  },
                  {
                    "name": "messageSid",
                    "type": "string"
                  },
                  {
                    "name": "sendStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioLoadFailed",
                "name": "ServiceTwilio load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioTwilioCompleted",
                "name": "ServiceTwilio twilio completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceTwilioTwilioFailed",
                "name": "ServiceTwilio twilio failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceTwilio",
                    {
                      "emit": {
                        "success": "ServiceTwilioLoaded",
                        "failure": "ServiceTwilioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "message-circle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "ServiceTwilio Messaging",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "+1234567890",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "icon": "message-circle",
                              "action": "SEND_SMS",
                              "label": "Send SMS",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "icon": "phone",
                              "variant": "secondary",
                              "label": "Send WhatsApp",
                              "action": "SEND_WHATSAPP"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "align": "stretch",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_SMS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Delivering servicetwilio message...",
                      "type": "loading-state",
                      "title": "Sending message..."
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendSMS",
                    {
                      "to": "@entity.to",
                      "body": "@entity.messageBody"
                    },
                    {
                      "emit": {
                        "failure": "ServiceTwilioTwilioFailed",
                        "success": "ServiceTwilioTwilioCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_WHATSAPP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Delivering servicetwilio message...",
                      "title": "Sending message..."
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendWhatsApp",
                    {
                      "body": "@entity.messageBody",
                      "to": "@entity.to"
                    },
                    {
                      "emit": {
                        "success": "ServiceTwilioTwilioCompleted",
                        "failure": "ServiceTwilioTwilioFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.messageSid",
                    "@payload.messageSid"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "message": "Message sent successfully",
                          "variant": "success"
                        },
                        {
                          "label": "Send Another",
                          "action": "RESET",
                          "variant": "ghost",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "title": "Send Failed",
                          "message": "Could not deliver the message.",
                          "type": "error-state",
                          "onRetry": "RETRY"
                        },
                        {
                          "children": [
                            {
                              "variant": "primary",
                              "icon": "refresh-cw",
                              "type": "button",
                              "action": "RETRY",
                              "label": "Retry"
                            },
                            {
                              "variant": "ghost",
                              "label": "Reset",
                              "action": "RESET",
                              "type": "button",
                              "icon": "rotate-ccw"
                            }
                          ],
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "variant": "h2",
                              "content": "ServiceTwilio Messaging",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "+1234567890"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "children": [
                            {
                              "label": "Send SMS",
                              "variant": "primary",
                              "type": "button",
                              "action": "SEND_SMS",
                              "icon": "message-circle"
                            },
                            {
                              "type": "button",
                              "label": "Send WhatsApp",
                              "action": "SEND_WHATSAPP",
                              "icon": "phone",
                              "variant": "secondary"
                            }
                          ],
                          "type": "stack",
                          "justify": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "stretch"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "name": "message-circle",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceTwilio Messaging"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "+1234567890"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "justify": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "action": "SEND_SMS",
                              "variant": "primary",
                              "label": "Send SMS",
                              "type": "button",
                              "icon": "message-circle"
                            },
                            {
                              "label": "Send WhatsApp",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "phone",
                              "action": "SEND_WHATSAPP"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "stretch"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "content": "ServiceTwilio Messaging",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "+1234567890"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "type": "stack",
                          "justify": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "button",
                              "variant": "primary",
                              "icon": "message-circle",
                              "label": "Send SMS",
                              "action": "SEND_SMS"
                            },
                            {
                              "type": "button",
                              "action": "SEND_WHATSAPP",
                              "variant": "secondary",
                              "icon": "phone",
                              "label": "Send WhatsApp"
                            }
                          ],
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceTwilioPage",
          "path": "/servicetwilios",
          "traits": [
            {
              "ref": "ServiceTwilioTwilio"
            }
          ]
        }
      ]
    }
  ]
}