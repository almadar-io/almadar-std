{
  "name": "std-service-calendar-ical",
  "version": "1.0.0",
  "description": "std-service-calendar-ical — iCal export service. Bind via `uses CalendarIcal from \"std/behaviors/std-service-calendar-ical\"` and configure `eventName` / `startsAt` / `endsAt` / `description` / `location` at the call site. Pass `uiTrait: \"@trait.YourEventForm\"` to inject your own form; leave unset to render the atom's default event form (standalone surface). Generates an .ics file attendees can add to Google/Apple Calendar.",
  "orbitals": [
    {
      "name": "ServiceCalendarIcalOrbital",
      "entity": {
        "name": "ServiceCalendarIcal",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "eventName",
            "type": "string",
            "default": ""
          },
          {
            "name": "startsAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "endsAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "location",
            "type": "string",
            "default": ""
          },
          {
            "name": "icsContent",
            "type": "string",
            "default": ""
          },
          {
            "name": "downloadUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "idle",
            "values": [
              "idle",
              "generating",
              "succeeded",
              "error"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCalendarIcalDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "GENERATE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                },
                {
                  "name": "eventName",
                  "type": "string"
                },
                {
                  "name": "startsAt",
                  "type": "string"
                },
                {
                  "name": "endsAt",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "Add to Calendar",
                              "type": "typography"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "inputType": "text",
                              "placeholder": "Event name",
                              "type": "input"
                            },
                            {
                              "inputType": "text",
                              "placeholder": "Starts at (ISO 8601)",
                              "type": "input"
                            },
                            {
                              "inputType": "text",
                              "placeholder": "Ends at (ISO 8601)",
                              "type": "input"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md"
                        },
                        {
                          "icon": "calendar",
                          "variant": "primary",
                          "type": "button",
                          "label": "Generate .ics",
                          "action": "GENERATE"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceCalendarIcalIcal",
          "category": "interaction",
          "linkedEntity": "ServiceCalendarIcal",
          "emits": [
            {
              "event": "ServiceCalendarIcalLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCalendarIcalLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GENERATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "icsContent",
                  "type": "string"
                },
                {
                  "name": "downloadUrl",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCalendarIcalIcalFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "GENERATE",
              "triggers": "GENERATE",
              "source": {
                "kind": "trait",
                "trait": "ServiceCalendarIcalDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "generating"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  },
                  {
                    "name": "eventName",
                    "type": "string"
                  },
                  {
                    "name": "startsAt",
                    "type": "string"
                  },
                  {
                    "name": "endsAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCalendarIcalLoaded",
                "name": "ServiceCalendarIcal loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCalendarIcalLoadFailed",
                "name": "ServiceCalendarIcal load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GENERATED",
                "name": "Generated",
                "payloadSchema": [
                  {
                    "name": "icsContent",
                    "type": "string"
                  },
                  {
                    "name": "downloadUrl",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceCalendarIcalIcalFailed",
                "name": "ServiceCalendarIcal ical failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.eventName",
                    "@config.eventName"
                  ],
                  [
                    "set",
                    "@entity.startsAt",
                    "@config.startsAt"
                  ],
                  [
                    "set",
                    "@entity.endsAt",
                    "@config.endsAt"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@config.description"
                  ],
                  [
                    "set",
                    "@entity.location",
                    "@config.location"
                  ],
                  [
                    "fetch",
                    "ServiceCalendarIcal",
                    {
                      "emit": {
                        "success": "ServiceCalendarIcalLoaded",
                        "failure": "ServiceCalendarIcalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "generating",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "generating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Creating your calendar file.",
                      "title": "Generating .ics...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "calendar-ical",
                    "generate",
                    {
                      "startsAt": "@entity.startsAt",
                      "location": "@entity.location",
                      "eventName": "@entity.eventName",
                      "endsAt": "@entity.endsAt",
                      "description": "@entity.description"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "GENERATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceCalendarIcalLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceCalendarIcalLoadFailed"
              },
              {
                "from": "generating",
                "to": "succeeded",
                "event": "GENERATED",
                "effects": [
                  [
                    "set",
                    "@entity.icsContent",
                    "@payload.icsContent"
                  ],
                  [
                    "set",
                    "@entity.downloadUrl",
                    "@payload.downloadUrl"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Calendar file ready!",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "type": "typography",
                          "content": "@entity.downloadUrl"
                        },
                        {
                          "variant": "primary",
                          "icon": "download",
                          "label": "Download .ics",
                          "type": "button",
                          "action": "RESET"
                        },
                        {
                          "type": "button",
                          "label": "New Event",
                          "icon": "rotate-ccw",
                          "action": "RESET",
                          "variant": "ghost"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "generating",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "error"
                  ],
                  [
                    "emit",
                    "ServiceCalendarIcalIcalFailed",
                    {
                      "error": "@entity.error",
                      "code": "generate_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Generation Failed",
                      "type": "error-state",
                      "message": "@entity.error",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "GENERATED"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceCalendarIcalIcalFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "location": {
              "type": "string",
              "default": ""
            },
            "startsAt": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceCalendarIcalDefaultForm"
            },
            "eventName": {
              "type": "string",
              "default": ""
            },
            "endsAt": {
              "type": "string",
              "default": ""
            },
            "description": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceCalendarIcalPage",
          "path": "/servicecalendaricals",
          "traits": [
            {
              "ref": "ServiceCalendarIcalIcal"
            }
          ]
        }
      ]
    }
  ]
}
