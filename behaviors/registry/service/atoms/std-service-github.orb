{
  "name": "std-service-github",
  "version": "2.0.0",
  "description": "std-service-github — GitHub service. Bind via `uses Github from \"std/behaviors/std-service-github\"` and configure `owner` / `repo` / `path` / `ref` / `op` at the call site. Pass `uiTrait: \"@trait.YourGithubForm\"` to inject your own form; leave unset to render the atom's default form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceGithubOrbital",
      "entity": {
        "name": "ServiceGithub",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "owner",
            "type": "string",
            "default": ""
          },
          {
            "name": "repo",
            "type": "string",
            "default": ""
          },
          {
            "name": "path",
            "type": "string",
            "default": ""
          },
          {
            "name": "ref",
            "type": "string",
            "default": "main"
          },
          {
            "name": "result",
            "type": "object",
            "default": {}
          },
          {
            "name": "ghStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceGithubDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "RUN",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RUN",
                "name": "Run"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "github"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "GitHub"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "options": [
                                {
                                  "label": "Get File",
                                  "value": "getFile"
                                },
                                {
                                  "label": "List Commits",
                                  "value": "listCommits"
                                },
                                {
                                  "value": "createIssue",
                                  "label": "Create Issue"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "type": "input",
                              "placeholder": "owner"
                            },
                            {
                              "placeholder": "repo",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "path"
                            },
                            {
                              "placeholder": "ref (default: main)",
                              "type": "input"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Run",
                          "action": "RUN",
                          "icon": "play"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceGithubGithub",
          "category": "interaction",
          "linkedEntity": "ServiceGithub",
          "emits": [
            {
              "event": "ServiceGithubLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceGithubLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GithubDone",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceGithubGithubFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "RUN",
              "triggers": "RUN",
              "source": {
                "kind": "trait",
                "trait": "ServiceGithubDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RUN",
                "name": "Run"
              },
              {
                "key": "ServiceGithubLoaded",
                "name": "ServiceGithub loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceGithubLoadFailed",
                "name": "ServiceGithub load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GithubDone",
                "name": "Github done",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceGithubGithubFailed",
                "name": "ServiceGithub github failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.owner",
                    "@config.owner"
                  ],
                  [
                    "set",
                    "@entity.repo",
                    "@config.repo"
                  ],
                  [
                    "set",
                    "@entity.path",
                    "@config.path"
                  ],
                  [
                    "set",
                    "@entity.ref",
                    "@config.ref"
                  ],
                  [
                    "fetch",
                    "ServiceGithub",
                    {
                      "emit": {
                        "success": "ServiceGithubLoaded",
                        "failure": "ServiceGithubLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "running",
                "event": "RUN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Running GitHub operation...",
                      "type": "loading-state",
                      "message": "Calling the GitHub service."
                    }
                  ],
                  [
                    "call-service",
                    "github",
                    "@config.op",
                    {
                      "path": "@config.path",
                      "repo": "@config.repo",
                      "owner": "@config.owner",
                      "ref": "@config.ref"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "GithubDone"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceGithubLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceGithubLoadFailed"
              },
              {
                "from": "running",
                "to": "succeeded",
                "event": "GithubDone",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.ghStatus",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "GithubDone",
                    {
                      "result": "@payload.result",
                      "id": "@entity.id"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "GitHub operation completed!"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.id",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "action": "RESET",
                          "type": "button",
                          "label": "Run Again",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceGithubGithubFailed",
                    {
                      "error": "@entity.error",
                      "code": "github_op_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "onRetry": "RETRY",
                      "title": "GitHub Operation Failed",
                      "message": "@entity.error"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "GithubDone"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceGithubGithubFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "repo": {
              "type": "string",
              "default": ""
            },
            "op": {
              "type": "string",
              "default": "getFile",
              "values": [
                "getFile",
                "listCommits",
                "createIssue"
              ]
            },
            "ref": {
              "type": "string",
              "default": "main"
            },
            "owner": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceGithubDefaultForm"
            },
            "path": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceGithubPage",
          "path": "/servicegithubs",
          "traits": [
            {
              "ref": "ServiceGithubGithub"
            }
          ]
        }
      ]
    }
  ]
}
