{
  "name": "std-service-youtube",
  "version": "2.0.0",
  "description": "std-service-youtube. YouTube embed service. Bind via `uses Youtube from \"std/behaviors/std-service-youtube\"` and configure `videoId` / `autoplay` / `controls` / `start` at the call site. SPECIAL: the default render IS the embed itself, so passing `uiTrait: \"@trait.YourPlayerSkin\"` OVERRIDES the embed (e.g., a custom player skin) rather than supplements it. Leave `uiTrait` unset to render the atom's default embed.",
  "orbitals": [
    {
      "name": "ServiceYoutubeOrbital",
      "entity": {
        "name": "ServiceYoutube",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "videoId",
            "type": "string",
            "default": ""
          },
          {
            "name": "autoplay",
            "type": "boolean",
            "default": false
          },
          {
            "name": "controls",
            "type": "boolean",
            "default": true
          },
          {
            "name": "start",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceYoutubeDefaultPlayer",
          "category": "interaction",
          "emits": [
            {
              "event": "PLAY",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "READY",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAY",
                "name": "Play"
              },
              {
                "key": "READY",
                "name": "Ready"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "card",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "video"
                            },
                            {
                              "content": "YouTube Video",
                              "type": "typography",
                              "variant": "h2"
                            },
                            {
                              "type": "typography",
                              "content": "@config.videoId",
                              "variant": "body",
                              "color": "muted"
                            },
                            {
                              "children": [
                                {
                                  "type": "button",
                                  "action": "PLAY",
                                  "variant": "primary",
                                  "icon": "play",
                                  "label": "Play"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "justify": "center"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "PLAY",
                "effects": [
                  [
                    "emit",
                    "PLAY",
                    {
                      "source": "default-player"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceYoutubeYoutube",
          "category": "interaction",
          "linkedEntity": "ServiceYoutube",
          "emits": [
            {
              "event": "ServiceYoutubeLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeYoutubeReady",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "videoId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeYoutubeFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "READY",
              "triggers": "READY",
              "source": {
                "kind": "trait",
                "trait": "ServiceYoutubeDefaultPlayer"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "ready"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "READY",
                "name": "Ready"
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ServiceYoutubeLoaded",
                "name": "ServiceYoutube loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeLoadFailed",
                "name": "ServiceYoutube load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeYoutubeReady",
                "name": "ServiceYoutube youtube ready",
                "payloadSchema": [
                  {
                    "name": "videoId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeYoutubeFailed",
                "name": "ServiceYoutube youtube failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.videoId",
                    "@config.videoId"
                  ],
                  [
                    "set",
                    "@entity.autoplay",
                    "@config.autoplay"
                  ],
                  [
                    "set",
                    "@entity.controls",
                    "@config.controls"
                  ],
                  [
                    "set",
                    "@entity.start",
                    "@config.start"
                  ],
                  [
                    "fetch",
                    "ServiceYoutube",
                    {
                      "emit": {
                        "success": "ServiceYoutubeLoaded",
                        "failure": "ServiceYoutubeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "ready",
                "event": "READY",
                "effects": [
                  [
                    "emit",
                    "ServiceYoutubeYoutubeReady",
                    {
                      "videoId": "@entity.videoId"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceYoutubeYoutubeFailed",
                    {
                      "code": "youtube_embed_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Video Failed",
                      "type": "error-state",
                      "message": "@entity.error",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceYoutubeLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceYoutubeLoadFailed"
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "ServiceYoutubeYoutubeReady"
              },
              {
                "from": "ready",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceYoutubeYoutubeFailed",
                    {
                      "error": "@entity.error",
                      "code": "youtube_playback_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "title": "Video Failed",
                      "type": "error-state",
                      "message": "@entity.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceYoutubeYoutubeFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "emit",
                    "FAILED",
                    {
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceYoutubeDefaultPlayer",
              "label": "Player skin",
              "description": "Trait that replaces the default YouTube embed surface"
            },
            "autoplay": {
              "type": "boolean",
              "default": false,
              "label": "Autoplay",
              "description": "Start playback automatically when the embed loads"
            },
            "videoId": {
              "type": "string",
              "default": "",
              "label": "YouTube video ID",
              "description": "Eleven-character YouTube ID from the share URL"
            },
            "controls": {
              "type": "boolean",
              "default": true,
              "label": "Show controls",
              "description": "Display the YouTube player controls overlay"
            },
            "start": {
              "type": "number",
              "default": 0.0,
              "label": "Start at seconds",
              "description": "Number of seconds to skip in before playback begins"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceYoutubePage",
          "path": "/serviceyoutubes",
          "traits": [
            {
              "ref": "ServiceYoutubeYoutube"
            }
          ]
        }
      ]
    }
  ]
}