{
  "name": "std-service-storage",
  "version": "1.0.0",
  "description": "std-service-storage as a Function",
  "orbitals": [
    {
      "name": "ServiceStorageOrbital",
      "entity": {
        "name": "ServiceStorage",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "bucket",
            "type": "string",
            "default": "uploads"
          },
          {
            "name": "fileKey",
            "type": "string"
          },
          {
            "name": "prefix",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "storageStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "result",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceStorageStorage",
          "category": "interaction",
          "linkedEntity": "ServiceStorage",
          "emits": [
            {
              "event": "ServiceStorageLoaded",
              "description": "Fired when ServiceStorage finishes loading",
              "scope": "internal",
              "payload": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "bucket",
                  "type": "string"
                },
                {
                  "name": "fileKey",
                  "type": "string"
                },
                {
                  "name": "prefix",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "storageStatus",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStorageLoadFailed",
              "description": "Fired when ServiceStorage fails to load",
              "scope": "internal",
              "payload": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStorageStorageCompleted",
              "scope": "internal",
              "payload": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceStorageStorageFailed",
              "scope": "internal",
              "payload": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD_FILE",
                "name": "Upload File"
              },
              {
                "key": "DOWNLOAD_FILE",
                "name": "Download File"
              },
              {
                "key": "LIST_FILES",
                "name": "List Files"
              },
              {
                "key": "DELETE_FILE",
                "name": "Delete File"
              },
              {
                "key": "EXECUTED",
                "name": "Executed",
                "payload": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceStorageLoaded",
                "name": "ServiceStorage loaded",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "bucket",
                    "type": "string"
                  },
                  {
                    "name": "fileKey",
                    "type": "string"
                  },
                  {
                    "name": "prefix",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "storageStatus",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStorageLoadFailed",
                "name": "ServiceStorage load failed",
                "payload": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStorageStorageCompleted",
                "name": "ServiceStorage storage completed",
                "payload": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceStorageStorageFailed",
                "name": "ServiceStorage storage failed",
                "payload": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ServiceStorage",
                    {
                      "emit": {
                        "failure": "ServiceStorageLoadFailed",
                        "success": "ServiceStorageLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "hard-drive",
                              "type": "icon"
                            },
                            {
                              "content": "ServiceStorage Storage",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "bucket-name"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/to/file.txt"
                        },
                        {
                          "placeholder": "path/prefix/",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "File content..."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "UPLOAD_FILE",
                              "label": "Upload",
                              "type": "button",
                              "icon": "upload"
                            },
                            {
                              "type": "button",
                              "variant": "secondary",
                              "icon": "download",
                              "label": "Download",
                              "action": "DOWNLOAD_FILE"
                            },
                            {
                              "icon": "list",
                              "action": "LIST_FILES",
                              "label": "List",
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "icon": "trash-2",
                              "type": "button",
                              "action": "DELETE_FILE"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "UPLOAD_FILE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Executing storage operation on servicestorage...",
                      "title": "Processing...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "key": "@entity.fileKey",
                      "content": "@entity.content",
                      "bucket": "@entity.bucket"
                    },
                    {
                      "emit": {
                        "failure": "ServiceStorageStorageFailed",
                        "success": "ServiceStorageStorageCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DOWNLOAD_FILE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Executing storage operation on servicestorage...",
                      "title": "Processing...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "download",
                    {
                      "bucket": "@entity.bucket",
                      "key": "@entity.fileKey"
                    },
                    {
                      "emit": {
                        "success": "ServiceStorageStorageCompleted",
                        "failure": "ServiceStorageStorageFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "LIST_FILES",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Processing...",
                      "message": "Executing storage operation on servicestorage..."
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "list",
                    {
                      "bucket": "@entity.bucket",
                      "prefix": "@entity.prefix"
                    },
                    {
                      "emit": {
                        "failure": "ServiceStorageStorageFailed",
                        "success": "ServiceStorageStorageCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DELETE_FILE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Executing storage operation on servicestorage...",
                      "type": "loading-state",
                      "title": "Processing..."
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "delete",
                    {
                      "key": "@entity.fileKey",
                      "bucket": "@entity.bucket"
                    },
                    {
                      "emit": {
                        "failure": "ServiceStorageStorageFailed",
                        "success": "ServiceStorageStorageCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "complete",
                "event": "EXECUTED",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.storageStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Operation completed successfully"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.result",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "type": "button",
                          "action": "RESET",
                          "label": "Back",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.storageStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "title": "Operation Failed",
                          "message": "@entity.error",
                          "type": "error-state"
                        },
                        {
                          "action": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Back"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.storageStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "hard-drive"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "ServiceStorage Storage"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "bucket-name"
                        },
                        {
                          "placeholder": "path/to/file.txt",
                          "type": "input"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/prefix/"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "File content..."
                        },
                        {
                          "children": [
                            {
                              "label": "Upload",
                              "variant": "primary",
                              "icon": "upload",
                              "action": "UPLOAD_FILE",
                              "type": "button"
                            },
                            {
                              "action": "DOWNLOAD_FILE",
                              "label": "Download",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "download"
                            },
                            {
                              "action": "LIST_FILES",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "list",
                              "label": "List"
                            },
                            {
                              "label": "Delete",
                              "icon": "trash-2",
                              "variant": "danger",
                              "type": "button",
                              "action": "DELETE_FILE"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.storageStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "name": "hard-drive",
                              "type": "icon"
                            },
                            {
                              "content": "ServiceStorage Storage",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "bucket-name"
                        },
                        {
                          "placeholder": "path/to/file.txt",
                          "type": "input"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/prefix/"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "File content..."
                        },
                        {
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Upload",
                              "variant": "primary",
                              "action": "UPLOAD_FILE",
                              "icon": "upload"
                            },
                            {
                              "type": "button",
                              "icon": "download",
                              "variant": "secondary",
                              "action": "DOWNLOAD_FILE",
                              "label": "Download"
                            },
                            {
                              "action": "LIST_FILES",
                              "type": "button",
                              "variant": "secondary",
                              "label": "List",
                              "icon": "list"
                            },
                            {
                              "variant": "danger",
                              "type": "button",
                              "action": "DELETE_FILE",
                              "label": "Delete",
                              "icon": "trash-2"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "align": "stretch",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceStoragePage",
          "path": "/servicestorages",
          "traits": [
            {
              "ref": "ServiceStorageStorage"
            }
          ]
        }
      ]
    }
  ]
}