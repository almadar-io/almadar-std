{
  "name": "std-service-llm",
  "version": "2.0.0",
  "description": "std-service-llm — LLM completion service. Bind via `uses Llm from \"std/behaviors/std-service-llm\"` and configure `provider` / `model` / `prompt` / `temperature` / `maxTokens` at the call site. Pass `uiTrait: \"@trait.YourLlmForm\"` to inject your own prompt form; leave unset to render the atom's default form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceLlmOrbital",
      "entity": {
        "name": "ServiceLlm",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string",
            "default": "openai"
          },
          {
            "name": "model",
            "type": "string",
            "default": "gpt-4"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "temperature",
            "type": "number",
            "default": 0.7
          },
          {
            "name": "maxTokens",
            "type": "number",
            "default": 2048.0
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "llmStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceLlmDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "COMPLETE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "LLM Completion",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "options": [
                                {
                                  "value": "openai",
                                  "label": "OpenAI"
                                },
                                {
                                  "value": "anthropic",
                                  "label": "Anthropic"
                                },
                                {
                                  "value": "google",
                                  "label": "Google"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "options": [
                                {
                                  "label": "GPT-4",
                                  "value": "gpt-4"
                                },
                                {
                                  "value": "gpt-4-turbo",
                                  "label": "GPT-4 Turbo"
                                },
                                {
                                  "label": "Claude 3.5 Sonnet",
                                  "value": "claude-3-5-sonnet"
                                },
                                {
                                  "value": "gemini-pro",
                                  "label": "Gemini Pro"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "placeholder": "Enter your prompt...",
                              "type": "textarea"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "input",
                                  "placeholder": "Temperature (0.0 - 2.0)",
                                  "inputType": "number"
                                },
                                {
                                  "inputType": "number",
                                  "placeholder": "Max tokens",
                                  "type": "input"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "icon": "sparkles",
                          "action": "COMPLETE",
                          "type": "button",
                          "variant": "primary",
                          "label": "Complete"
                        }
                      ],
                      "align": "stretch",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceLlmLlm",
          "category": "interaction",
          "linkedEntity": "ServiceLlm",
          "emits": [
            {
              "event": "ServiceLlmLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LlmCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLlmFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "COMPLETE",
              "triggers": "COMPLETE",
              "source": {
                "kind": "trait",
                "trait": "ServiceLlmDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "processing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "ServiceLlmLoaded",
                "name": "ServiceLlm loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceLlmLoadFailed",
                "name": "ServiceLlm load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LlmCompleted",
                "name": "Llm completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceLlmLlmFailed",
                "name": "ServiceLlm llm failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    "@config.provider"
                  ],
                  [
                    "set",
                    "@entity.model",
                    "@config.model"
                  ],
                  [
                    "set",
                    "@entity.prompt",
                    "@config.prompt"
                  ],
                  [
                    "set",
                    "@entity.temperature",
                    "@config.temperature"
                  ],
                  [
                    "set",
                    "@entity.maxTokens",
                    "@config.maxTokens"
                  ],
                  [
                    "fetch",
                    "ServiceLlm",
                    {
                      "emit": {
                        "failure": "ServiceLlmLoadFailed",
                        "success": "ServiceLlmLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@config.uiTrait"
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Calling LLM provider.",
                      "type": "loading-state",
                      "title": "Generating..."
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "generate",
                    {
                      "userPrompt": "@config.prompt",
                      "model": "@config.model",
                      "temperature": "@config.temperature",
                      "maxTokens": "@config.maxTokens"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "LlmCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceLlmLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceLlmLoadFailed"
              },
              {
                "from": "processing",
                "to": "complete",
                "event": "LlmCompleted",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "message": "LLM completion ready",
                          "type": "alert"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.result",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Start Over",
                          "variant": "ghost",
                          "action": "RESET"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "error"
                  ],
                  [
                    "emit",
                    "ServiceLlmLlmFailed",
                    {
                      "code": "llm_complete_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.error",
                      "onRetry": "RETRY",
                      "type": "error-state",
                      "title": "LLM Failed"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "complete",
                "event": "LlmCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceLlmLlmFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@config.uiTrait"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@config.uiTrait"
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "provider": {
              "type": "string",
              "default": "openai",
              "label": "Provider",
              "description": "LLM vendor to call (openai, anthropic, google, etc.)"
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceLlmDefaultForm",
              "label": "Prompt form",
              "description": "Trait that renders the LLM prompt UI"
            },
            "prompt": {
              "type": "string",
              "default": "",
              "label": "Prompt text",
              "description": "Prompt sent to the model for completion"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "label": "Temperature",
              "description": "Sampling randomness, 0.0 deterministic to 2.0 highly creative"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048.0,
              "label": "Max tokens",
              "description": "Upper bound on tokens in the model's response"
            },
            "model": {
              "type": "string",
              "default": "gpt-4",
              "label": "Model",
              "description": "Specific model identifier from the chosen provider"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceLlmPage",
          "path": "/servicellms",
          "traits": [
            {
              "ref": "ServiceLlmLlm"
            }
          ]
        }
      ]
    }
  ]
}