app std-wizard-form "1.0.0"
"std-wizard-form — canonical molecule-level wizard example"
;;
;; Wizards are not an atom. Their state machine shape IS the wizard —
;; every consumer has a different step count and domain-specific flow.
;; Encoding a wizard in a reusable atom is a false abstraction; atoms
;; exist to encode PORTABLE state machines (Modal = open/closed,
;; Confirmation = idle/confirming). Wizards fail that bar.
;;
;; This molecule is the reference: a 3-step sign-up flow authored
;; entirely at molecule tier with ONE trait that owns its state
;; machine. UI reuse happens through `@almadar/patterns`
;; (`wizard-progress`, `wizard-navigation`, `progress-dots`) —
;; NOT through a `std-wizard` atom import.
;;
;; See `docs/Almadar_Std_Behaviors.md` "Atom-tier criterion" for the
;; principle, and `std-cart` for the broader own-trait pattern.

orbital WizardFormOrbital {
  entity WizardFormEntry [persistent: wizardformentries] {
    id    : string!
    name  : string
    email : string
    theme : string
  }

  type WizardFormSaved      = Event { id : string }                   "Fired when wizard flow completes successfully"
  type WizardFormSaveFailed = Event { error : string, code : string } "Fired when the final persist fails"

  trait WizardFormFlow -> WizardFormEntry [interaction, instance] {
    initial: personal
    state personal {
      INIT -> personal
        (fetch WizardFormEntry)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Sign-up" },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Personal Info" },
          { type: "form-section", entity: "WizardFormEntry", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["name", "email"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 3, showBack: false, showNext: true, showComplete: false, onNext: "NEXT" }
        ] })
      NEXT -> preferences
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Sign-up" },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Preferences" },
          { type: "form-section", entity: "WizardFormEntry", mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["theme"] },
          { type: "wizard-navigation", currentStep: 1, totalSteps: 3, showBack: true, showNext: true, showComplete: false, onBack: "PREV", onNext: "NEXT" }
        ] })
    }
    state preferences {
      NEXT -> review
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Sign-up" },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 2 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Review" },
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Theme" }, { type: "typography", variant: "body", content: "@entity.theme" }] }
          ] },
          { type: "wizard-navigation", currentStep: 2, totalSteps: 3, showBack: true, showNext: false, showComplete: true, onBack: "PREV", onComplete: "COMPLETE" }
        ] })
      PREV -> personal
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Sign-up" },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Personal Info" },
          { type: "form-section", entity: "WizardFormEntry", mode: "edit", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["name", "email"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 3, showBack: false, showNext: true, showComplete: false, onNext: "NEXT" }
        ] })
    }
    state review {
      COMPLETE -> persisting
        (persist create WizardFormEntry @payload.data { emit: { success: "WizardFormSaved", failure: "WizardFormSaveFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "spinner" },
          { type: "typography", variant: "caption", color: "muted", content: "Completing sign-up…" }
        ] })
      PREV -> preferences
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Sign-up" },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Preferences" },
          { type: "form-section", entity: "WizardFormEntry", mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["theme"] },
          { type: "wizard-navigation", currentStep: 1, totalSteps: 3, showBack: true, showNext: true, showComplete: false, onBack: "PREV", onNext: "NEXT" }
        ] })
    }
    state persisting {
      WizardFormSaved -> complete
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "icon", name: "check-circle" },
          { type: "typography", variant: "h2", content: "Welcome!" },
          { type: "typography", variant: "body", color: "muted", content: "Your account has been created." },
          { type: "button", label: "Start Over", action: "RESTART", variant: "ghost", icon: "rotate-ccw" }
        ] })
      WizardFormSaveFailed -> review
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "icon", name: "alert-triangle", color: "destructive" },
          { type: "typography", variant: "h2", content: "Sign-up Failed" },
          { type: "alert", variant: "error", message: "@payload.error" },
          { type: "button", label: "Retry", action: "COMPLETE", variant: "primary", icon: "refresh-cw" }
        ] })
    }
    state complete {
      RESTART -> personal
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Sign-up" },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Personal Info" },
          { type: "form-section", entity: "WizardFormEntry", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["name", "email"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 3, showBack: false, showNext: true, showComplete: false, onNext: "NEXT" }
        ] })
    }
    emits: [WizardFormSaved, WizardFormSaveFailed]
    listens {
      NEXT                   { data : object! }
      PREV                   { }
      COMPLETE               { data : object! }
      WizardFormSaveFailed   { error : string, code : string }
    }
  }

  page "/wizard-form" as WizardForm -> WizardFormFlow
}
