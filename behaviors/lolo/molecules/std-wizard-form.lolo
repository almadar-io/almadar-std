app std-wizard-form "1.0.0"
"std-wizard-form as a Function"
;;
;; Multi-step form. Wizard drives the step flow, Input renders each step's
;; field, ValidateOnSave gates the final submit. Two-hop @trait.X exercise:
;; WizardFormWizard embeds @trait.WizardFormInput inside its own step render.
;; Composition wires:
;;   WizardFormWizard emits STEP_COMPLETED external -> WizardFormValidate.VALIDATE
;;   WizardFormValidate emits VALIDATED external     -> WizardFormWizard.NEXT
;;   WizardFormInput emits INPUT_CHANGED external    -> WizardFormWizard.UPDATE

orbital WizardFormOrbital {
  uses Wizard   from "std/behaviors/std-wizard"
  uses Input    from "std/behaviors/std-input"
  uses Validate from "std/behaviors/std-validate-on-save"

  entity WizardFormEntry [persistent: wizardformentries] {
    id : string!
    step : string
    name : string
    email : string
  }

  trait WizardFormInput = Input.traits.TextInputInput -> WizardFormEntry {}

  trait WizardFormWizard = Wizard.traits.WizardEntryWizard -> WizardFormEntry {
    ;; Override the step-render frame to embed WizardFormInput inside.
    on RENDER_STEP {
      (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-xl mx-auto w-full", children: [{ type: "typography", variant: "h2", content: "@entity.step" }, { type: "divider" }, "@trait.WizardFormInput", { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", event: "PREV", variant: "ghost" }, { type: "button", label: "Next", event: "NEXT", variant: "primary" }] }] })
    }
  }

  trait WizardFormValidate = Validate.traits.OrbFileWatcher -> WizardFormEntry {
  }

  trait WizardFormLayout -> WizardFormEntry [interaction, instance] {
    state composing {
      INIT -> composing
        (fetch WizardFormEntry)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@trait.WizardFormWizard"] })
    }
  }

  page "/wizard-form" as WizardForm -> WizardFormLayout
}
