app std-wizard-form "1.0.0"
"std-wizard-form as a Function"
;;
;; Multi-step form using std-wizard's built-in rendering. Previously this
;; molecule overrode RENDER_STEP to embed `@trait.WizardFormInput` inline
;; — the trait-embedding showcase. Phase 9.5.H removes `on EVENT` overrides,
;; and std-wizard doesn't yet have a `contentTrait` config to support
;; external trait embedding. See G7 in the gaps doc (trait-embedding).
;;
;; Current molecule just refs std-wizard; its default rendering is used.
;; The Validate coordinator is wired via listens.

orbital WizardFormOrbital {
  uses Wizard   from "std/behaviors/std-wizard"
  uses Validate from "std/behaviors/std-validate-on-save"

  entity WizardFormEntry [persistent: wizardformentries] {
    id    : string!
    step  : string
    name  : string
    email : string
  }

  trait WizardFormWizard = Wizard.traits.WizardEntryWizard -> WizardFormEntry {}

  trait WizardFormValidate = Validate.traits.OrbFileWatcher -> WizardFormEntry {}

  page "/wizard-form" as WizardForm -> WizardFormWizard
}
