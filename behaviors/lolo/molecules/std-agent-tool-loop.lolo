app std-agent-tool-loop "1.0.0"
"std-agent-tool-loop as a Function"

orbital AgentToolLoopOrbital {
  uses AgentCompletion from "std/behaviors/std-agent-completion"
  uses AgentContextWindow from "std/behaviors/std-agent-context-window"
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"
  uses AgentToolCall from "std/behaviors/std-agent-tool-call"

  entity AgentToolLoop [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    task : string = ""
    plan : string = ""
    iterations : number = 0
    maxIterations : number = 10
    result : string = ""
    currentTool : string = ""
    lastToolResult : string = ""
    error : string = ""
    currentStep : number = 0
    totalSteps : number = 4
    steps : string = "Plan,Execute,Check,Complete"
    toolName : string = ""
    args : string = ""
    prompt : string = ""
    response : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
    tokenCount : number = 0
    maxTokens : number = 200000
    usage : number = 0
    current : number = 0
    max : number = 200000
    threshold : number = 0.85
    lastCompactedAt : string = ""
    action : string = ""
    detail : string = ""
    timestamp : string = ""
    duration : number = 0
  }

  type AgentToolLoopLoaded     = Event AgentToolLoop                  "Fired when AgentToolLoop finishes loading"
  type AgentToolLoopLoadFailed = Event { message : string } "Fired when AgentToolLoop fails to load"
  trait AgentToolLoopLoop -> AgentToolLoop [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: "AgentToolLoop", mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] })
      EXECUTE -> planning
        (set @entity.status planning)
        (set @entity.iterations 0)
        (agent/generate (str/concat "Task: " @entity.task "\n\nAvailable tools: " (str/join (agent/tools) ", ") "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "Planning execution...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "@entity.task", variant: "caption" }] })
    }
    state planning {
      PLAN_GENERATED -> executing
        (set @entity.plan @payload.plan)
        (set @entity.currentTool @payload.toolName)
        (set @entity.iterations (+ @entity.iterations 1))
        (agent/invoke @payload.toolName @payload.toolArgs)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "tool"}, { type: "typography", content: "Executing Tool", variant: "h2" }] }, { type: "badge", label: "@entity.maxIterations" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Current Tool", variant: "caption" }, { type: "typography", content: "@entity.currentTool", variant: "h4" }, { type: "spinner"}] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Plan", variant: "caption" }, { type: "typography", content: "@entity.plan", variant: "body" }] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state executing {
      TOOL_RESULT -> checking
        (set @entity.lastToolResult @payload.output)
        (agent/generate (str/concat "Task: " @entity.task "\nPlan: " @entity.plan "\nTool output: " @payload.output "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "eye"}, { type: "typography", content: "Checking result...", variant: "h3" }, { type: "spinner"}, { type: "badge", label: "@entity.iterations" }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state checking {
      CHECK_PASSED -> completed
        (set @entity.result @payload.result)
        (set @entity.status completed)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Loop Complete", variant: "h2" }] }, { type: "button", label: "New Task", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Status", value: "@entity.status", icon: "check" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Task", variant: "caption" }, { type: "typography", content: "@entity.task", variant: "body" }, { type: "divider" }, { type: "typography", content: "Result", variant: "caption" }, { type: "typography", content: "@entity.result", variant: "body" }] }] }] })
      CHECK_NEEDS_MORE -> executing
        (set @entity.currentTool @payload.toolName)
        (set @entity.iterations (+ @entity.iterations 1))
        (if (>= (agent/context-usage) 0.8) (agent/compact hybrid) (log "Context below compact threshold"))
        (agent/invoke @payload.toolName @payload.toolArgs)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "tool"}, { type: "typography", content: "Executing Tool", variant: "h2" }] }, { type: "badge", label: "@entity.maxIterations" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Current Tool", variant: "caption" }, { type: "typography", content: "@entity.currentTool", variant: "h4" }, { type: "spinner"}] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Plan", variant: "caption" }, { type: "typography", content: "@entity.plan", variant: "body" }] }] }] })
      MAX_ITERATIONS -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: "AgentToolLoop", mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: "AgentToolLoop", mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] })
    }
    listens {
      PLAN_GENERATED { plan : string!, toolName : string!, toolArgs : object! }
      TOOL_RESULT { output : string! }
      CHECK_PASSED { result : string! }
      CHECK_NEEDS_MORE { toolName : string!, toolArgs : object! }
      MAX_ITERATIONS { error : string! }
      FAILED { error : string! }
    }
  }
  trait ToolLoopStepProgress = AgentStepProgress.traits.AgentStepProgressProgress -> AgentToolLoop {
    emitsScope internal
  }
  trait ToolLoopCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentToolLoop {
    emitsScope internal
  }
  trait ToolLoopToolCallFlow = AgentToolCall.traits.AgentToolCallModal -> AgentToolLoop {
    emitsScope internal
  }
  trait ToolLoopContextMonitor = AgentContextWindow.traits.AgentContextWindowGauge -> AgentToolLoop {
    emitsScope internal
  }
  page "/agenttoolloops" as AgentToolLoopPage -> AgentToolLoopLoop, ToolLoopStepProgress, ToolLoopCompletionFlow, ToolLoopToolCallFlow, ToolLoopContextMonitor
}