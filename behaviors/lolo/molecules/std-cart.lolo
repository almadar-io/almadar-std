app std-cart "1.0.0"
"std-cart as a Function"
;;
;; Daisy-chain composition showcase (no `on EVENT` overrides).
;; Modal + Confirmation trait refs are configured via `config: { ... }`
;; at the call site. Side effects (persist) live in sibling coordinator
;; traits that listen for the modal/confirmation trait's emits.

orbital CartItemOrbital {
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Modal        from "std/behaviors/std-modal"

  entity CartItem [persistent: cartitems] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    pendingId : string = ""
  }

  type CartItemLoaded     = Event { data : object }       "Fired when the cart collection finishes loading; payload.data holds the CartItem list"
  type CartItemLoadFailed = Event { message : string }    "Fired when the cart collection fails to load"

  trait CartItemCartBrowse -> CartItem [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch CartItem { emit: { success: "CartItemLoaded", failure: "CartItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner", size: "lg" }, { type: "typography", variant: "caption", color: "muted", content: "Loading cart…" }] })
      CartItemLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "shopping-cart", size: "lg" }, { type: "typography", content: "Shopping Cart", variant: "h2" }] }, { type: "button", label: "Add Item", action: "ADD_ITEM", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Remove", event: "REQUEST_REMOVE", variant: "danger" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "shopping-cart" }, { name: "description", label: "Description", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }] }] })
      CartItemLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", size: "xl", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load cart" }, { type: "typography", variant: "body", color: "muted", content: "@payload.message" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch CartItem { emit: { success: "CartItemLoaded", failure: "CartItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "lg" })
    }
    state error {
      INIT -> loading
        (fetch CartItem { emit: { success: "CartItemLoaded", failure: "CartItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "lg" })
    }
    emits: [CartItemLoaded, CartItemLoadFailed]
    listens {
      CartItemLoadFailed { message : string }
      CartItemPersistor ITEM_CREATED  -> INIT
      CartItemPersistor ITEM_DELETED  -> INIT
    }
  }

  ;; Add-item modal: configured via `config`, no effects overrides.
  trait CartItemAddItem = Modal.traits.ModalRecordModal -> CartItem {
    config: {
      icon: "plus-circle",
      title: "Add Item",
      openButtonLabel: "Add Item",
      fields: ["name", "description", "status"],
      mode: "create"
    }
    events {
      OPEN: ADD_ITEM
    }
  }

  ;; Remove-confirm: configured via `config`, no effects overrides.
  trait CartItemRemoveConfirm = Confirmation.traits.ConfirmActionConfirmation -> CartItem {
    config: {
      icon: "alert-triangle",
      title: "Remove Item",
      alertMessage: "Are you sure you want to remove this item from your cart?",
      confirmLabel: "Remove"
    }
    events {
      REQUEST: REQUEST_REMOVE
      CONFIRM: CONFIRM_REMOVE
    }
  }

  ;; Coordinator trait: owns the persist side-effects triggered by the
  ;; Modal/Confirmation trait refs' emits. This replaces the old
  ;; `on SAVE { (persist create ...) }` override pattern.
  trait CartItemPersistor -> CartItem [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create CartItem @payload.data)
        (emit ITEM_CREATED { id: "@payload.data.id" })
      DO_DELETE -> idle
        (persist delete CartItem @payload.id)
        (emit ITEM_DELETED { id: "@payload.id" })
    }
    emits {
      ITEM_CREATED external { id : string }
      ITEM_DELETED external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      CartItemAddItem      SAVE           -> DO_CREATE
      CartItemRemoveConfirm CONFIRM_REMOVE -> DO_DELETE
    }
  }

  page "/cart" as CartItemPage -> CartItemCartBrowse, CartItemAddItem, CartItemRemoveConfirm, CartItemPersistor
}
