app std-service-devops-toolkit "1.0.0"
"std-service-devops-toolkit as a Function"

orbital ServiceDevopsToolkitOrbital {
  entity ServiceDevopsToolkit [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    title : string = ""
    body : string = ""
    head : string = ""
    base : string = "main"
    prUrl : string = ""
    cacheKey : string = ""
    cacheValue : string = ""
    bucket : string = "uploads"
    fileKey : string = ""
    result : string = ""
    toolStatus : string = "idle"
    activeTab : string = "github"
    error : string = ""
  }

  type ServiceDevopsToolkitLoaded     = Event ServiceDevopsToolkit                  "Fired when ServiceDevopsToolkit finishes loading"
  type ServiceDevopsToolkitLoadFailed = Event { message : string } "Fired when ServiceDevopsToolkit fails to load"
  type ServiceDevopsToolkitGithubCompleted = Event { result : object }
  type ServiceDevopsToolkitGithubFailed = Event { error : string, code : string }
  type ServiceDevopsToolkitRedisCompleted = Event { result : object }
  type ServiceDevopsToolkitRedisFailed = Event { error : string, code : string }
  type ServiceDevopsToolkitStorageCompleted = Event { result : object }
  type ServiceDevopsToolkitStorageFailed = Event { error : string, code : string }
  trait ServiceDevopsToolkitGithub -> ServiceDevopsToolkit [interaction, instance] {
    initial: ghIdle
    state ghIdle {
      INIT -> ghIdle
        (fetch ServiceDevopsToolkit { emit: { success: "ServiceDevopsToolkitLoaded", failure: "ServiceDevopsToolkitLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "git-pull-request" }, { type: "typography", content: "GitHub: Create PR", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "PR title" }, { type: "textarea", placeholder: "Describe your changes..." }, { type: "input", placeholder: "feature-branch" }, { type: "input", placeholder: "main" }, { type: "button", label: "Create PR", action: "CREATE_PR", variant: "primary", icon: "git-pull-request" }] })
      CREATE_PR -> creatingPR
        (render-ui main { type: "loading-state", title: "Creating pull request...", message: "Submitting your PR to GitHub." })
        (call-service github "createPR" { title: "@entity.title", body: "@entity.body", head: "@entity.head", base: "@entity.base" } { emit: { success: "ServiceDevopsToolkitGithubCompleted", failure: "ServiceDevopsToolkitGithubFailed" } })
    }
    state creatingPR {
      PR_CREATED -> prCreated
        (set @entity.prUrl @payload.url)
        (set @entity.toolStatus pr-created)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Pull request created!" }, { type: "typography", variant: "body", color: "muted", content: "@entity.prUrl" }, { type: "button", label: "Create Another", action: "GH_RESET", variant: "ghost", icon: "rotate-ccw" }] })
      GH_FAILED -> ghError
        (set @entity.error @payload.error)
        (set @entity.toolStatus error)
        (render-ui main { type: "error-state", title: "PR Creation Failed", message: "@entity.error", onRetry: "GH_RETRY" })
    }
    state prCreated {
      GH_RESET -> ghIdle
        (set @entity.toolStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "git-pull-request" }, { type: "typography", content: "GitHub: Create PR", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "PR title" }, { type: "textarea", placeholder: "Describe your changes..." }, { type: "input", placeholder: "feature-branch" }, { type: "input", placeholder: "main" }, { type: "button", label: "Create PR", action: "CREATE_PR", variant: "primary", icon: "git-pull-request" }] })
    }
    state ghError {
      GH_RETRY -> ghIdle
        (set @entity.toolStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "git-pull-request" }, { type: "typography", content: "GitHub: Create PR", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "PR title" }, { type: "textarea", placeholder: "Describe your changes..." }, { type: "input", placeholder: "feature-branch" }, { type: "input", placeholder: "main" }, { type: "button", label: "Create PR", action: "CREATE_PR", variant: "primary", icon: "git-pull-request" }] })
    }
    listens {
      PR_CREATED { url : string! }
      GH_FAILED { error : string! }
          ServiceDevopsToolkitLoadFailed { message : string }
    
      ServiceDevopsToolkitGithubFailed { error : string, code : string }
      ServiceDevopsToolkitRedisFailed { error : string, code : string }
      ServiceDevopsToolkitStorageFailed { error : string, code : string }
    }
    emits: [ServiceDevopsToolkitLoaded, ServiceDevopsToolkitLoadFailed, ServiceDevopsToolkitGithubCompleted, ServiceDevopsToolkitGithubFailed, ServiceDevopsToolkitRedisCompleted, ServiceDevopsToolkitRedisFailed, ServiceDevopsToolkitStorageCompleted, ServiceDevopsToolkitStorageFailed]
  }
  trait ServiceDevopsToolkitRedis -> ServiceDevopsToolkit [interaction, instance] {
    initial: redisIdle
    state redisIdle {
      INIT -> redisIdle
        (fetch ServiceDevopsToolkit { emit: { success: "ServiceDevopsToolkitLoaded", failure: "ServiceDevopsToolkitLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] })
      GET_KEY -> redisExecuting
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running Redis operation..." })
        (call-service redis get { key: "@entity.cacheKey" } { emit: { success: "ServiceDevopsToolkitRedisCompleted", failure: "ServiceDevopsToolkitRedisFailed" } })
      SET_KEY -> redisExecuting
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running Redis operation..." })
        (call-service redis set { key: "@entity.cacheKey", value: "@entity.cacheValue" } { emit: { success: "ServiceDevopsToolkitRedisCompleted", failure: "ServiceDevopsToolkitRedisFailed" } })
      DELETE_KEY -> redisExecuting
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running Redis operation..." })
        (call-service redis delete { key: "@entity.cacheKey" } { emit: { success: "ServiceDevopsToolkitRedisCompleted", failure: "ServiceDevopsToolkitRedisFailed" } })
    }
    state redisExecuting {
      REDIS_DONE -> redisComplete
        (set @entity.result @payload.data)
        (set @entity.toolStatus redis-complete)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Redis operation complete" }, { type: "typography", variant: "body", color: "muted", content: "@entity.result" }, { type: "button", label: "Reset", action: "REDIS_RESET", variant: "ghost", icon: "rotate-ccw" }] })
      REDIS_FAILED -> redisError
        (set @entity.error @payload.error)
        (set @entity.toolStatus error)
        (render-ui main { type: "error-state", title: "Redis Error", message: "@entity.error", onRetry: "REDIS_RETRY" })
    }
    state redisComplete {
      REDIS_RESET -> redisIdle
        (set @entity.toolStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] })
    }
    state redisError {
      REDIS_RETRY -> redisIdle
        (set @entity.toolStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] })
    }
    listens {
      REDIS_DONE { data : string! }
      REDIS_FAILED { error : string! }
          ServiceDevopsToolkitLoadFailed { message : string }
    }
    emits: [ServiceDevopsToolkitLoadFailed, ServiceDevopsToolkitLoaded, ServiceDevopsToolkitRedisCompleted, ServiceDevopsToolkitRedisFailed]
  }
  trait ServiceDevopsToolkitStorage -> ServiceDevopsToolkit [interaction, instance] {
    initial: storageIdle
    state storageIdle {
      INIT -> storageIdle
        (fetch ServiceDevopsToolkit { emit: { success: "ServiceDevopsToolkitLoaded", failure: "ServiceDevopsToolkitLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Storage Files", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "bucket-name" }, { type: "input", placeholder: "path/to/file.txt" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Upload", action: "UPLOAD", variant: "primary", icon: "upload" }, { type: "button", label: "Download", action: "DOWNLOAD", variant: "secondary", icon: "download" }, { type: "button", label: "List", action: "LIST", variant: "secondary", icon: "list" }, { type: "button", label: "Delete", action: "DELETE_FILE", variant: "danger", icon: "trash-2" }] }] })
      UPLOAD -> storageExecuting
        (render-ui main { type: "loading-state", title: "Processing...", message: "Executing storage operation..." })
        (call-service storage upload { bucket: "@entity.bucket", key: "@entity.fileKey" } { emit: { success: "ServiceDevopsToolkitStorageCompleted", failure: "ServiceDevopsToolkitStorageFailed" } })
      DOWNLOAD -> storageExecuting
        (render-ui main { type: "loading-state", title: "Processing...", message: "Executing storage operation..." })
        (call-service storage download { bucket: "@entity.bucket", key: "@entity.fileKey" } { emit: { success: "ServiceDevopsToolkitStorageCompleted", failure: "ServiceDevopsToolkitStorageFailed" } })
      LIST -> storageExecuting
        (render-ui main { type: "loading-state", title: "Processing...", message: "Executing storage operation..." })
        (call-service storage list { bucket: "@entity.bucket" } { emit: { success: "ServiceDevopsToolkitStorageCompleted", failure: "ServiceDevopsToolkitStorageFailed" } })
      DELETE_FILE -> storageExecuting
        (render-ui main { type: "loading-state", title: "Processing...", message: "Executing storage operation..." })
        (call-service storage delete { bucket: "@entity.bucket", key: "@entity.fileKey" } { emit: { success: "ServiceDevopsToolkitStorageCompleted", failure: "ServiceDevopsToolkitStorageFailed" } })
    }
    state storageExecuting {
      STORAGE_DONE -> storageComplete
        (set @entity.result @payload.data)
        (set @entity.toolStatus storage-complete)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Storage operation complete" }, { type: "typography", variant: "body", color: "muted", content: "@entity.result" }, { type: "button", label: "Back", action: "STORAGE_RESET", variant: "ghost", icon: "rotate-ccw" }] })
      STORAGE_FAILED -> storageError
        (set @entity.error @payload.error)
        (set @entity.toolStatus error)
        (render-ui main { type: "error-state", title: "Storage Error", message: "@entity.error", onRetry: "STORAGE_RETRY" })
    }
    state storageComplete {
      STORAGE_RESET -> storageIdle
        (set @entity.toolStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Storage Files", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "bucket-name" }, { type: "input", placeholder: "path/to/file.txt" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Upload", action: "UPLOAD", variant: "primary", icon: "upload" }, { type: "button", label: "Download", action: "DOWNLOAD", variant: "secondary", icon: "download" }, { type: "button", label: "List", action: "LIST", variant: "secondary", icon: "list" }, { type: "button", label: "Delete", action: "DELETE_FILE", variant: "danger", icon: "trash-2" }] }] })
    }
    state storageError {
      STORAGE_RETRY -> storageIdle
        (set @entity.toolStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Storage Files", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "bucket-name" }, { type: "input", placeholder: "path/to/file.txt" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Upload", action: "UPLOAD", variant: "primary", icon: "upload" }, { type: "button", label: "Download", action: "DOWNLOAD", variant: "secondary", icon: "download" }, { type: "button", label: "List", action: "LIST", variant: "secondary", icon: "list" }, { type: "button", label: "Delete", action: "DELETE_FILE", variant: "danger", icon: "trash-2" }] }] })
    }
    listens {
      STORAGE_DONE { data : string! }
      STORAGE_FAILED { error : string! }
          ServiceDevopsToolkitLoadFailed { message : string }
    }
    emits: [ServiceDevopsToolkitLoadFailed, ServiceDevopsToolkitLoaded, ServiceDevopsToolkitStorageCompleted, ServiceDevopsToolkitStorageFailed]
  }
  page "/servicedevopstoolkits" as ServiceDevopsToolkitPage -> ServiceDevopsToolkitGithub, ServiceDevopsToolkitRedis, ServiceDevopsToolkitStorage
}