;; app std-negotiator-game

orbital NegotiatorGameOrbital {
  entity NegotiatorGame [runtime] {
    id : string
    name : string
    description : string
    status : string
    createdAt : string
    score : number
    level : number
  }
  trait NegotiatorGameNegotiatorGame -> NegotiatorGame [interaction] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch NegotiatorGame)
        (render-ui main { type: "game-menu", title: "Negotiator", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "negotiator-board", entity: "NegotiatorGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Negotiator", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
  }
  page "/negotiatorgames" -> NegotiatorGameNegotiatorGame
}