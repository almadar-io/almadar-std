app std-simulator-game "1.0.0"
"std-simulator-game as a Function"

orbital SimulatorGameOrbital {
  entity SimulatorGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number = 0
    level : number = 1
  }

  type SimulatorGameLoaded     = Event SimulatorGame                  "Fired when SimulatorGame finishes loading"
  type SimulatorGameLoadFailed = Event { message : string } "Fired when SimulatorGame fails to load"
  trait SimulatorGameSimulatorGame -> SimulatorGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch SimulatorGame { emit: { success: "SimulatorGameLoaded", failure: "SimulatorGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Simulator", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "simulator-board", entity: "SimulatorGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Simulator", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits: [SimulatorGameLoaded, SimulatorGameLoadFailed]
    listens {
      SimulatorGameLoadFailed { message : string }
    }
  }
  page "/simulatorgames" as SimulatorGamePage -> SimulatorGameSimulatorGame
}