app std-service-payment-flow "1.0.0"
"std-service-payment-flow as a Function"

orbital ServicePaymentFlowOrbital {
  entity ServicePaymentFlow [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    amount : number
    currency : string = "usd"
    paymentIntentId : string
    clientSecret : string
    paymentStatus : string = "idle"
    to : string
    subject : string = "Payment Receipt"
    body : string
    sendStatus : string = "idle"
    error : string
  }

  type ServicePaymentFlowLoaded     = Event ServicePaymentFlow                  "Fired when ServicePaymentFlow finishes loading"
  type ServicePaymentFlowLoadFailed = Event { message : string } "Fired when ServicePaymentFlow fails to load"
  trait ServicePaymentFlowPayment -> ServicePaymentFlow [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServicePaymentFlow { emit: { success: "ServicePaymentFlowLoaded", failure: "ServicePaymentFlowLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Payment", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", inputType: "number", placeholder: "0.00" }, { type: "select", label: "Currency", options: [{ label: "USD", value: "usd" }, { label: "EUR", value: "eur" }, { label: "GBP", value: "gbp" }] }] }, { type: "button", label: "Pay", action: "CREATE_PAYMENT", variant: "primary", icon: "credit-card" }] })
      CREATE_PAYMENT -> creating
        (render-ui main { type: "loading-state", title: "Creating payment...", message: "Setting up your payment intent." })
        (call-service stripe "createPaymentIntent" { amount: "@entity.amount", currency: "@entity.currency" })
    }
    state creating {
      PAYMENT_CREATED -> confirming
        (set @entity.paymentIntentId @payload.id)
        (set @entity.clientSecret @payload.clientSecret)
        (render-ui main { type: "loading-state", title: "Confirming payment...", message: "Processing your payment." })
        (call-service stripe "confirmPayment" { paymentIntentId: "@entity.paymentIntentId" })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "error-state", title: "Payment Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state confirming {
      PAYMENT_CONFIRMED -> succeeded
        (set @entity.paymentStatus succeeded)
        (emit SEND_RECEIPT)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Payment successful! Sending receipt..." }, { type: "typography", variant: "body", color: "muted", content: "@entity.paymentIntentId" }, { type: "button", label: "New Payment", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "error-state", title: "Payment Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state succeeded {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Payment", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", inputType: "number", placeholder: "0.00" }, { type: "select", label: "Currency", options: [{ label: "USD", value: "usd" }, { label: "EUR", value: "eur" }, { label: "GBP", value: "gbp" }] }] }, { type: "button", label: "Pay", action: "CREATE_PAYMENT", variant: "primary", icon: "credit-card" }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Payment", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", inputType: "number", placeholder: "0.00" }, { type: "select", label: "Currency", options: [{ label: "USD", value: "usd" }, { label: "EUR", value: "eur" }, { label: "GBP", value: "gbp" }] }] }, { type: "button", label: "Pay", action: "CREATE_PAYMENT", variant: "primary", icon: "credit-card" }] })
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Payment", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", inputType: "number", placeholder: "0.00" }, { type: "select", label: "Currency", options: [{ label: "USD", value: "usd" }, { label: "EUR", value: "eur" }, { label: "GBP", value: "gbp" }] }] }, { type: "button", label: "Pay", action: "CREATE_PAYMENT", variant: "primary", icon: "credit-card" }] })
    }
    emits {
      SEND_RECEIPT
    }
    listens {
      PAYMENT_CREATED { id : string!, clientSecret : string! }
      FAILED { error : string! }
          ServicePaymentFlowLoadFailed { message : string }
    }
    emits: [ServicePaymentFlowLoaded, ServicePaymentFlowLoadFailed]
  }
  trait ServicePaymentFlowReceipt -> ServicePaymentFlow [interaction, instance] {
    initial: waiting
    state waiting {
      INIT -> waiting
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "mail" }, { type: "typography", content: "Receipt will be sent after payment.", variant: "body", color: "muted" }] })
      SEND_RECEIPT -> sending
        (render-ui main { type: "loading-state", title: "Sending receipt...", message: "Delivering your payment receipt." })
        (call-service email send { to: "@entity.to", subject: "@entity.subject", body: "@entity.body" })
    }
    state sending {
      SENT -> sent
        (set @entity.sendStatus sent)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Receipt sent successfully" }] })
      FAILED -> receiptError
        (set @entity.sendStatus error)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "error-state", title: "Receipt Failed", message: "Could not send receipt email.", onRetry: "RETRY_RECEIPT" }, { type: "button", label: "Retry", action: "RETRY_RECEIPT", variant: "primary", icon: "refresh-cw" }] })
    }
    state sent {
      SEND_RECEIPT -> sending
        (render-ui main { type: "loading-state", title: "Resending receipt..." })
        (call-service email send { to: "@entity.to", subject: "@entity.subject", body: "@entity.body" })
    }
    state receiptError {
      RETRY_RECEIPT -> sending
        (render-ui main { type: "loading-state", title: "Sending receipt...", message: "Delivering your payment receipt." })
        (call-service email send { to: "@entity.to", subject: "@entity.subject", body: "@entity.body" })
    }
    listens {
      ServicePaymentFlowPayment SEND_RECEIPT -> SEND_RECEIPT
      FAILED { error : string! }
    }
  }
  page "/servicepaymentflows" as ServicePaymentFlowPage -> ServicePaymentFlowPayment, ServicePaymentFlowReceipt
}