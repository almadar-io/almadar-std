app std-agent-planner "1.0.0"
"std-agent-planner as a Function"

orbital AgentPlannerOrbital {
  uses AgentClassifier from "std/behaviors/std-agent-classifier"
  uses AgentCompletion from "std/behaviors/std-agent-completion"
  uses AgentMemory from "std/behaviors/std-agent-memory"
  uses Modal from "std/behaviors/std-modal"

  entity AgentPlanner [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    task : string = ""
    category : string = ""
    steps : string = ""
    confidence : number = 0
    relevantMemories : string = ""
    memoryCount : number = 0
    error : string = ""
    input : string = ""
    prompt : string = ""
    response : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
    content : string = ""
    scope : string = ""
    strength : number = 1
    pinned : boolean = false
    action : string = ""
    detail : string = ""
    timestamp : string = ""
    duration : number = 0
    icon : string = "circle"
  }

  type AgentPlannerLoaded     = Event AgentPlanner                  "Fired when AgentPlanner finishes loading"
  type AgentPlannerLoadFailed = Event { message : string } "Fired when AgentPlanner fails to load"
  trait AgentPlannerPlanner -> AgentPlanner [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map"}, { type: "typography", content: "Task Planner", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to plan", variant: "body" }, { type: "form-section", entity: "AgentPlanner", mode: "edit", submitEvent: "PLAN", fields: ["task"] }] }] }] })
      PLAN -> classifying
        (set @entity.status classifying)
        (agent/generate (str/concat "Classify this task into exactly one category.\n" "Categories: " "code, schema, design, debug, deploy" "\n" "Task: " @entity.task "\n" "Return only the category name."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Classifying task...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "@entity.task", variant: "caption" }] })
    }
    state classifying {
      CLASSIFIED -> recalling
        (set @entity.category @payload.category)
        (set @entity.status recalling)
        (agent/recall (str/concat @entity.category " " @entity.task) 5)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "Recalling relevant experience...", variant: "h3" }, { type: "spinner"}, { type: "badge", label: ["str/concat", "Category: ", "@entity.category"] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state recalling {
      MEMORIES_LOADED -> planning
        (set @entity.relevantMemories @payload.memories)
        (set @entity.memoryCount @payload.count)
        (set @entity.status planning)
        (agent/generate (str/concat "Task: " @entity.task "\n" "Category: " @entity.category "\n" "Relevant experience:\n" @entity.relevantMemories "\n\n" "Generate a numbered step-by-step execution plan. " "Include a confidence score (0-100) for how likely this plan will succeed."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating plan...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: ["str/concat", "Category: ", "@entity.category"] }, { type: "badge", label: ["str/concat", ["str/concat", "@entity.memoryCount"], " memories loaded"] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state planning {
      PLAN_GENERATED -> ready
        (set @entity.steps @payload.steps)
        (set @entity.confidence @payload.confidence)
        (set @entity.status ready)
        (agent/memorize (str/concat "Plan for " @entity.category " task: " @entity.task) pattern-affinity)
        (emit PLAN_READY)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Plan Ready", variant: "h2" }] }, { type: "button", label: "New Plan", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Category", value: "@entity.category", icon: "tag" }, { type: "stat-display", label: "Confidence", value: ["str/concat", ["str/concat", "@entity.confidence"], "%"], icon: "target" }, { type: "stat-display", label: "Memories Used", value: "@entity.memoryCount", icon: "brain" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Task", variant: "caption" }, { type: "typography", content: "@entity.task", variant: "body" }, { type: "divider" }, { type: "typography", content: "Execution Plan", variant: "caption" }, { type: "typography", content: "@entity.steps", variant: "body" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Relevant Memories", variant: "caption" }, { type: "typography", content: "@entity.relevantMemories", variant: "body" }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state ready {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.category "")
        (set @entity.steps "")
        (set @entity.confidence 0)
        (set @entity.relevantMemories "")
        (set @entity.memoryCount 0)
        (set @entity.error "")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map"}, { type: "typography", content: "Task Planner", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to plan", variant: "body" }, { type: "form-section", entity: "AgentPlanner", mode: "edit", submitEvent: "PLAN", fields: ["task"] }] }] }] })
    }
    emits {
      PLAN_READY external { plan: string, category: string }
    }
    listens {
      AgentPlannerPlanner PLAN_READY -> INIT
      PlannerTaskInput PLAN -> PLAN
      CLASSIFIED { category : string! }
      MEMORIES_LOADED { memories : string!, count : number! }
      PLAN_GENERATED { steps : string!, confidence : number! }
      FAILED { error : string! }
    }
  }
  trait PlannerTaskInput = Modal.traits.ModalRecordModal -> AgentPlanner {
    events {
      OPEN: NEW_TASK
      SAVE: PLAN
    }
  }
  trait PlannerClassifierFlow = AgentClassifier.traits.AgentClassifierModal -> AgentPlanner {
    emitsScope internal
  }
  trait PlannerCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentPlanner {
    emitsScope internal
  }
  trait PlannerMemoryLifecycle = AgentMemory.traits.AgentMemoryBrowse -> AgentPlanner {
    emitsScope internal
  }
  page "/agentplanners" as AgentPlannerPage -> AgentPlannerPlanner, PlannerTaskInput, PlannerClassifierFlow, PlannerCompletionFlow, PlannerMemoryLifecycle
}