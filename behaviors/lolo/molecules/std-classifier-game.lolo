app std-classifier-game "1.0.0"
"std-classifier-game as a Function"

orbital ClassifierGameOrbital {
  entity ClassifierGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number = 0
    level : number = 1
  }

  type ClassifierGameLoaded     = Event ClassifierGame                  "Fired when ClassifierGame finishes loading"
  type ClassifierGameLoadFailed = Event { message : string } "Fired when ClassifierGame fails to load"
  trait ClassifierGameClassifierGame -> ClassifierGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch ClassifierGame { emit: { success: "ClassifierGameLoaded", failure: "ClassifierGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Sort & Classify", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "classifier-board", entity: "ClassifierGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Sort & Classify", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits: [ClassifierGameLoaded, ClassifierGameLoadFailed]
    listens {
      ClassifierGameLoadFailed { message : string }
    }
  }
  page "/classifiergames" as ClassifierGamePage -> ClassifierGameClassifierGame
}