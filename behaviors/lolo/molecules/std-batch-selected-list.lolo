;; app std-batch-selected-list
;;
;; Browse + Selection + Confirmation with a batch-action toolbar. Selection
;; fires BATCH_SELECTED when items are toggled; the layout's render-ui has
;; the toolbar inline and Browse below. Confirmation renders into its own
;; modal slot (not via @trait.X).

orbital BatchListItemOrbital {
  uses Browse       from "std/behaviors/std-browse"
  uses Selection    from "std/behaviors/std-selection"
  uses Confirmation from "std/behaviors/std-confirmation"

  entity BatchListItem [persistent: batchlistitems] {
    id : string!
    name : string
    description : string
    status : string
  }

  trait BatchItemBrowse       = Browse.traits.BrowseItemBrowse             -> BatchListItem {}
  trait BatchItemSelection    = Selection.traits.SelectableItemSelection   -> BatchListItem {}
  trait BatchItemConfirmation = Confirmation.traits.ConfirmActionConfirmation -> BatchListItem {}

  trait BatchListLayout -> BatchListItem [interaction] {
    state composing {
      INIT -> composing
        (render-ui main {
          type: "stack",
          direction: "vertical",
          gap: "md",
          children: [
            {
              type: "stack",
              direction: "horizontal",
              gap: "sm",
              justify: "end",
              children: [
                { type: "button", label: "Delete selected", event: "REQUEST", variant: "danger", icon: "trash-2" }
              ]
            },
            "@trait.BatchItemSelection",
            "@trait.BatchItemBrowse"
          ]
        })
    }
  }

  page "/batch-list" -> BatchListLayout
}
