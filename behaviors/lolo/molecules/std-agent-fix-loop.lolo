app std-agent-fix-loop "1.0.0"
"std-agent-fix-loop as a Function"

orbital AgentFixLoopOrbital {
  uses AgentCompletion from "std/behaviors/std-agent-completion"
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"
  uses AgentToolCall from "std/behaviors/std-agent-tool-call"
  uses Browse from "std/behaviors/std-browse"

  entity AgentFixLoop [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    target : string = ""
    validationErrors : string = ""
    fixAttempts : number = 0
    maxAttempts : number = 5
    currentFix : string = ""
    errorCount : number = 0
    error : string = ""
    currentStep : number = 0
    totalSteps : number = 4
    steps : string = "Validate,Analyze,Fix,Re-validate"
    toolName : string = ""
    args : string = ""
    result : string = ""
    prompt : string = ""
    response : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
  }

  type AgentFixLoopLoaded     = Event AgentFixLoop                  "Fired when AgentFixLoop finishes loading"
  type AgentFixLoopLoadFailed = Event { message : string } "Fired when AgentFixLoop fails to load"
  trait AgentFixLoopCycle -> AgentFixLoop [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wrench"}, { type: "typography", content: "Validation-Fix Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter the target to validate and auto-fix", variant: "body" }, { type: "form-section", entity: "AgentFixLoop", mode: "edit", submitEvent: "FIX", fields: ["target"] }] }] }] })
      FIX -> validating
        (set @entity.status validating)
        (set @entity.fixAttempts 0)
        (set @entity.validationErrors "")
        (set @entity.errorCount 0)
        (agent/invoke validate-schema { target: "@entity.target" })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield-check"}, { type: "typography", content: "Validating...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.target" }, { type: "badge", label: "@entity.maxAttempts" }] }] })
    }
    state validating {
      VALIDATION_PASSED -> succeeded
        (set @entity.status succeeded)
        (emit FIX_SUCCEEDED)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Validation Passed", variant: "h2" }] }, { type: "button", label: "New Target", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Fix Attempts", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Status", value: "Passed", icon: "check" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Target", variant: "caption" }, { type: "typography", content: "@entity.target", variant: "body" }] }] }] })
      VALIDATION_ERRORS -> fixing
        (set @entity.validationErrors @payload.errors)
        (set @entity.errorCount @payload.count)
        (set @entity.fixAttempts (+ @entity.fixAttempts 1))
        (set @entity.status fixing)
        (agent/generate (str/concat "Target: " @entity.target "\n\nValidation errors:\n" @payload.errors "\n\nGenerate a fix that resolves these errors. Return only the fix content."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating fix...", variant: "h2" }] }, { type: "badge", label: "@entity.fixAttempts" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Validation Errors", variant: "caption" }, { type: "alert", variant: "error", message: "@entity.validationErrors" }] }] }, { type: "spinner"}] })
      EXCEEDED_ATTEMPTS -> failed
        (set @entity.status failed)
        (set @entity.error @payload.error)
        (emit FIX_FAILED)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Fix Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Attempts Used", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Remaining Errors", value: "@entity.errorCount", icon: "alert-triangle" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Validation Errors", variant: "caption" }, { type: "typography", content: "@entity.validationErrors", variant: "body" }] }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state fixing {
      FIX_GENERATED -> applying
        (set @entity.currentFix @payload.fix)
        (set @entity.status applying)
        (agent/invoke apply-fix { target: "@entity.target", fix: "@payload.fix" })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "tool"}, { type: "typography", content: "Applying fix...", variant: "h3" }, { type: "spinner"}, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Proposed Fix", variant: "caption" }, { type: "typography", content: "@entity.currentFix", variant: "body" }] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (emit FIX_FAILED)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Fix Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Attempts Used", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Remaining Errors", value: "@entity.errorCount", icon: "alert-triangle" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Validation Errors", variant: "caption" }, { type: "typography", content: "@entity.validationErrors", variant: "body" }] }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state applying {
      FIX_APPLIED -> validating
        (set @entity.status validating)
        (agent/invoke validate-schema { target: "@entity.target" })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield-check"}, { type: "typography", content: "Validating...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.target" }, { type: "badge", label: "@entity.maxAttempts" }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (emit FIX_FAILED)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Fix Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Attempts Used", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Remaining Errors", value: "@entity.errorCount", icon: "alert-triangle" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Validation Errors", variant: "caption" }, { type: "typography", content: "@entity.validationErrors", variant: "body" }] }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state succeeded {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.target "")
        (set @entity.validationErrors "")
        (set @entity.currentFix "")
        (set @entity.fixAttempts 0)
        (set @entity.errorCount 0)
        (set @entity.error "")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wrench"}, { type: "typography", content: "Validation-Fix Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter the target to validate and auto-fix", variant: "body" }, { type: "form-section", entity: "AgentFixLoop", mode: "edit", submitEvent: "FIX", fields: ["target"] }] }] }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.target "")
        (set @entity.validationErrors "")
        (set @entity.currentFix "")
        (set @entity.fixAttempts 0)
        (set @entity.errorCount 0)
        (set @entity.error "")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wrench"}, { type: "typography", content: "Validation-Fix Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter the target to validate and auto-fix", variant: "body" }, { type: "form-section", entity: "AgentFixLoop", mode: "edit", submitEvent: "FIX", fields: ["target"] }] }] }] })
    }
    emits {
      FIX_SUCCEEDED external { target: string }
      FIX_FAILED external { target: string, error: string }
    }
    listens {
      AgentFixLoopCycle FIX_SUCCEEDED -> INIT
      AgentFixLoopCycle FIX_FAILED -> INIT
      VALIDATION_ERRORS { errors : string!, count : number! }
      FIX_GENERATED { fix : string! }
      EXCEEDED_ATTEMPTS { error : string! }
      FAILED { error : string! }
    }
  }
  trait FixLoopStepProgress = AgentStepProgress.traits.AgentStepProgressProgress -> AgentFixLoop {
    emitsScope internal
  }
  trait FixLoopErrorsBrowse = Browse.traits.BrowseItemBrowse -> AgentFixLoop {
  }
  trait FixLoopValidateCall = AgentToolCall.traits.AgentToolCallModal -> AgentFixLoop {
    emitsScope internal
  }
  trait FixLoopFixCall = AgentToolCall.traits.AgentToolCallModal -> AgentFixLoop {
    emitsScope internal
  }
  trait FixLoopCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentFixLoop {
    emitsScope internal
  }
  page "/agentfixloops" as AgentFixLoopPage -> AgentFixLoopCycle, FixLoopStepProgress, FixLoopErrorsBrowse, FixLoopValidateCall, FixLoopFixCall, FixLoopCompletionFlow
}