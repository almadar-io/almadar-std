;; app std-debugger-game

orbital DebuggerGameOrbital {
  entity DebuggerGame [runtime] {
    id : string
    name : string
    description : string
    status : string
    createdAt : string
    score : number
    level : number
  }
  trait DebuggerGameDebuggerGame -> DebuggerGame [interaction] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch DebuggerGame)
        (render-ui main { type: "game-menu", title: "Bug Hunter", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "debugger-board", entity: "DebuggerGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Bug Hunter", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
  }
  page "/debuggergames" -> DebuggerGameDebuggerGame
}