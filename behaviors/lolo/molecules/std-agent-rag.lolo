app std-agent-rag "1.0.0"
"std-agent-rag as a Function"

orbital AgentRagOrbital {
  uses AgentCompletion from "std/behaviors/std-agent-completion"
  uses AgentMemory from "std/behaviors/std-agent-memory"
  uses AgentSearch from "std/behaviors/std-agent-search"
  uses Tabs from "std/behaviors/std-tabs"

  entity AgentRag [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    query : string = ""
    context : string = ""
    response : string = ""
    memoryHits : number = 0
    searchHits : number = 0
    error : string = ""
    content : string = ""
    category : string = ""
    scope : string = ""
    strength : number = 1
    pinned : boolean = false
    language : string = ""
    resultCount : number = 0
    results : string = "[]"
    prompt : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
  }

  type AgentRagLoaded     = Event AgentRag                  "Fired when AgentRag finishes loading"
  type AgentRagLoadFailed = Event { message : string } "Fired when AgentRag fails to load"
  trait AgentRagRag -> AgentRag [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "RAG Pipeline", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter a query to retrieve context and generate a response", variant: "body" }, { type: "form-section", entity: "AgentRag", mode: "edit", submitEvent: "GENERATE", fields: ["query"] }] }] }] })
      GENERATE -> retrieving
        (set @entity.status retrieving)
        (agent/recall @entity.query 5)
        (agent/search-code @entity.query)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search"}, { type: "typography", content: "Retrieving context...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "Recalling memories" }, { type: "badge", label: "Searching code" }] }] })
    }
    state retrieving {
      RETRIEVAL_DONE -> generating
        (set @entity.context @payload.context)
        (set @entity.memoryHits @payload.memoryHits)
        (set @entity.searchHits @payload.searchHits)
        (set @entity.status generating)
        (agent/generate (str/concat "Context:\n" @entity.context "\n\nQuery: " @entity.query "\n\nProvide a comprehensive answer based on the retrieved context."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating response...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: ["str/concat", ["str/concat", "@entity.memoryHits"], " memories"] }, { type: "badge", label: ["str/concat", ["str/concat", "@entity.searchHits"], " code hits"] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "RAG Pipeline Error", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state generating {
      GENERATION_DONE -> completed
        (set @entity.response @payload.response)
        (set @entity.status completed)
        (agent/memorize (str/concat "RAG query: " @entity.query) pattern-affinity)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "RAG Complete", variant: "h2" }] }, { type: "button", label: "New Query", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Memory Hits", value: "@entity.memoryHits", icon: "brain" }, { type: "stat-display", label: "Code Hits", value: "@entity.searchHits", icon: "code" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Query", variant: "caption" }, { type: "typography", content: "@entity.query", variant: "body" }, { type: "divider" }, { type: "typography", content: "Response", variant: "caption" }, { type: "typography", content: "@entity.response", variant: "body" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Retrieved Context", variant: "caption" }, { type: "typography", content: "@entity.context", variant: "body" }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "RAG Pipeline Error", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.context "")
        (set @entity.memoryHits 0)
        (set @entity.searchHits 0)
        (set @entity.error "")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "RAG Pipeline", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter a query to retrieve context and generate a response", variant: "body" }, { type: "form-section", entity: "AgentRag", mode: "edit", submitEvent: "GENERATE", fields: ["query"] }] }] }] })
    }
    listens {
      RETRIEVAL_DONE { context : string!, memoryHits : number!, searchHits : number! }
      GENERATION_DONE { response : string! }
      FAILED { error : string! }
    }
  }
  trait RagTabs = Tabs.traits.TabContentTabs -> AgentRag {
  }
  trait RagMemoryLifecycle = AgentMemory.traits.AgentMemoryBrowse -> AgentRag {
    emitsScope internal
  }
  trait RagSearchLifecycle = AgentSearch.traits.AgentSearchBrowse -> AgentRag {
    emitsScope internal
  }
  trait RagCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentRag {
    emitsScope internal
  }
  page "/agentrags" as AgentRagPage -> AgentRagRag, RagTabs, RagMemoryLifecycle, RagSearchLifecycle, RagCompletionFlow
}