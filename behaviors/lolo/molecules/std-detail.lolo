app std-detail "1.0.0"
"std-detail as a Function"
;;
;; Detail browse: list, create new, view one. The View trait is inlined
;; (not a ref) because std-modal's form-section can't render a read-only
;; detail view — mode "view" isn't supported. Per G6 in the gaps doc,
;; eventually std-modal could grow a view mode; until then, view flows
;; author their own read-only render-ui.

orbital DetailRecordOrbital {
  uses Modal from "std/behaviors/std-modal"

  entity DetailRecord [persistent: detailrecords] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  type DetailRecordLoaded     = Event { data : [DetailRecord] }          "Fired when the DetailRecord collection finishes loading"
  type DetailRecordLoadFailed = Event { error : string, code : string }  "Fired when the DetailRecord collection fails to load"

  trait DetailRecordBrowse -> DetailRecord [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch DetailRecord { emit: { success: "DetailRecordLoaded", failure: "DetailRecordLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading records…" }] })
      DetailRecordLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "DetailRecords", variant: "h2" }] }, { type: "button", label: "Create", action: "CREATE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "file-text" }, { name: "description", label: "Description", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }] }] })
      DetailRecordLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load records" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch DetailRecord { emit: { success: "DetailRecordLoaded", failure: "DetailRecordLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch DetailRecord { emit: { success: "DetailRecordLoaded", failure: "DetailRecordLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits: [DetailRecordLoaded, DetailRecordLoadFailed]
    listens {
      DetailRecordLoadFailed { error : string, code : string }
      DetailRecordPersistor DETAIL_RECORD_CREATED -> INIT
    }
  }

  ;; Create: ref std-modal with create mode. Config-only, no effects.
  trait DetailRecordCreate = Modal.traits.ModalRecordModal -> DetailRecord {
    config: {
      icon:  "plus-circle",
      title: "New DetailRecord",
      fields: ["name", "description", "status"],
      mode:  "create"
    }
    events {
      OPEN: CREATE
      SAVE: DETAIL_RECORD_CREATED
    }
  }

  ;; View: own-trait since std-modal can't render a read-only detail view.
  ;; VIEW fetches target row by @payload.id, renders detail on open.
  trait DetailRecordView -> DetailRecord [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch DetailRecord { emit: { success: "DetailRecordLoaded", failure: "DetailRecordLoadFailed" } })
      VIEW -> closed
        (set @entity.id @payload.id)
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
      CLOSE -> closed
        (render-ui modal null)
    }
    listens {
      VIEW { id : string! }
    }
  }

  ;; Coordinator: persist side-effects for create.
  trait DetailRecordPersistor -> DetailRecord [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create DetailRecord @payload.data)
        (emit DETAIL_RECORD_CREATED { id: "@payload.data.id" })
    }
    emits {
      DETAIL_RECORD_CREATED external { id : string! }
    }
    listens {
      DO_CREATE { data : DetailRecord }
      DetailRecordCreate DETAIL_RECORD_CREATED -> DO_CREATE
    }
  }

  page "/detailrecords" as DetailRecordPage -> DetailRecordBrowse, DetailRecordCreate, DetailRecordView, DetailRecordPersistor
}
