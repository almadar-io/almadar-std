app std-builder-game "1.0.0"
"std-builder-game as a Function"

orbital BuilderGameOrbital {
  entity BuilderGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number = 0
    level : number = 1
  }

  type BuilderGameLoaded     = Event BuilderGame                  "Fired when BuilderGame finishes loading"
  type BuilderGameLoadFailed = Event { message : string } "Fired when BuilderGame fails to load"
  trait BuilderGameBuilderGame -> BuilderGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch BuilderGame { emit: { success: "BuilderGameLoaded", failure: "BuilderGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Builder Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "builder-board", entity: "BuilderGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Builder Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits: [BuilderGameLoaded, BuilderGameLoadFailed]
    listens {
      BuilderGameLoadFailed { message : string }
    }
  }
  page "/buildergames" as BuilderGamePage -> BuilderGameBuilderGame
}