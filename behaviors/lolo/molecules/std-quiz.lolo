app std-quiz "1.0.0"
"std-quiz as a Function"

orbital QuizItemOrbital {
  entity QuizItem [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    question : string = ""
    answer : string = ""
    optionA : string = ""
    optionB : string = ""
    optionC : string = ""
    optionD : string = ""
    difficulty : string = "medium"
    currentIndex : number = 0
    totalQuestions : number = 3
  }

  type QuizItemLoaded     = Event QuizItem                  "Fired when QuizItem finishes loading"
  type QuizItemLoadFailed = Event { message : string } "Fired when QuizItem fails to load"
  trait QuizItemQuiz -> QuizItem [interaction, collection] {
    initial: question
    state question {
      INIT -> question
        (fetch QuizItem { emit: { success: "QuizItemLoaded", failure: "QuizItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", content: "Quiz", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: ["object/get", ["array/first", "@entity"], "name"] }] }] }, { type: "simple-grid", cols: 2, children: [{ type: "button", label: ["object/get", ["array/first", "@entity"], "optionA"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "A" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionB"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "B" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionC"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "C" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionD"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "D" } }] }, { type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "signal" }, { type: "typography", variant: "caption", color: "muted", content: "Difficulty:" }, { type: "badge", label: ["object/get", ["array/first", "@entity"], "difficulty"] }] }, { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [{ type: "typography", variant: "caption", color: "muted", content: "Question" }, { type: "typography", variant: "caption", content: ["+", ["or", ["object/get", ["array/first", "@entity"], "currentIndex"], 0], 1] }, { type: "typography", variant: "caption", color: "muted", content: "of" }, { type: "typography", variant: "caption", content: ["or", ["object/get", ["array/first", "@entity"], "totalQuestions"], 0] }] }] }] })
      ANSWER -> answer-revealed
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", content: "Answer Revealed", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Question" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "name"] }, { type: "divider" }, { type: "typography", variant: "caption", color: "muted", content: "Answer" }, { type: "typography", variant: "h3", content: ["object/get", ["array/first", "@entity"], "description"] }] }] }, { type: "alert", variant: "info", message: "Review the answer above." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Next Question", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] })
    }
    state answer-revealed {
      NEXT -> question
        (set @entity.currentIndex (+ @entity.currentIndex 1))
        (fetch QuizItem { emit: { success: "QuizItemLoaded", failure: "QuizItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", content: "Quiz", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: ["object/get", ["array/first", "@entity"], "name"] }] }] }, { type: "simple-grid", cols: 2, children: [{ type: "button", label: ["object/get", ["array/first", "@entity"], "optionA"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "A" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionB"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "B" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionC"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "C" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionD"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "D" } }] }, { type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "signal" }, { type: "typography", variant: "caption", color: "muted", content: "Difficulty:" }, { type: "badge", label: ["object/get", ["array/first", "@entity"], "difficulty"] }] }, { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [{ type: "typography", variant: "caption", color: "muted", content: "Question" }, { type: "typography", variant: "caption", content: ["+", ["or", ["object/get", ["array/first", "@entity"], "currentIndex"], 0], 1] }, { type: "typography", variant: "caption", color: "muted", content: "of" }, { type: "typography", variant: "caption", content: ["or", ["object/get", ["array/first", "@entity"], "totalQuestions"], 0] }] }] }] })
      RESTART -> complete
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Quiz Complete!", variant: "h2" }, { type: "alert", variant: "success", message: "You have completed all questions." }, { type: "button", label: "Restart", action: "RESTART", variant: "primary", icon: "rotate-ccw" }] })
    }
    state complete {
      RESTART -> question
        (fetch QuizItem { emit: { success: "QuizItemLoaded", failure: "QuizItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", content: "Quiz", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "icon", name: "help-circle" }, { type: "typography", variant: "h3", content: ["object/get", ["array/first", "@entity"], "name"] }] }] }, { type: "simple-grid", cols: 2, children: [{ type: "button", label: ["object/get", ["array/first", "@entity"], "optionA"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "A" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionB"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "B" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionC"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "C" } }, { type: "button", label: ["object/get", ["array/first", "@entity"], "optionD"], action: "ANSWER", variant: "secondary", actionPayload: { answer: "D" } }] }, { type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "signal" }, { type: "typography", variant: "caption", color: "muted", content: "Difficulty:" }, { type: "badge", label: ["object/get", ["array/first", "@entity"], "difficulty"] }] }, { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [{ type: "typography", variant: "caption", color: "muted", content: "Question" }, { type: "typography", variant: "caption", content: ["+", ["or", ["object/get", ["array/first", "@entity"], "currentIndex"], 0], 1] }, { type: "typography", variant: "caption", color: "muted", content: "of" }, { type: "typography", variant: "caption", content: ["or", ["object/get", ["array/first", "@entity"], "totalQuestions"], 0] }] }] }] })
    }
    listens {
      ANSWER { answer : string! }
          QuizItemLoadFailed { message : string }
    }
    emits: [QuizItemLoaded, QuizItemLoadFailed]
  }
  page "/quizitems/quiz" as QuizItemQuizPage -> QuizItemQuiz
}