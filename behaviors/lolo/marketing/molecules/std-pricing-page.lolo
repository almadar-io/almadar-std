app std-pricing-page "1.0.0"
"Pricing page molecule for marketing sites. Composes hero, pricing grid, FAQ accordion, and CTA sections as a vertical stack of individual marketing patterns. Pick for SaaS pricing pages and plan comparisons."

orbital PricingPageItemOrbital {
  entity PricingPageItem [runtime] {
    id : string
  }

  type PricingAction = { label : string!, href : string! }
  type PricingPlan = { name : string!, price : string!, description : string, features : [string], action : PricingAction!, highlighted : boolean, badge : string }
  type FaqItem = { question : string!, answer : string! }
  type ActionCard = { label : string!, href : string! }
  type FooterLink = { label : string!, href : string! }
  type FooterColumn = { title : string!, items : [FooterLink] }

  trait PricingPageItemLayout -> PricingPageItem [interaction, instance] {
    config {
      heroTag : string = ""
      heroTitle : string = "Simple, transparent pricing"
      heroTitleAccent : string = ""
      heroSubtitle : string = "Start free, scale as you grow."
      heroPrimaryActionLabel : string = "Get Started"
      heroPrimaryActionHref : string = "/signup"
      heroSecondaryActionLabel : string = "Contact Sales"
      heroSecondaryActionHref : string = "/contact"
      heroBackground : string = "subtle"
      heroAlign : string = "center"
      plans : [PricingPlan] = [
        { name: "Starter", price: "$0", description: "For individuals and small projects.", features: ["1 project", "Community support", "Basic analytics"], action: { label: "Get Started", href: "#" }, highlighted: false, badge: "" },
        { name: "Pro", price: "$49", description: "For growing teams that need more power.", features: ["Unlimited projects", "Priority support", "Advanced analytics", "Custom domains"], action: { label: "Start Trial", href: "#" }, highlighted: true, badge: "Most Popular" },
        { name: "Enterprise", price: "Custom", description: "For organizations with advanced needs.", features: ["Dedicated infra", "SLA guarantee", "SSO & SAML", "Audit logs", "Custom contracts"], action: { label: "Contact Sales", href: "#" }, highlighted: false, badge: "" }
      ]
      faq : [FaqItem] = [
        { question: "Can I change plans later?", answer: "Yes, you can upgrade or downgrade at any time." },
        { question: "Is there a free trial?", answer: "Yes, every paid plan includes a 14-day free trial." },
        { question: "What payment methods do you accept?", answer: "We accept all major credit cards and wire transfers for Enterprise." }
      ]
      ctaTitle : string = "Still have questions?"
      ctaSubtitle : string = "Our team is here to help you find the right plan."
      ctaAction : ActionCard = { label: "Contact Sales", href: "/contact" }
      footerColumns : [FooterColumn] = [
        { title: "Product", items: [{ label: "Features", href: "#" }, { label: "Pricing", href: "#" }, { label: "Changelog", href: "#" }] },
        { title: "Company", items: [{ label: "About", href: "#" }, { label: "Careers", href: "#" }, { label: "Blog", href: "#" }] },
        { title: "Resources", items: [{ label: "Docs", href: "#" }, { label: "Community", href: "#" }, { label: "Support", href: "#" }] }
      ]
      footerCopyright : string = "© 2026 Almadar. All rights reserved."
    }
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "none", children: [
          { type: "hero-section", tag: "@config.heroTag", title: "@config.heroTitle", titleAccent: "@config.heroTitleAccent", subtitle: "@config.heroSubtitle", primaryAction: { label: "@config.heroPrimaryActionLabel", href: "@config.heroPrimaryActionHref" }, secondaryAction: { label: "@config.heroSecondaryActionLabel", href: "@config.heroSecondaryActionHref" }, background: "@config.heroBackground", align: "@config.heroAlign" },
          { type: "pricing-grid", plans: "@config.plans" },
          { type: "accordion", items: "@config.faq" },
          { type: "cta-banner", title: "@config.ctaTitle", subtitle: "@config.ctaSubtitle", primaryAction: "@config.ctaAction" },
          { type: "marketing-footer", columns: "@config.footerColumns", copyright: "@config.footerCopyright" }
        ]})
    }
  }
  page "/pricing" as PricingPage -> PricingPageItemLayout
}
