app std-about-page "1.0.0"
"About page molecule for marketing sites. Composes hero, articles, team grid, case studies, and CTA sections as a vertical stack of individual marketing patterns. Pick for company overviews, team showcases, and culture pages."

orbital AboutPageItemOrbital {
  entity AboutPageItem [runtime] {
    id : string
  }

  type TeamMemberCard = { id : string, name : string!, nameAr : string, role : string!, bio : string!, avatar : string }
  type CaseStudyCard = { id : string, title : string!, description : string!, category : string!, categoryColor : string, href : string!, linkLabel : string }
  type ActionCard = { label : string!, href : string! }
  type FooterLink = { label : string!, href : string! }
  type FooterColumn = { title : string!, items : [FooterLink] }

  trait AboutPageItemLayout -> AboutPageItem [interaction, instance] {
    config {
      heroTag : string = ""
      heroTitle : string = "About Almadar"
      heroTitleAccent : string = ""
      heroSubtitle : string = "We're building the future of software creation."
      heroPrimaryActionLabel : string = "Join Us"
      heroPrimaryActionHref : string = "/careers"
      heroBackground : string = "subtle"
      heroAlign : string = "center"
      article1Title : string = "Our Story"
      article1Content : string = "Almadar started with a simple belief: everyone should be able to build software."
      article2Title : string = "Our Mission"
      article2Content : string = "We exist to democratize software creation through natural language and AI."
      article3Title : string = "Our Values"
      article3Content : string = "Speed, simplicity, and developer joy guide every decision we make."
      team : [TeamMemberCard] = [
        { id: "1", name: "Jane Doe", nameAr: "", role: "CEO", bio: "Former VP Engineering at BigTech. Obsessed with developer experience.", avatar: "" },
        { id: "2", name: "John Smith", nameAr: "", role: "CTO", bio: "Built distributed systems at scale for a decade.", avatar: "" },
        { id: "3", name: "Alice Chen", nameAr: "", role: "Head of Design", bio: "Believes great design is invisible.", avatar: "" }
      ]
      caseStudies : [CaseStudyCard] = [
        { id: "1", title: "Acme Corp", description: "How Acme scaled from 1K to 1M users in 6 months.", category: "SaaS", categoryColor: "", href: "#", linkLabel: "Read story" },
        { id: "2", title: "Globex", description: "Globex reduced infrastructure costs by 70%.", category: "Fintech", categoryColor: "", href: "#", linkLabel: "Read story" }
      ]
      ctaTitle : string = "Want to work with us?"
      ctaAction : ActionCard = { label: "View Open Roles", href: "/careers" }
      footerColumns : [FooterColumn] = [
        { title: "Product", items: [{ label: "Features", href: "#" }, { label: "Pricing", href: "#" }, { label: "Changelog", href: "#" }] },
        { title: "Company", items: [{ label: "About", href: "#" }, { label: "Careers", href: "#" }, { label: "Blog", href: "#" }] },
        { title: "Resources", items: [{ label: "Docs", href: "#" }, { label: "Community", href: "#" }, { label: "Support", href: "#" }] }
      ]
      footerCopyright : string = "© 2026 Almadar. All rights reserved."
    }
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "none", children: [
          { type: "hero-section", tag: "@config.heroTag", title: "@config.heroTitle", titleAccent: "@config.heroTitleAccent", subtitle: "@config.heroSubtitle", primaryAction: { label: "@config.heroPrimaryActionLabel", href: "@config.heroPrimaryActionHref" }, background: "@config.heroBackground", align: "@config.heroAlign" },
          { type: "stack", direction: "vertical", gap: "md", className: "max-w-prose mx-auto py-12", children: [
            { type: "typography", variant: "h2", content: "@config.article1Title" },
            { type: "typography", variant: "body", content: "@config.article1Content" },
            { type: "typography", variant: "h2", content: "@config.article2Title" },
            { type: "typography", variant: "body", content: "@config.article2Content" },
            { type: "typography", variant: "h2", content: "@config.article3Title" },
            { type: "typography", variant: "body", content: "@config.article3Content" }
          ] },
          { type: "team-organism", entity: "@config.team" },
          { type: "case-study-organism", entity: "@config.caseStudies" },
          { type: "cta-banner", title: "@config.ctaTitle", primaryAction: "@config.ctaAction" },
          { type: "marketing-footer", columns: "@config.footerColumns", copyright: "@config.footerCopyright" }
        ]})
    }
  }
  page "/about" as AboutPage -> AboutPageItemLayout
}
