app std-feature-detail-page "1.0.0"
"Feature detail page molecule for marketing sites. Composes hero, alternating split sections, and CTA as a vertical stack of individual marketing patterns. Pick for product deep-dives and capability explainers."

orbital FeatureDetailPageItemOrbital {
  entity FeatureDetailPageItem [runtime] {
    id : string
  }

  type SectionCard = { title : string!, description : string!, bullets : [string], image : { src : string, alt : string }, imagePosition : string }
  type ActionCard = { label : string!, href : string! }
  type FooterLink = { label : string!, href : string! }
  type FooterColumn = { title : string!, items : [FooterLink] }

  trait FeatureDetailPageItemLayout -> FeatureDetailPageItem [interaction, instance] {
    config {
      heroTag : string = "Feature"
      heroTitle : string = "Everything you need to ship"
      heroTitleAccent : string = ""
      heroSubtitle : string = "From design to deployment, Almadar handles the entire stack."
      heroPrimaryActionLabel : string = "Get Started"
      heroPrimaryActionHref : string = "/signup"
      heroSecondaryActionLabel : string = "Watch Demo"
      heroSecondaryActionHref : string = "#"
      heroBackground : string = "gradient"
      heroAlign : string = "center"
      sections : [SectionCard] = [
        { title: "Design in Natural Language", description: "Describe what you want. Almadar translates your words into a complete application schema.", bullets: ["No-code visual editor", "AI-assisted schema generation", "Real-time preview"], image: { src: "", alt: "Design interface" }, imagePosition: "right" },
        { title: "Full-Stack Generation", description: "Get a production-ready TypeScript backend and React frontend in seconds.", bullets: ["Type-safe APIs", "Auto-generated database schema", "Instant deployments"], image: { src: "", alt: "Generated code" }, imagePosition: "left" },
        { title: "Enterprise-Grade Security", description: "Built-in auth, audit logs, and compliance from day one.", bullets: ["SOC-2 ready", "RBAC & SSO", "End-to-end encryption"], image: { src: "", alt: "Security dashboard" }, imagePosition: "right" }
      ]
      ctaTitle : string = "Ready to experience the future?"
      ctaAction : ActionCard = { label: "Get Started", href: "/signup" }
      footerColumns : [FooterColumn] = [
        { title: "Product", items: [{ label: "Features", href: "#" }, { label: "Pricing", href: "#" }, { label: "Changelog", href: "#" }] },
        { title: "Company", items: [{ label: "About", href: "#" }, { label: "Careers", href: "#" }, { label: "Blog", href: "#" }] },
        { title: "Resources", items: [{ label: "Docs", href: "#" }, { label: "Community", href: "#" }, { label: "Support", href: "#" }] }
      ]
      footerCopyright : string = "© 2026 Almadar. All rights reserved."
    }
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "none", children: [
          { type: "hero-section", tag: "@config.heroTag", title: "@config.heroTitle", titleAccent: "@config.heroTitleAccent", subtitle: "@config.heroSubtitle", primaryAction: { label: "@config.heroPrimaryActionLabel", href: "@config.heroPrimaryActionHref" }, secondaryAction: { label: "@config.heroSecondaryActionLabel", href: "@config.heroSecondaryActionHref" }, background: "@config.heroBackground", align: "@config.heroAlign" },
          { type: "split-section", title: "@config.sections[0].title", description: "@config.sections[0].description", bullets: "@config.sections[0].bullets", image: "@config.sections[0].image", imagePosition: "@config.sections[0].imagePosition" },
          { type: "split-section", title: "@config.sections[1].title", description: "@config.sections[1].description", bullets: "@config.sections[1].bullets", image: "@config.sections[1].image", imagePosition: "@config.sections[1].imagePosition" },
          { type: "split-section", title: "@config.sections[2].title", description: "@config.sections[2].description", bullets: "@config.sections[2].bullets", image: "@config.sections[2].image", imagePosition: "@config.sections[2].imagePosition" },
          { type: "cta-banner", title: "@config.ctaTitle", primaryAction: "@config.ctaAction" },
          { type: "marketing-footer", columns: "@config.footerColumns", copyright: "@config.footerCopyright" }
        ]})
    }
  }
  page "/features" as FeatureDetailPage -> FeatureDetailPageItemLayout
}
