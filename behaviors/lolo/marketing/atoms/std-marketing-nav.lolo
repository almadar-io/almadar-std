app std-marketing-nav "1.0.0"
"Marketing navigation atom for marketing pages. Renders a sticky header with brand logo and nav links. Pick for site-wide navigation on static pages."
;; Config-driven navigation using the `header` marketing pattern.
;; Items are declared as an array of { label, href } objects.
;; The atom emits NAV_CLICK when a link is clicked.

orbital NavItemOrbital {
  type NavLink = { label : string!, href : string! }

  entity NavItem [runtime] {
    id : string!
  }

  trait NavItemNav -> NavItem [interaction, instance] {
    config {
      brandName : string = "Almadar"
        @label "Brand Name"
        @tier "essential"
      logoSrc : string = ""
        @label "Logo Source"
        @tier "customization"
      items : [NavLink] = [
        { label: "Product", href: "#product" },
        { label: "Pricing", href: "#pricing" },
        { label: "About", href: "#about" },
        { label: "Docs", href: "#docs" }
      ]
        @label "Navigation Items"
        @description "Array of nav links"
        @tier "essential"
      primaryActionLabel : string = "Get Started"
        @label "Primary Action Label"
        @tier "customization"
      primaryActionHref : string = "#"
        @label "Primary Action Link"
        @tier "customization"
    }
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "header", brandName: "@config.brandName", logoSrc: "@config.logoSrc", navigationItems: "@config.items", actions: [{ label: "@config.primaryActionLabel", href: "@config.primaryActionHref", variant: "primary" }] })
      NAV_CLICK -> idle
        (emit NAV_CLICK { href: "@payload.href", label: "@payload.label" })
    }
    emits {
      NAV_CLICK -> external { href : string, label : string }
    }
    listens {
      NAV_CLICK { href : string, label : string }
    }
  }
  page "/nav" as NavItemNavPage -> NavItemNav
}
