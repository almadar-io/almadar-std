app std-marketing-community "1.0.0"
"Community links atom for marketing pages. Renders GitHub, Discord, and Twitter links with follower counts. Pick for open-source projects and community-driven products."
;; Config-driven community section using the `community-links` marketing pattern.
;; The atom renders immediately on INIT with no fetch required.

orbital CommunityItemOrbital {
  entity CommunityItem [runtime] {
    id : string!
  }

  trait CommunityItemCommunity -> CommunityItem [interaction, instance] {
    config {
      heading : string = "Join the community"
        @label "Heading"
        @tier "presentation"
      subtitle : string = "Connect with thousands of builders."
        @label "Subtitle"
        @tier "presentation"
      githubUrl : string = ""
        @label "GitHub URL"
        @tier "presentation"
      githubStars : string = ""
        @label "GitHub Stars"
        @tier "presentation"
      discordUrl : string = ""
        @label "Discord URL"
        @tier "presentation"
      discordMembers : string = ""
        @label "Discord Members"
        @tier "presentation"
      twitterUrl : string = ""
        @label "Twitter URL"
        @tier "presentation"
      twitterFollowers : string = ""
        @label "Twitter Followers"
        @tier "presentation"
    }
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "community-links", heading: "@config.heading", subtitle: "@config.subtitle", github: { url: "@config.githubUrl", stars: "@config.githubStars" }, discord: { url: "@config.discordUrl", members: "@config.discordMembers" }, twitter: { url: "@config.twitterUrl", followers: "@config.twitterFollowers" } })
    }
  }
  page "/community" as CommunityItemCommunityPage -> CommunityItemCommunity
}
