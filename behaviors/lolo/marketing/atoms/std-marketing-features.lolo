app std-marketing-features "1.0.0"
"Feature grid atom for marketing pages. Renders a responsive grid of feature cards with icons, titles, descriptions, and optional links. Pick for product capability showcases and benefit sections."
;; Config-driven feature grid using the `feature-grid` marketing pattern.
;; Items are declared as an array of { icon, title, description, href, linkLabel } objects.
;; The atom emits FEATURE_CLICK when a card with an href is clicked.

orbital FeatureItemOrbital {
  type FeatureCard = { icon : string, title : string!, description : string!, href : string, linkLabel : string }

  entity FeatureItem [runtime] {
    id : string!
  }

  trait FeatureItemFeatures -> FeatureItem [interaction, instance] {
    config {
      items : [FeatureCard] = [
        { icon: "zap", title: "Lightning Fast", description: "Build and deploy in minutes, not months.", href: "", linkLabel: "Learn more" },
        { icon: "shield", title: "Enterprise Secure", description: "SOC-2 compliant with end-to-end encryption.", href: "", linkLabel: "Learn more" },
        { icon: "puzzle", title: "Infinitely Extensible", description: "Plug in any service, any data source, any UI pattern.", href: "", linkLabel: "Learn more" }
      ]
        @label "Feature Items"
        @description "Array of feature cards"
        @tier "presentation"
      columns : number = 3
        @label "Columns"
        @description "Number of grid columns"
        @tier "presentation"
      gap : string = "lg"
        @label "Gap"
        @description "Spacing between cards"
        @tier "presentation"
    }
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "feature-grid", items: "@config.items", columns: "@config.columns", gap: "@config.gap" })
      FEATURE_CLICK -> idle
        (emit FEATURE_CLICK { id: "@payload.id", title: "@payload.title" })
    }
    emits {
      FEATURE_CLICK -> external { id : string, title : string }
    }
    listens {
      FEATURE_CLICK { id : string, title : string }
    }
  }
  page "/features" as FeatureItemFeaturesPage -> FeatureItemFeatures
}
