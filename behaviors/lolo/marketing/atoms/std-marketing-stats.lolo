app std-marketing-stats "1.0.0"
"Stats grid atom for marketing pages. Renders a responsive grid of key metrics with values and labels. Pick for social proof, traction, and credibility sections."
;; Config-driven stats grid using the `stats-grid` marketing pattern.
;; Stats are declared as an array of { value, label } objects.
;; The atom renders immediately on INIT with no fetch required.

orbital StatItemOrbital {
  type StatCard = { value : string!, label : string! }

  entity StatItem [runtime] {
    id : string!
  }

  trait StatItemStats -> StatItem [interaction, instance] {
    config {
      stats : [StatCard] = [
        { value: "10K+", label: "Developers" },
        { value: "99.9%", label: "Uptime" },
        { value: "50M+", label: "Requests served" },
        { value: "4.9", label: "Average rating" }
      ]
        @label "Stats"
        @description "Array of stat value/label pairs"
        @tier "presentation"
      columns : number = 4
        @label "Columns"
        @description "Number of grid columns"
        @tier "presentation"
    }
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stats-grid", stats: "@config.stats", columns: "@config.columns" })
    }
  }
  page "/stats" as StatItemStatsPage -> StatItemStats
}
