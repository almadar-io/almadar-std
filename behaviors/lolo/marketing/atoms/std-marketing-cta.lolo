app std-marketing-cta "1.0.0"
"Call-to-action banner atom for marketing pages. Renders a high-conversion CTA section with title, subtitle, and action buttons. Pick for conversion points at the end of pages or between sections."
;; Config-driven CTA banner using the `cta-banner` marketing pattern.
;; The atom emits CTA_PRIMARY and CTA_SECONDARY when buttons are clicked.

orbital CTAItemOrbital {
  entity CTAItem [runtime] {
    id : string!
  }

  trait CTAItemCTA -> CTAItem [interaction, instance] {
    config {
      title : string = "Ready to get started?"
        @label "Title"
        @description "Banner headline"
        @tier "essential"
      subtitle : string = "Join thousands of teams shipping faster."
        @label "Subtitle"
        @description "Supporting text below the title"
        @tier "essential"
      primaryActionLabel : string = "Get Started"
        @label "Primary Action Label"
        @tier "essential"
      primaryActionHref : string = "#"
        @label "Primary Action Link"
        @tier "essential"
      secondaryActionLabel : string = "Learn More"
        @label "Secondary Action Label"
        @tier "customization"
      secondaryActionHref : string = ""
        @label "Secondary Action Link"
        @tier "customization"
      background : string = "primary"
        @label "Background"
        @description "default, alt, dark, gradient, or primary"
        @tier "customization"
      align : string = "center"
        @label "Alignment"
        @description "center or left"
        @tier "customization"
    }
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "cta-banner", title: "@config.title", subtitle: "@config.subtitle", primaryAction: { label: "@config.primaryActionLabel", href: "@config.primaryActionHref" }, secondaryAction: { label: "@config.secondaryActionLabel", href: "@config.secondaryActionHref" }, background: "@config.background", align: "@config.align" })
      CTA_PRIMARY -> idle
        (emit CTA_PRIMARY { href: "@config.primaryActionHref" })
      CTA_SECONDARY -> idle
        (emit CTA_SECONDARY { href: "@config.secondaryActionHref" })
    }
    emits {
      CTA_PRIMARY -> external { href : string }
      CTA_SECONDARY -> external { href : string }
    }
    listens {
      CTA_PRIMARY { href : string }
      CTA_SECONDARY { href : string }
    }
  }
  page "/cta" as CTAItemCTAPage -> CTAItemCTA
}
