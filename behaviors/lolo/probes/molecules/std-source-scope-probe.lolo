app std-source-scope-probe "1.0.0"
"Diagnostic: proves source-scoped listens disambiguate duplicate event names end-to-end."
;;
;; Both ProbeCreate and ProbeEdit emit the SAME event name `SAVED` with NO rename.
;; ProbePersistor source-scopes its listens to distinguish which sibling fired.
;;
;; If source-scoping works end-to-end:
;;   SAVE on ProbeCreate  -> persist create (+1 row)
;;   SAVE on ProbeEdit    -> persist update (0 row delta, mutation delta)
;;
;; If source-scoping is broken: BOTH cascades fire on every SAVE.

orbital SourceProbeOrbital {
  entity Probe [persistent: probes] {
    id   : string!
    kind : string = ""
    name : string = ""
  }

  type ProbeLoaded     = Event { data : [Probe] }
  type ProbeLoadFailed = Event { error : string, code : string }
  type ProbeSaved      = Event { id : string }
  type ProbeSaveFailed = Event { error : string, code : string }
  type ProbeUpdated    = Event { id : string }
  type ProbeUpdateFailed = Event { error : string, code : string }
  type ProbeCreateLoaded     = Event { data : [Probe] }
  type ProbeCreateLoadFailed = Event { error : string, code : string }
  type ProbeEditLoaded       = Event { data : [Probe] }
  type ProbeEditLoadFailed   = Event { error : string, code : string }
  type ProbePersistorLoaded     = Event { data : [Probe] }
  type ProbePersistorLoadFailed = Event { error : string, code : string }

  trait ProbeCreate -> Probe [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Probe { emit: { success: "ProbeCreateLoaded", failure: "ProbeCreateLoadFailed" } })
        (render-ui main { type: "button", label: "Fire Create SAVE", action: "SAVE", variant: "primary" })
      ProbeCreateLoaded -> idle
        (render-ui main { type: "button", label: "Fire Create SAVE", action: "SAVE", variant: "primary" })
      ProbeCreateLoadFailed -> idle
        (render-ui main { type: "button", label: "Fire Create SAVE", action: "SAVE", variant: "primary" })
      SAVE -> idle
        (emit SAVED { kind: "create" })
        (render-ui main { type: "button", label: "Fire Create SAVE", action: "SAVE", variant: "primary" })
    }
    emits {
      SAVED external { kind : string! }
      ProbeCreateLoaded internal { data : [Probe] }
      ProbeCreateLoadFailed internal { error : string, code : string }
    }
    listens {
      SAVE { data : object! }
    }
  }

  trait ProbeEdit -> Probe [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Probe { emit: { success: "ProbeEditLoaded", failure: "ProbeEditLoadFailed" } })
        (render-ui main { type: "button", label: "Fire Edit SAVE", action: "SAVE", variant: "secondary" })
      ProbeEditLoaded -> idle
        (render-ui main { type: "button", label: "Fire Edit SAVE", action: "SAVE", variant: "secondary" })
      ProbeEditLoadFailed -> idle
        (render-ui main { type: "button", label: "Fire Edit SAVE", action: "SAVE", variant: "secondary" })
      SAVE -> idle
        (emit SAVED { kind: "edit" })
        (render-ui main { type: "button", label: "Fire Edit SAVE", action: "SAVE", variant: "secondary" })
    }
    emits {
      SAVED external { kind : string! }
      ProbeEditLoaded internal { data : [Probe] }
      ProbeEditLoadFailed internal { error : string, code : string }
    }
    listens {
      SAVE { data : object! }
    }
  }

  trait ProbePersistor -> Probe [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Probe { emit: { success: "ProbePersistorLoaded", failure: "ProbePersistorLoadFailed" } })
        (render-ui main { type: "typography", variant: "caption", content: "Persistor idle" })
      ProbePersistorLoaded -> idle
        (render-ui main { type: "typography", variant: "caption", content: "Persistor idle" })
      ProbePersistorLoadFailed -> idle
        (render-ui main { type: "typography", variant: "caption", content: "Persistor idle" })
      DO_CREATE -> idle
        (persist create Probe { kind: "create", name: "probe-created" } { emit: { success: "ProbeSaved", failure: "ProbeSaveFailed" } })
        (render-ui main { type: "typography", variant: "caption", content: "DO_CREATE fired" })
      DO_UPDATE -> idle
        (persist create Probe { kind: "edit", name: "probe-updated" } { emit: { success: "ProbeUpdated", failure: "ProbeUpdateFailed" } })
        (render-ui main { type: "typography", variant: "caption", content: "DO_UPDATE fired" })
    }
    emits: [ProbeSaved, ProbeSaveFailed, ProbeUpdated, ProbeUpdateFailed, ProbePersistorLoaded, ProbePersistorLoadFailed]
    listens {
      ProbeCreate SAVED -> DO_CREATE
      ProbeEdit   SAVED -> DO_UPDATE
    }
  }

  page "/probes" as ProbePage -> ProbeCreate, ProbeEdit, ProbePersistor
}
