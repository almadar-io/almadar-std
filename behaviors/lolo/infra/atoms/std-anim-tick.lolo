app std-anim-tick "1.1.0"
"std-anim-tick — sprite animation clock atom. Owns a global animation counter and exposes the current frame NAME (@entity.frameName = frames[counter % len]) every 100ms tick. Boards compose it via `uses` + a trait-ref rebound (linkedEntity) to the board entity; render-ui merges @entity.frameName onto the animated sprite's asset, replacing the inlined animTick frame counters that were duplicated across game boards. 1.1.0 redesign: the 1.0.0 units-frame-advance / effects-aging sets were removed — numeric unit frames served the pre-animation-contract regime (draw-sprite paints atlas sub-texture NAMES, which is exactly what frameName now exposes; zero consumers existed), effects aging is owned by std-fx-particles, and the shared-entity one-writer rule (ORB_SHARED_ENTITY_FIELD_CONFLICT) forbids a shared atom co-writing fields a board's own ticks also write. Tick interval is a language-level literal (100ms); the config surface is `frames`."
orbital AnimTickOrbital {
  entity AnimTickItem [runtime] {
    id : string!
    animCounter : number = 0
    frameName : string = ""
  }

  trait AnimTick -> @rebindable AnimTickItem [game-core, instance] {
    initial: running

    state running {
      INIT -> running
        (set @entity.animCounter 0)
        (set @entity.frameName (if (> (array/len @config.frames) 0) (array/nth @config.frames 0) @entity.frameName))
    }

    ticks {
      animTick every 100ms
        (set @entity.animCounter (+ @entity.animCounter 1))
        (set @entity.frameName (if (> (array/len @config.frames) 0) (array/nth @config.frames (% @entity.animCounter (array/len @config.frames))) @entity.frameName))
    }

    config {
      frames : [string] = []
        @label "Frame names"
        @description "Atlas sub-texture names cycled into @entity.frameName, one per tick; empty disables name cycling."
        @synonyms "sprite names, atlas frames, animation frames"
        @tier "domain"
    }
  }

  page "/anim-tick" as AnimTickPage -> AnimTick
}
