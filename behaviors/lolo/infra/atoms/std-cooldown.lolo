app std-cooldown "1.0.0"
"std-cooldown — ability/action cooldown primitive; START begins the countdown, READY fires when it expires."
orbital CooldownOrbital {
    type CooldownReady = Event { entityId : string } "Emitted when the cooldown expires and the action is available again."

  entity CooldownRecord [persistent: cooldown_states] {
    id : string!
    remainingMs : number @description "Milliseconds remaining on the active cooldown." @synonyms "time left, remaining, countdown, ms left" = 0
    active : boolean @description "Whether the cooldown is currently counting down." @synonyms "cooling, on cooldown, busy, in progress" = false
  }

  trait Cooldown -> CooldownRecord [game-core, instance] {
    initial: ready

    state ready {
      START -> cooling
        (set @entity.remainingMs @config.defaultDurationMs)
        (set @entity.active true)
    }

    state cooling {
      EXPIRE -> ready
        (set @entity.active false)
        (set @entity.remainingMs 0)
        (emit CooldownReady { entityId: @entity.id })
    }

    emits {
      CooldownReady -> external {
        entityId : string
      }
        @description "Fired when the cooldown expires; wire to re-enable the ability or action."
        @synonyms "ready, cooldown-done, available, recharged, action-ready"
        @tier "domain"

      EXPIRE { }
        @description "Internal: fired by the expiry tick to drive the cooling→ready transition."
    }

    listens {
      START { durationMs : number }
      EXPIRE { }
    }

    ticks {
      cooldownTick every 100ms
        when (== @entity.active true)
        (set @entity.remainingMs (math/max 0 (- @entity.remainingMs 100)))

      expiryCheck every 100ms
        when (and (== @entity.active true) (<= @entity.remainingMs 0))
        (emit EXPIRE { })
    }

    config {
      defaultDurationMs : number = 3000
        @label "Default cooldown duration (ms)"
        @description "Milliseconds the cooldown runs when START is received without an explicit durationMs payload."
        @synonyms "cooldown time, duration, delay, recharge time, wait time"
        @tier "domain"
    }
  }

  page "/game/cooldown" as CooldownPage -> Cooldown
}
