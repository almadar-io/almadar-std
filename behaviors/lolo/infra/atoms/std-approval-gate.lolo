app std-approval-gate "1.0.1"
"std-approval-gate — generic approval gate / approver workflow. Use when a user voices that an action must be reviewed, approved, signed off, or authorized by a privileged role before it proceeds (admin approval, supervisor sign-off, manager approval, gatekeeper review, editor approval, senior editor approval, reviewer approval, publishing approval, draft approval, content review, submit drafts then editors review and approve or reject, needs approval before going live, requires sign-off before publish). Persists ApprovalRequest rows + surfaces them in a review queue with Approve / Deny / Reject actions, optionally requiring a written rejection reason or feedback comment. On approval emits ApprovalGranted; on denial emits ApprovalDenied. Compose onto any orbital whose action you want to gate: the target orbital emits an external event, an ApprovalRequest row is created, and downstream effects wait on ApprovalGranted. Differs from std-mod-queue, which is content-moderation-specific."
orbital ApprovalGateOrbital {
    uses Spinner from "std/behaviors/ui-spinner"
    uses Typography from "std/behaviors/ui-typography"
    uses Icon from "std/behaviors/ui-icon"
    uses Button from "std/behaviors/ui-button"
    uses Divider from "std/behaviors/ui-divider"
    uses Alert from "std/behaviors/ui-alert"

    type ApprovalRequestLoaded = Event { data : [ApprovalRequest] } "Fired when the approval queue collection finishes loading"

    type ApprovalRequestLoadFailed = Event { error : string, code : string } "Fired when the approval queue fails to load"

    type ApprovalRequestReviewed = Event { row : ApprovalRequest } "Fired after a row's status persists (approve / deny)"

    type ApprovalRequestReviewFailed = Event { error : string, code : string } "Fired when the persist fails"

    type ApprovalGranted = Event { requestId : string, payload : object } "Re-emitted on approval; carries the held payload so the downstream listener can replay the gated action without a lookup."

    type ApprovalDenied = Event { requestId : string } "Emitted on denial; downstream listeners can log or notify."

  entity ApprovalRequest [persistent: approval_requests] {
    id : string!
    gatedEvent : string @description "The event that triggered the approval request." @synonyms "trigger, event, source" = ""
    status : "pending" | "approved" | "denied" | "escalated" @description "Current state of the approval process." @synonyms "approval status, state, condition" = pending
    reviewer : string @description "The user or system responsible for reviewing the request." @synonyms "assignee, owner, approver, responsible party" = ""
    requestedAt : number @description "Timestamp indicating when the approval request was initiated." @synonyms "creation time, request date, submission time" = 0
    decidedAt : number @description "Timestamp indicating when a decision was made on the request." @synonyms "decision time, resolved at, completed at" = 0
    escalatedAt : number @description "Timestamp indicating when the request was escalated." @synonyms "escalation time, escalation timestamp, escalated time" = 0
    notes : string @description "Free-form text providing additional context or details." @synonyms "comments, remarks, explanation, details" = ""
    payload : object @description "The held data of the gated action, replayed by the downstream listener when the request is granted." @synonyms "request data, held payload, pending data, gated data" = {}
  }

  trait LoadingSpinner = Spinner.traits.SpinnerRender -> ApprovalRequest {
    config {}
  }

  trait ErrorSpinner = Spinner.traits.SpinnerRender -> ApprovalRequest {
    config {
      size: sm
    }
  }

  trait LoadingText = Typography.traits.TypographyRender -> ApprovalRequest {
    config {
      color: muted
      content: "Loading approval queue…"
      variant: caption
    }
  }

  trait ShieldCheckIcon = Icon.traits.IconRender -> ApprovalRequest {
    config {
      name: shield-check
    }
  }

  trait ApprovalQueueTitle = Typography.traits.TypographyRender -> ApprovalRequest {
    config {
      content: "Approval queue"
      variant: h3
    }
  }

  trait CloseButton = Button.traits.ButtonRender -> ApprovalRequest {
    config {
      action: CLOSE
      icon: x
      label: Close
      variant: ghost
    }
  }

  trait ApprovalDivider = Divider.traits.DividerRender -> ApprovalRequest {
    config {}
  }

  trait ErrorAlert = Alert.traits.AlertRender -> ApprovalRequest {
    config {
      message: ?error
      variant: error
    }
  }

  trait ApprovalGateReview -> @rebindable ApprovalRequest [interaction, collection, approval] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ApprovalRequest {
          emit: { failure: ApprovalRequestLoadFailed, success: ApprovalRequestLoaded }
        })
      ApprovalRequestLoaded -> idle
      ApprovalRequestLoadFailed -> idle
      OPEN -> loading when @config.enabled
        (fetch ApprovalRequest {
          emit: { failure: ApprovalRequestLoadFailed, success: ApprovalRequestLoaded }
        })
        (render-ui @config.reviewSlot {
          align: center
          children: [@trait.LoadingSpinner, @trait.LoadingText]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state loading {
      ApprovalRequestLoaded -> reviewing
        (render-ui @config.reviewSlot {
          children: [{
            align: center
            children: [{
              align: center
              children: [@trait.ShieldCheckIcon, @trait.ApprovalQueueTitle]
              direction: horizontal
              gap: sm
              type: stack
            }, @trait.CloseButton]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, @trait.ApprovalDivider, {
            cols: 1
            entity: ?data
            fields: [{
              label: Action
              name: gatedEvent
              variant: badge
            }, {
              label: Requested
              name: requestedAt
              variant: caption
            }, {
              label: Status
              name: status
              variant: badge
            }]
            gap: sm
            itemActions: [{
              event: APPROVE
              icon: check
              label: Approve
              variant: primary
            }, {
              event: DENY
              icon: x
              label: Deny
              variant: danger
            }]
            look: @config.tableLook
            type: data-grid
          }]
          direction: vertical
          gap: md
          type: stack
        })
      ApprovalRequestLoadFailed -> error
        (render-ui @config.reviewSlot {
          children: [@trait.ErrorAlert]
          type: stack
        })
      CLOSE -> idle
        (render-ui @config.reviewSlot null)
    }

    state reviewing {
      APPROVE -> reviewing
        (set @entity.id ?id)
        (set @entity.status approved)
        (set @entity.reviewer @user.id)
        (persist update ApprovalRequest @entity {
          emit: { failure: ApprovalRequestReviewFailed, success: ApprovalRequestReviewed }
        })
        (emit ApprovalGranted { payload: ?row.payload, requestId: ?id })
      DENY -> reviewing
        (set @entity.id ?id)
        (set @entity.status denied)
        (set @entity.reviewer @user.id)
        (persist update ApprovalRequest @entity {
          emit: { failure: ApprovalRequestReviewFailed, success: ApprovalRequestReviewed }
        })
        (emit ApprovalDenied { requestId: ?id })
      ApprovalRequestReviewed -> loading
        (fetch ApprovalRequest {
          emit: { failure: ApprovalRequestLoadFailed, success: ApprovalRequestLoaded }
        })
      ApprovalRequestReviewFailed -> reviewing
        (render-ui @config.reviewSlot {
          children: [@trait.ErrorAlert]
          type: stack
        })
      CLOSE -> idle
        (render-ui @config.reviewSlot null)
    }

    state error {
      OPEN -> loading
        (fetch ApprovalRequest {
          emit: { failure: ApprovalRequestLoadFailed, success: ApprovalRequestLoaded }
        })
        (render-ui @config.reviewSlot {
          children: [@trait.ErrorSpinner]
          type: stack
        })
      CLOSE -> idle
        (render-ui @config.reviewSlot null)
    }

    emits {
      APPROVE {
        id : string!
        row : ApprovalRequest
      }
        @description "Signals that an approval request has been approved."
        @synonyms "accept, authorize, confirm, pass"
        @tier "domain"
      DENY {
        id : string!
        row : ApprovalRequest
      }
        @description "Signals that an approval request has been denied."
        @synonyms "reject, decline"
        @tier "domain"
      CLOSE
        @description "Dismisses the review queue overlay."
        @synonyms "dismiss, hide, cancel, done"
        @tier "domain"
      ApprovalGranted -> external {
        requestId : string
        payload : object
      }
        @description "Signals that an approval process has been successfully completed; carries the held payload for the downstream listener to replay."
        @synonyms "approved, authorized, confirmed, validated"
        @tier "domain"
      ApprovalDenied -> external {
        requestId : string
      }
        @description "Indicates an approval request has been denied."
        @synonyms "rejected, declined"
        @tier "domain"
      ApprovalRequestLoaded {
        data : [ApprovalRequest]
      }
        @description "Indicates an approval request has been successfully loaded."
        @synonyms "loaded, fetched, retrieved"
        @tier "internal"
      ApprovalRequestLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load an approval request."
        @synonyms "load error, failed load, request failure"
        @tier "internal"
      ApprovalRequestReviewed {
        row : ApprovalRequest
      }
        @description "Signals that an approval request has been reviewed."
        @synonyms "reviewed, processed, examined"
        @tier "internal"
      ApprovalRequestReviewFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load or process an approval request for review."
        @synonyms "load error, failed review, processing failure"
        @tier "internal"
    }

    listens {
      CloseButton.CLOSE -> CLOSE
      OPEN
        @description "Summons the review queue (host nav/affordance requests it)."
        @synonyms "open, show, review, view queue, open approvals"
        @tier "domain"
      CLOSE
        @description "Dismisses the review queue overlay."
        @synonyms "dismiss, hide, cancel, done"
        @tier "domain"
      APPROVE {
        id : string!
        row : ApprovalRequest
      }
        @description "Indicates an approval action has been completed."
        @synonyms "accept, authorize, confirm, validate"
        @tier "domain"
      DENY {
        id : string!
        row : ApprovalRequest
      }
        @description "Indicates an approval request has been rejected."
        @synonyms "reject, decline, deny"
        @tier "domain"
      ApprovalRequestLoaded {
        data : [ApprovalRequest]
      }
        @description "Indicates an approval request has been successfully retrieved."
        @synonyms "loaded, fetched, retrieved"
        @tier "internal"
      ApprovalRequestLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load an approval request."
        @synonyms "load error, failed load, request failure"
        @tier "internal"
      ApprovalRequestReviewed {
        row : ApprovalRequest
      }
        @description "Indicates an approval request has been reviewed."
        @synonyms "reviewed, checked, processed"
        @tier "domain"
      ApprovalRequestReviewFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load or process an approval request."
        @synonyms "error, failure, problem, issue"
        @tier "internal"
    }

    config {
      enabled : boolean = false
        @label "Require approval"
        @description "Require sign-off before a record is finalized. Off by default."
        @synonyms "enable, turn on, enforce, require, activate, apply, switch on, approval, needs approval, sign-off, signed off, review before, gatekeeper, editor approval, publishing approval, draft approval, content review, requires approval, manager approval, supervisor approval, admin approval, before going live"
        @tier "policy"
      approverRoles : [string] = []
        @label "Who can approve requests?"
        @description "Roles eligible to approve. The host application enforces role-gating on the page."
        @synonyms "approver, reviewer, authorized roles, sign-off roles, who approves"
        @tier "policy"
      threshold : number = 0
        @label "Auto-approve below this value"
        @description "Requests whose gated value is below this threshold are auto-approved. v1.0 declarative only."
        @synonyms "auto approve amount, skip review under, threshold, limit"
        @tier "policy"
      autoApproveBelowThreshold : boolean = true
        @label "Skip review queue for low-value requests?"
        @description "When true, auto-approves requests below the threshold without queuing. v1.0 declarative only."
        @synonyms "auto approve, skip review, bypass queue, automatic approval"
        @tier "policy"
      valueField : string = ""
        @label "Value field"
        @description "Payload field name to compare against threshold (e.g. 'amount' on a RefundRequested event). v1.0 declarative only."
        @tier "internal"
      escalationHours : number = 0
        @label "Escalate after how many hours pending?"
        @description "Hours a request can sit pending before escalating. v1.0 declarative only."
        @synonyms "escalation time, SLA hours, pending timeout, escalate after"
        @tier "policy"
      escalationRoles : [string] = []
        @label "Who gets notified when a request escalates?"
        @description "Roles notified on escalation (compose sibling std-notify-on-event to deliver)."
        @synonyms "escalation contacts, escalate to, notify roles, escalated approver"
        @tier "policy"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Review queue table style"
        @description "Visual treatment for the approval-queue data table."
        @synonyms "table style, grid look, compact, spacious, striped"
        @tier "presentation"
      reviewSlot : slot = modal
        @label "Review slot"
        @description "UI slot the review queue renders into. Defaults to the modal overlay so the queue never seizes the host's main content; summoned via OPEN, cleared via CLOSE."
        @tier "internal"
    }
  }

  page "/approvals/queue" as ApprovalGateReviewPage -> ApprovalGateReview
}