app std-cache-aside "1.0.0"
"std-cache-aside as a Function"
orbital CacheEntryOrbital {
    uses Icon from "std/behaviors/ui-icon"
    uses Typography from "std/behaviors/ui-typography"
    uses Button from "std/behaviors/ui-button"
    uses Divider from "std/behaviors/ui-divider"
    uses EmptyState from "std/behaviors/ui-empty-state"
    uses Spinner from "std/behaviors/ui-spinner"
    uses StatusDot from "std/behaviors/ui-status-dot"
    uses Badge from "std/behaviors/ui-badge"
    uses Alert from "std/behaviors/ui-alert"

    type CacheEntryLoaded = Event { data : [CacheEntry] } "Fired when CacheEntry finishes loading; payload.data holds the entries"

    type CacheEntryLoadFailed = Event { error : string, code : string } "Fired when CacheEntry fails to load"

    type CacheEntryUpdated = Event { id : string } "Fired when persist update succeeds"

    type CacheEntryUpdateFailed = Event { error : string, code : string } "Fired when persist update fails"

  entity CacheEntry [runtime] {
    id : string!
    name : string! @description "A user-defined identifier for the cache entry." @synonyms "key, identifier, alias"
    description : string @description "A human-readable explanation of the entry's content." @synonyms "explanation, details, notes, summary"
    status : "active" | "inactive" | "pending" @description "Current operational state of the entry." @synonyms "state, condition, operationalStatus" = active
    createdAt : string
    hitCount : number @description "The number of times this entry has been retrieved." @synonyms "count, occurrences, retrievals" = 0
    cacheAge : number @description "Duration since the cache entry was last updated." @synonyms "age, duration, expiry" = 0
  }

  trait FetchButton = Button.traits.ButtonRender -> CacheEntry {
    config {
      action: FETCH
      icon: download
      label: Fetch
      variant: primary
    }
  }

  trait InvalidateButton = Button.traits.ButtonRender -> CacheEntry {
    config {
      action: INVALIDATE
      icon: trash
      label: Invalidate
      variant: ghost
    }
  }

  trait RefreshButton = Button.traits.ButtonRender -> CacheEntry {
    config {
      action: REFRESH
      icon: refresh-cw
      label: Refresh
      variant: primary
    }
  }

  trait RetryButton = Button.traits.ButtonRender -> CacheEntry {
    config {
      action: FETCH
      icon: rotate-ccw
      label: Retry
      variant: primary
    }
  }

  trait CacheEntryCacheManager -> CacheEntry [interaction, collection] {
    initial: empty

    state empty {
      INIT -> empty
        (render-ui main {
          children: [{
            children: [{
              children: [<Icon.traits.IconRender linkedEntity={CacheEntry} name={database} />, <Typography.traits.TypographyRender linkedEntity={CacheEntry} content={"Cache (empty)"} variant={h2} />]
              direction: horizontal
              gap: md
              type: stack
            }, @trait.FetchButton]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, <Divider.traits.DividerRender linkedEntity={CacheEntry} />, <EmptyState.traits.EmptyStateRender description={"Fetch data to populate the cache."} icon={inbox} linkedEntity={CacheEntry} look={@config.emptyLook} title={"Cache is empty"} />]
          direction: vertical
          gap: lg
          type: stack
        })
      FETCH -> loading
        (fetch CacheEntry {
          emit: { failure: CacheEntryLoadFailed, success: CacheEntryLoaded }
        })
        (render-ui main {
          align: center
          children: [<Spinner.traits.SpinnerRender linkedEntity={CacheEntry} />, <Typography.traits.TypographyRender color={muted} content={"Fetching cache…"} linkedEntity={CacheEntry} variant={caption} />]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state loading {
      CacheEntryLoaded -> cached
        (render-ui main {
          children: [{
            children: [{
              children: [<Icon.traits.IconRender linkedEntity={CacheEntry} name={database} />, <Typography.traits.TypographyRender linkedEntity={CacheEntry} content={"Cache (hot)"} variant={h2} />]
              direction: horizontal
              gap: md
              type: stack
            }, {
              align: center
              children: [<StatusDot.traits.StatusDotRender label={Cached} linkedEntity={CacheEntry} pulse={false} status={online} />, @trait.InvalidateButton]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, <Divider.traits.DividerRender linkedEntity={CacheEntry} />, {
            entity: ?data
            fields: []
            look: @config.tableLook
            renderItem: (fn item {
              children: [{
                align: center
                children: [{
                  align: center
                  children: [<Icon.traits.IconRender linkedEntity={CacheEntry} name={database} />, <Typography.traits.TypographyRender content={@item.name} linkedEntity={CacheEntry} variant={h4} />]
                  direction: horizontal
                  gap: sm
                  type: stack
                }, <Badge.traits.BadgeRender label={@item.description} linkedEntity={CacheEntry} />]
                direction: horizontal
                justify: between
                type: stack
              }, <Typography.traits.TypographyRender content={@item.status} linkedEntity={CacheEntry} variant={caption} />]
              direction: vertical
              gap: sm
              type: stack
            })
            type: data-grid
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      CacheEntryLoadFailed -> error
        (render-ui main {
          align: center
          children: [<Icon.traits.IconRender color={error} linkedEntity={CacheEntry} name={alert-triangle} />, <Typography.traits.TypographyRender content={"Failed to load"} linkedEntity={CacheEntry} variant={h3} />, <Typography.traits.TypographyRender color={muted} content={?error} linkedEntity={CacheEntry} variant={body} />, @trait.RetryButton]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state cached {
      INVALIDATE -> stale
        (render-ui main {
          children: [{
            children: [{
              children: [<Icon.traits.IconRender linkedEntity={CacheEntry} name={database} />, <Typography.traits.TypographyRender linkedEntity={CacheEntry} content={"Cache (stale)"} variant={h2} />]
              direction: horizontal
              gap: md
              type: stack
            }, {
              align: center
              children: [<StatusDot.traits.StatusDotRender label={Stale} linkedEntity={CacheEntry} pulse={true} status={warning} />, @trait.RefreshButton]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, <Divider.traits.DividerRender linkedEntity={CacheEntry} />, <Alert.traits.AlertRender linkedEntity={CacheEntry} message={"Cache data is stale. Refresh to get the latest data."} variant={warning} />]
          direction: vertical
          gap: lg
          type: stack
        })
      CACHED -> loading
        (persist update CacheEntry ?data {
          emit: { failure: CacheEntryUpdateFailed, success: CacheEntryUpdated }
        })
        (fetch CacheEntry {
          emit: { failure: CacheEntryLoadFailed, success: CacheEntryLoaded }
        })
        (render-ui main <Stack>
          <Spinner.traits.SpinnerRender linkedEntity={CacheEntry} />
        </Stack>)
    }

    state stale {
      REFRESH -> loading
        (fetch CacheEntry {
          emit: { failure: CacheEntryLoadFailed, success: CacheEntryLoaded }
        })
        (render-ui main <Stack>
          <Spinner.traits.SpinnerRender linkedEntity={CacheEntry} />
        </Stack>)
      FETCH -> loading
        (fetch CacheEntry {
          emit: { failure: CacheEntryLoadFailed, success: CacheEntryLoaded }
        })
        (render-ui main <Stack>
          <Spinner.traits.SpinnerRender linkedEntity={CacheEntry} />
        </Stack>)
    }

    state error {
      INIT -> empty
        (render-ui main <Stack>
          <EmptyState.traits.EmptyStateRender description={"Fetch data to populate the cache."} icon={inbox} linkedEntity={CacheEntry} look={@config.emptyLook} title={"Cache is empty"} />
        </Stack>)
      FETCH -> loading
        (fetch CacheEntry {
          emit: { failure: CacheEntryLoadFailed, success: CacheEntryLoaded }
        })
        (render-ui main <Stack>
          <Spinner.traits.SpinnerRender linkedEntity={CacheEntry} />
        </Stack>)
    }

    emits {
      CacheEntryLoaded
        @description "Indicates a cache entry has been successfully retrieved."
        @synonyms "loaded, retrieved, fetched"
        @tier "domain"
      CacheEntryLoadFailed
        @description "Indicates a failure to load a cache entry."
        @synonyms "error, failure, miss, not found"
        @tier "internal"
      CacheEntryUpdated
        @description "Signals that a cached entry's data has been modified."
        @synonyms "modified, refreshed, changed, updated"
        @tier "presentation"
      CacheEntryUpdateFailed
        @description "Indicates a failure to update a cached entry."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }

    listens {
      FetchButton.FETCH -> FETCH
      InvalidateButton.INVALIDATE -> INVALIDATE
      RefreshButton.REFRESH -> REFRESH
      RetryButton.FETCH -> FETCH
      CACHED {
        data : CacheEntry
      }
        @description "Data retrieved successfully from the cache."
        @synonyms "hit, found, retrieved"
        @tier "domain"
      CacheEntryLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to retrieve a cached entry."
        @synonyms "error, failure, miss, not found"
        @tier "internal"
      CacheEntryUpdateFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to update a cached entry."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }

    config {
      ttlSeconds : number = 300
        @label "TTL (seconds)"
        @description "Cache entry time-to-live before it goes stale. Default 5 minutes. Shorter = fresher/real-time data; longer = stable/long-lived caching."
        @synonyms "expiration, time to live, cache duration, freshness, real-time (short) vs long-lived (long)"
        @tier "domain"
      staleWhileRevalidate : boolean = true
        @label "Serve stale while revalidating"
        @description "When true, serve stale entries to consumers while a background refresh fetches fresh data. Reduces latency at the cost of brief staleness."
        @synonyms "SWR, stale serving"
        @tier "domain"
      evictionPolicy : "lru" | "lfu" | "fifo" | "ttl-only" = lru
        @label "Eviction policy"
        @description "How entries are evicted when the cache fills: least-recently-used, least-frequently-used, first-in-first-out, or TTL-only (never evict early)."
        @synonyms "cache replacement, eviction strategy"
        @tier "domain"
      maxCacheSize : number = 1000
        @label "Max cache entries"
        @description "Hard cap on cached entries before eviction. 0 = unlimited."
        @synonyms "cache capacity, max entries"
        @tier "domain"
      emptyLook : "illustrated" | "icon-only" | "text-only" | "mascot" = icon-only
        @label "Empty-state look"
        @description "Layer 2 visual treatment for the empty-state placeholder."
        @tier "presentation"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
    }
  }

  page "/cacheentrys" as CacheEntryPage -> CacheEntryCacheManager
}
