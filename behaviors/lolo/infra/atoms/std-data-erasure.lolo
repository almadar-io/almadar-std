app std-data-erasure "1.0.0"
"std-data-erasure — GDPR Art. 17 right-to-be-forgotten queue. Tracks ErasureRequest rows through pending → grace → executed lifecycle with Cancel during grace. v1.0 ships the request lifecycle UI + knob set; auto-emit of ExecuteErasure after grace lands in v1.1 (loop-with-emit gap — docs/Almadar_Std_Factories.md). Target app/ atoms then own the actual delete or piiFields scrub via an ExecuteErasure listener."
orbital DataErasureOrbital {
    type ErasureLoaded = Event { data : [ErasureRequest] } "Fired when the erasure queue finishes loading."

    type ErasureLoadFailed = Event { error : string, code : string } "Fired when the erasure queue fails to load."

    type ErasureSaved = Event { row : ErasureRequest } "Fired after an ErasureRequest row persists."

    type ErasureSaveFailed = Event { error : string, code : string } "Fired when an ErasureRequest persist fails."

    type ExecScanLoaded = Event { data : [ErasureRequest] } "Internal: grace requests whose execution time has passed."

    type ExecScanFailed = Event { error : string, code : string } "Internal: execution scan fetch / persist failed."

    type ExecStepped = Event { id : string } "Internal: one request executed; drives the next loop pass."

    type ExecuteErasure = Event { requestId : string, targetEntity : string, subjectId : string } "Per-request: the target atom performs the actual delete / PII scrub."

  entity ErasureRequest [persistent: erasure_requests] {
    id : string!
    subjectId : string @description "Unique identifier for the data subject." @synonyms "data subject ID, identifier, user ID" = ""
    targetEntity : string @description "The entity or system affected by the erasure request." @synonyms "affected entity, target system, destination" = ""
    status : "pending" | "grace" | "executed" | "cancelled" @description "Current state of the erasure request." @synonyms "state, lifecycle, condition" = pending
    requestedAt : number @description "Timestamp indicating when the erasure request was initially submitted." @synonyms "submission time, creation time, request date" = 0
    executesAt : number @description "Timestamp indicating when the erasure process completed." @synonyms "completion time, finish time, end time" = 0
    executedAt : number @description "Timestamp indicating when the erasure process completed." @synonyms "completion time, finish time, end time" = 0
    cancelledAt : number @description "Timestamp when the erasure request was cancelled." @synonyms "cancellation time, cancelled timestamp, cancel date" = 0
    notes : string @description "Free-form text providing additional information or context." @synonyms "comment, remark, description, details" = ""
  }

  trait ErasureWorkflow -> ErasureRequest [interaction, collection, erasure, compliance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ErasureRequest {
          emit: { failure: ErasureLoadFailed, success: ErasureLoaded }
        })
      ErasureLoaded -> idle
      ErasureLoadFailed -> idle
      OPEN -> loading when @config.enabled
        (fetch ErasureRequest {
          emit: { failure: ErasureLoadFailed, success: ErasureLoaded }
        })
        (render-ui @config.reviewSlot {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading erasure requests…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      ExecScanLoaded -> execScanning when (and @config.enabled [">", (array/len ?data), 0])
        (set @entity.id (object/get (array/first ?data) id))
        (set @entity.targetEntity (object/get (array/first ?data) targetEntity))
        (set @entity.subjectId (object/get (array/first ?data) subjectId))
        (emit ExecuteErasure {
          requestId: @entity.id
          subjectId: @entity.subjectId
          targetEntity: @entity.targetEntity
        })
        (persist update ErasureRequest {
          executedAt: @now
          id: @entity.id
          status: executed
        } {
          emit: { failure: ExecScanFailed, success: ExecStepped }
        })
      ExecScanLoaded -> idle when ["=", (array/len ?data), 0]
      ExecScanFailed -> idle
    }

    state execScanning {
      ExecStepped -> execScanning
        (fetch ErasureRequest {
          emit: { failure: ExecScanFailed, success: ExecScanLoaded }
          filter: (and ["=", (object/get @entity status), grace] ["<", (object/get @entity executesAt), @now])
        })
      ExecScanLoaded -> execScanning when [">", (array/len ?data), 0]
        (set @entity.id (object/get (array/first ?data) id))
        (set @entity.targetEntity (object/get (array/first ?data) targetEntity))
        (set @entity.subjectId (object/get (array/first ?data) subjectId))
        (emit ExecuteErasure {
          requestId: @entity.id
          subjectId: @entity.subjectId
          targetEntity: @entity.targetEntity
        })
        (persist update ErasureRequest {
          executedAt: @now
          id: @entity.id
          status: executed
        } {
          emit: { failure: ExecScanFailed, success: ExecStepped }
        })
      ExecScanLoaded -> idle when ["=", (array/len ?data), 0]
      ExecScanFailed -> idle
    }

    state loading {
      ErasureLoaded -> browsing
        (render-ui @config.reviewSlot {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: trash-2, type: icon }, {
                content: "Erasure requests"
                type: typography
                variant: h3
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CLOSE
              icon: x
              label: Close
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, { type: divider }, {
            cols: 1
            entity: ?data
            fields: [{
              label: Subject
              name: subjectId
              variant: caption
            }, {
              label: Status
              name: status
              variant: badge
            }, {
              label: Executes
              name: executesAt
              variant: caption
            }]
            gap: sm
            itemActions: [{
              event: CANCEL_ERASURE
              icon: x
              label: Cancel
              variant: secondary
            }]
            look: @config.tableLook
            type: data-grid
          }]
          direction: vertical
          gap: md
          type: stack
        })
      ErasureLoadFailed -> error
        (render-ui @config.reviewSlot {
          message: ?error
          type: alert
          variant: error
        })
      CLOSE -> idle
        (render-ui @config.reviewSlot null)
    }

    state browsing {
      CANCEL_ERASURE -> loading
        (set @entity.id ?id)
        (set @entity.status cancelled)
        (persist update ErasureRequest @entity {
          emit: { failure: ErasureSaveFailed, success: ErasureSaved }
        })
      ErasureSaved -> loading
        (fetch ErasureRequest {
          emit: { failure: ErasureLoadFailed, success: ErasureLoaded }
        })
      ErasureSaveFailed -> browsing
        (render-ui @config.reviewSlot {
          message: ?error
          type: alert
          variant: error
        })
      CLOSE -> idle
        (render-ui @config.reviewSlot null)
    }

    state error {
      OPEN -> loading
        (fetch ErasureRequest {
          emit: { failure: ErasureLoadFailed, success: ErasureLoaded }
        })
        (render-ui @config.reviewSlot { size: sm, type: spinner })
      CLOSE -> idle
        (render-ui @config.reviewSlot null)
    }

    emits {
      CANCEL_ERASURE {
        id : string!
        row : ErasureRequest
      }
        @description "Signals a request cancellation during its processing lifecycle."
        @synonyms "abort, revoke, undo, terminate"
        @tier "domain"
      CLOSE
        @description "Dismisses the erasure-requests overlay."
        @synonyms "dismiss, hide, cancel, done"
        @tier "domain"
      ErasureLoaded {
        data : [ErasureRequest]
      }
        @description "Indicates that erasure request data has been successfully loaded."
        @synonyms "loaded, fetched, retrieved"
        @tier "domain"
      ErasureLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load erasure request data."
        @synonyms "load error, failed load, data error"
        @tier "internal"
      ErasureSaved {
        row : ErasureRequest
      }
        @description "Indicates a new erasure request has been successfully saved."
        @synonyms "created, added, persisted"
        @tier "domain"
      ErasureSaveFailed {
        error : string
        code : string
      }
        @description "Indicates that saving the erasure request failed."
        @synonyms "failed, error, unsuccessful"
        @tier "internal"
      ExecuteErasure -> external {
        requestId : string
        targetEntity : string
        subjectId : string
      }
        @description "Instructs the target atom to perform the actual delete or PII scrub for a request whose grace period has elapsed."
        @synonyms "execute, perform erasure, delete now, scrub, finalize erasure"
        @tier "domain"
      ExecScanLoaded {
        data : [ErasureRequest]
      }
        @description "Internal: grace requests due for execution."
        @synonyms "scan loaded, due requests"
        @tier "internal"
      ExecScanFailed {
        error : string
        code : string
      }
        @description "Internal: execution scan failed."
        @synonyms "scan error, scan failed"
        @tier "internal"
      ExecStepped {
        id : string
      }
        @description "Internal: one request executed; advances the scan loop."
        @synonyms "stepped, next"
        @tier "internal"
    }

    listens {
      ExecScanLoaded {
        data : [ErasureRequest]
      }
        @description "Internal: grace requests due for execution."
        @synonyms "scan loaded, due requests"
        @tier "internal"
      ExecScanFailed {
        error : string
        code : string
      }
        @description "Internal: execution scan failed."
        @synonyms "scan error, scan failed"
        @tier "internal"
      ExecStepped {
        id : string
      }
        @description "Internal: one request executed; advances the scan loop."
        @synonyms "stepped, next"
        @tier "internal"
      OPEN
        @description "Summons the erasure-requests queue (host nav/affordance requests it)."
        @synonyms "open, show, review, view queue, erasure requests"
        @tier "domain"
      CLOSE
        @description "Dismisses the erasure-requests overlay."
        @synonyms "dismiss, hide, cancel, done"
        @tier "domain"
      CANCEL_ERASURE {
        id : string!
        row : ErasureRequest
      }
        @description "Indicates a request cancellation during the erasure process."
        @synonyms "revoke, abort, undo, stop"
        @tier "domain"
      ErasureLoaded {
        data : [ErasureRequest]
      }
        @description "Data erasure request successfully loaded."
        @synonyms "loaded, retrieved, fetched"
        @tier "domain"
      ErasureLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load erasure request data."
        @synonyms "load error, failed load, data error"
        @tier "internal"
      ErasureSaved {
        row : ErasureRequest
      }
        @description "A new erasure request has been successfully saved."
        @synonyms "created, added, persisted"
        @tier "domain"
      ErasureSaveFailed {
        error : string
        code : string
      }
        @description "Indicates that saving the erasure request failed."
        @synonyms "failure, error, rejected, invalid"
        @tier "presentation"
    }

    ticks {
      executionScan every "0 * * * *"
        (fetch ErasureRequest {
          emit: { failure: ExecScanFailed, success: ExecScanLoaded }
          filter: (and ["=", (object/get @entity status), grace] ["<", (object/get @entity executesAt), @now])
        })
      
    }

    config {
      enabled : boolean = false
        @label "Allow data erasure (GDPR)"
        @description "Let people request that their data be permanently removed. Off by default."
        @synonyms "enable, turn on, enforce, require, activate, apply, switch on, gdpr, erasure, right to be forgotten, data deletion, scheduled deletion, retention purge, account deletion, anonymize user data, scrub PII, delete user data"
        @tier "policy"
      targetEntity : string = ""
        @label "Target entity"
        @description "Entity name whose records erasure requests apply to (e.g. 'CustomerAccount')."
        @tier "internal"
      gracePeriodDays : number = 30
        @label "How many days before deletion is carried out?"
        @description "Days between request submission and execution. The subject can cancel during this window."
        @synonyms "grace period, cancellation window, deletion delay, days before delete"
        @tier "policy"
      anonymizeVsDelete : "anonymize" | "delete" = anonymize
        @label "Anonymize or fully delete the record?"
        @description "anonymize = scrub PII fields and keep row for audit; delete = remove the row entirely."
        @synonyms "deletion mode, anonymize, delete, scrub or remove, retention mode"
        @tier "policy"
      piiFields : [string] = []
        @label "Which fields contain personal data to scrub?"
        @description "Fields the target atom nulls when anonymizing (e.g. email, name, phone)."
        @synonyms "PII fields, personal data fields, sensitive fields, fields to scrub"
        @tier "policy"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Erasure queue table style"
        @description "Visual treatment for the erasure-requests data table."
        @synonyms "table style, grid look, compact, spacious"
        @tier "presentation"
      reviewSlot : slot = modal
        @label "Review slot"
        @description "UI slot the erasure-requests queue renders into. Defaults to the modal overlay so it never seizes the host's main content; summoned via OPEN, cleared via CLOSE."
        @tier "internal"
    }
  }

  page "/erasure/queue" as ErasureWorkflowPage -> ErasureWorkflow
}