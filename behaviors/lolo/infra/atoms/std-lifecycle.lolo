app std-lifecycle "1.1.0"
"std-lifecycle — age-based status lifecycle for a target entity. A periodic tick scans the target for records in `fromStatus` whose `dateField` is older than `ageDays`, and transitions each one to `toStatus` — every matching record, via a self-driving scan loop (process the head of a filtered fetch, persist the status, re-fetch until the set drains). Compose onto any orbital and bind `targetEntity` + the status/date knobs."
orbital LifecycleOrbital {
    type ScanRecordsLoaded = Event { data : [object] } "Internal: target records matching the lifecycle filter."

    type ScanFailed = Event { error : string, code : string } "Internal: scan fetch / persist failed."

    type LifecycleStepped = Event { id : string } "Internal: one record transitioned; drives the next loop pass."

    type LifecycleTransitioned = Event { entityId : string, status : string } "Re-emitted per record as it transitions; rename to wire downstream listeners."

  entity LifecycleRunLog [persistent: lifecycle_runs] {
    id : string!
    targetEntity : string @description "The entity to which lifecycle rules apply." @synonyms "subject, reference, target" = ""
    recordCount : number @description "The number of records processed." @synonyms "count, size, quantity" = 0
    ranAt : number @description "Timestamp indicating when the lifecycle run occurred." @synonyms "timestamp, execution time, run time" = 0
    errors : string @description "A textual description of any errors encountered." @synonyms "error message, problem, issue, fault" = ""
    status : string @description "Lifecycle status (also lets the standalone default target validate)." @synonyms "state, stage" = ""
    headId : string @description "Scratch: id of the record the scan loop is currently transitioning." @synonyms "current id, cursor" = ""
    headStatus : string @description "Scratch: the status applied to the current record." @synonyms "new status, to status" = ""
  }

  trait LifecycleScheduler -> @rebindable LifecycleRunLog [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      ScanRecordsLoaded -> scanning when (and @config.enabled [">", (array/len ?data), 0])
        (set @entity.headId (object/get (array/first ?data) id))
        (set @entity.headStatus @config.toStatus)
        (emit LifecycleTransitioned { entityId: @entity.headId, status: @entity.headStatus })
        (persist update @config.targetEntity { id: @entity.headId, status: @entity.headStatus } {
          emit: { failure: ScanFailed, success: LifecycleStepped }
        })
      ScanRecordsLoaded -> idle when ["=", (array/len ?data), 0]
      ScanFailed -> idle
    }

    state scanning {
      LifecycleStepped -> scanning
        (fetch @config.targetEntity {
          emit: { failure: ScanFailed, success: ScanRecordsLoaded }
          filter: (and ["=", (object/get @entity status), @config.fromStatus] ["<", (object/get @entity @config.dateField), ["-", @now, ["*", @config.ageDays, 86400000]]])
        })
      ScanRecordsLoaded -> scanning when [">", (array/len ?data), 0]
        (set @entity.headId (object/get (array/first ?data) id))
        (set @entity.headStatus @config.toStatus)
        (emit LifecycleTransitioned { entityId: @entity.headId, status: @entity.headStatus })
        (persist update @config.targetEntity { id: @entity.headId, status: @entity.headStatus } {
          emit: { failure: ScanFailed, success: LifecycleStepped }
        })
      ScanRecordsLoaded -> idle when ["=", (array/len ?data), 0]
      ScanFailed -> idle
    }

    emits {
      LifecycleTransitioned -> external {
        entityId : string
        status : string
      }
      ScanRecordsLoaded {
        data : [object]
      }
      ScanFailed {
        error : string
        code : string
      }
      LifecycleStepped {
        id : string
      }
    }

    listens {
      ScanRecordsLoaded {
        data : [object]
      }
      ScanFailed {
        error : string
        code : string
      }
      LifecycleStepped {
        id : string
      }
    }

    ticks {
      scanCycle every "0 * * * *"
        (fetch @config.targetEntity {
          emit: { failure: ScanFailed, success: ScanRecordsLoaded }
          filter: (and ["=", (object/get @entity status), @config.fromStatus] ["<", (object/get @entity @config.dateField), ["-", @now, ["*", @config.ageDays, 86400000]]])
        })
      
    }

    config {
      enabled : boolean = false
        @label "Auto-archive old records"
        @description "Automatically change the status of records once they age past a threshold. Off by default."
        @synonyms "enable, turn on, enforce, require, activate, apply, switch on, retention, ttl, expire, archive after, sunset, lifecycle, age out, time-based status, scheduled transitions, expire old records, auto-archive"
        @tier "infra"
      targetEntity : entity = LifecycleRunLog
        @label "Target entity"
        @description "Entity name to scan and transition (e.g. 'Task'). Defaults to the atom's own log so the standalone validates; rebind per composition. Typed `entity`, so a rename of the bound entity threads through to this value automatically."
        @tier "internal"
      fromStatus : string = ""
        @label "Which status triggers the age-out?"
        @description "Only records currently in this status are candidates for automatic transition."
        @synonyms "source status, current status, eligible status, starting status"
        @tier "infra"
      toStatus : string = ""
        @label "What status should old records move to?"
        @description "Status assigned once a record ages past the threshold (e.g. 'archived', 'expired')."
        @synonyms "target status, end status, destination status, archive status"
        @tier "infra"
      dateField : string = ranAt
        @label "Which date field measures the record's age?"
        @description "Numeric (ms-epoch) entity field compared against the age threshold (e.g. 'createdAt')."
        @tier "internal"
      ageDays : number = 30
        @label "How old (in days) before a record is transitioned?"
        @description "Records older than this many days move from the source status to the destination status."
        @synonyms "age threshold, days until archive, expiry days, max age, retention days"
        @tier "infra"
      dryRun : boolean = false
        @label "Run in dry-run mode (no changes written)?"
        @description "When true, the scan runs but no status transitions are persisted."
        @synonyms "test mode, preview, simulate, dry run, no write"
        @tier "infra"
    }
  }

  page "/lifecycle/scheduler" as LifecycleSchedulerPage -> LifecycleScheduler
}