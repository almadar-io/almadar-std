app std-app-layout-minimal "1.0.0"
"Minimal chrome. Embeds std-app-layout with minimal layout pattern."

orbital MinimalLayoutOrbital {
  uses AppLayout from "std/behaviors/std-app-layout"

  entity MinimalLayoutState [runtime] {
    id : string!
  }

  trait MinimalLayout = AppLayout.traits.AppLayout -> MinimalLayoutState {
    config: {
      layoutPattern: "minimal-layout"
    }
  }

  page "/minimal-layout" as MinimalLayoutPage -> MinimalLayout
}
