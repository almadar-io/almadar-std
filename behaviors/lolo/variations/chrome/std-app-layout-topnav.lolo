app std-app-layout-topnav "1.0.0"
"Top-navigation chrome. Embeds std-app-layout with topnav layout pattern."

orbital TopnavLayoutOrbital {
  uses AppLayout from "std/behaviors/std-app-layout"

  entity TopnavLayoutState [runtime] {
    id : string!
  }

  trait TopnavLayout = AppLayout.traits.AppLayout -> TopnavLayoutState {
    config: {
      layoutPattern: "topnav-layout"
    }
  }

  page "/topnav-layout" as TopnavLayoutPage -> TopnavLayout
}
