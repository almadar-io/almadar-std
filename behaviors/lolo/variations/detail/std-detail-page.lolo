app std-detail-page "1.0.0"
"Full-page detail view. Embeds std-modal with full-page form pattern override."

orbital DetailPageOrbital {
  uses Modal from "std/behaviors/std-modal"

  entity DetailPageRecord [runtime] {
    id          : string
    name        : string
    description : string
    status      : string
  }

  trait DetailPageModal = Modal.traits.ModalRecordModal -> DetailPageRecord {
    config: {
      detailSlot: "main"
      detailPattern: "form-section"
    }
  }

  page "/detail-page" as DetailPagePage -> DetailPageModal
}
