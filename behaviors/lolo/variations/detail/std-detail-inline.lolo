app std-detail-inline "1.0.0"
"Inline detail view. Embeds std-modal with inline form pattern override."

orbital DetailInlineOrbital {
  uses Modal from "std/behaviors/std-modal"

  entity DetailInlineRecord [runtime] {
    id          : string
    name        : string
    description : string
    status      : string
  }

  trait DetailInlineModal = Modal.traits.ModalRecordModal -> DetailInlineRecord {
    config: {
      detailSlot: "main"
      detailPattern: "inline-form"
    }
  }

  page "/detail-inline" as DetailInlinePage -> DetailInlineModal
}
