app std-browse-grid "1.0.0"
"Card grid view for std-browse. Embeds base browse atom with entity-cards pattern override."

orbital GridBrowseItemOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity GridBrowseItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  trait GridBrowseItemBrowse = Browse.traits.BrowseItemBrowse -> GridBrowseItem {
    config: {
      viewPattern: "entity-cards"
    }
  }

  page "/grid-browse" as GridBrowsePage -> GridBrowseItemBrowse
}
