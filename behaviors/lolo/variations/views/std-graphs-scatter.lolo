app std-graphs-scatter "1.0.0"
"Scatter plot view. Embeds std-graphs with scatter plot pattern override."

orbital ScatterGraphItemOrbital {
  uses Graph from "std/behaviors/std-graphs"

  entity ScatterGraphItem [runtime] {
    id        : string!
    chartData : [object] = []
  }

  trait ScatterGraphItemGraph = Graph.traits.GraphItemGraph -> ScatterGraphItem {
    config: {
      chartType: "scatter"
    }
  }

  page "/scatter-graph" as ScatterGraphPage -> ScatterGraphItemGraph
}
