app std-stats-sparkline "1.0.0"
"Sparkline stat view. Embeds std-stats with sparkline pattern override."

orbital SparklineStatsItemOrbital {
  uses Stats from "std/behaviors/std-stats"

  entity SparklineStatsItem [runtime] {
    id    : string!
    cards : [object] = []
  }

  trait SparklineStatsItemStats = Stats.traits.StatsItemStats -> SparklineStatsItem {
    config: {
      viewPattern: "data-grid"
    }
  }

  page "/sparkline-stats" as SparklineStatsPage -> SparklineStatsItemStats
}
