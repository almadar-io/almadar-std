app std-browse-kanban "1.0.0"
"Kanban view for std-browse. Embeds base browse atom with kanban pattern override."

orbital KanbanBrowseItemOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity KanbanBrowseItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  trait KanbanBrowseItemBrowse = Browse.traits.BrowseItemBrowse -> KanbanBrowseItem {
    config: {
      viewPattern: "data-grid"
    }
  }

  page "/kanban-browse" as KanbanBrowsePage -> KanbanBrowseItemBrowse
}
