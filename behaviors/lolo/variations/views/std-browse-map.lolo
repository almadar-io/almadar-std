app std-browse-map "1.0.0"
"Map view for std-browse. Embeds base browse atom with map pattern override."

orbital MapBrowseItemOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity MapBrowseItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  trait MapBrowseItemBrowse = Browse.traits.BrowseItemBrowse -> MapBrowseItem {
    config: {
      viewPattern: "map-view"
    }
  }

  page "/map-browse" as MapBrowsePage -> MapBrowseItemBrowse
}
