app std-graphs-area "1.0.0"
"Area chart view. Embeds std-graphs with area chart pattern override."

orbital AreaGraphItemOrbital {
  uses Graph from "std/behaviors/std-graphs"

  entity AreaGraphItem [runtime] {
    id        : string!
    chartData : [object] = []
  }

  trait AreaGraphItemGraph = Graph.traits.GraphItemGraph -> AreaGraphItem {
    config: {
      chartType: "area"
    }
  }

  page "/area-graph" as AreaGraphPage -> AreaGraphItemGraph
}
