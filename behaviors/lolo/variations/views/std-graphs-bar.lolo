app std-graphs-bar "1.0.0"
"Bar chart view. Embeds std-graphs with the bar chartType — vertical bars, one per category bucket. Default for distribution-of-categories visualisations."

orbital BarGraphItemOrbital {
  uses Graph from "std/behaviors/std-graphs"

  entity BarGraphItem [runtime] {
    id        : string!
    chartData : [object] = []
  }

  trait BarGraphItemGraph = Graph.traits.GraphItemGraph -> BarGraphItem {
    config: {
      chartType: "bar"
    }
  }

  page "/bar-graph" as BarGraphPage -> BarGraphItemGraph
}
