app std-browse-feed "1.0.0"
"Feed view for std-browse. Embeds base browse atom with feed pattern override."

orbital FeedBrowseItemOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity FeedBrowseItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  trait FeedBrowseItemBrowse = Browse.traits.BrowseItemBrowse -> FeedBrowseItem {
    config: {
      viewPattern: "data-list"
    }
  }

  page "/feed-browse" as FeedBrowsePage -> FeedBrowseItemBrowse
}
