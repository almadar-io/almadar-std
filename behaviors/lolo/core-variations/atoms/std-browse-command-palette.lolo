app std-browse-command-palette "1.0.1"
"Command-palette browse — VS Code/Linear/Raycast floating overlay with search input header, tight result list, and kbd hint chips."

orbital CommandPaletteBrowseOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity CommandPaletteItem [runtime] {
    id          : string!
    name        : string! @description "The item's identifier or display text." @synonyms "title, label, identifier"
    description : string @description "A brief explanation of the item's content or function." @synonyms "text, details, explanation, notes"
    status      : "active" | "inactive" | "pending" @description "Indicates the current operational state of the item." @synonyms "state, condition, enabled" = "active"
    createdAt   : string
  }

  trait CommandPaletteBrowse = Browse.traits.BrowseItemBrowse -> CommandPaletteItem {
    config: {
      bodyContent: {
        type: "stack",
        direction: "vertical",
        gap: "lg",
        align: "center",
        className: "pt-card-md px-card-md w-full",
        children: [
          { type: "card", look: "elevated", padding: "md", className: "w-full max-w-2xl",
            children: [
              { type: "stack", direction: "vertical", gap: "none", children: [
                { type: "stack", direction: "horizontal", gap: "sm", align: "center", className: "px-card-md py-3",
                  children: [
                    { type: "icon", name: "search", className: "text-muted-foreground" },
                    { type: "input", inputType: "search", placeholder: "@config.searchPlaceholder", action: "REFETCH_QUERY", className: "flex-1" },
                    { type: "badge", label: "ESC", variant: "neutral", size: "sm" }
                  ]
                },
                { type: "divider" },
                { type: "data-list", entity: "@payload.data", gap: "none", fields: [],
                  className: "max-h-96 overflow-y-auto p-1",
                  renderItem: ["fn", "item", {
                    type: "stack", direction: "horizontal", gap: "sm", align: "center",
                    className: "px-3 py-2 rounded-sm cursor-pointer hover:bg-muted/50 transition-colors",
                    children: [
                      { type: "icon", name: "file" },
                      { type: "stack", direction: "vertical", gap: "none", className: "flex-1 min-w-0",
                        children: [
                          { type: "typography", variant: "body", weight: "medium", content: "@config.titleBinding", className: "truncate" },
                          { type: "typography", variant: "caption", color: "muted", content: "@config.descriptionBinding", className: "truncate" }
                        ]
                      },
                      { type: "badge", label: "@config.badgeBinding", variant: "neutral", size: "sm" },
                      { type: "badge", label: "↵", variant: "neutral", size: "sm" }
                    ]
                  }]
                },
                { type: "divider" },
                { type: "stack", direction: "horizontal", gap: "md", align: "center", className: "px-card-md py-2 bg-[var(--color-surface-muted)]",
                  children: [
                    { type: "badge", label: "↑↓", variant: "neutral", size: "sm" },
                    { type: "typography", variant: "caption", color: "muted", content: "Navigate" },
                    { type: "badge", label: "↵", variant: "neutral", size: "sm" },
                    { type: "typography", variant: "caption", color: "muted", content: "Select" },
                    { type: "stack", direction: "horizontal", gap: "sm", align: "center", className: "ml-auto",
                      children: [
                        { type: "badge", label: "⌘K", variant: "neutral", size: "sm" },
                        { type: "typography", variant: "caption", color: "muted", content: "Toggle" }
                      ]
                    }
                  ]
                }
              ]
            }
            ]
          }
        ]
      }
    }
  }

  page "/cmd-browse" as CommandPalettePage -> CommandPaletteBrowse
}
