app std-browse-command-palette "1.0.1"
"Command-palette browse — VS Code/Linear/Raycast floating overlay with search input header, tight result list, and kbd hint chips."
orbital CommandPaletteBrowseOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity CommandPaletteItem [runtime] {
    id : string!
    name : string! @description "The item's identifier or display text." @synonyms "title, label, identifier"
    description : string @description "A brief explanation of the item's content or function." @synonyms "text, details, explanation, notes"
    status : "active" | "inactive" | "pending" @description "Indicates the current operational state of the item." @synonyms "state, condition, enabled" = active
    createdAt : string
  }

  trait CommandPaletteBrowse = Browse.traits.BrowseItemBrowse -> CommandPaletteItem {
    config {
      bodyContent: {
        align: center
        children: [{
          children: [{
            children: [{
              align: center
              children: [{
                className: text-muted-foreground
                name: search
                type: icon
              }, {
                action: REFETCH_QUERY
                className: flex-1
                inputType: search
                placeholder: @config.searchPlaceholder
                type: input
              }, {
                label: ESC
                size: sm
                type: badge
                variant: neutral
              }]
              className: "px-card-md py-3"
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              className: "max-h-96 overflow-y-auto p-1"
              entity: ?data
              fields: []
              gap: none
              renderItem: (fn item {
                align: center
                children: [{ name: file, type: icon }, {
                  children: [{
                    className: truncate
                    content: @config.titleBinding
                    type: typography
                    variant: body
                    weight: medium
                  }, {
                    className: truncate
                    color: muted
                    content: @config.descriptionBinding
                    type: typography
                    variant: caption
                  }]
                  className: "flex-1 min-w-0"
                  direction: vertical
                  gap: none
                  type: stack
                }, {
                  label: @config.badgeBinding
                  size: sm
                  type: badge
                  variant: neutral
                }, {
                  label: "↵"
                  size: sm
                  type: badge
                  variant: neutral
                }]
                className: "px-3 py-2 rounded-sm cursor-pointer hover:bg-muted/50 transition-colors"
                direction: horizontal
                gap: sm
                type: stack
              })
              type: data-list
            }, { type: divider }, {
              align: center
              children: [{
                label: "↑↓"
                size: sm
                type: badge
                variant: neutral
              }, {
                color: muted
                content: Navigate
                type: typography
                variant: caption
              }, {
                label: "↵"
                size: sm
                type: badge
                variant: neutral
              }, {
                color: muted
                content: Select
                type: typography
                variant: caption
              }, {
                align: center
                children: [{
                  label: "⌘K"
                  size: sm
                  type: badge
                  variant: neutral
                }, {
                  color: muted
                  content: Toggle
                  type: typography
                  variant: caption
                }]
                className: ml-auto
                direction: horizontal
                gap: sm
                type: stack
              }]
              className: "px-card-md py-2 bg-[var(--color-surface-muted)]"
              direction: horizontal
              gap: md
              type: stack
            }]
            direction: vertical
            gap: none
            type: stack
          }]
          className: "w-full max-w-2xl"
          look: elevated
          padding: md
          type: card
        }]
        className: "pt-card-md px-card-md w-full"
        direction: vertical
        gap: lg
        type: stack
      }
    }
  }

  page "/cmd-browse" as CommandPalettePage -> CommandPaletteBrowse
}