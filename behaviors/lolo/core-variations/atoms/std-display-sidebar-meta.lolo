app std-display-sidebar-meta "1.0.0"
"Narrow right-rail meta panel — Linear/Jira/GitHub issue sidebar. Stacked label/value rows in a ~280px column, grouped with dividers."

orbital SidebarMetaDisplayOrbital {
  uses Display from "std/behaviors/std-display"

  entity SidebarRecord [runtime] {
    id          : string!
    title       : string!
    status      : "open" | "in_progress" | "closed" = "open"
    priority    : "low" | "medium" | "high" = "medium"
    assignee    : string
    reporter    : string
    milestone   : string
    labels      : string
    createdAt   : string
    updatedAt   : string
  }

  trait SidebarMetaDisplay = Display.traits.DisplayItemDisplay -> SidebarRecord {
    config: {
      bodyContent: {
        type: "stack",
        direction: "vertical",
        gap: "md",
        className: "max-w-[280px] w-full p-card-md",
        children: [
          { type: "stack", direction: "vertical", gap: "xs", children: [
            { type: "typography", variant: "caption", color: "muted", content: "@entity.id", className: "font-mono uppercase tracking-wide" },
            { type: "typography", variant: "h4", weight: "semibold", content: "@entity.title", className: "leading-snug break-words" }
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Status" },
            { type: "badge", label: "@entity.status", variant: "default" }
          ]},
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Priority" },
            { type: "badge", label: "@entity.priority", variant: "neutral" }
          ]},
          { type: "divider" },
          { type: "stack", direction: "vertical", gap: "xs", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Assignee" },
            { type: "stack", direction: "horizontal", gap: "xs", align: "center", className: "hover:bg-[var(--color-muted)] rounded-sm -mx-1 px-1 py-0.5 transition-colors cursor-pointer", children: [
              { type: "avatar", name: "@entity.assignee", size: "xs" },
              { type: "typography", variant: "body2", content: "@entity.assignee" }
            ]}
          ]},
          { type: "stack", direction: "vertical", gap: "xs", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Reporter" },
            { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [
              { type: "avatar", name: "@entity.reporter", size: "xs" },
              { type: "typography", variant: "body2", content: "@entity.reporter" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Milestone" },
            { type: "typography", variant: "body2", content: "@entity.milestone" }
          ]},
          { type: "stack", direction: "vertical", gap: "xs", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Labels" },
            { type: "badge", label: "@entity.labels", variant: "neutral" }
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Created" },
            { type: "typography", variant: "caption", color: "muted", content: "@entity.createdAt", className: "tabular-nums" }
          ]},
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [
            { type: "typography", variant: "overline", color: "muted", content: "Updated" },
            { type: "typography", variant: "caption", color: "muted", content: "@entity.updatedAt", className: "tabular-nums" }
          ]}
        ]
      }
    }
  }

  page "/sidebar-display" as SidebarMetaDisplayPage -> SidebarMetaDisplay
}
