app std-app-layout-minimal "1.1.0"
"Minimal chrome. Embeds std-app-layout with minimal layout pattern + a placeholder content trait so the main slot has visible content."
orbital MinimalLayoutOrbital {
  uses AppLayout from "std/behaviors/std-app-layout"

  entity MinimalLayoutData [runtime] {
    id : string!
  }

  trait MinimalContent -> MinimalLayoutData [interaction, instance] {
    initial: showing

    state showing {
      INIT -> showing
        (render-ui main {
          description: "Override the contentTrait config to fill this area with your own trait."
          icon: layout
          title: "Minimal Layout"
          type: empty-state
        })
    }
  }

  trait MinimalLayout = AppLayout.traits.AppLayout -> MinimalLayoutData {
    config {
      layoutMode: minimal
      appName: "Minimal Demo"
      navItems: [{
        href: "/"
        icon: home
        label: Home
      }, {
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/settings"
        icon: settings
        label: Settings
      }]
      contentTrait: @trait.MinimalContent
    }
  }

  page "/minimal-layout" as MinimalLayoutPage -> MinimalLayout, MinimalContent
}