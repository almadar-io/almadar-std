app std-browse-dense "1.1.1"
"Spreadsheet-style dense browse — column-row data-table molecule with sticky header, monospaced numerics, status badges, tight row padding."

orbital DenseBrowseOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity DenseRow [runtime] {
    id          : string!
    name        : string!
    description : string
    value       : string
    change      : string
    volume      : string
    status      : "ok" | "warn" | "error" = "ok"
    createdAt   : string
  }

  trait DenseBrowse = Browse.traits.BrowseItemBrowse -> DenseRow {
    config: {
      bodyContent: {
        type: "stack",
        direction: "vertical",
        gap: "sm",
        className: "p-card-md",
        children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", className: "max-w-md", children: [
            { type: "icon", name: "search" },
            { type: "input", inputType: "search", placeholder: "Filter records…", action: "REFETCH_QUERY" }
          ]},
          { type: "stack", direction: "vertical", gap: "none", className: "rounded-lg border border-[var(--color-border)] overflow-x-auto bg-[var(--color-card)] shadow-sm", children: [
            { type: "table-view",
              entity: "@payload.data",
              selectable: true,
              look: "dense",
              emptyMessage: "No records",
              columns: [
                { key: "id",          field: "id",          header: "ID",      width: "7rem",                  align: "left",   className: "font-mono text-[var(--color-text-muted)]" },
                { key: "name",        field: "name",        header: "Name",    width: "minmax(10rem, 1.5fr)",  align: "left",   weight: "medium" },
                { key: "description", field: "description", header: "Detail",  width: "minmax(12rem, 2fr)",    align: "left",   className: "text-[var(--color-text-muted)]" },
                { key: "value",       field: "value",       header: "Value",   width: "6rem",                  align: "right",  className: "font-mono tabular-nums" },
                { key: "change",      field: "change",      header: "Change",  width: "6rem",                  align: "right",  className: "font-mono tabular-nums" },
                { key: "volume",      field: "volume",      header: "Volume",  width: "6rem",                  align: "right",  className: "font-mono tabular-nums text-[var(--color-text-muted)]" },
                { key: "status",      field: "status",      header: "Status",  width: "6rem",                  align: "center", format: "badge" },
                { key: "createdAt",   field: "createdAt",   header: "Created", width: "9rem",                  align: "right",  className: "font-mono tabular-nums text-[var(--color-text-muted)]", format: "date" }
              ]
            }
          ]}
        ]
      }
    }
  }

  page "/dense-browse" as DenseBrowsePage -> DenseBrowse
}
