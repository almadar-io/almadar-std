app std-step-flow-progress-vertical "1.0.0"
"Header progress bar above a vertical step list — full-width progress affordance up top, every step as a row card below."

orbital ProgressVerticalOrbital {
  uses StepFlow from "std/behaviors/std-step-flow"

  entity ProgressVerticalView [runtime] {
    id            : string!
    progressLabel : string
  }

  trait ProgressVerticalReview = StepFlow.traits.StepFlowReview -> ProgressVerticalView {
    config: {
      bodyContent: {
        type: "stack",
        direction: "vertical",
        gap: "lg",
        className: "max-w-2xl mx-auto pt-section w-full",
        children: [
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [
              { type: "typography", content: "@config.title", variant: "h3" },
              { type: "typography", content: "@entity.progressLabel", variant: "caption", color: "muted" }
            ] },
            { type: "progress-bar", value: "@entity.currentStepIndex", max: "@entity.totalSteps", steps: "@entity.totalSteps" }
          ] },
          { type: "divider" },
          { type: "data-list", entity: "@entity.wizardSteps", gap: "md", fields: [], renderItem: ["fn", "step", { type: "card", look: "@config.cardLook", children: [
            { type: "stack", direction: "horizontal", gap: "md", align: "center", className: "p-card-md", children: [
              { type: "badge", label: "@step.indexLabel", variant: "@step.badgeVariant" },
              { type: "icon", name: "@step.icon", size: "md" },
              { type: "stack", direction: "vertical", gap: "xs", children: [
                { type: "typography", content: "@step.label", variant: "h4" },
                { type: "typography", content: "@step.description", variant: "caption", color: "muted" }
              ] }
            ] }
          ] }] },
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", className: "justify-between", children: [
            { type: "button", label: "Back", variant: "ghost", action: "BACK", icon: "chevron-left", disabled: "@entity.isFirstStep", actionPayload: { id: "@entity.id" } },
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "button", label: "Reject", variant: "ghost", action: "REJECT", icon: "x", actionPayload: { id: "@entity.id" } },
              { type: "button", label: "Escalate", variant: "ghost", action: "ESCALATE", icon: "alert-triangle", actionPayload: { id: "@entity.id" } },
              { type: "button", label: "@entity.primaryActionLabel", variant: "primary", action: "ADVANCE", icon: "@entity.primaryActionIcon", actionPayload: { id: "@entity.id" } }
            ] }
          ] }
        ]
      }
    }
  }

  page "/progress-vertical" as ProgressVerticalPage -> ProgressVerticalReview
}
