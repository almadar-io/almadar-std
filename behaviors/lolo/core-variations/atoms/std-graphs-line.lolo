app std-graphs-line "1.0.0"
"Line chart view. Embeds std-graphs with the line chartType — connected points over a continuous (typically time) axis. Best for trends and time-series."

type ChartPoint = { label : string!, value : number! }

orbital LineGraphItemOrbital {
  uses Graph from "std/behaviors/std-graphs"

  entity LineGraphItem [runtime] {
    id        : string!
    chartData : [ChartPoint] = []
  }

  trait LineGraphItemGraph = Graph.traits.GraphItemGraph -> LineGraphItem {
    config: {
      chartType: "line"
    }
  }

  page "/line-graph" as LineGraphPage -> LineGraphItemGraph
}
