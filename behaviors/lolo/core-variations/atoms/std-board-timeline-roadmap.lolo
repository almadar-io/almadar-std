app std-board-timeline-roadmap "1.1.0"
"Timeline / roadmap board — horizontal time axis with quarters or months as columns; items render as cards inside their target column (item.stage = column.key). Mirrors the Linear / Asana / Productboard roadmap UX. Configure `columns` as ['Q1', 'Q2', 'Q3', 'Q4'] (or months) and the board lays them out left-to-right along a time axis. Same BoardItemBoard trait, same state machine, same emits/listens as std-board — only the bodyContent tree differs."

orbital TimelineRoadmapBoardOrbital {
  uses Board from "std/behaviors/std-board"

  entity TimelineRoadmapItem [persistent: timeline_roadmap_items] {
    id                  : string!
    title               : string! @description "The item's displayed name or heading." @synonyms "name, heading, label"
    description         : string @description "A textual explanation or summary of the item." @synonyms "details, summary, explanation, notes" = ""
    stage               : "Q1" | "Q2" | "Q3" | "Q4" @description "The item's position within the timeline's time divisions." @synonyms "period, timeframe, phase, quarter, month" = "Q1"
    notes               : string @description "Free-form text providing additional information." @synonyms "comments, remarks, details, annotations" = ""
    position            : number @description "Numerical order within the timeline." @synonyms "order, sequence, index" = 0
    boards              : [object] @intrinsic = []
    currentId           : string @intrinsic = ""
    currentTitle        : string @intrinsic = ""
    currentDescription  : string @intrinsic = ""
    currentStage        : string @intrinsic = ""
    currentNotes        : string @intrinsic = ""
    errorMessage        : string @intrinsic = ""
  }

  trait TimelineRoadmapBoard = Board.traits.BoardItemBoard -> TimelineRoadmapItem {
    config: {
      columns: [
        { key: "Q1", label: "Q1", icon: "calendar", variant: "default" },
        { key: "Q2", label: "Q2", icon: "calendar", variant: "primary" },
        { key: "Q3", label: "Q3", icon: "calendar", variant: "info" },
        { key: "Q4", label: "Q4", icon: "calendar", variant: "success" }
      ],
      gridCols: 4,
      bodyContent: {
        type: "stack",
        direction: "vertical",
        gap: "md",
        children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", className: "px-card-md", children: [
            { type: "icon", name: "calendar-range" },
            { type: "typography", content: "@config.title", variant: "h2" },
            { type: "typography", variant: "caption", color: "muted", content: "Roadmap", className: "ml-2" }
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "none", align: "stretch", className: "overflow-x-auto border-y border-[var(--color-border)]",
            children: [
              { type: "data-grid", entity: "@entity.boards", cols: "@config.gridCols", gap: "none", fields: [], dndRoot: true,
                className: "min-w-full",
                renderItem: ["fn", "col", {
                  type: "stack", direction: "vertical", gap: "none",
                  className: "min-w-[240px] border-r border-[var(--color-border)] last:border-r-0",
                  children: [
                    { type: "stack", direction: "horizontal", gap: "xs", align: "center", className: "px-card-md py-2 bg-[var(--color-surface-subtle)] border-b border-[var(--color-border)] sticky top-0", children: [
                      { type: "icon", name: "@col.icon" },
                      { type: "typography", content: "@col.label", variant: "h4", className: "flex-1" },
                      { type: "badge", label: "@col.count", variant: "primary", size: "sm" }
                    ]},
                    { type: "data-list", entity: "@col.items", gap: "sm", fields: [], dragGroup: "@col.key", accepts: "*", sortable: true, dropEvent: "MOVE_CARD", reorderEvent: "REORDER_CARD", positionEvent: "REORDER_POSITION",
                      className: "p-card-md min-h-[160px]",
                      renderItem: ["fn", "item", {
                        type: "card", look: "elevated", padding: "sm",
                        className: "cursor-grab hover:shadow-md transition-shadow",
                        children: [
                          { type: "stack", direction: "vertical", gap: "xs", children: [
                            { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [
                              { type: "icon", name: "flag" },
                              { type: "typography", content: "@config.cardTitleBinding", variant: "body", weight: "medium", className: "flex-1" }
                            ]},
                            { type: "typography", content: "@config.cardDescriptionBinding", variant: "caption", color: "muted", className: "line-clamp-2" },
                            { type: "stack", direction: "horizontal", gap: "xs", align: "center", className: "pt-1", children: [
                              { type: "badge", label: "@config.cardStageBinding", variant: "primary", size: "sm" },
                              { type: "button", label: "Details", variant: "ghost", size: "sm", action: "OPEN_CARD", actionPayload: { id: "@config.cardIdBinding", row: "@item" }, icon: "arrow-right", className: "ml-auto" }
                            ]}
                          ]}
                        ]
                      }]
                    }
                  ]
                }]
              }
            ]
          },
          { type: "floating-action-button", label: "Add milestone", action: "ADD_CARD", icon: "plus", variant: "primary" }
        ]
      }
    }
  }

  page "/timeline-roadmap" as TimelineRoadmapPage -> TimelineRoadmapBoard
}
