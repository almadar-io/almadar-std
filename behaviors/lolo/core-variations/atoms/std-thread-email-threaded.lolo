app std-thread-email-threaded "1.2.0"
"Email-threaded — Gmail/Outlook/Mail.app split-pane: left message list (sender, subject, preview), right pane shows the focused message with from/to/subject header and quoted-reply nested tree. For helpdesk email threads, support tickets, document discussions that read like email."

orbital EmailThreadedOrbital {
  uses Thread from "std/behaviors/std-thread"

  entity EmailThreadedPost [persistent: emailthreadedposts] {
    id                 : string!
    parentId           : string
    threadRootId       : string!
    authorId           : string!
    authorName         : string!
    fromAddress        : string!
    toAddress          : string!
    subject            : string!
    preview            : string
    content            : string!
    createdAt          : string
    voteCount          : number = 0
    replyCount         : number = 0
    replies            : [EmailThreadedPost]
    focusedRow         : FocusedEmail = {}
  }

  ;; Typed shape of the SELECT-focused message so the detail pane's
  ;; `@entity.focusedRow.<field>` bindings resolve to concrete types
  ;; (a bare `object` resolves to `object`, which strict string props like
  ;; avatar `name` reject).
  type FocusedEmail = {
    id          : string
    authorName  : string
    fromAddress : string
    toAddress   : string
    subject     : string
    content     : string
    createdAt   : string
    replies     : [EmailThreadedPost]
  }

  trait EmailThreaded = Thread.traits.ThreadPostBrowse -> EmailThreadedPost {
    config: {
      bodyContent: {
        type: "stack",
        direction: "horizontal",
        gap: "none",
        className: "max-w-7xl mx-auto h-full border border-[var(--color-border)] rounded-md overflow-hidden",
        children: [
          { type: "stack", direction: "vertical", gap: "none",
            className: "w-80 shrink-0 border-r border-[var(--color-border)] bg-[var(--color-muted)]",
            children: [
              { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                className: "px-card-md py-md border-b border-[var(--color-border)]",
                children: [
                  { type: "icon", name: "inbox", size: "sm" },
                  { type: "typography", variant: "label", weight: "medium", content: "Inbox" }
                ]
              },
              { type: "data-list", entity: "@payload.data", gap: "none", variant: "default",
                fields: [],
                itemActions: [{ label: "Open", event: "SELECT", icon: "mail-open" }],
                renderItem: ["fn", "item", {
                  type: "card", look: "borderless-divider", padding: "md",
                  children: {
                    type: "stack", direction: "horizontal", gap: "sm", align: "start",
                    children: [
                      { type: "avatar", name: "@item.authorName", size: "sm" },
                      { type: "stack", direction: "vertical", gap: "xs", className: "flex-1 min-w-0",
                        children: [
                          { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                            children: [
                              { type: "typography", variant: "body", weight: "medium", content: "@item.authorName", className: "flex-1 truncate" },
                              { type: "typography", variant: "caption", color: "muted", content: "@item.createdAt" }
                            ]
                          },
                          { type: "typography", variant: "body2", weight: "medium", content: "@item.subject", className: "truncate" },
                          { type: "typography", variant: "caption", color: "muted", content: "@item.preview", className: "truncate" }
                        ]
                      }
                    ]
                  }
                }]
              }
            ]
          },
          { type: "stack", direction: "vertical", gap: "md",
            className: "flex-1 px-card-md py-md overflow-y-auto",
            children: [
              { type: "stack", direction: "vertical", gap: "xs",
                className: "pb-md border-b border-[var(--color-border)]",
                children: [
                  { type: "typography", variant: "h3", content: "@entity.focusedRow.subject" },
                  { type: "stack", direction: "horizontal", gap: "md", align: "center",
                    children: [
                      { type: "avatar", name: "@entity.focusedRow.authorName", size: "md" },
                      { type: "stack", direction: "vertical", gap: "xs", className: "flex-1",
                        children: [
                          { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                            children: [
                              { type: "typography", variant: "label", color: "muted", content: "From" },
                              { type: "typography", variant: "body2", weight: "medium", content: "@entity.focusedRow.fromAddress" }
                            ]
                          },
                          { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                            children: [
                              { type: "typography", variant: "label", color: "muted", content: "To" },
                              { type: "typography", variant: "body2", content: "@entity.focusedRow.toAddress" }
                            ]
                          }
                        ]
                      },
                      { type: "typography", variant: "caption", color: "muted", content: "@entity.focusedRow.createdAt" },
                      { type: "button", label: "Reply", icon: "corner-up-left", action: "REPLY", actionPayload: { parentId: "@entity.focusedRow.id" }, variant: "secondary", size: "sm" },
                      { type: "button", label: "Forward", icon: "corner-up-right", action: "REPLY", variant: "ghost", size: "sm" }
                    ]
                  }
                ]
              },
              { type: "card", look: "flat-bordered", padding: "md",
                children: { type: "typography", variant: "body", content: "@entity.focusedRow.content" }
              },
              { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                children: [
                  { type: "icon", name: "corner-down-right", size: "xs" },
                  { type: "typography", variant: "label", color: "muted", content: "Quoted replies" }
                ]
              },
              { type: "data-list", entity: "@entity.focusedRow.replies", gap: "sm", variant: "default",
                fields: [],
                renderItem: ["fn", "reply", {
                  type: "card", look: "flat-bordered", padding: "md",
                  className: "border-l-4 border-l-[var(--color-primary)] ml-card-md",
                  children: {
                    type: "stack", direction: "vertical", gap: "sm",
                    children: [
                      { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                        children: [
                          { type: "avatar", name: "@reply.authorName", size: "xs" },
                          { type: "typography", variant: "body2", weight: "medium", content: "@reply.authorName" },
                          { type: "typography", variant: "caption", color: "muted", content: "@reply.fromAddress" },
                          { type: "typography", variant: "caption", color: "muted", content: "·" },
                          { type: "typography", variant: "caption", color: "muted", content: "@reply.createdAt" }
                        ]
                      },
                      { type: "typography", variant: "body", content: "@reply.content" }
                    ]
                  }
                }]
              }
            ]
          }
        ]
      }
    }
  }

  page "/email-thread" as EmailThreadedPage -> EmailThreaded
}
