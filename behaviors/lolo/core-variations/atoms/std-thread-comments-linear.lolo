app std-thread-comments-linear "1.1.0"
"Nested threaded comments — Disqus/Hacker News style: indented reply tree, inline reply composer on every comment card, and a visible replies group per parent. For forum discussions, blog comments, document review threads, project-manager issue comments."

orbital CommentsLinearOrbital {
  uses Thread from "std/behaviors/std-thread"

  entity CommentsLinearPost [persistent: commentslinearposts] {
    id            : string!
    parentId      : string
    threadRootId  : string!
    authorId      : string!
    authorName    : string!
    content       : string!
    createdAt     : string
    voteCount     : number = 0
    replyCount    : number = 0
    replies       : [CommentsLinearPost]
  }

  trait CommentsLinear = Thread.traits.ThreadPostBrowse -> CommentsLinearPost {
    config: {
      bodyContent: {
        type: "stack",
        direction: "vertical",
        gap: "lg",
        className: "max-w-3xl mx-auto px-card-md py-section",
        children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center",
            children: [
              { type: "icon", name: "message-square", size: "md" },
              { type: "typography", variant: "h3", content: "Discussion" }
            ]
          },
          { type: "card", look: "flat-bordered", padding: "md",
            children: {
              type: "stack", direction: "vertical", gap: "sm",
              children: [
                { type: "typography", variant: "label", content: "Add a comment" },
                { type: "input", inputType: "textarea", rows: 3, placeholder: "Share your thoughts…", action: "EDIT_REPLY" },
                { type: "stack", direction: "horizontal", gap: "sm", justify: "end",
                  children: [
                    { type: "button", label: "Cancel", action: "CANCEL_REPLY", variant: "ghost", size: "sm" },
                    { type: "button", label: "Comment", icon: "send", action: "SUBMIT_REPLY", variant: "primary", size: "sm" }
                  ]
                }
              ]
            }
          },
          { type: "data-list", entity: "@payload.data", gap: "md", variant: "default",
            fields: [],
            renderItem: ["fn", "item", {
              type: "card", look: "flat-bordered", padding: "md",
              children: {
                type: "stack", direction: "vertical", gap: "sm",
                children: [
                  { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                    children: [
                      { type: "avatar", name: "@item.authorName", size: "sm" },
                      { type: "typography", variant: "body", weight: "medium", content: "@item.authorName" },
                      { type: "typography", variant: "caption", color: "muted", content: "·" },
                      { type: "typography", variant: "caption", color: "muted", content: "@item.createdAt" }
                    ]
                  },
                  { type: "typography", variant: "body", content: "@item.content" },
                  { type: "stack", direction: "horizontal", gap: "xs", align: "center",
                    children: [
                      { type: "button", label: "Reply", icon: "corner-down-right", action: "REPLY", actionPayload: { parentId: "@item.id" }, variant: "ghost", size: "sm" }
                    ]
                  },
                  { type: "stack", direction: "vertical", gap: "sm",
                    className: "pl-card-md border-l border-[var(--color-border)]",
                    children: [
                      { type: "stack", direction: "horizontal", gap: "xs", align: "center",
                        children: [
                          { type: "icon", name: "chevron-down", size: "xs" },
                          { type: "typography", variant: "caption", weight: "medium", color: "muted", content: "@item.replyCount replies" }
                        ]
                      },
                      { type: "data-list", entity: "@item.replies", gap: "sm", variant: "default",
                        fields: [],
                        renderItem: ["fn", "reply", {
                          type: "card", look: "borderless-divider", padding: "sm",
                          children: {
                            type: "stack", direction: "vertical", gap: "xs",
                            children: [
                              { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                                children: [
                                  { type: "avatar", name: "@reply.authorName", size: "xs" },
                                  { type: "typography", variant: "caption", weight: "medium", content: "@reply.authorName" },
                                  { type: "typography", variant: "caption", color: "muted", content: "·" },
                                  { type: "typography", variant: "caption", color: "muted", content: "@reply.createdAt" }
                                ]
                              },
                              { type: "typography", variant: "body", content: "@reply.content" },
                              { type: "stack", direction: "horizontal", gap: "xs", align: "center",
                                children: [
                                  { type: "button", label: "Reply", icon: "corner-down-right", action: "REPLY", actionPayload: { parentId: "@reply.id" }, variant: "ghost", size: "sm" }
                                ]
                              }
                            ]
                          }
                        }]
                      },
                      { type: "stack", direction: "horizontal", gap: "sm", align: "center",
                        children: [
                          { type: "input", inputType: "text", placeholder: "Write a reply…", action: "EDIT_REPLY" },
                          { type: "button", label: "Send", icon: "send", action: "SUBMIT_REPLY", actionPayload: { parentId: "@item.id" }, variant: "primary", size: "sm" }
                        ]
                      }
                    ]
                  }
                ]
              }
            }]
          }
        ]
      }
    }
  }

  page "/comments-thread" as CommentsLinearPage -> CommentsLinear
}
