app std-app-layout-topnav "1.0.0"
"Top-navigation chrome. Embeds std-app-layout with topnav layout pattern."
orbital TopnavLayoutOrbital {
  uses AppLayout from "std/behaviors/std-app-layout"

  entity TopnavLayoutData [runtime] {
    id : string!
  }

  trait TopnavLayout = AppLayout.traits.AppLayout -> TopnavLayoutData {
    config {
      layoutMode: topnav
      appName: "Topnav Demo"
      navItems: [{
        href: "/"
        icon: home
        label: Home
      }, {
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/settings"
        icon: settings
        label: Settings
      }]
    }
  }

  page "/topnav-layout" as TopnavLayoutPage -> TopnavLayout
}