app std-detail-drawer "1.0.0"
"Drawer detail view. Embeds std-modal with drawer slot override."
orbital DetailDrawerOrbital {
  uses Modal from "std/behaviors/std-modal"

  entity DetailDrawerRecord [runtime] {
    id : string
    name : string @description "A user-facing identifier or title for the record." @synonyms "title, label, identifier"
    description : string @description "A textual explanation or summary of the item." @synonyms "summary, explanation, details, notes"
    status : string @description "Current state or condition of the item." @synonyms "condition, state, condition, flag"
  }

  trait DetailDrawerModal = Modal.traits.ModalRecordModal -> DetailDrawerRecord {
    config {
      detailSlot: drawer
    }
  }

  page "/detail-drawer" as DetailDrawerPage -> DetailDrawerModal
}