app std-stats-sparkline-row "1.0.0"
"Sparkline tile grid — chart-first card tiles where the mini trend line is the visual centerpiece, with label above and value+delta footer. For trend-led overviews: telemetry, weekly active users, traffic shape, observability at a glance."

orbital SparklineRowStatsOrbital {
  uses Stats from "std/behaviors/std-stats"

  type StatCard = {
    label          : string!
    value          : number
    icon           : string
    format         : "number" | "currency" | "percent"
    variant        : "default" | "primary" | "success" | "warning" | "error" | "info"
    prefix         : string
    suffix         : string
    max            : number
    target         : number
    trend          : number
    trendPolarity  : "higher-is-better" | "lower-is-better"
    trendFormat    : "absolute" | "percent"
    sparklineData  : [number]
    clickEvent     : string
  }

  entity SparklineRowStats [runtime] {
    id    : string!
    cards : [StatCard] = []
  }

  trait SparklineRowStatsItemStats = Stats.traits.StatsItemStats -> SparklineRowStats {
    config: {
      bodyContent: {
        type: "simple-grid",
        cols: 2,
        gap: "md",
        className: "w-full",
        children: [{
          type: "data-list",
          entity: "@entity.cards",
          gap: "md",
          fields: [],
          renderItem: ["fn", "card", {
            type: "stack",
            direction: "vertical",
            gap: "sm",
            className: "rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] p-card-md shadow-elevation-sm hover:shadow-elevation-md transition-shadow min-h-[180px]",
            children: [
              { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [
                { type: "icon", name: "@card.icon", size: "xs", color: "muted" },
                { type: "typography", variant: "overline", color: "muted", weight: "semibold", content: "@card.label", className: "uppercase tracking-wide truncate" }
              ]},
              { type: "sparkline", data: [1, 2, 3, 4, 5, 6, 7], color: "auto", height: 64, strokeWidth: 2, fill: true, className: "w-full" },
              { type: "stack", direction: "horizontal", gap: "sm", align: "baseline", justify: "between", children: [
                { type: "stack", direction: "horizontal", gap: "xs", align: "baseline", children: [
                  { type: "typography", variant: "caption", color: "muted", content: "@card.prefix" },
                  { type: "typography", variant: "h3", weight: "semibold", content: "@card.value", className: "tabular-nums" },
                  { type: "typography", variant: "caption", color: "muted", content: "@card.suffix" }
                ]},
                { type: "trend-indicator", value: "@card.trend", size: "sm", showValue: true }
              ]}
            ]
          }]
        }]
      }
    }
  }

  page "/sparkline-row" as SparklineRowStatsPage -> SparklineRowStatsItemStats
}
