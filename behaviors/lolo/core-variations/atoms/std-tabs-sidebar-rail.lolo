app std-tabs-sidebar-rail "1.0.0"
"Sidebar-rail tabs — vertical nav rail on the left listing tab items as a Stack with the active one highlighted; the matching @trait.X content trait renders to the right. Ideal for app-shell side nav, settings pages with many sections, and profile pages. Same TabsItemTabs trait, state machine, emits/listens as std-tabs — only the bodyContent tree differs."
type TabSpec = { id : string, label : string!, value : string, icon : string }
orbital SidebarRailTabsOrbital {
  uses Tabs from "std/behaviors/std-tabs"

  entity SidebarRailTabsItem [runtime] {
    id : string!
    activeTab : string @description "Identifies the currently selected tab." @synonyms "selected, current, highlighted" = ""
    items : [TabSpec] @description "A collection of tab specifications." @synonyms "tabs, list, entries, data" = []
  }

  trait SidebarRailTabs = Tabs.traits.TabsItemTabs -> SidebarRailTabsItem {
    config {
      bodyContent: {
        align: stretch
        children: [{
          align: stretch
          children: [{
            activeTab: @entity.activeTab
            className: "px-2 gap-1"
            items: [{
              icon: home
              id: tab1
              label: "Tab 1"
            }, {
              icon: settings
              id: tab2
              label: "Tab 2"
            }, {
              icon: user
              id: tab3
              label: "Tab 3"
            }]
            orientation: vertical
            tabChangeEvent: TAB_CHANGED
            type: tabs
            variant: pills
          }]
          className: "w-56 shrink-0 border-r bg-muted/30 py-3"
          direction: vertical
          gap: none
          type: stack
        }, {
          children: []
          className: "flex-1 min-w-0 p-card-md"
          direction: vertical
          gap: md
          type: stack
        }]
        className: "min-h-[24rem] border rounded-md overflow-hidden"
        direction: horizontal
        gap: none
        type: stack
      }
    }
  }

  page "/sidebar-tabs" as SidebarRailTabsPage -> SidebarRailTabs
}