app std-app-layout-bottomnav "1.0.0"
"Bottom-navigation chrome. Embeds std-app-layout with bottomnav layout pattern."
orbital BottomnavLayoutOrbital {
  uses AppLayout from "std/behaviors/std-app-layout"

  entity BottomnavLayoutData [runtime] {
    id : string!
  }

  trait BottomnavLayout = AppLayout.traits.AppLayout -> BottomnavLayoutData {
    config {
      layoutMode: bottomnav
      appName: "Bottomnav Demo"
      navItems: [{
        href: "/"
        icon: home
        label: Home
      }, {
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/settings"
        icon: settings
        label: Settings
      }]
    }
  }

  page "/bottomnav-layout" as BottomnavLayoutPage -> BottomnavLayout
}