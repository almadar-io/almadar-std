app std-stats-hero-metric "1.0.0"
"Hero metric — single dominant splash with one massive centered number, descriptive label below, and contextual badges flanking it (target, change, period). For executive landing pages, accounting / finance hero KPI, headline revenue, single-number focus dashboards. Renders the first card from the metrics aggregation as the hero; remaining cards (if any) become small context chips below. Same StatsItemStats trait, same aggregation pipeline, same listens as std-stats — only the bodyContent tree differs."

orbital HeroMetricStatsOrbital {
  uses Stats from "std/behaviors/std-stats"

  type StatCard = {
    label          : string!
    value          : number
    icon           : string
    format         : "number" | "currency" | "percent"
    variant        : "default" | "primary" | "success" | "warning" | "error" | "info"
    prefix         : string
    suffix         : string
    max            : number
    target         : number
    trend          : number
    trendPolarity  : "higher-is-better" | "lower-is-better"
    trendFormat    : "absolute" | "percent"
    sparklineData  : [number]
    clickEvent     : string
  }

  entity HeroMetricStats [runtime] {
    id    : string!
    cards : [StatCard] = []
  }

  trait HeroMetricStatsItemStats = Stats.traits.StatsItemStats -> HeroMetricStats {
    config: {
      bodyContent: {
        type: "center",
        horizontal: true,
        vertical: true,
        fullWidth: true,
        className: "py-section",
        children: [{
          type: "stack",
          direction: "vertical",
          gap: "lg",
          align: "center",
          className: "max-w-3xl mx-auto px-card-lg text-center",
          children: [
            { type: "data-list", entity: "@entity.cards", gap: "lg", fields: [],
              renderItem: ["fn", "card", {
                type: "stack",
                direction: "vertical",
                gap: "md",
                align: "center",
                className: "w-full",
                children: [
                  { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "center", children: [
                    { type: "icon", name: "@card.icon", size: "md", color: "muted" },
                    { type: "typography", variant: "overline", color: "muted", weight: "semibold", content: "@card.label", className: "uppercase tracking-widest" }
                  ]},
                  { type: "stack", direction: "horizontal", gap: "sm", align: "baseline", justify: "center", children: [
                    { type: "typography", variant: "h2", color: "muted", weight: "normal", content: "@card.prefix" },
                    { type: "animated-counter", value: "@card.value", className: "text-7xl font-bold tracking-tight tabular-nums" },
                    { type: "typography", variant: "h2", color: "muted", weight: "normal", content: "@card.suffix" }
                  ]},
                  { type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "center", wrap: true, children: [
                    { type: "trend-indicator", value: "@card.trend", size: "md", showValue: true },
                    { type: "badge", label: "@card.variant", variant: "@card.variant", size: "md" }
                  ]},
                  { type: "sparkline", data: [1, 2, 3, 4, 5, 6, 7], color: "auto", height: 48, strokeWidth: 2, fill: true, className: "w-full max-w-md" }
                ]
              }]
            }
          ]
        }]
      }
    }
  }

  page "/hero-metric" as HeroMetricStatsPage -> HeroMetricStatsItemStats
}
