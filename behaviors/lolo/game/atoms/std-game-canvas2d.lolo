app std-game-canvas2d "1.0.0"
"std-game-canvas2d as a Function"

orbital GameCanvas2dOrbital {
  entity GameCanvas2d [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type GameCanvas2dLoaded     = Event GameCanvas2d                  "Fired when GameCanvas2d finishes loading"
  type GameCanvas2dLoadFailed = Event { message : string } "Fired when GameCanvas2d fails to load"
  trait GameCanvas2dGameCanvas2d -> GameCanvas2d [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch GameCanvas2d { emit: { success: "GameCanvas2dLoaded", failure: "GameCanvas2dLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "monitor" }, { type: "typography", content: "GameCanvas2d Canvas", variant: "h3" }] }, { type: "typography", content: "800x600 @ 60fps", variant: "caption", color: "muted" }, { type: "game-canvas-2d", width: 800, height: 600, fps: 60 }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
      START -> rendering
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "monitor" }, { type: "typography", content: "GameCanvas2d Canvas", variant: "h3" }] }, { type: "game-canvas-2d", width: 800, height: 600, fps: 60 }, { type: "button", label: "Stop", action: "STOP", variant: "ghost", icon: "square" }] })
    }
    state rendering {
      TICK -> rendering
      STOP -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "monitor" }, { type: "typography", content: "GameCanvas2d Canvas", variant: "h3" }] }, { type: "typography", content: "800x600 @ 60fps", variant: "caption", color: "muted" }, { type: "game-canvas-2d", width: 800, height: 600, fps: 60 }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
    }
    emits: [GameCanvas2dLoaded, GameCanvas2dLoadFailed]
    listens {
      GameCanvas2dLoadFailed { message : string }
    }
  }
  page "/gamecanvas2ds" as GameCanvas2dCanvas2dPage -> GameCanvas2dGameCanvas2d
}