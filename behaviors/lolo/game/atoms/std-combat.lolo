app std-combat "1.0.0"
"std-combat as a Function"

orbital CombatantOrbital {
  entity Combatant [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    hp : number = 100
    attack : number = 10
    defense : number = 5
  }

  type CombatantLoaded     = Event Combatant                  "Fired when Combatant finishes loading"
  type CombatantLoadFailed = Event { message : string } "Fired when Combatant fails to load"
  trait CombatantCombat -> Combatant [interaction, instance] {
    initial: ready
    state ready {
      CombatantLoaded -> ready
        (set @entity.id          @payload.id)
        (set @entity.name        @payload.name)
        (set @entity.description @payload.description)
        (set @entity.status      @payload.status)
        (set @entity.createdAt   @payload.createdAt)
        (set @entity.hp          @payload.hp)
        (set @entity.attack      @payload.attack)
        (set @entity.defense     @payload.defense)
      INIT -> ready
        (fetch Combatant { emit: { success: "CombatantLoaded", failure: "CombatantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-hud", position: "top", stats: [{ label: "HP", value: "@entity.hp" }, { label: "Attack", value: "@entity.attack" }, { label: "Defense", value: "@entity.defense" }] }, { type: "button", label: "Attack", action: "ATTACK", variant: "primary", icon: "swords" }] })
      ATTACK -> attacking
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-hud", position: "top", stats: [{ label: "HP", value: "@entity.hp" }, { label: "Attack", value: "@entity.attack" }, { label: "Defense", value: "@entity.defense" }] }, { type: "button", label: "Cooldown End", action: "HIT", variant: "secondary", icon: "clock" }] })
    }
    state attacking {
      HIT -> cooldown
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-hud", position: "top", stats: [{ label: "HP", value: "@entity.hp" }, { label: "Attack", value: "@entity.attack" }, { label: "Defense", value: "@entity.defense" }] }, { type: "badge", label: "Cooling down..." }] })
      DEFEAT -> defeated
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-over-screen", title: "Defeated", variant: "defeat" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
    }
    state cooldown {
      COOLDOWN_END -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-hud", position: "top", stats: [{ label: "HP", value: "@entity.hp" }, { label: "Attack", value: "@entity.attack" }, { label: "Defense", value: "@entity.defense" }] }, { type: "button", label: "Attack", action: "ATTACK", variant: "primary", icon: "swords" }] })
      DEFEAT -> defeated
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-over-screen", title: "Defeated", variant: "defeat" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
    }
    state defeated {
      RESET -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "game-hud", position: "top", stats: [{ label: "HP", value: "@entity.hp" }, { label: "Attack", value: "@entity.attack" }, { label: "Defense", value: "@entity.defense" }] }, { type: "button", label: "Attack", action: "ATTACK", variant: "primary", icon: "swords" }] })
    }
emits {
      CombatantLoaded
      CombatantLoadFailed
    }

        listens {
      ATTACK { targetId : string! }
      HIT { damage : number! }
          CombatantLoadFailed { message : string }
    }
  }
  page "/combatants" as CombatantPage -> CombatantCombat
}