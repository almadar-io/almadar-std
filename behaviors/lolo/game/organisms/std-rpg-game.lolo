app std-rpg-game "1.0.0"
"RPG game: battles, world zones, items, and missions. Pick for turn-based RPGs."

orbital BattleStateOrbital {
  entity BattleState [runtime] {
    id : string!
    turn : number = 0
    score : number = 0
    phase : string = "setup"
    outcome : string
  }

  type BattleStateLoaded     = Event { data : [BattleState] }                  "Fired when BattleState finishes loading"
  type BattleStateLoadFailed = Event { error : string, code : string } "Fired when BattleState fails to load"
  type RpgItemSaved = Event { id : string }
  type RpgItemSaveFailed = Event { error : string, code : string }
  type RpgItemUpdated = Event { id : string }
  type RpgItemUpdateFailed = Event { error : string, code : string }
  type RpgItemDeleted = Event { id : string }
  type RpgItemDeleteFailed = Event { error : string, code : string }
  type MissionUpdated = Event { id : string }
  type MissionUpdateFailed = Event { error : string, code : string }
  trait BattleStateBattleFlow -> BattleState [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch BattleState { emit: { success: "BattleStateLoaded", failure: "BattleStateLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-menu", title: "Battle Arena", subtitle: "Turn-Based Strategy", menuItems: [{ label: "Start Battle", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      NAVIGATE -> menu
    }
    state playing {
      END_TURN -> playing
        (set @entity.turn (+ @entity.turn 1))
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      PAUSE -> paused
        (render-ui modal { type: "game-menu", title: "Paused", menuItems: [{ label: "Resume", event: "RESUME", variant: "primary" }, { label: "Quit", event: "RESTART", variant: "ghost" }] })
      GAME_OVER -> gameover
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-over-screen", title: "Battle Over", stats: [{ label: "Turns", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }], menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }, { label: "Main Menu", event: "RESTART", variant: "secondary" }] }] })
    }
    state paused {
      NAVIGATE -> paused
      RESUME -> playing
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      CLOSE -> playing
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      RESTART -> menu
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-menu", title: "Battle Arena", subtitle: "Turn-Based Strategy", menuItems: [{ label: "Start Battle", event: "START", variant: "primary" }] }] })
    }
    state gameover {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-menu", title: "Battle Arena", subtitle: "Turn-Based Strategy", menuItems: [{ label: "Start Battle", event: "START", variant: "primary" }] }] })
    }
    emits {
      LOOT_DROPPED -> external { itemId: string }
      BattleStateLoaded
      BattleStateLoadFailed
      RpgItemSaved
      RpgItemSaveFailed
      RpgItemUpdated
      RpgItemUpdateFailed
      RpgItemDeleted
      RpgItemDeleteFailed
      MissionUpdated
      MissionUpdateFailed
    }
    listens {
      WorldZoneOrbital.WorldZoneNavigation.ENCOUNTER_STARTED -> START
          BattleStateLoadFailed { error : string, code : string }
    
      RpgItemSaveFailed { error : string, code : string }
      RpgItemUpdateFailed { error : string, code : string }
      RpgItemDeleteFailed { error : string, code : string }
      MissionUpdateFailed { error : string, code : string }
    }
  }
  trait BattleStateCombatLog -> BattleState [interaction, collection] {
    state idle {
      INIT -> idle
        (fetch BattleState { emit: { success: "BattleStateLoaded", failure: "BattleStateLoadFailed" } })
      LOG_EVENT -> idle
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "combat-log", events: "@BattleState", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" }] })
      CLEAR -> idle
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "combat-log", events: "@BattleState", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" }] })
    }
emits {
      BattleStateLoaded
      BattleStateLoadFailed
    }

        listens {
      LOG_EVENT { data : object! }
          BattleStateLoadFailed { error : string, code : string }
    }
  }
  page "/battle" as BattlePage -> BattleStateBattleFlow, BattleStateCombatLog
}
orbital WorldZoneOrbital {
  entity WorldZone [runtime] {
    id : string!
    name : string!
    description : string
    level : number
    explored : boolean
  }

  type WorldZoneLoaded     = Event { data : [WorldZone] }                  "Fired when WorldZone finishes loading"
  type WorldZoneLoadFailed = Event { error : string, code : string } "Fired when WorldZone fails to load"
  trait WorldZoneNavigation -> WorldZone [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch WorldZone { emit: { success: "WorldZoneLoaded", failure: "WorldZoneLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading map…" }] })
      WorldZoneLoaded -> exploring
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "map" }, { type: "typography", content: "World Map", variant: "h2" }] }, { type: "status-dot", status: "online", pulse: false, label: "Exploring" }] }, { type: "divider" }, { type: "map-view", markers: [], height: "200px", zoom: 10 }, { type: "data-grid", entity: @payload.data, fields: [], itemActions: [{ label: "Travel", event: "TRAVEL" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", variant: "h4", content: "@item.name" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.level" }] }] }] }] })
      WorldZoneLoadFailed -> loading
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load map" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state exploring {
      TRAVEL -> transitioning
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "loader" }, { type: "typography", content: "Traveling...", variant: "h2" }] }, { type: "divider" }, { type: "typography", content: "Traveling to the destination worldzone.", variant: "body" }] }] })
    }
    state transitioning {
      ARRIVE -> loading
        (fetch WorldZone { emit: { success: "WorldZoneLoaded", failure: "WorldZoneLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      ENCOUNTER_STARTED -> external { zoneId: string }
      QUEST_ACCEPTED -> external { questId: string }
      WorldZoneLoaded
      WorldZoneLoadFailed
    }
    listens {
      WorldZoneLoadFailed { error : string, code : string }
    }
  }
  page "/world" -> WorldZoneNavigation
}
orbital RpgItemOrbital {
  entity RpgItem [persistent: rpgitems] {
    id : string!
    name : string!
    type : string!
    quantity : number
    rarity : string
    pendingId : string
  }

  type RpgItemLoaded     = Event { data : [RpgItem] }                  "Fired when RpgItem finishes loading"
  type RpgItemLoadFailed = Event { error : string, code : string } "Fired when RpgItem fails to load"
  type RpgItemDeleteFailed = Event { error : string, code : string }
  type RpgItemDeleted = Event { id : string }
  type RpgItemSaveFailed = Event { error : string, code : string }
  type RpgItemSaved = Event { id : string }
  type RpgItemUpdateFailed = Event { error : string, code : string }
  type RpgItemUpdated = Event { id : string }
  trait RpgItemBrowse -> RpgItem [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      RpgItemLoaded -> browsing
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "briefcase" }, { type: "typography", content: "Inventory", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Add RpgItem", action: "ADD_ITEM", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Use", event: "USE_ITEM", variant: "ghost" }, { label: "Drop", event: "DROP", variant: "danger" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "briefcase" }, { name: "type", label: "Type", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "quantity", label: "Quantity", variant: "caption" }] }] }] })
      RpgItemLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load rpgitem" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      ADD_ITEM
      USE_ITEM { id : string!, row : RpgItem }
      DROP { id : string!, row : RpgItem }
      RpgItemLoaded
      RpgItemLoadFailed
    }
    listens {
      RpgItemAdd.ITEM_ADDED -> INIT
      RpgItemUse.ITEM_USED -> INIT
      RpgItemDrop.CONFIRM_DROP -> INIT
      BattleStateOrbital.BattleStateBattleFlow.LOOT_DROPPED -> INIT
          RpgItemLoadFailed { error : string, code : string }
    }
  }
  trait RpgItemAdd -> RpgItem [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
      ADD_ITEM -> open
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Add RpgItem", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "type", "quantity", "rarity"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create RpgItem @payload.data { emit: { success: "RpgItemSaved", failure: "RpgItemSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ITEM_ADDED)
    }
    emits {
      ITEM_ADDED
      RpgItemLoadFailed
      RpgItemLoaded
      RpgItemSaveFailed
      RpgItemSaved
    }
    listens {
      RpgItemLoadFailed { error : string, code : string }
      SAVE { data : string }
      RpgItemBrowse.ADD_ITEM -> ADD_ITEM
    }
  }
  trait RpgItemUse -> RpgItem [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
      USE_ITEM -> open
        (fetch RpgItem {id: "@payload.id" , emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" }, emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "zap" }, { type: "typography", content: "Use RpgItem", variant: "h3" }] }, { type: "divider" }, { type: "typography", content: "@entity.name", variant: "body" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Cancel", action: "CLOSE", variant: "ghost" }, { type: "button", label: "Confirm Use", action: "SAVE", variant: "primary", icon: "check" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update RpgItem @payload.data { emit: { success: "RpgItemUpdated", failure: "RpgItemUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ITEM_USED)
    }
    emits {
      ITEM_USED
      RpgItemLoadFailed
      RpgItemLoaded
      RpgItemUpdateFailed
      RpgItemUpdated
    }
    listens {
      RpgItemLoadFailed { error : string, code : string }
      USE_ITEM { id : string }
      SAVE { data : string }
      RpgItemBrowse.USE_ITEM -> USE_ITEM
    }
  }
  trait RpgItemDrop -> RpgItem [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
      DROP -> confirming
        (set @entity.pendingId @payload.id)
        (fetch RpgItem {id: "@payload.id" , emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" }, emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Drop RpgItem", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Are you sure you want to drop this rpgitem?" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Drop", action: "CONFIRM_DROP", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DROP -> idle
        (persist delete RpgItem @entity.pendingId { emit: { success: "RpgItemDeleted", failure: "RpgItemDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
    }
    emits {
      CONFIRM_DROP
      RpgItemDeleteFailed
      RpgItemDeleted
      RpgItemLoadFailed
      RpgItemLoaded
    }
    listens {
      RpgItemLoadFailed { error : string, code : string }
      DROP { id : string }
      RpgItemBrowse.DROP -> DROP
    }
  }
  page "/inventory" -> RpgItemBrowse, RpgItemAdd, RpgItemUse, RpgItemDrop
}
orbital MissionOrbital {
  entity Mission [runtime] {
    id : string!
    title : string!
    description : string
    status : string
    reward : string
  }

  type MissionLoaded     = Event { data : [Mission] }                  "Fired when Mission finishes loading"
  type MissionLoadFailed = Event { error : string, code : string } "Fired when Mission fails to load"
  type MissionUpdateFailed = Event { error : string, code : string }
  type MissionUpdated = Event { id : string }
  trait MissionTracking -> Mission [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading missions…" }] })
      MissionLoaded -> available
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], groupBy: "status", itemActions: [{ label: "Accept", event: "ACCEPT" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
      MissionLoadFailed -> loading
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load missions" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state available {
      ACCEPT -> active
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "typography", content: "Quest Active", variant: "h2" }, { type: "progress-bar", value: 50, showPercentage: true }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Progress", action: "PROGRESS", variant: "primary" }, { type: "button", label: "Complete", action: "COMPLETE", variant: "success" }, { type: "button", label: "Fail", action: "FAIL", variant: "danger" }] }] }] })
    }
    state active {
      PROGRESS -> progressing
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "trending-up" }, { type: "typography", content: "Update Progress", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SAVE", cancelEvent: "CANCEL", fields: ["title", "description", "status", "reward"] }] })
      COMPLETE -> complete
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Quest Complete", variant: "h2" }, { type: "alert", variant: "success", message: "Congratulations! The quest has been completed." }, { type: "button", label: "View Quests", action: "RESET", variant: "primary", icon: "arrow-left" }] }] })
      FAIL -> failed
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle" }, { type: "typography", content: "Quest Failed", variant: "h2" }, { type: "alert", variant: "error", message: "The quest was not completed. You can try again." }, { type: "button", label: "View Quests", action: "RESET", variant: "primary", icon: "arrow-left" }] }] })
    }
    state progressing {
      SAVE -> loading
        (persist update Mission @payload.data { emit: { success: "MissionUpdated", failure: "MissionUpdateFailed" } })
        (render-ui modal null)
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "spinner" })
      CANCEL -> loading
        (render-ui modal null)
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "spinner" })
      CLOSE -> loading
        (render-ui modal null)
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state complete {
      RESET -> loading
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state failed {
      RESET -> loading
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
emits {
      MissionLoadFailed
      MissionLoaded
      MissionUpdateFailed
      MissionUpdated
    }

        listens {
      WorldZoneOrbital.WorldZoneNavigation.QUEST_ACCEPTED -> INIT
      MissionLoadFailed { error : string, code : string }
      SAVE { data : Mission }
    }
  }
  page "/quests" -> MissionTracking
}
