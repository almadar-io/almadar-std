app std-platformer-app "1.0.0"
"std-platformer-app as a Function"

orbital PlatLevelOrbital {
  entity PlatLevel [runtime] {
    id : string!
    level : number = 1
    score : number = 0
    lives : number = 3
    time : number = 0
    player : string = ""
    platforms : string = ""
  }

  type PlatLevelLoaded     = Event { data : [PlatLevel] }                  "Fired when PlatLevel finishes loading"
  type PlatLevelLoadFailed = Event { error : string, code : string } "Fired when PlatLevel fails to load"
  type CollectibleSaved = Event { id : string }
  type CollectibleSaveFailed = Event { error : string, code : string }
  type CollectibleUpdated = Event { id : string }
  type CollectibleUpdateFailed = Event { error : string, code : string }
  type CollectibleDeleted = Event { id : string }
  type CollectibleDeleteFailed = Event { error : string, code : string }
  trait PlatLevelPlatformerFlow -> PlatLevel [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch PlatLevel { emit: { success: "PlatLevelLoaded", failure: "PlatLevelLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "game-menu", title: "Platformer", subtitle: "Side-Scrolling Adventure", menuItems: [{ label: "Start Game", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "platformer-canvas", canvasWidth: 800, canvasHeight: 400, worldWidth: 2400, worldHeight: 400, followCamera: true, bgColor: "#1a1a2e", leftEvent: "LEFT", rightEvent: "RIGHT", jumpEvent: "JUMP", stopEvent: "STOP" }] })
      NAVIGATE -> menu
    }
    state playing {
      LEFT -> playing
      RIGHT -> playing
      JUMP -> playing
      STOP -> playing
      PAUSE -> paused
        (render-ui modal { type: "game-menu", title: "Paused", menuItems: [{ label: "Resume", event: "RESUME", variant: "primary" }, { label: "Quit", event: "RESTART", variant: "ghost" }] })
      GAME_OVER -> gameover
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "game-over-screen", title: "Game Over", stats: [{ label: "Score", value: "@entity.score" }, { label: "Lives", value: "@entity.lives" }], menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }, { label: "Main Menu", event: "RESTART", variant: "secondary" }] }] })
    }
    state paused {
      NAVIGATE -> paused
      RESUME -> playing
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "platformer-canvas", canvasWidth: 800, canvasHeight: 400, worldWidth: 2400, worldHeight: 400, followCamera: true, bgColor: "#1a1a2e", leftEvent: "LEFT", rightEvent: "RIGHT", jumpEvent: "JUMP", stopEvent: "STOP" }] })
      CLOSE -> playing
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "platformer-canvas", canvasWidth: 800, canvasHeight: 400, worldWidth: 2400, worldHeight: 400, followCamera: true, bgColor: "#1a1a2e", leftEvent: "LEFT", rightEvent: "RIGHT", jumpEvent: "JUMP", stopEvent: "STOP" }] })
      RESTART -> menu
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "game-menu", title: "Platformer", subtitle: "Side-Scrolling Adventure", menuItems: [{ label: "Start Game", event: "START", variant: "primary" }] }] })
    }
    state gameover {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "game-menu", title: "Platformer", subtitle: "Side-Scrolling Adventure", menuItems: [{ label: "Start Game", event: "START", variant: "primary" }] }] })
    }
    emits: [PlatLevelLoaded, PlatLevelLoadFailed, CollectibleSaved, CollectibleSaveFailed, CollectibleUpdated, CollectibleUpdateFailed, CollectibleDeleted, CollectibleDeleteFailed]
    listens {
      PlatLevelLoadFailed { error : string, code : string }
    
      CollectibleSaveFailed { error : string, code : string }
      CollectibleUpdateFailed { error : string, code : string }
      CollectibleDeleteFailed { error : string, code : string }
    }
  }
  trait PlatLevelPlatformerCanvas -> PlatLevel [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch PlatLevel { emit: { success: "PlatLevelLoaded", failure: "PlatLevelLoadFailed" } })
      START -> running
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "platformer-canvas", platforms: "@entity.platforms", player: "@entity.player", canvasWidth: 800, canvasHeight: 400, worldWidth: 2400, worldHeight: 400, followCamera: true, bgColor: "#1a1a2e", leftEvent: "LEFT", rightEvent: "RIGHT", jumpEvent: "JUMP", stopEvent: "STOP" }] })
    }
    state running {
      LEFT -> running
      RIGHT -> running
      JUMP -> running
      STOP -> idle
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "platformer-canvas", platforms: "@entity.platforms", player: "@entity.player", canvasWidth: 800, canvasHeight: 400, worldWidth: 2400, worldHeight: 400, followCamera: true, bgColor: "#1a1a2e", leftEvent: "LEFT", rightEvent: "RIGHT", jumpEvent: "JUMP", stopEvent: "STOP" }] })
    }
    emits: [PlatLevelLoaded, PlatLevelLoadFailed]
    listens {
      PlatLevelLoadFailed { error : string, code : string }
    }
  }
  page "/game" as GamePage -> PlatLevelPlatformerFlow, PlatLevelPlatformerCanvas
}
orbital PlatScoreOrbital {
  entity PlatScore [runtime] {
    id : string!
    playerName : string!
    score : number! = 0
    level : number = 1
    completedAt : string
    highScore : number
    combo : number
    multiplier : number
  }

  type PlatScoreLoaded     = Event { data : [PlatScore] }                  "Fired when PlatScore finishes loading"
  type PlatScoreLoadFailed = Event { error : string, code : string } "Fired when PlatScore fails to load"
  trait PlatScoreScoreBoard -> PlatScore [interaction, collection] {
    state idle {
      INIT -> idle
        (fetch PlatScore { emit: { success: "PlatScoreLoaded", failure: "PlatScoreLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "score-board", score: "@entity.score", highScore: "@entity.highScore", combo: "@entity.combo", multiplier: "@entity.multiplier", level: "@entity.level" }] })
      ADD_SCORE -> idle
        (set @entity.score (+ @entity.score @payload.points))
        (set @entity.combo (+ @entity.combo 1))
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "score-board", score: "@entity.score", highScore: "@entity.highScore", combo: "@entity.combo", multiplier: "@entity.multiplier", level: "@entity.level" }] })
      COMBO -> idle
        (set @entity.multiplier @payload.multiplier)
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "score-board", score: "@entity.score", highScore: "@entity.highScore", combo: "@entity.combo", multiplier: "@entity.multiplier", level: "@entity.level" }] })
      RESET -> idle
        (set @entity.score 0)
        (set @entity.combo 0)
        (set @entity.multiplier 1)
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "score-board", score: "@entity.score", highScore: "@entity.highScore", combo: "@entity.combo", multiplier: "@entity.multiplier", level: "@entity.level" }] })
    }
    emits: [PlatScoreLoaded, PlatScoreLoadFailed]
    listens {
      PlatScoreLoadFailed { error : string, code : string }
      ADD_SCORE { points : string }
      COMBO { multiplier : string }
    }
  }
  page "/scores" -> PlatScoreScoreBoard
}
orbital CollectibleOrbital {
  entity Collectible [persistent: collectibles] {
    id : string!
    name : string!
    type : string!
    quantity : number
    rarity : string
    pendingId : string
  }

  type CollectibleLoaded     = Event { data : [Collectible] }                  "Fired when Collectible finishes loading"
  type CollectibleLoadFailed = Event { error : string, code : string } "Fired when Collectible fails to load"
  type CollectibleDeleteFailed = Event { error : string, code : string }
  type CollectibleDeleted = Event { id : string }
  type CollectibleSaveFailed = Event { error : string, code : string }
  type CollectibleSaved = Event { id : string }
  type CollectibleUpdateFailed = Event { error : string, code : string }
  type CollectibleUpdated = Event { id : string }
  trait CollectibleBrowse -> Collectible [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      CollectibleLoaded -> browsing
        (render-ui main { type: "game-shell", appName: "Platformer App", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "package" }, { type: "typography", content: "Collectibles", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Add Collectible", action: "ADD_ITEM", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Use", event: "USE_ITEM", variant: "ghost" }, { label: "Drop", event: "DROP", variant: "danger" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "package" }, { name: "type", label: "Type", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "quantity", label: "Quantity", variant: "caption" }] }] }] })
      CollectibleLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load collectible" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
      CollectibleAdd ITEM_ADDED -> INIT
      CollectibleUse ITEM_USED -> INIT
      CollectibleDrop CONFIRM_DROP -> INIT
          CollectibleLoadFailed { error : string, code : string }
    }
    emits: [CollectibleLoaded, CollectibleLoadFailed]
  }
  trait CollectibleAdd -> Collectible [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
      ADD_ITEM -> open
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Add Collectible", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "type", "quantity", "rarity"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Collectible @payload.data { emit: { success: "CollectibleSaved", failure: "CollectibleSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ITEM_ADDED)
    }
    emits {
      ITEM_ADDED
    }
    emits: [CollectibleLoadFailed, CollectibleLoaded, CollectibleSaveFailed, CollectibleSaved]
    listens {
      CollectibleLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait CollectibleUse -> Collectible [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
      USE_ITEM -> open
        (fetch Collectible {id: "@payload.id" , emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" }, emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "zap" }, { type: "typography", content: "Use Collectible", variant: "h3" }] }, { type: "divider" }, { type: "typography", content: "@entity.name", variant: "body" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Cancel", action: "CLOSE", variant: "ghost" }, { type: "button", label: "Confirm Use", action: "SAVE", variant: "primary", icon: "check" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Collectible @payload.data { emit: { success: "CollectibleUpdated", failure: "CollectibleUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ITEM_USED)
    }
    emits {
      ITEM_USED
    }
    emits: [CollectibleLoadFailed, CollectibleLoaded, CollectibleUpdateFailed, CollectibleUpdated]
    listens {
      CollectibleLoadFailed { error : string, code : string }
      USE_ITEM { id : string }
      SAVE { data : string }
    }
  }
  trait CollectibleDrop -> Collectible [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
      DROP -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Collectible {id: "@payload.id" , emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" }, emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Drop Collectible", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Are you sure you want to drop this collectible?" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Drop", action: "CONFIRM_DROP", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DROP -> idle
        (persist delete Collectible @entity.pendingId { emit: { success: "CollectibleDeleted", failure: "CollectibleDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Collectible { emit: { success: "CollectibleLoaded", failure: "CollectibleLoadFailed" } })
    }
    emits {
      CONFIRM_DROP
    }
    emits: [CollectibleDeleteFailed, CollectibleDeleted, CollectibleLoadFailed, CollectibleLoaded]
    listens {
      CollectibleLoadFailed { error : string, code : string }
      DROP { id : string }
    }
  }
  page "/collectibles" -> CollectibleBrowse, CollectibleAdd, CollectibleUse, CollectibleDrop
}
