app std-negotiator-game "1.0.0"
"std-negotiator-game as a Function"

orbital NegotiatorGameOrbital {
  entity NegotiatorGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number = 0
    level : number = 1
  }

  type NegotiatorGameLoaded     = Event NegotiatorGame                  "Fired when NegotiatorGame finishes loading"
  type NegotiatorGameLoadFailed = Event { message : string } "Fired when NegotiatorGame fails to load"
  trait NegotiatorGameNegotiatorGame -> NegotiatorGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch NegotiatorGame { emit: { success: "NegotiatorGameLoaded", failure: "NegotiatorGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Negotiator", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "negotiator-board", entity: "NegotiatorGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Negotiator", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits: [NegotiatorGameLoaded, NegotiatorGameLoadFailed]
    listens {
      NegotiatorGameLoadFailed { message : string }
    }
  }
  page "/negotiatorgames" as NegotiatorGamePage -> NegotiatorGameNegotiatorGame
}