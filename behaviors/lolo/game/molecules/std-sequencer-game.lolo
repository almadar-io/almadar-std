app std-sequencer-game "1.0.0"
"std-sequencer-game as a Function"

orbital SequencerGameOrbital {
  entity SequencerGame [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    score : number = 0
    level : number = 1
  }

  type SequencerGameLoaded     = Event SequencerGame                  "Fired when SequencerGame finishes loading"
  type SequencerGameLoadFailed = Event { message : string } "Fired when SequencerGame fails to load"
  trait SequencerGameSequencerGame -> SequencerGame [interaction, instance] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch SequencerGame { emit: { success: "SequencerGameLoaded", failure: "SequencerGameLoadFailed" } })
        (render-ui main { type: "game-menu", title: "Sequencer", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
      START -> playing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "sequencer-board", entity: "SequencerGame", completeEvent: "COMPLETE" }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-menu", title: "Sequencer", menuItems: [{ label: "Start", event: "START", variant: "primary" }] })
    }
    emits: [SequencerGameLoaded, SequencerGameLoadFailed]
    listens {
      SequencerGameLoadFailed { message : string }
    }
  }
  page "/sequencergames" as SequencerGamePage -> SequencerGameSequencerGame
}