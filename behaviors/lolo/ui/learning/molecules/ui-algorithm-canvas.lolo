app ui-algorithm-canvas "1.0.0"
"AlgorithmCanvas — UI factory (1:1 with the @almadar/ui algorithm-canvas pattern)."
orbital AlgorithmCanvasOrbital {
  type AlgorithmCanvasBarsItem = {
    value : number!
    color : string
    label : string
  }
  type AlgorithmCanvasCellsItem = {
    row : number!
    col : number!
    value : number
    color : string
    label : string
  }
  type AlgorithmCanvasPointersItem = {
    index : number!
    label : string
    color : string
  }
  type AlgorithmCanvasShapesItem = {
    type : "line" | "arrow" | "circle" | "rect" | "polygon" | "path" | "text" | "axis" | "grid"!
    id : string
    x : number
    y : number
    x1 : number
    y1 : number
    x2 : number
    y2 : number
    radius : number
    width : number
    height : number
    points : [AlgorithmCanvasShapesItemPointsItem]
    path : string
    text : string
    label : string
    fontSize : number
    align : "left" | "center" | "right"
    axis : "x" | "y"
    min : number
    max : number
    step : number
    color : string
    fill : string
    lineWidth : number
    opacity : number
  }
  type AlgorithmCanvasShapesItemPointsItem = {
    x : number!
    y : number!
  }
  type AlgorithmCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type AlgorithmCanvasSHAPECLICKPayload = {
    id : string
    type : string
    index : number!
  }

  entity AlgorithmCanvasItem [runtime] {
    id : string!
  }

  trait AlgorithmCanvasRender -> @rebindable AlgorithmCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          backgroundColor: @config.backgroundColor
          bars: @config.bars
          cells: @config.cells
          pointers: @config.pointers
          shapes: @config.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: algorithm-canvas
        })
      UPDATE -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          backgroundColor: @config.backgroundColor
          bars: @payload.bars
          cells: @payload.cells
          pointers: @payload.pointers
          shapes: @payload.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: algorithm-canvas
        })
    }

    emits {
      @config.onShapeClick -> external {
        payload : AlgorithmCanvasSHAPECLICKPayload
      }
        @description "onShapeClick prop"
        @tier "essential"
    }

    listens {
      UPDATE {
        bars : [AlgorithmCanvasBarsItem]
        cells : [AlgorithmCanvasCellsItem]
        pointers : [AlgorithmCanvasPointersItem]
        shapes : [AlgorithmCanvasShapesItem]
      }
        @description "Live scene update; payload carries the current drawable state."
        @synonyms "tick, redraw, animate, frame"
        @tier "domain"
    }

    config {
      className : string
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "height prop"
        @tier "presentation"
      title : string
        @label "Title"
        @description "title prop"
        @tier "presentation"
      backgroundColor : string
        @label "Background Color"
        @description "backgroundColor prop"
        @tier "presentation"
      bars : [AlgorithmCanvasBarsItem] = []
        @label "Bars"
        @description "Sorting/histogram bars; laid out left-to-right, height proportional to value."
        @tier "presentation"
      cells : [AlgorithmCanvasCellsItem] = []
        @label "Cells"
        @description "Grid/array/DP cells; laid out on a row/col lattice sized to the extent."
        @tier "presentation"
      pointers : [AlgorithmCanvasPointersItem] = []
        @label "Pointers"
        @description "Index cursors (i/j/lo/hi/mid); drawn as markers beneath the referenced bar/cell column."
        @tier "presentation"
      shapes : [AlgorithmCanvasShapesItem] = []
        @label "Shapes"
        @description "Extra declarative shapes in canvas pixel coordinates."
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "interactive prop"
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "animate prop"
        @tier "presentation"
      onShapeClick : string = "SHAPE_CLICK"
        @label "On Shape Click"
        @description "onShapeClick prop"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "isLoading prop"
        @tier "presentation"
      error : AlgorithmCanvasError
        @label "Error"
        @description "error prop"
        @tier "presentation"
    }
  }

  page "/algorithm-canvas" as AlgorithmCanvasPage -> AlgorithmCanvasRender
}
