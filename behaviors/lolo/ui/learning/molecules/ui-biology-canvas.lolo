app ui-biology-canvas "1.0.0"
"BiologyCanvas — UI factory (1:1 with the @almadar/ui biology-canvas pattern)."
orbital BiologyCanvasOrbital {
  type BiologyCanvasNodesItem = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    kind : "cell" | "organelle" | "molecule" | "organism"
  }
  type BiologyCanvasEdgesItem = {
    from : string!
    to : string!
    color : string
    label : string
  }
  type BiologyCanvasShapesItem = {
    type : "line" | "arrow" | "circle" | "rect" | "polygon" | "path" | "text" | "axis" | "grid"!
    id : string
    x : number
    y : number
    x1 : number
    y1 : number
    x2 : number
    y2 : number
    radius : number
    width : number
    height : number
    points : [BiologyCanvasShapesItemPointsItem]
    path : string
    text : string
    label : string
    fontSize : number
    align : "left" | "center" | "right"
    axis : "x" | "y"
    min : number
    max : number
    step : number
    color : string
    fill : string
    lineWidth : number
    opacity : number
  }
  type BiologyCanvasShapesItemPointsItem = {
    x : number!
    y : number!
  }
  type BiologyCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type BiologyCanvasSHAPECLICKPayload = {
    id : string
    type : string
    index : number!
  }

  entity BiologyCanvasItem [runtime] {
    id : string!
  }

  trait BiologyCanvasRender -> @rebindable BiologyCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          backgroundColor: @config.backgroundColor
          nodes: @config.nodes
          edges: @config.edges
          shapes: @config.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: biology-canvas
        })
      UPDATE -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          backgroundColor: @config.backgroundColor
          nodes: @payload.nodes
          edges: @payload.edges
          shapes: @payload.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: biology-canvas
        })
    }

    emits {
      SHAPE_CLICK -> external {
        payload : BiologyCanvasSHAPECLICKPayload
      }
        @description "onShapeClick prop"
        @tier "essential"
    }

    listens {
      UPDATE {
        nodes : [BiologyCanvasNodesItem]
        edges : [BiologyCanvasEdgesItem]
        shapes : [BiologyCanvasShapesItem]
      }
        @description "Live scene update; payload carries the current drawable state."
        @synonyms "tick, redraw, animate, frame"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "height prop"
        @tier "presentation"
      title : string = "Title"
        @label "Title"
        @description "title prop"
        @tier "presentation"
      backgroundColor : string = "Background Color"
        @label "Background Color"
        @description "backgroundColor prop"
        @tier "presentation"
      nodes : [BiologyCanvasNodesItem] = [{ id: "Id", x: 1, y: 1, radius: 1, color: "Color", label: "Label", kind: cell }, { id: "Id 2", x: 2, y: 2, radius: 2, color: "Color 2", label: "Label 2", kind: organelle }]
        @label "Nodes"
        @description "nodes prop"
        @tier "presentation"
      edges : [BiologyCanvasEdgesItem] = [{ from: "From", to: "To", color: "Color", label: "Label" }, { from: "From 2", to: "To 2", color: "Color 2", label: "Label 2" }]
        @label "Edges"
        @description "edges prop"
        @tier "presentation"
      shapes : [BiologyCanvasShapesItem] = [{ type: line, id: "Id", x: 1, y: 1, x1: 1, y1: 1, x2: 1, y2: 1, radius: 1, width: 1, height: 1, points: [{ x: 1, y: 1 }, { x: 2, y: 2 }], path: "Path", text: "Text", label: "Label", fontSize: 1, align: left, axis: x, min: 1, max: 1, step: 1, color: "Color", fill: "Fill", lineWidth: 1, opacity: 1 }, { type: arrow, id: "Id 2", x: 2, y: 2, x1: 2, y1: 2, x2: 2, y2: 2, radius: 2, width: 2, height: 2, points: [{ x: 1, y: 1 }, { x: 2, y: 2 }], path: "Path 2", text: "Text 2", label: "Label 2", fontSize: 2, align: center, axis: y, min: 2, max: 2, step: 2, color: "Color 2", fill: "Fill 2", lineWidth: 2, opacity: 2 }]
        @label "Shapes"
        @description "Extra declarative shapes in canvas pixel coordinates."
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "interactive prop"
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "animate prop"
        @tier "presentation"
      onShapeClick : string = "SHAPE_CLICK"
        @label "On Shape Click"
        @description "onShapeClick prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "isLoading prop"
        @tier "presentation"
      error : BiologyCanvasError
        @label "Error"
        @description "error prop"
        @tier "presentation"
    }
  }

  page "/biology-canvas" as BiologyCanvasPage -> BiologyCanvasRender
}
