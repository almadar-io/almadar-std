app ui-physics-canvas "1.0.0"
"PhysicsCanvas — UI factory (1:1 with the @almadar/ui physics-canvas pattern)."
orbital PhysicsCanvasOrbital {
  type PhysicsCanvasBodiesItem = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }
  type PhysicsCanvasConstraintsItem = {
    from : string!
    to : string!
    color : string
  }
  type PhysicsCanvasShapesItem = {
    type : "line" | "arrow" | "circle" | "rect" | "polygon" | "path" | "text" | "axis" | "grid"!
    id : string
    x : number
    y : number
    x1 : number
    y1 : number
    x2 : number
    y2 : number
    radius : number
    width : number
    height : number
    points : [PhysicsCanvasShapesItemPointsItem]
    path : string
    text : string
    label : string
    fontSize : number
    align : "left" | "center" | "right"
    axis : "x" | "y"
    min : number
    max : number
    step : number
    color : string
    fill : string
    lineWidth : number
    opacity : number
  }
  type PhysicsCanvasShapesItemPointsItem = {
    x : number!
    y : number!
  }
  type PhysicsCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type PhysicsCanvasSHAPECLICKPayload = {
    id : string
    type : string
    index : number!
  }

  entity PhysicsCanvasItem [runtime] {
    id : string!
  }

  trait PhysicsCanvasRender -> @rebindable PhysicsCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          backgroundColor: @config.backgroundColor
          bodies: @config.bodies
          constraints: @config.constraints
          showVelocity: @config.showVelocity
          showForces: @config.showForces
          velocityScale: @config.velocityScale
          forceScale: @config.forceScale
          shapes: @config.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: physics-canvas
        })
      UPDATE -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          backgroundColor: @config.backgroundColor
          bodies: @payload.bodies
          constraints: @payload.constraints
          showVelocity: @config.showVelocity
          showForces: @config.showForces
          velocityScale: @config.velocityScale
          forceScale: @config.forceScale
          shapes: @payload.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: physics-canvas
        })
    }

    emits {
      @config.onShapeClick -> external {
        payload : PhysicsCanvasSHAPECLICKPayload
      }
        @description "onShapeClick prop"
        @tier "essential"
    }

    listens {
      UPDATE {
        bodies : [PhysicsCanvasBodiesItem]
        constraints : [PhysicsCanvasConstraintsItem]
        shapes : [PhysicsCanvasShapesItem]
      }
        @description "Live scene update; payload carries the current drawable state."
        @synonyms "tick, redraw, animate, frame"
        @tier "domain"
    }

    config {
      className : string
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "height prop"
        @tier "presentation"
      title : string
        @label "Title"
        @description "title prop"
        @tier "presentation"
      backgroundColor : string
        @label "Background Color"
        @description "backgroundColor prop"
        @tier "presentation"
      bodies : [PhysicsCanvasBodiesItem] = []
        @label "Bodies"
        @description "bodies prop"
        @tier "presentation"
      constraints : [PhysicsCanvasConstraintsItem] = []
        @label "Constraints"
        @description "constraints prop"
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "showVelocity prop"
        @tier "presentation"
      showForces : boolean = false
        @label "Show Forces"
        @description "showForces prop"
        @tier "presentation"
      velocityScale : number = 20
        @label "Velocity Scale"
        @description "velocityScale prop"
        @tier "presentation"
      forceScale : number = 20
        @label "Force Scale"
        @description "forceScale prop"
        @tier "presentation"
      shapes : [PhysicsCanvasShapesItem] = []
        @label "Shapes"
        @description "Extra declarative shapes in canvas pixel coordinates."
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "interactive prop"
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "animate prop"
        @tier "presentation"
      onShapeClick : string = "SHAPE_CLICK"
        @label "On Shape Click"
        @description "onShapeClick prop"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "isLoading prop"
        @tier "presentation"
      error : PhysicsCanvasError
        @label "Error"
        @description "error prop"
        @tier "presentation"
    }
  }

  page "/physics-canvas" as PhysicsCanvasPage -> PhysicsCanvasRender
}
