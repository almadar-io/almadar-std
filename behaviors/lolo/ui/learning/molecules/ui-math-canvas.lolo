app ui-math-canvas "1.0.0"
"MathCanvas — UI factory (1:1 with the @almadar/ui math-canvas pattern)."
orbital MathCanvasOrbital {
  type MathCanvasCurvesItem = {
    label : string
    color : string
    samples : [MathCanvasCurvesItemSamplesItem]!
  }
  type MathCanvasCurvesItemSamplesItem = {
    x : number!
    y : number!
  }
  type MathCanvasPointsItem = {
    x : number!
    y : number!
    label : string
    color : string
    radius : number
  }
  type MathCanvasVectorsItem = {
    x : number!
    y : number!
    vx : number!
    vy : number!
    color : string
    label : string
  }
  type MathCanvasShapesItem = {
    type : "line" | "arrow" | "circle" | "rect" | "polygon" | "path" | "text" | "axis" | "grid"!
    id : string
    x : number
    y : number
    x1 : number
    y1 : number
    x2 : number
    y2 : number
    radius : number
    width : number
    height : number
    points : [MathCanvasShapesItemPointsItem]
    path : string
    text : string
    label : string
    fontSize : number
    align : "left" | "center" | "right"
    axis : "x" | "y"
    min : number
    max : number
    step : number
    color : string
    fill : string
    lineWidth : number
    opacity : number
  }
  type MathCanvasShapesItemPointsItem = {
    x : number!
    y : number!
  }
  type MathCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type MathCanvasSHAPECLICKPayload = {
    id : string
    type : string
    index : number!
  }

  entity MathCanvasItem [runtime] {
    id : string!
  }

  trait MathCanvasRender -> @rebindable MathCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          xMin: @config.xMin
          xMax: @config.xMax
          yMin: @config.yMin
          yMax: @config.yMax
          showAxes: @config.showAxes
          showGrid: @config.showGrid
          gridStep: @config.gridStep
          curves: @config.curves
          points: @config.points
          vectors: @config.vectors
          shapes: @config.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: math-canvas
        })
      UPDATE -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          title: @config.title
          xMin: @config.xMin
          xMax: @config.xMax
          yMin: @config.yMin
          yMax: @config.yMax
          showAxes: @config.showAxes
          showGrid: @config.showGrid
          gridStep: @config.gridStep
          curves: @payload.curves
          points: @payload.points
          vectors: @payload.vectors
          shapes: @payload.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          isLoading: @config.isLoading
          error: @config.error
          type: math-canvas
        })
    }

    emits {
      @config.onShapeClick -> external {
        payload : MathCanvasSHAPECLICKPayload
      }
        @description "onShapeClick prop"
        @tier "essential"
    }

    listens {
      UPDATE {
        curves : [MathCanvasCurvesItem]
        points : [MathCanvasPointsItem]
        vectors : [MathCanvasVectorsItem]
        shapes : [MathCanvasShapesItem]
      }
        @description "Live scene update; payload carries the current drawable state."
        @synonyms "tick, redraw, animate, frame"
        @tier "domain"
    }

    config {
      className : string
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "height prop"
        @tier "presentation"
      title : string
        @label "Title"
        @description "title prop"
        @tier "presentation"
      xMin : number = -10
        @label "X Min"
        @description "xMin prop"
        @tier "presentation"
      xMax : number = 10
        @label "X Max"
        @description "xMax prop"
        @tier "presentation"
      yMin : number = -10
        @label "Y Min"
        @description "yMin prop"
        @tier "presentation"
      yMax : number = 10
        @label "Y Max"
        @description "yMax prop"
        @tier "presentation"
      showAxes : boolean = true
        @label "Show Axes"
        @description "showAxes prop"
        @tier "presentation"
      showGrid : boolean = true
        @label "Show Grid"
        @description "showGrid prop"
        @tier "presentation"
      gridStep : number = 1
        @label "Grid Step"
        @description "gridStep prop"
        @tier "presentation"
      curves : [MathCanvasCurvesItem] = []
        @label "Curves"
        @description "curves prop"
        @tier "presentation"
      points : [MathCanvasPointsItem] = []
        @label "Points"
        @description "points prop"
        @tier "presentation"
      vectors : [MathCanvasVectorsItem] = []
        @label "Vectors"
        @description "vectors prop"
        @tier "presentation"
      shapes : [MathCanvasShapesItem] = []
        @label "Shapes"
        @description "Extra declarative shapes in canvas pixel coordinates."
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "interactive prop"
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "animate prop"
        @tier "presentation"
      onShapeClick : string = "SHAPE_CLICK"
        @label "On Shape Click"
        @description "onShapeClick prop"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "isLoading prop"
        @tier "presentation"
      error : MathCanvasError
        @label "Error"
        @description "error prop"
        @tier "presentation"
    }
  }

  page "/math-canvas" as MathCanvasPage -> MathCanvasRender
}
