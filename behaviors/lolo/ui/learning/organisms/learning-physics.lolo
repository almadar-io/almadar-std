      bodies: [
        { id: "sun", x: 300, y: 200, radius: 20, color: "#f59e0b", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "planet-a", x: 300, y: 80, radius: 10, color: "#2563eb", label: "", vx: 2.24, vy: 0, fx: 0, fy: 0 },
        { id: "planet-b", x: 470, y: 200, radius: 8, color: "#16a34a", label: "", vx: 0, vy: 1.88, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/orbit" as OrbitMotionPage -> OrbitEngine
}

orbital GasMotionOrbital {
  uses Gas from "std/behaviors/std-physics-gas"

