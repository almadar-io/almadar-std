app learning-physics "1.0.0"
"Physics learning app — a fat organism whose orbitals are individual physics topics, each composed via `uses` from a per-law engine atom. kflow presents one orbital as one lesson."
orbital ProjectileMotionOrbital {
  uses Projectile from "std/behaviors/std-physics-projectile"

  type ProjectileBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity ProjectileScene [runtime] {
    id : string!
    bodies : [ProjectileBody]
    running : boolean = false
  }

  trait ProjectileEngine = Projectile.traits.ProjectileSim -> ProjectileScene {
    config {
      gravity: 0.4
      restitution: 0.78
      damping: 0.995
      running: true
      width: 600
      height: 400
      bodies: [
        { id: "ball-a", x: 90, y: 70, radius: 16, color: "#2563eb", label: "A", vx: 5, vy: 0, fx: 0, fy: 0 },
        { id: "ball-b", x: 320, y: 50, radius: 11, color: "#16a34a", label: "B", vx: -4, vy: 3, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/projectile" as ProjectileMotionPage -> ProjectileEngine
}

orbital FreeFallMotionOrbital {
  uses FreeFall from "std/behaviors/std-physics-freefall"

  type FreeFallBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity FreeFallScene [runtime] {
    id : string!
    bodies : [FreeFallBody]
    running : boolean = false
  }

  trait FreeFallEngine = FreeFall.traits.FreeFallSim -> FreeFallScene {
    config {
      gravity: 0.5
      restitution: 0.8
      damping: 0.995
      running: true
      width: 600
      height: 400
      bodies: [
        { id: "ball-a", x: 100, y: 40, radius: 16, color: "#2563eb", label: "A", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-b", x: 300, y: 70, radius: 13, color: "#16a34a", label: "B", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-c", x: 480, y: 100, radius: 10, color: "#dc2626", label: "C", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/freefall" as FreeFallMotionPage -> FreeFallEngine
}

orbital SpringMotionOrbital {
  uses Spring from "std/behaviors/std-physics-spring"

  type SpringBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity SpringScene [runtime] {
    id : string!
    bodies : [SpringBody]
    running : boolean = false
  }

  trait SpringEngine = Spring.traits.SpringSim -> SpringScene {
    config {
      springK: 0.02
      damping: 0.99
      anchorX: 300
      running: true
      width: 600
      height: 400
      bodies: [
        { id: "ball-a", x: 120, y: 200, radius: 14, color: "#2563eb", label: "A", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-b", x: 300, y: 200, radius: 14, color: "#16a34a", label: "B", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-c", x: 480, y: 200, radius: 14, color: "#dc2626", label: "C", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/spring" as SpringMotionPage -> SpringEngine
}

