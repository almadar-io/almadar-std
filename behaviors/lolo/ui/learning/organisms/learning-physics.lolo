orbital ReflectionMotionOrbital {
  uses Reflection from "std/behaviors/std-physics-reflection"

  type ReflectionBody = { id:string x:number! y:number! radius:number color:string label:string vx:number vy:number fx:number fy:number }

  type ReflectionShape = { type:string! x1:number! y1:number! x2:number! y2:number! color:string lineWidth:number }

  entity ReflectionScene [runtime] {
    id : string!
    bodies : [ReflectionBody]
    running : boolean = false
  }

  trait ReflectionEngine = Reflection.traits.ReflectionSim -> ReflectionScene {
    config {
      running: true
      width: 600
      height: 400
      shapes: [{ type: "line", x1: 20, y1: 380, x2: 580, y2: 380, color: "#334155", lineWidth: 3 }]
      bodies: [
        { id: "ray-a", x: 120, y: 120, radius: 7, color: "#f59e0b", label: "", vx: 6, vy: 4, fx: 0, fy: 0 },
        { id: "ray-b", x: 480, y: 150, radius: 7, color: "#2563eb", label: "", vx: -5, vy: 5, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/reflection" as ReflectionMotionPage -> ReflectionEngine
}
