orbital PendulumMotionOrbital {
  uses Pendulum from "std/behaviors/std-physics-pendulum"

  type PendulumBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  type PendulumConstraint = {
    from : string!
    to : string!
    color : string
  }

  entity PendulumScene [runtime] {
    id : string!
    bodies : [PendulumBody]
    running : boolean = false
  }

  trait PendulumEngine = Pendulum.traits.PendulumSim -> PendulumScene {
    config {
      gravity: 0.5
      damping: 0.995
      length: 170
      pivotX: 300
      pivotY: 70
      running: true
      width: 600
      height: 400
      constraints: [{ from: "pivot", to: "bob", color: "#94a3b8" }]
      bodies: [
        { id: "pivot", x: 300, y: 70, radius: 6, color: "#334155", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "bob", x: 450, y: 110, radius: 18, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/pendulum" as PendulumMotionPage -> PendulumEngine
}

