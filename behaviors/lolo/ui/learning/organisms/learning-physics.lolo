orbital InclineMotionOrbital {
  uses Incline from "std/behaviors/std-physics-incline"

  type InclineBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  type InclineShape = {
    type : string!
    x1 : number!
    y1 : number!
    x2 : number!
    y2 : number!
    color : string
    lineWidth : number
  }

  entity InclineScene [runtime] {
    id : string!
    bodies : [InclineBody]
    running : boolean = false
  }

  trait InclineEngine = Incline.traits.InclineSim -> InclineScene {
    config {
      gravity: 0.5
      damping: 0.99
      rampX0: 120
      rampY0: 90
      rampX1: 520
      rampY1: 330
      running: true
      width: 600
      height: 400
      shapes: [{ type: "line", x1: 120, y1: 90, x2: 520, y2: 330, color: "#334155", lineWidth: 3 }]
      bodies: [
        { id: "block", x: 170, y: 110, radius: 16, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
    }
  }

  page "/physics/incline" as InclineMotionPage -> InclineEngine
}

