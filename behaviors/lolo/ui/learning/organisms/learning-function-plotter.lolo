app learning-function-plotter "1.0.0"
"Function plotter organism — plots multiple sampled functions on a math-canvas."
orbital FunctionPlotterOrbital {
  entity FunctionPlotterItem [runtime] {
    id : string!
  }

  trait FunctionPlotterRender -> @rebindable FunctionPlotterItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          padding: md
          children: [
            { type: typography, variant: h4, content: @config.title },
            { type: math-canvas,
              width: @config.width,
              height: @config.height,
              xMin: @config.xMin,
              xMax: @config.xMax,
              yMin: @config.yMin,
              yMax: @config.yMax,
              showAxes: true,
              showGrid: true,
              gridStep: 1,
              curves: [
                { label: "sin(x)", color: "#2563eb",
                  samples: [
                    { x: -6.28, y: 0 }, { x: -5.5, y: 0.71 }, { x: -4.71, y: 1 },
                    { x: -3.93, y: 0.71 }, { x: -3.14, y: 0 }, { x: -2.36, y: -0.71 },
                    { x: -1.57, y: -1 }, { x: -0.79, y: -0.71 }, { x: 0, y: 0 },
                    { x: 0.79, y: 0.71 }, { x: 1.57, y: 1 }, { x: 2.36, y: 0.71 },
                    { x: 3.14, y: 0 }, { x: 3.93, y: -0.71 }, { x: 4.71, y: -1 },
                    { x: 5.5, y: -0.71 }, { x: 6.28, y: 0 }
                  ]
                },
                { label: "cos(x)", color: "#dc2626",
                  samples: [
                    { x: -6.28, y: 1 }, { x: -5.5, y: 0.71 }, { x: -4.71, y: 0 },
                    { x: -3.93, y: -0.71 }, { x: -3.14, y: -1 }, { x: -2.36, y: -0.71 },
                    { x: -1.57, y: 0 }, { x: -0.79, y: 0.71 }, { x: 0, y: 1 },
                    { x: 0.79, y: 0.71 }, { x: 1.57, y: 0 }, { x: 2.36, y: -0.71 },
                    { x: 3.14, y: -1 }, { x: 3.93, y: -0.71 }, { x: 4.71, y: 0 },
                    { x: 5.5, y: 0.71 }, { x: 6.28, y: 1 }
                  ]
                }
              ]
            }
          ]
        })
    }

    config {
      title : string = "Function Plotter"
        @label "Title"
        @description "Title shown above the plot."
        @tier "domain"
      width : number = 600
        @label "Width"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @tier "presentation"
      xMin : number = -7
        @label "X Min"
        @tier "domain"
      xMax : number = 7
        @label "X Max"
        @tier "domain"
      yMin : number = -2
        @label "Y Min"
        @tier "domain"
      yMax : number = 2
        @label "Y Max"
        @tier "domain"
    }
  }

  page "/learning/function-plotter" as FunctionPlotterPage -> FunctionPlotterRender
}
