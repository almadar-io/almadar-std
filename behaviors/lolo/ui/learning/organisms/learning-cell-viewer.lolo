app learning-cell-viewer "1.0.0"
"Cell viewer organism — a biology-canvas bound to entity data."
orbital CellViewerOrbital {
  type CellViewerNode = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    kind : "cell" | "organelle" | "molecule" | "organism"
  }
  type CellViewerEdge = {
    from : string!
    to : string!
    color : string
    label : string
  }

  entity CellViewerItem [runtime] {
    id : string!
    title : string
    backgroundColor : string
    nodes : [CellViewerNode]
    edges : [CellViewerEdge]
  }

  trait CellViewerRender -> @rebindable CellViewerItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.title @config.title)
        (set @entity.backgroundColor @config.backgroundColor)
        (set @entity.nodes @config.nodes)
        (set @entity.edges @config.edges)
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          padding: md
          children: [
            { type: typography, variant: h4, content: @entity.title },
            { type: biology-canvas,
              width: @config.width,
              height: @config.height,
              backgroundColor: @entity.backgroundColor,
              nodes: @entity.nodes,
              edges: @entity.edges,
              interactive: @config.interactive,
              animate: @config.animate
            }
          ]
        })
    }

    config {
      title : string = "Cell Viewer"
        @label "Title"
        @description "Title shown above the cell."
        @tier "domain"
      backgroundColor : string = "#f0fdf4"
        @label "Background Color"
        @tier "presentation"
      nodes : [CellViewerNode] = [
        { id: "cell", x: 300, y: 200, radius: 120, color: "#16a34a", label: "Cell membrane", kind: cell },
        { id: "nucleus", x: 300, y: 200, radius: 40, color: "#2563eb", label: "Nucleus", kind: organelle },
        { id: "mitochondria", x: 230, y: 150, radius: 20, color: "#dc2626", label: "Mitochondrion", kind: organelle },
        { id: "ribosome", x: 360, y: 260, radius: 10, color: "#ca8a04", label: "Ribosome", kind: organelle }
      ]
        @label "Nodes"
        @description "Cell / organelle nodes to render."
        @tier "domain"
      edges : [CellViewerEdge] = []
        @label "Edges"
        @description "Connections between nodes."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "Enable pointer interaction on the canvas."
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "Enable continuous redraw loop."
        @tier "presentation"
    }
  }

  page "/learning/cell-viewer" as CellViewerPage -> CellViewerRender
}
