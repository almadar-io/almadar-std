app learning-physics-lab "1.0.0"
"Physics lab organism — a live gravity + wall-bounce simulation on a physics-canvas; Start/Pause/Reset drive a per-tick integrator that advances each body's velocity and position."
orbital PhysicsLabOrbital {
  type PhysicsLabBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }
  type PhysicsLabConstraint = {
    from : string!
    to : string!
    color : string
  }
  type PhysicsLabShape = {
    type : "line" | "arrow" | "circle" | "rect" | "polygon" | "path" | "text" | "axis" | "grid"!
    id : string
    x : number
    y : number
    x1 : number
    y1 : number
    x2 : number
    y2 : number
    radius : number
    width : number
    height : number
    points : [PhysicsLabShapePoint]
    path : string
    text : string
    label : string
    fontSize : number
    align : "left" | "center" | "right"
    axis : "x" | "y"
    min : number
    max : number
    step : number
    color : string
    fill : string
    lineWidth : number
    opacity : number
  }
  type PhysicsLabShapePoint = {
    x : number!
    y : number!
  }

  entity PhysicsLabItem [runtime] {
    id : string!
    title : string
    bodies : [PhysicsLabBody]
    constraints : [PhysicsLabConstraint]
    shapes : [PhysicsLabShape]
    running : boolean = false
  }

  trait PhysicsLabRender -> @rebindable PhysicsLabItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.title @config.title)
        (set @entity.bodies @config.bodies)
        (set @entity.constraints @config.constraints)
        (set @entity.shapes @config.shapes)
        (set @entity.running false)
        (render-ui main {
          type: box
          padding: md
          children: [
            { type: stack, direction: vertical, gap: md, children: [
              { type: typography, variant: h4, content: @entity.title },
              { type: stack, direction: horizontal, gap: sm, children: [
                { type: button, action: START, label: "Start", variant: primary },
                { type: button, action: PAUSE, label: "Pause", variant: secondary },
                { type: button, action: RESET, label: "Reset", variant: ghost }
              ] },
              { type: physics-canvas, width: @config.width, height: @config.height, backgroundColor: @config.backgroundColor, bodies: @entity.bodies, constraints: @entity.constraints, shapes: @entity.shapes, showVelocity: @config.showVelocity, showForces: @config.showForces, velocityScale: @config.velocityScale, forceScale: @config.forceScale, interactive: @config.interactive, animate: @config.animate }
            ] }
          ]
        })

      START -> idle
        (set @entity.running true)
        (render-ui main {
          type: box
          padding: md
          children: [
            { type: stack, direction: vertical, gap: md, children: [
              { type: typography, variant: h4, content: @entity.title },
              { type: stack, direction: horizontal, gap: sm, children: [
                { type: button, action: START, label: "Start", variant: primary },
                { type: button, action: PAUSE, label: "Pause", variant: secondary },
                { type: button, action: RESET, label: "Reset", variant: ghost }
              ] },
              { type: physics-canvas, width: @config.width, height: @config.height, backgroundColor: @config.backgroundColor, bodies: @entity.bodies, constraints: @entity.constraints, shapes: @entity.shapes, showVelocity: @config.showVelocity, showForces: @config.showForces, velocityScale: @config.velocityScale, forceScale: @config.forceScale, interactive: @config.interactive, animate: @config.animate }
            ] }
          ]
        })

      PAUSE -> idle
        (set @entity.running false)
        (render-ui main {
          type: box
          padding: md
          children: [
            { type: stack, direction: vertical, gap: md, children: [
              { type: typography, variant: h4, content: @entity.title },
              { type: stack, direction: horizontal, gap: sm, children: [
                { type: button, action: START, label: "Start", variant: primary },
                { type: button, action: PAUSE, label: "Pause", variant: secondary },
                { type: button, action: RESET, label: "Reset", variant: ghost }
              ] },
              { type: physics-canvas, width: @config.width, height: @config.height, backgroundColor: @config.backgroundColor, bodies: @entity.bodies, constraints: @entity.constraints, shapes: @entity.shapes, showVelocity: @config.showVelocity, showForces: @config.showForces, velocityScale: @config.velocityScale, forceScale: @config.forceScale, interactive: @config.interactive, animate: @config.animate }
            ] }
          ]
        })

      RESET -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running false)
        (render-ui main {
          type: box
          padding: md
          children: [
            { type: stack, direction: vertical, gap: md, children: [
              { type: typography, variant: h4, content: @entity.title },
              { type: stack, direction: horizontal, gap: sm, children: [
                { type: button, action: START, label: "Start", variant: primary },
                { type: button, action: PAUSE, label: "Pause", variant: secondary },
                { type: button, action: RESET, label: "Reset", variant: ghost }
              ] },
              { type: physics-canvas, width: @config.width, height: @config.height, backgroundColor: @config.backgroundColor, bodies: @entity.bodies, constraints: @entity.constraints, shapes: @entity.shapes, showVelocity: @config.showVelocity, showForces: @config.showForces, velocityScale: @config.velocityScale, forceScale: @config.forceScale, interactive: @config.interactive, animate: @config.animate }
            ] }
          ]
        })
    }

    ticks {
      physicsTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (r (object/get @b radius))
            (nvx (* (object/get @b vx) @config.damping))
            (nvy (* (+ (object/get @b vy) @config.gravity) @config.damping))
          )
          (let (
            (nx (+ (object/get @b x) @nvx))
            (ny (+ (object/get @b y) @nvy))
          )
          (let (
            (hitx (or (< @nx @r) (> @nx (- @config.width @r))))
            (hity (or (< @ny @r) (> @ny (- @config.height @r))))
          )
          (object/merge @b {
            x: (math/clamp @nx @r (- @config.width @r)),
            y: (math/clamp @ny @r (- @config.height @r)),
            vx: (if @hitx (* @nvx (* -1 @config.restitution)) @nvx),
            vy: (if @hity (* @nvy (* -1 @config.restitution)) @nvy)
          })))))))
        (render-ui main {
          type: box
          padding: md
          children: [
            { type: stack, direction: vertical, gap: md, children: [
              { type: typography, variant: h4, content: @entity.title },
              { type: stack, direction: horizontal, gap: sm, children: [
                { type: button, action: START, label: "Start", variant: primary },
                { type: button, action: PAUSE, label: "Pause", variant: secondary },
                { type: button, action: RESET, label: "Reset", variant: ghost }
              ] },
              { type: physics-canvas, width: @config.width, height: @config.height, backgroundColor: @config.backgroundColor, bodies: @entity.bodies, constraints: @entity.constraints, shapes: @entity.shapes, showVelocity: @config.showVelocity, showForces: @config.showForces, velocityScale: @config.velocityScale, forceScale: @config.forceScale, interactive: @config.interactive, animate: @config.animate }
            ] }
          ]
        })
    }

    emits {
      START -> external {
        id : string
      }
        @description "startEvent prop — begins the physics integration loop"
        @tier "domain"
      PAUSE -> external {
        id : string
      }
        @description "pauseEvent prop — halts the integration loop, freezing the bodies"
        @tier "domain"
      RESET -> external {
        id : string
      }
        @description "resetEvent prop — restores the bodies to their initial config state"
        @tier "domain"
    }

    config {
      mode : "wave" | "field" | "ray-diagram" | "pendulum" | "circuit" = wave
        @label "Mode"
        @description "What kind of physics visualization to render."
        @synonyms "oscillation, sine wave, sound wave, light, electric field, magnetic field, gravitational field, force, ray, lens, mirror, pendulum, swing, circuit, resistor, battery, current, projectile, bounce, gravity, kinematics, motion"
        @tier "domain"
      title : string = "Physics Lab"
        @label "Title"
        @description "Title shown above the canvas."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      gravity : number = 0.4
        @label "Gravity"
        @description "Downward acceleration added to each body's vy every tick."
        @tier "domain"
      restitution : number = 0.78
        @label "Restitution"
        @description "Fraction of speed kept when a body bounces off a wall (0 = dead stop, 1 = perfectly elastic)."
        @tier "domain"
      damping : number = 0.995
        @label "Damping"
        @description "Fraction of velocity retained each tick, modelling air resistance."
        @tier "domain"
      bodies : [PhysicsLabBody] = [
        { id: "ball-a", x: 90, y: 70, radius: 16, color: "#2563eb", label: "A", vx: 5, vy: 0, fx: 0, fy: 0 },
        { id: "ball-b", x: 320, y: 50, radius: 11, color: "#16a34a", label: "B", vx: -4, vy: 3, fx: 0, fy: 0 },
        { id: "ball-c", x: 500, y: 90, radius: 13, color: "#dc2626", label: "C", vx: 2, vy: -2, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Bodies or particles to simulate; each carries position (x,y) and velocity (vx,vy)."
        @tier "domain"
      constraints : [PhysicsLabConstraint] = []
        @label "Constraints"
        @description "Links between bodies, drawn as connecting lines."
        @tier "domain"
      shapes : [PhysicsLabShape] = []
        @label "Shapes"
        @description "Extra declarative shapes such as field lines, rays, or circuit wires."
        @tier "domain"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Render velocity arrows for each body."
        @tier "presentation"
      showForces : boolean = false
        @label "Show Forces"
        @description "Render force arrows for each body."
        @tier "presentation"
      velocityScale : number = 8
        @label "Velocity Scale"
        @tier "presentation"
      forceScale : number = 30
        @label "Force Scale"
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "Enable pointer interaction on the canvas."
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "Enable the canvas's own redraw loop (independent of the physics tick)."
        @tier "presentation"
    }
  }

  page "/learning/physics-lab" as PhysicsLabPage -> PhysicsLabRender
}
