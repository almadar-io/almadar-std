app learning-coordinate-plane "1.0.0"
"Coordinate plane organism — a math-canvas with a sample curve and scatter points, wrapped in a card with a title."
orbital CoordinatePlaneOrbital {
  entity CoordinatePlaneItem [runtime] {
    id : string!
  }

  trait CoordinatePlaneRender -> @rebindable CoordinatePlaneItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          padding: md
          children: [
            { type: typography, variant: h4, content: @config.title },
            { type: math-canvas,
              width: @config.width,
              height: @config.height,
              xMin: @config.xMin,
              xMax: @config.xMax,
              yMin: @config.yMin,
              yMax: @config.yMax,
              showAxes: true,
              showGrid: true,
              gridStep: 1,
              curves: [
                { label: "y = x²", color: "#2563eb",
                  samples: [
                    { x: -3, y: 9 }, { x: -2, y: 4 }, { x: -1, y: 1 },
                    { x: 0, y: 0 }, { x: 1, y: 1 }, { x: 2, y: 4 }, { x: 3, y: 9 }
                  ]
                }
              ],
              points: [
                { x: -2, y: 4, label: "A", color: "#dc2626" },
                { x: 1, y: 1, label: "B", color: "#16a34a" }
              ]
            }
          ]
        })
    }

    config {
      title : string = "Coordinate Plane"
        @label "Title"
        @description "Title shown above the plane."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      xMin : number = -5
        @label "X Min"
        @description "Minimum x value."
        @tier "domain"
      xMax : number = 5
        @label "X Max"
        @description "Maximum x value."
        @tier "domain"
      yMin : number = -2
        @label "Y Min"
        @description "Minimum y value."
        @tier "domain"
      yMax : number = 10
        @label "Y Max"
        @description "Maximum y value."
        @tier "domain"
    }
  }

  page "/learning/coordinate-plane" as CoordinatePlanePage -> CoordinatePlaneRender
}
