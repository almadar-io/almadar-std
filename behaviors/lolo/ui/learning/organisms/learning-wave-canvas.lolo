app learning-wave-canvas "1.0.0"
"Wave canvas organism — a sampled sine wave rendered on a math-canvas, useful for teaching periodic motion."
orbital WaveCanvasOrbital {
  entity WaveCanvasItem [runtime] {
    id : string!
  }

  trait WaveCanvasRender -> @rebindable WaveCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          padding: md
          children: [
            { type: typography, variant: h4, content: @config.title },
            { type: math-canvas,
              width: @config.width,
              height: @config.height,
              xMin: @config.xMin,
              xMax: @config.xMax,
              yMin: -1.5,
              yMax: 1.5,
              showAxes: true,
              showGrid: true,
              gridStep: 1,
              curves: [
                { label: "y = sin(x)", color: "#7c3aed",
                  samples: [
                    { x: 0, y: 0 }, { x: 0.79, y: 0.71 }, { x: 1.57, y: 1 },
                    { x: 2.36, y: 0.71 }, { x: 3.14, y: 0 }, { x: 3.93, y: -0.71 },
                    { x: 4.71, y: -1 }, { x: 5.5, y: -0.71 }, { x: 6.28, y: 0 }
                  ]
                }
              ]
            }
          ]
        })
    }

    config {
      title : string = "Wave Canvas"
        @label "Title"
        @description "Title shown above the wave."
        @tier "domain"
      width : number = 600
        @label "Width"
        @tier "presentation"
      height : number = 300
        @label "Height"
        @tier "presentation"
      xMin : number = 0
        @label "X Min"
        @tier "domain"
      xMax : number = 7
        @label "X Max"
        @tier "domain"
    }
  }

  page "/learning/wave-canvas" as WaveCanvasPage -> WaveCanvasRender
}
