app learning-vector-canvas "1.0.0"
"Vector canvas organism — plots coordinate axes and a set of vectors on a math-canvas."
orbital VectorCanvasOrbital {
  entity VectorCanvasItem [runtime] {
    id : string!
  }

  trait VectorCanvasRender -> @rebindable VectorCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          padding: md
          children: [
            { type: typography, variant: h4, content: @config.title },
            { type: math-canvas,
              width: @config.width,
              height: @config.height,
              xMin: @config.xMin,
              xMax: @config.xMax,
              yMin: @config.yMin,
              yMax: @config.yMax,
              showAxes: true,
              showGrid: true,
              gridStep: 1,
              vectors: [
                { x: 0, y: 0, vx: 3, vy: 2, label: "u", color: "#2563eb" },
                { x: 0, y: 0, vx: -2, vy: 3, label: "v", color: "#dc2626" },
                { x: 0, y: 0, vx: 1, vy: 5, label: "w", color: "#16a34a" }
              ]
            }
          ]
        })
    }

    config {
      title : string = "Vector Canvas"
        @label "Title"
        @description "Title shown above the canvas."
        @tier "domain"
      width : number = 600
        @label "Width"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @tier "presentation"
      xMin : number = -6
        @label "X Min"
        @tier "domain"
      xMax : number = 6
        @label "X Max"
        @tier "domain"
      yMin : number = -2
        @label "Y Min"
        @tier "domain"
      yMax : number = 6
        @label "Y Max"
        @tier "domain"
    }
  }

  page "/learning/vector-canvas" as VectorCanvasPage -> VectorCanvasRender
}
