app learning-algorithms "1.0.0"
"Algorithms learning app — orbitals are individual computer-science algorithms, each composed via `uses` from a per-algorithm engine atom on algorithm-canvas (bars/cells) or biology-canvas (graphs)."
orbital AstargraphOrbital {
  uses Astargraph from "std/behaviors/std-algo-astargraph"

    type GraphNode = {
      id : string!
      x : number!
      y : number!
      radius : number
      color : string
      label : string
      kind : "cell" | "organelle" | "molecule" | "organism"
    }
    type GraphEdge = {
      from : string!
      to : string!
      color : string
      label : string
    }
    type WEdge = {
      from : string!
      to : string!
      w : number!
    }
    type Dist = {
      id : string!
      d : number!
    }
    type FEntry = {
      id : string!
      f : number!
    }

    entity AstargraphScene [runtime] {
      id : string!
      nodes : [GraphNode]
      edges : [GraphEdge]
      wedges : [WEdge]
      gscore : [Dist]
      visited : [string]
      openF : [FEntry]
      goal : string = ""
      goalX : number = 0
      goalY : number = 0
      cur : string = ""
      minF : number = 0
      distU : number = 0
      done : boolean = false
      running : boolean = true
    }

  trait AstargraphEngine = Astargraph.traits.AstarSim -> AstargraphScene {
    config {
      running: true
    }
  }

  page "/algorithms/astargraph" as AstargraphPage -> AstargraphEngine
}
orbital AstargridOrbital {
  uses Astargrid from "std/behaviors/std-algo-astargrid"

    type AlgoCell = {
      id : number!
      row : number!
      col : number!
      value : number
      color : string
      label : string
      g : number
    }

    entity AstargridScene [runtime] {
      id : string!
      cells : [AlgoCell]
      open : [number]
      closed : [number]
      cur : number = 0
      gcur : number = 0
      tr : number = 0
      tc : number = 0
      reached : boolean = false
      done : boolean = false
      running : boolean = true
    }

  trait AstargridEngine = Astargrid.traits.AstarGridSim -> AstargridScene {
    config {
      running: true
    }
  }

  page "/algorithms/astargrid" as AstargridPage -> AstargridEngine
}
