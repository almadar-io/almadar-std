      takeLeft : boolean = false
      srcVal : number = 0
      advancing : boolean = false
      nextLo : number = 0
      moreMerges : boolean = false
      levelEnd : boolean = false
      moreLevels : boolean = false
      newWidth : number = 0
    }

  trait MergesortEngine = Mergesort.traits.MergeSortSim -> MergesortScene {
