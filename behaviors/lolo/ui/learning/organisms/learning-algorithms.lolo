orbital QuicksortOrbital {
  uses Quicksort from "std/behaviors/std-algo-quicksort"

    type AlgoBar = {
      value : number!
      color : string
      label : string
    }

    type Range = {
      lo : number!
      hi : number!
    }

    entity QuicksortScene [runtime] {
      id : string!
      bars : [AlgoBar]
      stack : [Range]
      lo : number = 0
      hi : number = 0
      pivot : number = 0
      si : number = 0
      j : number = 0
      active : boolean = false
      done : boolean = false
      running : boolean = true
      sEmpty : boolean = false
      topLo : number = 0
      topHi : number = 0
      cmpLess : boolean = false
      doSwap : boolean = false
      swapA : number = 0
      swapB : number = 0
    }

  trait QuicksortEngine = Quicksort.traits.QuickSortSim -> QuicksortScene {
    config {
      running: true
    }
  }

  page "/algorithms/quicksort" as QuicksortPage -> QuicksortEngine
}
