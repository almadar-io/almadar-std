      running : boolean = true
      largest : number = 0
      willSwap : boolean = false
      buildMore : boolean = false
      buildDone : boolean = false
      sortExtract : boolean = false
      finished : boolean = false
      doSwap : boolean = false
      swapA : number = 0
      swapB : number = 0
    }

  trait HeapsortEngine = Heapsort.traits.HeapSortSim -> HeapsortScene {
    config {
      running: true
    }
  }

  page "/algorithms/heapsort" as HeapsortPage -> HeapsortEngine
}
