app learning-molecule-viewer "1.0.0"
"Molecule viewer organism — a chemistry-canvas bound to entity data."
orbital MoleculeViewerOrbital {
  type MoleculeViewerAtom = {
    id : string
    x : number!
    y : number!
    element : string
    radius : number
    color : string
  }
  type MoleculeViewerBond = {
    from : string!
    to : string!
    type : "single" | "double" | "triple"
    color : string
  }
  type MoleculeViewerArrow = {
    x : number!
    y : number!
    angle : number
    length : number
    color : string
    label : string
  }

  entity MoleculeViewerItem [runtime] {
    id : string!
    title : string
    backgroundColor : string
    atoms : [MoleculeViewerAtom]
    bonds : [MoleculeViewerBond]
    arrows : [MoleculeViewerArrow]
  }

  trait MoleculeViewerRender -> @rebindable MoleculeViewerItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.title @config.title)
        (set @entity.backgroundColor @config.backgroundColor)
        (set @entity.atoms @config.atoms)
        (set @entity.bonds @config.bonds)
        (set @entity.arrows @config.arrows)
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          padding: md
          children: [
            { type: typography, variant: h4, content: @entity.title },
            { type: chemistry-canvas,
              width: @config.width,
              height: @config.height,
              backgroundColor: @entity.backgroundColor,
              atoms: @entity.atoms,
              bonds: @entity.bonds,
              arrows: @entity.arrows,
              interactive: @config.interactive,
              animate: @config.animate
            }
          ]
        })
    }

    config {
      title : string = "Molecule Viewer"
        @label "Title"
        @description "Title shown above the molecule."
        @tier "domain"
      backgroundColor : string = "#fafafa"
        @label "Background Color"
        @tier "presentation"
      atoms : [MoleculeViewerAtom] = [
        { id: "C", x: 300, y: 200, element: "C", radius: 22, color: "#374151" },
        { id: "O", x: 380, y: 160, element: "O", radius: 20, color: "#dc2626" },
        { id: "H1", x: 240, y: 160, element: "H", radius: 14, color: "#2563eb" },
        { id: "H2", x: 260, y: 270, element: "H", radius: 14, color: "#2563eb" },
        { id: "H3", x: 340, y: 270, element: "H", radius: 14, color: "#2563eb" }
      ]
        @label "Atoms"
        @description "Atoms to render."
        @tier "domain"
      bonds : [MoleculeViewerBond] = [
        { from: "C", to: "O", type: double },
        { from: "C", to: "H1", type: single },
        { from: "C", to: "H2", type: single },
        { from: "C", to: "H3", type: single }
      ]
        @label "Bonds"
        @description "Bonds between atoms."
        @tier "domain"
      arrows : [MoleculeViewerArrow] = []
        @label "Arrows"
        @description "Reaction arrows."
        @tier "domain"
      width : number = 600
        @label "Width"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "Enable pointer interaction on the canvas."
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "Enable continuous redraw loop."
        @tier "presentation"
    }
  }

  page "/learning/molecule-viewer" as MoleculeViewerPage -> MoleculeViewerRender
}
