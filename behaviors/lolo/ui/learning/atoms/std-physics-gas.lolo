app std-physics-gas "1.0.0"
"Ideal-gas kinetic-theory engine — many equal-mass particles bounce elastically off walls and each other in a box."
orbital GasEngineOrbital {
  type GasBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity GasState [runtime] {
    id : string!
    bodies : [GasBody]
    running : boolean = false
  }

  trait GasSim -> @rebindable GasState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      gasTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (r (object/get @b radius))
          )
          (let (
            (cv (array/reduce @entity.bodies
              (fn (acc o)
                (if (= (object/get @o id) (object/get @b id))
                  @acc
                  (let (
                    (dx (- (object/get @o x) (object/get @b x)))
                    (dy (- (object/get @o y) (object/get @b y)))
                  )
                  (let (
                    (dist (math/sqrt (+ (* @dx @dx) (* @dy @dy))))
                    (sumr (+ (object/get @b radius) (object/get @o radius)))
                  )
                  (if (and (< @dist @sumr) (> @dist 0))
                    (let (
                      (nx (/ @dx @dist))
                      (ny (/ @dy @dist))
                    )
                    (let (
                      (vrel (+ (* (- (object/get @acc vx) (object/get @o vx)) @nx)
                               (* (- (object/get @acc vy) (object/get @o vy)) @ny)))
                    )
                    (if (> @vrel 0)
                      (object/merge @acc {
                        vx: (- (object/get @acc vx) (* @vrel @nx)),
                        vy: (- (object/get @acc vy) (* @vrel @ny))
                      })
                      @acc)))
                    @acc)))))
              { vx: (object/get @b vx), vy: (object/get @b vy) }))
          )
          (let (
            (bvx (object/get @cv vx))
            (bvy (object/get @cv vy))
          )
          (let (
            (newvx (if (or (< (+ (object/get @b x) @bvx) @r) (> (+ (object/get @b x) @bvx) (- @config.width @r)))
              (* @bvx -1)
              @bvx))
            (newvy (if (or (< (+ (object/get @b y) @bvy) @r) (> (+ (object/get @b y) @bvy) (- @config.height @r)))
              (* @bvy -1)
              @bvy))
          )
          (let (
            (nx (math/clamp (+ (object/get @b x) @newvx) @r (- @config.width @r)))
            (ny (math/clamp (+ (object/get @b y) @newvy) @r (- @config.height @r)))
          )
          (object/merge @b {
            x: @nx,
            y: @ny,
            vx: @newvx,
            vy: @newvy
          })))))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [GasBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels; bounds the wall bounce."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels; bounds the wall bounce."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each body's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 6
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
      bodies : [GasBody] = [
        { id: "p1", x: 80, y: 80, radius: 9, color: "#2563eb", label: "", vx: 3, vy: -2, fx: 0, fy: 0 },
        { id: "p2", x: 220, y: 80, radius: 9, color: "#16a34a", label: "", vx: -4, vy: 5, fx: 0, fy: 0 },
        { id: "p3", x: 360, y: 80, radius: 9, color: "#dc2626", label: "", vx: 5, vy: 3, fx: 0, fy: 0 },
        { id: "p4", x: 500, y: 80, radius: 9, color: "#f59e0b", label: "", vx: -3, vy: -4, fx: 0, fy: 0 },
        { id: "p5", x: 80, y: 160, radius: 9, color: "#16a34a", label: "", vx: 6, vy: 1, fx: 0, fy: 0 },
        { id: "p6", x: 220, y: 160, radius: 9, color: "#dc2626", label: "", vx: -5, vy: -3, fx: 0, fy: 0 },
        { id: "p7", x: 360, y: 160, radius: 9, color: "#f59e0b", label: "", vx: 2, vy: 6, fx: 0, fy: 0 },
        { id: "p8", x: 500, y: 160, radius: 9, color: "#2563eb", label: "", vx: -6, vy: 2, fx: 0, fy: 0 },
        { id: "p9", x: 80, y: 240, radius: 9, color: "#dc2626", label: "", vx: 4, vy: -5, fx: 0, fy: 0 },
        { id: "p10", x: 220, y: 240, radius: 9, color: "#f59e0b", label: "", vx: -2, vy: 4, fx: 0, fy: 0 },
        { id: "p11", x: 360, y: 240, radius: 9, color: "#2563eb", label: "", vx: 3, vy: -6, fx: 0, fy: 0 },
        { id: "p12", x: 500, y: 240, radius: 9, color: "#16a34a", label: "", vx: -4, vy: 3, fx: 0, fy: 0 },
        { id: "p13", x: 80, y: 320, radius: 9, color: "#f59e0b", label: "", vx: 5, vy: 2, fx: 0, fy: 0 },
        { id: "p14", x: 220, y: 320, radius: 9, color: "#2563eb", label: "", vx: -3, vy: -2, fx: 0, fy: 0 },
        { id: "p15", x: 360, y: 320, radius: 9, color: "#16a34a", label: "", vx: 6, vy: -1, fx: 0, fy: 0 },
        { id: "p16", x: 500, y: 320, radius: 9, color: "#dc2626", label: "", vx: -5, vy: 4, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "16 small equal-mass particles spread across the box with varied velocities — the ideal-gas ensemble."
        @tier "domain"
    }
  }

  page "/physics-gas" as GasEnginePage -> GasSim
}
