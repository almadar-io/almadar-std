app std-prob-galton "1.0.0"
"Galton board engine — balls fall under gravity and random-walk past pegs, piling into a bell curve on a physics-canvas."
orbital GaltonEngineOrbital {
  type GaltonBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  type GaltonPeg = {
    type : string!
    x : number!
    y : number!
    radius : number
    color : string
    fill : string
  }

  entity GaltonState [runtime] {
    id : string!
    bodies : [GaltonBody]
    running : boolean = false
  }

  trait GaltonSim -> @rebindable GaltonState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          shapes: @config.shapes
          showVelocity: false
          showForces: false
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      galtonTick every 32ms
        when @entity.running
        (do
          (set @entity.bodies (array/map @entity.bodies (fn b
            (let (
              (y (object/get @b y))
              (x (object/get @b x))
              (vy (object/get @b vy))
              (radius (object/get @b radius))
            )
            (if (>= @y @config.floor)
              @b
              (let (
                (nvy (+ @vy @config.gravity))
              )
              (let (
                (ny (+ @y @nvy))
                (nx (math/clamp (+ @x (- (* (math/random) (* 2 @config.jitter)) @config.jitter)) @radius (- @config.width @radius)))
              )
              (let (
                (ny2 (if (>= @ny @config.floor) @config.floor @ny))
              )
              (object/merge @b { x: @nx, y: @ny2, vy: @nvy })))))))))
          (render-ui main {
            type: physics-canvas
            width: @config.width
            height: @config.height
            backgroundColor: @config.backgroundColor
            bodies: @entity.bodies
            shapes: @config.shapes
            showVelocity: false
            showForces: false
          })
          (emit BODIES_UPDATED { bodies: @entity.bodies }))
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [GaltonBody]
      }
        @description "The current scene each tick — a composed listener (histogram, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      gravity : number = 0.5
        @label "Gravity"
        @description "Downward acceleration added to each falling ball's vy every tick (y grows downward)."
        @tier "domain"
      jitter : number = 5
        @label "Jitter"
        @description "Half-width of the per-tick random horizontal kick in pixels; the peg deflections that build the spread."
        @tier "domain"
      floor : number = 380
        @label "Floor"
        @description "Y pixel at which a ball has landed; at or below it the ball freezes and the pile persists."
        @tier "domain"
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the drop."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels; bounds the horizontal walk."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      bodies : [GaltonBody] = [
        { id: "b1", x: 298, y: 20, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b2", x: 302, y: 24, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b3", x: 300, y: 28, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b4", x: 296, y: 22, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b5", x: 304, y: 26, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b6", x: 300, y: 30, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b7", x: 298, y: 21, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b8", x: 302, y: 34, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b9", x: 300, y: 25, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b10", x: 296, y: 29, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b11", x: 304, y: 23, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b12", x: 300, y: 32, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b13", x: 298, y: 27, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b14", x: 302, y: 20, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b15", x: 300, y: 31, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "b16", x: 304, y: 24, radius: 6, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "16 balls dropped from the top center; the widening horizontal spread at the floor forms the bell curve."
        @tier "domain"
      shapes : [GaltonPeg] = [
        { type: "circle", x: 300, y: 90, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 278, y: 145, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 322, y: 145, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 256, y: 200, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 300, y: 200, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 344, y: 200, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 234, y: 255, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 278, y: 255, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 322, y: 255, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 366, y: 255, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 212, y: 310, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 256, y: 310, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 300, y: 310, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 344, y: 310, radius: 4, color: "#94a3b8", fill: "#94a3b8" },
        { type: "circle", x: 388, y: 310, radius: 4, color: "#94a3b8", fill: "#94a3b8" }
      ]
        @label "Shapes"
        @description "Triangular grid of 15 static peg markers the balls deflect around as they fall."
        @tier "domain"
    }
  }

  page "/prob-galton" as GaltonEnginePage -> GaltonSim
}
