app std-physics-reflection "1.0.0"
"Reflection engine — photons travel straight, bouncing off box walls at equal angles; composed via `uses`."
orbital ReflectionEngineOrbital {
  type ReflectionBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  type ReflectionShape = {
    type : string!
    x1 : number!
    y1 : number!
    x2 : number!
    y2 : number!
    color : string
    lineWidth : number
  }

  entity ReflectionState [runtime] {
    id : string!
    bodies : [ReflectionBody]
    running : boolean = false
  }

  trait ReflectionSim -> @rebindable ReflectionState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          shapes: @config.shapes
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      reflectionTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (r (object/get @b radius))
          )
          (let (
            (nvx0 (object/get @b vx))
            (nvy0 (object/get @b vy))
          )
          (let (
            (hitx (or (< (+ (object/get @b x) @nvx0) @r) (> (+ (object/get @b x) @nvx0) (- @config.width @r))))
            (hity (or (< (+ (object/get @b y) @nvy0) @r) (> (+ (object/get @b y) @nvy0) (- @config.height @r))))
          )
          (let (
            (nvx (if @hitx (* @nvx0 -1) @nvx0))
            (nvy (if @hity (* @nvy0 -1) @nvy0))
          )
          (let (
            (nx (math/clamp (+ (object/get @b x) @nvx) @r (- @config.width @r)))
            (ny (math/clamp (+ (object/get @b y) @nvy) @r (- @config.height @r)))
          )
          (object/merge @b {
            x: @nx,
            y: @ny,
            vx: @nvx,
            vy: @nvy
          })))))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          shapes: @config.shapes
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [ReflectionBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      shapes : [ReflectionShape] = [
        { type: "line", x1: 20, y1: 380, x2: 580, y2: 380, color: "#334155", lineWidth: 3 }
      ]
        @label "Shapes"
        @description "Static reflecting frame line drawn by the physics-canvas — the mirror surface the photons bounce off."
        @tier "domain"
      bodies : [ReflectionBody] = [
        { id: "ray-a", x: 120, y: 120, radius: 7, color: "#f59e0b", label: "", vx: 6, vy: 4, fx: 0, fy: 0 },
        { id: "ray-b", x: 480, y: 150, radius: 7, color: "#2563eb", label: "", vx: -5, vy: 5, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Initial photons; each travels in a straight line at constant speed and bounces off the box walls."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels; bounds the reflecting box."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels; bounds the reflecting box."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each photon's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 10
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
    }
  }

  page "/physics-reflection" as ReflectionEnginePage -> ReflectionSim
}
