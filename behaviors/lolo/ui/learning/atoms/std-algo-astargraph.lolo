app std-algo-astargraph "1.0.0"
"Algorithm-animation engine (algorithm-canvas): A* engine — each tick expands the min-f (g+straight-line-h) node toward the goal on the weighted biology-canvas."
orbital AstarGraphEngineOrbital {
  type GraphNode = {
    id : string!
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    kind : "cell" | "organelle" | "molecule" | "organism"
  }
  type GraphEdge = {
    from : string!
    to : string!
    color : string
    label : string
  }
  type WEdge = {
    from : string!
    to : string!
    w : number!
  }
  type Dist = {
    id : string!
    d : number!
  }
  type FEntry = {
    id : string!
    f : number!
  }

  entity AstarScene [runtime] {
    id : string!
    nodes : [GraphNode]
    edges : [GraphEdge]
    wedges : [WEdge]
    gscore : [Dist]
    visited : [string]
    openF : [FEntry]
    goal : string = ""
    goalX : number = 0
    goalY : number = 0
    cur : string = ""
    minF : number = 0
    distU : number = 0
    done : boolean = false
    running : boolean = true
  }

  trait AstarSim -> @rebindable AstarScene [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.nodes @config.nodes)
        (set @entity.edges @config.edges)
        (set @entity.wedges @config.wedges)
        (set @entity.gscore @config.gscore)
        (set @entity.running @config.running)
        (set @entity.goal @config.goal)
        (set @entity.goalX
          (object/get (array/first (array/filter @entity.nodes (fn nd (== (object/get @nd id) @config.goal)))) x))
        (set @entity.goalY
          (object/get (array/first (array/filter @entity.nodes (fn nd (== (object/get @nd id) @config.goal)))) y))
        (set @entity.visited [])
        (set @entity.openF [])
        (set @entity.cur "")
        (set @entity.minF 0)
        (set @entity.distU 0)
        (set @entity.done false)
        (render-ui main {
          type: biology-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          nodes: @entity.nodes
          edges: @entity.edges
        })
        (emit NODES_UPDATED { nodes: @entity.nodes, edges: @entity.edges })
    }

    ticks {
      astarTick every 500ms
        when (and @entity.running (not @entity.done))
        (set @entity.openF
          (array/map
            (array/filter @entity.gscore (fn gs
              (and (not (array/includes @entity.visited (object/get @gs id)))
                   (< (object/get @gs d) 9999))))
            (fn gs
              (let ( (gid (object/get @gs id)) (gd (object/get @gs d)) )
                (let ( (nd (array/first (array/filter @entity.nodes (fn n2 (== (object/get @n2 id) @gid))))) )
                  (let ( (nx (object/get @nd x)) (ny (object/get @nd y)) )
                    (let ( (hh (math/round (math/sqrt (+ (* (- @nx @entity.goalX) (- @nx @entity.goalX))
                                                         (* (- @ny @entity.goalY) (- @ny @entity.goalY)))))) )
                      { id: @gid, f: (+ @gd @hh) })))))))
        (set @entity.minF (array/min (array/map @entity.openF (fn of (object/get @of f)))))
        (set @entity.cur
          (object/get
            (array/first (array/filter @entity.openF (fn of (== (object/get @of f) @entity.minF))))
            id))
        (set @entity.distU
          (object/get
            (array/first (array/filter @entity.gscore (fn gs (== (object/get @gs id) @entity.cur))))
            d))
        (set @entity.visited (array/append @entity.visited @entity.cur))
        (set @entity.gscore
          (array/map @entity.gscore (fn row
            (let ( (nid (object/get @row id)) (dcur (object/get @row d)) )
              (object/merge @row {
                d: (let ( (matches (array/filter @entity.wedges (fn w
                            (or (and (== (object/get @w from) @entity.cur) (== (object/get @w to) @nid))
                                (and (== (object/get @w from) @nid) (== (object/get @w to) @entity.cur)))))) )
                     (if (== (array/len @matches) 0)
                       @dcur
                       (let ( (ww (object/get (array/first @matches) w)) )
                         (if (< (+ @entity.distU @ww) @dcur)
                           (+ @entity.distU @ww)
                           @dcur))))
              })))))
        (set @entity.nodes
          (array/map @entity.nodes (fn nd
            (let ( (nid (object/get @nd id)) )
              (object/merge @nd {
                color: (if (and (== @nid @entity.goal) (not (array/includes @entity.visited @entity.goal))) "#ef4444"
                         (if (== @nid @entity.cur) "#3b82f6"
                           (if (array/includes @entity.visited @nid) "#22c55e"
                             (let ( (grec (array/first (array/filter @entity.gscore (fn gs (== (object/get @gs id) @nid))))) )
                               (if (< (object/get @grec d) 9999) "#f59e0b" "#64748b")))))
              })))))
        (set @entity.done (== @entity.cur @entity.goal))
        (render-ui main {
          type: biology-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          nodes: @entity.nodes
          edges: @entity.edges
        })
        (emit NODES_UPDATED { nodes: @entity.nodes, edges: @entity.edges })
    }

    emits {
      NODES_UPDATED -> external {
        nodes : [GraphNode]
        edges : [GraphEdge]
      }
        @description "The graph each step — a composed listener can subscribe; a harmless no-op standalone."
        @synonyms "tick, frame, step, expand, heuristic, astar, goal, path"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick expands one node per step; toggle to start/pause the search."
        @tier "domain"
      start : string = "A"
        @label "Start Node"
        @description "Id of the node A* searches from."
        @tier "domain"
      goal : string = "G"
        @label "Goal Node"
        @description "Id of the target node; A* stops once it is expanded."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      nodes : [GraphNode] = [
        { id: "A", x: 60, y: 340, radius: 20, color: "#f59e0b", label: "A", kind: cell },
        { id: "B", x: 180, y: 200, radius: 20, color: "#cbd5e1", label: "B", kind: cell },
        { id: "C", x: 200, y: 340, radius: 20, color: "#cbd5e1", label: "C", kind: cell },
        { id: "D", x: 340, y: 180, radius: 20, color: "#cbd5e1", label: "D", kind: cell },
        { id: "E", x: 360, y: 340, radius: 20, color: "#cbd5e1", label: "E", kind: cell },
        { id: "F", x: 500, y: 200, radius: 20, color: "#cbd5e1", label: "F", kind: cell },
        { id: "G", x: 540, y: 340, radius: 20, color: "#ef4444", label: "G", kind: cell }
      ]
        @label "Nodes"
        @description "Graph vertices; A* recolours them slate→amber(open)→green(closed), blue=current, red=goal."
        @tier "domain"
      edges : [GraphEdge] = [
        { from: "A", to: "B", color: "#9ca3af", label: "186" },
        { from: "A", to: "C", color: "#9ca3af", label: "142" },
        { from: "B", to: "C", color: "#9ca3af", label: "143" },
        { from: "B", to: "D", color: "#9ca3af", label: "163" },
        { from: "C", to: "E", color: "#9ca3af", label: "162" },
        { from: "D", to: "E", color: "#9ca3af", label: "163" },
        { from: "D", to: "F", color: "#9ca3af", label: "163" },
        { from: "E", to: "F", color: "#9ca3af", label: "200" },
        { from: "E", to: "G", color: "#9ca3af", label: "182" },
        { from: "F", to: "G", color: "#9ca3af", label: "148" }
      ]
        @label "Edges"
        @description "Rendered undirected edges (weight in label); drawing only, A* reads wedges."
        @tier "domain"
      wedges : [WEdge] = [
        { from: "A", to: "B", w: 186 },
        { from: "A", to: "C", w: 142 },
        { from: "B", to: "C", w: 143 },
        { from: "B", to: "D", w: 163 },
        { from: "C", to: "E", w: 162 },
        { from: "D", to: "E", w: 163 },
        { from: "D", to: "F", w: 163 },
        { from: "E", to: "F", w: 200 },
        { from: "E", to: "G", w: 182 },
        { from: "F", to: "G", w: 148 }
      ]
        @label "Weighted Edges"
        @description "Undirected weighted adjacency A* relaxes; each weight exceeds its edge's straight-line length so the heuristic stays admissible."
        @tier "domain"
      gscore : [Dist] = [
        { id: "A", d: 0 },
        { id: "B", d: 9999 },
        { id: "C", d: 9999 },
        { id: "D", d: 9999 },
        { id: "E", d: 9999 },
        { id: "F", d: 9999 },
        { id: "G", d: 9999 }
      ]
        @label "G Scores"
        @description "Best-known cost from start per node; start 0, others 9999 (infinity sentinel). Not rendered."
        @tier "domain"
    }
  }

  page "/algo-astargraph" as AstarGraphEnginePage -> AstarSim
}
