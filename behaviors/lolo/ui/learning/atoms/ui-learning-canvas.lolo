app ui-learning-canvas "1.0.0"
"LearningCanvas — UI factory (1:1 with the @almadar/ui learning-canvas pattern)."
orbital LearningCanvasOrbital {
  type LearningCanvasShapesItem = {
    type : "line" | "arrow" | "circle" | "rect" | "polygon" | "path" | "text" | "axis" | "grid"!
    id : string
    x : number
    y : number
    x1 : number
    y1 : number
    x2 : number
    y2 : number
    radius : number
    width : number
    height : number
    points : [LearningCanvasShapesItemPointsItem]
    path : string
    text : string
    label : string
    fontSize : number
    align : "left" | "center" | "right"
    axis : "x" | "y"
    min : number
    max : number
    step : number
    color : string
    fill : string
    lineWidth : number
    opacity : number
  }
  type LearningCanvasShapesItemPointsItem = {
    x : number!
    y : number!
  }
  type LearningCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type LearningCanvasSHAPECLICKPayload = {
    id : string
    type : string
    index : number!
  }
  type LearningCanvasSHAPEHOVERPayload = {
    id : string
    type : string
    index : number!
  }

  entity LearningCanvasItem [runtime] {
    id : string!
  }

  trait LearningCanvasRender -> @rebindable LearningCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          shapes: @config.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          onShapeHover: @config.onShapeHover
          isLoading: @config.isLoading
          error: @config.error
          type: learning-canvas
        })
      UPDATE -> idle
        (render-ui main {
          className: @config.className
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          shapes: @payload.shapes
          interactive: @config.interactive
          animate: @config.animate
          onShapeClick: @config.onShapeClick
          onShapeHover: @config.onShapeHover
          isLoading: @config.isLoading
          error: @config.error
          type: learning-canvas
        })
    }

    emits {
      @config.onShapeClick -> external {
        payload : LearningCanvasSHAPECLICKPayload
      }
        @description "Clicked shape payload: { id?, type?, index }."
        @tier "essential"
      @config.onShapeHover -> external {
        payload : LearningCanvasSHAPEHOVERPayload
      }
        @description "Hovered shape payload: { id?, type?, index }."
        @tier "essential"
    }

    listens {
      UPDATE {
        shapes : [LearningCanvasShapesItem]
      }
        @description "Live scene update; payload carries the current drawable state."
        @synonyms "tick, redraw, animate, frame"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes."
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "Canvas width in CSS pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in CSS pixels."
        @tier "presentation"
      backgroundColor : string = "Background Color"
        @label "Background Color"
        @description "Background color (default transparent)."
        @tier "presentation"
      shapes : [LearningCanvasShapesItem] = [{ type: line, id: "Id", x: 1, y: 1, x1: 1, y1: 1, x2: 1, y2: 1, radius: 1, width: 1, height: 1, points: [{ x: 1, y: 1 }, { x: 2, y: 2 }], path: "Path", text: "Text", label: "Label", fontSize: 1, align: left, axis: x, min: 1, max: 1, step: 1, color: "Color", fill: "Fill", lineWidth: 1, opacity: 1 }, { type: arrow, id: "Id 2", x: 2, y: 2, x1: 2, y1: 2, x2: 2, y2: 2, radius: 2, width: 2, height: 2, points: [{ x: 1, y: 1 }, { x: 2, y: 2 }], path: "Path 2", text: "Text 2", label: "Label 2", fontSize: 2, align: center, axis: y, min: 2, max: 2, step: 2, color: "Color 2", fill: "Fill 2", lineWidth: 2, opacity: 2 }]
        @label "Shapes"
        @description "Declarative shapes to draw."
        @tier "presentation"
      interactive : boolean = false
        @label "Interactive"
        @description "Enable pointer interaction (click/hover)."
        @tier "presentation"
      animate : boolean = false
        @label "Animate"
        @description "Enable continuous redraw loop."
        @tier "presentation"
      onShapeClick : string = "SHAPE_CLICK"
        @label "On Shape Click"
        @description "Clicked shape payload: { id?, type?, index }."
        @tier "presentation"
      onShapeHover : string = "SHAPE_HOVER"
        @label "On Shape Hover"
        @description "Hovered shape payload: { id?, type?, index }."
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state."
        @tier "presentation"
      error : LearningCanvasError
        @label "Error"
        @description "Error state."
        @tier "presentation"
    }
  }

  page "/learning-canvas" as LearningCanvasPage -> LearningCanvasRender
}
