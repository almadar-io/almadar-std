app std-math-numberline "1.0.0"
"Integer number-line engine — a marker hops integer-by-integer along y=0 on math-canvas, sweeping -9..9 via a phase-driven step."
orbital MathNumberlineEngineOrbital {
  type MathSample = {
    x : number!
    y : number!
  }

  type MathCurve = {
    label : string
    color : string
    samples : [MathSample]
  }

  type MathPoint = {
    x : number!
    y : number!
    label : string
    color : string
    radius : number
  }

  entity MathNumberlineState [runtime] {
    id : string!
    phase : number = 0
    curves : [MathCurve]
    points : [MathPoint]
    running : boolean = false
  }

  trait MathNumberlineSim -> @rebindable MathNumberlineState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.phase 0)
        (set @entity.curves @config.curves)
        (set @entity.points @config.points)
        (set @entity.running @config.running)
        (render-ui main {
          type: math-canvas
          width: @config.width
          height: @config.height
          curves: @entity.curves
          points: @entity.points
        })
        (emit LINE_UPDATED { curves: @entity.curves, points: @entity.points })
    }

    ticks {
      numberlineTick every 32ms
        when @entity.running
        (let (
          (nphase (+ @entity.phase 3))
        )
        (let (
          (pos (- (math/mod (math/round (/ @nphase 10)) 19) 9))
        )
        (do
          (set @entity.phase @nphase)
          (set @entity.points (array/map @entity.points (fn p
            (if (= (object/get @p label) "n")
              (object/merge @p { x: @pos })
              @p))))
          (render-ui main {
            type: math-canvas
            width: @config.width
            height: @config.height
            curves: @entity.curves
            points: @entity.points
          })
          (emit LINE_UPDATED { curves: @entity.curves, points: @entity.points })
        )))
    }

    emits {
      LINE_UPDATED -> external {
        curves : [MathCurve]
        points : [MathPoint]
      }
        @description "The current scene each tick — a composed listener (readout, graph) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick advances the phase and hops the marker to the next integer; toggle to start/pause."
        @tier "domain"
      curves : [MathCurve] = [
        { label: "", color: "#94a3b8", samples: [{ x: -9, y: 0 }, { x: 9, y: 0 }] }
      ]
        @label "Curves"
        @description "The number line itself: a single horizontal segment along y=0 from x=-9 to x=9 in data coordinates."
        @tier "domain"
      points : [MathPoint] = [
        { x: -9, y: 0, label: "-9", color: "#94a3b8", radius: 2 },
        { x: -8, y: 0, label: "-8", color: "#94a3b8", radius: 2 },
        { x: -7, y: 0, label: "-7", color: "#94a3b8", radius: 2 },
        { x: -6, y: 0, label: "-6", color: "#94a3b8", radius: 2 },
        { x: -5, y: 0, label: "-5", color: "#94a3b8", radius: 2 },
        { x: -4, y: 0, label: "-4", color: "#94a3b8", radius: 2 },
        { x: -3, y: 0, label: "-3", color: "#94a3b8", radius: 2 },
        { x: -2, y: 0, label: "-2", color: "#94a3b8", radius: 2 },
        { x: -1, y: 0, label: "-1", color: "#94a3b8", radius: 2 },
        { x: 0, y: 0, label: "0", color: "#94a3b8", radius: 2 },
        { x: 1, y: 0, label: "1", color: "#94a3b8", radius: 2 },
        { x: 2, y: 0, label: "2", color: "#94a3b8", radius: 2 },
        { x: 3, y: 0, label: "3", color: "#94a3b8", radius: 2 },
        { x: 4, y: 0, label: "4", color: "#94a3b8", radius: 2 },
        { x: 5, y: 0, label: "5", color: "#94a3b8", radius: 2 },
        { x: 6, y: 0, label: "6", color: "#94a3b8", radius: 2 },
        { x: 7, y: 0, label: "7", color: "#94a3b8", radius: 2 },
        { x: 8, y: 0, label: "8", color: "#94a3b8", radius: 2 },
        { x: 9, y: 0, label: "9", color: "#94a3b8", radius: 2 },
        { x: -9, y: 0, label: "n", color: "#dc2626", radius: 6 }
      ]
        @label "Points"
        @description "19 gray integer tick dots along y=0 plus one bold red marker 'n' that hops between them each tick."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
    }
  }

  page "/math-numberline" as MathNumberlineEnginePage -> MathNumberlineSim
}
