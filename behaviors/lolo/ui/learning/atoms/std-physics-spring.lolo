app std-physics-spring "1.0.0"
"Spring engine — Hooke's-law restoring force toward an anchor each tick; renders physics-canvas, composed via `uses`."
orbital SpringEngineOrbital {
  type SpringBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity SpringState [runtime] {
    id : string!
    bodies : [SpringBody]
    running : boolean = false
  }

  trait SpringSim -> @rebindable SpringState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      springTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (a (* (* -1 @config.springK) (- (object/get @b x) @config.anchorX)))
          )
          (let (
            (nvx (* (+ (object/get @b vx) @a) @config.damping))
          )
          (let (
            (nx (+ (object/get @b x) @nvx))
          )
          (object/merge @b {
            x: (math/clamp @nx (object/get @b radius) (- @config.width (object/get @b radius))),
            vx: @nvx
          })))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [SpringBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      springK : number = 0.02
        @label "Spring Constant"
        @description "Restoring-force strength pulling each body toward the anchor (Hooke's law k)."
        @tier "domain"
      damping : number = 0.99
        @label "Damping"
        @description "Fraction of velocity retained each tick (energy loss)."
        @tier "domain"
      anchorX : number = 300
        @label "Anchor X"
        @description "Horizontal position each body oscillates around."
        @tier "domain"
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels; bounds body position."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each body's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 10
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
      bodies : [SpringBody] = [
        { id: "ball-a", x: 120, y: 200, radius: 14, color: "#2563eb", label: "A", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-b", x: 300, y: 200, radius: 14, color: "#16a34a", label: "B", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-c", x: 480, y: 200, radius: 14, color: "#dc2626", label: "C", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Initial bodies; each oscillates around anchorX (300) by Hooke's law."
        @tier "domain"
    }
  }

  page "/physics-spring" as SpringEnginePage -> SpringSim
}
