app std-physics-pendulum "1.0.0"
"Pendulum engine — swings a bob about a fixed pivot via rigid-length projection; renders physics-canvas via uses."
orbital PendulumEngineOrbital {
  type PendulumBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  type PendulumConstraint = {
    from : string!
    to : string!
    color : string
  }

  entity PendulumState [runtime] {
    id : string!
    bodies : [PendulumBody]
    running : boolean = false
  }

  trait PendulumSim -> @rebindable PendulumState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          constraints: @config.constraints
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      pendulumTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (if (= (object/get @b id) "pivot")
            @b
            (let (
              (nvy (* (+ (object/get @b vy) @config.gravity) @config.damping))
              (nvx (* (object/get @b vx) @config.damping))
            )
            (let (
              (px (+ (object/get @b x) @nvx))
              (py (+ (object/get @b y) @nvy))
            )
            (let (
              (dx (- @px @config.pivotX))
              (dy (- @py @config.pivotY))
            )
            (let (
              (dist (math/sqrt (+ (* @dx @dx) (* @dy @dy))))
            )
            (let (
              (s (/ @config.length @dist))
            )
            (let (
              (cxp (+ @config.pivotX (* @dx @s)))
              (cyp (+ @config.pivotY (* @dy @s)))
            )
            (object/merge @b {
              x: @cxp,
              y: @cyp,
              vx: (- @cxp (object/get @b x)),
              vy: (- @cyp (object/get @b y))
            })))))))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          constraints: @config.constraints
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [PendulumBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      gravity : number = 0.5
        @label "Gravity"
        @description "Downward acceleration added to the bob's vy every tick before the length projection."
        @tier "domain"
      damping : number = 0.995
        @label "Damping"
        @description "Fraction of the bob's velocity retained each tick (air resistance)."
        @tier "domain"
      length : number = 170
        @label "Length"
        @description "Rigid string length — the radius the bob is projected back onto each tick."
        @tier "domain"
      pivotX : number = 300
        @label "Pivot X"
        @description "X coordinate of the fixed pivot the bob swings about."
        @tier "domain"
      pivotY : number = 70
        @label "Pivot Y"
        @description "Y coordinate of the fixed pivot the bob swings about."
        @tier "domain"
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      constraints : [PendulumConstraint] = [{ from: "pivot", to: "bob", color: "#94a3b8" }]
        @label "Constraints"
        @description "String linking the pivot to the bob, drawn by the physics-canvas."
        @tier "domain"
      bodies : [PendulumBody] = [
        { id: "pivot", x: 300, y: 70, radius: 6, color: "#334155", label: "", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "bob", x: 450, y: 110, radius: 18, color: "#2563eb", label: "", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Initial bodies; the pivot is static, the bob starts off to the side so it swings."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each body's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 5
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
    }
  }

  page "/physics-pendulum" as PendulumEnginePage -> PendulumSim
}
