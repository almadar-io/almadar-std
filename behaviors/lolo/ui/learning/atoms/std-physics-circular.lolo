app std-physics-circular "1.0.0"
"Circular-motion engine — integrates bodies under a central force each tick and renders a physics-canvas via `uses`."
orbital CircularEngineOrbital {
  type CircularBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity CircularState [runtime] {
    id : string!
    bodies : [CircularBody]
    running : boolean = false
  }

  trait CircularSim -> @rebindable CircularState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      circularTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (ax (* (* -1 @config.centerK) (- (object/get @b x) @config.centerX)))
            (ay (* (* -1 @config.centerK) (- (object/get @b y) @config.centerY)))
          )
          (let (
            (nvx (+ (object/get @b vx) @ax))
            (nvy (+ (object/get @b vy) @ay))
          )
          (let (
            (nx (+ (object/get @b x) @nvx))
            (ny (+ (object/get @b y) @nvy))
          )
          (object/merge @b {
            x: @nx,
            y: @ny,
            vx: @nvx,
            vy: @nvy
          })))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [CircularBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      centerK : number = 0.0009
        @label "Center Attraction"
        @description "Linear central-force constant; acceleration toward the center scales with distance times this value."
        @tier "domain"
      centerX : number = 300
        @label "Center X"
        @description "X coordinate of the central attractor bodies orbit around."
        @tier "domain"
      centerY : number = 200
        @label "Center Y"
        @description "Y coordinate of the central attractor bodies orbit around."
        @tier "domain"
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each body's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 12
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
      bodies : [CircularBody] = [
        { id: "orbit-a", x: 300, y: 70, radius: 14, color: "#2563eb", label: "A", vx: 3.9, vy: 0, fx: 0, fy: 0 },
        { id: "orbit-b", x: 470, y: 200, radius: 10, color: "#dc2626", label: "B", vx: 0, vy: 5.1, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Initial bodies; each orbits the center with velocity perpendicular to its radius vector."
        @tier "domain"
    }
  }

  page "/physics-circular" as CircularEnginePage -> CircularSim
}
