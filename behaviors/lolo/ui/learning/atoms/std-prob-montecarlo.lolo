app std-prob-montecarlo "1.0.0"
"Monte-Carlo π engine — ~250 points shimmer in a [-5,5] square; the red inside-circle fraction ≈ π/4 estimates π on math-canvas."
orbital MonteCarloEngineOrbital {
  type MCPoint = { x:number! y:number! label:string color:string radius:number }

  entity MonteCarloState [runtime] {
    id : string!
    points : [MCPoint]
    running : boolean = false
  }

  trait MonteCarloSim -> @rebindable MonteCarloState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.points @config.points)
        (set @entity.running @config.running)
        (render-ui main {
          type: math-canvas
          width: @config.width
          height: @config.height
          points: @entity.points
        })
        (emit POINTS_UPDATED { points: @entity.points })
    }

    ticks {
      mcTick every 32ms
        when @entity.running
        (do
          (set @entity.points (array/map @entity.points (fn p
            (let (
              (nx (- (* (math/random) 10) 5))
              (ny (- (* (math/random) 10) 5))
            )
            (let (
              (ncolor (if (< (+ (* @nx @nx) (* @ny @ny)) 25) "#dc2626" "#2563eb"))
            )
            (object/merge @p { x: @nx, y: @ny, color: @ncolor }))))))
          (render-ui main {
            type: math-canvas
            width: @config.width
            height: @config.height
            points: @entity.points
          })
          (emit POINTS_UPDATED { points: @entity.points }))
    }

    emits {
      POINTS_UPDATED -> external {
        points : [MCPoint]
      }
        @description "The current point field each tick — a composed listener (π readout, histogram, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick re-scatters every point uniformly in the [-5,5] square and recolors it; toggle to start/pause."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      points : [MCPoint] = [
        { x: 1.39, y: -4.75, label: "", color: "#dc2626", radius: 2 },
        { x: -2.25, y: -2.77, label: "", color: "#dc2626", radius: 2 },
        { x: 2.36, y: 1.77, label: "", color: "#dc2626", radius: 2 },
        { x: 3.92, y: -4.13, label: "", color: "#2563eb", radius: 2 },
        { x: -0.78, y: -4.7, label: "", color: "#dc2626", radius: 2 },
        { x: -2.81, y: 0.05, label: "", color: "#dc2626", radius: 2 },
