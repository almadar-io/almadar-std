        { id: 22, row: 2, col: 0, value: 1, color: "#0f172a", label: "", room: 1 },
        { id: 23, row: 2, col: 1, value: 1, color: "#0f172a", label: "", room: 0 },
        { id: 24, row: 2, col: 2, value: 1, color: "#0f172a", label: "", room: 1 },
