app std-physics-magnetic "1.0.0"
"Magnetic cyclotron engine — integrates charged bodies under F=qv×B each tick and renders a physics-canvas via `uses`."
orbital MagneticEngineOrbital {
  type MagneticBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity MagneticState [runtime] {
    id : string!
    bodies : [MagneticBody]
    running : boolean = true
  }

  trait MagneticSim -> @rebindable MagneticState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      magneticTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (ax (* @config.qB (object/get @b vy)))
            (ay (* (* -1 @config.qB) (object/get @b vx)))
          )
          (let (
            (nvx (+ (object/get @b vx) @ax))
            (nvy (+ (object/get @b vy) @ay))
          )
          (let (
            (nx (+ (object/get @b x) @nvx))
            (ny (+ (object/get @b y) @nvy))
          )
          (object/merge @b {
            x: @nx,
            y: @ny,
            vx: @nvx,
            vy: @nvy
          })))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [MagneticBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      qB : number = 0.03
        @label "Magnetic Force (qB)"
        @description "Charge times field strength; the perpendicular force it drives turns velocity into circular motion — circle radius equals speed divided by qB."
        @tier "domain"
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each body's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 10
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
      bodies : [MagneticBody] = [
        { id: "q1", x: 200, y: 120, radius: 12, color: "#2563eb", label: "", vx: 0, vy: 4, fx: 0, fy: 0 },
        { id: "q2", x: 420, y: 150, radius: 10, color: "#dc2626", label: "", vx: 0, vy: -3, fx: 0, fy: 0 },
        { id: "q3", x: 320, y: 300, radius: 8, color: "#16a34a", label: "", vx: 5, vy: 0, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Initial charges; each traces its own circle of radius speed / qB — opposite-sign velocities give opposite rotation sense."
        @tier "domain"
    }
  }

  page "/physics-magnetic" as MagneticEnginePage -> MagneticSim
}
