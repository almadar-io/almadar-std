app std-algo-gridbfs "1.0.0"
"Algorithm-animation engine (algorithm-canvas): Grid BFS wavefront — each tick dequeues one open cell and enqueues its non-wall 4-neighbours, expanding toward the target on algorithm-canvas cells."
orbital GridBfsEngineOrbital {
  type AlgoCell = {
    id : number!
    row : number!
    col : number!
    value : number
    color : string
    label : string
  }

  entity GridBfsScene [runtime] {
    id : string!
    cells : [AlgoCell]
    queue : [number]
    seen : [number]
    visited : [number]
    cur : number = 0
    newIds : [number]
    done : boolean = false
    running : boolean = true
  }

  trait GridBfsSim -> @rebindable GridBfsScene [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.cells @config.cells)
        (set @entity.running @config.running)
        (set @entity.queue [@config.startId])
        (set @entity.seen [@config.startId])
        (set @entity.visited [])
        (set @entity.done false)
        (render-ui main {
          type: algorithm-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          cells: @entity.cells
        })
        (emit CELLS_UPDATED { cells: @entity.cells })
    }

    ticks {
      bfsTick every 300ms
        when (and @entity.running (not @entity.done))
        (set @entity.cur (array/first @entity.queue))
        (set @entity.newIds
          (let ( (curcell (array/first (array/filter @entity.cells (== (object/get @item id) @entity.cur)))) )
          (let ( (cr (object/get @curcell row)) (cc (object/get @curcell col)) )
          (array/map
            (array/filter @entity.cells
              (and (== (+ (math/abs (- (object/get @item row) @cr)) (math/abs (- (object/get @item col) @cc))) 1)
                (and (not (== (object/get @item value) 1))
                  (not (array/includes @entity.seen (object/get @item id))))))
            (object/get @item id)))))
        (set @entity.visited (array/append @entity.visited @entity.cur))
        (set @entity.seen (array/concat @entity.seen @entity.newIds))
        (set @entity.queue (array/concat (array/drop @entity.queue 1) @entity.newIds))
        (set @entity.done (or (== (array/len @entity.queue) 0) (array/includes @entity.visited @config.targetId)))
        (set @entity.cells
          (array/map @entity.cells
            (object/merge @item {
              color: (if (== (object/get @item value) 1) "#0f172a"
                       (if (== (object/get @item id) @config.startId) "#3b82f6"
                         (if (== (object/get @item id) @config.targetId)
                           (if (array/includes @entity.visited (object/get @item id)) "#22c55e" "#ef4444")
                           (if (array/includes @entity.visited (object/get @item id)) "#22c55e"
                             (if (array/includes @entity.seen (object/get @item id)) "#f59e0b"
                               "#334155")))))
            })))
        (render-ui main {
          type: algorithm-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          cells: @entity.cells
        })
        (emit CELLS_UPDATED { cells: @entity.cells })
    }

    emits {
      CELLS_UPDATED -> external {
        cells : [AlgoCell]
      }
        @description "The grid each step — a composed listener can subscribe; a harmless no-op standalone."
        @synonyms "tick, frame, step, wavefront, traverse"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick expands the wavefront one cell per step; toggle to start/pause."
        @tier "domain"
      startId : number = 0
        @label "Start Cell"
        @description "Id (row*cols+col) of the cell BFS starts from."
        @tier "domain"
      targetId : number = 119
        @label "Target Cell"
        @description "Id (row*cols+col) of the goal; BFS stops when its wavefront reaches it."
        @tier "domain"
      width : number = 720
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 600
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      backgroundColor : string = "#0f172a"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      cells : [AlgoCell] = [
        { id: 0, row: 0, col: 0, value: 2, color: "#3b82f6", label: "" },
        { id: 1, row: 0, col: 1, value: 0, color: "#334155", label: "" },
        { id: 2, row: 0, col: 2, value: 0, color: "#334155", label: "" },
        { id: 3, row: 0, col: 3, value: 0, color: "#334155", label: "" },
        { id: 4, row: 0, col: 4, value: 0, color: "#334155", label: "" },
        { id: 5, row: 0, col: 5, value: 1, color: "#0f172a", label: "" },
        { id: 6, row: 0, col: 6, value: 0, color: "#334155", label: "" },
        { id: 7, row: 0, col: 7, value: 0, color: "#334155", label: "" },
        { id: 8, row: 0, col: 8, value: 0, color: "#334155", label: "" },
        { id: 9, row: 0, col: 9, value: 0, color: "#334155", label: "" },
        { id: 10, row: 0, col: 10, value: 0, color: "#334155", label: "" },
        { id: 11, row: 0, col: 11, value: 0, color: "#334155", label: "" },
        { id: 12, row: 1, col: 0, value: 0, color: "#334155", label: "" },
        { id: 13, row: 1, col: 1, value: 0, color: "#334155", label: "" },
        { id: 14, row: 1, col: 2, value: 0, color: "#334155", label: "" },
        { id: 15, row: 1, col: 3, value: 0, color: "#334155", label: "" },
        { id: 16, row: 1, col: 4, value: 0, color: "#334155", label: "" },
        { id: 17, row: 1, col: 5, value: 1, color: "#0f172a", label: "" },
        { id: 18, row: 1, col: 6, value: 0, color: "#334155", label: "" },
        { id: 19, row: 1, col: 7, value: 0, color: "#334155", label: "" },
        { id: 20, row: 1, col: 8, value: 0, color: "#334155", label: "" },
        { id: 21, row: 1, col: 9, value: 0, color: "#334155", label: "" },
        { id: 22, row: 1, col: 10, value: 0, color: "#334155", label: "" },
