app std-algo-insertionsort "1.0.0"
"Algorithm-animation engine (algorithm-canvas): Insertion-sort engine — one shift/settle step per tick over a bar array on algorithm-canvas; composed by a learning orbital via `uses`."
orbital InsertionSortEngineOrbital {
  type AlgoBar = {
    value : number!
    color : string
    label : string
  }

  entity InsertionScene [runtime] {
    id : string!
    bars : [AlgoBar]
    i : number = 1
    j : number = 1
    shift : boolean = false
    done : boolean = false
    running : boolean = true
  }

  trait InsertionSortSim -> @rebindable InsertionScene [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bars @config.bars)
        (set @entity.running @config.running)
        (render-ui main {
          type: algorithm-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bars: @entity.bars
        })
        (emit BARS_UPDATED { bars: @entity.bars })
    }

    ticks {
      insertionTick every 300ms
        when (and @entity.running (not @entity.done))
        (set @entity.shift
          (and (>= @entity.j 1)
            (> (object/get (array/nth @entity.bars (- @entity.j 1)) value)
               (object/get (array/nth @entity.bars @entity.j) value))))
        (set @entity.bars
          (let (
            (a (array/nth @entity.bars (- @entity.j 1)))
            (b (array/nth @entity.bars @entity.j))
          )
          (array/map @entity.bars
            (object/merge @item {
              value: (if (and @entity.shift (== @index (- @entity.j 1))) (object/get @b value)
                       (if (and @entity.shift (== @index @entity.j)) (object/get @a value)
                         (object/get @item value)))
              color: (if (== @index @entity.j) "#f59e0b"
                       (if (or (< @index @entity.i) (>= @entity.i (array/len @entity.bars))) "#22c55e"
                         "#3b82f6"))
            }))))
        (set @entity.i (if @entity.shift @entity.i (+ @entity.i 1)))
        (set @entity.j (if @entity.shift (- @entity.j 1) @entity.i))
        (set @entity.done (>= @entity.i (array/len @entity.bars)))
        (render-ui main {
          type: algorithm-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bars: @entity.bars
        })
        (emit BARS_UPDATED { bars: @entity.bars })
    }

    emits {
      BARS_UPDATED -> external {
        bars : [AlgoBar]
      }
        @description "The current bar array each step — a composed listener (a mirror canvas, a readout) can subscribe; a harmless no-op standalone."
        @synonyms "tick, frame, step, redraw, compare, shift, insert"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick performs one shift/settle step; toggle to start/pause the sort."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      bars : [AlgoBar] = [
        { value: 5, color: "#3b82f6", label: "5" },
        { value: 2, color: "#3b82f6", label: "2" },
        { value: 8, color: "#3b82f6", label: "8" },
        { value: 1, color: "#3b82f6", label: "1" },
        { value: 9, color: "#3b82f6", label: "9" },
        { value: 3, color: "#3b82f6", label: "3" },
        { value: 7, color: "#3b82f6", label: "7" },
        { value: 4, color: "#3b82f6", label: "4" }
      ]
        @label "Bars"
        @description "Initial unsorted array; each bar's height is proportional to its value."
        @tier "domain"
    }
  }

  page "/algo-insertionsort" as InsertionSortEnginePage -> InsertionSortSim
}
