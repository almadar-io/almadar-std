app std-algo-dijkstra "1.0.0"
"Algorithm-animation engine (algorithm-canvas): Dijkstra engine — each tick settles the nearest unvisited node and relaxes its weighted edges on biology-canvas."
orbital DijkstraEngineOrbital {
  type GraphNode = {
    id : string!
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    kind : "cell" | "organelle" | "molecule" | "organism"
  }
  type GraphEdge = {
    from : string!
    to : string!
    color : string
    label : string
  }
  type WEdge = {
    from : string!
    to : string!
    w : number!
  }
  type Dist = {
    id : string!
    d : number!
  }

  entity DijkstraScene [runtime] {
    id : string!
    nodes : [GraphNode]
    edges : [GraphEdge]
    wedges : [WEdge]
    dists : [Dist]
    visited : [string]
    cur : string = ""
    minD : number = 0
    distU : number = 0
    done : boolean = false
    running : boolean = true
  }

  trait DijkstraSim -> @rebindable DijkstraScene [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.nodes @config.nodes)
        (set @entity.edges @config.edges)
        (set @entity.wedges @config.wedges)
        (set @entity.dists @config.dists)
        (set @entity.running @config.running)
        (set @entity.visited [])
        (set @entity.cur "")
        (set @entity.minD 0)
        (set @entity.distU 0)
        (set @entity.done false)
        (render-ui main {
          type: biology-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          nodes: @entity.nodes
          edges: @entity.edges
        })
        (emit NODES_UPDATED { nodes: @entity.nodes, edges: @entity.edges })
    }

    ticks {
      dijkstraTick every 500ms
        when (and @entity.running (not @entity.done))
        (set @entity.minD
          (array/min
            (array/map
              (array/filter @entity.dists (fn dd (not (array/includes @entity.visited (object/get @dd id)))))
              (fn dd (object/get @dd d)))))
        (set @entity.cur
          (object/get
            (array/first
              (array/filter @entity.dists (fn dd
                (and (not (array/includes @entity.visited (object/get @dd id)))
                     (== (object/get @dd d) @entity.minD)))))
            id))
        (set @entity.distU @entity.minD)
        (set @entity.visited (array/append @entity.visited @entity.cur))
        (set @entity.dists
          (array/map @entity.dists (fn row
            (let ( (nid (object/get @row id)) (dcur (object/get @row d)) )
              (object/merge @row {
                d: (let ( (matches (array/filter @entity.wedges (fn w
                            (or (and (== (object/get @w from) @entity.cur) (== (object/get @w to) @nid))
                                (and (== (object/get @w from) @nid) (== (object/get @w to) @entity.cur)))))) )
                     (if (== (array/len @matches) 0)
                       @dcur
                       (let ( (ww (object/get (array/first @matches) w)) )
                         (if (< (+ @entity.distU @ww) @dcur)
                           (+ @entity.distU @ww)
                           @dcur))))
              })))))
        (set @entity.nodes
          (array/map @entity.nodes (fn nd
            (let ( (nid (object/get @nd id)) )
              (object/merge @nd {
                color: (if (== @nid @entity.cur) "#3b82f6"
                         (if (array/includes @entity.visited @nid) "#22c55e"
                           (let ( (drec (array/first (array/filter @entity.dists (fn dd (== (object/get @dd id) @nid))))) )
                             (if (< (object/get @drec d) 9999) "#f59e0b" "#64748b"))))
              })))))
        (set @entity.done
          (== (array/len
                (array/filter @entity.dists (fn dd
                  (and (not (array/includes @entity.visited (object/get @dd id)))
                       (< (object/get @dd d) 9999)))))
              0))
        (render-ui main {
          type: biology-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          nodes: @entity.nodes
          edges: @entity.edges
        })
        (emit NODES_UPDATED { nodes: @entity.nodes, edges: @entity.edges })
    }

    emits {
      NODES_UPDATED -> external {
        nodes : [GraphNode]
        edges : [GraphEdge]
      }
        @description "The graph each step — a composed listener can subscribe; a harmless no-op standalone."
        @synonyms "tick, frame, step, relax, settle, shortest, path"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick settles one node per step; toggle to start/pause the search."
        @tier "domain"
      start : string = "A"
        @label "Start Node"
        @description "Id of the source node Dijkstra measures distances from."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      nodes : [GraphNode] = [
        { id: "A", x: 300, y: 60, radius: 20, color: "#f59e0b", label: "A", kind: cell },
        { id: "B", x: 150, y: 160, radius: 20, color: "#cbd5e1", label: "B", kind: cell },
        { id: "C", x: 450, y: 160, radius: 20, color: "#cbd5e1", label: "C", kind: cell },
        { id: "D", x: 90, y: 300, radius: 20, color: "#cbd5e1", label: "D", kind: cell },
        { id: "E", x: 240, y: 300, radius: 20, color: "#cbd5e1", label: "E", kind: cell },
        { id: "F", x: 400, y: 300, radius: 20, color: "#cbd5e1", label: "F", kind: cell },
        { id: "G", x: 520, y: 300, radius: 20, color: "#cbd5e1", label: "G", kind: cell }
      ]
        @label "Nodes"
        @description "Graph vertices; Dijkstra recolours them slate→amber(reached)→green(settled), blue=current."
        @tier "domain"
      edges : [GraphEdge] = [
        { from: "A", to: "B", color: "#9ca3af", label: "4" },
        { from: "A", to: "C", color: "#9ca3af", label: "3" },
        { from: "B", to: "C", color: "#9ca3af", label: "1" },
        { from: "B", to: "D", color: "#9ca3af", label: "5" },
        { from: "C", to: "D", color: "#9ca3af", label: "6" },
        { from: "C", to: "E", color: "#9ca3af", label: "8" },
        { from: "D", to: "E", color: "#9ca3af", label: "2" },
        { from: "D", to: "F", color: "#9ca3af", label: "7" },
        { from: "E", to: "F", color: "#9ca3af", label: "3" },
        { from: "E", to: "G", color: "#9ca3af", label: "9" },
        { from: "F", to: "G", color: "#9ca3af", label: "4" }
      ]
        @label "Edges"
        @description "Rendered undirected edges (weight in label); drawing only, algorithm reads wedges."
        @tier "domain"
      wedges : [WEdge] = [
        { from: "A", to: "B", w: 4 },
        { from: "A", to: "C", w: 3 },
        { from: "B", to: "C", w: 1 },
        { from: "B", to: "D", w: 5 },
        { from: "C", to: "D", w: 6 },
        { from: "C", to: "E", w: 8 },
        { from: "D", to: "E", w: 2 },
        { from: "D", to: "F", w: 7 },
        { from: "E", to: "F", w: 3 },
        { from: "E", to: "G", w: 9 },
        { from: "F", to: "G", w: 4 }
      ]
        @label "Weighted Edges"
        @description "Undirected weighted adjacency the relaxation reads; one wedge per drawn edge."
        @tier "domain"
      dists : [Dist] = [
        { id: "A", d: 0 },
        { id: "B", d: 9999 },
        { id: "C", d: 9999 },
        { id: "D", d: 9999 },
        { id: "E", d: 9999 },
        { id: "F", d: 9999 },
        { id: "G", d: 9999 }
      ]
        @label "Distances"
        @description "Best-known distance per node; start 0, others 9999 (infinity sentinel). Not rendered."
        @tier "domain"
    }
  }

  page "/algo-dijkstra" as DijkstraEnginePage -> DijkstraSim
}
