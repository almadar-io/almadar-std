app std-algo-bubblesort "1.0.0"
"Bubble-sort engine — one adjacent compare/swap per tick over a bar array on algorithm-canvas; composed by a learning orbital via `uses`."
orbital BubbleSortEngineOrbital {
  type AlgoBar = {
    value : number!
    color : string
    label : string
  }

  entity BubbleScene [runtime] {
    id : string!
    bars : [AlgoBar]
    i : number = 0
    n : number = 0
    pass : boolean = false
    done : boolean = false
    running : boolean = true
  }

  trait BubbleSortSim -> @rebindable BubbleScene [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bars @config.bars)
        (set @entity.n (array/len @config.bars))
        (set @entity.running @config.running)
        (render-ui main {
          type: algorithm-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bars: @entity.bars
        })
        (emit BARS_UPDATED { bars: @entity.bars })
    }

    ticks {
      bubbleTick every 300ms
        when (and @entity.running (not @entity.done))
        (set @entity.bars
          (let (
            (a (array/nth @entity.bars @entity.i))
            (b (array/nth @entity.bars (+ @entity.i 1)))
          )
          (let (
            (swap (and (> (object/get @a value) (object/get @b value)) (< @entity.i (- @entity.n 1))))
          )
          (array/map @entity.bars
            (object/merge @item {
              value: (if (and @swap (== @index @entity.i)) (object/get @b value)
                       (if (and @swap (== @index (+ @entity.i 1))) (object/get @a value)
                         (object/get @item value)))
              color: (if (or (>= @index @entity.n) (<= @entity.n 1)) "#22c55e"
                       (if (and (>= @index @entity.i) (<= @index (+ @entity.i 1))) "#f59e0b"
                         "#3b82f6"))
            })))))
        (set @entity.pass (>= @entity.i (- @entity.n 2)))
        (set @entity.done (and @entity.pass (<= @entity.n 1)))
        (set @entity.n (if @entity.pass (- @entity.n 1) @entity.n))
        (set @entity.i (if @entity.pass 0 (+ @entity.i 1)))
        (render-ui main {
          type: algorithm-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bars: @entity.bars
        })
        (emit BARS_UPDATED { bars: @entity.bars })
    }

    emits {
      BARS_UPDATED -> external {
        bars : [AlgoBar]
      }
        @description "The current bar array each step — a composed listener (a mirror canvas, a readout) can subscribe; a harmless no-op standalone."
        @synonyms "tick, frame, step, redraw, compare, swap"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the tick performs one compare/swap step; toggle to start/pause the sort."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Canvas width in pixels."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height in pixels."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      bars : [AlgoBar] = [
        { value: 5, color: "#3b82f6", label: "5" },
        { value: 2, color: "#3b82f6", label: "2" },
        { value: 8, color: "#3b82f6", label: "8" },
        { value: 1, color: "#3b82f6", label: "1" },
        { value: 9, color: "#3b82f6", label: "9" },
        { value: 3, color: "#3b82f6", label: "3" },
        { value: 7, color: "#3b82f6", label: "7" },
        { value: 4, color: "#3b82f6", label: "4" }
      ]
        @label "Bars"
        @description "Initial unsorted array; each bar's height is proportional to its value."
        @tier "domain"
    }
  }

  page "/algo-bubblesort" as BubbleSortEnginePage -> BubbleSortSim
}
