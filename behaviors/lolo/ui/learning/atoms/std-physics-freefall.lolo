app std-physics-freefall "1.0.0"
"Free-fall engine — bodies drop under gravity, bounce off floor/walls losing energy; composed via `uses`."
orbital FreeFallEngineOrbital {
  type FreeFallBody = {
    id : string
    x : number!
    y : number!
    radius : number
    color : string
    label : string
    vx : number
    vy : number
    fx : number
    fy : number
  }

  entity FreeFallState [runtime] {
    id : string!
    bodies : [FreeFallBody]
    running : boolean = false
  }

  trait FreeFallSim -> @rebindable FreeFallState [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.bodies @config.bodies)
        (set @entity.running @config.running)
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    ticks {
      freefallTick every 32ms
        when @entity.running
        (set @entity.bodies (array/map @entity.bodies (fn b
          (let (
            (r (object/get @b radius))
            (nvx (* (object/get @b vx) @config.damping))
            (nvy (* (+ (object/get @b vy) @config.gravity) @config.damping))
          )
          (let (
            (nx (+ (object/get @b x) @nvx))
            (ny (+ (object/get @b y) @nvy))
          )
          (let (
            (hitx (or (< @nx @r) (> @nx (- @config.width @r))))
            (hity (or (< @ny @r) (> @ny (- @config.height @r))))
          )
          (object/merge @b {
            x: (math/clamp @nx @r (- @config.width @r)),
            y: (math/clamp @ny @r (- @config.height @r)),
            vx: (if @hitx (* @nvx (* -1 @config.restitution)) @nvx),
            vy: (if @hity (* @nvy (* -1 @config.restitution)) @nvy)
          })))))))
        (render-ui main {
          type: physics-canvas
          width: @config.width
          height: @config.height
          backgroundColor: @config.backgroundColor
          bodies: @entity.bodies
          showVelocity: @config.showVelocity
          showForces: false
          velocityScale: @config.velocityScale
        })
        (emit BODIES_UPDATED { bodies: @entity.bodies })
    }

    emits {
      BODIES_UPDATED -> external {
        bodies : [FreeFallBody]
      }
        @description "The current scene each tick — a composed listener (graph, readout, mirror canvas) can subscribe; a harmless no-op when the atom runs standalone."
        @synonyms "tick, frame, step, redraw"
        @tier "domain"
    }

    config {
      gravity : number = 0.5
        @label "Gravity"
        @description "Downward acceleration added to each body's vy every tick."
        @tier "domain"
      restitution : number = 0.8
        @label "Restitution"
        @description "Fraction of speed kept when a body bounces off the floor or a wall."
        @tier "domain"
      damping : number = 0.995
        @label "Damping"
        @description "Fraction of velocity retained each tick (air resistance)."
        @tier "domain"
      running : boolean = true
        @label "Running"
        @description "When true the tick integrates; toggle to start/pause the sim."
        @tier "domain"
      width : number = 600
        @label "Width"
        @description "Simulation width in pixels; bounds the bounce."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Simulation height in pixels; bounds the bounce."
        @tier "presentation"
      backgroundColor : string = "#f8fafc"
        @label "Background Color"
        @description "Canvas background color."
        @tier "presentation"
      showVelocity : boolean = true
        @label "Show Velocity"
        @description "Draw each body's velocity vector as an arrow."
        @tier "presentation"
      velocityScale : number = 8
        @label "Velocity Scale"
        @description "Length multiplier for the velocity arrows."
        @tier "presentation"
      bodies : [FreeFallBody] = [
        { id: "ball-a", x: 100, y: 40, radius: 16, color: "#2563eb", label: "A", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-b", x: 300, y: 70, radius: 13, color: "#16a34a", label: "B", vx: 0, vy: 0, fx: 0, fy: 0 },
        { id: "ball-c", x: 480, y: 100, radius: 10, color: "#dc2626", label: "C", vx: 0, vy: 0, fx: 0, fy: 0 }
      ]
        @label "Bodies"
        @description "Initial bodies; each starts high with zero velocity so it drops straight down and bounces."
        @tier "domain"
    }
  }

  page "/physics-freefall" as FreeFallEnginePage -> FreeFallSim
}
