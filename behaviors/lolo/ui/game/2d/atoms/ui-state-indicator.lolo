app ui-state-indicator "1.0.0"
"StateIndicator — UI factory (1:1 with the @almadar/ui state-indicator pattern)."
orbital StateIndicatorOrbital {
  type StateIndicatorAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type StateIndicatorStateStylesValue = {
    icon : icon!
    bgClass : string!
  }

  entity StateIndicatorItem [runtime] {
    id : string!
  }

  trait StateIndicatorRender -> @rebindable StateIndicatorItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          assetUrl: @config.assetUrl
          state: @config.stateProp
          label: @config.label
          size: @config.size
          animated: @config.animated
          stateStyles: @config.stateStyles
          className: @config.className
          type: state-indicator
        })
    }

    config {
      assetUrl : StateIndicatorAssetUrl = { url: "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png", role: "decoration", category: "asset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "asset", thumbnailUrl: "" }
        @label "Asset Url"
        @description "Sprite image URL — takes precedence over the state icon when provided"
        @tier "presentation"
      stateProp : string = idle
        @label "State"
        @description "The current state name"
        @synonyms "state"
        @tier "presentation"
      label : string = "Label"
        @label "Label"
        @description "Optional label override (defaults to capitalized state name)"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      animated : boolean = true
        @label "Animated"
        @description "Whether to show pulse animation on non-idle states"
        @tier "presentation"
      stateStyles : Map string StateIndicatorStateStylesValue = {}
        @label "State Styles"
        @description "Custom state styles to extend/override defaults"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/state-indicator" as StateIndicatorPage -> StateIndicatorRender
}
