app ui-item-slot "1.0.0"
"ItemSlot — UI factory (1:1 with the @almadar/ui item-slot pattern)."
orbital ItemSlotOrbital {
  type ItemSlotAssetUrl = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity ItemSlotItem [runtime] {
    id : string!
  }

  trait ItemSlotRender -> @rebindable ItemSlotItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          assetUrl: @config.assetUrl
          icon: @config.icon
          label: @config.label
          quantity: @config.quantity
          rarity: @config.rarity
          empty: @config.empty
          size: @config.size
          selected: @config.selected
          onClick: CLICK
          action: ACTION
          className: @config.className
          type: item-slot
        })
    }

    emits {
      CLICK -> external {
        id : string
      }
        @description "Click handler"
        @tier "essential"
      ACTION -> external {
        id : string
      }
        @description "Declarative event name — emits UI:{action} via eventBus on select"
        @tier "essential"
    }

    config {
      assetUrl : ItemSlotAssetUrl = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }
        @label "Asset Url"
        @description "Sprite asset — takes precedence over icon when provided"
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Icon component or emoji — shown only when assetUrl is absent"
        @tier "presentation"
      label : string = "Iron Sword"
        @label "Label"
        @description "Item label"
        @tier "presentation"
      quantity : number = 0
        @label "Quantity"
        @description "Stack quantity"
        @tier "presentation"
      rarity : "common" | "uncommon" | "rare" | "epic" | "legendary" = uncommon
        @label "Rarity"
        @description "Rarity tier affecting border color"
        @tier "presentation"
      empty : boolean = false
        @label "Empty"
        @description "Whether the slot is empty"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      selected : boolean = false
        @label "Selected"
        @description "Whether the slot is selected"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/item-slot" as ItemSlotPage -> ItemSlotRender
}
