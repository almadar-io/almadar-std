app ui-resource-counter "1.0.0"
"ResourceCounter — UI factory (1:1 with the @almadar/ui resource-counter pattern)."
orbital ResourceCounterOrbital {
  type ResourceCounterAssetUrl = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity ResourceCounterItem [runtime] {
    id : string!
  }

  trait ResourceCounterRender -> @rebindable ResourceCounterItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          assetUrl: @config.assetUrl
          icon: @config.icon
          label: @config.label
          value: @config.value
          max: @config.max
          color: @config.color
          size: @config.size
          className: @config.className
          type: resource-counter
        })
    }

    config {
      assetUrl : ResourceCounterAssetUrl = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }
        @label "Asset Url"
        @description "Sprite asset — takes precedence over icon when provided"
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Icon component or emoji"
        @tier "presentation"
      label : string = Gold
        @label "Label"
        @description "Resource label"
        @tier "presentation"
      value : number = 250
        @label "Value"
        @description "Current value"
        @tier "presentation"
      max : number = 0
        @label "Max"
        @description "Maximum value"
        @tier "presentation"
      color : "primary" | "secondary" | "success" | "warning" | "error" | "muted" = primary
        @label "Color"
        @description "Semantic palette token or an arbitrary Tailwind color class."
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/resource-counter" as ResourceCounterPage -> ResourceCounterRender
}
