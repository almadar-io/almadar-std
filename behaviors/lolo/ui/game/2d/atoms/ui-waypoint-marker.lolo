app ui-waypoint-marker "1.0.0"
"WaypointMarker — UI factory (1:1 with the @almadar/ui waypoint-marker pattern)."
orbital WaypointMarkerOrbital {
  type WaypointMarkerAssetUrl = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity WaypointMarkerItem [runtime] {
    id : string!
  }

  trait WaypointMarkerRender -> @rebindable WaypointMarkerItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          assetUrl: @config.assetUrl
          label: @config.label
          icon: @config.icon
          active: @config.active
          completed: @config.completed
          size: @config.size
          className: @config.className
          type: waypoint-marker
        })
    }

    config {
      assetUrl : WaypointMarkerAssetUrl = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }
        @label "Asset Url"
        @description "Sprite asset — takes precedence over icon when provided"
        @tier "presentation"
      label : string = "Label"
        @label "Label"
        @description "Label text below the marker"
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Custom icon to render inside the marker"
        @tier "presentation"
      active : boolean = true
        @label "Active"
        @description "Whether this waypoint is currently active"
        @tier "presentation"
      completed : boolean = false
        @label "Completed"
        @description "Whether this waypoint has been completed"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/waypoint-marker" as WaypointMarkerPage -> WaypointMarkerRender
}
