app ui-xp-bar "1.0.0"
"XpBar — XP progress display: a labeled stat-badge bar."
orbital XpBarOrbital {
  entity XpBarItem [runtime] {
    id : string!
  }

  trait XpBarRender -> @rebindable XpBarItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: stack
          direction: horizontal
          gap: sm
          align: center
          className: @config.className
          children: [ { type: stat-badge, label: "XP", value: @config.current, max: @config.max, format: bar, icon: "star", size: @config.size } ]
        })
    }

    config {
      current : number = 350
        @label "Current"
        @description "Current XP value"
        @tier "presentation"
      max : number = 1000
        @label "Max"
        @description "XP needed for next level"
        @tier "presentation"
      level : number = 5
        @label "Level"
        @description "Current level (informational)"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/xp-bar" as XpBarPage -> XpBarRender
}
