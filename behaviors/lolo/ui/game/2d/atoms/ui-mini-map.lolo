app ui-mini-map "1.0.0"
"MiniMap — UI factory (1:1 with the @almadar/ui mini-map pattern)."
orbital MiniMapOrbital {
  type MiniMapTilesItem = {
    x : number!
    y : number!
    color : string!
  }
  type MiniMapUnitsItem = {
    x : number!
    y : number!
    color : string!
    isPlayer : boolean
  }
  type MiniMapViewportRect = {
    x : number!
    y : number!
    w : number!
    h : number!
  }
  type MiniMapTileAssetsValue = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }
  type MiniMapUnitAssetsValue = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity MiniMapItem [runtime] {
    id : string!
  }

  trait MiniMapRender -> @rebindable MiniMapItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          tiles: @config.tiles
          units: @config.units
          width: @config.width
          height: @config.height
          mapWidth: @config.mapWidth
          mapHeight: @config.mapHeight
          viewportRect: @config.viewportRect
          className: @config.className
          tileAssets: @config.tileAssets
          unitAssets: @config.unitAssets
          type: mini-map
        })
    }

    config {
      tiles : [MiniMapTilesItem] = [{ x: 1, y: 1, color: "Color" }, { x: 2, y: 2, color: "Color 2" }]
        @label "Tiles"
        @description "Tile data: each tile renders as a 1px dot at (x,y) with the given color"
        @tier "presentation"
      units : [MiniMapUnitsItem] = [{ x: 1, y: 1, color: "Color", isPlayer: false }, { x: 2, y: 2, color: "Color 2", isPlayer: true }]
        @label "Units"
        @description "Unit positions: each unit renders as a 2px dot"
        @tier "presentation"
      width : number = 150
        @label "Width"
        @description "Canvas display width in pixels"
        @tier "presentation"
      height : number = 150
        @label "Height"
        @description "Canvas display height in pixels"
        @tier "presentation"
      mapWidth : number = 100
        @label "Map Width"
        @description "Logical map width (for coordinate scaling)"
        @tier "presentation"
      mapHeight : number = 100
        @label "Map Height"
        @description "Logical map height (for coordinate scaling)"
        @tier "presentation"
      viewportRect : MiniMapViewportRect = { x: 1, y: 1, w: 1, h: 1 }
        @label "Viewport Rect"
        @description "Viewport rectangle outline"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      tileAssets : Map string MiniMapTileAssetsValue = { item: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/sword.png", role: "item", category: "item", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "item", thumbnailUrl: "" } }
        @label "Tile Assets"
        @description "Map of terrain key → Asset; when present, draws sprites instead of flat hex colors for tiles."
        @tier "presentation"
      unitAssets : Map string MiniMapUnitAssetsValue = { item: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/sword.png", role: "item", category: "item", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "item", thumbnailUrl: "" } }
        @label "Unit Assets"
        @description "Map of unit id or unit type → Asset; when present, draws sprites instead of flat dots for units."
        @tier "presentation"
    }
  }

  page "/mini-map" as MiniMapPage -> MiniMapRender
}
