app std-market-flow "1.0.0"
"Headless win/lose authority for market-service boards: owns only result. Listens SERVICE_CHANGED (served + lost) and sets result to won when enough customers are served, lost when too many patience timers expire, else none. Renders nothing."
orbital MarketFlowOrbital {
  entity MarketFlowData [runtime, shared] {
    id : string!
    result : string = "none"
  }

  trait MarketFlow -> @rebindable MarketFlowData [lifecycle] {
    initial: active

    state active {
      INIT -> active
        (set @entity.result "none")

      SERVICE_CHANGED -> active when @config.running
        (set @entity.result (if (>= @payload.served @config.targetServed) "won" (if (>= @payload.lost @config.maxLost) "lost" "none")))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)

      RESTART -> active
        (set @entity.result "none")
    }

    emits {
      GAME_END -> external {
        result : string!
      }
        @description "Emitted when result becomes won or lost"
        @tier "domain"
    }

    listens {
      SERVICE_CHANGED { served : number, pending : number, lost : number }
      RESTART { id : string }
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true, SERVICE_CHANGED signals resolve win/lose; toggle to freeze"
        @tier "domain"
      targetServed : number = 10
        @label "Target Served"
        @description "Cumulative customers served needed to win"
        @tier "domain"
      maxLost : number = 3
        @label "Max Lost"
        @description "Cumulative starved-customer count that ends the round in a loss"
        @tier "domain"
    }
  }

  page "/market-flow" as MarketFlowPage -> MarketFlow
}
