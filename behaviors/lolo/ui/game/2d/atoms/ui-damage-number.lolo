app ui-damage-number "1.0.0"
"DamageNumber — UI factory (1:1 with the @almadar/ui damage-number pattern)."
orbital DamageNumberOrbital {
  type DamageNumberAssetUrl = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity DamageNumberItem [runtime] {
    id : string!
  }

  trait DamageNumberRender -> @rebindable DamageNumberItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          assetUrl: @config.assetUrl
          value: @config.value
          size: @config.size
          className: @config.className
          type: damage-number
        })
    }

    config {
      assetUrl : DamageNumberAssetUrl = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }
        @label "Asset Url"
        @description "Sprite asset — displayed as a hit-effect icon alongside the number"
        @tier "presentation"
      value : number = 42
        @label "Value"
        @description "The damage/heal value to display"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/damage-number" as DamageNumberPage -> DamageNumberRender
}
