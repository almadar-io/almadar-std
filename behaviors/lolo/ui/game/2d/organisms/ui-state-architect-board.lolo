app ui-state-architect-board "1.0.0"
"StateArchitectBoard — visual state-machine graph editor: wire transitions between state nodes so every test case reaches its expected state."
orbital StateArchitectBoardOrbital {
  type StateArchitectBoardError = {
    message : string!
    name    : string
    code    : string
    stack   : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type StateArchitectBoardTransitionsItem = {
    id        : string!
    from      : string!
    to        : string!
    event     : string!
    guardHint : string
  }
  type StateArchitectBoardTestCasesItem = {
    label         : string!
    events        : [string]
    expectedState : string!
  }
  type StateArchitectBoardVariablesItem = {
    id    : string!
    name  : string
    value : string
  }

  entity StateArchitectBoardItem [runtime] {
    id             : string!
    states         : [string]
    initialState   : string
    currentState   : string
    selectedState  : string = ""
    addingFrom     : string = ""
    entityName     : string
    availableEvents: [string]
    transitions    : [StateArchitectBoardTransitionsItem]
    testCases      : [StateArchitectBoardTestCasesItem]
    variables      : [StateArchitectBoardVariablesItem]
    passedTests    : number = 0
    totalTests     : number = 0
    title          : string
    description    : string
    hint           : string
    attempts       : number = 0
    result         : "none" | "win" = none
  }

  trait StateArchitectBoardRender -> @rebindable StateArchitectBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.states          @config.states)
        (set @entity.initialState    @config.initialState)
        (set @entity.currentState    @config.initialState)
        (set @entity.selectedState   "")
        (set @entity.addingFrom      "")
        (set @entity.entityName      @config.entityName)
        (set @entity.availableEvents @config.availableEvents)
        (set @entity.transitions     @config.transitions)
        (set @entity.testCases       @config.testCases)
        (set @entity.variables       @config.variables)
        (set @entity.totalTests      (array/len @config.testCases))
        (set @entity.passedTests     0)
        (set @entity.title           @config.title)
        (set @entity.description     @config.description)
        (set @entity.hint            @config.hint)
        (set @entity.attempts        0)
        (set @entity.result          "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.states          @config.states)
        (set @entity.initialState    @config.initialState)
        (set @entity.currentState    @config.initialState)
        (set @entity.selectedState   "")
        (set @entity.addingFrom      "")
        (set @entity.entityName      @config.entityName)
        (set @entity.availableEvents @config.availableEvents)
        (set @entity.transitions     @config.transitions)
        (set @entity.testCases       @config.testCases)
        (set @entity.variables       @config.variables)
        (set @entity.totalTests      (array/len @config.testCases))
        (set @entity.passedTests     0)
        (set @entity.title           @config.title)
        (set @entity.description     @config.description)
        (set @entity.hint            @config.hint)
        (set @entity.attempts        0)
        (set @entity.result          "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      SELECT_NODE -> playing when (and (!= @entity.addingFrom "") (!= @entity.addingFrom ?stateId))
        (set @entity.transitions (array/append @entity.transitions { id: (array/first @entity.availableEvents), from: @entity.addingFrom, to: ?stateId, event: (array/first @entity.availableEvents) }))
        (set @entity.addingFrom "")
        (set @entity.selectedState "")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      SELECT_NODE -> playing when (and (!= @entity.addingFrom "") (== @entity.addingFrom ?stateId))
        (set @entity.addingFrom "")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      SELECT_NODE -> playing when (== @entity.addingFrom "")
        (set @entity.selectedState ?stateId)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      START_CONNECT -> playing when (!= @entity.selectedState "")
        (set @entity.addingFrom @entity.selectedState)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      REMOVE_TRANSITION -> playing
        (set @entity.transitions (array/filter @entity.transitions (fn t (not (and (== @t.from ?from) (== @t.to ?to) (== @t.event ?event))))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      RUN_TESTS -> complete when (and (> (array/len @entity.transitions) 0) (== @entity.totalTests (array/len (array/filter @entity.testCases (fn tc (== (array/reduce @tc.events (fn st e (object/get (array/find @entity.transitions (fn t (and (== @t.from @st) (== @t.event @e)))) "to" @st)) @entity.initialState) @tc.expectedState))))))
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.passedTests (array/len (array/filter @entity.testCases (fn tc (== (array/reduce @tc.events (fn st e (object/get (array/find @entity.transitions (fn t (and (== @t.from @st) (== @t.event @e)))) "to" @st)) @entity.initialState) @tc.expectedState)))))
        (set @entity.result "win")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })

      RUN_TESTS -> playing when (or (== (array/len @entity.transitions) 0) (!= @entity.totalTests (array/len (array/filter @entity.testCases (fn tc (== (array/reduce @tc.events (fn st e (object/get (array/find @entity.transitions (fn t (and (== @t.from @st) (== @t.event @e)))) "to" @st)) @entity.initialState) @tc.expectedState))))))
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.passedTests (array/len (array/filter @entity.testCases (fn tc (== (array/reduce @tc.events (fn st e (object/get (array/find @entity.transitions (fn t (and (== @t.from @st) (== @t.event @e)))) "to" @st)) @entity.initialState) @tc.expectedState)))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.states          @config.states)
        (set @entity.initialState    @config.initialState)
        (set @entity.currentState    @config.initialState)
        (set @entity.selectedState   "")
        (set @entity.addingFrom      "")
        (set @entity.entityName      @config.entityName)
        (set @entity.availableEvents @config.availableEvents)
        (set @entity.transitions     @config.transitions)
        (set @entity.testCases       @config.testCases)
        (set @entity.variables       @config.variables)
        (set @entity.totalTests      (array/len @config.testCases))
        (set @entity.passedTests     0)
        (set @entity.title           @config.title)
        (set @entity.description     @config.description)
        (set @entity.hint            @config.hint)
        (set @entity.attempts        0)
        (set @entity.result          "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Passed", value: @entity.passedTests }, { label: "Total", value: @entity.totalTests }, { label: "Attempts", value: @entity.attempts }, { label: "Result", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: START_CONNECT, label: "Add Transition", variant: ghost }, { type: button, action: RUN_TESTS, label: "Run Tests", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: state-graph, states: @entity.states, transitions: @entity.transitions, currentState: @entity.currentState, selectedState: @entity.selectedState, addingFrom: @entity.addingFrom, initialState: @entity.initialState, nodeClickEvent: SELECT_NODE } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Transitions" }, { type: data-list, entity: @entity.transitions, fields: [], gap: xs, renderItem: (fn t { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @t.from }, { type: typography, variant: caption, content: @t.event }, { type: typography, variant: caption, content: @t.to }, { type: button, action: REMOVE_TRANSITION, actionPayload: { from: @t.from, to: @t.to, event: @t.event }, label: "Remove", variant: ghost } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Test Cases" }, { type: data-list, entity: @entity.testCases, fields: [], gap: xs, renderItem: (fn tc { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @tc.label }, { type: badge, label: @tc.expectedState } ] }) } ] },
            { type: card, children: [ { type: typography, variant: label, content: "Variables" }, { type: data-list, entity: @entity.variables, fields: [], gap: xs, renderItem: (fn v { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: caption, content: @v.name }, { type: badge, label: @v.value } ] }) } ] }
          ]
        })
    }

    emits {
      SELECT_NODE -> external {
        stateId : string!
      }
        @description "Player clicks a state node; FSM either selects it, cancels a pending connect, or wires a transition from the pending source."
        @tier "domain"
      START_CONNECT -> external {
        id : string
      }
        @description "Player begins wiring a transition from the currently selected state node."
        @tier "domain"
      REMOVE_TRANSITION -> external {
        from  : string!
        to    : string!
        event : string!
      }
        @description "Player removes a transition, identified by its (from, to, event) triple."
        @tier "domain"
      RUN_TESTS -> external {
        id : string
      }
        @description "Player runs the test suite; the FSM simulates each test case through the transition graph and scores passes."
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Reset the puzzle back to the menu."
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : StateArchitectBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      stepDurationMs : number = 600
        @label "Step Duration Ms"
        @description "Playback speed"
        @tier "presentation"
      title : string = "Build the Traffic Light"
        @label "Title"
        @description "Puzzle title shown above the board."
        @tier "domain"
      description : string = "Wire transitions between states so every test case reaches the correct final state."
        @label "Description"
        @description "One-line puzzle brief shown to the player."
        @tier "domain"
      hint : string = "Red must go to Green on ADVANCE. Green must go to Yellow on ADVANCE. Yellow must go back to Red on ADVANCE."
        @label "Hint"
        @description "Optional hint revealed after 3 failed attempts."
        @tier "domain"
      entityName : string = "TrafficLight"
        @label "Entity Name"
        @description "Name of the machine being built, shown in the code view."
        @tier "domain"
      initialState : string = "red"
        @label "Initial State"
        @description "The state the machine starts in when a test begins."
        @tier "domain"
      states : [string] = ["red", "green", "yellow"]
        @label "States"
        @description "All valid states in the puzzle's machine."
        @tier "domain"
      availableEvents : [string] = ["ADVANCE", "RESET"]
        @label "Available Events"
        @description "Events the player can assign to transitions they add."
        @tier "domain"
      transitions : [StateArchitectBoardTransitionsItem] = []
        @label "Transitions"
        @description "The player's current transition graph; empty at puzzle start so they must build it."
        @tier "domain"
      variables : [StateArchitectBoardVariablesItem] = [{ id: "v1", name: "current", value: "red" }]
        @label "Variables"
        @description "Variable panel entries shown in the side panel."
        @tier "domain"
      testCases : [StateArchitectBoardTestCasesItem] = [{ label: "One ADVANCE from red → green", events: ["ADVANCE"], expectedState: "green" }, { label: "Two ADVANCEs from red → yellow", events: ["ADVANCE", "ADVANCE"], expectedState: "yellow" }, { label: "Three ADVANCEs cycle back → red", events: ["ADVANCE", "ADVANCE", "ADVANCE"], expectedState: "red" }]
        @label "Test Cases"
        @description "Ordered event sequences starting from initialState; must all reach expectedState for a win. Non-empty by default so an empty graph cannot win vacuously."
        @tier "domain"
    }
  }

  page "/state-architect-board" as StateArchitectBoardPage -> StateArchitectBoardRender
}
