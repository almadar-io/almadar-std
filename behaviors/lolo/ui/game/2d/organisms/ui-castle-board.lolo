app ui-castle-board "1.0.0"
"CastleBoard — build-and-defend: game-shell + canvas-2d with LOLO-driven sprite animation and combat effects."
orbital CastleBoardOrbital {
  type CastleBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type CastleBoardUnitsItem = {
    id : string!
    position : CastleBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [CastleBoardUnitsItemTraitsItem]
    previousPosition : CastleBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type CastleBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type CastleBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type CastleBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type CastleBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type CastleBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type CastleBoardBuildingsItem = {
    id : string!
    type : string!
    x : number!
    y : number!
    cost : number!
    incomePerTick : number
  }
  type CastleBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }
  type CastleBoardFEATURECLICKFeature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type CastleBoardUNITCLICKUnit = {
    id : string!
    position : CastleBoardUNITCLICKUnitPosition
    x : number
    y : number
    z : number
    sprite : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [CastleBoardUNITCLICKUnitTraitsItem]
    previousPosition : CastleBoardUNITCLICKUnitPreviousPosition
    elevation : number
  }
  type CastleBoardUNITCLICKUnitPosition = {
    x : number!
    y : number!
  }
  type CastleBoardUNITCLICKUnitTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type CastleBoardUNITCLICKUnitPreviousPosition = {
    x : number!
    y : number!
  }

  entity CastleBoardItem [runtime] {
    id : string!
    tiles : [CastleBoardTilesItem]
    units : [CastleBoardUnitsItem]
    features : [CastleBoardFeaturesItem]
    buildings : [CastleBoardBuildingsItem]
    gold : number = 100
    health : number = 20
    maxHealth : number = 20
    wave : number = 0
    tickCount : number = 0
    lastWaveDamage : number = 0
    result : "none" | "victory" | "defeat" = none
    effects : [CastleBoardEffectItem] = []
  }

  trait CastleBoardRender -> @rebindable CastleBoardItem [interaction, instance] {
    initial: idle

    state menu {
      START -> idle
        (set @entity.tiles @config.tiles)
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.buildings [])
        (set @entity.gold 100)
        (set @entity.health 20)
        (set @entity.maxHealth 20)
        (set @entity.wave 0)
        (set @entity.tickCount 0)
        (set @entity.lastWaveDamage 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state idle {
      INIT -> idle
        (set @entity.tiles @config.tiles)
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.buildings [])
        (set @entity.gold 100)
        (set @entity.health 20)
        (set @entity.maxHealth 20)
        (set @entity.wave 0)
        (set @entity.tickCount 0)
        (set @entity.lastWaveDamage 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      FEATURE_CLICK -> idle when (>= @entity.gold 25)
        (set @entity.gold (- @entity.gold 25))
        (set @entity.buildings (array/append @entity.buildings { id: ?featureId, type: ?featureType, x: ?x, y: ?y, cost: 25, incomePerTick: 5 }))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      UNIT_CLICK -> idle
        (set @entity.wave (+ @entity.wave 1))
        (set @entity.health (math/max 0 (- @entity.health 5)))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?unitId) (object/merge @u { animation: "hit" }) @u))))
        (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) y), ttl: 4 }))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      TILE_CLICK -> idle
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      ATTACK -> idle when (let ((ap (object/get (array/find @entity.units (fn u (== @u.id ?attackerId))) position)) (tp (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position))) (and (<= (math/abs (- (object/get @ap x) (object/get @tp x))) 1) (and (<= (math/abs (- (object/get @ap y) (object/get @tp y))) 1) (!= @ap @tp))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?targetId) (object/merge @u { health: (math/max 0 (- (object/get @u health) ?damage)), animation: (if (<= (math/max 0 (- (object/get @u health) ?damage)) 0) "death" "hit") }) (if (== @u.id ?attackerId) (object/merge @u { animation: "attack" }) @u)))))
        (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position) y), ttl: 4 }))
        (if (<= (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) health) 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position) y), ttl: 5 })) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      WAVE_DEFEATED -> victory when (>= @entity.wave 3)
        (set @entity.result "victory")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      CASTLE_HIT -> defeat when (<= @entity.health 0)
        (set @entity.result "defeat")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state victory {
      PLAY_AGAIN -> menu
        (set @entity.tiles @config.tiles)
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.buildings [])
        (set @entity.gold 100)
        (set @entity.health 20)
        (set @entity.maxHealth 20)
        (set @entity.wave 0)
        (set @entity.tickCount 0)
        (set @entity.lastWaveDamage 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state defeat {
      PLAY_AGAIN -> menu
        (set @entity.tiles @config.tiles)
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.buildings [])
        (set @entity.gold 100)
        (set @entity.health 20)
        (set @entity.maxHealth 20)
        (set @entity.wave 0)
        (set @entity.tickCount 0)
        (set @entity.lastWaveDamage 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.units (array/map @entity.units (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      incomeTick every 4s
        when (> @entity.health 0)
        (set @entity.gold (+ @entity.gold (+ 10 (* (array/len @entity.buildings) 5))))
        (set @entity.tickCount (+ @entity.tickCount 1))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      waveTick every 8s
        when (and (> @entity.health 0) (< @entity.wave 3))
        (set @entity.wave (+ @entity.wave 1))
        (set @entity.lastWaveDamage (math/max 0 (- @entity.wave (array/len @entity.buildings))))
        (set @entity.health (math/max 0 (- @entity.health @entity.lastWaveDamage)))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "enemy") (object/merge @u { animation: "attack" }) (if (== @u.team "player") (object/merge @u { animation: (if (<= @entity.health 0) "hit" "idle") }) @u)))))
        (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get (object/get (array/first (array/filter @entity.units (fn u (== @u.team "enemy")))) position) x), y: (object/get (object/get (array/first (array/filter @entity.units (fn u (== @u.team "enemy")))) position) y), ttl: 4 }))
        (if (<= @entity.health 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: 4, y: 4, ttl: 5 })) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Wall HP", value: @entity.health }, { label: "Gold", value: @entity.gold }, { label: "Wave", value: @entity.wave } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
        (emit CASTLE_HIT { damage: @entity.lastWaveDamage })
        (emit WAVE_DEFEATED { wave: @entity.wave })
    }

    emits {
      ATTACK -> external {
        attacker : object
        target : object
        damage : number
        attackerId : string!
        targetId : string!
      }
        @description "-- Callbacks --"
        @tier "essential"
      FEATURE_CLICK -> external {
        feature : CastleBoardFEATURECLICKFeature
        featureId : string!
        featureType : string!
        x : number!
        y : number!
      }
        @description "-- Callback overrides --"
        @tier "essential"
      UNIT_CLICK -> external {
        unit : CastleBoardUNITCLICKUnit
        unitId : string!
      }
        @description "Called when a unit is clicked"
        @tier "essential"
      TILE_CLICK -> external {
        x : number
        y : number
      }
        @description "Called when any tile is clicked"
        @tier "essential"
      WAVE_DEFEATED -> external {
        wave : number!
      }
        @description "Emitted when the player defeats the current wave"
        @tier "essential"
      CASTLE_HIT -> external {
        damage : number!
      }
        @description "Emitted when the castle takes damage from an enemy"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "essential"
    }

    config {
      tiles : [CastleBoardTilesItem] = [{ x: 0, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { x: 1, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { x: 2, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { x: 3, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { x: 4, y: 0, terrain: "planks", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/planks.png", role: "tile", category: "planks", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "planks", thumbnailUrl: "" }, passable: true }, { x: 5, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { x: 6, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-castle-board/default/terrain/stone.png", role: "tile", category: "stone",