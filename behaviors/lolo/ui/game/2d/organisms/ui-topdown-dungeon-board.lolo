          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Turn", value: @entity.turn, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "arrowHead.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-turn", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: END_TURN, label: "End Turn", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "arrowStraight.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-end-turn", thumbnailUrl: "" }, variant: primary }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      enemyAiTick every 1s
        when (and (== @entity.enemyTurn true) (== @entity.result "none"))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "player") (> @u.health 0)) (if (> (array/len (array/filter @entity.units (fn e (and (and (== @e.team "enemy") (> @e.health 0)) (<= (grid/manhattan-distance (object/get @e position) (object/get @u position)) @entity.firingRange))))) 0) (object/merge @u { health: (math/max 0 (- @u.health 1)), animation: (if (<= (math/max 0 (- @u.health 1)) 0) "death" "hit") }) @u) @u))))
        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/first (array/filter @entity.units (fn u (and (== @u.team "player") (> @u.health 0))))) position) x), y: (object/get (object/get (array/first (array/filter @entity.units (fn u (and (== @u.team "player") (> @u.health 0))))) position) y), ttl: 4 }))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "enemy") (> @u.health 0)) (if (== (array/len (array/filter @entity.units (fn p (and (and (== @p.team "player") (> @p.health 0)) (<= (grid/manhattan-distance (object/get @u position) (object/get @p position)) @entity.firingRange))))) 0) (let ((target (array/first (array/filter @entity.units (fn p (and (== @p.team "player") (> @p.health 0))))))) (object/merge @u { position: { x: (math/clamp (+ (object/get (object/get @u position) x) (math/sign (- (object/get (object/get @target position) x) (object/get (object/get @u position) x)))) 0 (- @entity.gridWidth 1)), y: (math/clamp (+ (object/get (object/get @u position) y) (math/sign (- (object/get (object/get @target position) y) (object/get (object/get @u position) y)))) 0 (- @entity.gridHeight 1)) }, animation: "walk" })) (object/merge @u { animation: "attack" })) @u))))
        (set @entity.result (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> @u.health 0))))) 0) "defeat" (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> @u.health 0))))) 0) "victory" "none")))
        (set @entity.enemyTurn false)
        (set @entity.phase (if (!= @entity.result "none") "game_over" "observation"))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Turn", value: @entity.turn, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "arrowHead.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-turn", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: END_TURN, label: "End Turn", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "arrowStraight.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-end-turn", thumbnailUrl: "" }, variant: primary }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      FIRE -> external {
        attacker : object
        target : object
        damage : number
        attackerId : string!
        targetId : string!
      }
        @description "Fired when a tank shoots at a target."
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Called when the battle ends."
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click."
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click."
        @tier "domain"
      END_TURN -> external {
        id : string
      }
        @description "Emits UI:{endTurnEvent} with {} on end turn."
        @tier "domain"
      CANCEL -> external {
        id : string
      }
        @description "Emits UI:{cancelEvent} with {} on cancel."
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset."
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : TopdownDungeonBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [TopdownDungeonBoardTilesItem] = [{ x: 0, y: 0, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,4", role: "tile", category: "tileGrass1", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "tileGrass1", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,4", role: "tile", category: "tileGrass1", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "tileGrass1", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,4", role: "tile", category: "tileGrass1", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "tileGrass1", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,4", role: "tile", category: "tileGrass1", animations: ["static"], style: "pix