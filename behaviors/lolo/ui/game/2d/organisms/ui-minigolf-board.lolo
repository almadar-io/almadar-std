app ui-minigolf-board "1.0.0"
"MinigolfBoard — click tiles to putt the ball across the fairway to the hole. game-shell + canvas-2d with live input wiring (TILE_CLICK + selectedUnitId/validMoves) and a NEXT_HOLE HUD control on completion."
orbital MinigolfBoardOrbital {
  uses AnimTick from "std/behaviors/std-anim-tick"
  type MinigolfBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type MinigolfBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type MinigolfBoardUnitsItem = {
    id : string!
    position : MinigolfBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [MinigolfBoardUnitsItemTraitsItem]
    previousPosition : MinigolfBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type MinigolfBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type MinigolfBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type MinigolfBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type MinigolfBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type MinigolfBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type MinigolfBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  type MinigolfBoardUnitsItemPosition = {
    x : number!
    y : number!
  }

  entity MinigolfBoardItem [runtime] {
    id : string!
    units : [MinigolfBoardUnitsItem]
    hole : number = 1
    strokes : number = 0
    result : "none" | "complete" = none
    effects : [MinigolfBoardEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [MinigolfBoardUnitsItemPosition] = []
  }

  trait MinigolfBoardRender -> @rebindable MinigolfBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.hole 1)
        (set @entity.strokes 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Hole", value: @entity.hole }, { label: "Strokes", value: @entity.strokes }, { type: timer-display, label: "Par", value: @entity.strokes } ] } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      TILE_CLICK -> playing when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.unitType "ball") (object/merge @u { position: { x: ?x, y: ?y }, animation: "roll" }) @u))))
        (set @entity.strokes (+ @entity.strokes 1))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Hole", value: @entity.hole }, { label: "Strokes", value: @entity.strokes }, { type: timer-display, label: "Par", value: @entity.strokes } ] } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      HOLE_IN -> complete when (== @entity.result "none")
        (set @entity.result "complete")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Hole", value: @entity.hole }, { label: "Strokes", value: @entity.strokes }, { type: timer-display, label: "Par", value: @entity.strokes } ] } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    state complete {
      NEXT_HOLE -> playing
        (set @entity.hole (+ @entity.hole 1))
        (set @entity.strokes 0)
        (set @entity.units @config.units)
        (set @entity.result "none")
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Hole", value: @entity.hole }, { label: "Strokes", value: @entity.strokes }, { type: timer-display, label: "Par", value: @entity.strokes } ] } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      PLAY_AGAIN -> playing
        (set @entity.units @config.units)
        (set @entity.hole 1)
        (set @entity.strokes 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Hole", value: @entity.hole }, { label: "Strokes", value: @entity.strokes }, { type: timer-display, label: "Par", value: @entity.strokes } ] } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    ticks {
      renderTick every 100ms
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Hole", value: @entity.hole }, { label: "Strokes", value: @entity.strokes }, { type: timer-display, label: "Par", value: @entity.strokes } ] } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
      HOLE_IN -> external {
        id : string
      }
        @description "Emits when ball reaches the hole"
        @tier "domain"
      NEXT_HOLE -> external {
        id : string
      }
        @description "Emits to advance to the next hole"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits to restart from hole 1"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : MinigolfBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [MinigolfBoardTilesItem] = [{ x: 0, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 1, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 2, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 3, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 4, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: true }, { x: 5, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: true }, { x: 6, y: 0, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: true }, { x: 0, y: 1, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 1, y: 1, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 2, y: 1, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 3, y: 1, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 4, y: 1, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: true }, { x: 5, y: 1, terrain: "hole", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/hole.png", role: "tile", category: "hole", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hole", thumbnailUrl: "" }, passable: true }, { x: 6, y: 1, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: true }, { x: 0, y: 2, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 1, y: 2, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 2, y: 2, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 3, y: 2, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 4, y: 2, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 5, y: 2, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 6, y: 2, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 0, y: 3, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 1, y: 3, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 2, y: 3, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 3, y: 3, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 4, y: 3, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 5, y: 3, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 6, y: 3, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 0, y: 4, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: true }, { x: 1, y: 4, terrain: "fairway", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, passable: true }, { x: 2, y: 4, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 3, y: 4, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 4, y: 4, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 5, y: 4, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }, { x: 6, y: 4, terrain: "green", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, passable: false }]
        @label "Tiles"
        @description "Isometric grid tiles"
        @tier "presentation"
      units : [MinigolfBoardUnitsItem] = [{ id: "ball1", position: { x: 0, y: 4 }, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/units/ball.png", role: "npc", category: "ball", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "ball", thumbnailUrl: "" }, unitType: "ball", name: "Ball", team: player, health: 1, maxHealth: 1, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Units on the board"
        @tier "presentation"
      features : [MinigolfBoardFeaturesItem] = [{ id: "hole1", x: 5, y: 1, type: "hole" }, { id: "flag1", x: 5, y: 1, type: "flag", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/features/flag.png", role: "decoration", category: "flag", animations: ["static"], style: "", variant: "", dimension: "3d", aspect: "1:1", name: "flag", thumbnailUrl: "" } }]
        @label "Features"
        @description "Features (holes, obstacles) on the board"
        @tier "presentation"
      assetManifest : MinigolfBoardAssetManifest = { terrains: { green: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/green.png", role: "tile", category: "green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "green", thumbnailUrl: "" }, fairway: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/fairway.png", role: "tile", category: "fairway", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fairway", thumbnailUrl: "" }, hole: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/terrain/hole.png", role: "tile", category: "hole", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hole", thumbnailUrl: "" } }, units: { ball: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/units/ball.png", role: "npc", category: "ball", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "ball", thumbnailUrl: "" } }, features: { hole: { url: "", role: "decoration", category: "hole", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hole", thumbnailUrl: "" }, flag: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board/default/features/flag.png", role: "decoration", category: "flag", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "flag", thumbnailUrl: "" } }, effects: {} }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  trait MinigolfBoardAnimTick = AnimTick.traits.AnimTick -> MinigolfBoardItem {
    config { frameCount: 8 }
  }

  page "/minigolf-board" as MinigolfBoardPage -> MinigolfBoardRender, MinigolfBoardAnimTick
}
