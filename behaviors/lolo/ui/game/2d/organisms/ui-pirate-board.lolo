        @label "Tiles"
        @description "Sea/island grid tiles"
        @tier "presentation"
      units : [PirateBoardUnitsItem] = [{ id: "u1", position: { x: 1, y: 4 }, unitType: "ship", name: "Galleon", team: player, health: 10, maxHealth: 10, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/units/ship-galleon.png", role: "npc", category: "ship-galleon", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "ship-galleon", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "u2", position: { x: 6, y: 2 }, unitType: "ship", name: "Corsair", team: enemy, health: 8, maxHealth: 10, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/units/ship-corsair.png", role: "npc", category: "ship-corsair", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "ship-corsair", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "u3", position: { x: 4, y: 0 }, unitType: "ship", name: "Scout", team: neutral, health: 6, maxHealth: 6, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/units/ship-galleon.png", role: "npc", category: "ship-galleon", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "ship-galleon", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Ship units on the board"
        @tier "presentation"
      features : [PirateBoardFeaturesItem] = [{ id: "f1", x: 2, y: 1, type: "port", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/features/port.png", role: "decoration", category: "port", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "port", thumbnailUrl: "" } }, { id: "f2", x: 5, y: 5, type: "treasure", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/features/treasure.png", role: "decoration", category: "treasure", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "treasure", thumbnailUrl: "" } }]
        @label "Features"
        @description "Features (ports, treasures) on the board"
        @tier "presentation"
      assetManifest : PirateBoardAssetManifest = { terrains: { sea: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }, island: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/island.png", role: "tile", category: "island", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "island", thumbnailUrl: "" } }, units: { ship: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/units/ship-galleon.png", role: "npc", category: "ship", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "ship", thumbnailUrl: "" } }, features: { port: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/features/port.png", role: "decoration", category: "port", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "port", thumbnailUrl: "" }, treasure: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/features/treasure.png", role: "decoration", category: "treasure", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "treasure", thumbnailUrl: "" } }, effects: { explosion: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/pixelExplosion07.png", role: "effect", category: "explosion", animations: ["static"], style: "", dimension: "2d", aspect: "8:1", name: "explosion", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
    }
  }

  page "/pirate-board" as PirateBoardPage -> PirateBoardRender
}
