app ui-pirate-board "1.0.0"
"PirateBoard — game-shell composition with ship movement, cannon fx, and gold/turn HUD."
orbital PirateBoardOrbital {
  type PirateBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type PirateBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type PirateBoardUnitsItem = {
    id : string!
    position : PirateBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [PirateBoardUnitsItemTraitsItem]
    previousPosition : PirateBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type PirateBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type PirateBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type PirateBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type PirateBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type PirateBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type PirateBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }
  type PirateBoardCANNONFIRETo = {
    x : number!
    y : number!
  }

  entity PirateBoardItem [runtime] {
    id : string!
    ships : [PirateBoardUnitsItem]
    selectedShipId : string
    turn : number = 0
    gold : number = 0
    result : "none" | "victory" | "defeat" = none
    phase : string = "observation"
    gridWidth : number = 8
    gridHeight : number = 8
    movementRange : number = 2
    enemyTurn : boolean = false
    effects : [PirateBoardEffectItem] = []
  }

  trait PirateBoardRender -> @rebindable PirateBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.ships @config.units)
        (set @entity.selectedShipId "")
        (set @entity.turn 0)
        (set @entity.gold 0)
        (set @entity.result "none")
        (set @entity.phase "observation")
        (set @entity.enemyTurn false)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.ships @config.units)
        (set @entity.selectedShipId "")
        (set @entity.turn 0)
        (set @entity.gold 0)
        (set @entity.result "none")
        (set @entity.phase "observation")
        (set @entity.enemyTurn false)
        (set @entity.effects [])
        (set @entity.gridWidth 8)
        (set @entity.gridHeight 8)
        (set @entity.movementRange 2)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      UNIT_CLICK -> playing when (and (== @entity.selectedShipId ?unitId) (== (object/get (array/find @entity.ships (fn u (== @u.id ?unitId))) team) "player"))
        (set @entity.phase "action")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      UNIT_CLICK -> playing when (== (object/get (array/find @entity.ships (fn u (== @u.id ?unitId))) team) "player")
        (set @entity.selectedShipId ?unitId)
        (set @entity.phase "movement")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      TILE_CLICK -> playing when (and (!= @entity.selectedShipId "") (and (grid/in-bounds { x: ?x, y: ?y } @entity.gridWidth @entity.gridHeight) (and (<= (grid/manhattan-distance (object/get (array/find @entity.ships (fn u (== @u.id @entity.selectedShipId))) position) { x: ?x, y: ?y }) @entity.movementRange) (== (array/len (array/filter @entity.ships (fn u (and (== (object/get (object/get @u position) x) ?x) (== (object/get (object/get @u position) y) ?y))))) 0))))
        (set @entity.ships (array/map @entity.ships (fn u (if (== @u.id @entity.selectedShipId) (object/merge @u { position: { x: ?x, y: ?y }, animation: "walk" }) @u))))
        (set @entity.selectedShipId "")
        (set @entity.phase "observation")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      CANNON_FIRE -> playing when (let ((ap (object/get (array/find @entity.ships (fn u (== @u.id ?attackerId))) position)) (tp (object/get (array/find @entity.ships (fn u (== @u.id ?targetId))) position))) (and (<= (math/abs (- (object/get @ap x) (object/get @tp x))) 3) (and (<= (math/abs (- (object/get @ap y) (object/get @tp y))) 3) (!= @ap @tp))))
        (set @entity.ships (array/map @entity.ships (fn u (if (== @u.id ?targetId) (object/merge @u { health: (math/max 0 (- (object/get @u health) ?damage)), animation: (if (<= (math/max 0 (- (object/get @u health) ?damage)) 0) "death" "hit") }) (if (== @u.id ?attackerId) (object/merge @u { animation: "attack" }) @u)))))
        (if (> ?damage 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/find @entity.ships (fn u (== @u.id ?targetId))) position) x), y: (object/get (object/get (array/find @entity.ships (fn u (== @u.id ?targetId))) position) y), ttl: 5 })) null)
        (set @entity.selectedShipId "")
        (set @entity.phase "observation")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      COLLECT_GOLD -> playing
        (set @entity.gold (+ @entity.gold ?amount))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      END_TURN -> playing when (== @entity.result "none")
        (set @entity.turn (+ @entity.turn 1))
        (set @entity.selectedShipId "")
        (set @entity.enemyTurn true)
        (set @entity.phase "enemy_turn")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      CANCEL -> playing when (!= @entity.selectedShipId "")
        (set @entity.selectedShipId "")
        (set @entity.phase "observation")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      GAME_END -> gameover when (or (== (array/len (array/filter @entity.ships (fn u (and (== @u.team "enemy") (> (object/get @u health) 0))))) 0) (== (array/len (array/filter @entity.ships (fn u (and (== @u.team "player") (> (object/get @u health) 0))))) 0))
        (set @entity.result (if (== (array/len (array/filter @entity.ships (fn u (and (== @u.team "player") (> (object/get @u health) 0))))) 0) "defeat" "victory"))
        (set @entity.phase "game_over")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> menu
        (set @entity.ships @config.units)
        (set @entity.selectedShipId "")
        (set @entity.turn 0)
        (set @entity.gold 0)
        (set @entity.result "none")
        (set @entity.phase "observation")
        (set @entity.enemyTurn false)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.ships (array/map @entity.ships (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      enemyAiTick every 1s
        when (and (== @entity.enemyTurn true) (== @entity.result "none"))
        (set @entity.ships (array/map @entity.ships (fn u (if (and (== @u.team "player") (> @u.health 0)) (if (> (array/len (array/filter @entity.ships (fn e (and (and (== @e.team "enemy") (> @e.health 0)) (<= (grid/manhattan-distance (object/get @e position) (object/get @u position)) 3))))) 0) (object/merge @u { health: (math/max 0 (- @u.health 2)), animation: (if (<= (math/max 0 (- @u.health 2)) 0) "death" "hit") }) @u) @u))))
        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/first (array/filter @entity.ships (fn u (and (== @u.team "player") (> @u.health 0))))) position) x), y: (object/get (object/get (array/first (array/filter @entity.ships (fn u (and (== @u.team "player") (> @u.health 0))))) position) y), ttl: 5 }))
        (set @entity.ships (array/map @entity.ships (fn u (if (and (== @u.team "enemy") (> @u.health 0)) (if (== (array/len (array/filter @entity.ships (fn p (and (and (== @p.team "player") (> @p.health 0)) (<= (grid/manhattan-distance (object/get @u position) (object/get @p position)) 3))))) 0) (let ((target (array/first (array/filter @entity.ships (fn p (and (== @p.team "player") (> @p.health 0))))))) (object/merge @u { position: { x: (math/clamp (+ (object/get (object/get @u position) x) (math/sign (- (object/get (object/get @target position) x) (object/get (object/get @u position) x)))) 0 (- @entity.gridWidth 1)), y: (math/clamp (+ (object/get (object/get @u position) y) (math/sign (- (object/get (object/get @target position) y) (object/get (object/get @u position) y)))) 0 (- @entity.gridHeight 1)) }, animation: "walk" })) @u) @u))))
        (set @entity.result (if (== (array/len (array/filter @entity.ships (fn u (and (== @u.team "player") (> @u.health 0))))) 0) "defeat" (if (== (array/len (array/filter @entity.ships (fn u (and (== @u.team "enemy") (> @u.health 0))))) 0) "victory" "none")))
        (set @entity.enemyTurn false)
        (set @entity.phase (if (!= @entity.result "none") "game_over" "observation"))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Turn", value: @entity.turn } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.ships, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    emits {
      CANNON_FIRE -> external {
        attacker : object
        target : object
        damage : number
        attackerId : string!
        targetId : string!
      }
        @description "-- Callbacks --"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Called when the battle at sea ends"
        @tier "domain"
      UNIT_MOVE -> external {
        unit : object
        to : PirateBoardCANNONFIRETo
      }
        @description "Called after a ship moves"
        @tier "domain"
      COLLECT_GOLD -> external {
        amount : number!
      }
        @description "Called when gold is collected"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "-- Declarative event props --"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on ship click"
        @tier "domain"
      END_TURN -> external {
        id : string
      }
        @description "Emits UI:{endTurnEvent} with {} on end turn"
        @tier "domain"
      CANCEL -> external {
        id : string
      }
        @description "Emits UI:{cancelEvent} with {} on cancel"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : PirateBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [PirateBoardTilesItem] = [{"x":0,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":1,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":2,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":3,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":4,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":5,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":6,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":7,"y":0,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":0,"y":1,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":1,"y":1,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":2,"y":1,"terrain":"island","passable":false,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/island.png", role: "tile", category: "island", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "island", thumbnailUrl: "" }},{"x":3,"y":1,"terrain":"island","passable":false,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/island.png", role: "tile", category: "island", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "island", thumbnailUrl: "" }},{"x":4,"y":1,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "sea", thumbnailUrl: "" }},{"x":5,"y":1,"terrain":"sea","passable":true,"terrainSprite":{ url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board/default/terrain/sea.png", role: "tile", category: "sea", animations: ["static"], style: