      UNIT_CLICK -> playing when (and (!= @entity.selectedShipId "") (and (== (object/get (array/find @entity.ships (fn u (== @u.id ?unitId))) team) "enemy") (<= (grid/manhattan-distance (object/get (array/find @entity.ships (fn u (== @u.id @entity.selectedShipId))) position) (object/get (array/find @entity.ships (fn u (== @u.id ?unitId))) position)) @entity.firingRange)))
        (set @entity.ships (array/map @entity.ships (fn u (if (== @u.id ?unitId) (object/merge @u { health: (math/max 0 (- (object/get @u health) 3)), animation: (if (<= (math/max 0 (- (object/get @u health) 3)) 0) "death" "hit") }) (if (== @u.id @entity.selectedShipId) (object/merge @u { animation: "attack" }) @u)))))
        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/find @entity.ships (fn u (== @u.id ?unitId))) position) x), y: (object/get (object/get (array/find @entity.ships (fn u (== @u.id ?unitId))) position) y), ttl: 5 }))
        (set @entity.selectedShipId "")
        (set @entity.validMoves [])
        (set @entity.phase "observation")
        (emit GAME_END)
