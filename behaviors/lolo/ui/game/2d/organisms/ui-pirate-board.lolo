      TILE_CLICK -> playing when (and (!= @entity.selectedShipId "") (and (grid/in-bounds { x: ?x, y: ?y } @entity.gridWidth @entity.gridHeight) (and (<= (grid/manhattan-distance (object/get (array/find @entity.ships (fn u (== @u.id @entity.selectedShipId))) position) { x: ?x, y: ?y }) @entity.movementRange) (== (array/len (array/filter @entity.ships (fn u (and (== (object/get (object/get @u position) x) ?x) (== (object/get (object/get @u position) y) ?y))))) 0))))
        (set @entity.gold (if (and (not (array/includes @entity.visited (str/concat ?x (str/concat "," ?y)))) (> (array/len (array/filter @config.tiles (fn t (and (== (object/get @t terrain) "island") (== (grid/manhattan-distance { x: (object/get @t x), y: (object/get @t y) } { x: ?x, y: ?y }) 1))))) 0)) (+ @entity.gold 5) @entity.gold))
        (set @entity.visited (if (and (not (array/includes @entity.visited (str/concat ?x (str/concat "," ?y)))) (> (array/len (array/filter @config.tiles (fn t (and (== (object/get @t terrain) "island") (== (grid/manhattan-distance { x: (object/get @t x), y: (object/get @t y) } { x: ?x, y: ?y }) 1))))) 0)) (array/append @entity.visited (str/concat ?x (str/concat "," ?y))) @entity.visited))
