app ui-simulator-board "1.0.0"
"SimulatorBoard — parameter-tuning puzzle: adjust params until output is within tolerance of target."
orbital SimulatorBoardOrbital {
  type SimulatorBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type SimulatorBoardParameterItem = {
    id : string!
    label : string
    unit : string
    min : number
    max : number
    step : number
  }

  entity SimulatorBoardItem [runtime] {
    id : string!
    paramA : number = 0
    paramB : number = 0
    target : number = 10
    tolerance : number = 1
    output : number @intrinsic = derived (+ @entity.paramA (* @entity.paramB 2))
    attempts : number = 0
    result : "none" | "win" = none
    parameters : [SimulatorBoardParameterItem]
    title : string
    description : string
    outputLabel : string
  }

  trait SimulatorBoardRender -> @rebindable SimulatorBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.paramA 0)
        (set @entity.paramB 0)
        (set @entity.parameters @config.parameters)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.outputLabel @config.outputLabel)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.paramA 0)
        (set @entity.paramB 0)
        (set @entity.parameters @config.parameters)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.outputLabel @config.outputLabel)
        (set @entity.target @config.target)
        (set @entity.tolerance @config.tolerance)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })
      SET_A -> playing when (== @entity.result "none")
        (set @entity.paramA ?value)
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })

      SET_B -> playing when (== @entity.result "none")
        (set @entity.paramB ?value)
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })

      CHECK -> complete when (<= (math/abs (- @entity.output @entity.target)) @entity.tolerance)
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.result "win")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })

      CHECK -> playing when (> (math/abs (- @entity.output @entity.target)) @entity.tolerance)
        (set @entity.attempts (+ @entity.attempts 1))
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.paramA 0)
        (set @entity.paramB 0)
        (set @entity.parameters @config.parameters)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.outputLabel @config.outputLabel)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: ghost } ] }
          children: [ { type: data-list, entity: @entity.parameters, fields: [], gap: sm, renderItem: (fn it { type: card, title: (object/get it label), subtitle: (object/get it id) }) } ]
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "domain"
      SET_A -> external {
        value : number!
      }
        @description "Sets parameter A from { value } during play."
        @tier "domain"
      SET_B -> external {
        value : number!
      }
        @description "Sets parameter B from { value } during play."
        @tier "domain"
      CHECK -> external {
        id : string
      }
        @description "Evaluates output vs target/tolerance; wins or retries."
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets the puzzle back to the menu."
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SimulatorBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      title : string = "Tune the Formula"
        @label "Title"
        @description "Puzzle title shown above the board."
        @tier "domain"
      outputLabel : string = "Output = A + B × 2"
        @label "Output Label"
        @description "Human-readable formula label shown next to the output value."
        @tier "domain"
      target : number = 10
        @label "Target"
        @description "The output value the player must reach (within tolerance)."
        @tier "domain"
      tolerance : number = 1
        @label "Tolerance"
        @description "Acceptable error margin around the target."
        @tier "domain"
      description : string = "Adjust the sliders so the output lands within tolerance of the target."
        @label "Description"
        @description "One-line puzzle brief shown to the player."
        @tier "domain"
      parameters : [SimulatorBoardParameterItem] = [{ id: "paramA", label: "Base Value (A)", unit: "", min: 0, max: 10, step: 1 }, { id: "paramB", label: "Multiplier (B)", unit: "", min: 0, max: 5, step: 1 }]
        @label "Parameters"
        @description "Slider descriptors — index 0 drives parameter A, index 1 drives parameter B."
        @tier "domain"
    }
  }

  page "/simulator-board" as SimulatorBoardPage -> SimulatorBoardRender
}
