app ui-city-builder-board "1.0.0"
"CityBuilderBoard — isometric city builder: place buildings on a grid, grow population, earn resources. game-shell + canvas-2d with live input wiring (PLACE_BUILDING/SELECT_BUILD_TYPE + selectedUnitId/validMoves) and a build-palette control in the HUD."
orbital CityBuilderBoardOrbital {
  type CityBuilderBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type CityBuilderBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : Asset
    passable : boolean
  }
  type CityBuilderBoardFeaturesItem = {
    id : string!
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type CityBuilderBoardBuildTypesItem = {
    type : string!
    label : string!
    cost : number!
  }
  type CityBuilderBoardCitizensItemPosition = {
    x : number!
    y : number!
  }
  type CityBuilderBoardCitizensItem = {
    id : string!
    position : CityBuilderBoardCitizensItemPosition
    sprite : Asset
    animation : string
    frame : number
  }
  type CityBuilderBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type CityBuilderBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  type CityBuilderBoardUnitsItemPosition = {
    x : number!
    y : number!
  }

  entity CityBuilderBoardItem [runtime] {
    id : string!
    features : [CityBuilderBoardFeaturesItem]
    citizens : [CityBuilderBoardCitizensItem]
    gold : number = 100
    wood : number = 80
    population : number = 0
    pendingBuildType : string = "house"
    result : "none" | "won" | "lost" = none
    tick : number = 0
    effects : [CityBuilderBoardEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [CityBuilderBoardUnitsItemPosition] = []
  }

  trait CityBuilderBoardRender -> @rebindable CityBuilderBoardItem [interaction, instance] {
    initial: building

    state building {
      INIT -> building
        (set @entity.gold @config.gold)
        (set @entity.wood @config.wood)
        (set @entity.population 0)
        (set @entity.features @config.features)
        (set @entity.citizens @config.citizens)
        (set @entity.pendingBuildType @config.pendingBuildType)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      SELECT_BUILD_TYPE -> building when (== @entity.result "none")
        (set @entity.pendingBuildType ?buildType)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      PLACE_BUILDING -> building when (and (== @entity.result "none") (and (>= @entity.gold (object/get (array/first (array/filter @config.buildTypes (fn b (== (object/get @b type) @entity.pendingBuildType)))) cost)) (and (grid/in-bounds { x: ?x, y: ?y } @config.gridWidth @config.gridHeight) (and (== (array/len (array/filter @entity.features (fn b (and (== @b.x ?x) (== @b.y ?y))))) 0) (== (array/len (array/filter @config.tiles (fn tl (and (== (object/get @tl x) ?x) (and (== (object/get @tl y) ?y) (== (object/get @tl passable) false)))))) 0)))))
        (set @entity.gold (- @entity.gold (object/get (array/first (array/filter @config.buildTypes (fn b (== (object/get @b type) @entity.pendingBuildType)))) cost)))
        (set @entity.features (array/concat @entity.features [{ id: (str/concat "bld-" (array/len @entity.features)), x: ?x, y: ?y, type: @entity.pendingBuildType, sprite: (object/get @config.featureSprites @entity.pendingBuildType) }]))
        (set @entity.population (+ @entity.population @config.populationPerBuilding))
        (set @entity.result (if (>= @entity.population @config.targetPopulation) "won" @entity.result))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> building
        (set @entity.gold @config.gold)
        (set @entity.wood @config.wood)
        (set @entity.population 0)
        (set @entity.features @config.features)
        (set @entity.citizens @config.citizens)
        (set @entity.pendingBuildType @config.pendingBuildType)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.citizens (array/map @entity.citizens (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      resourceIncomeTick every 1s
        when (== @entity.result "none")
        (set @entity.tick (+ @entity.tick 1))
        (set @entity.gold (+ @entity.gold (* (array/len @entity.features) @config.goldPerBuilding)))
        (set @entity.wood (+ @entity.wood (* (array/len @entity.features) @config.woodPerBuilding)))
        (set @entity.citizens (array/map @entity.citizens (fn u (let ((nx (math/clamp (+ (object/get (object/get @u position) x) (math/sign (- (math/floor (* (math/random) @config.gridWidth)) (object/get (object/get @u position) x)))) 0 (- @config.gridWidth 1))) (ny (math/clamp (+ (object/get (object/get @u position) y) (math/sign (- (math/floor (* (math/random) @config.gridHeight)) (object/get (object/get @u position) y)))) 0 (- @config.gridHeight 1)))) (object/merge @u { position: { x: @nx, y: @ny }, animation: "walk" })))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population }, { label: "Gold", value: @entity.gold }, { label: "Wood", value: @entity.wood }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, icon: "coins" }, { type: stat-badge, label: "Wood", value: @entity.wood, icon: "tree" }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      SELECT_BUILD_TYPE -> external {
        buildType : string!
      }
        @description "Emits UI:{selectBuildTypeEvent} with {buildType} when player picks a building from the palette"
        @tier "domain"
      PLACE_BUILDING -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{placeBuildingEvent} with {x,y} on tile click when player places a building"
        @tier "domain"
      GAME_END -> external {
        result : string!
      }
        @description "Emits UI:{gameEndEvent} with {result} when the city reaches its goal or collapses"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : CityBuilderBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      gridWidth : number = 12
        @label "Grid Width"
        @description "Number of columns in the tile grid"
        @tier "presentation"
      gridHeight : number = 12
        @label "Grid Height"
        @description "Number of rows in the tile grid"
        @tier "presentation"
      gold : number = 100
        @label "Starting Gold"
        @description "Gold the player starts each game with"
        @tier "presentation"
      wood : number = 80
        @label "Starting Wood"
        @description "Wood the player starts each game with"
        @tier "presentation"
      targetPopulation : number = 12
        @label "Target Population"
        @description "Population to reach for victory"
        @tier "presentation"
      populationPerBuilding : number = 2
        @label "Population Per Building"
        @description "Population added per placed building"
        @tier "presentation"
      goldPerBuilding : number = 2
        @label "Gold Per Building"
        @description "Gold income per building per tick"
        @tier "presentation"
      woodPerBuilding : number = 1
        @label "Wood Per Building"
        @description "Wood income per building per tick"
        @tier "presentation"
      pendingBuildType : string = "house"
        @label "Pending Build Type"
        @description "Initially selected building type from the palette"
        @tier "presentation"
      scale : number = 0.3
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 0.6
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      buildTypes : [CityBuilderBoardBuildTypesItem] = [{ type: "house", label: "House", cost: 20 }, { type: "farm", label: "Farm", cost: 15 }, { type: "barracks", label: "Barracks", cost: 40 }, { type: "library", label: "Library", cost: 30 }, { type: "treasury", label: "Treasury", cost: 50 }, { type: "tower", label: "Tower", cost: 35 }, { type: "mine", label: "Mine", cost: 25 }]
        @label "Build Types"
        @description "Placeable building types shown in the build palette with cost."
        @tier "presentation"
      featureSprites : Map string Asset = { house: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" }, farm: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/farm.png", role: "decoration", category: "farm", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "farm", thumbnailUrl: "" }, barracks: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/barracks.png", role: "decoration", category: "barracks", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "barracks", thumbnailUrl: "" }, library: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/library.png", role: "decoration", category: "library", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "library", thumbnailUrl: "" }, treasury: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/treasury.png", role: "decoration", category: "treasury", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "treasury", thumbnailUrl: "" }, tower: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/tower.png", role: "decoration", category: "tower", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "tower", thumbnailUrl: "" }, mine: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/mine.png", role: "decoration", category: "mine", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "mine", thumbnailUrl: "" } }
        @label "Feature Sprites"
        @description "Per-type sprite URL map for building features."
        @tier "presentation"
      features : [CityBuilderBoardFeaturesItem] = [{ id: "bld-0", x: 1, y: 5, type: "house", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" } }, { id: "bld-1", x: 3, y: 5, type: "house", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" } }, { id: "bld-2", x: 5, y: 5, type: "house", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" } }, { id: "bld-3", x: 1, y: 7, type: "house", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" } }, { id: "bld-4", x: 3, y: 7, type: "house", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" } }, { id: "bld-5", x: 0, y: 9, type: "house", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/house.png", role: "decoration", category: "house", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "house", thumbnailUrl: "" } }, { id: "bld-6", x: 4, y: 1, type: "farm", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/farm.png", role: "decoration", category: "farm", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "farm", thumbnailUrl: "" } }, { id: "bld-7", x: 8, y: 1, type: "library", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/library.png", role: "decoration", category: "library", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "library", thumbnailUrl: "" } }, { id: "bld-8", x: 10, y: 1, type: "treasury", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/treasury.png", role: "decoration", category: "treasury", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "treasury", thumbnailUrl: "" } }, { id: "bld-9", x: 8, y: 3, type: "barracks", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/barracks.png", role: "decoration", category: "barracks", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "barracks", thumbnailUrl: "" } }, { id: "bld-10", x: 10, y: 3, type: "tower", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/tower.png", role: "decoration", category: "tower", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "tower", thumbnailUrl: "" } }, { id: "bld-11", x: 8, y: 6, type: "mine", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/mine.png", role: "decoration", category: "mine", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "mine", thumbnailUrl: "" } }, { id: "bld-12", x: 10, y: 8, type: "mine", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/features/mine.png", role: "decoration", category: "mine", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "mine", thumbnailUrl: "" } }]
        @label "Features"
        @description "Initial building placements rendered as canvas-2d features."
        @tier "presentation"
      citizens : [CityBuilderBoardCitizensItem] = [{ id: "c1", position: { x: 2, y: 5 }, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/units/citizen.png", role: "npc", category: "citizen", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "citizen", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "c2", position: { x: 4, y: 7 }, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/units/citizen.png", role: "npc", category: "citizen", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "citizen", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "c3", position: { x: 6, y: 6 }, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/units/citizen.png", role: "npc", category: "citizen", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "citizen", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Citizens"
        @description "Roaming citizen units displayed on the isometric canvas."
        @tier "presentation"
