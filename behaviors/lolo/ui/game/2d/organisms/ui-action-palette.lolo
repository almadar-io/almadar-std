app ui-action-palette "1.0.0"
"ActionPalette — UI factory (1:1 with the @almadar/ui action-palette pattern)."
orbital ActionPaletteOrbital {
  type ActionPaletteActionsItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : asset
    stateMachine : json
  }
  type ActionPaletteCategoryColorsValue = {
    bg : string!
    border : string!
  }

  entity ActionPaletteItem [runtime] {
    id : string!
  }

  trait ActionPaletteRender -> @rebindable ActionPaletteItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          actions: @config.actions
          usedActionIds: @config.usedActionIds
          allowDuplicates: @config.allowDuplicates
          categoryColors: @config.categoryColors
          size: @config.size
          label: @config.label
          className: @config.className
          type: action-palette
        })
    }

    config {
      actions : [ActionPaletteActionsItem] = [{ id: "Id", name: "Name", category: "Category", description: "Description", iconEmoji: "Icon Emoji", iconUrl: "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png" }, { id: "Id 2", name: "Name 2", category: "Category 2", description: "Description 2", iconEmoji: "Icon Emoji 2", iconUrl: "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png" }]
        @label "Actions"
        @description "Available actions"
        @tier "presentation"
      usedActionIds : [string] = []
        @label "Used Action Ids"
        @description "IDs of actions that are already used (shown as disabled)"
        @tier "presentation"
      allowDuplicates : boolean = true
        @label "Allow Duplicates"
        @description "Whether each action can be used multiple times"
        @tier "presentation"
      categoryColors : Map string ActionPaletteCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      label : string = "Label"
        @label "Label"
        @description "Label above the palette"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/action-palette" as ActionPalettePage -> ActionPaletteRender
}
