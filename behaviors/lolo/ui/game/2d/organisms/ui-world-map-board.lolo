  trait RoundLogic = Frame.traits.RoundLogic -> GameState {
    config { running: true }
  }

  trait GoldAuthority = Frame.traits.GoldAuthority -> GameState {
    config { running: true, startGold: 0, yieldAmount: 25 }
  }

