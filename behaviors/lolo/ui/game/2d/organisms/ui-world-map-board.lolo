app ui-world-map-board "1.0.0"
"WorldMapBoard — isometric overworld travel board with hero movement, enemy encounters, and gold mines."
orbital WorldMapBoardOrbital {
  uses Frame from "std/behaviors/std-worldmap-board-2d"

  type Asset = {
    url : asset
    atlas : asset
    sprite : string
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    sprite : Asset
    unitType : string
    name : string
    team : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    animation : string
    frame : number
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : Asset
    passable : boolean
  }
  type Feature = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type Effect = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type ValidMove = { x : number!  y : number! }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    result : string = "none"
    gold : number = 0
    selectedHeroId : string = ""
    validMoves : [ValidMove] = []
    waypoints : [string] = []
    turn : number = 0
    effects : [Effect] = []
  }

  trait Authority = Frame.traits.TacticsAuthority -> GameState {
    config {
      running: true
      gridWidth: 16
      gridHeight: 16
      attackDamage: 3
      units: [{ id: "u_hero", position: { x: 3, y: 10 }, unitType: "hero", name: "Hero", team: player, health: 10, maxHealth: 10, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-animal-pack-redux/units/round.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-animal-pack-redux/units/round.json", sprite: "bear.png", role: "npc", category: "hero", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hero", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "u_guard", position: { x: 13, y: 4 }, unitType: "guard", name: "Guard", team: enemy, health: 8, maxHealth: 8, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-animal-pack-redux/units/round.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-animal-pack-redux/units/round.json", sprite: "crocodile.png", role: "npc", category: "guard", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "guard", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
      tiles: [{ id: "t0_0", x: 0, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.json", sprite: "landscapeTiles_021.png", role: "tile", category: "forest", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t1_0", x: 1, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.json", sprite: "landscapeTiles_021.png", role: "tile", category: "forest", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t2_0", x: 2, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.json", sprite: "landscapeTiles_021.png", role: "tile", category: "forest", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t3_0", x: 3, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/kenney-isometric-tiles-base/terrain/landscapeTiles_sheet.json", sprite: "landscapeTiles_021.png", role: "tile", category: "fo