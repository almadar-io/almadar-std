app ui-racing-board "1.0.0"
"RacingBoard — steer-first momentum racer on an 8x8 ring track with checkpoints, laps, and a rival car."
orbital RacingBoardOrbital {
  type RacingBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type RacingBoardTilesItem = {
    x : number!
    y : number!
    terrain : string
    passable : boolean
    terrainSprite : Asset
  }
  type RacingBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type RacingBoardUnitsItem = {
    id : string!
    position : RacingBoardUnitsItemPosition
    previousPosition : RacingBoardUnitsItemPosition
    sprite : Asset
    unitType : string
    name : string
    team : "player" | "rival"
    animation : string
    frame : number
    speed : number
    facing : "up" | "down" | "left" | "right"
    nextCheckpoint : number
    lap : number
  }
  type RacingBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type RacingBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type RacingBoardCheckpointsItem = {
    x : number!
    y : number!
    label : string
  }
  type RacingBoardStartLine = {
    x : number!
    y : number!
  }
  type RacingBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity RacingBoardItem [runtime] {
    id : string!
    units : [RacingBoardUnitsItem]
    selectedUnitId : string = ""
    validMoves : [RacingBoardUnitsItemPosition] = []
    lap : number = 1
    position : number = 1
    speed : number = 1
    result : "none" | "victory" | "defeat" = none
    phase : string = "racing"
    effects : [RacingBoardEffectItem] = []
  }

  trait RacingBoardRender -> @rebindable RacingBoardItem [interaction, instance] {
    initial: racing

    state racing {
      INIT -> racing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.lap 1)
        (set @entity.position 1)
        (set @entity.speed 1)
        (set @entity.result "none")
        (set @entity.phase "racing")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      MOVE_LEFT -> racing when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "player") (let ((nx (+ @u.position.x -1)) (ny (+ @u.position.y 0))) (let ((tile (array/find @config.tiles (fn t (and (== @t.x @nx) (== @t.y @ny)))))) (let ((walkable (if (== @tile null) false (object/get @tile passable)))) (if @walkable (object/merge @u { position: { x: @nx, y: @ny }, previousPosition: @u.position, facing: "left", animation: "walk" }) (object/merge @u { facing: "left" }))))) @u))))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      MOVE_RIGHT -> racing when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "player") (let ((nx (+ @u.position.x 1)) (ny (+ @u.position.y 0))) (let ((tile (array/find @config.tiles (fn t (and (== @t.x @nx) (== @t.y @ny)))))) (let ((walkable (if (== @tile null) false (object/get @tile passable)))) (if @walkable (object/merge @u { position: { x: @nx, y: @ny }, previousPosition: @u.position, facing: "right", animation: "walk" }) (object/merge @u { facing: "right" }))))) @u))))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      MOVE_UP -> racing when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "player") (let ((nx (+ @u.position.x 0)) (ny (+ @u.position.y -1))) (let ((tile (array/find @config.tiles (fn t (and (== @t.x @nx) (== @t.y @ny)))))) (let ((walkable (if (== @tile null) false (object/get @tile passable)))) (if @walkable (object/merge @u { position: { x: @nx, y: @ny }, previousPosition: @u.position, facing: "up", animation: "walk", speed: (math/min 3 (+ @u.speed 1)) }) (object/merge @u { facing: "up", speed: (math/min 3 (+ @u.speed 1)) }))))) @u))))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      MOVE_DOWN -> racing when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "player") (let ((nx (+ @u.position.x 0)) (ny (+ @u.position.y 1))) (let ((tile (array/find @config.tiles (fn t (and (== @t.x @nx) (== @t.y @ny)))))) (let ((walkable (if (== @tile null) false (object/get @tile passable)))) (if @walkable (object/merge @u { position: { x: @nx, y: @ny }, previousPosition: @u.position, facing: "down", animation: "walk", speed: (math/max 0 (- @u.speed 1)) }) (object/merge @u { facing: "down", speed: (math/max 0 (- @u.speed 1)) }))))) @u))))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      UNIT_CLICK -> racing
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])

      TILE_CLICK -> racing
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])

      GAME_END -> gameover when (!= @entity.result "none")
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          overlay: { type: game-menu, title: (if (== @entity.result "victory") "VICTORY" "DEFEAT"), subtitle: (if (== @entity.result "victory") "You won the race!" "The rival crossed the line first"), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> racing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.lap 1)
        (set @entity.position 1)
        (set @entity.speed 1)
        (set @entity.result "none")
        (set @entity.phase "racing")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    ticks {
      driveTick every 400ms when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "player") (let ((dx (if (== @u.facing "left") -1 (if (== @u.facing "right") 1 0))) (dy (if (== @u.facing "up") -1 (if (== @u.facing "down") 1 0)))) (let ((nx (+ @u.position.x (* @dx @u.speed))) (ny (+ @u.position.y (* @dy @u.speed)))) (let ((tile (array/find @config.tiles (fn t (and (== @t.x @nx) (== @t.y @ny)))))) (let ((walkable (if (== @tile null) false (object/get @tile passable)))) (if (or (== @u.speed 0) (not @walkable)) (if (== @u.speed 0) @u (object/merge @u { speed: 0 })) (let ((target (if (< @u.nextCheckpoint 4) (array/nth @config.checkpoints @u.nextCheckpoint) @config.startLine))) (let ((passed (and (and (<= (math/min @u.position.x @nx) @target.x) (>= (math/max @u.position.x @nx) @target.x)) (and (<= (math/min @u.position.y @ny) @target.y) (>= (math/max @u.position.y @ny) @target.y))))) (object/merge @u { position: { x: @nx, y: @ny }, previousPosition: @u.position, animation: "walk", nextCheckpoint: (if @passed (math/mod (+ @u.nextCheckpoint 1) 5) @u.nextCheckpoint), lap: (if (and @passed (== @u.nextCheckpoint 4)) (+ @u.lap 1) @u.lap) })))))))) @u))))
        (set @entity.lap (object/get (array/find @entity.units (fn u (== @u.team "player"))) lap))
        (set @entity.speed (object/get (array/find @entity.units (fn u (== @u.team "player"))) speed))
        (set @entity.position (let ((rp (array/find @entity.units (fn u (== @u.team "rival"))))) (let ((pp (+ (* @entity.lap 4) (object/get (array/find @entity.units (fn u (== @u.team "player"))) nextCheckpoint))) (rvp (+ (* @rp.lap 4) @rp.nextCheckpoint))) (if (>= @pp @rvp) 1 2))))
        (if (>= @entity.lap @config.totalLaps) (do (set @entity.result "victory") (set @entity.phase "game_over") (emit GAME_END)) true)
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      rivalTick every 400ms when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "rival") (let ((facing (if (and (== @u.position.x 7) (== @u.position.y 0)) "down" (if (and (== @u.position.x 7) (== @u.position.y 7)) "left" (if (and (== @u.position.x 0) (== @u.position.y 7)) "up" (if (and (== @u.position.x 0) (== @u.position.y 0)) "right" @u.facing)))))) (let ((dx (if (== @facing "left") -1 (if (== @facing "right") 1 0))) (dy (if (== @facing "up") -1 (if (== @facing "down") 1 0)))) (let ((nx (+ @u.position.x @dx)) (ny (+ @u.position.y @dy))) (let ((target (if (< @u.nextCheckpoint 4) (array/nth @config.checkpoints @u.nextCheckpoint) @config.startLine))) (let ((passed (and (and (<= (math/min @u.position.x @nx) @target.x) (>= (math/max @u.position.x @nx) @target.x)) (and (<= (math/min @u.position.y @ny) @target.y) (>= (math/max @u.position.y @ny) @target.y))))) (object/merge @u { position: { x: @nx, y: @ny }, previousPosition: @u.position, facing: @facing, animation: "walk", nextCheckpoint: (if @passed (math/mod (+ @u.nextCheckpoint 1) 5) @u.nextCheckpoint), lap: (if (and @passed (== @u.nextCheckpoint 4)) (+ @u.lap 1) @u.lap) })))))) @u))))
        (set @entity.position (let ((rp (array/find @entity.units (fn u (== @u.team "rival"))))) (let ((pp (+ (* @entity.lap 4) (object/get (array/find @entity.units (fn u (== @u.team "player"))) nextCheckpoint))) (rvp (+ (* @rp.lap 4) @rp.nextCheckpoint))) (if (>= @pp @rvp) 1 2))))
        (if (>= (object/get (array/find @entity.units (fn u (== @u.team "rival"))) lap) @config.totalLaps) (do (set @entity.result "defeat") (set @entity.phase "game_over") (emit GAME_END)) true)
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: @entity.lap, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lap", thumbnailUrl: "" } }, { label: "Position", value: @entity.position, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-medals/ui/kenney-medals.generated.json", sprite: "flat_medal1.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-position", thumbnailUrl: "" } }, { label: "Speed", value: @entity.speed, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "arrow_yellow.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "5:3", name: "icon-speed", thumbnailUrl: "" } } ] } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/features/spritesheet_objects.json", sprite: "tires_white.png", role: "ui", category: "ui", animations: [], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click (inert, clears selection only)"
        @tier "interaction"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click (inert, clears selection only)"
        @tier "interaction"
      MOVE_LEFT -> external {
        id : string
      }
        @description "Steer left one cell (keyboard keyMap or d-pad)"
        @tier "domain"
      MOVE_RIGHT -> external {
        id : string
      }
        @description "Steer right one cell (keyboard keyMap or d-pad)"
        @tier "domain"
      MOVE_UP -> external {
        id : string
      }
        @description "Steer up one cell and accelerate (speed+1, cap 3)"
        @tier "domain"
      MOVE_DOWN -> external {
        id : string
      }
        @description "Steer down one cell and brake (speed-1, floor 0)"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Emitted when a car finishes totalLaps (victory) or the rival does (defeat)"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets the race to the start line"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : RacingBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      totalLaps : number = 3
        @label "Total Laps"
        @description "Number of laps to complete to win"
        @tier "presentation"
      tiles : [RacingBoardTilesItem] = [{ x: 0, y: 0, terrain: "road", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.json", sprite: "road_asphalt01.png", role: "tile", category: "road", animations: ["static"], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "road_asphalt", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "road", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.json", sprite: "road_asphalt01.png", role: "tile", category: "road", animations: ["static"], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "road_asphalt", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "road", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.json", sprite: "road_asphalt01.png", role: "tile", category: "road", animations: ["static"], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "road_asphalt", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "road", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/kenney-racing-pack/terrain/spritesheet_tiles.json", sprite: "road_asphalt01.png", role: "tile", category: "road", animations: ["static"], style: "flat", variant: "", dimension: "2d", aspect: "1:1", name: "road_asphalt", thumbnailUrl: "" }