        @label "Tiles"
        @description "Road circuit + grass infield tiles (8x8 rectangular track)"
        @tier "presentation"
      units : [RacingBoardUnitsItem] = [{ id: "player", position: { x: 3, y: 0 }, unitType: "car", name: "Player", team: player, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_player.png", role: "npc", category: "car_player", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "car_player", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "rival1", position: { x: 4, y: 0 }, unitType: "car", name: "Rival", team: rival, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_rival.png", role: "npc", category: "car_rival", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "car_rival", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Cars on the track (player + rival)"
        @tier "presentation"
      features : [RacingBoardFeaturesItem] = []
        @label "Features"
        @description "Track features (pit markers, start line, etc.)"
        @tier "presentation"
      assetManifest : RacingBoardAssetManifest = { terrains: { road: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/terrain/road.png", role: "tile", category: "road", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "road", thumbnailUrl: "" }, grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, units: { car_player: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_player.png", role: "npc", category: "car_player", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "car_player", thumbnailUrl: "" }, car_rival: { url: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_rival.png", role: "npc", category: "car_rival", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "car_rival", thumbnailUrl: "" } }, features: {}, effects: {} }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  trait RacingBoardAnimTick = AnimTick.traits.AnimTick -> RacingBoardItem {
    config { frameCount: 8 }
  }

  page "/racing-board" as RacingBoardPage -> RacingBoardRender, RacingBoardAnimTick
}
