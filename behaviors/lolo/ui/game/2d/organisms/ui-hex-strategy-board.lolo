  trait FxDecay = Frame.traits.FxDecay -> GameState {
    config { running: true }
  }

  trait RoundLogic = Frame.traits.RoundLogic -> GameState {
    config { running: true }
  }

  trait ScoreKeeper = Score.traits.ScoreKeeper -> GameState {
    config { running: true, pointsPerKill: 10, startScore: 0, initialEnemies: 2 }
  }

