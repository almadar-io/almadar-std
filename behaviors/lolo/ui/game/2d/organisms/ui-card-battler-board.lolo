app ui-card-battler-board "1.0.0"
"CardBattlerBoard — game-shell composition: HUD (mana/turn/result) + hand row of game-card atoms."
orbital CardBattlerBoardOrbital {
  type CardBattlerBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type CardBattlerBoardCard = {
    id : string!
    iconKey : string
    title : string
    cost : number
    attack : number
    defense : number
    sprite : Asset
  }
  type CardBattlerBoardAssetManifest = {
    cards : Map string Asset
  }

  entity CardBattlerBoardItem [runtime] {
    id : string!
    deck : [CardBattlerBoardCard]
    hand : [CardBattlerBoardCard]
    board : [CardBattlerBoardCard]
    mana : number = 3
    maxMana : number = 3
    turn : number = 1
    result : "none" | "won" | "lost" = none
  }

  trait CardBattlerBoardRender -> @rebindable CardBattlerBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.mana @config.maxMana)
        (set @entity.maxMana @config.maxMana)
        (set @entity.turn 1)
        (set @entity.result "none")
        (set @entity.deck @config.deck)
        (set @entity.hand @config.hand)
        (set @entity.board [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Mana", value: @entity.mana }, { label: "Turn", value: @entity.turn } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: secondary } ] } ] }
          children: [
            { type: data-list, entity: @entity.board, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" } }) },
            { type: data-list, entity: @entity.hand, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" }, clickEvent: PLAY_CARD }) }
          ]
        })

      PLAY_CARD -> playing when (and (== @entity.result "none") (> (array/len (array/filter @entity.hand (fn c (and (== @c.id ?cardId) (<= (object/get @c cost) @entity.mana))))) 0))
        (set @entity.mana (- @entity.mana (object/get (array/first (array/filter @entity.hand (fn c (== @c.id ?cardId)))) cost)))
        (set @entity.board (array/concat @entity.board (array/filter @entity.hand (fn c (== @c.id ?cardId)))))
        (set @entity.hand (array/filter @entity.hand (fn c (not (== @c.id ?cardId)))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Mana", value: @entity.mana }, { label: "Turn", value: @entity.turn } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: secondary } ] } ] }
          children: [
            { type: data-list, entity: @entity.board, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" } }) },
            { type: data-list, entity: @entity.hand, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" }, clickEvent: PLAY_CARD }) }
          ]
        })

      END_TURN -> playing when (== @entity.result "none")
        (set @entity.turn (+ @entity.turn 1))
        (set @entity.maxMana (math/min @config.manaCap (+ @entity.maxMana 1)))
        (set @entity.mana @entity.maxMana)
        (set @entity.hand (array/concat @entity.hand (array/slice @entity.deck 0 @config.drawPerTurn)))
        (set @entity.deck (array/slice @entity.deck @config.drawPerTurn (array/len @entity.deck)))
        (set @entity.result (if (>= @entity.turn @config.turnsToWin) "won" @entity.result))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Mana", value: @entity.mana }, { label: "Turn", value: @entity.turn } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: secondary } ] } ] }
          children: [
            { type: data-list, entity: @entity.board, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" } }) },
            { type: data-list, entity: @entity.hand, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" }, clickEvent: PLAY_CARD }) }
          ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Mana", value: @entity.mana }, { label: "Turn", value: @entity.turn } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: secondary } ] } ] }
          children: [
            { type: data-list, entity: @entity.board, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" } }) },
            { type: data-list, entity: @entity.hand, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" }, clickEvent: PLAY_CARD }) }
          ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.mana @config.maxMana)
        (set @entity.maxMana @config.maxMana)
        (set @entity.turn 1)
        (set @entity.result "none")
        (set @entity.deck @config.deck)
        (set @entity.hand @config.hand)
        (set @entity.board [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Mana", value: @entity.mana }, { label: "Turn", value: @entity.turn } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: secondary } ] } ] }
          children: [
            { type: data-list, entity: @entity.board, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" } }) },
            { type: data-list, entity: @entity.hand, fields: [], gap: sm, renderItem: (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/ui/diceWhite_border.json", sprite: "dieWhite_border6.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "card-frame", thumbnailUrl: "" }, clickEvent: PLAY_CARD }) }
          ]
        })
    }

    emits {
      PLAY_CARD -> external {
        cardId : string!
      }
        @description "Emits UI:{playCardEvent} with {cardId} when the player plays a card from hand"
        @tier "domain"
      END_TURN -> external {
        id : string
      }
        @description "Emits UI:{endTurnEvent} with {} when the player ends the turn"
        @tier "domain"
      GAME_END -> external {
        result : string!
      }
        @description "Emits UI:{gameEndEvent} with {result} when the match reaches won or lost"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : CardBattlerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      maxMana : number = 3
        @label "Starting Mana"
        @description "Mana the player starts each match with; also refills each turn."
        @tier "presentation"
      manaCap : number = 10
        @label "Mana Cap"
        @description "Maximum mana the per-turn ramp can reach."
        @tier "presentation"
      drawPerTurn : number = 1
        @label "Draw Per Turn"
        @description "Cards drawn from the deck at the end of each turn."
        @tier "presentation"
      turnsToWin : number = 8
        @label "Turns To Win"
        @description "Survive this many turns to win the match."
        @tier "presentation"
      deck : [CardBattlerBoardCard] = [{ id: "d1", iconKey: "rhino", title: "Rhino", cost: 3, attack: 4, defense: 5, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipRedWhite.png", role: "item", category: "rhino", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "rhino", thumbnailUrl: "" } }, { id: "d2", iconKey: "whale", title: "Whale", cost: 5, attack: 7, defense: 6, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipWhite.png", role: "item", category: "whale", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "whale", thumbnailUrl: "" } }, { id: "d3", iconKey: "parrot", title: "Parrot", cost: 2, attack: 3, defense: 2, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlue_side.png", role: "item", category: "parrot", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "parrot", thumbnailUrl: "" } }, { id: "d4", iconKey: "panda", title: "Panda", cost: 2, attack: 2, defense: 4, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlue_border.png", role: "item", category: "panda", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "panda", thumbnailUrl: "" } }, { id: "d5", iconKey: "monkey", title: "Monkey", cost: 1, attack: 2, defense: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlackWhite_side.png", role: "item", category: "monkey", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "monkey", thumbnailUrl: "" } }, { id: "d6", iconKey: "penguin", title: "Penguin", cost: 1, attack: 1, defense: 2, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlue_sideBorder.png", role: "item", category: "penguin", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "penguin", thumbnailUrl: "" } }, { id: "d7", iconKey: "elephant", title: "Elephant", cost: 4, attack: 5, defense: 6, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlackWhite.png", role: "item", category: "elephant", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "elephant", thumbnailUrl: "" } }]
        @label "Deck"
        @description "Draw deck — cards moved into hand at end of turn."
        @tier "presentation"
      hand : [CardBattlerBoardCard] = [{ id: "c1", iconKey: "bear", title: "Bear", cost: 3, attack: 5, defense: 4, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlue.png", role: "item", category: "bear", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "bear", thumbnailUrl: "" } }, { id: "c2", iconKey: "owl", title: "Owl", cost: 1, attack: 2, defense: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlackWhite_sideBorder.png", role: "item", category: "owl", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "owl", thumbnailUrl: "" } }, { id: "c3", iconKey: "gorilla", title: "Gorilla", cost: 4, attack: 6, defense: 5, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlackWhite_border.png", role: "item", category: "gorilla", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "gorilla", thumbnailUrl: "" } }, { id: "c4", iconKey: "frog", title: "Frog", cost: 1, attack: 1, defense: 2, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlueWhite.png", role: "item", category: "frog", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "frog", thumbnailUrl: "" } }, { id: "c5", iconKey: "snake", title: "Snake", cost: 2, attack: 4, defense: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipGreen.png", role: "item", category: "snake", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "snake", thumbnailUrl: "" } }]
        @label "Hand"
        @description "Opening hand dealt at INIT; takes priority over entity-derived hand."
        @tier "presentation"
      assetManifest : CardBattlerBoardAssetManifest = { cards: { bear: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlue.png", role: "item", category: "bear", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "bear", thumbnailUrl: "" }, owl: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlackWhite_sideBorder.png", role: "item", category: "owl", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "owl", thumbnailUrl: "" }, gorilla: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipBlackWhite_border.png", role: "item", category: "gorilla", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "gorilla", thumbnailUrl: "" }, rhino: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipRedWhite.png", role: "item", category: "rhino", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "5:7", name: "rhino", thumbnailUrl: "" }, whale: { url: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/kenney-boardgame-pack/cards/chips.json", sprite: "chipWhite.png", role: "item