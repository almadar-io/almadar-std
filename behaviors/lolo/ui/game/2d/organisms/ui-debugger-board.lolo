app ui-debugger-board "1.0.0"
"DebuggerBoard — flag every bug line and no clean line to win (1:1 with the @almadar/ui debugger-board pattern)."
orbital DebuggerBoardOrbital {
  type DebuggerBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type DebuggerBoardLinesItem = {
    id : string!
    content : string
    isBug : boolean
    isFlagged : boolean
    explanation : string
  }

  entity DebuggerBoardItem [runtime] {
    id : string!
    lines : [DebuggerBoardLinesItem]
    title : string
    description : string
    hint : string
    attempts : number = 0
    result : "none" | "win" = none
  }

  trait DebuggerBoardRender -> @rebindable DebuggerBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.lines @config.lines)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.hint @config.hint)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: data-list, entity: @entity.lines, fields: [], gap: xs, renderItem: (fn l { type: button, action: TOGGLE_FLAG, actionPayload: { lineId: @l.id }, label: @l.content, variant: (if (object/get @l isFlagged) "danger" "ghost") }) } ] }
          ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.lines @config.lines)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.hint @config.hint)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: data-list, entity: @entity.lines, fields: [], gap: xs, renderItem: (fn l { type: button, action: TOGGLE_FLAG, actionPayload: { lineId: @l.id }, label: @l.content, variant: (if (object/get @l isFlagged) "danger" "ghost") }) } ] }
          ]
        })
      TOGGLE_FLAG -> playing
        (set @entity.lines (array/map @entity.lines (fn l (if (== (object/get l id) ?lineId) (object/merge l { isFlagged: (not (object/get l isFlagged)) }) l))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: data-list, entity: @entity.lines, fields: [], gap: xs, renderItem: (fn l { type: button, action: TOGGLE_FLAG, actionPayload: { lineId: @l.id }, label: @l.content, variant: (if (object/get @l isFlagged) "danger" "ghost") }) } ] }
          ]
        })

      CHECK -> complete when (and (== (array/len (array/filter @entity.lines (fn l (and (object/get l isBug) (not (object/get l isFlagged)))))) 0) (== (array/len (array/filter @entity.lines (fn l (and (not (object/get l isBug)) (object/get l isFlagged))))) 0))
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.result "win")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: data-list, entity: @entity.lines, fields: [], gap: xs, renderItem: (fn l { type: button, action: TOGGLE_FLAG, actionPayload: { lineId: @l.id }, label: @l.content, variant: (if (object/get @l isFlagged) "danger" "ghost") }) } ] }
          ]
        })

      CHECK -> playing when (or (> (array/len (array/filter @entity.lines (fn l (and (object/get l isBug) (not (object/get l isFlagged)))))) 0) (> (array/len (array/filter @entity.lines (fn l (and (not (object/get l isBug)) (object/get l isFlagged))))) 0))
        (set @entity.attempts (+ @entity.attempts 1))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: data-list, entity: @entity.lines, fields: [], gap: xs, renderItem: (fn l { type: button, action: TOGGLE_FLAG, actionPayload: { lineId: @l.id }, label: @l.content, variant: (if (object/get @l isFlagged) "danger" "ghost") }) } ] }
          ]
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.lines @config.lines)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.hint @config.hint)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: CHECK, label: "Check", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: card, children: [ { type: data-list, entity: @entity.lines, fields: [], gap: xs, renderItem: (fn l { type: button, action: TOGGLE_FLAG, actionPayload: { lineId: @l.id }, label: @l.content, variant: (if (object/get @l isFlagged) "danger" "ghost") }) } ] }
          ]
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "domain"
      TOGGLE_FLAG -> external {
        lineId : string!
      }
        @description "Flip the flag on a reviewed code line"
        @tier "domain"
      CHECK -> external {
        id : string
      }
        @description "Submit the current flag set for scoring"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Reset the puzzle and play again"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : DebuggerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      title : string = "Debug the Add Function"
        @label "Title"
        @description "Puzzle title shown above the board."
        @tier "domain"
      description : string = "Flag every line that contains a bug. Flag no clean lines to win."
        @label "Description"
        @description "One-line puzzle brief shown to the player."
        @tier "domain"
      hint : string = "Check the operator in the return statement and the variable name in the log call."
        @label "Hint"
        @description "Optional hint the player can reveal."
        @tier "domain"
      lines : [DebuggerBoardLinesItem] = [{ id: "l1", content: "function add(a, b) {", isBug: false, isFlagged: false }, { id: "l2", content: "  return a - b;", isBug: true, isFlagged: false, explanation: "Should be a + b for an add function." }, { id: "l3", content: "}", isBug: false, isFlagged: false }, { id: "l4", content: "const total = add(2, 3);", isBug: false, isFlagged: false }, { id: "l5", content: "console.log(totl);", isBug: true, isFlagged: false, explanation: "Typo: 'totl' should be 'total'." }]
        @label "Lines"
        @description "Direct code-line data — takes priority over entity-derived lines."
        @tier "presentation"
    }
  }

  page "/debugger-board" as DebuggerBoardPage -> DebuggerBoardRender
}
