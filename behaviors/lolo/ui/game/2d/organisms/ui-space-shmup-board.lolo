app ui-space-shmup-board "1.0.0"
"SpaceShmupBoard — sci-fi SHMUP with TILE_CLICK/UNIT_CLICK input wiring, SHOOT HUD control, score/lives display, and UI Pack - Sci-fi assets."
orbital SpaceShmupBoardOrbital {
  uses AnimTick from "std/behaviors/std-anim-tick"

  type SpaceShmupBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type SpaceShmupBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type SpaceShmupBoardUnitsItem = {
    id : string!
    position : SpaceShmupBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    spriteSheet : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [SpaceShmupBoardUnitsItemTraitsItem]
    previousPosition : SpaceShmupBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type SpaceShmupBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type SpaceShmupBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type SpaceShmupBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type SpaceShmupBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type SpaceShmupBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type SpaceShmupBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity SpaceShmupBoardItem [runtime] {
    id : string!
    units : [SpaceShmupBoardUnitsItem]
    selectedUnitId : string = ""
    validMoves : [SpaceShmupBoardUnitsItemPosition] = []
    score : number = 0
    lives : number = 3
    result : "none" | "victory" | "defeat" = none
    effects : [SpaceShmupBoardEffectItem] = []
  }

  trait SpaceShmupBoardRender -> @rebindable SpaceShmupBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      TILE_CLICK -> playing
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      SHOOT -> playing when (!= (array/len (array/filter @entity.units (fn u (== @u.team "player")))) 0)
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.id ?targetId) (== @u.team "enemy")) (object/merge @u { health: (math/max 0 (- (object/get @u health) 1)), animation: (if (<= (math/max 0 (- (object/get @u health) 1)) 0) "death" "hit") }) @u))))
        (if (<= (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) health) 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) position) y), ttl: 5 })) null)
        (set @entity.score (if (<= (object/get (array/find @entity.units (fn u (== @u.id ?targetId))) health) 0) (+ @entity.score 100) @entity.score))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      PLAYER_HIT -> playing when (> @entity.lives 0)
        (set @entity.lives (- @entity.lives 1))
        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (object/get (array/first (array/filter @entity.units (fn u (== @u.team "player")))) position) x), y: (object/get (object/get (array/first (array/filter @entity.units (fn u (== @u.team "player")))) position) y), ttl: 5 }))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      PAUSE -> paused
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          overlay: { type: game-menu, title: "Paused", items: [ { label: "Resume", action: RESUME }, { label: "Restart", action: INIT } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      GAME_END -> gameover when (or (== (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> (object/get @u health) 0))))) 0) (<= @entity.lives 0))
        (set @entity.result (if (<= @entity.lives 0) "defeat" "victory"))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    state paused {
      RESUME -> playing
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> menu
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    ticks {
      renderTick every 100ms
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-lives.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-fire.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/ui/icon-pause.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Fires on tile click with grid coordinates"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Fires on unit click with unit id"
        @tier "domain"
      SHOOT -> external {
        targetId : string!
      }
        @description "Player fires at an enemy unit"
        @tier "domain"
      PLAYER_HIT -> external {
        id : string
      }
        @description "Player ship takes a hit"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Fires when all enemies are destroyed or lives reach zero"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Reset and restart the game"
        @tier "domain"
      PAUSE -> external {
        id : string
      }
        @description "Pause the game and show the pause menu"
        @tier "domain"
      RESUME -> external {
        id : string
      }
        @description "Resume play from the pause menu"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SpaceShmupBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [SpaceShmupBoardTilesItem] = [{ x: 0, y: 0, terrain: "space", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "space", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "space", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "space", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, { x: 4, y: 0, terrain: "space", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, { x: 5, y: 0, terrain: "space", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, { x: 0, y: 1, terrain: "space", pass