        @label "Tiles"
        @description "6×8 flat space-terrain tile grid"
        @tier "presentation"
      units : [SpaceShmupBoardUnitsItem] = [{ id: "enemy1", position: { x: 1, y: 0 }, unitType: "ship", name: "Invader A", team: enemy, health: 1, maxHealth: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "enemy2", position: { x: 3, y: 0 }, unitType: "ship", name: "Invader B", team: enemy, health: 1, maxHealth: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "enemy3", position: { x: 0, y: 1 }, unitType: "ship", name: "Invader C", team: enemy, health: 1, maxHealth: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "enemy4", position: { x: 4, y: 1 }, unitType: "ship", name: "Invader D", team: enemy, health: 1, maxHealth: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "player1", position: { x: 2, y: 7 }, unitType: "ship", name: "Player", team: player, health: 3, maxHealth: 3, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/ship.png", role: "npc", category: "ship", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "ship", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Player ship (bottom centre) and 4 enemy ships across the top rows"
        @tier "presentation"
      features : [SpaceShmupBoardFeaturesItem] = []
        @label "Features"
        @description "Optional hazards or power-ups on the field"
        @tier "presentation"
      assetManifest : SpaceShmupBoardAssetManifest = { terrains: { space: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png", role: "tile", category: "space", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "space", thumbnailUrl: "" } }, units: { ship: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/ship.png", role: "npc", category: "ship", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "ship", thumbnailUrl: "" }, enemy: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" } }, features: {}, effects: { explosion: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/pixelExplosion07.png", role: "effect", category: "explosion", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "8:1", name: "explosion", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Sprite manifest for terrain, units, and effects"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  trait SpaceShmupBoardAnimTick = AnimTick.traits.AnimTick -> SpaceShmupBoardItem {
    config { frameCount: 8 }
  }

  page "/space-shmup-board" as SpaceShmupBoardPage -> SpaceShmupBoardRender, SpaceShmupBoardAnimTick
}
