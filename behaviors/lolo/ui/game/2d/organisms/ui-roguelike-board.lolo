    ticks {
      animTick every 100ms
        (set @entity.playerFrame (% (+ @entity.playerFrame 1) 8))
        (set @entity.enemies (array/map @entity.enemies (fn e (object/merge @e { frame: (% (+ (object/get @e frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
