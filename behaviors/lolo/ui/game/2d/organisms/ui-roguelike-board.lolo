            { type: health-bar, current: @entity.playerHp, max: @entity.playerMaxHp, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-track.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-track", thumbnailUrl: "" }, fillAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } },
            { type: resource-bar, resources: [{ label: "XP", value: @entity.xp, max: @entity.xpToNext, assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } }] },
            { type: item-slot, assetUrl: (object/get (object/get @config.assetManifest features) sword), label: "Sword", rarity: "uncommon", empty: (== @entity.equippedWeapon ""), selected: (!= @entity.equippedWeapon ""), size: "sm" },
            { type: button, action: PLAY_AGAIN, label: "New Run", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: (array/append (array/map @entity.enemies (fn e (object/merge { id: @e.id, x: @e.x, y: @e.y, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, team: "enemy", health: @e.hp, maxHealth: 5, animation: @e.animation, frame: @e.frame } {}))) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y), sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, team: "player", health: @entity.playerHp, maxHealth: @entity.playerMaxHp, animation: @entity.playerAnimation, frame: @entity.playerFrame }), features: (array/map @entity.items (fn i { id: @i.id, x: @i.x, y: @i.y, type: @i.kind, sprite: (if (== @i.kind "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== @i.kind "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, scale: @config.scale } ]
        })

      enemyAiTick every 1s
        when (and (== @entity.phase "enemy_turn") (== @entity.result "none"))
        (set @entity.enemies (array/map @entity.enemies (fn e (if (> @e.hp 0) (let ((ex @e.x) (ey @e.y) (px (object/get @entity.player x)) (py (object/get @entity.player y))) (let ((adjP (and (== (math/abs (- @ex @px)) 1) (== @ey @py))) (adjQ (and (== @ex @px) (== (math/abs (- @ey @py)) 1)))) (if (or @adjP @adjQ) (object/merge @e { animation: "attack" }) (object/merge @e { animation: "walk", x: (math/clamp (+ @ex (math/sign (- @px @ex))) 0 (- @entity.gridWidth 1)), y: (math/clamp (+ @ey (math/sign (- @py @ey))) 0 (- @entity.gridHeight 1)) })))) @e))))
        (set @entity.playerHp (let ((adjEnemies (array/filter @entity.enemies (fn e (and (> @e.hp 0) (or (and (== (math/abs (- @e.x (object/get @entity.player x))) 1) (== @e.y (object/get @entity.player y))) (and (== @e.x (object/get @entity.player x)) (== (math/abs (- @e.y (object/get @entity.player y))) 1)))))))) (let ((dmg (if (== (array/len @adjEnemies) 0) 0 (array/reduce @adjEnemies (fn acc e (+ acc @e.attack)) 0)))) (math/max 0 (- @entity.playerHp @dmg)))))
        (set @entity.playerAnimation (if (> (let ((adjEnemies (array/filter @entity.enemies (fn e (and (> @e.hp 0) (or (and (== (math/abs (- @e.x (object/get @entity.player x))) 1) (== @e.y (object/get @entity.player y))) (and (== @e.x (object/get @entity.player x)) (== (math/abs (- @e.y (object/get @entity.player y))) 1)))))))) (array/len @adjEnemies)) 0) (if (<= @entity.playerHp 0) "death" "hit") "idle"))
        (set @entity.effects (if (> (array/len (array/filter @entity.enemies (fn e (and (> @e.hp 0) (or (and (== (math/abs (- @e.x (object/get @entity.player x))) 1) (== @e.y (object/get @entity.player y))) (and (== @e.x (object/get @entity.player x)) (== (math/abs (- @e.y (object/get @entity.player y))) 1))))))) 0) (array/append @entity.effects { key: "slash", x: (object/get @entity.player x), y: (object/get @entity.player y), ttl: 4 }) @entity.effects))
        (if (and (!= @entity.playerHp 0) (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
          (set @entity.depth (+ @entity.depth 1))
          true)
        (if (and (!= @entity.playerHp 0) (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
          (set @entity.xp (+ @entity.xp 50))
          true)
        (set @entity.result (if (== @entity.playerHp 0) "lost" (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY)) (if (>= @entity.depth 5) "won" "none") "none")))
        (set @entity.phase (if (!= @entity.result "none") "game_over" "player_turn"))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/health.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "health", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/star.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "star", thumbnailUrl: "" } }, { label: "Gold", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/coin.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "coin", thumbnailUrl: "" } } ] },
            { type: health-bar, current: @entity.playerHp, max: @entity.playerMaxHp, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-track.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-track", thumbnailUrl: "" }, fillAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } },
            { type: resource-bar, resources: [{ label: "XP", value: @entity.xp, max: @entity.xpToNext, assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } }] },
            { type: item-slot, assetUrl: (object/get (object/get @config.assetManifest features) sword), label: "Sword", rarity: "uncommon", empty: (== @entity.equippedWeapon ""), selected: (!= @entity.equippedWeapon ""), size: "sm" },
            { type: button, action: PLAY_AGAIN, label: "New Run", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: (array/append (array/map @entity.enemies (fn e (object/merge { id: @e.id, x: @e.x, y: @e.y, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, team: "enemy", health: @e.hp, maxHealth: 5, animation: @e.animation, frame: @e.frame } {}))) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y), sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, team: "player", health: @entity.playerHp, maxHealth: @entity.playerMaxHp, animation: @entity.playerAnimation, frame: @entity.playerFrame }), features: (array/map @entity.items (fn i { id: @i.id, x: @i.x, y: @i.y, type: @i.kind, sprite: (if (== @i.kind "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== @i.kind "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, scale: @config.scale } ]
        })
    }

    emits {
      MOVE -> external {
        dx : number!
        dy : number!
      }
        @description "Player move by delta (arrow key or tile click)"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets the dungeon to depth 1"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Emitted when result transitions to won or lost"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Player clicked a tile (fires selection clear)"
        @tier "interaction"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Player clicked a unit (sets selectedUnitId)"
        @tier "interaction"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : RoguelikeBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      scale : number = 0.25
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      playerMaxHp : number = 10
        @label "Player Max HP"
        @description "Starting max HP for the player"
        @tier "presentation"
      playerAttack : number = 3
        @label "Player Attack"
        @description "Player base damage per hit"
        @tier "presentation"
      player : RoguelikeBoardPlayerPos = { x: 2, y: 2 }
        @label "Player Start"
        @description "Player starting position"
        @tier "presentation"
      stairsX : number = 13
        @label "Stairs X"
        @description "Stairs tile X coordinate"
        @tier "presentation"
      stairsY : number = 9
        @label "Stairs Y"
        @description "Stairs tile Y coordinate"
        @tier "presentation"
      tiles : [RoguelikeBoardTilesItem] = [{ x: 0, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, tileType: "wall" }, { x: 1, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, tileType: "wall" }, { x: 2, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, tileType: "wall" }, { x: 3, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, tileType: "wall" }, { x: 4, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, tileType: "wall" }, { x: 5, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumb