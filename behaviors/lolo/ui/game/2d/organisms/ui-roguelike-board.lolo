app ui-roguelike-board "1.0.0"
"RoguelikeBoard — game-shell composition with LOLO-driven sprite animation and combat effects."
orbital RoguelikeBoardOrbital {
  type RoguelikeBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type RoguelikeBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : Asset
    passable : boolean
    tileType : string
  }
  type RoguelikeBoardPlayerPos = {
    x : number!
    y : number!
  }
  type RoguelikeBoardEnemiesItem = {
    id : string!
    x : number!
    y : number!
    hp : number!
    attack : number!
    animation : string
    frame : number
  }
  type RoguelikeBoardItemsItem = {
    id : string!
    x : number!
    y : number!
    kind : "health_potion" | "sword" | "shield"
  }
  type RoguelikeEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type RoguelikeBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }
  type RoguelikeBoardMOVEPayload = {
    dx : number!
    dy : number!
  }

  entity RoguelikeBoardItem [runtime] {
    id : string!
    tiles : [RoguelikeBoardTilesItem]
    player : RoguelikeBoardPlayerPos = { x: 2, y: 2 }
    playerHp : number = 10
    playerMaxHp : number = 10
    playerAttack : number = 3
    playerAnimation : string = "idle"
    playerFrame : number = 0
    enemies : [RoguelikeBoardEnemiesItem]
    items : [RoguelikeBoardItemsItem]
    depth : number = 1
    result : "none" | "won" | "lost" = none
    phase : string = "player_turn"
    stairsX : number = 13
    stairsY : number = 9
    gridWidth : number = 16
    gridHeight : number = 16
    effects : [RoguelikeEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [RoguelikeBoardPlayerPos] = []
    xp : number = 0
    xpToNext : number = 50
    inventory : [string] = []
    equippedWeapon : string = ""
  }

  trait RoguelikeBoardRender -> @rebindable RoguelikeBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.tiles @config.tiles)
        (set @entity.player @config.player)
        (set @entity.playerHp @config.playerMaxHp)
        (set @entity.playerMaxHp @config.playerMaxHp)
        (set @entity.playerAttack @config.playerAttack)
        (set @entity.playerAnimation "idle")
        (set @entity.playerFrame 0)
        (set @entity.enemies (array/map @config.enemies (fn e (object/merge @e { animation: "idle", frame: 0 }))))
        (set @entity.items @config.items)
        (set @entity.depth 1)
        (set @entity.result "none")
        (set @entity.phase "player_turn")
        (set @entity.stairsX @config.stairsX)
        (set @entity.stairsY @config.stairsY)
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.effects [])
        (set @entity.xp 0)
        (set @entity.xpToNext 50)
        (set @entity.inventory [])
        (set @entity.equippedWeapon "")
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/health.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "health", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/star.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "star", thumbnailUrl: "" } }, { label: "Gold", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/coin.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "coin", thumbnailUrl: "" } } ] },
            { type: health-bar, current: @entity.playerHp, max: @entity.playerMaxHp, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-track.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-track", thumbnailUrl: "" }, fillAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } },
            { type: resource-bar, resources: [{ label: "XP", value: @entity.xp, max: @entity.xpToNext, assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } }] },
            { type: item-slot, assetUrl: (object/get (object/get @config.assetManifest features) sword), label: "Sword", rarity: "uncommon", empty: (== @entity.equippedWeapon ""), selected: (!= @entity.equippedWeapon ""), size: "sm" },
            { type: button, action: PLAY_AGAIN, label: "New Run", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: (array/append (array/map @entity.enemies (fn e (object/merge { id: @e.id, x: @e.x, y: @e.y, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, team: "enemy", health: @e.hp, maxHealth: 5, animation: @e.animation, frame: @e.frame } {}))) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y), sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, team: "player", health: @entity.playerHp, maxHealth: @entity.playerMaxHp, animation: @entity.playerAnimation, frame: @entity.playerFrame }), features: (array/map @entity.items (fn i { id: @i.id, x: @i.x, y: @i.y, type: @i.kind, sprite: (if (== @i.kind "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== @i.kind "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, scale: @config.scale } ]
        })

      MOVE -> playing when (and (== @entity.result "none") (== @entity.phase "player_turn"))
        (let ((tx (+ (object/get @entity.player x) ?dx)) (ty (+ (object/get @entity.player y) ?dy)))
          (do
            (let ((inBounds (and (and (>= @tx 0) (< @tx @entity.gridWidth)) (and (>= @ty 0) (< @ty @entity.gridHeight))))
                  (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @tx) (== (object/get @t y) @ty)))))
                  (hitEnemy (array/find @entity.enemies (fn e (and (and (== @e.x @tx) (== @e.y @ty)) (> @e.hp 0)))))
                  (hitItem (array/find @entity.items (fn i (and (== @i.x @tx) (== @i.y @ty))))))
              (let ((walkable (if (== @tile null) false (object/get @tile passable))))
              (if (and @inBounds (== @hitEnemy null))
                (do
                  (if (== @hitItem null) true
                    (do
                      (if (== (object/get @hitItem kind) "health_potion")
                        (set @entity.playerHp (math/min @entity.playerMaxHp (+ @entity.playerHp 5)))
                        true)
                      (if (== (object/get @hitItem kind) "sword")
                        (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.equippedWeapon "sword"))
                        true)
                      (set @entity.items (array/filter @entity.items (fn i (!= @i.id (object/get @hitItem id)))))
                    ))
                  (if (and @walkable @inBounds)
                    (do
                      (set @entity.player { x: @tx, y: @ty })
                      (set @entity.playerAnimation "walk"))
                    true))
                (if (!= @hitEnemy null)
                  (do
                    (set @entity.playerAnimation "attack")
                    (set @entity.enemies (array/map @entity.enemies (fn e (if (== @e.id (object/get @hitEnemy id)) (object/merge @e { hp: (math/max 0 (- @e.hp @entity.playerAttack)), animation: (if (<= (math/max 0 (- @e.hp @entity.playerAttack)) 0) "death" "hit") }) @e))))
                    (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 4 }))
                    (if (<= (object/get (array/find @entity.enemies (fn e (== @e.id (object/get @hitEnemy id)))) hp) 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 5 })) null))
                  true))))
            (set @entity.enemies (array/filter @entity.enemies (fn e (> @e.hp 0))))
            (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
              (set @entity.depth (+ @entity.depth 1))
              true)
            (set @entity.phase "enemy_turn")))
        (set @entity.result (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY)) (if (>= @entity.depth 5) "won" "none") (if (== @entity.playerHp 0) "lost" "none")))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/health.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "health", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/star.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "star", thumbnailUrl: "" } }, { label: "Gold", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/coin.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "coin", thumbnailUrl: "" } } ] },
            { type: health-bar, current: @entity.playerHp, max: @entity.playerMaxHp, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-track.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-track", thumbnailUrl: "" }, fillAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } },
            { type: resource-bar, resources: [{ label: "XP", value: @entity.xp, max: @entity.xpToNext, assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } }] },
            { type: item-slot, assetUrl: (object/get (object/get @config.assetManifest features) sword), label: "Sword", rarity: "uncommon", empty: (== @entity.equippedWeapon ""), selected: (!= @entity.equippedWeapon ""), size: "sm" },
            { type: button, action: PLAY_AGAIN, label: "New Run", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: (array/append (array/map @entity.enemies (fn e (object/merge { id: @e.id, x: @e.x, y: @e.y, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, team: "enemy", health: @e.hp, maxHealth: 5, animation: @e.animation, frame: @e.frame } {}))) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y), sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, team: "player", health: @entity.playerHp, maxHealth: @entity.playerMaxHp, animation: @entity.playerAnimation, frame: @entity.playerFrame }), features: (array/map @entity.items (fn i { id: @i.id, x: @i.x, y: @i.y, type: @i.kind, sprite: (if (== @i.kind "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== @i.kind "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, scale: @config.scale } ]
        })

      TILE_CLICK -> playing
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/health.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "health", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/star.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "star", thumbnailUrl: "" } }, { label: "Gold", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/coin.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "coin", thumbnailUrl: "" } } ] },
            { type: health-bar, current: @entity.playerHp, max: @entity.playerMaxHp, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-track.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-track", thumbnailUrl: "" }, fillAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } },
            { type: resource-bar, resources: [{ label: "XP", value: @entity.xp, max: @entity.xpToNext, assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } }] },
            { type: item-slot, assetUrl: (object/get (object/get @config.assetManifest features) sword), label: "Sword", rarity: "uncommon", empty: (== @entity.equippedWeapon ""), selected: (!= @entity.equippedWeapon ""), size: "sm" },
            { type: button, action: PLAY_AGAIN, label: "New Run", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: (array/append (array/map @entity.enemies (fn e (object/merge { id: @e.id, x: @e.x, y: @e.y, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, team: "enemy", health: @e.hp, maxHealth: 5, animation: @e.animation, frame: @e.frame } {}))) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y), sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, team: "player", health: @entity.playerHp, maxHealth: @entity.playerMaxHp, animation: @entity.playerAnimation, frame: @entity.playerFrame }), features: (array/map @entity.items (fn i { id: @i.id, x: @i.x, y: @i.y, type: @i.kind, sprite: (if (== @i.kind "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== @i.kind "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, scale: @config.scale } ]
        })

      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/health.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "health", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/star.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "star", thumbnailUrl: "" } }, { label: "Gold", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/coin.png", role: "ui", category: "ui", animations: [], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "coin", thumbnailUrl: "" } } ] },
            { type: health-bar, current: @entity.playerHp, max: @entity.playerMaxHp, frameAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-track.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-track", thumbnailUrl: "" }, fillAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } },
            { type: resource-bar, resources: [{ label: "XP", value: @entity.xp, max: @entity.xpToNext, assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/ui/bar-fill.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "bar-fill", thumbnailUrl: "" } }] },
            { type: item-slot, assetUrl: (object/get (object/get @config.assetManifest features) sword), label: "Sword", rarity: "uncommon", empty: (== @entity.equippedWeapon ""), selected: (!= @entity.equippedWeapon ""), size: "sm" },
            { type: button, action: PLAY_AGAIN, label: "New Run", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: (array/append (array/map @entity.enemies (fn e (object/merge { id: @e.id, x: @e.x, y: @e.y, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" }, team: "enemy", health: @e.hp, maxHealth: 5, animation: @e.animation, frame: @e.frame } {}))) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y), sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, team: "player", health: @entity.playerHp, maxHealth: @entity.playerMaxHp, animation: @entity.playerAnimation, frame: @entity.playerFrame }), features: (array/map @entity.items (fn i { id: @i.id, x: @i.x, y: @i.y, type: @i.kind, sprite: (if (== @i.kind "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== @i.kind "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, scale: @config.scale } ]
