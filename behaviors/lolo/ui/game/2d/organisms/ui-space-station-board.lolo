app ui-space-station-board "1.0.0"
"SpaceStationBoard — sci-fi isometric crew board: crew units select/move across a station grid (no combat); composes the std multi-unit crew frame with UI Pack - Sci-fi assets."
orbital SpaceStationBoardOrbital {
  uses Frame from "std/behaviors/std-crew-board-2d"

  type Asset = {
    url : asset
    atlas : asset
    sprite : string
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    terrainSprite : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string
    assetUrl : Asset
    color : string
    elevation : number
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    movesLeft : number = 0
    fx : [Fx] = []
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    phase : string = "idle"
    oxygen : number = 100
    crewCount : number = 3
  }

  trait CrewAuthority = Frame.traits.CrewAuthority -> GameState {
    config {
      running: true
      gridWidth: 7
      gridHeight: 7
      moveBudget: 999999
      units: [
        { id: "u1", position: { x: 2, y: 3 }, x: 2, y: 3, z: 0, team: "player", health: 10, maxHealth: 10, unitType: "crew", name: "Commander" },
        { id: "u2", position: { x: 4, y: 3 }, x: 4, y: 3, z: 0, team: "player", health: 10, maxHealth: 10, unitType: "crew", name: "Engineer" },
        { id: "u3", position: { x: 3, y: 5 }, x: 3, y: 5, z: 0, team: "player", health: 10, maxHealth: 10, unitType: "crew", name: "Technician" }
      ]
      tiles: [
        { id: "t-0-0", x: 0, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } },
        { id: "t-1-0", x: 1, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } },
        { id: "t-2-0", x: 2, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } },
        { id: "t-3-0", x: 3, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } },
        { id: "t-4-0", x: 4, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } },
        { id: "t-5-0", x: 5, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } },
