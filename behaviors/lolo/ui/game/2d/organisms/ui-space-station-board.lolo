      hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
