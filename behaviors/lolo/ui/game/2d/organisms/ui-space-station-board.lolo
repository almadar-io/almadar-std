        { id: "t-1-1", x: 1, y: 1, terrain: "floor", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png", role: "tile", category: "floor", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "floor", thumbnailUrl: "" } },
        { id: "t-2-1", x: 2, y: 1, terrain: "floor", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png", role: "tile", category: "floor", animations: ["static"], style: "sci-fi", dimension: "2d", aspect: "1:1", name: "floor", thumbnailUrl: "" } },
