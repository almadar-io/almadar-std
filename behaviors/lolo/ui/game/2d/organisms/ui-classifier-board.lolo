app ui-classifier-board "1.0.0"
"ClassifierBoard — guarded classification puzzle: assign items to categories, win when every item's assigned category equals its correct category."
orbital ClassifierBoardOrbital {
  type ClassifierBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type ClassifierBoardItemsItem = {
    id : string!
    label : string
    correctCategory : string!
    assignedCategory : string
  }
  type ClassifierBoardCategoriesItem = {
    id : string!
    label : string
    color : string
  }

  entity ClassifierBoardItem [runtime] {
    id : string!
    items : [ClassifierBoardItemsItem]
    categories : [ClassifierBoardCategoriesItem]
    title : string
    description : string
    hint : string
    attempts : number = 0
    result : "none" | "win" = none
  }

  trait ClassifierBoardRender -> @rebindable ClassifierBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.items @config.items)
        (set @entity.categories @config.categories)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.hint @config.hint)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          assignEvent: ASSIGN
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: classifier-board
        })
    }

    state playing {
      INIT -> playing
        (set @entity.items @config.items)
        (set @entity.categories @config.categories)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.hint @config.hint)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          assignEvent: ASSIGN
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: classifier-board
        })
      ASSIGN -> playing
        (set @entity.items (array/map @entity.items (fn i (if (== @i.id ?itemId) (object/merge @i { assignedCategory: ?categoryId }) @i))))
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          assignEvent: ASSIGN
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: classifier-board
        })

      CHECK -> complete when (== (array/len (array/filter @entity.items (fn i (!= (object/get @i assignedCategory) (object/get @i correctCategory))))) 0)
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.result "win")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          assignEvent: ASSIGN
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: classifier-board
        })

      CHECK -> playing when (> (array/len (array/filter @entity.items (fn i (!= (object/get @i assignedCategory) (object/get @i correctCategory))))) 0)
        (set @entity.attempts (+ @entity.attempts 1))
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          assignEvent: ASSIGN
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: classifier-board
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.items @config.items)
        (set @entity.categories @config.categories)
        (set @entity.title @config.title)
        (set @entity.description @config.description)
        (set @entity.hint @config.hint)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          assignEvent: ASSIGN
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: classifier-board
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "essential"
      ASSIGN -> external {
        itemId : string!
        categoryId : string!
      }
        @description "Emits UI:{assignEvent} with { itemId, categoryId } when an item is dropped into a category"
        @tier "essential"
      CHECK -> external {
        id : string
      }
        @description "Emits UI:{checkEvent} with {} when the player submits their assignments"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : ClassifierBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      title : string = "Sort the Foods"
        @label "Title"
        @description "Puzzle title shown above the board."
        @tier "domain"
      description : string = "Drag each item into the correct category bucket."
        @label "Description"
        @description "One-line puzzle brief shown to the player."
        @tier "domain"
      hint : string = "Think about which foods grow on trees versus underground."
        @label "Hint"
        @description "Optional hint the player can reveal."
        @tier "domain"
      items : [ClassifierBoardItemsItem] = [{ id: "i1", label: "Apple", correctCategory: "fruit", assignedCategory: "" }, { id: "i2", label: "Carrot", correctCategory: "vegetable", assignedCategory: "" }, { id: "i3", label: "Banana", correctCategory: "fruit", assignedCategory: "" }, { id: "i4", label: "Potato", correctCategory: "vegetable", assignedCategory: "" }]
        @label "Items"
        @description "Sortable items — each carries its correct category and the player's current assignment."
        @tier "presentation"
      categories : [ClassifierBoardCategoriesItem] = [{ id: "fruit", label: "Fruit" }, { id: "vegetable", label: "Vegetable" }]
        @label "Categories"
        @description "Category buckets the player sorts items into."
        @tier "presentation"
    }
  }

  page "/classifier-board" as ClassifierBoardPage -> ClassifierBoardRender
}
