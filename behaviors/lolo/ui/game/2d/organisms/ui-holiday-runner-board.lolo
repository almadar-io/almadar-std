app ui-holiday-runner-board "1.0.0"
"HolidayRunnerBoard — endless runner on a flat tiled scene, composed via game-shell."
orbital HolidayRunnerBoardOrbital {
  type HolidayRunnerBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type HolidayRunnerBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
  }
  type HolidayRunnerBoardUnitsItem = {
    id : string!
    position : HolidayRunnerBoardUnitsItemPosition
    x : number
    y : number
    sprite : Asset
    unitType : string
    name : string
    team : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    animation : string
    frame : number
  }
  type HolidayRunnerBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type HolidayRunnerBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
    color : string
  }
  type HolidayRunnerBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type HolidayRunnerBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity HolidayRunnerBoardItem [runtime] {
    id : string!
    units : [HolidayRunnerBoardUnitsItem]
    distance : number = 0
    score : number = 0
    result : string = ""
    effects : [HolidayRunnerBoardEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [HolidayRunnerBoardUnitsItemPosition] = []
  }

  trait HolidayRunnerBoardRender -> @rebindable HolidayRunnerBoardItem [interaction, instance] {
    initial: running

    state running {
      INIT -> running
        (set @entity.units @config.units)
        (set @entity.distance 0)
        (set @entity.score 0)
        (set @entity.result "")
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_coins.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_gem_yellow.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_keyGreen.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-jump", thumbnailUrl: "" }, variant: primary }
          ] }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { Space: "JUMP", ArrowUp: "JUMP", KeyW: "JUMP" }, backgroundImage: @config.backgroundImage, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), frame: (object/get @u frame) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      TILE_CLICK -> running
        (set @entity.selectedUnitId "")
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_coins.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_gem_yellow.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_keyGreen.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-jump", thumbnailUrl: "" }, variant: primary }
          ] }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { Space: "JUMP", ArrowUp: "JUMP", KeyW: "JUMP" }, backgroundImage: @config.backgroundImage, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), frame: (object/get @u frame) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      UNIT_CLICK -> running
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_coins.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_gem_yellow.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_keyGreen.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-jump", thumbnailUrl: "" }, variant: primary }
          ] }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { Space: "JUMP", ArrowUp: "JUMP", KeyW: "JUMP" }, backgroundImage: @config.backgroundImage, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), frame: (object/get @u frame) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      JUMP -> running when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.unitType "runner") (object/merge @u { animation: "attack" }) @u))))
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_coins.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_gem_yellow.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_keyGreen.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-jump", thumbnailUrl: "" }, variant: primary }
          ] }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { Space: "JUMP", ArrowUp: "JUMP", KeyW: "JUMP" }, backgroundImage: @config.backgroundImage, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), frame: (object/get @u frame) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.units (array/map @entity.units (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (set @entity.distance (+ @entity.distance 1))
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_p1.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_coins.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_gem_yellow.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-platformer-assets-base/ui/hud_sheet.json", sprite: "hud_keyGreen.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-jump", thumbnailUrl: "" }, variant: primary }
          ] }
          children: [ { type: canvas-2d, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { Space: "JUMP", ArrowUp: "JUMP", KeyW: "JUMP" }, backgroundImage: @config.backgroundImage, children: [
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter @entity.units (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), frame: (object/get @u frame) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
      JUMP -> external {
        id : string
      }
        @description "Jump input — tap/click to jump over obstacles"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : HolidayRunnerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [HolidayRunnerBoardTilesItem] = [{ x: 0, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.json", sprite: "background_clouds", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.json", sprite: "background_clouds", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.json", sprite: "background_clouds", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesheet-backgrounds-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/kenney-new-platformer-pack/terrain/spritesh