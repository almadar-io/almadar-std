app ui-holiday-runner-board "1.0.0"
"HolidayRunnerBoard — endless runner on a flat tiled scene, composed via game-shell."
orbital HolidayRunnerBoardOrbital {
  type HolidayRunnerBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type HolidayRunnerBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
  }
  type HolidayRunnerBoardUnitsItem = {
    id : string!
    position : HolidayRunnerBoardUnitsItemPosition
    x : number
    y : number
    sprite : Asset
    unitType : string
    name : string
    team : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    animation : string
    frame : number
  }
  type HolidayRunnerBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type HolidayRunnerBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
    color : string
  }
  type HolidayRunnerBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type HolidayRunnerBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity HolidayRunnerBoardItem [runtime] {
    id : string!
    units : [HolidayRunnerBoardUnitsItem]
    distance : number = 0
    score : number = 0
    result : string = ""
    effects : [HolidayRunnerBoardEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [HolidayRunnerBoardUnitsItemPosition] = []
  }

  trait HolidayRunnerBoardRender -> @rebindable HolidayRunnerBoardItem [interaction, instance] {
    initial: running

    state running {
      INIT -> running
        (set @entity.units @config.units)
        (set @entity.distance 0)
        (set @entity.score 0)
        (set @entity.result "")
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-distance.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", icon: arrow-up, variant: primary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, backgroundImage: @config.backgroundImage } ]
        })

      TILE_CLICK -> running
        (set @entity.selectedUnitId "")
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-distance.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", icon: arrow-up, variant: primary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, backgroundImage: @config.backgroundImage } ]
        })

      UNIT_CLICK -> running
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-distance.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", icon: arrow-up, variant: primary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, backgroundImage: @config.backgroundImage } ]
        })

      JUMP -> running when (== @entity.result "none")
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-distance.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", icon: arrow-up, variant: primary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, backgroundImage: @config.backgroundImage } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.units (array/map @entity.units (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (set @entity.distance (+ @entity.distance 1))
        (render-ui main {
          type: game-shell, backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }, hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Distance", value: @entity.distance, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-distance.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: timer-display, value: @entity.distance, label: "Distance" },
            { type: button, action: JUMP, label: "Jump", icon: arrow-up, variant: primary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, backgroundImage: @config.backgroundImage } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
      JUMP -> external {
        id : string
      }
        @description "Jump input — tap/click to jump over obstacles"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : HolidayRunnerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [HolidayRunnerBoardTilesItem] = [{ x: 0, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 4, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 5, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 6, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 7, y: 0, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 0, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 1, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 2, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 3, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 4, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 5, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 6, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 7, y: 1, terrain: "sky", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" } }, { x: 0, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 1, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 2, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 3, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 4, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 5, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 6, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 7, y: 2, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 0, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 1, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 2, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 3, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 4, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 5, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 6, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, { x: 7, y: 3, terrain: "ground", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }]
        @label "Tiles"
        @description "Side-scroll strip: rows 0–1 sky, rows 2–3 snow ground"
        @tier "presentation"
      units : [HolidayRunnerBoardUnitsItem] = [{ id: "runner1", position: { x: 1, y: 2 }, unitType: "runner", name: "Holiday Runner", team: player, health: 3, maxHealth: 3, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/units/runner.png", role: "npc", category: "runner", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "runner", thumbnailUrl: "" }, animation: "walk", frame: 0 }, { id: "obs1", position: { x: 4, y: 2 }, unitType: "obstacle", name: "Obstacle", team: neutral, health: 1, maxHealth: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/features/obstacle.png", role: "npc", category: "obstacle", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "obstacle", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "obs2", position: { x: 6, y: 2 }, unitType: "obstacle", name: "Obstacle", team: neutral, health: 1, maxHealth: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/features/obstacle.png", role: "npc", category: "obstacle", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "obstacle", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Runner (animation:walk) plus obstacles on the ground row"
        @tier "presentation"
      features : [HolidayRunnerBoardFeaturesItem] = []
        @label "Features"
        @description "Static features on the board"
        @tier "presentation"
      assetManifest : HolidayRunnerBoardAssetManifest = { terrains: { sky: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/sky.png", role: "tile", category: "sky", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "sky", thumbnailUrl: "" }, ground: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" } }, units: { runner: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/units/runner.png", role: "npc", category: "runner", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "runner", thumbnailUrl: "" }, obstacle: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/features/obstacle.png", role: "npc", category: "obstacle", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "obstacle", thumbnailUrl: "" } }, features: {}, effects: {} }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      backgroundImage : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-runner-board/default/backgrounds/winter.png", role: "decoration", category: "background", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "16:9", name: "winter", thumbnailUrl: "" }
        @label "Background Image"
        @description "Scrolling winter background"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  page "/holiday-runner-board" as HolidayRunnerBoardPage -> HolidayRunnerBoardRender
}
