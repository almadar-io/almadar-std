app ui-event-handler-board "1.0.0"
"EventHandlerBoard — wire WHEN/THEN rules on objects so a trigger event chain reaches the goal."
orbital EventHandlerBoardOrbital {
  type EventHandlerBoardError = {
    message : string!
    name    : string
    code    : string
    stack   : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type EventHandlerBoardEventOption = {
    id    : string!
    label : string
  }
  type EventHandlerBoardRule = {
    whenEvent  : string!
    thenAction : string!
  }
  type EventHandlerBoardObjectsItem = {
    id              : string!
    name            : string
    icon            : string
    states          : [string]
    currentState    : string
    availableEvents : [EventHandlerBoardEventOption]
    availableActions: [EventHandlerBoardEventOption]
    rules           : [EventHandlerBoardRule]
    maxRules        : number
  }

  entity EventHandlerBoardItem [runtime] {
    id           : string!
    objects      : [EventHandlerBoardObjectsItem]
    triggerEvents: [string]
    goalEvent    : string
    goalCondition: string
    title        : string
    description  : string
    hint         : string
    attempts     : number = 0
    result       : "none" | "win" = none
  }

  trait EventHandlerBoardRender -> @rebindable EventHandlerBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.objects      @config.objects)
        (set @entity.triggerEvents @config.triggerEvents)
        (set @entity.goalEvent    @config.goalEvent)
        (set @entity.goalCondition @config.goalCondition)
        (set @entity.title        @config.title)
        (set @entity.description  @config.description)
        (set @entity.hint         @config.hint)
        (set @entity.attempts     0)
        (set @entity.result       "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.objects      @config.objects)
        (set @entity.triggerEvents @config.triggerEvents)
        (set @entity.goalEvent    @config.goalEvent)
        (set @entity.goalCondition @config.goalCondition)
        (set @entity.title        @config.title)
        (set @entity.description  @config.description)
        (set @entity.hint         @config.hint)
        (set @entity.attempts     0)
        (set @entity.result       "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })

      EDIT_RULE -> playing
        (set @entity.objects (array/map @entity.objects (fn obj (if (== (object/get obj id) ?objectId) (object/merge obj { rules: ?rules }) obj))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })

      PLAY -> complete when (> (array/len (array/filter @entity.objects (fn obj (array/some (object/get obj rules) (fn rule (== (object/get rule thenAction) @entity.goalEvent)))))) 0)
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.result "win")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })

      PLAY -> playing when (== (array/len (array/filter @entity.objects (fn obj (array/some (object/get obj rules) (fn rule (== (object/get rule thenAction) @entity.goalEvent)))))) 0)
        (set @entity.attempts (+ @entity.attempts 1))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.objects      @config.objects)
        (set @entity.triggerEvents @config.triggerEvents)
        (set @entity.goalEvent    @config.goalEvent)
        (set @entity.goalCondition @config.goalCondition)
        (set @entity.title        @config.title)
        (set @entity.description  @config.description)
        (set @entity.hint         @config.hint)
        (set @entity.attempts     0)
        (set @entity.result       "none")
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })

      COMPLETE -> complete
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Goal", value: @entity.goalEvent }, { label: "Attempts", value: @entity.attempts }, { label: "Status", value: @entity.result } ] }, { type: stack, direction: horizontal, gap: sm, children: [ { type: button, action: PLAY, label: "Play", variant: primary }, { type: button, action: PLAY_AGAIN, label: "Reset", variant: secondary } ] } ] }
          children: [
            { type: card, children: [ { type: typography, variant: h4, content: @entity.title }, { type: typography, variant: body, content: @entity.description } ] },
            { type: data-list, entity: @entity.objects, fields: [], gap: sm, renderItem: (fn obj { type: card, children: [ { type: stack, direction: horizontal, gap: sm, justify: between, children: [ { type: typography, variant: label, content: @obj.name }, { type: badge, label: @obj.currentState }, { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [] }, label: "Clear", variant: ghost } ] }, { type: data-list, entity: @obj.rules, fields: [], gap: xs, renderItem: (fn r { type: badge, label: @r.thenAction }) }, { type: data-list, entity: @obj.availableActions, fields: [], gap: xs, renderItem: (fn a { type: button, action: EDIT_RULE, actionPayload: { objectId: @obj.id, rules: [{ whenEvent: (array/first @entity.triggerEvents), thenAction: @a.id }] }, label: @a.label, variant: (if (== @a.id @entity.goalEvent) "success" "ghost") }) } ] }) }
          ]
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
      }
        @description "Emitted by the component when the animated chain resolves (success or failure)."
        @tier "domain"
      PLAY -> external {
        id : string
      }
        @description "Player hits Play; component runs the animated simulation and fires COMPLETE."
        @tier "domain"
      EDIT_RULE -> external {
        objectId : string!
        rules    : [EventHandlerBoardRule]
      }
        @description "Player saves a WHEN/THEN rule set for one object."
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Reset to menu after completing the puzzle."
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : EventHandlerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      stepDurationMs : number = 800
        @label "Step Duration Ms"
        @description "Playback speed in ms per event"
        @tier "presentation"
      title : string = "Chain the Events"
        @label "Title"
        @description "Puzzle title shown above the board."
        @tier "domain"
      description : string = "Set WHEN/THEN rules on each object so the trigger events eventually fire the goal event."
        @label "Description"
        @description "One-line puzzle brief shown to the player."
        @tier "domain"
      hint : string = "The Alarm object needs to react to DOOR_OPEN and fire SIREN_ON. The Siren needs to react to SIREN_ON and fire ALERT_SENT."
        @label "Hint"
        @description "Optional hint revealed after 3 failed attempts."
        @tier "domain"
      goalCondition : string = "ALERT_SENT must fire during the simulation"
        @label "Goal Condition"
        @description "Human-readable description of the win condition shown to the player."
        @tier "domain"
      goalEvent : string = "ALERT_SENT"
        @label "Goal Event"
        @description "The event name that must appear in the simulated chain for the player to win."
        @tier "domain"
      triggerEvents : [string] = ["DOOR_OPEN"]
        @label "Trigger Events"
        @description "Events that fire automatically at the start of each simulation run."
        @tier "domain"
      objects : [EventHandlerBoardObjectsItem] = [{ id: "obj-door", name: "Door Sensor", icon: "🚪", states: ["closed", "open"], currentState: "closed", availableEvents: [{ id: "DOOR_OPEN", label: "DOOR_OPEN" }, { id: "DOOR_CLOSE", label: "DOOR_CLOSE" }], availableActions: [{ id: "SIREN_ON", label: "SIREN_ON" }, { id: "LIGHT_ON", label: "LIGHT_ON" }], rules: [], maxRules: 2 }, { id: "obj-alarm", name: "Alarm", icon: "🔔", states: ["silent", "ringing"], currentState: "silent", availableEvents: [{ id: "SIREN_ON", label: "SIREN_ON" }, { id: "DOOR_OPEN", label: "DOOR_OPEN" }], availableActions: [{ id: "ALERT_SENT", label: "ALERT_SENT" }, { id: "LOG_EVENT", label: "LOG_EVENT" }], rules: [], maxRules: 2 }]
        @label "Objects"
        @description "Puzzle world objects each with their editable WHEN/THEN rule slots."
        @tier "domain"
    }
  }

  page "/event-handler-board" as EventHandlerBoardPage -> EventHandlerBoardRender
}
