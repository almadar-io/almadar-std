app ui-fishing-board "1.0.0"
"FishingBoard — game-shell composition with LOLO-driven sprite animation and catch effects."
orbital FishingBoardOrbital {
  uses AnimTick from "std/behaviors/std-anim-tick"
  type FishingBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type FishingBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type FishingBoardUnitsItem = {
    id : string!
    position : FishingBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    spriteSheet : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [FishingBoardUnitsItemTraitsItem]
    previousPosition : FishingBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type FishingBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type FishingBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type FishingBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type FishingBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type FishingBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type FishingBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity FishingBoardItem [runtime] {
    id : string!
    units : [FishingBoardUnitsItem]
    selectedUnitId : string = ""
    catchCount : number = 0
    score : number = 0
    effects : [FishingBoardEffectItem] = []
  }

  trait FishingBoardRender -> @rebindable FishingBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.catchCount 0)
        (set @entity.score 0)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }, { type: action-button, action: CAST, label: "Cast", icon: "anchor" } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: [] } ]
        })

      TILE_CLICK -> playing
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }, { type: action-button, action: CAST, label: "Cast", icon: "anchor" } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: [] } ]
        })

      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }, { type: action-button, action: CAST, label: "Cast", icon: "anchor" } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: [] } ]
        })

      CAST -> playing
        (set @entity.selectedUnitId "")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?unitId) (object/merge @u { animation: "cast" }) @u))))
        (if (== ?hitFish true) (set @entity.catchCount (+ @entity.catchCount 1)) null)
        (if (== ?hitFish true) (set @entity.score (+ @entity.score ?points)) null)
        (if (== ?hitFish true) (set @entity.effects (array/append @entity.effects { key: "splash", x: ?x, y: ?y, ttl: 4 })) null)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }, { type: action-button, action: CAST, label: "Cast", icon: "anchor" } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: [] } ]
        })
    }

    ticks {
      renderTick every 100ms
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }, { type: action-button, action: CAST, label: "Cast", icon: "anchor" } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: [] } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
      CAST -> external {
        unitId : string!
        x : number!
        y : number!
        hitFish : boolean
        points : number
      }
        @description "Emits when a cast action is triggered"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : FishingBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [FishingBoardTilesItem] = [{ x: 0, y: 0, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 4, y: 0, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 0, y: 1, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 1, y: 1, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 2, y: 1, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 3, y: 1, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 4, y: 1, terrain: "water", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" } }, { x: 0, y: 2, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 1, y: 2, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 2, y: 2, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 3, y: 2, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 4, y: 2, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 0, y: 3, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 1, y: 3, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 2, y: 3, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 3, y: 3, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 4, y: 3, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 0, y: 4, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 1, y: 4, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 2, y: 4, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 3, y: 4, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, { x: 4, y: 4, terrain: "seabed", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }]
        @label "Tiles"
        @description "Flat top-down fishing scene tiles (water + seabed)"
        @tier "presentation"
      units : [FishingBoardUnitsItem] = [{ id: "u1", position: { x: 2, y: 0 }, unitType: "boat", name: "Fishing Boat", team: player, health: 10, maxHealth: 10, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/boat.png", role: "npc", category: "boat", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "boat", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { id: "u2", position: { x: 2, y: 2 }, unitType: "hook", name: "Hook", team: player, health: 10, maxHealth: 10, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/hook.png", role: "npc", category: "hook", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hook", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Units on the board (boat, hook)"
        @tier "presentation"
      features : [FishingBoardFeaturesItem] = [{ id: "f1", x: 0, y: 2, type: "seaweed", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png", role: "decoration", category: "seaweed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seaweed", thumbnailUrl: "" } }, { id: "f2", x: 1, y: 2, type: "fish", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-blue.png", role: "decoration", category: "fish-blue", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish-blue", thumbnailUrl: "" } }, { id: "f3", x: 3, y: 2, type: "fish", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-orange.png", role: "decoration", category: "fish-orange", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish-orange", thumbnailUrl: "" } }, { id: "f4", x: 4, y: 2, type: "seaweed", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png", role: "decoration", category: "seaweed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seaweed", thumbnailUrl: "" } }, { id: "f5", x: 0, y: 3, type: "fish", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-green.png", role: "decoration", category: "fish-green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish-green", thumbnailUrl: "" } }, { id: "f6", x: 2, y: 3, type: "fish", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-blue.png", role: "decoration", category: "fish-blue", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish-blue", thumbnailUrl: "" } }, { id: "f7", x: 4, y: 3, type: "fish", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-orange.png", role: "decoration", category: "fish-orange", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish-orange", thumbnailUrl: "" } }, { id: "f8", x: 1, y: 4, type: "seaweed", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png", role: "decoration", category: "seaweed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seaweed", thumbnailUrl: "" } }, { id: "f9", x: 2, y: 4, type: "fish", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-green.png", role: "decoration", category: "fish-green", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish-green", thumbnailUrl: "" } }, { id: "f10", x: 3, y: 4, type: "seaweed", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png", role: "decoration", category: "seaweed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seaweed", thumbnailUrl: "" } }]
        @label "Features"
        @description "Features on the board (fish spots, seaweed)"
        @tier "presentation"
      assetManifest : FishingBoardAssetManifest = { terrains: { water: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", role: "tile", category: "water", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "water", thumbnailUrl: "" }, seabed: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png", role: "tile", category: "seabed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seabed", thumbnailUrl: "" } }, units: { boat: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/boat.png", role: "npc", category: "boat", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "boat", thumbnailUrl: "" }, hook: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/hook.png", role: "npc", category: "hook", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hook", thumbnailUrl: "" } }, features: { fish: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-blue.png", role: "decoration", category: "fish", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "fish", thumbnailUrl: "" }, seaweed: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png", role: "decoration", category: "seaweed", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "seaweed", thumbnailUrl: "" } }, effects: { splash: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/spark_06.png", role: "effect", category: "splash", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "8:1", name: "splash", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      scale : number = 1
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  trait FishingBoardAnimTick = AnimTick.traits.AnimTick -> FishingBoardItem {
    config { frameCount: 8 }
  }

  page "/fishing-board" as FishingBoardPage -> FishingBoardRender, FishingBoardAnimTick
}
