app ui-match-puzzle-board "1.0.0"
"MatchPuzzleBoard — match-3 puzzle composed via game-shell with score/moves HUD and spark effects."
orbital MatchPuzzleBoardOrbital {
  type MatchPuzzleBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type MatchPuzzleBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
    animation : string
    frame : number
  }
  type MatchPuzzleBoardUnitsItem = {
    id : string!
    position : MatchPuzzleBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    spriteSheet : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [MatchPuzzleBoardUnitsItemTraitsItem]
    previousPosition : MatchPuzzleBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type MatchPuzzleEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type MatchPuzzleBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type MatchPuzzleBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type MatchPuzzleBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type MatchPuzzleBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type MatchPuzzleBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity MatchPuzzleBoardItem [runtime] {
    id : string!
    score : number = 0
    moves : number = 20
    combo : number = 0
    effects : [MatchPuzzleEffectItem] = []
    selectedTileId : string = ""
    validMoves : [MatchPuzzleBoardUnitsItemPosition] = []
  }

  trait MatchPuzzleBoardRender -> @rebindable MatchPuzzleBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.score 0)
        (set @entity.moves 20)
        (set @entity.combo 0)
        (set @entity.effects [])
        (set @entity.selectedTileId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Moves", value: @entity.moves, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-moves.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-moves", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: combo-counter, value: @entity.combo, label: "Combo" },
            { type: button, action: INIT, label: "Restart", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @config.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedTileId, validMoves: @entity.validMoves } ]
        })

      TILE_CLICK -> playing when (> @entity.moves 0)
        (set @entity.moves (- @entity.moves 1))
        (set @entity.score (+ @entity.score 10))
        (set @entity.combo (+ @entity.combo 1))
        (if (> (array/len (object/get @config.assetManifest effects)) 0) (set @entity.effects (array/append @entity.effects { key: "spark", x: ?x, y: ?y, ttl: 4 })) null)
        (set @entity.selectedTileId "")
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Moves", value: @entity.moves, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-moves.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-moves", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: combo-counter, value: @entity.combo, label: "Combo" },
            { type: button, action: INIT, label: "Restart", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @config.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedTileId, validMoves: @entity.validMoves } ]
        })

      UNIT_CLICK -> playing
        (set @entity.selectedTileId ?unitId)
        (set @entity.combo 0)
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Moves", value: @entity.moves, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-moves.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-moves", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: combo-counter, value: @entity.combo, label: "Combo" },
            { type: button, action: INIT, label: "Restart", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @config.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedTileId, validMoves: @entity.validMoves } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [
            { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-score.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Moves", value: @entity.moves, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/ui/icon-moves.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-moves", thumbnailUrl: "" } } ] },
            { type: score-display, value: @entity.score, label: "Score" },
            { type: combo-counter, value: @entity.combo, label: "Combo" },
            { type: button, action: INIT, label: "Restart", icon: refresh, variant: secondary }
          ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @config.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "flat", showMinimap: false, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedTileId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
    }

    config {
      tiles : [MatchPuzzleBoardTilesItem] = [{ x: 0, y: 0, terrain: "gem_red",    passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_red.png", role: "tile", category: "gem_red", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_red", thumbnailUrl: "" },    animation: "idle", frame: 0 }, { x: 1, y: 0, terrain: "gem_blue",   passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_blue.png", role: "tile", category: "gem_blue", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_blue", thumbnailUrl: "" },   animation: "idle", frame: 0 }, { x: 2, y: 0, terrain: "gem_green",  passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_green.png", role: "tile", category: "gem_green", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_green", thumbnailUrl: "" },  animation: "idle", frame: 0 }, { x: 3, y: 0, terrain: "gem_yellow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_yellow.png", role: "tile", category: "gem_yellow", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_yellow", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 4, y: 0, terrain: "gem_purple", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_purple.png", role: "tile", category: "gem_purple", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_purple", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 0, y: 1, terrain: "gem_blue",   passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_blue.png", role: "tile", category: "gem_blue", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_blue", thumbnailUrl: "" },   animation: "idle", frame: 0 }, { x: 1, y: 1, terrain: "gem_green",  passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_green.png", role: "tile", category: "gem_green", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_green", thumbnailUrl: "" },  animation: "idle", frame: 0 }, { x: 2, y: 1, terrain: "gem_yellow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_yellow.png", role: "tile", category: "gem_yellow", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_yellow", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 3, y: 1, terrain: "gem_purple", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_purple.png", role: "tile", category: "gem_purple", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_purple", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 4, y: 1, terrain: "gem_red",    passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_red.png", role: "tile", category: "gem_red", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_red", thumbnailUrl: "" },    animation: "idle", frame: 0 }, { x: 0, y: 2, terrain: "gem_green",  passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_green.png", role: "tile", category: "gem_green", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_green", thumbnailUrl: "" },  animation: "idle", frame: 0 }, { x: 1, y: 2, terrain: "gem_yellow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_yellow.png", role: "tile", category: "gem_yellow", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_yellow", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 2, y: 2, terrain: "gem_red",    passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_red.png", role: "tile", category: "gem_red", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_red", thumbnailUrl: "" },    animation: "idle", frame: 0 }, { x: 3, y: 2, terrain: "gem_blue",   passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_blue.png", role: "tile", category: "gem_blue", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_blue", thumbnailUrl: "" },   animation: "idle", frame: 0 }, { x: 4, y: 2, terrain: "gem_green",  passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_green.png", role: "tile", category: "gem_green", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_green", thumbnailUrl: "" },  animation: "idle", frame: 0 }, { x: 0, y: 3, terrain: "gem_purple", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_purple.png", role: "tile", category: "gem_purple", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_purple", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 1, y: 3, terrain: "gem_red",    passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_red.png", role: "tile", category: "gem_red", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_red", thumbnailUrl: "" },    animation: "idle", frame: 0 }, { x: 2, y: 3, terrain: "gem_blue",   passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_blue.png", role: "tile", category: "gem_blue", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_blue", thumbnailUrl: "" },   animation: "idle", frame: 0 }, { x: 3, y: 3, terrain: "gem_green",  passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_green.png", role: "tile", category: "gem_green", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_green", thumbnailUrl: "" },  animation: "idle", frame: 0 }, { x: 4, y: 3, terrain: "gem_yellow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_yellow.png", role: "tile", category: "gem_yellow", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_yellow", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 0, y: 4, terrain: "gem_purple", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_purple.png", role: "tile", category: "gem_purple", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_purple", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 1, y: 4, terrain: "gem_purple", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_purple.png", role: "tile", category: "gem_purple", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_purple", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 2, y: 4, terrain: "gem_yellow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_yellow.png", role: "tile", category: "gem_yellow", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_yellow", thumbnailUrl: "" }, animation: "idle", frame: 0 }, { x: 3, y: 4, terrain: "gem_red",    passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_red.png", role: "tile", category: "gem_red", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_red", thumbnailUrl: "" },    animation: "idle", frame: 0 }, { x: 4, y: 4, terrain: "gem_blue",   passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_blue.png", role: "tile", category: "gem_blue", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_blue", thumbnailUrl: "" },   animation: "idle", frame: 0 }]
        @label "Tiles"
        @description "Grid tiles for the match puzzle board"
        @tier "presentation"
      units : [MatchPuzzleBoardUnitsItem] = []
        @label "Units"
        @description "Units on the board"
        @tier "presentation"
      features : [MatchPuzzleBoardFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "powerup", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/features/powerup.png", role: "decoration", category: "powerup", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "powerup", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 3, type: "blocker", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/features/blocker.png", role: "decoration", category: "blocker", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "blocker", thumbnailUrl: "" } }, { id: "f3", x: 4, y: 4, type: "blocker", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/features/blocker.png", role: "decoration", category: "blocker", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "blocker", thumbnailUrl: "" } }]
        @label "Features"
        @description "Gem/tile features on the board"
        @tier "presentation"
      assetManifest : MatchPuzzleBoardAssetManifest = { terrains: { gem_red: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_red.png", role: "tile", category: "gem_red", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_red", thumbnailUrl: "" }, gem_blue: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_blue.png", role: "tile", category: "gem_blue", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_blue", thumbnailUrl: "" }, gem_green: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_green.png", role: "tile", category: "gem_green", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_green", thumbnailUrl: "" }, gem_yellow: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_yellow.png", role: "tile", category: "gem_yellow", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_yellow", thumbnailUrl: "" }, gem_purple: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/terrain/gem_purple.png", role: "tile", category: "gem_purple", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gem_purple", thumbnailUrl: "" } }, units: {}, features: { powerup: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/features/powerup.png", role: "decoration", category: "powerup", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "powerup", thumbnailUrl: "" }, blocker: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/features/blocker.png", role: "decoration", category: "blocker", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "blocker", thumbnailUrl: "" } }, effects: { spark: { url: "https://almadar-kflow-assets.web.app/shared/ui-match-puzzle-board/default/effects/spark_06.png", role: "effect", category: "spark", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "8:1", name: "spark", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Asset sprite manifest — terrains/units/features/effects maps"
        @tier "presentation"
      assetBaseUrl : Asset = "https://almadar-kflow-assets.web.app/shared/"
