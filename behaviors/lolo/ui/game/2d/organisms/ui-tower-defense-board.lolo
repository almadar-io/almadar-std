app ui-tower-defense-board "1.0.0"
"TowerDefenseBoard — game-shell composition with LOLO-driven sprite animation and combat effects."
orbital TowerDefenseBoardOrbital {
  type TowerDefenseBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type TowerDefenseBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : Asset
    passable : boolean
  }
  type TowerDefenseBoardPathItem = {
    x : number!
    y : number!
  }
  type TowerDefenseBoardTowersItem = {
    id : string!
    x : number!
    y : number!
    range : number!
    damage : number!
    cooldown : number!
    lastFiredAt : number
  }
  type TowerDefenseBoardCreepsItem = {
    id : string!
    x : number!
    y : number!
    hp : number!
    maxHp : number!
    pathIndex : number!
    speed : number!
    animation : string
    frame : number
  }
  type TowerDefenseBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type TowerDefenseBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type TowerDefenseBoardHero = {
    id : string!
    x : number!
    y : number!
  }
  type TowerDefenseBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity TowerDefenseBoardItem [runtime] {
    id : string!
    tiles : [TowerDefenseBoardTilesItem]
    path : [TowerDefenseBoardPathItem]
    towers : [TowerDefenseBoardTowersItem]
    creeps : [TowerDefenseBoardCreepsItem]
    hero : TowerDefenseBoardHero
    selectedUnitId : string = ""
    validMoves : [TowerDefenseBoardPathItem] = []
    gold : number = 100
    lives : number = 20
    wave : number = 1
    maxWaves : number = 5
    result : "none" | "won" | "lost" = none
    tick : number = 0
    waveActive : boolean = false
    effects : [TowerDefenseBoardEffectItem] = []
    waypointLabels : [string] = []
  }

  trait TowerDefenseBoardRender -> @rebindable TowerDefenseBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.gold @config.gold)
        (set @entity.lives @config.lives)
        (set @entity.wave 1)
        (set @entity.maxWaves @config.maxWaves)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.waveActive false)
        (set @entity.towers @config.towers)
        (set @entity.creeps [])
        (set @entity.hero @config.hero)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.effects [])
        (set @entity.waypointLabels [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      PLACE_TOWER -> playing when (and (>= @entity.gold @config.towerCost) (and (grid/in-bounds { x: ?x, y: ?y } @config.gridWidth @config.gridHeight) (and (== (array/len (array/filter @entity.towers (fn t (and (== @t.x ?x) (== @t.y ?y))))) 0) (== (array/len (array/filter @config.path (fn p (and (== (object/get @p x) ?x) (== (object/get @p y) ?y))))) 0))))
        (set @entity.gold (- @entity.gold @config.towerCost))
        (set @entity.towers (array/concat @entity.towers [{ id: (str/concat "tower-" (array/len @entity.towers)), x: ?x, y: ?y, range: @config.towerRange, damage: @config.towerDamage, cooldown: @config.towerCooldown, lastFiredAt: 0 }]))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      START_WAVE -> playing when (and (== @entity.waveActive false) (== @entity.result "none"))
        (set @entity.waveActive true)
        (set @entity.creeps (array/map (array/range 0 @config.creepsPerWave) (fn i { id: (str/concat "creep-" @i), x: (object/get (array/first @config.path) x), y: (object/get (array/first @config.path) y), hp: (+ @config.creepBaseHp (* @i @config.creepHpScaling)), maxHp: (+ @config.creepBaseHp (* @i @config.creepHpScaling)), pathIndex: 0, speed: @config.creepSpeed, animation: "walk", frame: 0 })))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      MOVE_HERO -> playing when (== @entity.result "none")
        (set @entity.hero (object/merge @entity.hero { x: (math/max 0 (math/min (- @config.gridWidth 1) (+ (object/get @entity.hero x) ?dx))), y: (math/max 0 (math/min (- @config.gridHeight 1) (+ (object/get @entity.hero y) ?dy))) }))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.gold @config.gold)
        (set @entity.lives @config.lives)
        (set @entity.wave 1)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.waveActive false)
        (set @entity.towers @config.towers)
        (set @entity.creeps [])
        (set @entity.hero @config.hero)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.effects [])
        (set @entity.waypointLabels [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.creeps (array/map @entity.creeps (fn c (object/merge @c { frame: (% (+ (object/get @c frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      creepMoveTick every 1s
        when (and (== @entity.waveActive true) (and (== @entity.result "none") (> (array/len @entity.creeps) 0)))
        (set @entity.tick (+ @entity.tick 1))
        (set @entity.creeps (array/map @entity.creeps (fn c (let ((nextIndex (math/min (+ (object/get @c pathIndex) 1) (- (array/len @config.path) 1))) (nextWaypoint (array/nth @config.path (math/min (+ (object/get @c pathIndex) 1) (- (array/len @config.path) 1))))) (object/merge @c { x: (object/get @nextWaypoint x), y: (object/get @nextWaypoint y), pathIndex: @nextIndex, animation: "walk" })))))
        (if (> (array/len (array/filter @entity.creeps (fn c (== (object/get @c pathIndex) (- (array/len @config.path) 1))))) 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (array/first (array/filter @entity.creeps (fn c (== (object/get @c pathIndex) (- (array/len @config.path) 1))))) x), y: (object/get (array/first (array/filter @entity.creeps (fn c (== (object/get @c pathIndex) (- (array/len @config.path) 1))))) y), ttl: 5 })) null)
        (set @entity.lives (- @entity.lives (array/len (array/filter @entity.creeps (fn c (== (object/get @c pathIndex) (- (array/len @config.path) 1)))))))
        (set @entity.creeps (array/filter @entity.creeps (fn c (< (object/get @c pathIndex) (- (array/len @config.path) 1)))))
        (set @entity.result (if (<= @entity.lives 0) "lost" @entity.result))
        (set @entity.waveActive (if (<= @entity.lives 0) false (if (== (array/len @entity.creeps) 0) false @entity.waveActive)))
        (set @entity.wave (if (and (== (array/len @entity.creeps) 0) (and (> @entity.lives 0) (== @entity.result "none"))) (+ @entity.wave 1) @entity.wave))
        (set @entity.result (if (and (== (array/len @entity.creeps) 0) (and (> @entity.lives 0) (>= @entity.wave @entity.maxWaves))) "won" @entity.result))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })

      towerFireTick every 1s
        when (and (== @entity.waveActive true) (and (== @entity.result "none") (> (array/len @entity.creeps) 0)))
        (set @entity.creeps (array/map @entity.creeps (fn c (let ((inRangeTowers (array/filter @entity.towers (fn t (<= (vec/distance { x: (object/get @t x), y: (object/get @t y) } { x: (object/get @c x), y: (object/get @c y) }) (object/get @t range)))))) (if (> (array/len @inRangeTowers) 0) (object/merge @c { hp: (math/max 0 (- (object/get @c hp) (object/get (array/first @inRangeTowers) damage))), animation: (if (<= (math/max 0 (- (object/get @c hp) (object/get (array/first @inRangeTowers) damage))) 0) "death" "walk") }) @c)))))
        (if (> (array/len (array/filter @entity.creeps (fn c (<= (object/get @c hp) 0)))) 0) (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get (array/first (array/filter @entity.creeps (fn c (<= (object/get @c hp) 0)))) x), y: (object/get (array/first (array/filter @entity.creeps (fn c (<= (object/get @c hp) 0)))) y), ttl: 5 })) null)
        (set @entity.gold (+ @entity.gold (* @config.goldPerKill (array/len (array/filter @entity.creeps (fn c (<= (object/get @c hp) 0)))))))
        (set @entity.creeps (array/filter @entity.creeps (fn c (> (object/get @c hp) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Towers", value: (array/len @entity.towers) } ] }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower" })), effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      PLACE_TOWER -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{placeTowerEvent} with {x,y} on tile click when player places a tower"
        @tier "domain"
      START_WAVE -> external {
        wave : number
      }
        @description "Emits UI:{startWaveEvent} with {wave} when player launches a creep wave"
        @tier "domain"
      GAME_END -> external {
        result : string!
      }
        @description "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
      MOVE_HERO -> external {
        dx : number!
        dy : number!
      }
        @description "Emits UI:{moveHeroEvent} with {dx,dy} on arrow-key press to move the player hero"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "unitClickEvent prop — emitted when a creep is clicked on the canvas"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : TowerDefenseBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      gridWidth : number = 16
        @label "Grid Width"
        @description "Number of columns in the tile grid"
        @tier "presentation"
      gridHeight : number = 16
        @label "Grid Height"
        @description "Number of rows in the tile grid"
        @tier "presentation"
      gold : number = 100
        @label "Starting Gold"
        @description "Gold the player starts each game with"
        @tier "presentation"
      lives : number = 20
        @label "Starting Lives"
        @description "Lives the player starts with; reaching 0 = defeat"
        @tier "presentation"
      maxWaves : number = 5
        @label "Max Waves"
        @description "Number of waves to survive to win"
        @tier "presentation"
      towerCost : number = 25
        @label "Tower Cost"
        @description "Gold cost to place one tower"
        @tier "presentation"
      towerRange : number = 2
        @label "Tower Range"
        @description "Attack range in grid units"
        @tier "presentation"
      towerDamage : number = 3
        @label "Tower Damage"
        @description "Damage per hit per tower"
        @tier "presentation"
      towerCooldown : number = 1
        @label "Tower Cooldown"
        @description "Seconds between tower shots"
        @tier "presentation"
      creepsPerWave : number = 5
        @label "Creeps Per Wave"
        @description "Number of creeps spawned per wave"
        @tier "presentation"
      creepBaseHp : number = 10
        @label "Creep Base HP"
        @description "Base HP of the first creep in a wave"
        @tier "presentation"
      creepHpScaling : number = 2
        @label "Creep HP Scaling"
        @description "Additional HP per creep index within a wave"
        @tier "presentation"
      creepSpeed : number = 1
        @label "Creep Speed"
        @description "Waypoints advanced per tick"
        @tier "presentation"
      goldPerKill : number = 10
        @label "Gold Per Kill"
        @description "Gold awarded for each creep killed"
        @tier "presentation"
