        @label "Tiles"
        @description "Direct tile data — takes priority over entity-derived tiles."
        @tier "presentation"
      path : [TowerDefenseBoardPathItem] = [{x:0,y:2},{x:1,y:2},{x:2,y:2},{x:3,y:2},{x:4,y:2},{x:5,y:2},{x:6,y:2},{x:7,y:2},{x:7,y:3},{x:7,y:4},{x:7,y:5},{x:7,y:6},{x:7,y:7},{x:6,y:7},{x:5,y:7},{x:4,y:7},{x:3,y:7},{x:2,y:7},{x:2,y:8},{x:2,y:9},{x:2,y:10},{x:3,y:10},{x:4,y:10},{x:5,y:10},{x:6,y:10},{x:7,y:10},{x:8,y:10},{x:9,y:10},{x:10,y:10},{x:11,y:10},{x:12,y:10},{x:13,y:10},{x:13,y:11},{x:13,y:12},{x:13,y:13},{x:14,y:13},{x:15,y:13}]
        @label "Path"
        @description "Ordered waypoint coords that creeps follow from entry to exit."
        @tier "presentation"
      towers : [TowerDefenseBoardTowersItem] = [{id:"t0",x:1,y:1,range:3,damage:4,cooldown:1,lastFiredAt:0},{id:"t1",x:8,y:3,range:3,damage:4,cooldown:1,lastFiredAt:0},{id:"t2",x:6,y:6,range:3,damage:4,cooldown:1,lastFiredAt:0},{id:"t3",x:3,y:9,range:3,damage:4,cooldown:1,lastFiredAt:0},{id:"t4",x:12,y:9,range:3,damage:4,cooldown:1,lastFiredAt:0}]
        @label "Towers"
        @description "Initial tower placements on the board."
        @tier "presentation"
      scale : number = 0.25
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 0.6
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      hero : TowerDefenseBoardHero = { id: "hero", x: 8, y: 8 }
        @label "Hero"
        @description "Controllable player hero; seeded at map center"
        @tier "presentation"
      assetManifest : TowerDefenseBoardAssetManifest = { terrains: { ground: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png", role: "tile", category: "ground", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" }, path: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png", role: "tile", category: "path", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "path", thumbnailUrl: "" }, wall: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, stone: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, units: { creep: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/creep.png", role: "npc", category: "creep", animations: ["idle","walk","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "creep", thumbnailUrl: "" }, hero: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/hero.png", role: "player", category: "hero", animations: ["idle","walk","attack","hit","death"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "hero", thumbnailUrl: "" } }, features: { tower: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/features/tower.png", role: "decoration", category: "tower", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "1:1", name: "tower", thumbnailUrl: "" } }, effects: { explosion: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/effects/pixelExplosion07.png", role: "effect", category: "explosion", animations: ["static"], style: "", variant: "", dimension: "2d", aspect: "8:1", name: "explosion", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Base-url + terrain/unit/structure sprite maps; towers render as the structure asset."
        @tier "presentation"
      features : [TowerDefenseBoardFeaturesItem] = []
        @label "Features"
        @description "Static map features (structures, decorations) rendered on the board."
        @tier "presentation"
    }
  }

  page "/tower-defense-board" as TowerDefenseBoardPage -> TowerDefenseBoardRender
