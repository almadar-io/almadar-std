        @label "Tiles"
        @description "Grid tiles (floor, wall, target)"
        @tier "presentation"
      units : [SokobanBoardUnitsItem] = [{ id: "pusher", position: { x: 4, y: 2 }, unitType: "pusher", name: "Pusher", team: player, health: 10, maxHealth: 10, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/units/pusher.png", role: "npc", category: "pusher", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "pusher", thumbnailUrl: "" }, animation: "idle", frame: 0 }]
        @label "Units"
        @description "Units on the board (the pusher character)"
        @tier "presentation"
      features : [SokobanBoardFeaturesItem] = [{ id: "crate1", x: 2, y: 1, type: "crate", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/features/crate.png", role: "decoration", category: "crate", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "crate", thumbnailUrl: "" } }, { id: "crate2", x: 2, y: 3, type: "crate", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/features/crate.png", role: "decoration", category: "crate", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "crate", thumbnailUrl: "" } }, { id: "crate3", x: 2, y: 5, type: "crate", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/features/crate.png", role: "decoration", category: "crate", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "crate", thumbnailUrl: "" } }]
        @label "Features"
        @description "Features (crates) on the board"
        @tier "presentation"
      assetManifest : SokobanBoardAssetManifest = { terrains: { floor: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/terrain/floor.png", role: "tile", category: "floor", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "floor", thumbnailUrl: "" }, wall: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/terrain/wall.png", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, target: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/terrain/target.png", role: "tile", category: "target", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "target", thumbnailUrl: "" } }, units: { pusher: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/units/pusher.png", role: "npc", category: "pusher", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "pusher", thumbnailUrl: "" } }, features: { crate: { url: "https://almadar-kflow-assets.web.app/shared/ui-sokoban-board/default/features/crate.png", role: "decoration", category: "crate", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "crate", thumbnailUrl: "" } }, effects: {} }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      assetBaseUrl : Asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prepended to manifest sprite paths"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
      showMinimap : boolean = false
        @label "Show Minimap"
        @description "Show minimap overlay"
        @tier "presentation"
      enableCamera : boolean = false
        @label "Enable Camera"
        @description "Enable camera pan/zoom controls"
        @tier "presentation"
    }
  }

  trait SokobanBoardAnimTick = AnimTick.traits.AnimTick -> SokobanBoardItem {
    config { frameCount: 8 }
  }

  page "/sokoban-board" as SokobanBoardPage -> SokobanBoardRender, SokobanBoardAnimTick
}
