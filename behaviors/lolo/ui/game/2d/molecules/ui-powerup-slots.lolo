app ui-powerup-slots "1.0.0"
"PowerupSlots — ticks down remainingTime on each active powerup; drops expired ones."
orbital PowerupSlotsOrbital {
  type PowerupSlotsActiveItem = {
    id : string!
    icon : icon
    label : string!
    remainingTime : number
  }

  entity PowerupSlotsItem [runtime] {
    id     : string!
    active : [PowerupSlotsActiveItem]
  }

  trait PowerupSlotsRender -> @rebindable PowerupSlotsItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.active @config.active)
        (render-ui main {
          active: @entity.active
          maxSlots: @config.maxSlots
          className: @config.className
          type: powerup-slots
        })
    }

    ticks {
      powerupTick every 1s
        when (> (array/len @entity.active) 0)
        (set @entity.active
          (array/filter
            (array/map @entity.active (fn p (object/merge @p { remainingTime: (- (object/get @p remainingTime) 1) })))
            (fn p (> (object/get @p remainingTime) 0))))
        (render-ui main {
          active: @entity.active
          maxSlots: @config.maxSlots
          className: @config.className
          type: powerup-slots
        })
    }

    config {
      active : [PowerupSlotsActiveItem] = [{ id: "Id", icon: "circle", label: "Label", remainingTime: 1 }]
        @label "Active"
        @description "Array of active powerups"
        @tier "presentation"
      maxSlots : number = 4
        @label "Max Slots"
        @description "Maximum number of powerup slots"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/powerup-slots" as PowerupSlotsPage -> PowerupSlotsRender
}
