app ui-game-hud "1.0.0"
"GameHud — UI factory (1:1 with the @almadar/ui game-hud pattern)."
orbital GameHudOrbital {
  type GameHudStatsItem = {
    source : string
    field : string
  }
  type GameHudItemsItem = {
    source : string
    field : string
  }
  type GameHudElementsItem = {
    type : string
    bind : string
    position : string
    label : string
    value : string
    icon : icon
    assetUrl : GameHudElementsItemAssetUrl
    format : string
    max : number
  }
  type GameHudElementsItemAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity GameHudItem [runtime] {
    id : string!
  }

  trait GameHudRender -> @rebindable GameHudItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          position: @config.position
          stats: @config.stats
          items: @config.items
          elements: @config.elements
          size: @config.size
          className: @config.className
          transparent: @config.transparent
          type: game-hud
        })
    }

    config {
      position : "top" | "bottom" | "corners" = top
        @label "Position"
        @description "Position of the HUD"
        @tier "presentation"
      stats : [GameHudStatsItem] = [{ source: "Source", field: "Field" }, { source: "Source 2", field: "Field 2" }]
        @label "Stats"
        @description "Stats to display - accepts readonly for compatibility with generated const arrays"
        @tier "presentation"
      items : [GameHudItemsItem] = [{ source: "Source", field: "Field" }, { source: "Source 2", field: "Field 2" }]
        @label "Items"
        @description "Alias for stats (schema compatibility)"
        @tier "presentation"
      elements : [GameHudElementsItem] = [{ type: "Type", bind: "Bind", position: "Position", label: "Label", value: "Value", icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }, format: "Format", max: 1 }, { type: "Type 2", bind: "Bind 2", position: "Position 2", label: "Label 2", value: "Value 2", icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }, format: "Format 2", max: 2 }]
        @label "Elements"
        @description "Schema-style elements array (alternative to stats). Converted to stats internally for backwards compatibility."
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      transparent : boolean = true
        @label "Transparent"
        @description "Whether to use a semi-transparent background"
        @tier "presentation"
    }
  }

  page "/game-hud" as GameHudPage -> GameHudRender
}
