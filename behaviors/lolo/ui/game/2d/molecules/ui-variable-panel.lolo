app ui-variable-panel "1.0.0"
"VariablePanel — UI factory (1:1 with the @almadar/ui variable-panel pattern)."
orbital VariablePanelOrbital {
  type VariablePanelVariablesItem = {
    name : string!
    value : string!
  }

  entity VariablePanelItem [runtime] {
    id : string!
  }

  trait VariablePanelRender -> @rebindable VariablePanelItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entityName: @config.entityName
          variables: @config.variables
          className: @config.className
          type: variable-panel
        })
    }

    config {
      entityName : string = "Entity Name"
        @label "Entity Name"
        @description "Entity name shown in the header"
        @tier "presentation"
      variables : [VariablePanelVariablesItem] = [{ name: "Name", value: "Value" }, { name: "Name 2", value: "Value 2" }]
        @label "Variables"
        @description "Variable rows to display"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/variable-panel" as VariablePanelPage -> VariablePanelRender
}
