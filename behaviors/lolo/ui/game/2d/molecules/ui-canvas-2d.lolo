app ui-canvas-2d "1.0.0"
"Canvas2d — UI factory (1:1 with the @almadar/ui canvas-2d pattern)."
orbital Canvas2dOrbital {
  type Canvas2dError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Canvas2dPlatformsItem = {
    x : number!
    y : number!
    width : number!
    height : number!
    type : "ground" | "platform" | "hazard" | "goal"
  }
  type Canvas2dPlayer = {
    x : number!
    y : number!
    width : number
    height : number
    vx : number
    vy : number
    grounded : boolean
    facingRight : boolean
  }
  type Canvas2dBackgroundImage = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Canvas2dValidMovesItem = {
    x : number!
    y : number!
  }
  type Canvas2dAttackTargetsItem = {
    x : number!
    y : number!
  }
  type Canvas2dHoveredTile = {
    x : number!
    y : number!
  }
  type Canvas2dAnimate = {
    fps : number!
  }
  type Canvas2dPlayerSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Canvas2dTileSpritesValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Canvas2dAssetManifest = {
    terrains : Map string Canvas2dAssetManifestTerrainsValue
    units : Map string Canvas2dAssetManifestUnitsValue
    features : Map string Canvas2dAssetManifestFeaturesValue
    effects : Map string Canvas2dAssetManifestEffectsValue
  }
  type Canvas2dAssetManifestTerrainsValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Canvas2dAssetManifestUnitsValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Canvas2dAssetManifestFeaturesValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Canvas2dAssetManifestEffectsValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity Canvas2dItem [runtime] {
    id : string!
  }

  trait Canvas2dRender -> @rebindable Canvas2dItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          projection: @config.projection
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          effects: @config.effects
          platforms: @config.platforms
          player: @config.player
          backgroundImage: @config.backgroundImage
          selectedUnitId: @config.selectedUnitId
          validMoves: @config.validMoves
          attackTargets: @config.attackTargets
          hoveredTile: @config.hoveredTile
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          tileHoverEvent: TILE_HOVER
          tileLeaveEvent: TILE_LEAVE
          keyEvent: KEY
          camera: @config.camera
          scale: @config.scale
          unitScale: @config.unitScale
          showMinimap: @config.showMinimap
          animate: @config.animate
          debug: @config.debug
          spriteHeightRatio: @config.spriteHeightRatio
          spriteMaxWidthRatio: @config.spriteMaxWidthRatio
          diamondTopY: @config.diamondTopY
          effectSpriteUrls: @config.effectSpriteUrls
          playerSprite: @config.playerSprite
          tileSprites: @config.tileSprites
          bgColor: @config.bgColor
          worldWidth: @config.worldWidth
          worldHeight: @config.worldHeight
          assetManifest: @config.assetManifest
          type: canvas-2d
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "--- Declarative events back to LOLO ---"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
      TILE_HOVER -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileHoverEvent} with { x, y } on tile hover"
        @tier "essential"
      TILE_LEAVE -> external {
        id : string
      }
        @description "Emits UI:{tileLeaveEvent} with {} on tile leave"
        @tier "essential"
      KEY -> external {
        key : string!
      }
        @description "Emits UI:{keyEvent} with { key } on keydown — for side/free keyboard control"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "--- Closed-circuit ---"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : Canvas2dError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      projection : "isometric" | "hex" | "flat" | "free" | "side" = isometric
        @label "Projection"
        @description "--- Projection ---"
        @tier "presentation"
      tiles : [json] = []
        @label "Tiles"
        @description "--- Layer data (each an optional render pass) ---"
        @tier "presentation"
      units : [json] = []
        @label "Units"
        @description "Units on the board"
        @tier "presentation"
      features : [json] = []
        @label "Features"
        @description "Features (resources, portals, buildings, etc.)"
        @tier "presentation"
      effects : [json] = []
        @label "Effects"
        @description "Active visual effects, drawn after units"
        @tier "presentation"
      platforms : [Canvas2dPlatformsItem] = [{ x: 1, y: 1, width: 1, height: 1, type: ground }, { x: 2, y: 2, width: 2, height: 2, type: platform }]
        @label "Platforms"
        @description "Side-view platforms (AABB). `projection:'side'` only."
        @tier "presentation"
      player : Canvas2dPlayer = { x: 1, y: 1, width: 1, height: 1, vx: 1, vy: 1, grounded: false, facingRight: false }
        @label "Player"
        @description "Side-view player. `projection:'side'` only."
        @tier "presentation"
      backgroundImage : Canvas2dBackgroundImage = { url: "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png", role: "decoration", category: "backgroundImage", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "backgroundImage", thumbnailUrl: "" }
        @label "Background Image"
        @description "Background image (tiled behind iso/hex/flat/free; stretched in side)."
        @tier "presentation"
      selectedUnitId : string = ""
        @label "Selected Unit Id"
        @description "--- Interaction state (LOLO-owned, passed in) ---"
        @tier "presentation"
      validMoves : [Canvas2dValidMovesItem] = [{ x: 1, y: 1 }, { x: 2, y: 2 }]
        @label "Valid Moves"
        @description "Valid move positions (pulsing green highlights)"
        @tier "presentation"
      attackTargets : [Canvas2dAttackTargetsItem] = [{ x: 1, y: 1 }, { x: 2, y: 2 }]
        @label "Attack Targets"
        @description "Attack target positions (pulsing red highlights)"
        @tier "presentation"
      hoveredTile : Canvas2dHoveredTile = { x: 1, y: 1 }
        @label "Hovered Tile"
        @description "Hovered tile position"
        @tier "presentation"
      camera : "pan-zoom" | "follow" | "fixed" = "pan-zoom"
        @label "Camera"
        @description "--- View config (pure render) ---"
        @tier "presentation"
      scale : number = 0.4
        @label "Scale"
        @description "Render scale (0.4 = 40% zoom)."
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Extra scale multiplier for unit draw size. 1 = default."
        @tier "presentation"
      showMinimap : boolean = true
        @label "Show Minimap"
        @description "Toggle minimap overlay."
        @tier "presentation"
      animate : Canvas2dAnimate = { fps: 1 }
        @label "Animate"
        @description "Opt-in internal RAF clock. DEFAULT OFF — the LOLO state machine drives the clock."
        @tier "presentation"
      debug : boolean = false
        @label "Debug"
        @description "--- Tuning (iso/hex/flat/free) ---"
        @tier "presentation"
      spriteHeightRatio : number = 1.5
        @label "Sprite Height Ratio"
        @description "Ratio of unit draw height to scaledFloorHeight. Default 1.5."
        @tier "presentation"
      spriteMaxWidthRatio : number = 0.6
        @label "Sprite Max Width Ratio"
        @description "Max unit draw width as a ratio of scaledTileWidth. Default 0.6."
        @tier "presentation"
      diamondTopY : number = 0
        @label "Diamond Top Y"
        @description "Override for the diamond-top Y offset within the tile sprite."
        @tier "presentation"
      effectSpriteUrls : [string] = []
        @label "Effect Sprite Urls"
        @description "Additional sprite URLs to preload (e.g., effect sprites)"
        @tier "presentation"
      playerSprite : Canvas2dPlayerSprite = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "player", category: "playerSprite", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "playerSprite", thumbnailUrl: "" }
        @label "Player Sprite"
        @description "--- Side-view sprite resolution (projection:'side') ---"
        @tier "presentation"
      tileSprites : Map string Canvas2dTileSpritesValue = {}
        @label "Tile Sprites"
        @description "Platform-type → tile sprite URL map for `side`."
        @tier "presentation"
      bgColor : string = "#5c94fc"
        @label "Bg Color"
        @description "Background color for `side` (when no backgroundImage)."
        @tier "presentation"
      worldWidth : number = 800
        @label "World Width"
        @description "World dimensions for `side` follow-camera clamp."
        @tier "presentation"
      worldHeight : number = 400
        @label "World Height"
        @description "worldHeight prop"
        @tier "presentation"
      assetManifest : Canvas2dAssetManifest = { terrains: { grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, dirt: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/floor.png", role: "tile", category: "dirt", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "dirt", thumbnailUrl: "" }, stone: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, forest: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/grass.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, castle: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png", role: "tile", category: "castle", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "castle", thumbnailUrl: "" } }, units: { worker: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/creep.png", role: "npc", category: "worker", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "worker", thumbnailUrl: "" }, guardian: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/hero.png", role: "npc", category: "guardian", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "guardian", thumbnailUrl: "" }, scrapper: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "scrapper", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "scrapper", thumbnailUrl: "" }, mender: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "mender", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "mender", thumbnailUrl: "" } }, features: { gold_mine: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/features/tower.png", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" }, portal: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/health_potion.png", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" }, castle: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/features/tower.png", role: "decoration", category: "castle", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "castle", thumbnailUrl: "" } }, effects: {} }
        @label "Asset Manifest"
        @description "--- Remote asset loading ---"
        @tier "presentation"
    }
  }

  page "/canvas-2d" as Canvas2dPage -> Canvas2dRender
}
