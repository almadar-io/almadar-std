app ui-object-rule-panel "1.0.0"
"ObjectRulePanel — UI factory (1:1 with the @almadar/ui object-rule-panel pattern)."
orbital ObjectRulePanelOrbital {
    type ObjectRulePanelLoaded = Event { data : [ObjectRulePanelItem] } "ObjectRulePanel rows finished loading; payload.data holds the collection"

  entity ObjectRulePanelItem [runtime] {
    id : string!
  }

  trait ObjectRulePanelRender -> @rebindable ObjectRulePanelItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ObjectRulePanelItem { emit: { success: ObjectRulePanelLoaded } })
        (render-ui main {
          object: @entity
          onRulesChange: RULES_CHANGE
          rulesChangeEvent: RULES_CHANGE
          disabled: @config.disabled
          className: @config.className
          type: object-rule-panel
        })
      ObjectRulePanelLoaded -> idle
        (render-ui main {
          object: @payload.data
          onRulesChange: RULES_CHANGE
          rulesChangeEvent: RULES_CHANGE
          disabled: @config.disabled
          className: @config.className
          type: object-rule-panel
        })
    }

    emits {
      RULES_CHANGE -> external {
        objectId : string
        rules : [object]
      }
        @description "Called when rules change (callback path)"
        @tier "essential"
      ObjectRulePanelLoaded
        @description "ObjectRulePanel rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      disabled : boolean = false
        @label "Disabled"
        @description "Whether editing is disabled"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/object-rule-panel" as ObjectRulePanelPage -> ObjectRulePanelRender
}
