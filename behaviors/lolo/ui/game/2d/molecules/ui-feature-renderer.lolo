app ui-feature-renderer "1.0.0"
"FeatureRenderer — feature overlay via canvas-2d (feature-renderer was deleted in Stream E)."
orbital FeatureRendererOrbital {
  type FeatureRendererFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : FeatureRendererFeaturesItemSprite
    assetUrl : FeatureRendererFeaturesItemAssetUrl
    color : string
    elevation : number
  }
  type FeatureRendererFeaturesItemSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFeaturesItemAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFEATURECLICKFeature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    color : string
    elevation : number
  }
  type FeatureRendererFEATUREHOVERFeature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    color : string
    elevation : number
  }

  entity FeatureRendererItem [runtime] {
    id : string!
  }

  trait FeatureRendererRender -> @rebindable FeatureRendererItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: canvas-2d
          projection: isometric
          features: @config.features
          scale: @config.cellSize
          tileClickEvent: FEATURE_CLICK
          tileHoverEvent: FEATURE_HOVER
        })
    }

    emits {
      FEATURE_CLICK -> external {
        x : number!
        y : number!
        feature : FeatureRendererFEATURECLICKFeature
      }
        @description "Called when feature is clicked"
        @tier "essential"
      FEATURE_HOVER -> external {
        x : number!
        y : number!
        feature : FeatureRendererFEATUREHOVERFeature
      }
        @description "Called when feature is hovered"
        @tier "essential"
    }

    config {
      features : [FeatureRendererFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/medieval/props/barrels.glb", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 1, type: "portal", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/gates/gate-door.glb", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Array of features to render"
        @tier "presentation"
      cellSize : number = 1
        @label "Cell Size"
        @description "Grid cell size (maps to canvas-2d scale)"
        @tier "presentation"
    }
  }

  page "/feature-renderer" as FeatureRendererPage -> FeatureRendererRender
}
