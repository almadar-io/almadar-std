app ui-feature-renderer "1.0.0"
"FeatureRenderer — UI factory (1:1 with the @almadar/ui feature-renderer pattern)."
orbital FeatureRendererOrbital {
  type FeatureRendererFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : FeatureRendererFeaturesItemSprite
    assetUrl : FeatureRendererFeaturesItemAssetUrl
    color : string
    elevation : number
  }
  type FeatureRendererFeaturesItemSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFeaturesItemAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFEATURECLICKFeature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : FeatureRendererFEATURECLICKFeatureSprite
    assetUrl : FeatureRendererFEATURECLICKFeatureAssetUrl
    color : string
    elevation : number
  }
  type FeatureRendererFEATURECLICKFeatureSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFEATURECLICKFeatureAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFEATUREHOVERFeature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : FeatureRendererFEATUREHOVERFeatureSprite
    assetUrl : FeatureRendererFEATUREHOVERFeatureAssetUrl
    color : string
    elevation : number
  }
  type FeatureRendererFEATUREHOVERFeatureSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type FeatureRendererFEATUREHOVERFeatureAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity FeatureRendererItem [runtime] {
    id : string!
  }

  trait FeatureRendererRender -> @rebindable FeatureRendererItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          features: @config.features
          cellSize: @config.cellSize
          offsetX: @config.offsetX
          offsetZ: @config.offsetZ
          onFeatureClick: FEATURE_CLICK
          onFeatureHover: FEATURE_HOVER
          selectedFeatureIds: @config.selectedFeatureIds
          featureColors: @config.featureColors
          type: feature-renderer
        })
    }

    emits {
      FEATURE_CLICK -> external {
        feature : FeatureRendererFEATURECLICKFeature
      }
        @description "Called when feature is clicked"
        @tier "essential"
      FEATURE_HOVER -> external {
        feature : FeatureRendererFEATUREHOVERFeature
      }
        @description "Called when feature is hovered"
        @tier "essential"
    }

    config {
      features : [FeatureRendererFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/medieval/props/barrels.glb", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 1, type: "portal", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/gates/gate-door.glb", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Array of features to render"
        @tier "presentation"
      cellSize : number = 1
        @label "Cell Size"
        @description "Grid cell size"
        @tier "presentation"
      offsetX : number = 0
        @label "Offset X"
        @description "Grid offset X"
        @tier "presentation"
      offsetZ : number = 0
        @label "Offset Z"
        @description "Grid offset Z"
        @tier "presentation"
      selectedFeatureIds : [string] = []
        @label "Selected Feature Ids"
        @description "Selected feature IDs"
        @tier "presentation"
      featureColors : Map string string = {}
        @label "Feature Colors"
        @description "Feature color overrides"
        @tier "presentation"
    }
  }

  page "/feature-renderer" as FeatureRendererPage -> FeatureRendererRender
}
