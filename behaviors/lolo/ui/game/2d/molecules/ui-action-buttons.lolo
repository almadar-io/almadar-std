app ui-action-buttons "1.0.0"
"ActionButtons — configurable button set via control-grid (kind=actions)."
orbital ActionButtonsOrbital {
  type ActionButtonsButtonsItem = {
    id : string!
    label : string
    icon : icon
    variant : "primary" | "secondary" | "ghost"
  }

  entity ActionButtonsItem [runtime] {
    id : string!
  }

  trait ActionButtonsRender -> @rebindable ActionButtonsItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          kind: actions
          buttons: @config.buttons
          onAction: ACTION
          actionEvent: ACTION
          layout: @config.layout
          size: @config.size
          className: @config.className
          disabled: @config.disabled
          type: control-grid
        })
    }

    emits {
      ACTION -> external {
        id : string
        pressed : boolean
      }
        @description "Called when a button is pressed/released"
        @tier "essential"
    }

    config {
      buttons : [ActionButtonsButtonsItem] = [{ id: "Id", label: "Label", icon: "circle", variant: primary }, { id: "Id 2", label: "Label 2", icon: "circle", variant: secondary }]
        @label "Buttons"
        @description "Button configurations"
        @tier "presentation"
      layout : "horizontal" | "vertical" | "diamond" = horizontal
        @label "Layout"
        @description "Layout variant"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "Disabled state"
        @tier "presentation"
    }
  }

  page "/action-buttons" as ActionButtonsPage -> ActionButtonsRender
}
