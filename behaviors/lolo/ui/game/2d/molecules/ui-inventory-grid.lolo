app ui-inventory-grid "1.0.0"
"InventoryGrid — UI factory (1:1 with the @almadar/ui inventory-grid pattern)."
orbital InventoryGridOrbital {
  type InventoryGridItemsItem = {
    id : string!
    icon : icon
    assetUrl : InventoryGridItemsItemAssetUrl
    label : string
    quantity : number
    rarity : "common" | "uncommon" | "rare" | "epic" | "legendary"
  }
  type InventoryGridItemsItemAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity InventoryGridItem [runtime] {
    id : string!
  }

  trait InventoryGridRender -> @rebindable InventoryGridItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          columns: @config.columns
          totalSlots: @config.totalSlots
          selectedId: @config.selectedId
          onSelect: SELECT
          selectEvent: SELECT
          size: @config.size
          className: @config.className
          type: inventory-grid
        })
    }

    emits {
      SELECT -> external {
        id : string
      }
        @description "Callback when an item is selected"
        @tier "domain"
    }

    config {
      items : [InventoryGridItemsItem] = [{ id: "Id", icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png", role: "decoration", category: "asset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "asset", thumbnailUrl: "" }, label: "Label", quantity: 1, rarity: common }, { id: "Id 2", icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png", role: "decoration", category: "asset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "asset", thumbnailUrl: "" }, label: "Label 2", quantity: 2, rarity: uncommon }]
        @label "Items"
        @description "Array of items to display in the grid"
        @tier "presentation"
      columns : number = 4
        @label "Columns"
        @description "Number of columns in the grid"
        @tier "presentation"
      totalSlots : number = 12
        @label "Total Slots"
        @description "Total number of slots (empty slots fill remaining space)"
        @tier "presentation"
      selectedId : string = "Selected Id"
        @label "Selected Id"
        @description "Currently selected item ID"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant for all item slots"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/inventory-grid" as InventoryGridPage -> InventoryGridRender
}
