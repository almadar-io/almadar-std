app ui-resource-bar "1.0.0"
"ResourceBar — UI factory (1:1 with the @almadar/ui resource-bar pattern)."
orbital ResourceBarOrbital {
  type ResourceBarResourcesItem = {
    icon : icon
    assetUrl : ResourceBarResourcesItemAssetUrl
    label : string!
    value : number
    max : number
  }
  type ResourceBarResourcesItemAssetUrl = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity ResourceBarItem [runtime] {
    id : string!
  }

  trait ResourceBarRender -> @rebindable ResourceBarItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          resources: @config.resources
          size: @config.size
          className: @config.className
          type: resource-bar
        })
    }

    config {
      resources : [ResourceBarResourcesItem] = [{ icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }, label: "Label", value: 1, max: 1 }, { icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }, label: "Label 2", value: 2, max: 2 }]
        @label "Resources"
        @description "Resources to display"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/resource-bar" as ResourceBarPage -> ResourceBarRender
}
