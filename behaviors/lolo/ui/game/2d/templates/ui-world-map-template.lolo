app ui-world-map-template "1.0.0"
"WorldMapTemplate — thin playable shell; renders game-shell + isometric canvas-2d matching ui-world-map-board."
orbital WorldMapTemplateOrbital {
  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type WorldMapTemplateAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
  }
  type WorldMapTemplateTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type WorldMapTemplateUnitsItemPosition = {
    x : number!
    y : number!
  }
  type WorldMapTemplateUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type WorldMapTemplateUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type WorldMapTemplateUnitsItem = {
    id : string!
    position : WorldMapTemplateUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    spriteSheet : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [WorldMapTemplateUnitsItemTraitsItem]
    previousPosition : WorldMapTemplateUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type WorldMapTemplateFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type WorldMapTemplateEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type WorldMapTemplateValidMoveItem = {
    x : number!
    y : number!
  }

  entity WorldMapTemplateItem [runtime] {
    id : string!
    tiles : [WorldMapTemplateTilesItem]
    units : [WorldMapTemplateUnitsItem]
    features : [WorldMapTemplateFeaturesItem]
    effects : [WorldMapTemplateEffectItem] = []
    turn : number = 0
    selectedHeroId : string = ""
    validMoves : [WorldMapTemplateValidMoveItem] = []
    waypoints : [string] = []
    gridWidth : number = 5
    gridHeight : number = 5
    result : "none" | "won" | "lost" = none
  }

  trait WorldMapTemplateRender -> @rebindable WorldMapTemplateItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.tiles @config.tiles)
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.effects [])
        (set @entity.turn 0)
        (set @entity.selectedHeroId "")
        (set @entity.validMoves [])
        (set @entity.waypoints [])
        (set @entity.gridWidth 5)
        (set @entity.gridHeight 5)
        (set @entity.result none)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }, { type: mini-map, tiles: @entity.tiles, units: @entity.units, width: @entity.gridWidth, height: @entity.gridHeight }, { type: waypoint-marker, waypoints: @entity.waypoints, path: @entity.validMoves }, { type: button, action: ADVANCE_TURN, label: "Pass Turn", icon: arrow-right, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: HERO_MOVE, unitClickEvent: HERO_SELECT, selectedUnitId: @entity.selectedHeroId, validMoves: @entity.validMoves } ]
        })
      HERO_SELECT -> playing
        (set @entity.selectedHeroId ?unitId)
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }, { type: mini-map, tiles: @entity.tiles, units: @entity.units, width: @entity.gridWidth, height: @entity.gridHeight }, { type: waypoint-marker, waypoints: @entity.waypoints, path: @entity.validMoves }, { type: button, action: ADVANCE_TURN, label: "Pass Turn", icon: arrow-right, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: HERO_MOVE, unitClickEvent: HERO_SELECT, selectedUnitId: @entity.selectedHeroId, validMoves: @entity.validMoves } ]
        })
      HERO_MOVE -> playing
        (set @entity.selectedHeroId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }, { type: mini-map, tiles: @entity.tiles, units: @entity.units, width: @entity.gridWidth, height: @entity.gridHeight }, { type: waypoint-marker, waypoints: @entity.waypoints, path: @entity.validMoves }, { type: button, action: ADVANCE_TURN, label: "Pass Turn", icon: arrow-right, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: HERO_MOVE, unitClickEvent: HERO_SELECT, selectedUnitId: @entity.selectedHeroId, validMoves: @entity.validMoves } ]
        })
      ADVANCE_TURN -> playing
        (set @entity.turn (+ @entity.turn 1))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }, { type: mini-map, tiles: @entity.tiles, units: @entity.units, width: @entity.gridWidth, height: @entity.gridHeight }, { type: waypoint-marker, waypoints: @entity.waypoints, path: @entity.validMoves }, { type: button, action: ADVANCE_TURN, label: "Pass Turn", icon: arrow-right, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: HERO_MOVE, unitClickEvent: HERO_SELECT, selectedUnitId: @entity.selectedHeroId, validMoves: @entity.validMoves } ]
        })
      PLAY_AGAIN -> playing
        (set @entity.tiles @config.tiles)
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.effects [])
        (set @entity.turn 0)
        (set @entity.selectedHeroId "")
        (set @entity.validMoves [])
        (set @entity.waypoints [])
        (set @entity.result none)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }, { type: mini-map, tiles: @entity.tiles, units: @entity.units, width: @entity.gridWidth, height: @entity.gridHeight }, { type: waypoint-marker, waypoints: @entity.waypoints, path: @entity.validMoves }, { type: button, action: ADVANCE_TURN, label: "Pass Turn", icon: arrow-right, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: HERO_MOVE, unitClickEvent: HERO_SELECT, selectedUnitId: @entity.selectedHeroId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      HERO_MOVE -> external { x, y }
      HERO_SELECT -> external { unitId }
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      scale : number = 0.4
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 2.5
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      diamondTopY : number = 374
        @label "Diamond Top Y"
        @description "Override for the diamond-top Y offset within tile sprites (default: 374)."
        @tier "presentation"
      allowMoveAllHeroes : boolean = false
        @label "Allow Move All Heroes"
        @description "Allow selecting / moving ALL heroes (including enemy). For testing."
        @tier "presentation"
      tiles : [WorldMapTemplateTilesItem] = [{ x: 0, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 1, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 2, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 3, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 4, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 0, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 1, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 2, y: 1, terrain: "forest", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png" }, { x: 3, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 4, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 0, y: 2, terrain: "stone", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png" }, { x: 1, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 2, y: 2, terrain: "stone", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png" }, { x: 3, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 4, y: 2, terrain: "stone", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png" }, { x: 0, y: 3, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 1, y: 3, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 2, y: 3, terrain: "forest", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png" }, { x: 3, y: 3, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 4, y: 3, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 0, y: 4, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 1, y: 4, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 2, y: 4, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 3, y: 4, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }, { x: 4, y: 4, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png" }]
        @label "Tiles"
        @description "Direct tile data — forwarded to WorldMapBoard; takes priority over entity."
        @tier "presentation"
      units : [WorldMapTemplateUnitsItem] = [{ id: "u1", position: { x: 1, y: 1 }, unitType: "hero", name: "Hero", team: player, health: 10, maxHealth: 10, spriteSheet: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/units/hero.png", role: "unit", category: "hero", animations: ["idle","walk"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "hero", thumbnailUrl: "" } }, { id: "u2", position: { x: 3, y: 3 }, unitType: "guard", name: "Guard", team: enemy, health: 8, maxHealth: 10, spriteSheet: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/units/guard.png", role: "unit", category: "guard", animations: ["idle","walk"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "guard", thumbnailUrl: "" } }]
        @label "Units"
        @description "Direct unit data — forwarded to WorldMapBoard; takes priority over entity."
        @tier "presentation"
      features : [WorldMapTemplateFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/features/gold_mine.png", role: "feature", category: "gold_mine", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 1, type: "portal", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/features/portal.png", role: "feature", category: "portal", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Direct feature data — forwarded to WorldMapBoard; takes priority over entity."
        @tier "presentation"
      assetManifest : WorldMapTemplateAssetManifest = { terrains: { grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png", role: "terrain", category: "grass", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, forest: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "terrain", category: "forest", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, stone: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "terrain", category: "stone", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, units: { hero: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/units/hero.png", role: "unit", category: "hero", animations: ["idle","walk"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "hero", thumbnailUrl: "" }, guard: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/units/guard.png", role: "unit", category: "guard", animations: ["idle","walk"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "guard", thumbnailUrl: "" } }, features: { gold_mine: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/features/gold_mine.png", role: "feature", category: "gold_mine", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" }, portal: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/features/portal.png", role: "feature", category: "portal", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Terrain/unit/feature sprite maps."
        @tier "presentation"
    }
  }

  page "/world-map-template" as WorldMapTemplatePage -> WorldMapTemplateRender
}
