app ui-battle-template "1.0.0"
"BattleTemplate — thin playable shell; renders game-shell + isometric canvas-2d matching ui-battle-board."
orbital BattleTemplateOrbital {
  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type BattleTemplateTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type BattleTemplateUnitsItemPosition = {
    x : number!
    y : number!
  }
  type BattleTemplateUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type BattleTemplateUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type BattleTemplateUnitsItem = {
    id : string!
    position : BattleTemplateUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    spriteSheet : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [BattleTemplateUnitsItemTraitsItem]
    previousPosition : BattleTemplateUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type BattleTemplateFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type BattleTemplateEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }

  entity BattleTemplateItem [runtime] {
    id : string!
    units : [BattleTemplateUnitsItem]
    selectedUnitId : string = ""
    validMoves : [BattleTemplateUnitsItemPosition] = []
    turn : number = 0
    result : "none" | "victory" | "defeat" = none
    effects : [BattleTemplateEffectItem] = []
    xp : number = 0
    xpToNext : number = 100
    inventory : [string] = []
    selectedUnitEffects : [string] = []
  }

  trait BattleTemplateRender -> @rebindable BattleTemplateItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.turn 0)
        (set @entity.result none)
        (set @entity.effects [])
        (set @entity.xp 0)
        (set @entity.xpToNext 100)
        (set @entity.inventory [])
        (set @entity.selectedUnitEffects [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Result", value: @entity.result } ] }, { type: sprite, src: (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) sprite), label: "Selected Unit" }, { type: xp-bar, current: @entity.xp, max: @entity.xpToNext, label: "XP" }, { type: inventory-grid, items: @entity.inventory }, { type: button, action: END_TURN, label: "End Turn", icon: flag, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, damageNumbers: @entity.effects, statusEffects: @entity.selectedUnitEffects } ]
        })
      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])
        (set @entity.selectedUnitEffects [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Result", value: @entity.result } ] }, { type: sprite, src: (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) sprite), label: "Selected Unit" }, { type: xp-bar, current: @entity.xp, max: @entity.xpToNext, label: "XP" }, { type: inventory-grid, items: @entity.inventory }, { type: button, action: END_TURN, label: "End Turn", icon: flag, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, damageNumbers: @entity.effects, statusEffects: @entity.selectedUnitEffects } ]
        })
      TILE_CLICK -> playing
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Result", value: @entity.result } ] }, { type: sprite, src: (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) sprite), label: "Selected Unit" }, { type: xp-bar, current: @entity.xp, max: @entity.xpToNext, label: "XP" }, { type: inventory-grid, items: @entity.inventory }, { type: button, action: END_TURN, label: "End Turn", icon: flag, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, damageNumbers: @entity.effects, statusEffects: @entity.selectedUnitEffects } ]
        })
      END_TURN -> playing
        (set @entity.turn (+ @entity.turn 1))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Result", value: @entity.result } ] }, { type: sprite, src: (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) sprite), label: "Selected Unit" }, { type: xp-bar, current: @entity.xp, max: @entity.xpToNext, label: "XP" }, { type: inventory-grid, items: @entity.inventory }, { type: button, action: END_TURN, label: "End Turn", icon: flag, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, damageNumbers: @entity.effects, statusEffects: @entity.selectedUnitEffects } ]
        })
      PLAY_AGAIN -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.turn 0)
        (set @entity.result none)
        (set @entity.effects [])
        (set @entity.xp 0)
        (set @entity.xpToNext 100)
        (set @entity.inventory [])
        (set @entity.selectedUnitEffects [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Result", value: @entity.result } ] }, { type: sprite, src: (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) sprite), label: "Selected Unit" }, { type: xp-bar, current: @entity.xp, max: @entity.xpToNext, label: "XP" }, { type: inventory-grid, items: @entity.inventory }, { type: button, action: END_TURN, label: "End Turn", icon: flag, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves, damageNumbers: @entity.effects, statusEffects: @entity.selectedUnitEffects } ]
        })
    }

    emits {
      TILE_CLICK -> external { x : number, y : number }
      UNIT_CLICK -> external { unitId : string }
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      tiles : [BattleTemplateTilesItem] = [{ x: 0, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 1, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 2, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 3, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 4, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 0, y: 1, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 1, y: 1, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/dirt.png" }, { x: 2, y: 1, terrain: "planks", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/planks.png" }, { x: 3, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/grass.png" }, { x: 4, y: 1, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 0, y: 2, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 1, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/grass.png" }, { x: 2, y: 2, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/dirt.png" }, { x: 3, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/grass.png" }, { x: 4, y: 2, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 0, y: 3, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 1, y: 3, terrain: "planks", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/planks.png" }, { x: 2, y: 3, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/dirt.png" }, { x: 3, y: 3, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/grass.png" }, { x: 4, y: 3, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 0, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 1, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 2, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 3, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }, { x: 4, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png" }]
        @label "Tiles"
        @description "Direct tile data — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
      units : [BattleTemplateUnitsItem] = [{ id: "u1", position: { x: 1, y: 1 }, unitType: "scrapper", name: "Scrapper", team: player, health: 10, maxHealth: 10, spriteSheet: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/scrapper.png", role: "unit", category: "scrapper", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "scrapper", thumbnailUrl: "" } }, { id: "u2", position: { x: 3, y: 3 }, unitType: "guardian", name: "Guardian", team: enemy, health: 8, maxHealth: 10, spriteSheet: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/guardian.png", role: "unit", category: "guardian", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "guardian", thumbnailUrl: "" } }]
        @label "Units"
        @description "Direct unit data — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
      features : [BattleTemplateFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/features/gold_mine.png", role: "feature", category: "gold_mine", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 1, type: "portal", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/features/portal.png", role: "feature", category: "portal", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Direct feature data — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
      assetManifest : string = ""
        @label "Asset Manifest"
        @description "Direct asset manifest — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
    }
  }

  page "/battle-template" as BattleTemplatePage -> BattleTemplateRender
}
