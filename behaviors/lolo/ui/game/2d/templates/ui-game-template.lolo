app ui-game-template "1.0.0"
"GameTemplate — UI factory (1:1 with the @almadar/ui game-template pattern)."
orbital GameTemplateOrbital {
    type GameTemplateLoaded = Event { data : [GameTemplateItem] } "GameTemplate rows finished loading; payload.data holds the collection"
  type GameTemplateControls = {
    isPlaying : boolean
  }
  type GameTemplateBackgroundAsset = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity GameTemplateItem [runtime] {
    id : string!
  }

  trait GameTemplateRender -> @rebindable GameTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch GameTemplateItem { emit: { success: GameTemplateLoaded } })
        (render-ui main {
          entity: @entity
          className: @config.className
          title: @config.title
          children: [{ type: canvas-2d }]
          hud: [{ content: "Hud", type: typography }]
          debugPanel: @config.debugPanel
          showDebugPanel: @config.showDebugPanel
          controls: @config.controls
          backgroundAsset: @config.backgroundAsset
          type: game-template
        })
      GameTemplateLoaded -> idle
        (render-ui main {
          entity: @payload.data
          className: @config.className
          title: @config.title
          children: [{ type: canvas-2d }]
          hud: [{ content: "Hud", type: typography }]
          debugPanel: @config.debugPanel
          showDebugPanel: @config.showDebugPanel
          controls: @config.controls
          backgroundAsset: @config.backgroundAsset
          type: game-template
        })
    }

    emits {
      GameTemplateLoaded
        @description "GameTemplate rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional class name"
        @tier "presentation"
      title : string = Game
        @label "Title"
        @description "Title of the game"
        @tier "presentation"
      debugPanel : node
        @label "Debug Panel"
        @description "Debug panel content"
        @tier "presentation"
      showDebugPanel : boolean = false
        @label "Show Debug Panel"
        @description "Whether the debug panel is visible"
        @tier "presentation"
      controls : GameTemplateControls = { isPlaying: false }
        @label "Controls"
        @description "Game controls"
        @tier "presentation"
      backgroundAsset : GameTemplateBackgroundAsset = { url: "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png", role: "decoration", category: "backgroundAsset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "backgroundAsset", thumbnailUrl: "" }
        @label "Background Asset"
        @description "Background image for the canvas area. Falls back to bg-muted flat color."
        @tier "presentation"
    }
  }

  page "/game-template" as GameTemplatePage -> GameTemplateRender
}
