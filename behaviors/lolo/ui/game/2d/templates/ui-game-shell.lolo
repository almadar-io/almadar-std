app ui-game-shell "1.0.0"
"GameShell — UI factory (1:1 with the @almadar/ui game-shell pattern)."
orbital GameShellOrbital {
  type GameShellBackgroundAsset = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameShellHudBackgroundAsset = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity GameShellItem [runtime] {
    id : string!
  }

  trait GameShellRender -> @rebindable GameShellItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          appName: @config.appName
          hud: [{ content: "Hud", type: typography }]
          addons: [{ content: "Addons", type: typography }]
          controls: [{ content: "Controls", type: typography }]
          overlay: [{ content: "Overlay", type: typography }]
          className: @config.className
          showTopBar: @config.showTopBar
          children: [{ type: canvas-2d }]
          backgroundAsset: @config.backgroundAsset
          hudBackgroundAsset: @config.hudBackgroundAsset
          fontFamily: @config.fontFamily
          type: game-shell
        })
    }

    config {
      appName : string = Game
        @label "App Name"
        @description "Application / game title shown as a floating chip"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Extra class name on the root container"
        @tier "presentation"
      showTopBar : boolean = true
        @label "Show Top Bar"
        @description "Whether to show the title chip (default: true)"
        @tier "presentation"
      backgroundAsset : GameShellBackgroundAsset = { url: "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png", role: "decoration", category: "backgroundAsset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "backgroundAsset", thumbnailUrl: "" }
        @label "Background Asset"
        @description "Pattern slice tiled at low opacity across the surface (never cover-stretched)."
        @tier "presentation"
      hudBackgroundAsset : GameShellHudBackgroundAsset = { url: "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png", role: "decoration", category: "hudBackgroundAsset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "hudBackgroundAsset", thumbnailUrl: "" }
        @label "Hud Background Asset"
        @description "9-sliced panel skin for the HUD chips row + title chip."
        @tier "presentation"
      fontFamily : string = future
        @label "Font Family"
        @description "Game font key (future | future-narrow | pixel | blocks | mini) or a CSS font-family."
        @tier "presentation"
    }
  }

  page "/game-shell" as GameShellPage -> GameShellRender
}
