app ui-city-builder-template "1.0.0"
"CityBuilderTemplate — thin playable shell; renders game-shell + isometric canvas-2d matching ui-city-builder-board."
orbital CityBuilderTemplateOrbital {
  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type CityBuilderTemplateAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
  }
  type CityBuilderTemplateTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : asset
    passable : boolean
  }
  type CityBuilderTemplateBuildingsItem = {
    id : string!
    x : number!
    y : number!
    type : string!
  }
  type CityBuilderTemplateBuildTypesItem = {
    type : string!
    label : string!
    cost : number!
  }
  type CityBuilderTemplateCitizenItem = {
    id : string!
    x : number!
    y : number!
    type : string
  }
  type CityBuilderTemplateFeaturesItem = {
    id : string!
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type CityBuilderTemplateEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type CityBuilderTemplateValidMoveItem = {
    x : number!
    y : number!
  }

  entity CityBuilderTemplateItem [runtime] {
    id : string!
    citizens : [CityBuilderTemplateCitizenItem] = []
    features : [CityBuilderTemplateFeaturesItem]
    effects : [CityBuilderTemplateEffectItem] = []
    population : number = 0
    gold : number = 100
    wood : number = 80
    pendingBuildType : string = "house"
    selectedUnitId : string = ""
    validMoves : [CityBuilderTemplateValidMoveItem] = []
    result : "none" | "won" | "lost" = none
  }

  trait CityBuilderTemplateRender -> @rebindable CityBuilderTemplateItem [interaction, instance] {
    initial: building

    state building {
      INIT -> building
        (set @entity.features (array/map @config.buildings (fn b { id: @b.id, x: @b.x, y: @b.y, type: @b.type, sprite: (object/get @config.featureSprites @b.type) })))
        (set @entity.gold @config.gold)
        (set @entity.wood @config.wood)
        (set @entity.pendingBuildType @config.pendingBuildType)
        (set @entity.citizens [])
        (set @entity.effects [])
        (set @entity.population 0)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.result none)
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-population.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-population", thumbnailUrl: "" } }, { label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { type: stat-badge, label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      SELECT_BUILD_TYPE -> building
        (set @entity.pendingBuildType ?type)
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-population.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-population", thumbnailUrl: "" } }, { label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { type: stat-badge, label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      PLACE_BUILDING -> building
        (set @entity.features (array/concat @entity.features [{ id: (str/concat "bld-" (array/len @entity.features)), x: ?x, y: ?y, type: @entity.pendingBuildType, sprite: (object/get @config.featureSprites @entity.pendingBuildType) }]))
        (set @entity.population (+ @entity.population @config.populationPerBuilding))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-population.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-population", thumbnailUrl: "" } }, { label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { type: stat-badge, label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      PLAY_AGAIN -> building
        (set @entity.features (array/map @config.buildings (fn b { id: @b.id, x: @b.x, y: @b.y, type: @b.type, sprite: (object/get @config.featureSprites @b.type) })))
        (set @entity.gold @config.gold)
        (set @entity.wood @config.wood)
        (set @entity.pendingBuildType @config.pendingBuildType)
        (set @entity.citizens [])
        (set @entity.effects [])
        (set @entity.population 0)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.result none)
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-population.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-population", thumbnailUrl: "" } }, { label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { type: stat-badge, label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      GAME_END -> building
        (set @entity.result won)
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/panel-frame.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Population", value: @entity.population, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-population.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-population", thumbnailUrl: "" } }, { label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: resource-counter, label: "Build", value: @entity.pendingBuildType } ] }, { type: stat-badge, label: "Gold", value: @entity.gold, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-gold.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-gold", thumbnailUrl: "" } }, { type: stat-badge, label: "Wood", value: @entity.wood, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/ui/icon-wood.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wood", thumbnailUrl: "" } }, { type: control-grid, items: @config.buildTypes, action: SELECT_BUILD_TYPE, labelKey: "label", valueKey: "type", selected: @entity.pendingBuildType } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.citizens, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_BUILDING, unitClickEvent: SELECT_BUILD_TYPE, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      PLACE_BUILDING -> external { x : number, y : number }
      SELECT_BUILD_TYPE -> external { type : string }
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      title : string = "City Builder"
        @label "Title"
        @description "Display title shown in the template header"
        @tier "presentation"
      gold : number = 100
        @label "Starting Gold"
        @description "Gold the player starts with"
        @tier "presentation"
      wood : number = 80
        @label "Starting Wood"
        @description "Wood the player starts with"
        @tier "presentation"
      targetPopulation : number = 12
        @label "Target Population"
        @description "Population to reach for victory"
        @tier "presentation"
      populationPerBuilding : number = 2
        @label "Population Per Building"
        @description "Population added per placed building"
        @tier "presentation"
      goldPerBuilding : number = 2
        @label "Gold Per Building"
        @description "Gold income per building per tick"
        @tier "presentation"
      woodPerBuilding : number = 1
        @label "Wood Per Building"
        @description "Wood income per building per tick"
        @tier "presentation"
      pendingBuildType : string = "house"
        @label "Pending Build Type"
        @description "Initially selected building type from the palette"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 0.6
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      gridWidth : number = 5
        @label "Grid Width"
        @description "Number of columns in the tile grid"
        @tier "presentation"
      gridHeight : number = 5
        @label "Grid Height"
        @description "Number of rows in the tile grid"
        @tier "presentation"
      buildTypes : [CityBuilderTemplateBuildTypesItem] = [{ type: "house", label: "House", cost: 20 }, { type: "farm", label: "Farm", cost: 15 }, { type: "barracks", label: "Barracks", cost: 40 }, { type: "library", label: "Library", cost: 30 }]
        @label "Build Types"
        @description "Placeable building types forwarded to CityBuilderBoard."
        @tier "presentation"
      buildings : [CityBuilderTemplateBuildingsItem] = [{ id: "bld-0", x: 1, y: 1, type: "house" }, { id: "bld-1", x: 3, y: 3, type: "farm" }]
        @label "Buildings"
        @description "Pre-placed buildings forwarded to CityBuilderBoard."
        @tier "presentation"
      tiles : [CityBuilderTemplateTilesItem] = [{ x: 0, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 1, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 2, y: 0, terrain: "stone", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/stone.png" }, { x: 3, y: 0, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 4, y: 0, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/dirt.png" }, { x: 0, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 1, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 2, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 3, y: 1, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/dirt.png" }, { x: 4, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 0, y: 2, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/dirt.png" }, { x: 1, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-city-builder-board/default/terrain/grass.png" }, { x: 2, y: 2, terrain: "water", passab