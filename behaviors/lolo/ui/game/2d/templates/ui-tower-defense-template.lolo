app ui-tower-defense-template "1.0.0"
"TowerDefenseTemplate — thin playable shell; renders game-shell + isometric canvas-2d matching ui-tower-defense-board."
orbital TowerDefenseTemplateOrbital {
  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type TowerDefenseTemplateAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
  }
  type TowerDefenseTemplateTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : asset
    passable : boolean
  }
  type TowerDefenseTemplatePathItem = {
    x : number!
    y : number!
  }
  type TowerDefenseTemplateTowersItem = {
    id : string!
    x : number!
    y : number!
    range : number!
    damage : number!
    cooldown : number!
    lastFiredAt : number
  }
  type TowerDefenseTemplateCreepItem = {
    id : string!
    x : number!
    y : number!
    hp : number!
    maxHp : number!
    pathIndex : number!
    speed : number
    animation : string
    frame : number
  }
  type TowerDefenseTemplateFeaturesItem = {
    id : string!
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type TowerDefenseTemplateEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }

  entity TowerDefenseTemplateItem [runtime] {
    id : string!
    gold : number = 100
    lives : number = 20
    wave : number = 0
    waveActive : boolean = false
    towers : [TowerDefenseTemplateTowersItem]
    creeps : [TowerDefenseTemplateCreepItem] = []
    features : [TowerDefenseTemplateFeaturesItem] = []
    effects : [TowerDefenseTemplateEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [TowerDefenseTemplatePathItem] = []
    waypointLabels : [string] = []
    result : "none" | "won" | "lost" = none
  }

  trait TowerDefenseTemplateRender -> @rebindable TowerDefenseTemplateItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.gold @config.gold)
        (set @entity.lives @config.lives)
        (set @entity.wave 1)
        (set @entity.towers @config.towers)
        (set @entity.creeps [])
        (set @entity.features [])
        (set @entity.waypointLabels [])
        (set @entity.waveActive false)
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.result none)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave } ] }, { type: waypoint-marker, waypoints: @entity.waypointLabels, path: @config.path }, { type: feature-renderer, features: @entity.towers, manifest: @config.assetManifest }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      PLACE_TOWER -> playing when (>= @entity.gold @config.towerCost)
        (set @entity.gold (- @entity.gold @config.towerCost))
        (set @entity.towers (array/concat @entity.towers [{ id: (str/concat "tower-" (array/len @entity.towers)), x: ?x, y: ?y, range: @config.towerRange, damage: @config.towerDamage, cooldown: 1, lastFiredAt: 0 }]))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave } ] }, { type: waypoint-marker, waypoints: @entity.waypointLabels, path: @config.path }, { type: feature-renderer, features: @entity.towers, manifest: @config.assetManifest }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      START_WAVE -> playing
        (set @entity.wave (+ @entity.wave 1))
        (set @entity.waveActive true)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave } ] }, { type: waypoint-marker, waypoints: @entity.waypointLabels, path: @config.path }, { type: feature-renderer, features: @entity.towers, manifest: @config.assetManifest }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave } ] }, { type: waypoint-marker, waypoints: @entity.waypointLabels, path: @config.path }, { type: feature-renderer, features: @entity.towers, manifest: @config.assetManifest }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
      PLAY_AGAIN -> playing
        (set @entity.gold @config.gold)
        (set @entity.lives @config.lives)
        (set @entity.wave 1)
        (set @entity.towers @config.towers)
        (set @entity.creeps [])
        (set @entity.features [])
        (set @entity.waypointLabels [])
        (set @entity.waveActive false)
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.result none)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave } ] }, { type: waypoint-marker, waypoints: @entity.waypointLabels, path: @config.path }, { type: feature-renderer, features: @entity.towers, manifest: @config.assetManifest }, { type: button, action: START_WAVE, label: "Start Wave", icon: play, variant: secondary } ] }
          children: [ { type: canvas-2d, tiles: @config.tiles, units: @entity.creeps, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale, tileClickEvent: PLACE_TOWER, unitClickEvent: UNIT_CLICK, selectedUnitId: @entity.selectedUnitId, validMoves: @entity.validMoves } ]
        })
    }

    emits {
      PLACE_TOWER -> external { x, y }
      UNIT_CLICK -> external { unitId }
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      title : string = "Tower Defense"
        @label "Title"
        @description "Display title shown in the template header"
        @tier "presentation"
      gold : number = 100
        @label "Starting Gold"
        @description "Gold the player starts with"
        @tier "presentation"
      lives : number = 20
        @label "Starting Lives"
        @description "Lives the player starts with"
        @tier "presentation"
      maxWaves : number = 5
        @label "Max Waves"
        @description "Total waves to survive for victory"
        @tier "presentation"
      towerCost : number = 25
        @label "Tower Cost"
        @description "Gold cost to place one tower"
        @tier "presentation"
      towerRange : number = 2
        @label "Tower Range"
        @description "Attack range in grid units"
        @tier "presentation"
      towerDamage : number = 3
        @label "Tower Damage"
        @description "Damage per hit per tower"
        @tier "presentation"
      creepsPerWave : number = 5
        @label "Creeps Per Wave"
        @description "Number of creeps spawned per wave"
        @tier "presentation"
      creepBaseHp : number = 10
        @label "Creep Base HP"
        @description "Base HP of the first creep in a wave"
        @tier "presentation"
      goldPerKill : number = 10
        @label "Gold Per Kill"
        @description "Gold awarded for each creep killed"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 0.6
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      gridWidth : number = 5
        @label "Grid Width"
        @description "Number of columns in the tile grid"
        @tier "presentation"
      gridHeight : number = 5
        @label "Grid Height"
        @description "Number of rows in the tile grid"
        @tier "presentation"
      tiles : [TowerDefenseTemplateTilesItem] = [{ x: 0, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 1, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 2, y: 0, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }, { x: 3, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 4, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 0, y: 1, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 1, y: 1, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 2, y: 1, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }, { x: 3, y: 1, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 4, y: 1, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 0, y: 2, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 1, y: 2, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 2, y: 2, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }, { x: 3, y: 2, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }, { x: 4, y: 2, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }, { x: 0, y: 3, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 1, y: 3, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 2, y: 3, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 3, y: 3, terrain: "ground", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png" }, { x: 4, y: 3, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }, { x: 0, y: 4, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 1, y: 4, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 2, y: 4, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 3, y: 4, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png" }, { x: 4, y: 4, terrain: "path", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png" }]
        @label "Tiles"
        @description "Tile grid forwarded to TowerDefenseBoard; path cells marked passable:false."
        @tier "presentation"
      path : [TowerDefenseTemplatePathItem] = [{ x: 2, y: 0 }, { x: 2, y: 1 }, { x: 2, y: 2 }, { x: 3, y: 2 }, { x: 4, y: 2 }, { x: 4, y: 3 }, { x: 4, y: 4 }]
        @label "Path"
        @description "Ordered waypoint coords forwarded to TowerDefenseBoard."
        @tier "presentation"
      towers : [TowerDefenseTemplateTowersItem] = [{ id: "t0", x: 1, y: 1, range: 2, damage: 3, cooldown: 1, lastFiredAt: 0 }, { id: "t1", x: 3, y: 3, range: 2, damage: 3, cooldown: 1, lastFiredAt: 0 }]
        @label "Towers"
        @description "Pre-placed towers forwarded to TowerDefenseBoard."
        @tier "presentation"
      features : [TowerDefenseTemplateFeaturesItem] = []
        @label "Features"
        @description "Static feature objects on the map."
        @tier "presentation"
      assetManifest : TowerDefenseTemplateAssetManifest = { terrains: { wall: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png", role: "terrain", category: "wall", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" }, ground: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/ground.png", role: "terrain", category: "ground", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "ground", thumbnailUrl: "" }, path: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/path.png", role: "terrain", category: "path", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "path", thumbnailUrl: "" } }, units: { creep: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/creep.png", role: "unit", category: "creep", animations: ["idle","walk","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "creep", thumbnailUrl: "" } }, features: { tower: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/features/tower.png", role: "feature", category: "tower", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "tower", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Terrain/unit/feature sprite maps."
        @tier "presentation"
    }
  }

  page "/tower-defense-template" as TowerDefenseTemplatePage -> TowerDefenseTemplateRender
}
