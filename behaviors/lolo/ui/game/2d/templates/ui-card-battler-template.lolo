app ui-card-battler-template "1.0.0"
"CardBattlerTemplate — thin playable shell; renders card-battler-board descriptor matching ui-card-battler-board."
orbital CardBattlerTemplateOrbital {
  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type CardBattlerTemplateCard = {
    id : string!
    iconKey : string
    title : string
    cost : number
    attack : number
    defense : number
    sprite : Asset
  }
  type CardBattlerTemplateAssetManifest = {
    baseUrl : asset
    cards : Map string asset
  }

  entity CardBattlerTemplateItem [runtime] {
    id : string!
    hand : [CardBattlerTemplateCard]
    deck : [CardBattlerTemplateCard]
    board : [CardBattlerTemplateCard] = []
    mana : number = 3
    maxMana : number = 3
    turn : number = 1
    result : "none" | "won" | "lost" = none
  }

  trait CardBattlerTemplateRender -> @rebindable CardBattlerTemplateItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.hand @config.hand)
        (set @entity.deck @config.deck)
        (set @entity.board [])
        (set @entity.mana @config.maxMana)
        (set @entity.maxMana @config.maxMana)
        (set @entity.turn 1)
        (set @entity.result none)
        (render-ui main {
          type: card-battler-board
          hand: @entity.hand
          handItems: (array/map @entity.hand (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, playEvent: PLAY_CARD }))
          deck: @entity.deck
          board: @entity.board
          mana: @entity.mana
          maxMana: @entity.maxMana
          turn: @entity.turn
          result: @entity.result
          assetManifest: @config.assetManifest
          playCardEvent: PLAY_CARD
          endTurnEvent: END_TURN
          playAgainEvent: PLAY_AGAIN
          gameEndEvent: GAME_END
        })
      PLAY_CARD -> playing
        (set @entity.board (array/concat @entity.board [(array/find @entity.hand (fn c (== @c.id ?cardId)))]))
        (set @entity.hand (array/filter @entity.hand (fn c (!= @c.id ?cardId))))
        (set @entity.mana (- @entity.mana (object/get (array/find @entity.board (fn c (== @c.id ?cardId))) cost)))
        (render-ui main {
          type: card-battler-board
          hand: @entity.hand
          handItems: (array/map @entity.hand (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, playEvent: PLAY_CARD }))
          deck: @entity.deck
          board: @entity.board
          mana: @entity.mana
          maxMana: @entity.maxMana
          turn: @entity.turn
          result: @entity.result
          assetManifest: @config.assetManifest
          playCardEvent: PLAY_CARD
          endTurnEvent: END_TURN
          playAgainEvent: PLAY_AGAIN
          gameEndEvent: GAME_END
        })
      END_TURN -> playing
        (set @entity.turn (+ @entity.turn 1))
        (set @entity.mana @entity.maxMana)
        (set @entity.board [])
        (render-ui main {
          type: card-battler-board
          hand: @entity.hand
          handItems: (array/map @entity.hand (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, playEvent: PLAY_CARD }))
          deck: @entity.deck
          board: @entity.board
          mana: @entity.mana
          maxMana: @entity.maxMana
          turn: @entity.turn
          result: @entity.result
          assetManifest: @config.assetManifest
          playCardEvent: PLAY_CARD
          endTurnEvent: END_TURN
          playAgainEvent: PLAY_AGAIN
          gameEndEvent: GAME_END
        })
      GAME_END -> playing
        (set @entity.result won)
        (render-ui main {
          type: card-battler-board
          hand: @entity.hand
          handItems: (array/map @entity.hand (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, playEvent: PLAY_CARD }))
          deck: @entity.deck
          board: @entity.board
          mana: @entity.mana
          maxMana: @entity.maxMana
          turn: @entity.turn
          result: @entity.result
          assetManifest: @config.assetManifest
          playCardEvent: PLAY_CARD
          endTurnEvent: END_TURN
          playAgainEvent: PLAY_AGAIN
          gameEndEvent: GAME_END
        })
      PLAY_AGAIN -> playing
        (set @entity.hand @config.hand)
        (set @entity.deck @config.deck)
        (set @entity.board [])
        (set @entity.mana @config.maxMana)
        (set @entity.maxMana @config.maxMana)
        (set @entity.turn 1)
        (set @entity.result none)
        (render-ui main {
          type: card-battler-board
          hand: @entity.hand
          handItems: (array/map @entity.hand (fn c { type: game-card, id: @c.id, title: @c.title, cost: @c.cost, attack: @c.attack, defense: @c.defense, sprite: @c.sprite, playEvent: PLAY_CARD }))
          deck: @entity.deck
          board: @entity.board
          mana: @entity.mana
          maxMana: @entity.maxMana
          turn: @entity.turn
          result: @entity.result
          assetManifest: @config.assetManifest
          playCardEvent: PLAY_CARD
          endTurnEvent: END_TURN
          playAgainEvent: PLAY_AGAIN
          gameEndEvent: GAME_END
        })
    }

    emits {
      PLAY_CARD -> external { cardId : string }
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      title : string = "Card Battler"
        @label "Title"
        @description "Display title shown in the template header"
        @tier "presentation"
      maxMana : number = 3
        @label "Starting Mana"
        @description "Mana the player starts each match with"
        @tier "presentation"
      manaCap : number = 10
        @label "Mana Cap"
        @description "Maximum mana the player can have"
        @tier "presentation"
      drawPerTurn : number = 1
        @label "Draw Per Turn"
        @description "Cards drawn at the start of each turn"
        @tier "presentation"
      turnsToWin : number = 5
        @label "Turns To Win"
        @description "Number of turns needed to win"
        @tier "presentation"
      deck : [CardBattlerTemplateCard] = [{ id: "d1", iconKey: "rhino", title: "Rhino", cost: 3, attack: 4, defense: 5, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/rhino.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "rhino", thumbnailUrl: "" } }, { id: "d2", iconKey: "whale", title: "Whale", cost: 5, attack: 7, defense: 6, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/whale.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "whale", thumbnailUrl: "" } }, { id: "d3", iconKey: "parrot", title: "Parrot", cost: 2, attack: 3, defense: 2, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/parrot.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "parrot", thumbnailUrl: "" } }, { id: "d4", iconKey: "panda", title: "Panda", cost: 2, attack: 2, defense: 4, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/panda.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "panda", thumbnailUrl: "" } }, { id: "d5", iconKey: "monkey", title: "Monkey", cost: 1, attack: 2, defense: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/monkey.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "monkey", thumbnailUrl: "" } }, { id: "d6", iconKey: "penguin", title: "Penguin", cost: 1, attack: 1, defense: 2, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/penguin.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "penguin", thumbnailUrl: "" } }, { id: "d7", iconKey: "elephant", title: "Elephant", cost: 4, attack: 5, defense: 6, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/elephant.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "elephant", thumbnailUrl: "" } }]
        @label "Deck"
        @description "Draw deck forwarded to CardBattlerBoard."
        @tier "presentation"
      hand : [CardBattlerTemplateCard] = [{ id: "c1", iconKey: "bear", title: "Bear", cost: 3, attack: 5, defense: 4, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/bear.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "bear", thumbnailUrl: "" } }, { id: "c2", iconKey: "owl", title: "Owl", cost: 1, attack: 2, defense: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/owl.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "owl", thumbnailUrl: "" } }, { id: "c3", iconKey: "gorilla", title: "Gorilla", cost: 4, attack: 6, defense: 5, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/gorilla.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "gorilla", thumbnailUrl: "" } }, { id: "c4", iconKey: "frog", title: "Frog", cost: 1, attack: 1, defense: 2, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/frog.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "frog", thumbnailUrl: "" } }, { id: "c5", iconKey: "snake", title: "Snake", cost: 2, attack: 4, defense: 1, sprite: { url: "https://almadar-kflow-assets.web.app/shared/cards/cards-standard/trait-wars/standard/snake.png", role: "card", category: "creature", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "2:3", name: "snake", thumbnailUrl: "" } }]
        @label "Hand"
        @description "Opening hand forwarded to CardBattlerBoard."
        @tier "presentation"
      assetManifest : CardBattlerTemplateAssetManifest = { baseUrl: "https://almadar-kflow-assets.web.app/shared/", cards: { bear: "cards/cards-standard/trait-wars/standard/bear.png", owl: "cards/cards-standard/trait-wars/standard/owl.png", gorilla: "cards/cards-standard/trait-wars/standard/gorilla.png", rhino: "cards/cards-standard/trait-wars/standard/rhino.png", whale: "cards/cards-standard/trait-wars/standard/whale.png", parrot: "cards/cards-standard/trait-wars/standard/parrot.png", panda: "cards/cards-standard/trait-wars/standard/panda.png", monkey: "cards/cards-standard/trait-wars/standard/monkey.png", penguin: "cards/cards-standard/trait-wars/standard/penguin.png", snake: "cards/cards-standard/trait-wars/standard/snake.png", frog: "cards/cards-standard/trait-wars/standard/frog.png", elephant: "cards/cards-standard/trait-wars/standard/elephant.png" } }
        @label "Asset Manifest"
        @description "Base-url + per-iconKey card-art sprite map forwarded to CardBattlerBoard."
        @tier "presentation"
    }
  }

  page "/card-battler-template" as CardBattlerTemplatePage -> CardBattlerTemplateRender
}
