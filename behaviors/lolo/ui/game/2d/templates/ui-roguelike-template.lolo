/features/shield.png", role: "pickup", category: "item", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "shield", thumbnailUrl: "" } }, effects: {} }
        @label "Asset Manifest"
        @description "Terrain/unit/feature/effect sprite maps."
        @tier "presentation"
    }
  }

  page "/roguelike-template" as RoguelikeTemplatePage -> RoguelikeTemplateRender
