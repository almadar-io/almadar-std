app ui-game-canvas-3d "1.0.0"
"GameCanvas3d — UI factory (1:1 with the @almadar/ui game-canvas-3d pattern)."
orbital GameCanvas3dOrbital {
  type GameCanvas3dTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : GameCanvas3dTilesItemTerrainSprite
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : GameCanvas3dTilesItemModelUrl
  }
  type GameCanvas3dTilesItemTerrainSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dTilesItemModelUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUnitsItem = {
    id : string!
    position : GameCanvas3dUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : GameCanvas3dUnitsItemSprite
    spriteSheet : GameCanvas3dUnitsItemSpriteSheet
    modelUrl : GameCanvas3dUnitsItemModelUrl
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [GameCanvas3dUnitsItemTraitsItem]
    previousPosition : GameCanvas3dUnitsItemPreviousPosition
    elevation : number
    animation : "idle" | "walk" | "attack" | "hit" | "death"
    frame : number
  }
  type GameCanvas3dUnitsItemPosition = {
    x : number!
    y : number!
  }
  type GameCanvas3dUnitsItemSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUnitsItemSpriteSheet = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUnitsItemModelUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type GameCanvas3dUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type GameCanvas3dFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : GameCanvas3dFeaturesItemSprite
    assetUrl : GameCanvas3dFeaturesItemAssetUrl
    color : string
    elevation : number
  }
  type GameCanvas3dFeaturesItemSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dFeaturesItemAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dEventsItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
  }
  type GameCanvas3dValidMovesItem = {
    x : number!
    z : number!
  }
  type GameCanvas3dAttackTargetsItem = {
    x : number!
    z : number!
  }
  type GameCanvas3dTILECLICKTile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : GameCanvas3dTILECLICKTileTerrainSprite
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : GameCanvas3dTILECLICKTileModelUrl
  }
  type GameCanvas3dTILECLICKTileTerrainSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dTILECLICKTileModelUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dTILECLICKEvent = {
    clientX : number!
    clientY : number!
    button : number!
  }
  type GameCanvas3dUNITCLICKUnit = {
    id : string!
    position : GameCanvas3dUNITCLICKUnitPosition
    x : number
    y : number
    z : number
    sprite : GameCanvas3dUNITCLICKUnitSprite
    spriteSheet : GameCanvas3dUNITCLICKUnitSpriteSheet
    modelUrl : GameCanvas3dUNITCLICKUnitModelUrl
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [GameCanvas3dUNITCLICKUnitTraitsItem]
    previousPosition : GameCanvas3dUNITCLICKUnitPreviousPosition
    elevation : number
    animation : "idle" | "walk" | "attack" | "hit" | "death"
    frame : number
  }
  type GameCanvas3dUNITCLICKUnitPosition = {
    x : number!
    y : number!
  }
  type GameCanvas3dUNITCLICKUnitSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUNITCLICKUnitSpriteSheet = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUNITCLICKUnitModelUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dUNITCLICKUnitTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type GameCanvas3dUNITCLICKUnitPreviousPosition = {
    x : number!
    y : number!
  }
  type GameCanvas3dUNITCLICKEvent = {
    clientX : number!
    clientY : number!
    button : number!
  }
  type GameCanvas3dFEATURECLICKFeature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : GameCanvas3dFEATURECLICKFeatureSprite
    assetUrl : GameCanvas3dFEATURECLICKFeatureAssetUrl
    color : string
    elevation : number
  }
  type GameCanvas3dFEATURECLICKFeatureSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dFEATURECLICKFeatureAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dFEATURECLICKEvent = {
    clientX : number!
    clientY : number!
    button : number!
  }
  type GameCanvas3dCANVASCLICKEvent = {
    clientX : number!
    clientY : number!
    button : number!
  }
  type GameCanvas3dTILEHOVERTile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : GameCanvas3dTILEHOVERTileTerrainSprite
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : GameCanvas3dTILEHOVERTileModelUrl
  }
  type GameCanvas3dTILEHOVERTileTerrainSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dTILEHOVERTileModelUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dTILEHOVEREvent = {
    clientX : number!
    clientY : number!
    button : number!
  }

  entity GameCanvas3dItem [runtime] {
    id : string!
  }

  trait GameCanvas3dRender -> @rebindable GameCanvas3dItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          events: @config.events
          fogOfWar: @config.fogOfWar
          orientation: @config.orientation
          cameraMode: @config.cameraMode
          showGrid: @config.showGrid
          showCoordinates: @config.showCoordinates
          showTileInfo: @config.showTileInfo
          overlay: @config.overlay
          shadows: @config.shadows
          backgroundColor: @config.backgroundColor
          onTileClick: TILE_CLICK
          onUnitClick: UNIT_CLICK
          onFeatureClick: FEATURE_CLICK
          onCanvasClick: CANVAS_CLICK
          onTileHover: TILE_HOVER
          onUnitAnimation: UNIT_ANIMATION
          preloadAssets: @config.preloadAssets
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          featureClickEvent: FEATURE_CLICK
          canvasClickEvent: CANVAS_CLICK
          tileHoverEvent: TILE_HOVER
          tileLeaveEvent: TILE_LEAVE
          unitAnimationEvent: UNIT_ANIMATION
          cameraChangeEvent: CAMERA_CHANGE
          loadingMessage: @config.loadingMessage
          useInstancing: @config.useInstancing
          validMoves: @config.validMoves
          attackTargets: @config.attackTargets
          selectedTileIds: @config.selectedTileIds
          selectedUnitId: @config.selectedUnitId
          unitScale: @config.unitScale
          scale: @config.scale
          type: game-canvas-3d
        })
    }

    emits {
      TILE_CLICK -> external {
        tile : GameCanvas3dTILECLICKTile
        event : GameCanvas3dTILECLICKEvent
        tileId : string!
        x : number!
        z : number!
        terrain : string
        elevation : number
      }
        @description "Callback when a tile is clicked"
        @tier "essential"
      UNIT_CLICK -> external {
        unit : GameCanvas3dUNITCLICKUnit
        event : GameCanvas3dUNITCLICKEvent
        unitId : string!
        x : number!
        z : number!
        unitType : string
        name : string
        team : string
        faction : string
        health : number
        maxHealth : number
      }
        @description "Callback when a unit is clicked"
        @tier "essential"
      FEATURE_CLICK -> external {
        feature : GameCanvas3dFEATURECLICKFeature
        event : GameCanvas3dFEATURECLICKEvent
        featureId : string!
        x : number!
        z : number!
        elevation : number
      }
        @description "Callback when a feature is clicked"
        @tier "essential"
      CANVAS_CLICK -> external {
        event : GameCanvas3dCANVASCLICKEvent
        clientX : number!
        clientY : number!
        button : number!
      }
        @description "Callback when canvas is clicked (background)"
        @tier "essential"
      TILE_HOVER -> external {
        tile : GameCanvas3dTILEHOVERTile
        event : GameCanvas3dTILEHOVEREvent
        tileId : string!
        x : number!
        z : number!
      }
        @description "Callback when mouse moves over a tile"
        @tier "essential"
      UNIT_ANIMATION -> external {
        unitId : string
        state : string
        timestamp : number!
      }
        @description "Callback for unit animation state change"
        @tier "essential"
      TILE_LEAVE -> external {
        id : string
      }
        @description "Declarative event: tile leave"
        @tier "essential"
      CAMERA_CHANGE -> external {
        position : object!
        timestamp : number!
      }
        @description "Declarative event: camera change"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "--- Closed-circuit props (MANDATORY) ---"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : string = ""
        @label "Error"
        @description "Error state"
        @tier "presentation"
      tiles : [GameCanvas3dTilesItem] = [{ x: 0, y: 0, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 4, y: 0, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 0, y: 1, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 1, y: 1, terrain: "dirt", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail.glb", role: "tile", category: "dirt", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "dirt", thumbnailUrl: "" } }, { x: 2, y: 1, terrain: "grass", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, { x: 3, y: 1, terrain: "grass", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, { x: 4, y: 1, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 0, y: 2, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 1, y: 2, terrain: "grass", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, { x: 2, y: 2, terrain: "dirt", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail.glb", role: "tile", category: "dirt", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "dirt", thumbnailUrl: "" } }, { x: 3, y: 2, terrain: "grass", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, { x: 4, y: 2, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 0, y: 3, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 1, y: 3, terrain: "grass", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, { x: 2, y: 3, terrain: "grass", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "grass", thumbnailUrl: "" } }, { x: 3, y: 3, terrain: "dirt", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail.glb", role: "tile", category: "dirt", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "dirt", thumbnailUrl: "" } }, { x: 4, y: 3, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 0, y: 4, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 1, y: 4, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 2, y: 4, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 3, y: 4, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, { x: 4, y: 4, terrain: "stone", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail-a.glb", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }]
        @label "Tiles"
        @description "Array of tiles to render"
        @tier "presentation"
      units : [GameCanvas3dUnitsItem] = [{ id: "u1", position: { x: 1, y: 1 }, unitType: "worker", name: "Worker", team: player, health: 10, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/models/characters/pit_slave.glb", role: "npc", category: "worker", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "3d", aspect: "1:1", name: "worker", thumbnailUrl: "" } }, { id: "u2", position: { x: 3, y: 3 }, unitType: "guardian", name: "Guardian", team: enemy, health: 8, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/models/characters/shadow_legionnaire.glb", role: "npc", category: "guardian", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "3d", aspect: "1:1", name: "guardian", thumbnailUrl: "" } }]
        @label "Units"
        @description "Array of units to render"
        @tier "presentation"
      features : [GameCanvas3dFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/medieval/props/barrels.glb", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 1, type: "portal", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/gates/gate-door.glb", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "3d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Array of features to render"
        @tier "presentation"
      events : [GameCanvas3dEventsItem] = [{ id: "e1", x: 2, y: 2, type: "spawn", message: "Unit spawned" }, { id: "e2", x: 3, y: 1, type: "effect", message: "Attack landed" }]
        @label "Events"
        @description "Array of events to display"
        @tier "presentation"
      fogOfWar : [[boolean]] = []
        @label "Fog Of War"
        @description "Fog of war data"
        @tier "presentation"
      orientation : "standard" | "rotated" = standard
        @label "Orientation"
        @description "Map orientation"
        @tier "presentation"
      cameraMode : "isometric" | "perspective" | "top-down" = isometric
        @label "Camera Mode"
        @description "Camera mode"
        @tier "presentation"
      showGrid : boolean = true
        @label "Show Grid"
        @description "Show grid"
        @tier "presentation"
      showCoordinates : boolean = false
        @label "Show Coordinates"
        @description "Show coordinates overlay"
        @tier "presentation"
      showTileInfo : boolean = false
        @label "Show Tile Info"
        @description "Show tile information"
        @tier "presentation"
      overlay : "default" | "hidden" | "minimap" = default
        @label "Overlay"
        @description "Overlay control mode"
        @tier "presentation"
      shadows : boolean = true
        @label "Shadows"
        @description "Enable shadows"
        @tier "presentation"
      backgroundColor : string = "#1a1a2e"
        @label "Background Color"
        @description "Background color"
        @tier "presentation"
      preloadAssets : [string] = []
        @label "Preload Assets"
        @description "URLs to preload"
        @tier "presentation"
      loadingMessage : string = "Loading 3D Scene..."
        @label "Loading Message"
        @description "Loading message"
        @tier "presentation"
      useInstancing : boolean = true
        @label "Use Instancing"
        @description "Whether to use instancing for tiles"
        @tier "presentation"
      validMoves : [GameCanvas3dValidMovesItem] = [{ x: 1, z: 1 }, { x: 2, z: 2 }]
        @label "Valid Moves"
        @description "Valid move positions"
        @tier "presentation"
      attackTargets : [GameCanvas3dAttackTargetsItem] = [{ x: 1, z: 1 }, { x: 2, z: 2 }]
        @label "Attack Targets"
        @description "Attack target positions"
        @tier "presentation"
      selectedTileIds : [string] = []
        @label "Selected Tile Ids"
        @description "Selected tile IDs"
        @tier "presentation"
      selectedUnitId : string = ""
        @label "Selected Unit Id"
        @description "Selected unit ID"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier. 1 = default tile-proportional size."
        @tier "presentation"
      scale : number = 0
        @label "Scale"
        @description "Board zoom/group scale. Applied to the scene group. Default 0.45."
        @tier "presentation"
    }
  }

  page "/game-canvas-3d" as GameCanvas3dPage -> GameCanvas3dRender
}
