app ui-game-menu "1.0.0"
"GameMenu — UI factory (1:1 with the @almadar/ui game-menu pattern)."
orbital GameMenuOrbital {
  type GameMenuOptionsItem = {
    id : string
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
    disabled : boolean
    subLabel : string
    action : string
  }
  type GameMenuMenuItemsItem = {
    id : string
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
    disabled : boolean
    subLabel : string
    action : string
  }
  type GameMenuLogo = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }
  type GameMenuSELECTOption = {
    id : string
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
    disabled : boolean
    subLabel : string
    action : string
  }

  entity GameMenuItem [runtime] {
    id : string!
  }

  trait GameMenuRender -> @rebindable GameMenuItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          title: @config.title
          subtitle: @config.subtitle
          options: @config.options
          menuItems: @config.menuItems
          onSelect: @config.onSelect
          background: @config.background
          logo: @config.logo
          className: @config.className
          type: game-menu
        })
    }

    emits {
      @config.onSelect -> external {
        option : GameMenuSELECTOption
      }
        @description "Called when an option is selected (legacy callback, prefer event bus)"
        @tier "essential"
    }

    config {
      title : string = "Epic Quest"
        @label "Title"
        @description "Menu title"
        @tier "presentation"
      subtitle : string = ""
        @label "Subtitle"
        @description "Optional subtitle or version"
        @tier "presentation"
      options : [GameMenuOptionsItem] = [{ id: "Id", label: "Label", navigatesTo: "Navigates To", variant: primary, disabled: false, subLabel: "Sub Label", action: "Action" }, { id: "Id 2", label: "Label 2", navigatesTo: "Navigates To 2", variant: secondary, disabled: true, subLabel: "Sub Label 2", action: "Action 2" }]
        @label "Options"
        @description "Menu options - accepts readonly for compatibility with generated const arrays"
        @tier "presentation"
      menuItems : [GameMenuMenuItemsItem] = [{ id: "Id", label: "Label", navigatesTo: "Navigates To", variant: primary, disabled: false, subLabel: "Sub Label", action: "Action" }, { id: "Id 2", label: "Label 2", navigatesTo: "Navigates To 2", variant: secondary, disabled: true, subLabel: "Sub Label 2", action: "Action 2" }]
        @label "Menu Items"
        @description "Alias for options (schema compatibility)"
        @tier "presentation"
      onSelect : string = "SELECT"
        @label "On Select"
        @description "Called when an option is selected (legacy callback, prefer event bus)"
        @tier "presentation"
      background : string = ""
        @label "Background"
        @description "Background image or gradient"
        @tier "presentation"
      logo : GameMenuLogo
        @label "Logo"
        @description "Logo asset"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/game-menu" as GameMenuPage -> GameMenuRender
}
