app ui-isometric-canvas "1.0.0"
"IsometricCanvas — UI factory (1:1 with the @almadar/ui isometric-canvas pattern)."
orbital IsometricCanvasOrbital {
  type IsometricCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type IsometricCanvasTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type IsometricCanvasUnitsItem = {
    id : string!
    position : IsometricCanvasUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    spriteSheet : asset
    modelUrl : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [IsometricCanvasUnitsItemTraitsItem]
    previousPosition : IsometricCanvasUnitsItemPreviousPosition
    elevation : number
  }
  type IsometricCanvasUnitsItemPosition = {
    x : number!
    y : number!
  }
  type IsometricCanvasUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type IsometricCanvasUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type IsometricCanvasFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }
  type IsometricCanvasValidMovesItem = {
    x : number!
    y : number!
  }
  type IsometricCanvasAttackTargetsItem = {
    x : number!
    y : number!
  }
  type IsometricCanvasHoveredTile = {
    x : number!
    y : number!
  }
  type IsometricCanvasAssetManifest = {
    terrains : Map string string
    units : Map string string
    features : Map string string
    effects : Map string string
  }

  entity IsometricCanvasItem [runtime] {
    id : string!
  }

  trait IsometricCanvasRender -> @rebindable IsometricCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          selectedUnitId: @config.selectedUnitId
          validMoves: @config.validMoves
          attackTargets: @config.attackTargets
          hoveredTile: @config.hoveredTile
          onTileClick: TILE_CLICK
          onUnitClick: UNIT_CLICK
          onTileHover: TILE_HOVER
          onTileLeave: TILE_LEAVE
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          tileHoverEvent: TILE_HOVER
          tileLeaveEvent: TILE_LEAVE
          tileLayout: @config.tileLayout
          scale: @config.scale
          debug: @config.debug
          backgroundImage: @config.backgroundImage
          showMinimap: @config.showMinimap
          enableCamera: @config.enableCamera
          unitScale: @config.unitScale
          spriteHeightRatio: @config.spriteHeightRatio
          spriteMaxWidthRatio: @config.spriteMaxWidthRatio
          boardWidth: @config.boardWidth
          boardHeight: @config.boardHeight
          diamondTopY: @config.diamondTopY
          effectSpriteUrls: @config.effectSpriteUrls
          hasActiveEffects: @config.hasActiveEffects
          assetBaseUrl: @config.assetBaseUrl
          assetManifest: @config.assetManifest
          type: isometric-canvas
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number
        y : number
      }
        @description "--- Event handlers (legacy callbacks — prefer declarative event string props below) ---"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string
      }
        @description "onUnitClick prop"
        @tier "essential"
      TILE_HOVER -> external {
        x : number
        y : number
      }
        @description "onTileHover prop"
        @tier "essential"
      TILE_LEAVE -> external {
        id : string
      }
        @description "onTileLeave prop"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : IsometricCanvasError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      tiles : [IsometricCanvasTilesItem] = [{ x: 0, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 2, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 3, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 4, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 1, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 1, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail.glb" }, { x: 2, y: 1, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor.glb" }, { x: 3, y: 1, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor.glb" }, { x: 4, y: 1, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 2, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 2, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor.glb" }, { x: 2, y: 2, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail.glb" }, { x: 3, y: 2, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor.glb" }, { x: 4, y: 2, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 3, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 3, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor.glb" }, { x: 2, y: 3, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor.glb" }, { x: 3, y: 3, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail.glb" }, { x: 4, y: 3, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 2, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 3, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 4, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/floor/template-floor-detail-a.glb" }]
        @label "Tiles"
        @description "--- Grid data ---"
        @tier "presentation"
      units : [IsometricCanvasUnitsItem] = [{ id: "u1", position: { x: 1, y: 1 }, unitType: "worker", name: "Worker", team: player, health: 10, maxHealth: 10, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/characters/pit_slave.glb" }, { id: "u2", position: { x: 3, y: 3 }, unitType: "guardian", name: "Guardian", team: enemy, health: 8, maxHealth: 10, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/characters/shadow_legionnaire.glb" }]
        @label "Units"
        @description "Array of units on the board"
        @tier "presentation"
      features : [IsometricCanvasFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", assetUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/medieval/props/barrels.glb" }, { id: "f2", x: 3, y: 1, type: "portal", assetUrl: "https://almadar-kflow-assets.web.app/shared/3d/environments/dungeon/gates/gate-door.glb" }]
        @label "Features"
        @description "Array of features (resources, portals, buildings, etc.)"
        @tier "presentation"
      selectedUnitId : string = ""
        @label "Selected Unit Id"
        @description "--- Interaction state ---"
        @tier "presentation"
      validMoves : [IsometricCanvasValidMovesItem] = [{ x: 1, y: 1 }, { x: 2, y: 2 }]
        @label "Valid Moves"
        @description "Valid move positions (shown as pulsing green highlights)"
        @tier "presentation"
      attackTargets : [IsometricCanvasAttackTargetsItem] = [{ x: 1, y: 1 }, { x: 2, y: 2 }]
        @label "Attack Targets"
        @description "Attack target positions (shown as pulsing red highlights)"
        @tier "presentation"
      hoveredTile : IsometricCanvasHoveredTile = { x: 1, y: 1 }
        @label "Hovered Tile"
        @description "Hovered tile position"
        @tier "presentation"
      tileLayout : "isometric" | "hex" = isometric
        @label "Tile Layout"
        @description "--- Rendering options ---"
        @tier "presentation"
      scale : number = 0.4
        @label "Scale"
        @description "Render scale (0.4 = 40% zoom)"
        @tier "presentation"
      debug : boolean = false
        @label "Debug"
        @description "Show debug grid lines and coordinates"
        @tier "presentation"
      backgroundImage : asset = "https://almadar-kflow-assets.web.app/shared/units/citizens/archetypes/00_base_model.png"
        @label "Background Image"
        @description "Background image URL tiled behind the isometric grid"
        @tier "presentation"
      showMinimap : boolean = true
        @label "Show Minimap"
        @description "Toggle minimap overlay"
        @tier "presentation"
      enableCamera : boolean = true
        @label "Enable Camera"
        @description "Enable camera pan/zoom controls"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Extra scale multiplier for unit draw size. 1 = default."
        @tier "presentation"
      spriteHeightRatio : number = 1.5
        @label "Sprite Height Ratio"
        @description "Ratio of unit draw height to scaledFloorHeight. Default 1.5."
        @tier "presentation"
      spriteMaxWidthRatio : number = 0.6
        @label "Sprite Max Width Ratio"
        @description "Max unit draw width as a ratio of scaledTileWidth. Default 0.6."
        @tier "presentation"
      boardWidth : number = 0
        @label "Board Width"
        @description "Board width in tiles (overrides tile-derived size)"
        @tier "presentation"
      boardHeight : number = 0
        @label "Board Height"
        @description "Board height in tiles (overrides tile-derived size)"
        @tier "presentation"
      diamondTopY : number = 0
        @label "Diamond Top Y"
        @description "Override for the diamond-top Y offset within the tile sprite (default: 374). This controls where the flat diamond face sits vertically inside the tile image."
        @tier "presentation"
      effectSpriteUrls : [asset] = []
        @label "Effect Sprite Urls"
        @description "Additional sprite URLs to preload (e.g., effect sprites)"
        @tier "presentation"
      hasActiveEffects : boolean = false
        @label "Has Active Effects"
        @description "Whether there are active effects — keeps RAF loop alive"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "--- Remote asset loading ---"
        @tier "presentation"
      assetManifest : IsometricCanvasAssetManifest = { terrains: { grass: "terrains/iso/medieval/dirt_E.png", dirt: "terrains/iso/medieval/dirtTiles_E.png", stone: "terrains/iso/medieval/stoneInset_E.png", forest: "terrains/iso/medieval/planks_E.png", castle: "terrains/iso/medieval/stoneTile_E.png" }, units: { worker: "units/domain/worker.png", guardian: "units/domain/guardian.png", scrapper: "units/domain/scrapper.png", mender: "units/domain/mender.png" }, features: { gold_mine: "features/world-map/gold_mine.png", portal: "features/world-map/portal_open.png", castle: "features/castle/resonator_citadel.png" }, effects: {} }
        @label "Asset Manifest"
        @description "Manifest mapping entity keys to relative sprite paths. Combined with assetBaseUrl to produce full URLs. Used as a fallback when inline URLs and callbacks don't resolve."
        @tier "presentation"
    }
  }

  page "/isometric-canvas" as IsometricCanvasPage -> IsometricCanvasRender
}
