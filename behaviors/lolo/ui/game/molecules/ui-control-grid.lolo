app ui-control-grid "1.0.0"
"ControlGrid — UI factory (1:1 with the @almadar/ui control-grid pattern)."
orbital ControlGridOrbital {
  type ControlGridButtonsItem = {
    id : string!
    label : string
    icon : icon
    assetUrl : ControlGridButtonsItemAssetUrl
    variant : "primary" | "secondary" | "ghost"
  }
  type ControlGridButtonsItemAssetUrl = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }
  type ControlGridDirectionAssetsValue = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity ControlGridItem [runtime] {
    id : string!
  }

  trait ControlGridRender -> @rebindable ControlGridItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          kind: @config.kind
          buttons: @config.buttons
          layout: @config.layout
          includeDiagonals: @config.includeDiagonals
          onAction: ACTION
          actionEvent: ACTION
          onDirection: DIRECTION
          directionEvent: DIRECTION
          directionEvents: @config.directionEvents
          directionReleaseEvents: @config.directionReleaseEvents
          directionAssets: @config.directionAssets
          size: @config.size
          disabled: @config.disabled
          className: @config.className
          type: control-grid
        })
    }

    emits {
      ACTION -> external {
        id : string
        pressed : boolean
      }
        @description "Called when a button/direction is pressed or released"
        @tier "essential"
      DIRECTION -> external {
        direction : string
        pressed : boolean
      }
        @description "Called when a direction is pressed or released (kind='dpad' convenience overload)"
        @tier "essential"
    }

    config {
      kind : "dpad" | "actions" = dpad
        @label "Kind"
        @description "kind prop"
        @tier "presentation"
      buttons : [ControlGridButtonsItem] = [{ id: "Id", label: "Label", icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "pixel", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }, variant: primary }, { id: "Id 2", label: "Label 2", icon: "circle", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "assetUrl", animations: ["idle", "walk", "attack", "hit", "death"], style: "pixel", dimension: "2d", aspect: "1:1", name: "assetUrl", thumbnailUrl: "" }, variant: secondary }]
        @label "Buttons"
        @description "action buttons (kind='actions')"
        @tier "presentation"
      layout : "horizontal" | "vertical" | "diamond" = horizontal
        @label "Layout"
        @description "Layout for kind='actions'"
        @tier "presentation"
      includeDiagonals : boolean = false
        @label "Include Diagonals"
        @description "Whether to include diagonal buttons (kind='dpad')"
        @tier "presentation"
      directionEvents : Map string string = { item: "Item" }
        @label "Direction Events"
        @description "Per-direction PRESS → the board's SEMANTIC event (kind='dpad'), e.g. `{ left: 'LEFT', right: 'RIGHT', up: 'JUMP' }`. Lets the d-pad emit the SAME intent events as the keyboard so the FSM stays device-agnostic."
        @tier "presentation"
      directionReleaseEvents : Map string string = { item: "Item" }
        @label "Direction Release Events"
        @description "Per-direction RELEASE → semantic event, e.g. `{ left: 'STOP', right: 'STOP' }`. Omit a direction to ignore its release."
        @tier "presentation"
      directionAssets : Map string ControlGridDirectionAssetsValue = { item: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/sword.png", role: "item", category: "item", animations: ["static"], style: "pixel", dimension: "2d", aspect: "1:1", name: "item", thumbnailUrl: "" } }
        @label "Direction Assets"
        @description "Per-direction sprite assets for kind='dpad' buttons (e.g. Kenny arrow PNGs). Falls back to arrow emoji."
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "size prop"
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "disabled prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/control-grid" as ControlGridPage -> ControlGridRender
}
