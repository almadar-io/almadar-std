app ui-dialogue-box "1.0.0"
"DialogueBox — UI factory (1:1 with the @almadar/ui dialogue-box pattern)."
orbital DialogueBoxOrbital {
  type DialogueBoxDialogue = {
    id : string
    speaker : string!
    text : string!
    portrait : string
    choices : [DialogueBoxDialogueChoicesItem]
    autoAdvance : number
  }
  type DialogueBoxDialogueChoicesItem = {
    text : string!
    action : string
    next : string
    disabled : boolean
  }
  type DialogueBoxCHOICEChoice = {
    text : string!
    action : string
    next : string
    disabled : boolean
  }

  entity DialogueBoxItem [runtime] {
    id : string!
  }

  trait DialogueBoxRender -> @rebindable DialogueBoxItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          dialogue: @config.dialogue
          typewriterSpeed: @config.typewriterSpeed
          position: @config.position
          onComplete: COMPLETE
          onChoice: CHOICE
          onAdvance: ADVANCE
          completeEvent: COMPLETE
          choiceEvent: CHOICE
          advanceEvent: ADVANCE
          backgroundImage: @config.backgroundImage
          portraitUrl: @config.portraitUrl
          portraitScale: @config.portraitScale
          className: @config.className
          type: dialogue-box
        })
    }

    emits {
      COMPLETE -> external {
        id : string
      }
        @description "Called when text animation completes"
        @tier "essential"
      CHOICE -> external {
        choice : DialogueBoxCHOICEChoice
      }
        @description "Called when a choice is selected"
        @tier "essential"
      ADVANCE -> external {
        id : string
      }
        @description "Called when dialogue is advanced (no choices)"
        @tier "essential"
    }

    config {
      dialogue : DialogueBoxDialogue = { id: "Id", speaker: "Speaker", text: "Text", portrait: "Portrait", choices: [{ text: "Text", action: "Action", next: "Next", disabled: false }, { text: "Text 2", action: "Action 2", next: "Next 2", disabled: true }], autoAdvance: 1 }
        @label "Dialogue"
        @description "Current dialogue node to display"
        @tier "presentation"
      typewriterSpeed : number = 30
        @label "Typewriter Speed"
        @description "Typewriter speed in ms per character (0 = instant)"
        @tier "presentation"
      position : "top" | "bottom" = bottom
        @label "Position"
        @description "Position of dialogue box"
        @tier "presentation"
      backgroundImage : asset = "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/citizens/archetypes/00_base_model.png"
        @label "Background Image"
        @description "Optional full-frame scene image rendered behind the dialogue (visual-novel mode)."
        @tier "presentation"
      portraitUrl : asset = "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/citizens/archetypes/00_base_model.png"
        @label "Portrait Url"
        @description "Optional larger character portrait rendered standing over the scene (visual-novel mode)."
        @tier "presentation"
      portraitScale : number = 1
        @label "Portrait Scale"
        @description "Multiplier for the large `portraitUrl` height relative to its default (default 1)."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Optional className"
        @tier "presentation"
    }
  }

  page "/dialogue-box" as DialogueBoxPage -> DialogueBoxRender
}
