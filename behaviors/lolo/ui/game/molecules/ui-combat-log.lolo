app ui-combat-log "1.0.0"
"CombatLog — UI factory (1:1 with the @almadar/ui combat-log pattern)."
orbital CombatLogOrbital {
  type CombatLogEventsItem = {
    id : string!
    type : "attack" | "defend" | "heal" | "move" | "special" | "death" | "spawn"!
    message : string!
    timestamp : number!
    actorName : string
    targetName : string
    value : number
    turn : number
  }

  entity CombatLogItem [runtime] {
    id : string!
  }

  trait CombatLogRender -> @rebindable CombatLogItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          events: @config.events
          maxVisible: @config.maxVisible
          autoScroll: @config.autoScroll
          showTimestamps: @config.showTimestamps
          title: @config.title
          className: @config.className
          type: combat-log
        })
    }

    config {
      events : [CombatLogEventsItem] = [{ id: "Id", type: attack, message: "Message", timestamp: 1, actorName: "Actor Name", targetName: "Target Name", value: 1, turn: 1 }]
        @label "Events"
        @description "events prop"
        @tier "presentation"
      maxVisible : number = 50
        @label "Max Visible"
        @description "maxVisible prop"
        @tier "presentation"
      autoScroll : boolean = true
        @label "Auto Scroll"
        @description "autoScroll prop"
        @tier "presentation"
      showTimestamps : boolean = false
        @label "Show Timestamps"
        @description "showTimestamps prop"
        @tier "presentation"
      title : string = "Combat Log"
        @label "Title"
        @description "title prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/combat-log" as CombatLogPage -> CombatLogRender
}
