      ]
    }
  }

  trait Enemies = Combat.traits.DungeonCombat -> GameState {
    config {
      running: true
      gridWidth: 4
      gridHeight: 4
      startHp: 5
      attackDamage: 1
      pointsPerKill: 50
      enemies: [
        { id: "goblin", position: { x: 2, y: 2 }, x: 2, y: 2, z: 0, team: "enemy", health: 2, maxHealth: 2, unitType: "goblin", name: "Goblin", sprite: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-shape-characters/units/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-shape-characters/units/spritesheet_default.json", sprite: "red_body_square.png", role: "enemy", category: "unit", animations: ["idle"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "enemy-unit", thumbnailUrl: "" } }
      ]
    }
  }

  trait Collector = Objective.traits.ObjectiveReach -> GameState {
    config {
      running: true
      targetType: "chest"
      pointsPerTarget: 200
      removeOnReach: false
      reachRadius: 0
      features: []
    }
  }

  trait FxDecay = Particles.traits.FxParticles -> GameState {
    config { running: true }
  }

  trait RoundGate = Gate.traits.ObjectiveFlow -> GameState {
    config { running: true }
  }

  trait DungeonIntent -> GameState [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (render-ui main {
          type: game-shell
          fontFamily: @config.fontFamily
          backgroundAsset: @config.backgroundAsset
          hudBackgroundAsset: @config.hudBackgroundAsset
          hud: { type: game-hud, stats: [ { label: "HP", value: @entity.hp, max: @entity.maxHp, format: "hearts" }, { label: "Score", value: (+ @entity.score @entity.combatScore) } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" }, directionAssets: @config.directionAssets }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: "VICTORY", subtitle: "You found the chest!", options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } (if (!= @entity.combatResult "none") { type: game-menu, title: "DEFEAT", subtitle: "The dungeon claims another hero", options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null))
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "flat", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @entity.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc" })) }
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (if (object/get (object/get @t terrainSprite) url) (object/get @t terrainSprite) (object/get (object/get @config.assetManifest terrains) (object/get @t terrain))), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-sprite, position: (object/get @u position), asset: (if (object/get (object/get @u sprite) url) (object/get @u sprite) (object/get (object/get @config.assetManifest units) (object/get @u unitType))), anchor: "ground", width: 0.5, height: 0.5 })) }
            { type: draw-shape-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: 0.5, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: (* 0.5 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })

      MOVE_UP -> playing when (and (== @entity.result "none") (== @entity.combatResult "none"))
        (let ((hero (array/find @entity.units (fn u (== @u.id "hero")))))
          (let ((nx (object/get (object/get @hero position) x)) (ny (- (object/get (object/get @hero position) y) 1)))
            (let ((targetEnemy (array/find @entity.enemies (fn e (and (> @e.health 0) (and (== (object/get (object/get @e position) x) @nx) (== (object/get (object/get @e position) y) @ny)))))) (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny))))))
              (if (!= @targetEnemy null)
                (emit ATTACK { targetId: (object/get @targetEnemy id) })
                (if (and (grid/in-bounds { x: @nx, y: @ny } @config.gridWidth @config.gridHeight) (== (if (== @tile null) false (object/get @tile passable)) true))
                  (emit MOVE { unitId: "hero", x: @nx, y: @ny })
                  true)))))

      MOVE_DOWN -> playing when (and (== @entity.result "none") (== @entity.combatResult "none"))
        (let ((hero (array/find @entity.units (fn u (== @u.id "hero")))))
          (let ((nx (object/get (object/get @hero position) x)) (ny (+ (object/get (object/get @hero position) y) 1)))
            (let ((targetEnemy (array/find @entity.enemies (fn e (and (> @e.health 0) (and (== (object/get (object/get @e position) x) @nx) (== (object/get (object/get @e position) y) @ny)))))) (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny))))))
              (if (!= @targetEnemy null)
                (emit ATTACK { targetId: (object/get @targetEnemy id) })
                (if (and (grid/in-bounds { x: @nx, y: @ny } @config.gridWidth @config.gridHeight) (== (if (== @tile null) false (object/get @tile passable)) true))
                  (emit MOVE { unitId: "hero", x: @nx, y: @ny })
                  true)))))

      MOVE_LEFT -> playing when (and (== @entity.result "none") (== @entity.combatResult "none"))
        (let ((hero (array/find @entity.units (fn u (== @u.id "hero")))))
          (let ((nx (- (object/get (object/get @hero position) x) 1)) (ny (object/get (object/get @hero position) y)))
            (let ((targetEnemy (array/find @entity.enemies (fn e (and (> @e.health 0) (and (== (object/get (object/get @e position) x) @nx) (== (object/get (object/get @e position) y) @ny)))))) (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny))))))
              (if (!= @targetEnemy null)
                (emit ATTACK { targetId: (object/get @targetEnemy id) })
                (if (and (grid/in-bounds { x: @nx, y: @ny } @config.gridWidth @config.gridHeight) (== (if (== @tile null) false (object/get @tile passable)) true))
                  (emit MOVE { unitId: "hero", x: @nx, y: @ny })
                  true)))))

      MOVE_RIGHT -> playing when (and (== @entity.result "none") (== @entity.combatResult "none"))
        (let ((hero (array/find @entity.units (fn u (== @u.id "hero")))))
          (let ((nx (+ (object/get (object/get @hero position) x) 1)) (ny (object/get (object/get @hero position) y)))
            (let ((targetEnemy (array/find @entity.enemies (fn e (and (> @e.health 0) (and (== (object/get (object/get @e position) x) @nx) (== (object/get (object/get @e position) y) @ny)))))) (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny))))))
              (if (!= @targetEnemy null)
                (emit ATTACK { targetId: (object/get @targetEnemy id) })
                (if (and (grid/in-bounds { x: @nx, y: @ny } @config.gridWidth @config.gridHeight) (== (if (== @tile null) false (object/get @tile passable)) true))
                  (emit MOVE { unitId: "hero", x: @nx, y: @ny })
                  true)))))

      PLAY_AGAIN -> playing
        (emit RESTART { id: "board" })
    }

    ticks {
      renderTick every 100ms
        (render-ui main {
          type: game-shell
          fontFamily: @config.fontFamily
          backgroundAsset: @config.backgroundAsset
          hudBackgroundAsset: @config.hudBackgroundAsset
          hud: { type: game-hud, stats: [ { label: "HP", value: @entity.hp, max: @entity.maxHp, format: "hearts" }, { label: "Score", value: (+ @entity.score @entity.combatScore) } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" }, directionAssets: @config.directionAssets }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: "VICTORY", subtitle: "You found the chest!", options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } (if (!= @entity.combatResult "none") { type: game-menu, title: "DEFEAT", subtitle: "The dungeon claims another hero", options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null))
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "flat", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @entity.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc" })) }
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (if (object/get (object/get @t terrainSprite) url) (object/get @t terrainSprite) (object/get (object/get @config.assetManifest terrains) (object/get @t terrain))), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-sprite, position: (object/get @u position), asset: (if (object/get (object/get @u sprite) url) (object/get @u sprite) (object/get (object/get @config.assetManifest units) (object/get @u unitType))), anchor: "ground", width: 0.5, height: 0.5 })) }
            { type: draw-shape-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: 0.5, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: (* 0.5 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map (array/concat @entity.units @entity.enemies) (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })

      chaseTick every 900ms when (and (== @entity.result "none") (== @entity.combatResult "none"))
        (emit MONSTER_TICK { heroX: (object/get (object/get (array/find @entity.units (fn u (== @u.id "hero"))) position) x), heroY: (object/get (object/get (array/find @entity.units (fn u (== @u.id "hero"))) position) y) })
    }

    emits {
      MOVE -> external {
        unitId : string!
        x : number!
        y : number!
      }
        @description "Hero move intent applied by the hero-nav authority"
        @tier "domain"
      ATTACK -> external {
        targetId : string!
      }
        @description "Bump-attack intent applied by the dungeon-combat authority"
        @tier "domain"
      MONSTER_TICK -> external {
        heroX : number!
        heroY : number!
      }
        @description "Advances enemy chase AI and applies hero contact damage via the dungeon-combat authority"
        @tier "domain"
      MOVE_UP -> external {
        id : string
      }
        @description "Step north (keyMap or d-pad directionEvents)"
        @tier "domain"
      MOVE_DOWN -> external {
        id : string
      }
        @description "Step south (keyMap or d-pad directionEvents)"
        @tier "domain"
      MOVE_LEFT -> external {
        id : string
      }
        @description "Step west (keyMap or d-pad directionEvents)"
        @tier "domain"
      MOVE_RIGHT -> external {
        id : string
      }
        @description "Step east (keyMap or d-pad directionEvents)"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets every mechanic (units/enemies/HP, objectives, result) for a new run"
        @tier "domain"
      RESTART -> external {
        id : string
      }
        @description "Broadcast reset consumed by hero-nav/dungeon-combat/objective-reach/objective-flow"
        @tier "domain"
    }

    config {
      gridWidth : number = 4
        @label "Grid Width"
        @description "Grid column count (matches HeroAuthority/Enemies.gridWidth)."
        @tier "domain"
      gridHeight : number = 4
        @label "Grid Height"
        @description "Grid row count (matches HeroAuthority/Enemies.gridHeight)."
        @tier "domain"
      scale : number = 1
        @label "Scale"
        @description "Canvas render scale."
        @tier "presentation"
      fontFamily : string = ""
        @label "Font Family"
        @description "game-shell font family (e.g. pixel)."
        @tier "presentation"
      assetManifest : AssetManifest = { terrains: {}, units: {}, features: {}, effects: {} }
        @label "Asset Manifest"
        @description "Terrain/unit/feature/effect sprite manifest."
        @tier "presentation"
      backgroundAsset : Asset = {}
        @label "Background Asset"
        @description "Game-shell background panel sprite (theme chrome)."
        @tier "presentation"
      hudBackgroundAsset : Asset = {}
        @label "HUD Background Asset"
        @description "HUD panel background sprite (theme chrome)."
        @tier "presentation"
      directionAssets : DirectionAssets = {}
        @label "Direction Assets"
        @description "D-pad direction icon sprites."
        @tier "presentation"
    }
  }

  page "/dungeon-board-2d" as DungeonBoard2DPage -> HeroAuthority, Enemies, Collector, FxDecay, RoundGate, DungeonIntent
}
