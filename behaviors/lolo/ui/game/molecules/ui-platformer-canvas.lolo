app ui-platformer-canvas "1.1.0"
"PlatformerCanvas — model-authoritative platformer physics; 33ms tick owns gravity+integration+AABB collision; canvas interpolates from player/platforms props."
orbital PlatformerCanvasOrbital {
  type PlatformerCanvasPlayer = {
    x : number!
    y : number!
    width : number
    height : number
    vx : number
    vy : number
    grounded : boolean
    facingRight : boolean
  }
  type PlatformerCanvasPlatformsItem = {
    x : number!
    y : number!
    width : number!
    height : number!
    type : "ground" | "platform" | "hazard" | "goal"
  }

  entity PlatformerCanvasItem [runtime] {
    id : string!
    player : PlatformerCanvasPlayer = { x: 80, y: 320, width: 32, height: 48, vx: 0, vy: 0, grounded: false, facingRight: true }
    platforms : [PlatformerCanvasPlatformsItem] = []
  }

  trait PlatformerCanvasRender -> @rebindable PlatformerCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.player @config.player)
        (set @entity.platforms @config.platforms)
        (render-ui main {
          player: @entity.player
          platforms: @entity.platforms
          worldWidth: @config.worldWidth
          worldHeight: @config.worldHeight
          canvasWidth: @config.canvasWidth
          canvasHeight: @config.canvasHeight
          followCamera: @config.followCamera
          bgColor: @config.bgColor
          playerSprite: @config.playerSprite
          tileSprites: @config.tileSprites
          backgroundImage: @config.backgroundImage
          assetBaseUrl: @config.assetBaseUrl
          leftEvent: LEFT
          rightEvent: RIGHT
          jumpEvent: JUMP
          stopEvent: STOP
          className: @config.className
          type: platformer-canvas
        })

      LEFT -> idle
        (set @entity.player (object/merge @entity.player { vx: (- 0 @config.moveSpeed), facingRight: false }))

      RIGHT -> idle
        (set @entity.player (object/merge @entity.player { vx: @config.moveSpeed, facingRight: true }))

      JUMP -> idle when (== @entity.player.grounded true)
        (set @entity.player (object/merge @entity.player { vy: (- 0 @config.jumpStrength), grounded: false }))

      STOP -> idle
        (set @entity.player (object/merge @entity.player { vx: 0 }))
    }

    ticks {
      physicsStep every 33ms
        (let ((vy1 (math/clamp (+ @entity.player.vy @config.gravity) (- 0 @config.jumpStrength) @config.maxFallSpeed))
              (px1 (math/clamp (+ @entity.player.x @entity.player.vx) 0 (- @config.worldWidth @entity.player.width)))
              (py1 (+ @entity.player.y @vy1))
              (pw @entity.player.width)
              (ph @entity.player.height)
              (playerRect { x: @px1, y: @py1, w: @pw, h: @ph })
              (hit (array/find @entity.platforms (fn p (geo/aabb-overlap @playerRect { x: @p.x, y: @p.y, w: @p.width, h: @p.height }))))
              (hitY (object/get @hit "y" @config.worldHeight))
              (landed (and (!= @hit null) (> @vy1 0)))
              (py2 (if @landed (- @hitY @ph) @py1))
              (vy2 (if @landed 0 @vy1))
              (atGround (>= (+ @py2 @ph) @config.worldHeight))
              (py3 (if @atGround (- @config.worldHeight @ph) @py2))
              (vy3 (if @atGround 0 @vy2))
              (grounded (or @landed @atGround)))
          (do
            (set @entity.player (object/merge @entity.player { x: @px1, y: @py3, vy: @vy3, grounded: @grounded }))
            (render-ui main {
              player: @entity.player
              platforms: @entity.platforms
              worldWidth: @config.worldWidth
              worldHeight: @config.worldHeight
              canvasWidth: @config.canvasWidth
              canvasHeight: @config.canvasHeight
              followCamera: @config.followCamera
              bgColor: @config.bgColor
              playerSprite: @config.playerSprite
              tileSprites: @config.tileSprites
              backgroundImage: @config.backgroundImage
              assetBaseUrl: @config.assetBaseUrl
              leftEvent: LEFT
              rightEvent: RIGHT
              jumpEvent: JUMP
              stopEvent: STOP
              className: @config.className
              type: platformer-canvas
            })))
    }

    emits {
      LEFT -> external {
        direction : number!
      }
        @description "Left arrow / A key pressed"
        @tier "essential"
      RIGHT -> external {
        direction : number!
      }
        @description "Right arrow / D key pressed"
        @tier "essential"
      JUMP -> external {
        id : string
      }
        @description "Up / Space pressed; model checks grounded guard"
        @tier "essential"
      STOP -> external {
        id : string
      }
        @description "Horizontal key released"
        @tier "essential"
    }

    config {
      player : PlatformerCanvasPlayer = { x: 80, y: 320, width: 32, height: 48, vx: 0, vy: 0, grounded: false, facingRight: true }
        @label "Player"
        @description "Initial player state"
        @tier "presentation"
      platforms : [PlatformerCanvasPlatformsItem] = [{ x: 0, y: 368, width: 800, height: 32, type: ground }, { x: 150, y: 280, width: 160, height: 16, type: platform }, { x: 420, y: 220, width: 160, height: 16, type: platform }, { x: 620, y: 300, width: 140, height: 16, type: platform }]
        @label "Platforms"
        @description "Level geometry; ground at worldHeight-32"
        @tier "presentation"
      gravity : number = 0.6
        @label "Gravity"
        @description "vy delta applied each 33ms tick"
        @tier "presentation"
      jumpStrength : number = 12
        @label "Jump Strength"
        @description "vy set to -(jumpStrength) on JUMP"
        @tier "presentation"
      maxFallSpeed : number = 20
        @label "Max Fall Speed"
        @description "Terminal velocity cap downward"
        @tier "presentation"
      moveSpeed : number = 4
        @label "Move Speed"
        @description "Horizontal vx magnitude on LEFT/RIGHT"
        @tier "presentation"
      worldWidth : number = 800
        @label "World Width"
        @description "World dimensions in pixels"
        @tier "presentation"
      worldHeight : number = 400
        @label "World Height"
        @description "worldHeight prop"
        @tier "presentation"
      canvasWidth : number = 800
        @label "Canvas Width"
        @description "Canvas display size"
        @tier "presentation"
      canvasHeight : number = 400
        @label "Canvas Height"
        @description "canvasHeight prop"
        @tier "presentation"
      followCamera : boolean = true
        @label "Follow Camera"
        @description "Camera follows player"
        @tier "presentation"
      bgColor : string = "#5c94fc"
        @label "Bg Color"
        @description "Background color"
        @tier "presentation"
      playerSprite : asset = "https://almadar-kflow-assets.web.app/shared/units/chars-toon/kflow/toon/platformChar_idle.png"
        @label "Player Sprite"
        @description "Player sprite image URL"
        @tier "presentation"
      tileSprites : Map string asset = { ground: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kflow/flat/platformer/platformPack_tile029.png", platform: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kflow/flat/platformer/platformPack_tile046.png", hazard: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kflow/flat/platformer/platformPack_tile063.png", goal: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-flat-platformer/kflow/flat/platformer/platformPack_tile058.png" }
        @label "Tile Sprites"
        @description "Map of platform type to tile sprite URL"
        @tier "presentation"
      backgroundImage : asset = "https://almadar-kflow-assets.web.app/shared/backgrounds/bg-parallax/kflow/scenes/world/streets.png"
        @label "Background Image"
        @description "Background image URL"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prefix for asset URLs"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/platformer-canvas" as PlatformerCanvasPage -> PlatformerCanvasRender
}
