app ui-sequence-bar "1.0.0"
"SequenceBar — UI factory (1:1 with the @almadar/ui sequence-bar pattern)."
orbital SequenceBarOrbital {
  type SequenceBarSlotsItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : SequenceBarSlotsItemIconUrl
    stateMachine : json
  }
  type SequenceBarSlotsItemIconUrl = {
    url : asset!
    role : string!
    category : string!
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    variant : string
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    atlas : asset
    sprite : string
    name : string
    thumbnailUrl : string
  }
  type SequenceBarCategoryColorsValue = {
    bg : string!
    border : string!
  }
  type SequenceBarSLOTDROPItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : SequenceBarSLOTDROPItemIconUrl
    stateMachine : json
  }
  type SequenceBarSLOTDROPItemIconUrl = {
    url : asset!
    role : string!
    category : string!
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    variant : string
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    atlas : asset
    sprite : string
    name : string
    thumbnailUrl : string
  }

  entity SequenceBarItem [runtime] {
    id : string!
  }

  trait SequenceBarRender -> @rebindable SequenceBarItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          slots: @config.slots
          maxSlots: @config.maxSlots
          onSlotDrop: @config.onSlotDrop
          onSlotRemove: @config.onSlotRemove
          slotDropEvent: @config.slotDropEvent
          slotRemoveEvent: @config.slotRemoveEvent
          playing: @config.playing
          currentStep: @config.currentStep
          categoryColors: @config.categoryColors
          slotFeedback: @config.slotFeedback
          size: @config.size
          className: @config.className
          type: sequence-bar
        })
    }

    emits {
      @config.onSlotDrop -> external {
        index : number
        item : SequenceBarSLOTDROPItem
        slotNumber : number!
        itemId : string!
      }
        @description "Called when an item is dropped into slot at index (callback path)"
        @tier "essential"
      @config.onSlotRemove -> external {
        index : number
        slotNumber : number!
      }
        @description "Called when a slot is cleared (callback path)"
        @tier "essential"
    }

    config {
      slots : [SequenceBarSlotsItem] = [{ id: "Id", name: "Name", category: "Category", description: "Description", iconEmoji: "Icon Emoji", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png", role: "ui", category: "iconUrl", animations: ["static"], style: "pixel", dimension: "2d", aspect: "1:1", name: "iconUrl", thumbnailUrl: "" } }, { id: "Id 2", name: "Name 2", category: "Category 2", description: "Description 2", iconEmoji: "Icon Emoji 2", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png", role: "ui", category: "iconUrl", animations: ["static"], style: "pixel", dimension: "2d", aspect: "1:1", name: "iconUrl", thumbnailUrl: "" } }]
        @label "Slots"
        @description "The current sequence (sparse — undefined means empty slot)"
        @tier "presentation"
      maxSlots : number = 1
        @label "Max Slots"
        @description "Max number of slots"
        @tier "presentation"
      onSlotDrop : string = "SLOT_DROP"
        @label "On Slot Drop"
        @description "Called when an item is dropped into slot at index (callback path)"
        @tier "presentation"
      onSlotRemove : string = "SLOT_REMOVE"
        @label "On Slot Remove"
        @description "Called when a slot is cleared (callback path)"
        @tier "presentation"
      slotDropEvent : string = "SLOT_DROP"
        @label "Slot Drop Event"
        @description "Emits UI:{slotDropEvent} with { slotNumber, itemId } when an item is dropped (declarative path)"
        @tier "presentation"
      slotRemoveEvent : string = "SLOT_REMOVE"
        @label "Slot Remove Event"
        @description "Emits UI:{slotRemoveEvent} with { slotNumber } when a slot is cleared (declarative path)"
        @tier "presentation"
      playing : boolean = false
        @label "Playing"
        @description "Whether the sequence is currently playing (disable interaction)"
        @tier "presentation"
      currentStep : number = -1
        @label "Current Step"
        @description "Current step index during playback (-1 = not playing)"
        @tier "presentation"
      categoryColors : Map string SequenceBarCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
      slotFeedback : ["correct" | "wrong"] = []
        @label "Slot Feedback"
        @description "Per-slot correctness feedback shown after a failed attempt"
        @tier "presentation"
      size : "sm" | "md" | "lg" = lg
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/sequence-bar" as SequenceBarPage -> SequenceBarRender
}
