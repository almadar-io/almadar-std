app ui-state-graph "1.0.0"
"StateGraph — UI factory (1:1 with the @almadar/ui state-graph pattern)."
orbital StateGraphOrbital {
  type StateGraphTransitionsItem = {
    from : string!
    to : string!
    event : string!
    guardHint : string
  }

  entity StateGraphItem [runtime] {
    id : string!
  }

  trait StateGraphRender -> @rebindable StateGraphItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          states: @config.states
          transitions: @config.transitions
          currentState: @config.currentState
          selectedState: @config.selectedState
          addingFrom: @config.addingFrom
          initialState: @config.initialState
          width: @config.width
          height: @config.height
          nodeClickEvent: @config.nodeClickEvent
          className: @config.className
          type: state-graph
        })
    }

    emits {
      @config.nodeClickEvent -> external {
        id : string
      }
        @description "Emits UI:{nodeClickEvent} with { stateId } when a node is clicked."
        @tier "essential"
    }

    config {
      states : [string] = ["Item", "Item 2"]
        @label "States"
        @description "All states in the machine (node labels)."
        @tier "presentation"
      transitions : [StateGraphTransitionsItem] = []
        @label "Transitions"
        @description "Player-built transitions rendered as arrows."
        @tier "presentation"
      currentState : string
        @label "Current State"
        @description "State highlighted as current (test playback / initial)."
        @tier "presentation"
      selectedState : string
        @label "Selected State"
        @description "State the player has selected (first click)."
        @tier "presentation"
      addingFrom : string
        @label "Adding From"
        @description "When set, the graph is in 'pick a target' mode from this state."
        @tier "presentation"
      initialState : string
        @label "Initial State"
        @description "The machine's initial state (ring-marked)."
        @tier "presentation"
      width : number = 500
        @label "Width"
        @description "Graph canvas width."
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Graph canvas height."
        @tier "presentation"
      nodeClickEvent : string = "NODE_CLICK"
        @label "Node Click Event"
        @description "Emits UI:{nodeClickEvent} with { stateId } when a node is clicked."
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/state-graph" as StateGraphPage -> StateGraphRender
}
