app ui-canvas-2d "1.0.0"
"Canvas2d — UI factory (1:1 with the @almadar/ui canvas-2d pattern)."
orbital Canvas2dOrbital {
  type Canvas2dError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Canvas2dFollowTarget = {
    x : number!
    y : number!
    z : number
  }

  entity Canvas2dItem [runtime] {
    id : string!
  }

  trait Canvas2dRender -> @rebindable Canvas2dItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          projection: @config.projection
          drawables: @config.drawables
          backgroundImage: @config.backgroundImage
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          tileHoverEvent: TILE_HOVER
          tileLeaveEvent: TILE_LEAVE
          keyMap: @config.keyMap
          keyUpMap: @config.keyUpMap
          camera: @config.camera
          scale: @config.scale
          showMinimap: @config.showMinimap
          followTarget: @config.followTarget
          bgColor: @config.bgColor
          type: canvas-2d
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "--- Declarative events back to LOLO ---"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Unit-click event. The neutral drawable host cannot resolve a click to a per-entity id (descriptors carry only a `ScenePos`, no id), so this prop is accepted but not yet emitted — the id-hit-test is a tracked fork (docs/Almadar_Std_Game_V2_PLAN.md)."
        @tier "essential"
      TILE_HOVER -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileHoverEvent} with the unprojected scene { x, y } on hover."
        @tier "essential"
      TILE_LEAVE -> external {
        id : string
      }
        @description "Emits UI:{tileLeaveEvent} with {} on pointer leave."
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "--- Closed-circuit ---"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : Canvas2dError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      projection : "isometric" | "hex" | "flat" | "free" | "side" = isometric
        @label "Projection"
        @description "--- Projection ---"
        @tier "presentation"
      drawables : [json] = []
        @label "Drawables"
        @description "--- Scene ---"
        @tier "presentation"
      backgroundImage : asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png", role: "decoration", category: "backgroundImage", animations: ["static"], style: "pixel", dimension: "2d", aspect: "1:1", name: "backgroundImage", thumbnailUrl: "" }
        @label "Background Image"
        @description "Background image (tiled behind iso/hex/flat/free; cover-scaled for atlas slices). A bare URL string is accepted as shorthand for a standalone backdrop."
        @tier "presentation"
      keyMap : Map string string = { item: "Item" }
        @label "Key Map"
        @description "Maps a keydown `e.code` → the board's SEMANTIC event (device-agnostic input)."
        @tier "presentation"
      keyUpMap : Map string string = { item: "Item" }
        @label "Key Up Map"
        @description "Maps a keyup `e.code` → the board's SEMANTIC event."
        @tier "presentation"
      camera : "pan-zoom" | "follow" | "fixed" = "pan-zoom"
        @label "Camera"
        @description "--- View config (pure render) ---"
        @tier "presentation"
      scale : number = 0.4
        @label "Scale"
        @description "Render scale (0.4 = 40% zoom). Ignored by `free`/`side` (world-pixel-direct)."
        @tier "presentation"
      showMinimap : boolean = true
        @label "Show Minimap"
        @description "Toggle minimap overlay."
        @tier "presentation"
      followTarget : Canvas2dFollowTarget = { x: 1, y: 1, z: 1 }
        @label "Follow Target"
        @description "Follow-camera target in scene space (the neutral core `Camera.target`). When `camera:'follow'` the host lerps to keep this point centered."
        @tier "presentation"
      bgColor : string = "Bg Color"
        @label "Bg Color"
        @description "Solid backdrop colour (drawn when no `backgroundImage`)."
        @tier "presentation"
    }
  }

  page "/canvas-2d" as Canvas2dPage -> Canvas2dRender
}
