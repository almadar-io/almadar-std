app ui-trait-slot "1.0.0"
"TraitSlot — UI factory (1:1 with the @almadar/ui trait-slot pattern)."
orbital TraitSlotOrbital {
  type TraitSlotEquippedItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : TraitSlotEquippedItemIconUrl
    stateMachine : json
  }
  type TraitSlotEquippedItemIconUrl = {
    url : asset!
    role : string!
    category : string!
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    variant : string
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    atlas : asset
    sprite : string
    name : string
    thumbnailUrl : string
  }
  type TraitSlotCategoryColorsValue = {
    bg : string!
    border : string!
  }
  type TraitSlotTooltipFrameUrl = {
    url : asset!
    role : string!
    category : string!
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    variant : string
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    atlas : asset
    sprite : string
    name : string
    thumbnailUrl : string
  }
  type TraitSlotError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type TraitSlotITEMDROPItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : TraitSlotITEMDROPItemIconUrl
    stateMachine : json
  }
  type TraitSlotITEMDROPItemIconUrl = {
    url : asset!
    role : string!
    category : string!
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    variant : string
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    atlas : asset
    sprite : string
    name : string
    thumbnailUrl : string
  }
  type TraitSlotDRAGSTARTItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : TraitSlotDRAGSTARTItemIconUrl
    stateMachine : json
  }
  type TraitSlotDRAGSTARTItemIconUrl = {
    url : asset!
    role : string!
    category : string!
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    variant : string
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    atlas : asset
    sprite : string
    name : string
    thumbnailUrl : string
  }

  entity TraitSlotItem [runtime] {
    id : string!
    slotNumber : number = 1
  }

  trait TraitSlotRender -> @rebindable TraitSlotItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.slotNumber @config.slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          onItemDrop: @config.onItemDrop
          draggable: @config.draggable
          onDragStart: @config.onDragStart
          feedback: @config.feedback
          onClick: @config.onClick
          onRemove: @config.onRemove
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          dropEvent: @config.dropEvent
          type: trait-slot
        })
      CLICK -> idle
        (set @entity.slotNumber ?slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          onItemDrop: @config.onItemDrop
          draggable: @config.draggable
          onDragStart: @config.onDragStart
          feedback: @config.feedback
          onClick: @config.onClick
          onRemove: @config.onRemove
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          dropEvent: @config.dropEvent
          type: trait-slot
        })
      REMOVE -> idle
        (set @entity.slotNumber ?slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          onItemDrop: @config.onItemDrop
          draggable: @config.draggable
          onDragStart: @config.onDragStart
          feedback: @config.feedback
          onClick: @config.onClick
          onRemove: @config.onRemove
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          dropEvent: @config.dropEvent
          type: trait-slot
        })
      DROP -> idle
        (set @entity.slotNumber ?slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          onItemDrop: @config.onItemDrop
          draggable: @config.draggable
          onDragStart: @config.onDragStart
          feedback: @config.feedback
          onClick: @config.onClick
          onRemove: @config.onRemove
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          dropEvent: @config.dropEvent
          type: trait-slot
        })
    }

    emits {
      @config.onItemDrop -> external {
        item : TraitSlotITEMDROPItem
      }
        @description "-- Drag and drop --"
        @tier "essential"
      @config.onDragStart -> external {
        item : TraitSlotDRAGSTARTItem
      }
        @description "Called when drag starts from this slot"
        @tier "essential"
      @config.onClick -> external {
        slotNumber : number!
      }
        @description "-- Callbacks --"
        @tier "essential"
      @config.onRemove -> external {
        slotNumber : number!
      }
        @description "Remove handler"
        @tier "essential"
      @config.dropEvent -> external {
        slotNumber : number!
        itemId : string!
      }
        @description "Emits UI:{dropEvent} with { slotNumber, itemId } when an item is dropped into this slot"
        @tier "essential"
    }

    listens {
      CLICK {
        slotNumber : number!
      }
      REMOVE {
        slotNumber : number!
      }
      DROP {
        slotNumber : number!
        itemId : string!
      }
    }

    config {
      slotNumber : number = 1
        @label "Slot Number"
        @description "Slot index (1-based)"
        @tier "presentation"
      equippedItem : TraitSlotEquippedItem
        @label "Equipped Item"
        @description "Currently equipped item, if any"
        @tier "presentation"
      locked : boolean = false
        @label "Locked"
        @description "Whether slot is locked"
        @tier "presentation"
      lockLabel : string
        @label "Lock Label"
        @description "Label shown when locked"
        @tier "presentation"
      selected : boolean = false
        @label "Selected"
        @description "Whether slot is selected"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      showTooltip : boolean = true
        @label "Show Tooltip"
        @description "Show tooltip on hover"
        @tier "presentation"
      categoryColors : Map string TraitSlotCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
      tooltipFrameUrl : TraitSlotTooltipFrameUrl
        @label "Tooltip Frame Url"
        @description "Optional tooltip frame image asset"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : TraitSlotError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      onItemDrop : string = "ITEM_DROP"
        @label "On Item Drop"
        @description "-- Drag and drop --"
        @tier "presentation"
      draggable : boolean = false
        @label "Draggable"
        @description "Whether this slot's equipped item is draggable"
        @tier "presentation"
      onDragStart : string = "DRAG_START"
        @label "On Drag Start"
        @description "Called when drag starts from this slot"
        @tier "presentation"
      feedback : "correct" | "wrong" = correct
        @label "Feedback"
        @description "Per-slot correctness feedback after a failed attempt"
        @tier "presentation"
      onClick : string = "CLICK"
        @label "On Click"
        @description "-- Callbacks --"
        @tier "presentation"
      onRemove : string = "REMOVE"
        @label "On Remove"
        @description "Remove handler"
        @tier "presentation"
      clickEvent : string = "CLICK"
        @label "Click Event"
        @description "-- Declarative events --"
        @tier "presentation"
      removeEvent : string = "REMOVE"
        @label "Remove Event"
        @description "Emits UI:{removeEvent} with { slotNumber }"
        @tier "presentation"
      dropEvent : string = "DROP"
        @label "Drop Event"
        @description "Emits UI:{dropEvent} with { slotNumber, itemId } when an item is dropped into this slot"
        @tier "presentation"
    }
  }

  page "/trait-slot" as TraitSlotPage -> TraitSlotRender
}
