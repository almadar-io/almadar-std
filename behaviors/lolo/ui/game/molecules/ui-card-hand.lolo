app ui-card-hand "1.0.0"
"CardHand — UI factory (1:1 with the @almadar/ui card-hand pattern)."
orbital CardHandOrbital {
  type CardHandCardsItem = {
    id : string!
    iconUrl : asset
    title : string
    cost : number
    attack : number
    defense : number
    disabled : boolean
  }

  entity CardHandItem [runtime] {
    id : string!
  }

  trait CardHandRender -> @rebindable CardHandItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          cards: @config.cards
          selectedId: @config.selectedId
          size: @config.size
          onCardClick: CARD_CLICK
          cardClickEvent: CARD_CLICK
          emptyLabel: @config.emptyLabel
          className: @config.className
          type: card-hand
        })
    }

    emits {
      CARD_CLICK -> external {
        id : string
        cardId : string!
      }
        @description "Direct callback when a (non-disabled) card is clicked."
        @tier "essential"
    }

    config {
      cards : [CardHandCardsItem] = [{ id: "Id", iconUrl: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/default/cards/bear.png", title: "Bear", cost: 1, attack: 1, defense: 1, disabled: false }, { id: "Id 2", iconUrl: "https://almadar-kflow-assets.web.app/shared/ui-card-battler-board/default/cards/owl.png", title: "Owl", cost: 2, attack: 2, defense: 2, disabled: true }]
        @label "Cards"
        @description "Cards to lay out as a horizontal hand (or grid when wrapped)."
        @tier "presentation"
      selectedId : string = "Selected Id"
        @label "Selected Id"
        @description "Currently selected card id."
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Card-art size variant."
        @tier "presentation"
      emptyLabel : string = "No cards in hand"
        @label "Empty Label"
        @description "Empty-state label when there are no cards."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/card-hand" as CardHandPage -> CardHandRender
}
