app ui-battle-template "1.0.0"
"BattleTemplate — UI factory (1:1 with the @almadar/ui battle-template pattern)."
orbital BattleTemplateOrbital {
  type BattleTemplateTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type BattleTemplateUnitsItem = {
    id : string!
    position : BattleTemplateUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : json
    spriteSheet : json
    modelUrl : json
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [BattleTemplateUnitsItemTraitsItem]
    previousPosition : BattleTemplateUnitsItemPreviousPosition
    elevation : number
  }
  type BattleTemplateUnitsItemPosition = {
    x : number!
    y : number!
  }
  type BattleTemplateUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type BattleTemplateUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type BattleTemplateFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : json
    assetUrl : json
    color : string
    elevation : number
  }

  entity BattleTemplateItem [runtime] {
    id : string!
  }

  trait BattleTemplateRender -> @rebindable BattleTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch BattleTemplateItem {})
        (render-ui main {
          entity: @entity
          className: @config.className
          scale: @config.scale
          unitScale: @config.unitScale
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          assetManifest: @config.assetManifest
          type: battle-template
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      tiles : [BattleTemplateTilesItem] = [{ x: 0, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 1, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 2, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 3, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 4, y: 0, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 0, y: 1, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 1, y: 1, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/dirtTiles_E.png" }, { x: 2, y: 1, terrain: "planks", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/planks_E.png" }, { x: 3, y: 1, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/dirt_E.png" }, { x: 4, y: 1, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 0, y: 2, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 1, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/dirt_E.png" }, { x: 2, y: 2, terrain: "stairs", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stairs_E.png" }, { x: 3, y: 2, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/dirt_E.png" }, { x: 4, y: 2, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 0, y: 3, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 1, y: 3, terrain: "planks", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/planks_E.png" }, { x: 2, y: 3, terrain: "dirt", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/dirtTiles_E.png" }, { x: 3, y: 3, terrain: "grass", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/dirt_E.png" }, { x: 4, y: 3, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 0, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 1, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 2, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }, { x: 3, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneInset_E.png" }, { x: 4, y: 4, terrain: "stone", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/stoneTile_E.png" }]
        @label "Tiles"
        @description "Direct tile data — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
      units : [BattleTemplateUnitsItem] = [{ id: "u1", position: { x: 1, y: 1 }, unitType: "amir", name: "Amir", team: player, health: 10, maxHealth: 10, spriteSheet: "https://almadar-kflow-assets.web.app/shared/units/chars-roguelike/trait-wars/sprite-sheets/amir-sprite-sheet-se.png" }, { id: "u2", position: { x: 3, y: 3 }, unitType: "guardian", name: "Guardian", team: enemy, health: 8, maxHealth: 10, spriteSheet: "https://almadar-kflow-assets.web.app/shared/units/chars-roguelike/trait-wars/sprite-sheets/shadow-legion-sprite-sheet-se.png" }]
        @label "Units"
        @description "Direct unit data — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
      features : [BattleTemplateFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "chest", sprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/chestClosed_E.png" }, { id: "f2", x: 3, y: 1, type: "barrel", sprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/trait-wars/iso/medieval/barrel_E.png" }]
        @label "Features"
        @description "Direct feature data — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
      assetManifest : string = ""
        @label "Asset Manifest"
        @description "Direct asset manifest — forwarded to BattleBoard; takes priority over entity."
        @tier "presentation"
    }
  }

  page "/battle-template" as BattleTemplatePage -> BattleTemplateRender
}
