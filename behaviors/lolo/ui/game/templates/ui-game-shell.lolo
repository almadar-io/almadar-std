app ui-game-shell "1.0.0"
"GameShell — UI factory (1:1 with the @almadar/ui game-shell pattern)."
orbital GameShellOrbital {
  type GameShellBackgroundAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }
  type GameShellHudBackgroundAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity GameShellItem [runtime] {
    id : string!
  }

  trait GameShellRender -> @rebindable GameShellItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          appName: @config.appName
          hud: @config.hud
          addons: @config.addons
          controls: @config.controls
          overlay: @config.overlay
          className: @config.className
          showTopBar: @config.showTopBar
          children: @config.children
          backgroundAsset: @config.backgroundAsset
          hudBackgroundAsset: @config.hudBackgroundAsset
          fontFamily: @config.fontFamily
          type: game-shell
        })
    }

    config {
      appName : string = Game
        @label "App Name"
        @description "Application / game title shown as a floating chip"
        @tier "presentation"
      hud : node
        @label "Hud"
        @description "Stat chips row — floats along the top edge"
        @tier "presentation"
      addons : node
        @label "Addons"
        @description "Action cluster — floats bottom-right (End Turn, Fire, Reset, …)"
        @tier "presentation"
      controls : node
        @label "Controls"
        @description "Movement controls — floats bottom-left (d-pad / control-grid)."
        @tier "presentation"
      overlay : node
        @label "Overlay"
        @description "Centered overlay layer (victory/defeat banners, dialogs)."
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Extra class name on the root container"
        @tier "presentation"
      showTopBar : boolean = true
        @label "Show Top Bar"
        @description "Whether to show the title chip (default: true)"
        @tier "presentation"
      children : node = [{ type: canvas-2d }]
        @label "Children"
        @description "Game content — fills the whole surface underneath the overlays"
        @tier "presentation"
      backgroundAsset : GameShellBackgroundAsset
        @label "Background Asset"
        @description "Pattern slice tiled at low opacity across the surface (never cover-stretched)."
        @tier "presentation"
      hudBackgroundAsset : GameShellHudBackgroundAsset
        @label "Hud Background Asset"
        @description "9-sliced panel skin for the HUD chips row + title chip."
        @tier "presentation"
      fontFamily : string = future
        @label "Font Family"
        @description "Game font key (future | future-narrow | pixel | blocks | mini) or a CSS font-family."
        @tier "presentation"
    }
  }

  page "/game-shell" as GameShellPage -> GameShellRender
}
