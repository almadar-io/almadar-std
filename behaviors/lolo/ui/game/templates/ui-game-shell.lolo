app ui-game-shell "1.0.0"
"GameShell — full-viewport game layout; hud + children are config-driven."
orbital GameShellOrbital {
  type GameShellHudItem = {
    type : string
    label : string
    value : number
    max : number
    format : string
    variant : string
  }
  type GameShellCanvasItem = {
    type : string
  }

  entity GameShellItem [runtime] {
    id : string!
  }

  trait GameShellRender -> @rebindable GameShellItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          appName: @config.appName
          hud: @config.hud
          className: @config.className
          showTopBar: @config.showTopBar
          children: @config.children
          type: game-shell
        })
    }

    config {
      appName : string = Game
        @label "App Name"
        @description "Application / game title shown in the HUD bar"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Extra class name on the root container"
        @tier "presentation"
      showTopBar : boolean = true
        @label "Show Top Bar"
        @description "Whether to show the minimal top bar (default: true)"
        @tier "presentation"
      hud : [GameShellHudItem] = [{ type: "stat-badge", label: "HP", value: 100, max: 100, format: "bar", variant: "danger" }, { type: "stat-badge", label: "Score", value: 0, format: "number", variant: "warning" }]
        @label "HUD Items"
        @description "HUD stat badges rendered in the top bar; each item is a StatBadge descriptor"
        @tier "presentation"
      children : [GameShellCanvasItem] = [{ type: "game-canvas-2d" }]
        @label "Children"
        @description "Main game content; defaults to a 2D isometric canvas"
        @tier "presentation"
    }
  }

  page "/game-shell" as GameShellPage -> GameShellRender
}
