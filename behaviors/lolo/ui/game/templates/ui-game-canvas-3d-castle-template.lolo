app ui-game-canvas-3d-castle-template "1.0.0"
"GameCanvas3dCastleTemplate — UI factory (1:1 with the @almadar/ui game-canvas-3d-castle-template pattern)."
orbital GameCanvas3dCastleTemplateOrbital {
    type GameCanvas3dCastleTemplateLoaded = Event { data : [GameCanvas3dCastleTemplateItem] } "GameCanvas3dCastleTemplate rows finished loading; payload.data holds the collection"
  type GameCanvas3dCastleTemplateTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type GameCanvas3dCastleTemplateFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : json
    assetUrl : json
    color : string
    elevation : number
  }
  type GameCanvas3dCastleTemplateAssetManifest = {
    baseUrl : asset
    models : Map string asset
    features : Map string asset
  }

  entity GameCanvas3dCastleTemplateItem [runtime] {
    id : string!
  }

  trait GameCanvas3dCastleTemplateRender -> @rebindable GameCanvas3dCastleTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch GameCanvas3dCastleTemplateItem { emit: { success: GameCanvas3dCastleTemplateLoaded } })
        (render-ui main {
          entity: @entity
          className: @config.className
          tiles: @config.tiles
          features: @config.features
          assetManifest: @config.assetManifest
          cameraMode: @config.cameraMode
          showGrid: @config.showGrid
          shadows: @config.shadows
          backgroundColor: @config.backgroundColor
          buildingClickEvent: @config.buildingClickEvent
          unitClickEvent: @config.unitClickEvent
          endTurnEvent: @config.endTurnEvent
          cancelEvent: @config.cancelEvent
          attackEvent: @config.attackEvent
          playAgainEvent: @config.playAgainEvent
          gameEndEvent: @config.gameEndEvent
          buildEvent: @config.buildEvent
          recruitEvent: @config.recruitEvent
          exitEvent: @config.exitEvent
          showHeader: @config.showHeader
          unitScale: @config.unitScale
          scale: @config.scale
          type: game-canvas-3d-castle-template
        })
      GameCanvas3dCastleTemplateLoaded -> idle
        (render-ui main {
          entity: @payload.data
          className: @config.className
          tiles: @config.tiles
          features: @config.features
          assetManifest: @config.assetManifest
          cameraMode: @config.cameraMode
          showGrid: @config.showGrid
          shadows: @config.shadows
          backgroundColor: @config.backgroundColor
          buildingClickEvent: @config.buildingClickEvent
          unitClickEvent: @config.unitClickEvent
          endTurnEvent: @config.endTurnEvent
          cancelEvent: @config.cancelEvent
          attackEvent: @config.attackEvent
          playAgainEvent: @config.playAgainEvent
          gameEndEvent: @config.gameEndEvent
          buildEvent: @config.buildEvent
          recruitEvent: @config.recruitEvent
          exitEvent: @config.exitEvent
          showHeader: @config.showHeader
          unitScale: @config.unitScale
          scale: @config.scale
          type: game-canvas-3d-castle-template
        })
    }

    emits {
      GameCanvas3dCastleTemplateLoaded
        @description "GameCanvas3dCastleTemplate rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      tiles : [GameCanvas3dCastleTemplateTilesItem] = [{ x: 0, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 2, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 3, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 4, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 1, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 1, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail.glb" }, { x: 2, y: 1, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor.glb" }, { x: 3, y: 1, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor.glb" }, { x: 4, y: 1, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 2, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 2, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor.glb" }, { x: 2, y: 2, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail.glb" }, { x: 3, y: 2, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor.glb" }, { x: 4, y: 2, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 3, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 3, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor.glb" }, { x: 2, y: 3, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor.glb" }, { x: 3, y: 3, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail.glb" }, { x: 4, y: 3, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 0, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 1, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 2, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 3, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }, { x: 4, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/floor/template-floor-detail-a.glb" }]
        @label "Tiles"
        @description "Fallback tile data when no entity is present (layout only — model URLs resolve from assetManifest)"
        @tier "presentation"
      features : [GameCanvas3dCastleTemplateFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", assetUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/medieval/props/barrels.glb" }, { id: "f2", x: 3, y: 1, type: "portal", assetUrl: "https://almadar-kflow-assets.web.app/shared/3d/tiles-iso-medieval/trait-wars/environments/dungeon/gates/gate-door.glb" }]
        @label "Features"
        @description "Fallback feature data when no entity is present"
        @tier "presentation"
      assetManifest : GameCanvas3dCastleTemplateAssetManifest
        @label "Asset Manifest"
        @description "GLB model URLs keyed by terrain — owns all asset choice (no hardcoded URLs in this template)."
        @tier "presentation"
      cameraMode : "isometric" | "perspective" | "top-down" = isometric
        @label "Camera Mode"
        @description "3D camera mode"
        @tier "presentation"
      showGrid : boolean = false
        @label "Show Grid"
        @description "Show grid helper"
        @tier "presentation"
      shadows : boolean = false
        @label "Shadows"
        @description "Enable shadows"
        @tier "presentation"
      backgroundColor : string = "#1e1e2e"
        @label "Background Color"
        @description "Background color"
        @tier "presentation"
      buildingClickEvent : string = "Building Click Event"
        @label "Building Click Event"
        @description "Event name for building (feature) clicks"
        @tier "presentation"
      unitClickEvent : string = "Unit Click Event"
        @label "Unit Click Event"
        @description "Event name for unit clicks"
        @tier "presentation"
      endTurnEvent : string = "End Turn Event"
        @label "End Turn Event"
        @description "Event name for ending turn"
        @tier "presentation"
      cancelEvent : string = "Cancel Event"
        @label "Cancel Event"
        @description "Event name for cancel/deselect"
        @tier "presentation"
      attackEvent : string = "Attack Event"
        @label "Attack Event"
        @description "Event name for attack emission"
        @tier "presentation"
      playAgainEvent : string = "Play Again Event"
        @label "Play Again Event"
        @description "Event name for play again / reset"
        @tier "presentation"
      gameEndEvent : string = "Game End Event"
        @label "Game End Event"
        @description "Event name for game end detection"
        @tier "presentation"
      buildEvent : string = "Build Event"
        @label "Build Event"
        @description "Event name for build action"
        @tier "presentation"
      recruitEvent : string = "Recruit Event"
        @label "Recruit Event"
        @description "Event name for recruit action"
        @tier "presentation"
      exitEvent : string = "Exit Event"
        @label "Exit Event"
        @description "Event name for exit"
        @tier "presentation"
      showHeader : boolean = true
        @label "Show Header"
        @description "Show castle name header"
        @tier "presentation"
      unitScale : number = 0
        @label "Unit Scale"
        @description "Unit draw-size multiplier forwarded to GameBoard3D. Default 1."
        @tier "presentation"
      scale : number = 0
        @label "Scale"
        @description "Board zoom/group scale forwarded to GameBoard3D. Default 0.45."
        @tier "presentation"
    }
  }

  page "/game-canvas-3d-castle-template" as GameCanvas3dCastleTemplatePage -> GameCanvas3dCastleTemplateRender
}
