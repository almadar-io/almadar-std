        @label "Tiles"
        @description "6×6 S-shaped fairway grid — takes priority over entity-derived tiles."
        @tier "presentation"
      units : [MinigolfBoard3DUnitsItem] = [{ id: "ball", position: { x: 0, y: 0 }, unitType: "ball", name: "Ball", team: player, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/features/ball-blue.glb", role: "player", category: "features", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "ball-blue", thumbnailUrl: "" } }]
        @label "Units"
        @description "The putting ball, starting at the tee (t00)."
        @tier "presentation"
      features : [MinigolfBoard3DFeaturesItem] = [{ id: "f1", x: 5, y: 5, type: "flag", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/features/flag-red.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "flag-red", thumbnailUrl: "" } }, { id: "f2", x: 0, y: 1, type: "peg_wall", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/features/supports.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "supports", thumbnailUrl: "" } }, { id: "f3", x: 5, y: 3, type: "peg_wall", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/features/supports.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "supports", thumbnailUrl: "" } }]
        @label "Features"
        @description "Pin flag at the hole plus wooden peg-wall borders along the rough."
        @tier "presentation"
      par : number = 8
        @label "Par"
        @description "Stroke target — holing out at or under this value wins"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
    }
  }

