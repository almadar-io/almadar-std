"straight", thumbnailUrl: "" } }, { id: "t52", x: 5, y: 2, terrain: "fairway", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/terrain/corner.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "corner", thumbnailUrl: "" } }, { id: "t03", x: 0, y: 3, terrain: "fairway", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/terrain/straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "straight", thumbnailUrl: "" } }, { id: "t13", x: 1, y: 3, terrain: "obstacle", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/terrain/block.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "block", thumbnailUrl: "" } }, { id: "t23", x: 2, y: 3, terrain: "obstacle", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/terrain/block.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "block", thumbnailUrl: "" } }, { id: "t33", x: 3, y: 3, terrain: "obstacle", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/features/castle.glb", role: "tile", category: "features", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "castle", thumbnailUrl: "" } }, { id: "t43", x: 4, y: 3, terrain: "obstacle", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-minigolf-board-3d/kenney-minigolf-kit/terrain/block.glb", role: "tile", category