app ui-toy-track-board-3d "1.0.0"
"ToyTrackBoard3D — throttled keyboard/d-pad toy race on a multi-lap 6x6 loop; collect coins, follow camera, ticking rival."
orbital ToyTrackBoard3DOrbital {
  type ToyTrackBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type ToyTrackBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    order : number
    modelUrl : Asset
  }
  type ToyTrackBoard3DUnitsItem = {
    id : string!
    position : ToyTrackBoard3DUnitsItemPosition
    unitType : string
    name : string
    team : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    modelUrl : Asset
  }
  type ToyTrackBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type ToyTrackBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type ToyTrackBoard3DEffectItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity ToyTrackBoard3DItem [runtime] {
    id : string!
    units : [ToyTrackBoard3DUnitsItem]
    features : [ToyTrackBoard3DFeaturesItem]
    selectedUnitId : string = "player-car"
    playerProgress : number = 0
    rivalProgress : number = 0
    trackLength : number = 20
    lap : number = 1
    score : number = 0
    canAdvance : boolean = true
    result : "none" | "victory" | "defeat" = "none"
    gridWidth : number = 6
    gridHeight : number = 6
    fx : [ToyTrackBoard3DEffectItem] = []
  }

  trait ToyTrackBoard3DRender -> @rebindable ToyTrackBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.playerProgress 0)
        (set @entity.rivalProgress 0)
        (set @entity.trackLength 20)
        (set @entity.lap 1)
        (set @entity.score 0)
        (set @entity.canAdvance true)
        (set @entity.gridWidth 6)
        (set @entity.gridHeight 6)
        (set @entity.result "none")
        (set @entity.selectedUnitId "player-car")
        (set @entity.fx [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: (str/concat @entity.lap "/" @config.totalLaps) }, { label: "Score", value: @entity.score }, { label: "Result", value: @entity.result } ] }, { type: control-grid, kind: "dpad", directionEvents: { up: "ACCELERATE" } } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, tiles: @config.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, cameraMode: "follow", keyMap: { ArrowUp: "ACCELERATE", KeyW: "ACCELERATE", Space: "ACCELERATE" } } ]
        })

      ACCELERATE -> playing when (and (== @entity.canAdvance true) (== @entity.result "none"))
        (let ((nextOrder (% (+ @entity.playerProgress 1) @entity.trackLength))) (let ((target (array/find @config.tiles (fn t (== (object/get @t order) @nextOrder))))) (let ((coinHit (array/find @entity.features (fn f (and (== (object/get @f type) "coin") (and (== (object/get @f x) (object/get @target x)) (== (object/get @f y) (object/get @target y)))))))) (do
          (set @entity.units (array/map @entity.units (fn u (if (== @u.id "player-car") (object/merge @u { position: { x: (object/get @target x), y: (object/get @target y) } }) @u))))
          (set @entity.features (if (!= @coinHit null) (array/filter @entity.features (fn f (or (!= (object/get @f type) "coin") (or (!= (object/get @f x) (object/get @target x)) (!= (object/get @f y) (object/get @target y)))))) @entity.features))
          (set @entity.score (if (!= @coinHit null) (+ @entity.score 5) @entity.score))
          (set @entity.playerProgress (+ @entity.playerProgress 1))
          (set @entity.canAdvance false)
          (set @entity.lap (+ (math/floor (/ @entity.playerProgress @entity.trackLength)) 1))
          (set @entity.fx (if (!= @coinHit null) (array/append @entity.fx { id: (str/concat "pickup-" @entity.playerProgress), type: "pickup", x: (object/get @target x), z: (object/get @target y), message: "+5", ttl: 5 }) @entity.fx))
          (set @entity.fx (if (== (% @entity.playerProgress @entity.trackLength) 0) (array/append @entity.fx { id: (str/concat "lap-" @entity.playerProgress), type: "score", x: 0, z: 0, message: "Lap!", ttl: 5 }) @entity.fx))
          (set @entity.result (if (>= @entity.playerProgress (* @config.totalLaps @entity.trackLength)) "victory" @entity.result))
          (set @entity.fx (if (!= @entity.result "none") (array/append @entity.fx { id: "result-fx", type: (if (== @entity.result "victory") "win" "lose"), x: 0, z: 0, message: (if (== @entity.result "victory") "You Win!" "You Lose!"), ttl: 999 }) @entity.fx))
        ))))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: (str/concat @entity.lap "/" @config.totalLaps) }, { label: "Score", value: @entity.score }, { label: "Result", value: @entity.result } ] }, { type: control-grid, kind: "dpad", directionEvents: { up: "ACCELERATE" } } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, tiles: @config.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, cameraMode: "follow", keyMap: { ArrowUp: "ACCELERATE", KeyW: "ACCELERATE", Space: "ACCELERATE" } } ]
        })

      PLAY_AGAIN -> playing when (!= @entity.result "none")
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.playerProgress 0)
        (set @entity.rivalProgress 0)
        (set @entity.trackLength 20)
        (set @entity.lap 1)
        (set @entity.score 0)
        (set @entity.canAdvance true)
        (set @entity.gridWidth 6)
        (set @entity.gridHeight 6)
        (set @entity.result "none")
        (set @entity.selectedUnitId "player-car")
        (set @entity.fx [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: (str/concat @entity.lap "/" @config.totalLaps) }, { label: "Score", value: @entity.score }, { label: "Result", value: @entity.result } ] }, { type: control-grid, kind: "dpad", directionEvents: { up: "ACCELERATE" } } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, tiles: @config.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, cameraMode: "follow", keyMap: { ArrowUp: "ACCELERATE", KeyW: "ACCELERATE", Space: "ACCELERATE" } } ]
        })
    }

    ticks {
      paceTick every 400ms
        when (== @entity.result "none")
        (set @entity.canAdvance true)
        (set @entity.fx (array/filter (array/map @entity.fx (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))

      rivalAdvanceTick every 1200ms
        when (== @entity.result "none")
        (let ((nextOrder (% (+ @entity.rivalProgress 1) @entity.trackLength))) (let ((target (array/find @config.tiles (fn t (== (object/get @t order) @nextOrder))))) (do (set @entity.rivalProgress (+ @entity.rivalProgress 1)) (set @entity.units (array/map @entity.units (fn u (if (== @u.id "rival-car") (object/merge @u { position: { x: (object/get @target x), y: (object/get @target y) } }) @u)))) (set @entity.result (if (>= @entity.rivalProgress (* @config.totalLaps @entity.trackLength)) "defeat" @entity.result)) (set @entity.fx (if (!= @entity.result "none") (array/append @entity.fx { id: "result-fx", type: (if (== @entity.result "victory") "win" "lose"), x: 0, z: 0, message: (if (== @entity.result "victory") "You Win!" "You Lose!"), ttl: 999 }) @entity.fx)))))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Lap", value: (str/concat @entity.lap "/" @config.totalLaps) }, { label: "Score", value: @entity.score }, { label: "Result", value: @entity.result } ] }, { type: control-grid, kind: "dpad", directionEvents: { up: "ACCELERATE" } } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, tiles: @config.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, cameraMode: "follow", keyMap: { ArrowUp: "ACCELERATE", KeyW: "ACCELERATE", Space: "ACCELERATE" } } ]
        })
    }

    emits {
      ACCELERATE -> external {
        id : string
      }
        @description "Accelerate intent (keyboard keyMap or d-pad directionEvents) — advances one track cell when paced, collecting a coin if present"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Called when the lap race ends"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : ToyTrackBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      totalLaps : number = 2
        @label "Total Laps"
        @description "Laps around the loop required to win"
        @tier "presentation"
      tiles : [ToyTrackBoard3DTilesItem] = [{ id: "t20", x: 2, y: 0, terrain: "track", passable: true, order: 0, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t30", x: 3, y: 0, terrain: "track", passable: true, order: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t40", x: 4, y: 0, terrain: "track", passable: true, order: 2, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t50", x: 5, y: 0, terrain: "track", passable: true, order: 3, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t51", x: 5, y: 1, terrain: "track", passable: true, order: 4, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t52", x: 5, y: 2, terrain: "track", passable: true, order: 5, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t53", x: 5, y: 3, terrain: "track", passable: true, order: 6, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t54", x: 5, y: 4, terrain: "track", passable: true, order: 7, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t55", x: 5, y: 5, terrain: "track", passable: true, order: 8, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t45", x: 4, y: 5, terrain: "track", passable: true, order: 9, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t35", x: 3, y: 5, terrain: "track", passable: true, order: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t25", x: 2, y: 5, terrain: "track", passable: true, order: 11, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t15", x: 1, y: 5, terrain: "track", passable: true, order: 12, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t05", x: 0, y: 5, terrain: "track", passable: true, order: 13, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t04", x: 0, y: 4, terrain: "track", passable: true, order: 14, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t03", x: 0, y: 3, terrain: "track", passable: true, ord