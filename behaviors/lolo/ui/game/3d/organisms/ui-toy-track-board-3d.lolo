        @label "Tiles"
        @description "6x6 track loop — 20 outer track cells (order 0-19) plus 16 impassable infield cells."
        @tier "presentation"
      units : [ToyTrackBoard3DUnitsItem] = [{ id: "player-car", position: { x: 2, y: 0 }, unitType: "racer", name: "Player Car", team: player, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/units/vehicle-drag-racer.glb", role: "player", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "vehicle-drag-racer", thumbnailUrl: "" } }, { id: "rival-car", position: { x: 0, y: 0 }, unitType: "monster-truck", name: "Rival Car", team: enemy, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/units/vehicle-monster-truck.glb", role: "enemy", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "vehicle-monster-truck", thumbnailUrl: "" } }]
