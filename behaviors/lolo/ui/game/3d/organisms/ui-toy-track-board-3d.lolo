app ui-toy-track-board-3d "1.0.0"
"ToyTrackBoard3D — toy car race on a 6x6 track loop; click to advance, rival ticks, lap completion wins."
orbital ToyTrackBoard3DOrbital {
  type ToyTrackBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type ToyTrackBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    order : number
    modelUrl : Asset
  }
  type ToyTrackBoard3DUnitsItem = {
    id : string!
    position : ToyTrackBoard3DUnitsItemPosition
    unitType : string
    name : string
    team : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    modelUrl : Asset
  }
  type ToyTrackBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type ToyTrackBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type ToyTrackBoard3DValidMovesItem = {
    x : number!
    z : number!
  }
  type ToyTrackBoard3DAttackTargetsItem = {
    x : number!
    z : number!
  }

  entity ToyTrackBoard3DItem [runtime] {
    id : string!
    units : [ToyTrackBoard3DUnitsItem]
    validMoves : [ToyTrackBoard3DValidMovesItem]
    attackTargets : [ToyTrackBoard3DAttackTargetsItem]
    selectedUnitId : string = ""
    playerProgress : number = 0
    rivalProgress : number = 0
    trackLength : number = 20
    result : "none" | "victory" | "defeat" = "none"
    gridWidth : number = 6
    gridHeight : number = 6
  }

  trait ToyTrackBoard3DRender -> @rebindable ToyTrackBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.playerProgress 0)
        (set @entity.rivalProgress 0)
        (set @entity.trackLength 20)
        (set @entity.gridWidth 6)
        (set @entity.gridHeight 6)
        (set @entity.result "none")
        (set @entity.selectedUnitId "")
        (set @entity.attackTargets [])
        (set @entity.validMoves (array/map (array/filter @config.tiles (fn t (== (object/get @t order) (% (+ @entity.playerProgress 1) @entity.trackLength)))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Progress", value: @entity.playerProgress }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      TILE_CLICK -> playing when (and (== @entity.result "none") (let ((target (array/find @config.tiles (fn t (and (== (object/get @t x) ?x) (== (object/get @t y) ?z)))))) (and (!= @target null) (and (== (object/get @target passable) true) (== (object/get @target order) (% (+ @entity.playerProgress 1) @entity.trackLength))))))
        (set @entity.playerProgress (+ @entity.playerProgress 1))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id "player-car") (object/merge @u { position: { x: ?x, y: ?z } }) @u))))
        (set @entity.result (if (>= @entity.playerProgress @entity.trackLength) "victory" @entity.result))
        (set @entity.validMoves (array/map (array/filter @config.tiles (fn t (== (object/get @t order) (% (+ @entity.playerProgress 1) @entity.trackLength)))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Progress", value: @entity.playerProgress }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    ticks {
      rivalAdvanceTick every 1200ms
        when (== @entity.result "none")
        (let ((nextOrder (% (+ @entity.rivalProgress 1) @entity.trackLength))) (let ((target (array/find @config.tiles (fn t (== (object/get @t order) @nextOrder))))) (do (set @entity.rivalProgress (+ @entity.rivalProgress 1)) (set @entity.units (array/map @entity.units (fn u (if (== @u.id "rival-car") (object/merge @u { position: { x: (object/get @target x), y: (object/get @target y) } }) @u)))) (set @entity.result (if (>= @entity.rivalProgress @entity.trackLength) "defeat" @entity.result)))))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beige.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "panel", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panelInset_beigeLight.png", role: "ui", category: "ui", animations: [], style: "vector-flat", variant: "", dimension: "2d", aspect: "1:1", name: "hud-panel", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Progress", value: @entity.playerProgress }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        z : number!
        tileId : string
      }
        @description "Player advances to the next track cell along the loop"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : ToyTrackBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [ToyTrackBoard3DTilesItem] = [{ id: "t20", x: 2, y: 0, terrain: "track", passable: true, order: 0, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t30", x: 3, y: 0, terrain: "track", passable: true, order: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t40", x: 4, y: 0, terrain: "track", passable: true, order: 2, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t50", x: 5, y: 0, terrain: "track", passable: true, order: 3, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t51", x: 5, y: 1, terrain: "track", passable: true, order: 4, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t52", x: 5, y: 2, terrain: "track", passable: true, order: 5, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t53", x: 5, y: 3, terrain: "track", passable: true, order: 6, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t54", x: 5, y: 4, terrain: "track", passable: true, order: 7, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t55", x: 5, y: 5, terrain: "track", passable: true, order: 8, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t45", x: 4, y: 5, terrain: "track", passable: true, order: 9, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t35", x: 3, y: 5, terrain: "track", passable: true, order: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t25", x: 2, y: 5, terrain: "track", passable: true, order: 11, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t15", x: 1, y: 5, terrain: "track", passable: true, order: 12, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t05", x: 0, y: 5, terrain: "track", passable: true, order: 13, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t04", x: 0, y: 4, terrain: "track", passable: true, order: 14, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t03", x: 0, y: 3, terrain: "track", passable: true, order: 15, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t02", x: 0, y: 2, terrain: "track", passable: true, order: 16, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t01", x: 0, y: 1, terrain: "track", passable: true, order: 17, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t00", x: 0, y: 0, terrain: "track", passable: true, order: 18, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-corner-small.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-corner-small", thumbnailUrl: "" } }, { id: "t10", x: 1, y: 0, terrain: "track", passable: true, order: 19, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/track-striped-narrow-straight.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "track-striped-narrow-straight", thumbnailUrl: "" } }, { id: "t11", x: 1, y: 1, terrain: "infield", passable: false, order: -1 }, { id: "t21", x: 2, y: 1, terrain: "infield", passable: false, order: -1 }, { id: "t31", x: 3, y: 1, terrain: "infield", passable: false, order: -1 }, { id: "t41", x: 4, y: 1, terrain: "infield", passable: false, order: -1 }, { id: "t12", x: 1, y: 2, terrain: "infield", passable: false, order: -1 }, { id: "t22", x: 2, y: 2, terrain: "infield", passable: false, order: -1 }, { id: "t32", x: 3, y: 2, terrain: "infield", passable: false, order: -1 }, { id: "t42", x: 4, y: 2, terrain: "infield", passable: false, order: -1 }, { id: "t13", x: 1, y: 3, terrain: "infield", passable: false, order: -1 }, { id: "t23", x: 2, y: 3, terrain: "infield", passable: false, order: -1 }, { id: "t33", x: 3, y: 3, terrain: "infield", passable: false, order: -1 }, { id: "t43", x: 4, y: 3, terrain: "infield", passable: false, order: -1 }, { id: "t14", x: 1, y: 4, terrain: "infield", passable: false, order: -1 }, { id: "t24", x: 2, y: 4, terrain: "infield", passable: false, order: -1 }, { id: "t34", x: 3, y: 4, terrain: "infield", passable: false, order: -1 }, { id: "t44", x: 4, y: 4, terrain: "infield", passable: false, order: -1 }]
        @label "Tiles"
        @description "6x6 track loop — 20 outer track cells (order 0-19) plus 16 impassable infield cells."
        @tier "presentation"
      units : [ToyTrackBoard3DUnitsItem] = [{ id: "player-car", position: { x: 2, y: 0 }, unitType: "racer", name: "Player Car", team: player, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/units/vehicle-drag-racer.glb", role: "player", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "vehicle-drag-racer", thumbnailUrl: "" } }, { id: "rival-car", position: { x: 0, y: 0 }, unitType: "monster-truck", name: "Rival Car", team: enemy, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/units/vehicle-monster-truck.glb", role: "enemy", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "vehicle-monster-truck", thumbnailUrl: "" } }]
        @label "Units"
        @description "Player car (start/finish) and rival car, one cell behind."
        @tier "presentation"
      features : [ToyTrackBoard3DFeaturesItem] = [{ id: "f-finish", x: 2, y: 0, type: "finish_gate", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/gate-finish.glb", role: "decoration", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gate-finish", thumbnailUrl: "" } }, { id: "f-halfway", x: 3, y: 5, type: "gate", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/terrain/gate.glb", role: "decoration", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gate", thumbnailUrl: "" } }, { id: "f-tree1", x: 1, y: 1, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/features/tree-pine.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tree-pine", thumbnailUrl: "" } }, { id: "f-tree2", x: 4, y: 1, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-toy-car-kit/features/tree.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tree", thumbnailUrl: "" } }, { id: "f-tree3", x: 2, y: 2, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-coaster-kit/features/tree.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tree", thumbnailUrl: "" } }, { id: "f-bench", x: 3, y: 2, type: "bench", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-toy-track-board-3d/kenney-coaster-kit/features/bench.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bench", t