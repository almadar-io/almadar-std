app ui-game-board-3d "1.0.0"
"GameBoard3D — 3D tactics board: select, move, attack, end turn, AI turn, restart loop."
orbital GameBoard3DOrbital {
  type GameBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type GameBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type GameBoard3DUnitsItem = {
    id : string!
    position : GameBoard3DUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [GameBoard3DUnitsItemTraitsItem]
    previousPosition : GameBoard3DUnitsItemPreviousPosition
    elevation : number
  }
  type GameBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type GameBoard3DUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type GameBoard3DUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type GameBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type GameBoard3DValidMovesItem = {
    x : number!
    z : number!
  }
  type GameBoard3DAttackTargetsItem = {
    x : number!
    z : number!
  }
  type GameBoard3DFxItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity GameBoard3DItem [runtime] {
    id : string!
    units : [GameBoard3DUnitsItem]
    selectedUnitId : string
    validMoves : [GameBoard3DValidMovesItem]
    attackTargets : [GameBoard3DAttackTargetsItem]
    fx : [GameBoard3DFxItem] = []
    phase : "observation" | "selection" | "movement" | "action" | "enemy_turn" | "game_over" = "observation"
    turn : number = 0
    result : "none" | "victory" | "defeat" = none
    currentTeam : "player" | "enemy" = "player"
    gridWidth : number = 16
    gridHeight : number = 16
    movementRange : number = 4
    enemyTurn : boolean = false
    tiles : [GameBoard3DTilesItem] = []
  }

  trait GameBoard3DRender -> @rebindable GameBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.fx [])
        (set @entity.turn 0)
        (set @entity.result "none")
        (set @entity.phase "observation")
        (set @entity.currentTeam "player")
        (set @entity.enemyTurn false)
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.movementRange 4)
        (set @entity.tiles (array/flatten (array/map (array/range 0 16) (fn gy (array/map (array/range 0 16) (fn gx (let ((cover (and (>= @gy 3) (and (<= @gy 12) (== (math/mod (+ (* @gx 3) (* @gy 7)) 8) 0))))) { id: (str/concat "t-" @gx "-" @gy), x: @gx, y: @gy, terrain: (if @cover "wall" "floor"), passable: (if @cover false true), modelUrl: (if @cover @config.coverAsset @config.groundAsset) })))))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      UNIT_CLICK -> playing when (and (== @entity.phase "action") (and (== (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) team) "enemy") (and (> (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) health) 0) (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) position) (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position)) 1))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?unitId) (object/merge @u { health: (math/max 0 (- @u.health @config.attackDamage)) }) @u))))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.phase "observation")
        (set @entity.result (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> @u.health 0))))) 0) "victory" "none"))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (set @entity.fx (array/append @entity.fx { id: (str/concat "fx-atk-" @entity.turn), type: "hit", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) x), z: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) y), message: (str/concat "-" @config.attackDamage), ttl: 3 }))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      UNIT_CLICK -> playing when (and (== @entity.selectedUnitId ?unitId) (== (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) team) "player"))
        (set @entity.phase "action")
        (set @entity.attackTargets (array/map (array/filter @entity.units (fn u (and (== @u.team "enemy") (> @u.health 0) (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn s (== @s.id @entity.selectedUnitId))) position) (object/get @u position)) 1)))) (fn u { x: (object/get (object/get @u position) x), z: (object/get (object/get @u position) y) })))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      UNIT_CLICK -> playing when (== (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) team) "player")
        (set @entity.selectedUnitId ?unitId)
        (set @entity.phase "selection")
        (set @entity.validMoves (array/map (array/filter @entity.tiles (fn t (and (== (object/get @t passable) true) (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0)))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (set @entity.attackTargets [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      TILE_CLICK -> playing when (and (!= @entity.selectedUnitId "") (and (grid/in-bounds { x: ?x, y: ?z } @entity.gridWidth @entity.gridHeight) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) position) { x: ?x, y: ?z }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) ?x) (== (object/get (object/get @u position) y) ?z))))) 0))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id @entity.selectedUnitId) (object/merge @u { position: { x: ?x, y: ?z } }) @u))))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.phase "observation")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      END_TURN -> playing when (== @entity.result "none")
        (set @entity.turn (+ @entity.turn 1))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.enemyTurn true)
        (set @entity.currentTeam "enemy")
        (set @entity.phase "enemy_turn")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      CANCEL -> playing when (!= @entity.selectedUnitId "")
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.phase "observation")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      GAME_END -> gameover when (or (== (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> (object/get @u health) 0))))) 0) (== (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> (object/get @u health) 0))))) 0))
        (set @entity.result (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> (object/get @u health) 0))))) 0) "defeat" "victory"))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (set @entity.phase "game_over")
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: (if (== @entity.result "victory") "VICTORY" "DEFEAT"), subtitle: (str/concat "Turn " @entity.turn), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.fx [])
        (set @entity.turn 0)
        (set @entity.result "none")
        (set @entity.phase "observation")
        (set @entity.currentTeam "player")
        (set @entity.enemyTurn false)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: (if (== @entity.result "victory") "VICTORY" "DEFEAT"), subtitle: (str/concat "Turn " @entity.turn), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })
    }

    ticks {
      enemyAiTick every 1s
        when (and (== @entity.enemyTurn true) (== @entity.result "none"))
        (set @entity.fx (array/concat @entity.fx (array/map (array/filter @entity.units (fn u (and (and (== @u.team "player") (> @u.health 0)) (> (array/len (array/filter @entity.units (fn e (and (and (== @e.team "enemy") (> @e.health 0)) (== (grid/manhattan-distance (object/get @e position) (object/get @u position)) 1))))) 0)))) (fn u { id: (str/concat "fx-ai-" @u.id), type: "hit", x: (object/get (object/get @u position) x), z: (object/get (object/get @u position) y), message: "-1", ttl: 3 }))))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "player") (> @u.health 0)) (if (> (array/len (array/filter @entity.units (fn e (and (and (== @e.team "enemy") (> @e.health 0)) (== (grid/manhattan-distance (object/get @e position) (object/get @u position)) 1))))) 0) (object/merge @u { health: (math/max 0 (- @u.health 1)) }) @u) @u))))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "enemy") (> @u.health 0)) (if (== (array/len (array/filter @entity.units (fn p (and (and (== @p.team "player") (> @p.health 0)) (== (grid/manhattan-distance (object/get @u position) (object/get @p position)) 1))))) 0) (let ((target (array/reduce (array/filter @entity.units (fn p (and (== @p.team "player") (> @p.health 0)))) null (fn nearest p (if (or (== @nearest null) (< (grid/manhattan-distance (object/get @p position) (object/get @u position)) (grid/manhattan-distance (object/get @nearest position) (object/get @u position)))) @p @nearest))))) (if (== @target null) @u (let ((nextX (math/clamp (+ (object/get (object/get @u position) x) (math/sign (- (object/get (object/get @target position) x) (object/get (object/get @u position) x)))) 0 (- @entity.gridWidth 1))) (nextY (math/clamp (+ (object/get (object/get @u position) y) (math/sign (- (object/get (object/get @target position) y) (object/get (object/get @u position) y)))) 0 (- @entity.gridHeight 1)))) (if (and (grid/in-bounds { x: @nextX, y: @nextY } @entity.gridWidth @entity.gridHeight) (and (== (object/get (array/find @entity.tiles (fn t (and (== (object/get @t x) @nextX) (== (object/get @t y) @nextY)))) passable) true) (== (array/len (array/filter @entity.units (fn o (and (!= @o.id @u.id) (and (> @o.health 0) (and (== (object/get (object/get @o position) x) @nextX) (== (object/get (object/get @o position) y) @nextY))))))) 0))) (object/merge @u { position: { x: @nextX, y: @nextY } }) @u)))) @u) @u))))
        (set @entity.result (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> @u.health 0))))) 0) "defeat" (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> @u.health 0))))) 0) "victory" "none")))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (set @entity.enemyTurn false)
        (set @entity.currentTeam "player")
        (set @entity.phase (if (!= @entity.result "none") "game_over" "observation"))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: (if (== @entity.result "victory") "VICTORY" "DEFEAT"), subtitle: (str/concat "Turn " @entity.turn), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      fxTick every 500ms
        when (> (array/len @entity.fx) 0)
        (set @entity.fx (array/filter (array/map @entity.fx (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Turn", value: @entity.turn }, { label: "Phase", value: @entity.phase }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Defeat all enemies" }, { label: "How", value: "Click your unit → move → click it again → strike an adjacent foe" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: END_TURN, label: "End Turn", variant: primary }, { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "isometric", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })
    }

    emits {
      GAME_END -> external {
        result : string
      }
        @description "Called when the match ends"
        @tier "domain"
      UNIT_MOVE -> external {
        unit : object
        to : GameBoard3DValidMovesItem
      }
        @description "Called after a unit moves"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        z : number!
        tileId : string
      }
        @description "-- Declarative event props --"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
        x : number
        z : number
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
      END_TURN -> external {
        id : string
      }
        @description "Emits UI:{endTurnEvent} with {} on end turn"
        @tier "domain"
      CANCEL -> external {
        id : string
      }
        @description "Emits UI:{cancelEvent} with {} on cancel"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : GameBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      units : [GameBoard3DUnitsItem] = [{ id: "u1", position: { x: 4, y: 14 }, unitType: "worker", name: "Worker", team: player, health: 10, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-dungeon/units/character-human.glb", role: "decoration", category: "character-human", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-human", thumbnailUrl: "" } }, { id: "u2", position: { x: 8, y: 14 }, unitType: "warrior", name: "Warrior", team: player, health: 10, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-arena/units/character-soldier.glb", role: "decoration", category: "character-soldier", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-soldier", thumbnailUrl: "" } }, { id: "u3", position: { x: 12, y: 14 }, unitType: "worker", name: "Ranger", team: player, health: 10, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-dungeon/units/character-human.glb", role: "decoration", category: "character-human", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-human", thumbnailUrl: "" } }, { id: "e1", position: { x: 4, y: 1 }, unitType: "guardian", name: "Guardian", team: enemy, health: 8, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-dungeon/units/character-orc.glb", role: "decoration", category: "character-orc", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-orc", thumbnailUrl: "" } }, { id: "e2", position: { x: 8, y: 1 }, unitType: "scout", name: "Scout", team: enemy, health: 6, maxHealth: 8, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-graveyard-kit/units/character-skeleton.glb", role: "decoration", category: "character-skeleton", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-skeleton", thumbnailUrl: "" } }, { id: "e3", position: { x: 12, y: 1 }, unitType: "guardian", name: "Brute", team: enemy, health: 8, maxHealth: 10, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-dungeon/units/character-orc.glb", role: "decoration", category: "character-orc", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-orc", thumbnailUrl: "" } }]
        @label "Units"
        @description "Initial unit roster (3 player + 3 enemy at opposite ends) — takes priority over entity-derived units."
        @tier "presentation"
      features : [GameBoard3DFeaturesItem] = [{ id: "f1", x: 6, y: 7, type: "gold_mine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-dungeon/features/chest.glb", role: "decoration", category: "chest", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "chest", thumbnailUrl: "" } }, { id: "f2", x: 10, y: 8, type: "portal", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-modular-dungeon-kit/terrain/gate-metal-bars.glb", role: "decoration", category: "gate-metal-bars", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gate-metal-bars", thumbnailUrl: "" } }]
        @label "Features"
        @description "Decorative features on the board — both repositioned to the mid-band on passable floor tiles."
        @tier "presentation"
      groundAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-modular-dungeon-kit/terrain/template-floor.glb", role: "decoration", category: "template-floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "template-floor", thumbnailUrl: "" }
        @label "Ground Asset"
        @description "Passable dungeon floor tile, tiled across the battlefield."
        @tier "presentation"
      coverAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-game-board-3d/kenney-mini-dungeon/terrain/wall.glb", role: "decoration", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" }
        @label "Cover Asset"
        @description "Impassable dungeon wall tile, scattered for chokepoints."
        @tier "presentation"
      attackDamage : number = 3
        @label "Attack Damage"
        @description "Damage dealt when a selected unit attacks an adjacent enemy"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
    }
  }

  page "/game-board-3d" as GameBoard3DPage -> GameBoard3DRender
}
