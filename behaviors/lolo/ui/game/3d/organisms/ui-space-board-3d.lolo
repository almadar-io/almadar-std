app ui-space-board-3d "1.0.0"
"SpaceBoard3D — 3D Mars-base tactics board on a canyon grid composing game-shell + canvas; owns gameplay state."
orbital SpaceBoard3DOrbital {
  uses Frame from "std/behaviors/std-tactics-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string
    assetUrl : Asset
    color : string
    elevation : number
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    attackTargets : [ValidMove] = []
    uiPhase : string = "observation"
    turn : number = 0
  }

  trait Authority = Frame.traits.TacticsAuthority -> GameState {
    config {
      running: true
      gridWidth: 18
      gridHeight: 18
      attackDamage: 3
      units: [ { id: "u1", position: { x: 4, y: 16 }, x: 4, y: 16, z: 0, team: "player", health: 10, maxHealth: 10, unitType: "astronaut", name: "Astronaut", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/units/astronautA.glb", role: "player", category: "astronaut", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "astronautA", thumbnailUrl: "" } }, { id: "u2", position: { x: 9, y: 16 }, x: 9, y: 16, z: 0, team: "player", health: 12, maxHealth: 12, unitType: "rover", name: "Rover", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/rover.glb", role: "player", category: "rover", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "rover", thumbnailUrl: "" } }, { id: "u3", position: { x: 14, y: 16 }, x: 14, y: 16, z: 0, team: "player", health: 10, maxHealth: 10, unitType: "astronaut", name: "Engineer", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/units/astronautA.glb", role: "player", category: "astronaut", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "astronautA", thumbnailUrl: "" } }, { id: "e1", position: { x: 4, y: 1 }, x: 4, y: 1, z: 0, team: "enemy", health: 8, maxHealth: 10, unitType: "alien", name: "Alien", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/alien.glb", role: "enemy", category: "alien", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "alien", thumbnailUrl: "" } }, { id: "e2", position: { x: 9, y: 1 }, x: 9, y: 1, z: 0, team: "enemy", health: 6, maxHealth: 8, unitType: "raider", name: "Raider Craft", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/craft_speederA.glb", role: "enemy", category: "raider", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "craft_speederA", thumbnailUrl: "" } }, { id: "e3", position: { x: 14, y: 1 }, x: 14, y: 1, z: 0, team: "enemy", health: 8, maxHealth: 10, unitType: "alien", name: "Alien Scout", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/alien.glb", role: "enemy", category: "alien", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "alien", thumbnailUrl: "" } } ]
    }
  }

  trait FxDecay = Frame.traits.FxDecay -> GameState {
    config { running: true }
  }

  trait RoundLogic = Frame.traits.RoundLogic -> GameState {
    config { running: true }
  }

  trait Player = Frame.traits.PlayerIntent -> GameState {
    config {
      gridWidth: 18
      gridHeight: 18
      movementRange: 4
      features: [{ id: "f1", x: 9, y: 9, type: "dome", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/hangar_roundA.glb", role: "decoration", category: "dome", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "hangar_roundA", thumbnailUrl: "" } }, { id: "f2", x: 5, y: 7, type: "rocket", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/rocket_baseA.glb", role: "decoration", category: "rocket", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "rocket_baseA", thumbnailUrl: "" } }, { id: "f3", x: 13, y: 7, type: "hangar", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/hangar_smallA.glb", role: "decoration", category: "hangar", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "hangar_smallA", thumbnailUrl: "" } }, { id: "f4", x: 9, y: 12, type: "comms_dish", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/satelliteDish.glb", role: "decoration", category: "comms_dish", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "satelliteDish", thumbnailUrl: "" } }]
      assetManifest: { terrains: { regolith: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/terrain/terrain.glb", role: "tile", category: "regolith", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "regolith", thumbnailUrl: "" }, boulder: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/rock_largeA.glb", role: "tile", category: "boulder", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "boulder", thumbnailUrl: "" }, crater: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/crater.glb", role: "tile", category: "crater", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "crater", thumbnailUrl: "" } }, units: { astronaut: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/units/astronautA.glb", role: "npc", category: "astronaut", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "astronaut", thumbnailUrl: "" }, rover: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/rover.glb", role: "npc", category: "rover", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "rover", thumbnailUrl: "" }, alien: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/alien.glb", role: "npc", category: "alien", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "alien", thumbnailUrl: "" }, raider: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/craft_speederA.glb", role: "npc", category: "raider", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "raider", thumbnailUrl: "" } }, features: { dome: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/hangar_roundA.glb", role: "decoration", category: "dome", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "dome", thumbnailUrl: "" }, rocket: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/rocket_baseA.glb", role: "decoration", category: "rocket", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "rocket", thumbnailUrl: "" }, hangar: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/hangar_smallA.glb", role: "decoration", category: "hangar", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "hangar", thumbnailUrl: "" }, comms_dish: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/satelliteDish.glb", role: "decoration", category: "comms_dish", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "comms_dish", thumbnailUrl: "" } }, effects: { melee: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/weapon_gun.glb", role: "effect", category: "melee", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "8:1", name: "melee", thumbnailUrl: "" }, ranged: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/weapon_rifle.glb", role: "effect", category: "ranged", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "8:1", name: "ranged", thumbnailUrl: "" }, magic: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/machine_wireless.glb", role: "effect", category: "magic", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "8:1", name: "magic", thumbnailUrl: "" }, hit: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/meteor_half.glb", role: "effect", category: "hit", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "8:1", name: "hit", thumbnailUrl: "" }, heal: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/barrel.glb", role: "effect", category: "heal", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "8:1", name: "heal", thumbnailUrl: "" }, death: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-board-3d/kenney-space-kit/features/bones.glb", role: "effect", category: "death", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "8:1", name: "death", thumbnailUrl: "" } } }
      cameraMode: "isometric"
      scale: 0.45
      unitScale: 1
      bgColor: "#05070f"
    }
  }

  page "/space-board-3d" as SpaceBoard3DPage -> Authority, FxDecay, RoundLogic, Player
}
