app ui-market-board-3d "1.0.0"
"MarketBoard3D — 3D shop-service board organism (game-shell + game-canvas-3d); serve customers before patience hits zero."
orbital MarketBoard3DOrbital {
  type MarketBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type MarketBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type MarketBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type MarketBoard3DUnitsItem = {
    id : string!
    position : MarketBoard3DUnitsItemPosition
    unitType : string
    name : string
    team : "player" | "neutral"
    patience : number
    maxPatience : number
    modelUrl : Asset
  }
  type MarketBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type MarketBoard3DValidMovesItem = {
    x : number!
    z : number!
  }
  type MarketBoard3DAttackTargetsItem = {
    x : number!
    z : number!
  }

  entity MarketBoard3DItem [runtime] {
    id : string!
    units : [MarketBoard3DUnitsItem]
    selectedUnitId : string
    validMoves : [MarketBoard3DValidMovesItem]
    attackTargets : [MarketBoard3DAttackTargetsItem]
    score : number = 0
    lives : number = 3
    result : "none" | "won" | "lost" = none
    gridWidth : number = 5
    gridHeight : number = 6
    movementRange : number = 2
    maxPatience : number = 8
    scoreTarget : number = 10
  }

  trait MarketBoard3DRender -> @rebindable MarketBoard3DItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "u1")
        (set @entity.gridWidth 5)
        (set @entity.gridHeight 6)
        (set @entity.movementRange 2)
        (set @entity.maxPatience @config.maxPatience)
        (set @entity.scoreTarget @config.scoreTarget)
        (set @entity.attackTargets [])
        (set @entity.validMoves (array/map (array/filter @config.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "u1")
        (set @entity.gridWidth 5)
        (set @entity.gridHeight 6)
        (set @entity.movementRange 2)
        (set @entity.maxPatience @config.maxPatience)
        (set @entity.scoreTarget @config.scoreTarget)
        (set @entity.attackTargets [])
        (set @entity.validMoves (array/map (array/filter @config.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      TILE_CLICK -> playing when (and (== @entity.result "none") (and (grid/in-bounds { x: ?x, y: ?z } @entity.gridWidth @entity.gridHeight) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: ?x, y: ?z }) @entity.movementRange) (and (== (object/get (array/find @config.tiles (fn t (and (== @t.x ?x) (== @t.y ?z)))) passable) true) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) ?x) (== (object/get (object/get @u position) y) ?z))))) 0)))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id "u1") (object/merge @u { position: { x: ?x, y: ?z } }) @u))))
        (set @entity.validMoves (array/map (array/filter @config.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      UNIT_CLICK -> playing when (and (== @entity.result "none") (and (!= (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) team) "player") (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position)) 1)))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?unitId) (object/merge @u { patience: @entity.maxPatience }) @u))))
        (set @entity.score (+ @entity.score 1))
        (set @entity.result (if (>= @entity.score @entity.scoreTarget) "won" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> menu
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "u1")
        (set @entity.gridWidth 5)
        (set @entity.gridHeight 6)
        (set @entity.movementRange 2)
        (set @entity.maxPatience @config.maxPatience)
        (set @entity.scoreTarget @config.scoreTarget)
        (set @entity.attackTargets [])
        (set @entity.validMoves (array/map (array/filter @config.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    ticks {
      patienceTick every 1s
        when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "neutral") (object/merge @u { patience: (math/clamp (- @u.patience 1) 0 @entity.maxPatience) }) @u))))
        (set @entity.lives (math/max 0 (- @entity.lives (array/len (array/filter @entity.units (fn u (and (== @u.team "neutral") (<= @u.patience 0))))))))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "neutral") (<= @u.patience 0)) (object/merge @u { patience: @entity.maxPatience }) @u))))
        (set @entity.result (if (<= @entity.lives 0) "lost" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      wanderTick every 1500ms
        when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "neutral") (let ((cx (object/get (object/get @u position) x)) (cy (object/get (object/get @u position) y)) (tx (+ 1 (math/floor (* (math/random) 3)))) (ty (+ 1 (math/floor (* (math/random) 4))))) (object/merge @u { position: { x: (math/clamp (+ @cx (math/sign (- @tx @cx))) 1 3), y: (math/clamp (+ @cy (math/sign (- @ty @cy))) 1 4) } })) @u))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result } ] }
          children: [ { type: game-canvas-3d, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @config.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    emits {
      GAME_END -> external {
        result : string!
      }
        @description "Emitted when result becomes won or lost"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        z : number
        tileId : string
      }
        @description "Moves the shopkeeper toward the clicked tile"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
        x : number
        z : number
      }
        @description "Serves the clicked customer when the shopkeeper is adjacent"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : MarketBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [MarketBoard3DTilesItem] = [{ id: "t00", x: 0, y: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall-corner.glb", role: "tile", category: "wall-corner", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall-corner", thumbnailUrl: "" } }, { id: "t10", x: 1, y: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall-window.glb", role: "tile", category: "wall-window", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall-window", thumbnailUrl: "" } }, { id: "t20", x: 2, y: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t30", x: 3, y: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall-window.glb", role: "tile", category: "wall-window", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall-window", thumbnailUrl: "" } }, { id: "t40", x: 4, y: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall-corner.glb", role: "tile", category: "wall-corner", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall-corner", thumbnailUrl: "" } }, { id: "t01", x: 0, y: 1, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t11", x: 1, y: 1, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t21", x: 2, y: 1, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t31", x: 3, y: 1, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t41", x: 4, y: 1, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t02", x: 0, y: 2, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t12", x: 1, y: 2, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t22", x: 2, y: 2, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t32", x: 3, y: 2, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t42", x: 4, y: 2, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t03", x: 0, y: 3, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t13", x: 1, y: 3, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t23", x: 2, y: 3, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t33", x: 3, y: 3, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t43", x: 4, y: 3, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t04", x: 0, y: 4, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t14", x: 1, y: 4, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t24", x: 2, y: 4, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t34", x: 3, y: 4, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t44", x: 4, y: 4, terrain: "wal