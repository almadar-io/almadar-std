shopping-cart", thumbnailUrl: "" } }, { id: "f13", x: 7, y: 9, type: "checkout", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/cash-register.glb", role: "decoration", category: "cash-register", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "cash-register", thumbnailUrl: "" } }, { id: "f14", x: 11, y: 9, type: "bottle_return", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/bottle-return.glb", role: "decoration", category: "bottle-return", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bottle-return", thumbnailUrl: "" } }, { id: "f15", x: 12, y: 2, type: "shelf", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/shelf-end.glb", role: "decoration", category: "shelf-end", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "shelf-end", thumbnailUrl: "" } }]
        @label "Features"
        @description "Shop fixtures (shelves/freezers/checkout/carts) and food props, each on a unique cell across the 14×14 floor."
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      scoreTarget : number = 10
        @label "Score Target"
        @description "Score needed to win"
        @tier "presentation"
    }
  }

  page "/market-board-3d" as MarketBoard3DPage -> MarketBoard3DRender
}
