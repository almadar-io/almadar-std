app ui-market-board-3d "1.0.0"
"MarketBoard3D — 3D shop-service board organism (game-shell + game-canvas-3d); serve customers before patience hits zero."
orbital MarketBoard3DOrbital {
  type MarketBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type MarketBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type MarketBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type MarketBoard3DUnitsItem = {
    id : string!
    position : MarketBoard3DUnitsItemPosition
    unitType : string
    name : string
    team : "player" | "neutral"
    patience : number
    maxPatience : number
    modelUrl : Asset
  }
  type MarketBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type MarketBoard3DValidMovesItem = {
    x : number!
    z : number!
  }
  type MarketBoard3DAttackTargetsItem = {
    x : number!
    z : number!
  }
  type MarketBoard3DFxItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity MarketBoard3DItem [runtime] {
    id : string!
    units : [MarketBoard3DUnitsItem]
    selectedUnitId : string
    validMoves : [MarketBoard3DValidMovesItem]
    attackTargets : [MarketBoard3DAttackTargetsItem]
    fx : [MarketBoard3DFxItem] = []
    score : number = 0
    lives : number = 3
    result : "none" | "won" | "lost" = none
    gridWidth : number = 14
    gridHeight : number = 14
    movementRange : number = 4
    scoreTarget : number = 10
    tiles : [MarketBoard3DTilesItem] = []
  }

  trait MarketBoard3DRender -> @rebindable MarketBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "u1")
        (set @entity.gridWidth 14)
        (set @entity.gridHeight 14)
        (set @entity.movementRange 4)
        (set @entity.tiles (array/flatten (array/map (array/range 0 14) (fn gy (array/map (array/range 0 14) (fn gx (let ((cover (and (== (math/mod @gy 3) 1) (== (math/mod @gx 4) 2)))) { id: (str/concat "t-" @gx "-" @gy), x: @gx, y: @gy, terrain: (if @cover "shelf" "floor"), passable: (if @cover false true), modelUrl: (if @cover @config.shelfAsset @config.floorAsset) })))))))
        (set @entity.scoreTarget @config.scoreTarget)
        (set @entity.attackTargets [])
        (set @entity.fx [])
        (set @entity.validMoves (array/map (array/filter @entity.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      TILE_CLICK -> playing when (and (== @entity.result "none") (and (grid/in-bounds { x: ?x, y: ?z } @entity.gridWidth @entity.gridHeight) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: ?x, y: ?z }) @entity.movementRange) (and (== (object/get (array/find @entity.tiles (fn t (and (== @t.x ?x) (== @t.y ?z)))) passable) true) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) ?x) (== (object/get (object/get @u position) y) ?z))))) 0)))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id "u1") (object/merge @u { position: { x: ?x, y: ?z } }) @u))))
        (set @entity.validMoves (array/map (array/filter @entity.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      UNIT_CLICK -> playing when (and (== @entity.result "none") (and (!= (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) team) "player") (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position)) 1)))
        (set @entity.fx (array/append @entity.fx { id: (str/concat "fx-serve-" ?unitId), type: "score", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) x), z: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) y), message: "+1", ttl: 3 }))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?unitId) (object/merge @u { patience: @u.maxPatience }) @u))))
        (set @entity.score (+ @entity.score 1))
        (set @entity.result (if (>= @entity.score @entity.scoreTarget) "won" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "u1")
        (set @entity.gridWidth 14)
        (set @entity.gridHeight 14)
        (set @entity.movementRange 4)
        (set @entity.scoreTarget @config.scoreTarget)
        (set @entity.attackTargets [])
        (set @entity.fx [])
        (set @entity.validMoves (array/map (array/filter @entity.tiles (fn t (and (== (object/get @t passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id "u1"))) position) { x: (object/get @t x), y: (object/get @t y) }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) (object/get @t x)) (== (object/get (object/get @u position) y) (object/get @t y)))))) 0))))) (fn t { x: (object/get @t x), z: (object/get @t y) })))
        (set @entity.score 0)
        (set @entity.lives 3)
        (set @entity.result "none")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })
    }

    ticks {
      patienceTick every 1s
        when (== @entity.result "none")
        (set @entity.fx (array/filter (array/map @entity.fx (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "neutral") (object/merge @u { patience: (math/clamp (- @u.patience 1) 0 @u.maxPatience) }) @u))))
        (let ((starved (array/filter @entity.units (fn u (and (== @u.team "neutral") (<= @u.patience 0))))))
          (do
            (set @entity.fx (array/reduce @starved @entity.fx (fn acc u (array/append @acc { id: (str/concat "fx-starve-" @u.id), type: "damage", x: (object/get (object/get @u position) x), z: (object/get (object/get @u position) y), message: "-1 life", ttl: 3 }))))
            (set @entity.lives (math/max 0 (- @entity.lives (array/len @starved))))))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "neutral") (<= @u.patience 0)) (object/merge @u { patience: @u.maxPatience }) @u))))
        (set @entity.result (if (<= @entity.lives 0) "lost" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })

      wanderTick every 1500ms
        when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "neutral") (let ((cx (object/get (object/get @u position) x)) (cy (object/get (object/get @u position) y)) (dir (math/floor (* (math/random) 4)))) (let ((nx (if (== @dir 0) (+ @cx 1) (if (== @dir 1) (- @cx 1) @cx))) (ny (if (== @dir 2) (+ @cy 1) (if (== @dir 3) (- @cy 1) @cy)))) (let ((ntile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny))))) (occupied (array/find @entity.units (fn o (and (!= @o.id @u.id) (and (== (object/get (object/get @o position) x) @nx) (== (object/get (object/get @o position) y) @ny))))))) (if (and (grid/in-bounds { x: @nx, y: @ny } @entity.gridWidth @entity.gridHeight) (and (!= @ntile null) (and (== (object/get @ntile passable) true) (== @occupied null)))) (object/merge @u { position: { x: @nx, y: @ny } }) @u)))) @u))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Lives", value: @entity.lives }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Serve customers before patience runs out" }, { label: "How", value: "Click a floor tile to walk → click an adjacent customer to serve them" } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @config.features, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale, events: @entity.fx } ]
        })
    }

    emits {
      GAME_END -> external {
        result : string!
      }
        @description "Emitted when result becomes won or lost"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        z : number
        tileId : string
      }
        @description "Moves the shopkeeper toward the clicked tile"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
        x : number
        z : number
      }
        @description "Serves the clicked customer when the shopkeeper is adjacent"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : MarketBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      floorAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" }
        @label "Floor Asset"
        @description "Passable shop floor tile, tiled across the store."
        @tier "presentation"
      shelfAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/shelf-boxes.glb", role: "tile", category: "shelf-boxes", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "shelf-boxes", thumbnailUrl: "" }
        @label "Shelf Asset"
        @description "Impassable shelf/counter terrain tile, scattered for shop aisles."
        @tier "presentation"
      units : [MarketBoard3DUnitsItem] = [{ id: "u1", position: { x: 7, y: 7 }, unitType: "shopkeeper", name: "Shopkeeper", team: player, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/units/character-employee.glb", role: "player", category: "character-employee", animations: ["static", "idle", "walk", "sprint", "jump", "fall", "crouch", "sit", "drive", "die", "pick-up", "emote-yes", "emote-no", "holding-right", "holding-left", "holding-both", "holding-right-shoot", "holding-left-shoot", "holding-both-shoot", "attack-melee-right", "attack-melee-left", "attack-kick-right", "attack-kick-left", "interact-right", "interact-left", "wheelchair-sit", "wheelchair-look-left", "wheelchair-look-right", "wheelchair-move-forward", "wheelchair-move-back", "wheelchair-move-left", "wheelchair-move-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-employee", thumbnailUrl: "" } }, { id: "c1", position: { x: 4, y: 3 }, unitType: "customer", name: "Customer A", team: neutral, patience: 20, maxPatience: 20, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mini-characters/units/character-female-a.glb", role: "npc", category: "character-female-a", animations: ["static", "idle", "walk", "sprint", "jump", "fall", "crouch", "sit", "drive", "die", "pick-up", "emote-yes", "emote-no", "holding-right", "holding-left", "holding-both", "holding-right-shoot", "holding-left-shoot", "holding-both-shoot", "attack-melee-right", "attack-melee-left", "attack-kick-right", "attack-kick-left", "interact-right", "interact-left", "wheelchair-sit", "wheelchair-look-left", "wheelchair-look-right", "wheelchair-move-forward", "wheelchair-move-back", "wheelchair-move-left", "wheelchair-move-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-female-a", thumbnailUrl: "" } }, { id: "c2", position: { x: 10, y: 11 }, unitType: "customer", name: "Customer B", team: neutral, patience: 24, maxPatience: 24, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mini-characters/units/character-male-a.glb", role: "npc", category: "character-male-a", animations: ["static", "idle", "walk", "sprint", "jump", "fall", "crouch", "sit", "drive", "die", "pick-up", "emote-yes", "emote-no", "holding-right", "holding-left", "holding-both", "holding-right-shoot", "holding-left-shoot", "holding-both-shoot", "attack-melee-right", "attack-melee-left", "attack-kick-right", "attack-kick-left", "interact-right", "interact-left", "wheelchair-sit", "wheelchair-look-left", "wheelchair-look-right", "wheelchair-move-forward", "wheelchair-move-back", "wheelchair-move-left", "wheelchair-move-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-male-a", thumbnailUrl: "" } }]
        @label "Units"
        @description "Initial roster: shopkeeper + 2 customers, spread across the 14×14 floor — takes priority over entity-derived units."
        @tier "presentation"
      features : [MarketBoard3DFeaturesItem] = [{ id: "f1", x: 1, y: 2, type: "shelf", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/shelf-boxes.glb", role: "decoration", category: "shelf-boxes", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "shelf-boxes", thumbnailUrl: "" } }, { id: "f2", x: 5, y: 2, type: "shelf", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/shelf-bags.glb", role: "decoration", category: "shelf-bags", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "shelf-bags", thumbnailUrl: "" } }, { id: "f3", x: 9, y: 2, type: "shopping_basket", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/shopping-basket.glb", role: "decoration", category: "shopping-basket", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "shopping-basket", thumbnailUrl: "" } }, { id: "f4", x: 1, y: 5, type: "freezer", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/freezer.glb", role: "decoration", category: "freezer", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "freezer", thumbnailUrl: "" } }, { id: "f5", x: 5, y: 5, type: "freezer", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/freezers-standing.glb", role: "decoration", category: "freezers-standing", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "freezers-standing", thumbnailUrl: "" } }, { id: "f6", x: 9, y: 5, type: "display_fruit", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-market-board-3d/kenney-mini-market/features/display-fruit.glb", role: "decoration", category: "display-fruit", animations: ["static"], style: "low