        @description "Shop fixtures (shelves/freezers/checkout/carts) and food props on the floor."
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      maxPatience : number = 8
        @label "Max Patience"
        @description "Starting/reset patience ticks for each customer"
        @tier "presentation"
