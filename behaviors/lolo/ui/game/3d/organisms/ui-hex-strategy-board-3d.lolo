        @label "Tiles"
        @description "6x6 hex realm grid — biomes + neutral building hexes on square-lattice positions."
        @tier "presentation"
      units : [HexStrategyBoard3DUnitsItem] = [{ id: "settler", position: { x: 0, y: 0 }, unitType: "settler", name: "Settler", team: player, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board-3d/kenney-hexagon-kit/features/unit-tower.glb", role: "decoration", category: "unit-tower", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "unit-tower", thumbnailUrl: "" } }]
        @label "Units"
        @description "The player's single settler token — starts on the castle hex."
        @tier "presentation"
      features : [HexStrategyBoard3DFeaturesItem] = []
        @label "Features"
        @description "Unused — neutral buildings are encoded directly in tiles."
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      startingTurns : number = 20
        @label "Starting Turns"
        @description "Turn-clock ticks before an unfinished realm counts as lost"
        @tier "presentation"
    }
  }

  page "/hex-strategy-board-3d" as HexStrategyBoard3DPage -> HexStrategyBoard3DRender
}
