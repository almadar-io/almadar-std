        @label "Cliff Asset"
        @description "Impassable cliff obstacle tile, scattered across the map."
        @tier "presentation"
      features : [NatureSurvivalBoard3DFeaturesItem] = [{ id: "f1", x: 5, y: 1, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_default.glb", role: "decoration", category: "tree_default", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_default", thumbnailUrl: "" } }, { id: "f2", x: 13, y: 1, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_oak.glb", role: "decoration", category: "tree_oak", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_oak", thumbnailUrl: "" } }, { id: "f3", x: 5, y: 5, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_pineRoundA.glb", role: "decoration", category: "tree_pineRoundA", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_pineRoundA", thumbnailUrl: "" } }, { id: "f4", x: 13, y: 5, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_default.glb", role: "decoration", category: "tree_default", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_default", thumbnailUrl: "" } }, { id: "f5", x: 5, y: 9, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_oak.glb", role: "decoration", category: "tree_oak", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_oak", thumbnailUrl: "" } }, { id: "f6", x: 13, y: 9, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_pineRoundA.glb", role: "decoration", category: "tree_pineRoundA", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_pineRoundA", thumbnailUrl: "" } }, { id: "f7", x: 9, y: 13, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_default.glb", role: "decoration", category: "tree_default", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_default", thumbnailUrl: "" } }, { id: "f8", x: 3, y: 3, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/tree_oak.glb", role: "decoration", category: "tree_oak", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree_oak", thumbnailUrl: "" } }, { id: "f9", x: 9, y: 1, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeA.glb", role: "decoration", category: "rock_largeA", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeA", thumbnailUrl: "" } }, { id: "f10", x: 1, y: 5, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeB.glb", role: "decoration", category: "rock_largeB", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeB", thumbnailUrl: "" } }, { id: "f11", x: 9, y: 5, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeC.glb", role: "decoration", category: "rock_largeC", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeC", thumbnailUrl: "" } }, { id: "f12", x: 1, y: 9, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeA.glb", role: "decoration", category: "rock_largeA", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeA", thumbnailUrl: "" } }, { id: "f13", x: 9, y: 9, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeB.glb", role: "decoration", category: "rock_largeB", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeB", thumbnailUrl: "" } }, { id: "f14", x: 5, y: 13, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeC.glb", role: "decoration", category: "rock_largeC", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeC", thumbnailUrl: "" } }, { id: "f15", x: 13, y: 13, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeA.glb", role: "decoration", category: "rock_largeA", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeA", thumbnailUrl: "" } }, { id: "f16", x: 11, y: 3, type: "rock", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/features/rock_largeB.glb", role: "decoration", category: "rock_largeB", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "rock_largeB", thumbnailUrl: "" } }]
        @label "Features"
        @description "Initial resource nodes (8 trees for wood, 8 rocks for stone) scattered across the wilderness."
        @tier "presentation"
      units : [NatureSurvivalBoard3DUnitsItem] = [{ id: "survivor", position: { x: 1, y: 1 }, unitType: "survivor", name: "Survivor", team: player, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mini-characters/units/character-male-a.glb", role: "player", category: "character-male-a", animations: ["idle","walk"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "character-male-a", thumbnailUrl: "" } }, { id: "deer", position: { x: 2, y: 3 }, unitType: "deer", name: "Deer", team: neutral, health: 1, maxHealth: 1, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cube-pets/units/animal-deer.glb", role: "npc", category: "animal-deer", animations: ["idle","walk"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "animal-deer", thumbnailUrl: "" } }]
        @label "Units"
        @description "Survivor (player) and a wandering deer (neutral)."
        @tier "presentation"
      roamMinX : number = 0
        @label "Roam Min X"
        @description "Animal roam rectangle min x"
        @tier "presentation"
      roamMaxX : number = 5
        @label "Roam Max X"
        @description "Animal roam rectangle max x"
        @tier "presentation"
      roamMinY : number = 1
        @label "Roam Min Y"
        @description "Animal roam rectangle min y"
        @tier "presentation"
      roamMaxY : number = 6
        @label "Roam Max Y"
        @description "Animal roam rectangle max y"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      turnBudget : number = 100
        @label "Turn Budget"
        @description "Energy ticks allowed before defeat if the camp is not yet built"
        @tier "presentation"
    }
  }

  page "/nature-survival-board-3d" as NatureSurvivalBoard3DPage -> NatureSurvivalBoard3DRender
