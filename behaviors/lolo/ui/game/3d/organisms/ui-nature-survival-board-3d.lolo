app ui-nature-survival-board-3d "1.0.0"
"NatureSurvivalBoard3D — gather wood/stone before energy runs out; build a camp to win or run out and lose; composes the std single-hero survival frame."
orbital NatureSurvivalBoard3DOrbital {
  uses Frame from "std/behaviors/std-survival-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    assetUrl : Asset
    color : string
    elevation : number
  }
  type HudStat = { label : string  value : number }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    movesLeft : number = 0
    features : [Feature] = []
    wood : number = 0
    stone : number = 0
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    phase : string = "observation"
  }

  trait HeroAuthority = Frame.traits.HeroAuthority -> GameState {
    config {
      running: true
      gridWidth: 16
      gridHeight: 16
      moveBudget: 100
      units: [ { id: "survivor", position: { x: 1, y: 1 }, x: 1, y: 1, z: 0, team: "player", health: 1, maxHealth: 1, unitType: "survivor", name: "Survivor", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mini-characters/units/character-male-a.glb", role: "player", category: "character-male-a", animations: ["idle","walk"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "character-male-a", thumbnailUrl: "" } }, { id: "deer", position: { x: 2, y: 3 }, x: 2, y: 3, z: 0, team: "neutral", health: 1, maxHealth: 1, unitType: "deer", name: "Deer", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cube-pets/units/animal-deer.glb", role: "npc", category: "animal-deer", animations: ["idle","walk"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "animal-deer", thumbnailUrl: "" } } ]
