app ui-nature-survival-board-3d "1.0.0"
"NatureSurvivalBoard3D — gather wood/stone before energy runs out; build a camp to win or run out and lose."
orbital NatureSurvivalBoard3DOrbital {
  type NatureSurvivalBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type NatureSurvivalBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type NatureSurvivalBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type NatureSurvivalBoard3DUnitsItem = {
    id : string!
    position : NatureSurvivalBoard3DUnitsItemPosition
    unitType : string
    name : string
    team : "player" | "neutral"
    health : number
    maxHealth : number
    modelUrl : Asset
  }
  type NatureSurvivalBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type NatureSurvivalBoard3DValidMovesItem = {
    x : number!
    z : number!
  }
  type NatureSurvivalBoard3DAttackTargetsItem = {
    x : number!
    z : number!
  }
  type NatureSurvivalBoard3DFxEvent = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity NatureSurvivalBoard3DItem [runtime] {
    id : string!
    units : [NatureSurvivalBoard3DUnitsItem]
    features : [NatureSurvivalBoard3DFeaturesItem]
    selectedUnitId : string
    validMoves : [NatureSurvivalBoard3DValidMovesItem]
    attackTargets : [NatureSurvivalBoard3DAttackTargetsItem]
    fx : [NatureSurvivalBoard3DFxEvent] = []
    wood : number = 0
    stone : number = 0
    woodGoal : number = 4
    stoneGoal : number = 4
    result : "none" | "victory" | "defeat" = "none"
    energyLeft : number = 100
    gridWidth : number = 16
    gridHeight : number = 16
    movementRange : number = 3
    tiles : [NatureSurvivalBoard3DTilesItem] = []
  }

  trait NatureSurvivalBoard3DRender -> @rebindable NatureSurvivalBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.fx [])
        (set @entity.wood 0)
        (set @entity.stone 0)
        (set @entity.woodGoal 4)
        (set @entity.stoneGoal 4)
        (set @entity.result "none")
        (set @entity.energyLeft @config.turnBudget)
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.movementRange 3)
        (set @entity.tiles (array/flatten (array/map (array/range 0 16) (fn gy (array/map (array/range 0 16) (fn gx (let ((obstacle (== (math/mod (+ (* @gx 5) (* @gy 3)) 11) 0)) (isRiver (== (math/mod @gy 2) 0))) { id: (str/concat "t-" @gx "-" @gy), x: @gx, y: @gy, terrain: (if @obstacle (if @isRiver "river" "cliff") "grass"), passable: (if @obstacle false true), modelUrl: (if @obstacle (if @isRiver @config.riverAsset @config.cliffAsset) @config.groundAsset) })))))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      UNIT_CLICK -> playing when (== (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) team) "player")
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves (array/map (array/filter @entity.tiles (fn t (and (== @t.passable true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id ?unitId))) position) { x: @t.x, y: @t.y }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) @t.x) (== (object/get (object/get @u position) y) @t.y))))) 0))))) (fn t { x: @t.x, z: @t.y })))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      TILE_CLICK -> playing when (and (!= @entity.selectedUnitId "") (and (!= (array/find @entity.features (fn f (and (== @f.x ?x) (== @f.y ?z)))) null) (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) position) { x: ?x, y: ?z }) 1)))
        (let ((hitType (object/get (array/find @entity.features (fn f (and (== @f.x ?x) (== @f.y ?z)))) type)))
        (do
        (set @entity.wood (if (== @hitType "tree") (+ @entity.wood 1) @entity.wood))
        (set @entity.stone (if (== @hitType "rock") (+ @entity.stone 1) @entity.stone))
        (set @entity.features (array/filter @entity.features (fn f (or (!= @f.x ?x) (!= @f.y ?z)))))
        (set @entity.fx (array/append @entity.fx { id: (str/concat "fx-" (str/concat ?x ?z)), type: "pickup", x: ?x, z: ?z, message: (if (== @hitType "tree") "+1 wood" "+1 stone"), ttl: 3 }))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
        ))

      TILE_CLICK -> playing when (and (!= @entity.selectedUnitId "") (and (== (array/find @entity.features (fn f (and (== @f.x ?x) (== @f.y ?z)))) null) (and (grid/in-bounds { x: ?x, y: ?z } @entity.gridWidth @entity.gridHeight) (and (== (object/get (array/find @entity.tiles (fn t (and (== @t.x ?x) (== @t.y ?z)))) passable) true) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedUnitId))) position) { x: ?x, y: ?z }) @entity.movementRange) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) ?x) (== (object/get (object/get @u position) y) ?z))))) 0))))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id @entity.selectedUnitId) (object/merge @u { position: { x: ?x, y: ?z } }) @u))))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      CANCEL -> playing when (!= @entity.selectedUnitId "")
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      BUILD_CAMP -> gameover when (and (>= @entity.wood @entity.woodGoal) (>= @entity.stone @entity.stoneGoal))
        (set @entity.features (array/append @entity.features { id: "camp-fire", x: 2, y: 0, type: "campfire", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-survival-kit/features/campfire-pit.glb", role: "decoration", category: "campfire-pit", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "campfire-pit", thumbnailUrl: "" } }))
        (set @entity.features (array/append @entity.features { id: "camp-tent", x: 3, y: 0, type: "tent", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-survival-kit/features/tent-canvas.glb", role: "decoration", category: "tent-canvas", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tent-canvas", thumbnailUrl: "" } }))
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.result "victory")
        (set @entity.fx (array/append @entity.fx { id: "fx-camp", type: "win", x: 2, z: 0, message: "Camp built!", ttl: 6 }))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      GAME_END -> gameover when (!= @entity.result "none")
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.units @config.units)
        (set @entity.features @config.features)
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.attackTargets [])
        (set @entity.fx [])
        (set @entity.wood 0)
        (set @entity.stone 0)
        (set @entity.result "none")
        (set @entity.energyLeft @config.turnBudget)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    ticks {
      animalWanderTick every 1200ms
        when (== @entity.result "none")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.team "neutral") (let ((nx (math/clamp (+ (object/get (object/get @u position) x) (math/sign (- (math/floor (+ @config.roamMinX (* (math/random) (+ (- @config.roamMaxX @config.roamMinX) 1)))) (object/get (object/get @u position) x)))) @config.roamMinX @config.roamMaxX)) (ny (math/clamp (+ (object/get (object/get @u position) y) (math/sign (- (math/floor (+ @config.roamMinY (* (math/random) (+ (- @config.roamMaxY @config.roamMinY) 1)))) (object/get (object/get @u position) y)))) @config.roamMinY @config.roamMaxY))) (let ((valid (and (== (object/get (array/find @entity.tiles (fn t (and (== (object/get t x) @nx) (== (object/get t y) @ny)))) passable) true) (== (array/len (array/filter @entity.units (fn o (and (== (object/get (object/get o position) x) @nx) (== (object/get (object/get o position) y) @ny))))) 0)))) (if @valid (object/merge @u { position: { x: @nx, y: @ny } }) @u))) @u))))
        (set @entity.fx (array/filter (array/map @entity.fx (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })

      energyTick every 1500ms
        when (== @entity.result "none")
        (set @entity.energyLeft (math/max 0 (- @entity.energyLeft 1)))
        (set @entity.result (if (<= @entity.energyLeft 0) "defeat" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Wood", value: @entity.wood }, { label: "Stone", value: @entity.stone }, { label: "Energy", value: @entity.energyLeft }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Gather 4 wood + 4 stone, then build camp" }, { label: "How", value: "Click survivor, then click an adjacent tile to move or gather" } ] }, { type: button, action: BUILD_CAMP, label: "Build Camp", variant: primary } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CANCEL, label: "Cancel", variant: secondary }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: stack, direction: vertical, gap: md, align: center, children: [ { type: game-hud, stats: [ { label: "Result", value: @entity.result } ] }, { type: button, action: PLAY_AGAIN, label: "Play Again", variant: primary } ] } null)
          children: [ { type: game-canvas-3d, cameraMode: "top-down", tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, tiles: @entity.tiles, units: @entity.units, features: @entity.features, events: @entity.fx, validMoves: @entity.validMoves, attackTargets: @entity.attackTargets, selectedUnitId: @entity.selectedUnitId, scale: @config.scale, unitScale: @config.unitScale } ]
        })
    }

    emits {
      UNIT_CLICK -> external {
        unitId : string!
        x : number
        z : number
      }
        @description "Selects the survivor unit and computes valid move tiles"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        z : number
        tileId : string
      }
        @description "Gathers an adjacent resource, or moves the survivor to a valid tile"
        @tier "domain"
      CANCEL -> external {
        id : string
      }
        @description "Clears the current unit selection"
        @tier "domain"
      BUILD_CAMP -> external {
        id : string
      }
        @description "Builds the camp (campfire + tent) once wood/stone goals are met"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Called when the match ends in victory or defeat"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets the board after victory or defeat"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : NatureSurvivalBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      groundAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/terrain/ground_grass.glb", role: "tile", category: "ground_grass", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "ground_grass", thumbnailUrl: "" }
        @label "Ground Asset"
        @description "Passable grass ground tile, tiled across the wilderness."
        @tier "presentation"
      riverAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-nature-survival-board-3d/kenney-nature-kit/terrain/ground_riverStraight.glb", role: "tile", category: "ground_riverStraight", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "ground_riverStraight", thumbnailUrl: "" }
        @label "River Asset"
