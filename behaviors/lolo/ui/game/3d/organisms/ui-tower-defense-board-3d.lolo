le-tree-quad.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tile-tree-quad", thumbnailUrl: "" } }, { id: "t55", x: 5, y: 5, terrain: "path", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/terrain/tile-dirt.glb", role: "path", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tile-dirt", thumbnailUrl: "" } }]
        @label "Tiles"
        @description "6x6 grid — dirt path from spawn to base, grass cells buildable, rock/tree/crystal cells blocked."
        @tier "presentation"
      path : [TowerDefenseBoard3DPathItem] = [{ index: 0, x: 0, y: 0 }, { index: 1, x: 0, y: 1 }, { index: 2, x: 0, y: 2 }, { index: 3, x: 1, y: 2 }, { index: 4, x: 2, y: 2 }, { index: 5, x: 3, y: 2 }, { index: 6, x: 3, y: 3 }, { index: 7, x: 3, y: 4 }, { index: 8, x: 4, y: 4 }, { index: 9, x: 5, y: 4 }, { index: 10, x: 5, y: 5 }]
        @label "Path"
        @description "Ordered waypoints enemies follow — index 0 is the spawn portal, the last index is the base."
        @tier "presentation"
      features : [TowerDefenseBoard3DFeaturesItem] = [{ id: "f-spawn", x: 0, y: 0, type: "spawn_portal", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/spawn-round.glb", role: "portal", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "spawn-round", thumbnailUrl: "" } }, { id: "f-base", x: 5, y: 5, type: "base", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/tower-round-build-f.glb", role: "base", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tower-round-build-f", thumbnailUrl: "" } }, { id: "f-tree1", x: 3, y: 1, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-tree.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-tree", thumbnailUrl: "" } }, { id: "f-rocks1", x: 2, y: 3, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-rocks.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-rocks", thumbnailUrl: "" } }, { id: "f-crystal1", x: 1, y: 4, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-crystal.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-crystal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Static spawn portal, base structure and tree/rock/crystal decoration."
        @tier "presentation"
      startingGold : number = 120
        @label "Starting Gold"
        @description "Gold available at match start"
        @tier "presentation"
      startingLives : number = 3
        @label "Starting Lives"
        @description "Lives before defeat"
        @tier "presentation"
      towerCost : number = 40
        @label "Tower Cost"
        @description "Gold spent per tower build; earned back via killReward per enemy killed"
        @tier "presentation"
      towerDamage : number = 2
        @label "Tower Damage"
        @description "Damage dealt per tick to enemies within 1 cell of a tower"
        @tier "presentation"
      killReward : number = 15
        @label "Kill Reward"
        @description "Gold earned per enemy killed by a tower"
        @tier "presentation"
      enemyHealth : number = 6
        @label "Enemy Health"
        @description "Base HP of each spawned enemy, scaled up per wave"
        @tier "presentation"
      maxWaves : number = 12
        @label "Max Waves"
        @description "Total enemies to survive for victory"
        @tier "presentation"
      towerAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/weapon-turret.glb", role: "tower", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "weapon-turret", thumbnailUrl: "" }
        @label "Tower Model"
        @description "GLB Asset placed at built tower cells"
        @tier "presentation"
      enemyAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/units/enemy-ufo-a.glb", role: "enemy", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "enemy-ufo-a", thumbnailUrl: "" }
        @label "Enemy Model"
        @description "GLB Asset for spawned enemies"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
    }
  }

  page "/tower-defense-board-3d" as TowerDefenseBoard3DPage -> TowerDefenseBoard3DRender
}
