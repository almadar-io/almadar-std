app ui-tower-defense-board-3d "1.0.0"
"TowerDefenseBoard3D — 3D one-lane tower-defense organism; build turrets beside the path to stop UFOs reaching the base."
orbital TowerDefenseBoard3DOrbital {
  type TowerDefenseBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type TowerDefenseBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type TowerDefenseBoard3DUnitsItemPosition = {
    x : number!
    y : number!
  }
  type TowerDefenseBoard3DUnitsItem = {
    id : string!
    position : TowerDefenseBoard3DUnitsItemPosition
    unitType : string
    name : string
    team : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    modelUrl : Asset
    pathIndex : number
  }
  type TowerDefenseBoard3DTowersItem = {
    id : string!
    x : number!
    y : number!
  }
  type TowerDefenseBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type TowerDefenseBoard3DPathItem = {
    index : number!
    x : number!
    y : number!
  }
  type TowerDefenseBoard3DFxItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type TowerDefenseBoard3DCoverageItem = {
    x : number!
    z : number!
  }

  entity TowerDefenseBoard3DItem [runtime] {
    id : string!
    units : [TowerDefenseBoard3DUnitsItem] = []
    towers : [TowerDefenseBoard3DTowersItem] = []
    fx : [TowerDefenseBoard3DFxItem] = []
    gold : number = 100
    lives : number = 3
    wave : number = 0
    result : "none" | "victory" | "defeat" = none
    gridWidth : number = 14
    gridHeight : number = 14
    tiles : [TowerDefenseBoard3DTilesItem] = []
    towerCoverage : [TowerDefenseBoard3DCoverageItem] = []
  }

  trait TowerDefenseBoard3DRender -> @rebindable TowerDefenseBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units [])
        (set @entity.towers [])
        (set @entity.fx [])
        (set @entity.gold @config.startingGold)
        (set @entity.lives @config.startingLives)
        (set @entity.wave 0)
        (set @entity.result "none")
        (set @entity.gridWidth 14)
        (set @entity.gridHeight 14)
        (set @entity.tiles (array/flatten (array/map (array/range 0 14) (fn gy (array/map (array/range 0 14) (fn gx (let ((onPath (> (array/len (array/filter @config.path (fn p (and (== @p.x @gx) (== @p.y @gy))))) 0))) { id: (str/concat "t-" @gx "-" @gy), x: @gx, y: @gy, terrain: (if @onPath "path" "grass"), passable: (if @onPath false true), modelUrl: (if @onPath @config.pathAsset @config.grassAsset) })))))))
        (set @entity.towerCoverage [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })

      TILE_CLICK -> playing when (and (== @entity.result "none") (>= @entity.gold @config.towerCost) (let ((tile (array/find @entity.tiles (fn t (and (== @t.x ?x) (== @t.y ?z)))))) (and (!= @tile null) (== (object/get @tile passable) true) (== (array/len (array/filter @entity.towers (fn tw (and (== @tw.x ?x) (== @tw.y ?z))))) 0))))
        (set @entity.gold (- @entity.gold @config.towerCost))
        (set @entity.towers (array/append @entity.towers { id: (str/concat "tower-" (array/len @entity.towers)), x: ?x, y: ?z }))
        (set @entity.fx (array/append @entity.fx { id: (str/concat "fx-build-" (array/len @entity.towers)), type: "pickup", x: ?x, z: ?z, message: "-40", ttl: 3 }))
        (set @entity.towerCoverage (array/map (array/filter @entity.tiles (fn t (and (== @t.passable true) (array/some @entity.towers (fn tw (<= (grid/manhattan-distance { x: @t.x, y: @t.y } { x: @tw.x, y: @tw.y }) @config.towerRange)))))) (fn t { x: @t.x, z: @t.y })))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })

      GAME_END -> gameover when (or (== @entity.result "victory") (== @entity.result "defeat"))
        (render-ui main {
          type: game-shell
          overlay: { type: game-menu, title: (if (== @entity.result "victory") "VICTORY" "DEFEAT"), subtitle: (str/concat "Reached wave " (str/concat @entity.wave (str/concat " of " @config.maxWaves))), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.units [])
        (set @entity.towers [])
        (set @entity.fx [])
        (set @entity.gold @config.startingGold)
        (set @entity.lives @config.startingLives)
        (set @entity.wave 0)
        (set @entity.result "none")
        (set @entity.gridWidth 14)
        (set @entity.gridHeight 14)
        (set @entity.tiles (array/flatten (array/map (array/range 0 14) (fn gy (array/map (array/range 0 14) (fn gx (let ((onPath (> (array/len (array/filter @config.path (fn p (and (== @p.x @gx) (== @p.y @gy))))) 0))) { id: (str/concat "t-" @gx "-" @gy), x: @gx, y: @gy, terrain: (if @onPath "path" "grass"), passable: (if @onPath false true), modelUrl: (if @onPath @config.pathAsset @config.grassAsset) })))))))
        (set @entity.towerCoverage [])
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })
    }

    ticks {
      enemySpawnTick every 1200ms
        when (and (== @entity.result "none") (< @entity.wave @config.maxWaves))
        (set @entity.units (array/append @entity.units { id: (str/concat "enemy-" @entity.wave), position: { x: (object/get (array/first @config.path) x), y: (object/get (array/first @config.path) y) }, unitType: "ufo", name: "Invader", team: enemy, health: (+ @config.enemyHealth (* @entity.wave 2)), maxHealth: (+ @config.enemyHealth (* @entity.wave 2)), modelUrl: @config.enemyAsset, pathIndex: 0 }))
        (set @entity.wave (+ @entity.wave 1))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })

      enemyMoveTick every 900ms
        when (and (== @entity.result "none") (> (array/len @entity.units) 0))
        (set @entity.units (array/map @entity.units (fn u (let ((nextIndex (math/min (+ @u.pathIndex 1) (- (array/len @config.path) 1))) (nextWaypoint (array/nth @config.path (math/min (+ @u.pathIndex 1) (- (array/len @config.path) 1))))) (object/merge @u { position: { x: (object/get @nextWaypoint x), y: (object/get @nextWaypoint y) }, pathIndex: @nextIndex })))))
        (set @entity.fx (array/concat @entity.fx (array/map (array/filter @entity.units (fn u (== @u.pathIndex (- (array/len @config.path) 1)))) (fn u { id: (str/concat "fx-leak-" @u.id), type: "damage", x: (object/get (object/get @u position) x), z: (object/get (object/get @u position) y), message: "-1 life", ttl: 3 }))))
        (set @entity.lives (math/max 0 (- @entity.lives (array/len (array/filter @entity.units (fn u (== @u.pathIndex (- (array/len @config.path) 1))))))))
        (set @entity.units (array/filter @entity.units (fn u (< @u.pathIndex (- (array/len @config.path) 1)))))
        (set @entity.result (if (<= @entity.lives 0) "defeat" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (set @entity.result (if (and (>= @entity.wave @config.maxWaves) (and (> @entity.lives 0) (== (array/len @entity.units) 0))) "victory" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })

      towerFireTick every 900ms
        when (and (== @entity.result "none") (> (array/len @entity.units) 0))
        (set @entity.units (array/map @entity.units (fn u (if (and (> @u.health 0) (array/some @entity.towers (fn tw (<= (grid/manhattan-distance (object/get @u position) { x: @tw.x, y: @tw.y }) @config.towerRange)))) (object/merge @u { health: (math/max 0 (- @u.health @config.towerDamage)) }) @u))))
        (set @entity.gold (+ @entity.gold (* (array/len (array/filter @entity.units (fn u (<= @u.health 0)))) @config.killReward)))
        (set @entity.fx (array/concat @entity.fx (array/map (array/filter @entity.units (fn u (<= @u.health 0))) (fn u { id: (str/concat "fx-kill-" @u.id), type: "score", x: (object/get (object/get @u position) x), z: (object/get (object/get @u position) y), message: "+15", ttl: 3 }))))
        (set @entity.units (array/filter @entity.units (fn u (> @u.health 0))))
        (set @entity.fx (array/filter (array/map @entity.fx (fn e (object/merge @e { ttl: (- @e.ttl 1) }))) (fn e (> @e.ttl 0))))
        (set @entity.result (if (and (>= @entity.wave @config.maxWaves) (and (> @entity.lives 0) (== (array/len @entity.units) 0))) "victory" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END { result: @entity.result }) null)
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Gold", value: @entity.gold }, { label: "Lives", value: @entity.lives }, { label: "Wave", value: @entity.wave }, { label: "Result", value: @entity.result }, { label: "Range", value: @config.towerRange }, { label: "Goal", value: (str/concat "Survive " (str/concat @config.maxWaves " waves")) }, { label: "How", value: "Click grass beside the lane to build a turret (40g) — turrets auto-fire enemies within range" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          children: [ { type: game-canvas-3d, cameraMode: "top-down", scale: @config.scale, unitScale: @config.unitScale, interpolateUnits: true, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map (array/concat @config.features (array/map @entity.towers (fn t { id: @t.id, x: @t.x, y: @t.y, type: "tower", assetUrl: @config.towerAsset }))) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.towerCoverage (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m z) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u modelUrl) })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), offsetY: -0.6, width: (* 0.8 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn f { type: draw-text, text: (object/get @f message), position: { x: (object/get @f x), y: (object/get @f z) }, color: "#ffe066" })) }
          ] } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        tileId : string
        x : number!
        z : number
      }
        @description "Emits UI:{tileClickEvent} with { x, z } — builds a tower on a buildable grass cell"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Called when lives reach 0 (defeat) or all waves are cleared with lives left (victory)"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : TowerDefenseBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      pathAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/terrain/tile-dirt.glb", role: "path", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tile-dirt", thumbnailUrl: "" }
        @label "Path Tile"
        @description "Dirt tile Asset used for every lane cell"
        @tier "presentation"
      grassAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/terrain/tile.glb", role: "tile", category: "terrain", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tile", thumbnailUrl: "" }
        @label "Grass Tile"
        @description "Buildable grass tile Asset used for every non-lane cell"
        @tier "presentation"
      path : [TowerDefenseBoard3DPathItem] = [{ index: 0, x: 0, y: 1 }, { index: 1, x: 1, y: 1 }, { index: 2, x: 2, y: 1 }, { index: 3, x: 3, y: 1 }, { index: 4, x: 4, y: 1 }, { index: 5, x: 5, y: 1 }, { index: 6, x: 6, y: 1 }, { index: 7, x: 7, y: 1 }, { index: 8, x: 8, y: 1 }, { index: 9, x: 9, y: 1 }, { index: 10, x: 10, y: 1 }, { index: 11, x: 11, y: 1 }, { index: 12, x: 12, y: 1 }, { index: 13, x: 13, y: 1 }, { index: 14, x: 13, y: 2 }, { index: 15, x: 13, y: 3 }, { index: 16, x: 13, y: 4 }, { index: 17, x: 12, y: 4 }, { index: 18, x: 11, y: 4 }, { index: 19, x: 10, y: 4 }, { index: 20, x: 9, y: 4 }, { index: 21, x: 8, y: 4 }, { index: 22, x: 7, y: 4 }, { index: 23, x: 6, y: 4 }, { index: 24, x: 5, y: 4 }, { index: 25, x: 4, y: 4 }, { index: 26, x: 3, y: 4 }, { index: 27, x: 2, y: 4 }, { index: 28, x: 1, y: 4 }, { index: 29, x: 0, y: 4 }, { index: 30, x: 0, y: 5 }, { index: 31, x: 0, y: 6 }, { index: 32, x: 0, y: 7 }, { index: 33, x: 1, y: 7 }, { index: 34, x: 2, y: 7 }, { index: 35, x: 3, y: 7 }, { index: 36, x: 4, y: 7 }, { index: 37, x: 5, y: 7 }, { index: 38, x: 6, y: 7 }, { index: 39, x: 7, y: 7 }, { index: 40, x: 8, y: 7 }, { index: 41, x: 9, y: 7 }, { index: 42, x: 10, y: 7 }, { index: 43, x: 11, y: 7 }, { index: 44, x: 12, y: 7 }, { index: 45, x: 13, y: 7 }, { index: 46, x: 13, y: 8 }, { index: 47, x: 13, y: 9 }, { index: 48, x: 13, y: 10 }, { index: 49, x: 12, y: 10 }, { index: 50, x: 11, y: 10 }, { index: 51, x: 10, y: 10 }, { index: 52, x: 9, y: 10 }, { index: 53, x: 8, y: 10 }, { index: 54, x: 7, y: 10 }, { index: 55, x: 6, y: 10 }, { index: 56, x: 5, y: 10 }, { index: 57, x: 4, y: 10 }, { index: 58, x: 3, y: 10 }, { index: 59, x: 2, y: 10 }, { index: 60, x: 1, y: 10 }, { index: 61, x: 0, y: 10 }, { index: 62, x: 0, y: 11 }, { index: 63, x: 0, y: 12 }, { index: 64, x: 0, y: 13 }, { index: 65, x: 1, y: 13 }, { index: 66, x: 2, y: 13 }, { index: 67, x: 3, y: 13 }, { index: 68, x: 4, y: 13 }, { index: 69, x: 5, y: 13 }, { index: 70, x: 6, y: 13 }]
        @label "Path"
        @description "Ordered waypoints enemies follow — index 0 is the spawn portal, the last index is the base. Also drives procedural tile generation."
        @tier "presentation"
      features : [TowerDefenseBoard3DFeaturesItem] = [{ id: "f-spawn", x: 0, y: 1, type: "spawn_portal", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/spawn-round.glb", role: "portal", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "spawn-round", thumbnailUrl: "" } }, { id: "f-base", x: 6, y: 13, type: "base", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/tower-round-build-f.glb", role: "base", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tower-round-build-f", thumbnailUrl: "" } }, { id: "f-tree1", x: 7, y: 2, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-tree.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-tree", thumbnailUrl: "" } }, { id: "f-rocks1", x: 10, y: 3, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-rocks.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-rocks", thumbnailUrl: "" } }, { id: "f-crystal1", x: 4, y: 2, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-crystal.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-crystal", thumbnailUrl: "" } }, { id: "f-tree2", x: 9, y: 9, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-tree.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-tree", thumbnailUrl: "" } }, { id: "f-rocks2", x: 10, y: 12, type: "decoration", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/detail-rocks.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-rocks", thumbnailUrl: "" } }]
        @label "Features"
        @description "Spawn portal, base structure and tree/rock/crystal decoration scattered off the lane."
        @tier "presentation"
      towerRange : number = 1
        @label "Tower Range"
        @description "Manhattan-distance radius within which a tower damages enemies each tick; also drives the build-preview coverage highlight"
        @tier "presentation"
      startingGold : number = 160
        @label "Starting Gold"
        @description "Gold available at match start"
        @tier "presentation"
      startingLives : number = 3
        @label "Starting Lives"
        @description "Lives before defeat"
        @tier "presentation"
      towerCost : number = 40
        @label "Tower Cost"
        @description "Gold spent per tower build; earned back via killReward per enemy killed"
        @tier "presentation"
      towerDamage : number = 2
        @label "Tower Damage"
        @description "Damage dealt per tick to enemies within 1 cell of a tower"
        @tier "presentation"
      killReward : number = 15
        @label "Kill Reward"
        @description "Gold earned per enemy killed by a tower"
        @tier "presentation"
      enemyHealth : number = 6
        @label "Enemy Health"
        @description "Base HP of each spawned enemy, scaled up per wave"
        @tier "presentation"
      maxWaves : number = 14
        @label "Max Waves"
        @description "Total enemies to survive for victory"
        @tier "presentation"
      towerAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/features/weapon-turret.glb", role: "tower", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "weapon-turret", thumbnailUrl: "" }
        @label "Tower Model"
        @description "GLB Asset placed at built tower cells"
        @tier "presentation"
      enemyAsset : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board-3d/kenney-tower-defense-kit/units/enemy-ufo-a.glb", role: "enemy", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "enemy-ufo-a", thumbnailUrl: "" }
        @label "Enemy Model"
        @description "GLB Asset for spawned enemies"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
    }
  }

  page "/tower-defense-board-3d" as TowerDefenseBoard3DPage -> TowerDefenseBoard3DRender
}
