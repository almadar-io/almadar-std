app ui-game-canvas-3d "1.0.0"
"GameCanvas3d — UI factory (1:1 with the @almadar/ui game-canvas-3d pattern)."
orbital GameCanvas3dOrbital {
  type GameCanvas3dEventsItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
  }
  type GameCanvas3dValidMovesItem = {
    x : number!
    z : number!
  }
  type GameCanvas3dAttackTargetsItem = {
    x : number!
    z : number!
  }
  type GameCanvas3dPlayer = {
    x : number!
    y : number!
    width : number
    height : number
    vx : number
    vy : number
    grounded : boolean
    facingRight : boolean
    animation : string
    frame : number
  }
  type GameCanvas3dPlatformsItem = {
    x : number!
    y : number!
    width : number!
    height : number!
    type : "ground" | "platform" | "hazard" | "goal"
  }
  type GameCanvas3dPlayerSprite = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dTileSpritesValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dAssetManifest = {
    terrains : Map string GameCanvas3dAssetManifestTerrainsValue
    units : Map string GameCanvas3dAssetManifestUnitsValue
    features : Map string GameCanvas3dAssetManifestFeaturesValue
    effects : Map string GameCanvas3dAssetManifestEffectsValue
  }
  type GameCanvas3dAssetManifestTerrainsValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dAssetManifestUnitsValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dAssetManifestFeaturesValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type GameCanvas3dAssetManifestEffectsValue = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity GameCanvas3dItem [runtime] {
    id : string!
  }

  trait GameCanvas3dRender -> @rebindable GameCanvas3dItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          events: @config.events
          fogOfWar: @config.fogOfWar
          orientation: @config.orientation
          cameraMode: @config.cameraMode
          showGrid: @config.showGrid
          showCoordinates: @config.showCoordinates
          showTileInfo: @config.showTileInfo
          overlay: @config.overlay
          shadows: @config.shadows
          backgroundColor: @config.backgroundColor
          onTileClick: TILE_CLICK
          onUnitClick: UNIT_CLICK
          onFeatureClick: FEATURE_CLICK
          onCanvasClick: CANVAS_CLICK
          onTileHover: TILE_HOVER
          onUnitAnimation: UNIT_ANIMATION
          preloadAssets: @config.preloadAssets
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          featureClickEvent: FEATURE_CLICK
          canvasClickEvent: CANVAS_CLICK
          tileHoverEvent: TILE_HOVER
          tileLeaveEvent: TILE_LEAVE
          unitAnimationEvent: UNIT_ANIMATION
          cameraChangeEvent: CAMERA_CHANGE
          loadingMessage: @config.loadingMessage
          useInstancing: @config.useInstancing
          validMoves: @config.validMoves
          attackTargets: @config.attackTargets
          selectedTileIds: @config.selectedTileIds
          selectedUnitId: @config.selectedUnitId
          unitScale: @config.unitScale
          scale: @config.scale
          keyMap: @config.keyMap
          keyUpMap: @config.keyUpMap
          player: @config.player
          platforms: @config.platforms
          worldWidth: @config.worldWidth
          worldHeight: @config.worldHeight
          pixelsPerUnit: @config.pixelsPerUnit
          playerSprite: @config.playerSprite
          tileSprites: @config.tileSprites
          assetManifest: @config.assetManifest
          interpolateUnits: @config.interpolateUnits
          type: game-canvas-3d
        })
    }

    emits {
      TILE_CLICK -> external {
        tile : object
        event : object
        tileId : string!
        x : number!
        z : number!
        terrain : string
        elevation : number
      }
        @description "Callback when a tile is clicked"
        @tier "essential"
      UNIT_CLICK -> external {
        unit : object
        event : object
        unitId : string!
        x : number!
        z : number!
        unitType : string
        name : string
        team : string
        faction : string
        health : number
        maxHealth : number
      }
        @description "Callback when a unit is clicked"
        @tier "essential"
      FEATURE_CLICK -> external {
        feature : object
        event : object
        featureId : string!
        x : number!
        z : number!
        elevation : number
      }
        @description "Callback when a feature is clicked"
        @tier "essential"
      CANVAS_CLICK -> external {
        event : object
        clientX : number!
        clientY : number!
        button : number!
      }
        @description "Callback when canvas is clicked (background)"
        @tier "essential"
      TILE_HOVER -> external {
        tile : object
        event : object
        tileId : string!
        x : number!
        z : number!
      }
        @description "Callback when mouse moves over a tile"
        @tier "essential"
      UNIT_ANIMATION -> external {
        unitId : string
        state : string
        timestamp : number!
      }
        @description "Callback for unit animation state change"
        @tier "essential"
      TILE_LEAVE -> external {
        id : string
      }
        @description "Declarative event: tile leave"
        @tier "essential"
      CAMERA_CHANGE -> external {
        position : object!
        timestamp : number!
      }
        @description "Declarative event: camera change"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "--- Closed-circuit props (MANDATORY) ---"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : string = ""
        @label "Error"
        @description "Error state"
        @tier "presentation"
      tiles : [json] = []
        @label "Tiles"
        @description "Array of tiles to render"
        @tier "presentation"
      units : [json] = []
        @label "Units"
        @description "Array of units to render"
        @tier "presentation"
      features : [json] = []
        @label "Features"
        @description "Array of features to render"
        @tier "presentation"
      events : [GameCanvas3dEventsItem] = [{ id: "e1", x: 2, y: 2, type: "spawn", message: "Unit spawned" }, { id: "e2", x: 3, y: 1, type: "effect", message: "Attack landed" }]
        @label "Events"
        @description "Array of events to display"
        @tier "presentation"
      fogOfWar : [[boolean]] = []
        @label "Fog Of War"
        @description "Fog of war data"
        @tier "presentation"
      orientation : "standard" | "rotated" = standard
        @label "Orientation"
        @description "Map orientation"
        @tier "presentation"
      cameraMode : "pan-zoom" | "follow" | "fixed" = "pan-zoom"
        @label "Camera Mode"
        @description "Camera mode"
        @tier "presentation"
      showGrid : boolean = true
        @label "Show Grid"
        @description "Show grid"
        @tier "presentation"
      showCoordinates : boolean = false
        @label "Show Coordinates"
        @description "Show coordinates overlay"
        @tier "presentation"
      showTileInfo : boolean = false
        @label "Show Tile Info"
        @description "Show tile information"
        @tier "presentation"
      overlay : "default" | "hidden" | "minimap" = default
        @label "Overlay"
        @description "Overlay control mode"
        @tier "presentation"
      shadows : boolean = true
        @label "Shadows"
        @description "Enable shadows"
        @tier "presentation"
      backgroundColor : string = "#1a1a2e"
        @label "Background Color"
        @description "Background color"
        @tier "presentation"
      preloadAssets : [string] = []
        @label "Preload Assets"
        @description "URLs to preload"
        @tier "presentation"
      loadingMessage : string = "Loading 3D Scene..."
        @label "Loading Message"
        @description "Loading message"
        @tier "presentation"
      useInstancing : boolean = true
        @label "Use Instancing"
        @description "Whether to use instancing for tiles"
        @tier "presentation"
      validMoves : [GameCanvas3dValidMovesItem] = [{ x: 1, z: 1 }, { x: 2, z: 2 }]
        @label "Valid Moves"
        @description "Valid move positions"
        @tier "presentation"
      attackTargets : [GameCanvas3dAttackTargetsItem] = [{ x: 1, z: 1 }, { x: 2, z: 2 }]
        @label "Attack Targets"
        @description "Attack target positions"
        @tier "presentation"
      selectedTileIds : [string] = []
        @label "Selected Tile Ids"
        @description "Selected tile IDs"
        @tier "presentation"
      selectedUnitId : string = ""
        @label "Selected Unit Id"
        @description "Selected unit ID"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier. 1 = default tile-proportional size."
        @tier "presentation"
      scale : number = 0
        @label "Scale"
        @description "Board zoom/group scale. Applied to the scene group. Default 0.45."
        @tier "presentation"
      keyMap : Map string string = { item: "Item" }
        @label "Key Map"
        @description "Maps a keydown `e.code` → the board's SEMANTIC event, e.g. `{ ArrowLeft: 'LEFT', Space: 'JUMP' }`. The input layer emits `UI:<event>` so the FSM stays device-agnostic — keyboard and d-pad converge."
        @tier "presentation"
      keyUpMap : Map string string = { item: "Item" }
        @label "Key Up Map"
        @description "Maps a keyup `e.code` → the board's SEMANTIC event, e.g. `{ ArrowLeft: 'STOP' }`."
        @tier "presentation"
      player : GameCanvas3dPlayer = { x: 1, y: 1, width: 1, height: 1, vx: 1, vy: 1, grounded: false, facingRight: false, animation: "Animation", frame: 1 }
        @label "Player"
        @description "Side-view player (pixel coords, LOLO-owned physics) — presence switches to side-scroller rendering."
        @tier "presentation"
      platforms : [GameCanvas3dPlatformsItem] = [{ x: 1, y: 1, width: 1, height: 1, type: ground }, { x: 2, y: 2, width: 2, height: 2, type: platform }]
        @label "Platforms"
        @description "Side-view level geometry (pixel AABBs, same contract as Canvas2D)."
        @tier "presentation"
      worldWidth : number = 0
        @label "World Width"
        @description "Side-view world size in pixels."
        @tier "presentation"
      worldHeight : number = 400
        @label "World Height"
        @description "Side-view world size in pixels."
        @tier "presentation"
      pixelsPerUnit : number = 32
        @label "Pixels Per Unit"
        @description "Pixel→world-unit divisor for side view (default 32 = one 2D tile per 3D cell)."
        @tier "presentation"
      playerSprite : GameCanvas3dPlayerSprite = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "player", category: "playerSprite", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "playerSprite", thumbnailUrl: "" }
        @label "Player Sprite"
        @description "Player model — named for 2D parity; in 3D the Asset's url is a GLB."
        @tier "presentation"
      tileSprites : Map string GameCanvas3dTileSpritesValue = {}
        @label "Tile Sprites"
        @description "Platform-type → model map — named for 2D parity; values are GLB Assets."
        @tier "presentation"
      assetManifest : GameCanvas3dAssetManifest = { terrains: { grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, dirt: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/terrain/floor.png", role: "tile", category: "dirt", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "dirt", thumbnailUrl: "" }, stone: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, forest: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/grass.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, castle: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/terrain/wall.png", role: "tile", category: "castle", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "castle", thumbnailUrl: "" } }, units: { worker: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/creep.png", role: "npc", category: "worker", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "worker", thumbnailUrl: "" }, guardian: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/units/hero.png", role: "npc", category: "guardian", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "guardian", thumbnailUrl: "" }, scrapper: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/enemy.png", role: "npc", category: "scrapper", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "scrapper", thumbnailUrl: "" }, mender: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "mender", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "mender", thumbnailUrl: "" } }, features: { gold_mine: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/features/tower.png", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" }, portal: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/features/health_potion.png", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" }, castle: { url: "https://almadar-kflow-assets.web.app/shared/ui-tower-defense-board/default/features/tower.png", role: "decoration", category: "castle", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "castle", thumbnailUrl: "" } }, effects: {} }
        @label "Asset Manifest"
        @description "Per-role model manifest; resolves tiles/units/features without explicit modelUrl/assetUrl."
        @tier "presentation"
      interpolateUnits : boolean = false
        @label "Interpolate Units"
        @description "Opt-in: smooth-lerp unit positions between LOLO tick snapshots. DEFAULT OFF."
        @tier "presentation"
    }
  }

  page "/game-canvas-3d" as GameCanvas3dPage -> GameCanvas3dRender
}
