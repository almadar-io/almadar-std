app ui-pinball-board "1.0.0"
"PinballBoard — flipper pinball: launch the ball, flip to bounce it into bumpers for points, three drains ends the game."
orbital PinballBoardOrbital {
  type PinballBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type PinballBoardBallState = {
    x : number!
    y : number!
    vx : number!
    vy : number!
  }
  type PinballBoardBumperItem = {
    id : string!
    x : number!
    y : number!
  }
  type PinballBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type PinballBoardAssetManifest = {
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
    background : Asset
  }

  entity PinballBoardItem [runtime] {
    id : string!
    ball : PinballBoardBallState
    score : number = 0
    balls : number = 3
    audioEnabled : boolean = true
    ballLive : boolean = false
    leftFlipperActive : boolean = false
    rightFlipperActive : boolean = false
    result : "none" | "lost" = none
    effects : [PinballBoardEffectItem] = []
  }

  trait PinballBoardRender -> @rebindable PinballBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.ball { x: @config.launchX, y: @config.launchY, vx: 0, vy: 0 })
        (set @entity.score 0)
        (set @entity.balls @config.startingBalls)
        (set @entity.audioEnabled true)
        (set @entity.ballLive false)
        (set @entity.leftFlipperActive false)
        (set @entity.rightFlipperActive false)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "star.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Balls", value: @entity.balls, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-balls", thumbnailUrl: "" } } ] }, { type: game-audio-toggle } ] }
          controls: { type: button, action: LEFT_FLIPPER, label: "Left Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_w.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-left-flipper", thumbnailUrl: "" }, variant: primary }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: LAUNCH, label: "Launch", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_arrowUpWhite.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-launch", thumbnailUrl: "" }, variant: primary }, { type: button, action: RIGHT_FLIPPER, label: "Right Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_e.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-right-flipper", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { KeyZ: "LEFT_FLIPPER", ArrowLeft: "LEFT_FLIPPER", KeySlash: "RIGHT_FLIPPER", ArrowRight: "RIGHT_FLIPPER", Space: "LAUNCH" }, children: [
            { type: draw-sprite-layer, items: (array/map (array/concat (array/map @config.bumpers (fn b { id: @b.id, x: @b.x, y: @b.y, type: "bumper", sprite: (object/get (object/get @config.assetManifest features) bumper) })) [ { id: "flipperL", x: @config.leftFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.leftFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) }, { id: "flipperR", x: @config.rightFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.rightFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) } ]) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map [ { id: "ball", position: { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }, sprite: (object/get (object/get @config.assetManifest units) ball), team: "player" } ] (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      LEFT_FLIPPER -> playing when (== @entity.result "none")
        (set @entity.leftFlipperActive true)

      RIGHT_FLIPPER -> playing when (== @entity.result "none")
        (set @entity.rightFlipperActive true)

      LAUNCH -> playing when (and (== @entity.result "none") (not @entity.ballLive))
        (set @entity.ballLive true)
        (set @entity.ball { x: @config.launchX, y: @config.launchY, vx: @config.launchVx, vy: (- 0 @config.launchSpeed) })

      TOGGLE_AUDIO -> playing
        (set @entity.audioEnabled (not @entity.audioEnabled))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "star.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Balls", value: @entity.balls, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-balls", thumbnailUrl: "" } } ] }, { type: game-audio-toggle } ] }
          controls: { type: button, action: LEFT_FLIPPER, label: "Left Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_w.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-left-flipper", thumbnailUrl: "" }, variant: primary }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: LAUNCH, label: "Launch", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_arrowUpWhite.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-launch", thumbnailUrl: "" }, variant: primary }, { type: button, action: RIGHT_FLIPPER, label: "Right Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_e.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-right-flipper", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { KeyZ: "LEFT_FLIPPER", ArrowLeft: "LEFT_FLIPPER", KeySlash: "RIGHT_FLIPPER", ArrowRight: "RIGHT_FLIPPER", Space: "LAUNCH" }, children: [
            { type: draw-sprite-layer, items: (array/map (array/concat (array/map @config.bumpers (fn b { id: @b.id, x: @b.x, y: @b.y, type: "bumper", sprite: (object/get (object/get @config.assetManifest features) bumper) })) [ { id: "flipperL", x: @config.leftFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.leftFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) }, { id: "flipperR", x: @config.rightFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.rightFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) } ]) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map [ { id: "ball", position: { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }, sprite: (object/get (object/get @config.assetManifest units) ball), team: "player" } ] (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      GAME_END -> gameover when (== @entity.result "lost")
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "star.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Balls", value: @entity.balls, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-balls", thumbnailUrl: "" } } ] }, { type: game-audio-toggle } ] }
          controls: { type: button, action: LEFT_FLIPPER, label: "Left Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_w.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-left-flipper", thumbnailUrl: "" }, variant: primary }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: LAUNCH, label: "Launch", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_arrowUpWhite.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-launch", thumbnailUrl: "" }, variant: primary }, { type: button, action: RIGHT_FLIPPER, label: "Right Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_e.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-right-flipper", thumbnailUrl: "" }, variant: primary } ] }
          overlay: { type: game-menu, title: "GAME OVER", subtitle: (str/concat "Final Score: " @entity.score), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { KeyZ: "LEFT_FLIPPER", ArrowLeft: "LEFT_FLIPPER", KeySlash: "RIGHT_FLIPPER", ArrowRight: "RIGHT_FLIPPER", Space: "LAUNCH" }, children: [
            { type: draw-sprite-layer, items: (array/map (array/concat (array/map @config.bumpers (fn b { id: @b.id, x: @b.x, y: @b.y, type: "bumper", sprite: (object/get (object/get @config.assetManifest features) bumper) })) [ { id: "flipperL", x: @config.leftFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.leftFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) }, { id: "flipperR", x: @config.rightFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.rightFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) } ]) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map [ { id: "ball", position: { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }, sprite: (object/get (object/get @config.assetManifest units) ball), team: "player" } ] (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.ball { x: @config.launchX, y: @config.launchY, vx: 0, vy: 0 })
        (set @entity.score 0)
        (set @entity.balls @config.startingBalls)
        (set @entity.ballLive false)
        (set @entity.leftFlipperActive false)
        (set @entity.rightFlipperActive false)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "star.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Balls", value: @entity.balls, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-balls", thumbnailUrl: "" } } ] }, { type: game-audio-toggle } ] }
          controls: { type: button, action: LEFT_FLIPPER, label: "Left Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_w.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-left-flipper", thumbnailUrl: "" }, variant: primary }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: LAUNCH, label: "Launch", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_arrowUpWhite.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-launch", thumbnailUrl: "" }, variant: primary }, { type: button, action: RIGHT_FLIPPER, label: "Right Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_e.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-right-flipper", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { KeyZ: "LEFT_FLIPPER", ArrowLeft: "LEFT_FLIPPER", KeySlash: "RIGHT_FLIPPER", ArrowRight: "RIGHT_FLIPPER", Space: "LAUNCH" }, children: [
            { type: draw-sprite-layer, items: (array/map (array/concat (array/map @config.bumpers (fn b { id: @b.id, x: @b.x, y: @b.y, type: "bumper", sprite: (object/get (object/get @config.assetManifest features) bumper) })) [ { id: "flipperL", x: @config.leftFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.leftFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) }, { id: "flipperR", x: @config.rightFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.rightFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) } ]) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map [ { id: "ball", position: { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }, sprite: (object/get (object/get @config.assetManifest units) ball), team: "player" } ] (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    ticks {
      physicsTick every 90ms
        when (and (== @entity.result "none") @entity.ballLive)
        (set @entity.ball (object/merge @entity.ball { vy: (+ (object/get @entity.ball vy) @config.gravity) }))
        (set @entity.ball (object/merge @entity.ball { x: (+ (object/get @entity.ball x) (object/get @entity.ball vx)), y: (+ (object/get @entity.ball y) (object/get @entity.ball vy)) }))
        (set @entity.ball (if (<= (object/get @entity.ball x) @config.ballRadius) (object/merge @entity.ball { x: @config.ballRadius, vx: (math/max (object/get @entity.ball vx) (- 0 (object/get @entity.ball vx))) }) @entity.ball))
        (set @entity.ball (if (>= (object/get @entity.ball x) (- @config.width @config.ballRadius)) (object/merge @entity.ball { x: (- @config.width @config.ballRadius), vx: (math/min (object/get @entity.ball vx) (- 0 (object/get @entity.ball vx))) }) @entity.ball))
        (set @entity.ball (if (<= (object/get @entity.ball y) @config.ballRadius) (object/merge @entity.ball { y: @config.ballRadius, vy: (math/max (object/get @entity.ball vy) (- 0 (object/get @entity.ball vy))) }) @entity.ball))
        (set @entity.score (+ @entity.score (* @config.bumperScore (array/len (array/filter @config.bumpers (fn b (<= (vec/distance { x: @b.x, y: @b.y } { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }) @config.bumperRadius)))))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @config.bumpers (fn b (<= (vec/distance { x: @b.x, y: @b.y } { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }) @config.bumperRadius))) (fn b { key: "spark", x: @b.x, y: @b.y, ttl: 4 }))))
        (set @entity.ball (if (> (array/len (array/filter @config.bumpers (fn b (<= (vec/distance { x: @b.x, y: @b.y } { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }) @config.bumperRadius)))) 0) (object/merge @entity.ball { vx: (* @config.bumperKick (- (object/get @entity.ball x) (object/get (array/find @config.bumpers (fn b (<= (vec/distance { x: @b.x, y: @b.y } { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }) @config.bumperRadius))) x))), vy: (* @config.bumperKick (- (object/get @entity.ball y) (object/get (array/find @config.bumpers (fn b (<= (vec/distance { x: @b.x, y: @b.y } { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }) @config.bumperRadius))) y))) }) @entity.ball))
        (set @entity.ball (if (and @entity.leftFlipperActive (and (< (object/get @entity.ball x) (/ @config.width 2)) (> (object/get @entity.ball y) @config.flipperZoneY))) (object/merge @entity.ball { vy: (- 0 @config.flipperPower), vx: (+ (object/get @entity.ball vx) @config.flipperSideKick) }) @entity.ball))
        (set @entity.ball (if (and @entity.rightFlipperActive (and (>= (object/get @entity.ball x) (/ @config.width 2)) (> (object/get @entity.ball y) @config.flipperZoneY))) (object/merge @entity.ball { vy: (- 0 @config.flipperPower), vx: (- (object/get @entity.ball vx) @config.flipperSideKick) }) @entity.ball))
        (set @entity.leftFlipperActive false)
        (set @entity.rightFlipperActive false)
        (set @entity.balls (if (> (object/get @entity.ball y) @config.height) (- @entity.balls 1) @entity.balls))
        (set @entity.result (if (and (> (object/get @entity.ball y) @config.height) (<= @entity.balls 0)) "lost" @entity.result))
        (set @entity.ballLive (if (> (object/get @entity.ball y) @config.height) false @entity.ballLive))
        (set @entity.ball (if (> (object/get @entity.ball y) @config.height) { x: @config.launchX, y: @config.launchY, vx: 0, vy: 0 } @entity.ball))
        (set @entity.effects (array/filter (array/map @entity.effects (fn ef (object/merge @ef { ttl: (- (object/get @ef ttl) 1) }))) (fn ef (> (object/get @ef ttl) 0))))
        (if (== @entity.result "lost") (emit GAME_END { result: "lost" }) null)
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "star.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Balls", value: @entity.balls, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-balls", thumbnailUrl: "" } } ] }, { type: game-audio-toggle } ] }
          controls: { type: button, action: LEFT_FLIPPER, label: "Left Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_w.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-left-flipper", thumbnailUrl: "" }, variant: primary }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: LAUNCH, label: "Launch", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_arrowUpWhite.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-launch", thumbnailUrl: "" }, variant: primary }, { type: button, action: RIGHT_FLIPPER, label: "Right Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_e.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-right-flipper", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { KeyZ: "LEFT_FLIPPER", ArrowLeft: "LEFT_FLIPPER", KeySlash: "RIGHT_FLIPPER", ArrowRight: "RIGHT_FLIPPER", Space: "LAUNCH" }, children: [
            { type: draw-sprite-layer, items: (array/map (array/concat (array/map @config.bumpers (fn b { id: @b.id, x: @b.x, y: @b.y, type: "bumper", sprite: (object/get (object/get @config.assetManifest features) bumper) })) [ { id: "flipperL", x: @config.leftFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.leftFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) }, { id: "flipperR", x: @config.rightFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.rightFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) } ]) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map [ { id: "ball", position: { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }, sprite: (object/get (object/get @config.assetManifest units) ball), team: "player" } ] (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      idleTick every 150ms
        when (and (== @entity.result "none") (not @entity.ballLive))
        (set @entity.effects (array/filter (array/map @entity.effects (fn ef (object/merge @ef { ttl: (- (object/get @ef ttl) 1) }))) (fn ef (> (object/get @ef ttl) 0))))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "star.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Balls", value: @entity.balls, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-balls", thumbnailUrl: "" } } ] }, { type: game-audio-toggle } ] }
          controls: { type: button, action: LEFT_FLIPPER, label: "Left Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_w.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-left-flipper", thumbnailUrl: "" }, variant: primary }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: LAUNCH, label: "Launch", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_arrowUpWhite.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-launch", thumbnailUrl: "" }, variant: primary }, { type: button, action: RIGHT_FLIPPER, label: "Right Flipper", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "arrow_e.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-right-flipper", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { KeyZ: "LEFT_FLIPPER", ArrowLeft: "LEFT_FLIPPER", KeySlash: "RIGHT_FLIPPER", ArrowRight: "RIGHT_FLIPPER", Space: "LAUNCH" }, children: [
            { type: draw-sprite-layer, items: (array/map (array/concat (array/map @config.bumpers (fn b { id: @b.id, x: @b.x, y: @b.y, type: "bumper", sprite: (object/get (object/get @config.assetManifest features) bumper) })) [ { id: "flipperL", x: @config.leftFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.leftFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) }, { id: "flipperR", x: @config.rightFlipperX, y: @config.flipperY, type: "paddle", sprite: (if @entity.rightFlipperActive (object/get (object/get @config.assetManifest features) paddleActive) (object/get (object/get @config.assetManifest features) paddle)) } ]) (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
            { type: draw-sprite-layer, items: (array/map [ { id: "ball", position: { x: (object/get @entity.ball x), y: (object/get @entity.ball y) }, sprite: (object/get (object/get @config.assetManifest units) ball), team: "player" } ] (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    emits {
      LEFT_FLIPPER -> external {
        id : string
      }
        @description "Left flipper flick (KeyZ / ArrowLeft / Left Flipper button)"
        @tier "domain"
      RIGHT_FLIPPER -> external {
        id : string
      }
        @description "Right flipper flick (KeySlash / ArrowRight / Right Flipper button)"
        @tier "domain"
      LAUNCH -> external {
        id : string
      }
        @description "Launches the ball from the plunger lane (Space / Launch button)"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Emits when the last ball drains"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} on reset"
        @tier "domain"
      TOGGLE_AUDIO -> external {
        id : string
      }
        @description "Emits when the audio toggle is pressed"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : PinballBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      width : number = 480
        @label "Width"
        @description "Playfield width in pixels"
        @tier "presentation"
      height : number = 640
        @label "Height"
        @description "Playfield height in pixels; a ball past this drains"
        @tier "presentation"
      ballRadius : number = 12
        @label "Ball Radius"
        @description "Ball collision radius against the playfield walls"
        @tier "presentation"
      gravity : number = 1.6
        @label "Gravity"
        @description "Downward velocity added to the ball each physics tick"
        @tier "presentation"
      launchSpeed : number = 40
        @label "Launch Speed"
        @description "Initial upward velocity when the ball is launched"
        @tier "presentation"
      launchVx : number = -3
        @label "Launch Vx"
        @description "Initial horizontal velocity when the ball is launched"
        @tier "presentation"
      launchX : number = 452
        @label "Launch X"
        @description "Plunger lane x position where the ball waits and respawns"
        @tier "presentation"
      launchY : number = 560
        @label "Launch Y"
        @description "Plunger lane y position where the ball waits and respawns"
        @tier "presentation"
      flipperPower : number = 36
        @label "Flipper Power"
        @description "Upward velocity a flipper flick gives the ball"
        @tier "presentation"
      flipperSideKick : number = 6
        @label "Flipper Side Kick"
        @description "Horizontal velocity a flipper adds toward the table center"
        @tier "presentation"
      flipperZoneY : number = 500
        @label "Flipper Zone Y"
        @description "Ball must be below this y for a flipper flick to connect"
        @tier "presentation"
      flipperY : number = 566
        @label "Flipper Y"
        @description "Y position where the flipper paddles are drawn"
        @tier "presentation"
      leftFlipperX : number = 150
        @label "Left Flipper X"
        @description "X position of the left flipper paddle"
        @tier "presentation"
      rightFlipperX : number = 330
        @label "Right Flipper X"
        @description "X position of the right flipper paddle"
        @tier "presentation"
      bumperRadius : number = 40
        @label "Bumper Radius"
        @description "Ball-to-bumper collision radius in pixels"
        @tier "presentation"
      bumperScore : number = 100
        @label "Bumper Score"
        @description "Points awarded per bumper hit"
        @tier "presentation"
      bumperKick : number = 0.8
        @label "Bumper Kick"
        @description "Velocity multiplier applied radially away from a hit bumper"
        @tier "presentation"
      startingBalls : number = 3
        @label "Starting Balls"
        @description "Balls per game; draining the last one ends the game"
        @tier "presentation"
      bumpers : [PinballBoardBumperItem] = [{ id: "bumper1", x: 140, y: 180 }, { id: "bumper2", x: 240, y: 110 }, { id: "bumper3", x: 340, y: 180 }]
        @label "Bumpers"
        @description "Bumper positions on the playfield in pixels"
        @tier "presentation"
      assetManifest : PinballBoardAssetManifest = { units: { ball: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_balls.json", sprite: "ballGrey_01.png", role: "npc", category: "ball", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "ball", thumbnailUrl: "" } }, features: { bumper: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets/features/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets/features/spritesheet_default.json", sprite: "element_red_polygon_glossy.png", role: "decoration", category: "bumper", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "bumper", thumbnailUrl: "" }, paddle: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_paddles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_paddles.json", sprite: "paddle_01.png", role: "decoration", category: "paddle", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "4:1", name: "paddle", thumbnailUrl: "" }, paddleActive: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_paddles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/features/spritesheet_paddles.json", sprite: "paddle_07.png", role: "decoration", category: "paddle", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "4:1", name: "paddle-active", thumbnailUrl: "" } }, effects: { spark: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/effects/spritesheet_particles.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-puzzle-assets-2/effects/spritesheet_particles.json", sprite: "particleYellow_1.png", role: "effect", category: "spark", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "spark", thumbnailUrl: "" } }, background: { url: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-pinball-board/kenney-rolling-ball-assets/features/rollingBall_sheet.json", sprite: "background_blue.png", role: "background", category: "background", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "playfield", thumbnailUrl: "" } }
        @label "Asset Manifest"
        @description "Ball/bumper/paddle/spark sprite maps + playfield background"
        @tier "presentation"
      scale : number = 1
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
      showMinimap : boolean = false
        @label "Show Minimap"
        @description "Show minimap overlay"
        @tier "presentation"
      enableCamera : boolean = false
        @label "Enable Camera"
        @description "Enable camera pan/zoom controls"
        @tier "presentation"
    }
  }

  page "/pinball-board" as PinballBoardPage -> PinballBoardRender
}
