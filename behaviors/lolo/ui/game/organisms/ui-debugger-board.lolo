app ui-debugger-board "1.0.0"
"DebuggerBoard — UI factory (1:1 with the @almadar/ui debugger-board pattern)."
orbital DebuggerBoardOrbital {
  type DebuggerBoardEntity = {
    id : string!
    title : string!
    description : string!
    language : string
    lines : [DebuggerBoardEntityLinesItem]!
    bugCount : number!
    successMessage : string
    failMessage : string
    hint : string
    headerImage : string
    theme : DebuggerBoardEntityTheme
  }
  type DebuggerBoardEntityLinesItem = {
    id : string!
    content : string!
    isBug : boolean!
    explanation : string
  }
  type DebuggerBoardEntityTheme = {
    background : string
    accentColor : string
  }

  entity DebuggerBoardItem [runtime] {
    id : string!
  }

  trait DebuggerBoardRender -> @rebindable DebuggerBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          completeEvent: COMPLETE
          type: debugger-board
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "essential"
    }

    config {
      entityProp : DebuggerBoardEntity
        @label "Entity"
        @description "The compiler binds the generic `EntityRow`, so the inlet accepts it (and"
        @synonyms "entity"
        @tier "presentation"
    }
  }

  page "/debugger-board" as DebuggerBoardPage -> DebuggerBoardRender
}
