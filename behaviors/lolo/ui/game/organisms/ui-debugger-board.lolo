app ui-debugger-board "1.0.0"
"DebuggerBoard — flag every bug line and no clean line to win (1:1 with the @almadar/ui debugger-board pattern)."
orbital DebuggerBoardOrbital {
  type DebuggerBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type DebuggerBoardLinesItem = {
    id : string!
    content : string
    isBug : boolean
    isFlagged : boolean
    explanation : string
  }

  entity DebuggerBoardItem [runtime] {
    id : string!
    lines : [DebuggerBoardLinesItem]
    attempts : number = 0
    result : "none" | "win" = none
  }

  trait DebuggerBoardRender -> @rebindable DebuggerBoardItem [interaction, instance] {
    initial: menu

    state menu {
      INIT -> menu
        (set @entity.lines @config.lines)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          completeEvent: COMPLETE
          type: debugger-board
        })
      START -> playing
        (set @entity.lines @config.lines)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          type: debugger-board
        })
    }

    state playing {
      TOGGLE_FLAG -> playing
        (set @entity.lines (array/map @entity.lines (fn l (if (== (object/get l id) ?lineId) (object/merge l { isFlagged: (not (object/get l isFlagged)) }) l))))
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          type: debugger-board
        })

      CHECK -> complete when (and (== (array/len (array/filter @entity.lines (fn l (and (object/get l isBug) (not (object/get l isFlagged)))))) 0) (== (array/len (array/filter @entity.lines (fn l (and (not (object/get l isBug)) (object/get l isFlagged))))) 0))
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.result "win")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          type: debugger-board
        })

      CHECK -> playing when (or (> (array/len (array/filter @entity.lines (fn l (and (object/get l isBug) (not (object/get l isFlagged)))))) 0) (> (array/len (array/filter @entity.lines (fn l (and (not (object/get l isBug)) (object/get l isFlagged))))) 0))
        (set @entity.attempts (+ @entity.attempts 1))
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          type: debugger-board
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.lines @config.lines)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          type: debugger-board
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "essential"
      TOGGLE_FLAG -> external {
        lineId : string!
      }
        @description "Flip the flag on a reviewed code line"
        @tier "essential"
      CHECK -> external {
        id : string
      }
        @description "Submit the current flag set for scoring"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Reset the puzzle and play again"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : DebuggerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      lines : [DebuggerBoardLinesItem] = [{ id: "l1", content: "function add(a, b) {", isBug: false, isFlagged: false }, { id: "l2", content: "  return a - b;", isBug: true, isFlagged: false, explanation: "Should be a + b for an add function." }, { id: "l3", content: "}", isBug: false, isFlagged: false }, { id: "l4", content: "const total = add(2, 3);", isBug: false, isFlagged: false }, { id: "l5", content: "console.log(totl);", isBug: true, isFlagged: false, explanation: "Typo: 'totl' should be 'total'." }]
        @label "Lines"
        @description "Direct code-line data — takes priority over entity-derived lines."
        @tier "presentation"
    }
  }

  page "/debugger-board" as DebuggerBoardPage -> DebuggerBoardRender
}
