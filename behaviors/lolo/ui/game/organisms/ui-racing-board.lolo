app ui-racing-board "1.0.0"
"RacingBoard — UI factory (1:1 with the @almadar/ui racing-board pattern)."
orbital RacingBoardOrbital {
  type RacingBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type RacingBoardUnitsItem = {
    id : string!
    x : number
    y : number
    sprite : asset
    unitType : string
    team : "player" | "rival" | "neutral"
    speed : number
    lap : number
  }

  entity RacingBoardItem [runtime] {
    id : string!
  }

  trait RacingBoardRender -> @rebindable RacingBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          backgroundImage: @config.backgroundImage
          playerSprite: @config.playerSprite
          rivalSprite: @config.rivalSprite
          hudLightsSprite: @config.hudLightsSprite
          units: @config.units
          assetBaseUrl: @config.assetBaseUrl
          width: @config.width
          height: @config.height
          fps: @config.fps
          tickEvent: TICK
          drawEvent: DRAW
          type: racing-board
        })
    }

    emits {
      TICK -> external {
        dt : number!
        frame : number!
      }
        @description "Declarative event: emits UI:{tickEvent} with { dt, frame } each tick"
        @tier "essential"
      DRAW -> external {
        frame : number!
      }
        @description "Declarative event: emits UI:{drawEvent} with { frame } each draw frame"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : RacingBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      backgroundImage : asset = "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/backgrounds/track.png"
        @label "Background Image"
        @description "Tiled asphalt road tile (Racing Pack road_asphalt01)"
        @tier "presentation"
      playerSprite : asset = "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_player.png"
        @label "Player Sprite"
        @description "Player car sprite (Racing Pack car_red_1)"
        @tier "presentation"
      rivalSprite : asset = "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_rival.png"
        @label "Rival Sprite"
        @description "Rival car sprite (Racing Pack car_blue_1)"
        @tier "presentation"
      hudLightsSprite : asset = "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/ui/lights.png"
        @label "HUD Lights Sprite"
        @description "Traffic lights / start signal (Racing Pack Objects/lights)"
        @tier "presentation"
      units : [RacingBoardUnitsItem] = [{ id: "player", x: 380, y: 480, unitType: "car", team: player, speed: 0, lap: 1, sprite: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_player.png" }, { id: "rival1", x: 420, y: 520, unitType: "car", team: rival, speed: 0, lap: 1, sprite: "https://almadar-kflow-assets.web.app/shared/ui-racing-board/default/units/car_rival.png" }]
        @label "Units"
        @description "Cars on the track (player + rivals)"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prepended to asset paths"
        @tier "presentation"
      width : number = 800
        @label "Width"
        @description "Canvas width in pixels"
        @tier "presentation"
      height : number = 600
        @label "Height"
        @description "Canvas height in pixels"
        @tier "presentation"
      fps : number = 60
        @label "FPS"
        @description "Target frames per second"
        @tier "presentation"
    }
  }

  page "/racing-board" as RacingBoardPage -> RacingBoardRender
}
