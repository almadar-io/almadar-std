ble: true }, { id: "t-9-9", x: 9, y: 9, z: 0, terrain: "wall", passable: false }, { id: "t-10-9", x: 10, y: 9, z: 0, terrain: "snow", passable: true }, { id: "t-11-9", x: 11, y: 9, z: 0, terrain: "snow", passable: true }, { id: "t-0-10", x: 0, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-1-10", x: 1, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-2-10", x: 2, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-3-10", x: 3, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-4-10", x: 4, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-5-10", x: 5, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-6-10", x: 6, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-7-10", x: 7, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-8-10", x: 8, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-9-10", x: 9, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-10-10", x: 10, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-11-10", x: 11, y: 10, z: 0, terrain: "snow", passable: true }, { id: "t-0-11", x: 0, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-1-11", x: 1, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-2-11", x: 2, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-3-11", x: 3, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-4-11", x: 4, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-5-11", x: 5, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-6-11", x: 6, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-7-11", x: 7, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-8-11", x: 8, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-9-11", x: 9, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-10-11", x: 10, y: 11, z: 0, terrain: "snow", passable: true }, { id: "t-11-11", x: 11, y: 11, z: 0, terrain: "snow", passable: true } ]
