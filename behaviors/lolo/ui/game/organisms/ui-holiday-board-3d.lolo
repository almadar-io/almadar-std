  trait Collector = Frame.traits.Collector -> GameState {
    config {
      running: true
      targetType: "gift"
      pointsPerTarget: 1
      removeOnReach: true
      features: [ { id: "gift1", x: 4, y: 2, type: "gift", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/present-a-round.glb", role: "item", category: "present-a-round", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "present-a-round", thumbnailUrl: "" } }, { id: "gift2", x: 9, y: 3, type: "gift", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/present-b-cube.glb", role: "item", category: "present-b-cube", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "present-b-cube", thumbnailUrl: "" } }, { id: "gift3", x: 3, y: 8, type: "gift", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/present-a-rectangle.glb", role: "item", category: "present-a-rectangle", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "present-a-rectangle", thumbnailUrl: "" } }, { id: "gift4", x: 7, y: 9, type: "gift", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/present-b-round.glb", role: "item", category: "present-b-round", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "present-b-round", thumbnailUrl: "" } }, { id: "deco1", x: 6, y: 2, type: "wreath", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/wreath-decorated.glb", role: "decoration", category: "wreath-decorated", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wreath-decorated", thumbnailUrl: "" } }, { id: "deco2", x: 2, y: 9, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/tree-snow-a.glb", role: "decoration", category: "tree-snow-a", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "tree-snow-a", thumbnailUrl: "" } }, { id: "deco3", x: 9, y: 6, type: "candy-cane", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/candy-cane-red.glb", role: "decoration", category: "candy-cane-red", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "candy-cane-red", thumbnailUrl: "" } } ]
