app ui-holiday-board-3d "1.0.0"
"HolidayBoard3D — snowy 3D grid board: a nutcracker collects gifts within a move budget or loses; composes the std single-hero objective frame."
;; @capabilities "3D grid gift collection, nutcracker hero movement, move-budget objective, holiday-themed challenge"
orbital HolidayBoard3DOrbital {
  uses Frame from "std/behaviors/std-objective-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    assetUrl : Asset
    color : string
    elevation : number
  }
  type HudStat = { label : string  value : number }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    movesLeft : number = 0
    features : [Feature] = []
    score : number = 0
    objectivesLeft : number = 0
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    phase : string = "observation"
  }

  trait HeroAuthority = Frame.traits.HeroAuthority -> GameState {
    config {
      running: true
      gridWidth: 12
      gridHeight: 12
      moveBudget: 45
      units: [ { id: "player1", position: { x: 1, y: 1 }, x: 1, y: 1, z: 0, team: "player", health: 1, maxHealth: 1, unitType: "nutcracker", name: "Nutcracker", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/nutcracker.glb", role: "player", category: "nutcracker", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "nutcracker", thumbnailUrl: "" } }, { id: "npc1", position: { x: 8, y: 8 }, x: 8, y: 8, z: 0, team: "neutral", health: 1, maxHealth: 1, unitType: "reindeer", name: "Reindeer", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/features/reindeer.glb", role: "npc", category: "reindeer", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "reindeer", thumbnailUrl: "" } } ]
      tiles: [ { id: "t-0-0", x: 0, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-1-0", x: 1, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-2-0", x: 2, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-3-0", x: 3, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-4-0", x: 4, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-5-0", x: 5, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-6-0", x: 6, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-7-0", x: 7, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-8-0", x: 8, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-9-0", x: 9, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-10-0", x: 10, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-11-0", x: 11, y: 0, z: 0, terrain: "snow", passable: true }, { id: "t-0-1", x: 0, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-1-1", x: 1, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-2-1", x: 2, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-3-1", x: 3, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-4-1", x: 4, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-5-1", x: 5, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-6-1", x: 6, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-7-1", x: 7, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-8-1", x: 8, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-9-1", x: 9, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-10-1", x: 10, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-11-1", x: 11, y: 1, z: 0, terrain: "snow", passable: true }, { id: "t-0-2", x: 0, y: 2, z: 0, terrain: "snow", passable: true }, { id: "t-1-2", x: 1, y: 2, z: 0, terrain: "snow", passable: true }, { id: "t-2-2", x: 2, y: 2, z: 0, terrain: "snow", passable: true }, { id: "t-3-2", x: 3, y: 2, z: 0, terrain: "snow", passable: true }, { id: "t-4-2", x: 4, y: 2, z: 0, terrain: "snow", passable: true }, { id: