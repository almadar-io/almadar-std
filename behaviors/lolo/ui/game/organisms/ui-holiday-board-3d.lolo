  trait Player = Frame.traits.HeroIntent -> GameState {
    config {
      gridWidth: 12
      gridHeight: 12
      movementRange: 1
      objectiveLabel: "Gifts Left"
      cameraMode: "top-down"
      scale: 0.45
      unitScale: 1
      bgColor: "#0a1420"
      assetManifest: { terrains: { snow: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/terrain/floor-wood-snow.glb", role: "tile", category: "snow", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "snow", thumbnailUrl: "" }, wall: { url: "https://almadar-kflow-assets.web.app/shared/ui-holiday-board-3d/kenney-holiday-kit/terrain/cabin-wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, units: {}, features: {}, effects: {} }
    }
