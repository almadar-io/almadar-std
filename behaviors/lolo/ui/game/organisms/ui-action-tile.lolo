app ui-action-tile "1.0.0"
"ActionTile — UI factory (1:1 with the @almadar/ui action-tile pattern)."
orbital ActionTileOrbital {
  type ActionTileError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type ActionTileAction = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : string
    stateMachine : ActionTileActionStateMachine
  }
  type ActionTileActionStateMachine = {
    name : string!
    states : [string]!
    currentState : string!
    transitions : [ActionTileActionStateMachineTransitionsItem]!
    description : string
  }
  type ActionTileActionStateMachineTransitionsItem = {
    from : string!
    to : string!
    event : string!
    guardHint : string
  }
  type ActionTileCategoryColorsValue = {
    bg : string!
    border : string!
  }

  entity ActionTileItem [runtime] {
    id : string!
  }

  trait ActionTileRender -> @rebindable ActionTileItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          action: @config.action
          size: @config.size
          disabled: @config.disabled
          categoryColors: @config.categoryColors
          type: action-tile
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : ActionTileError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      action : ActionTileAction = { id: "Id", name: "Name", category: "Category", description: "Description", iconEmoji: "Icon Emoji", iconUrl: "Icon Url", stateMachine: { name: "Name", states: ["Item"], currentState: "Current State", transitions: [{ from: "From", to: "To", event: "Event", guardHint: "Guard Hint" }], description: "Description" } }
        @label "Action"
        @description "The action data"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "Whether the tile is disabled / already used"
        @tier "presentation"
      categoryColors : Map string ActionTileCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
    }
  }

  page "/action-tile" as ActionTilePage -> ActionTileRender
}
