  ] } ]
        })

      TILE_CLICK -> idle when (and (> (array/len (array/filter @entity.features (fn ft (and (== @ft.x ?x) (== @ft.y ?y))))) 0) (>= @entity.gold 25))
        (set @entity.gold (- @entity.gold 25))
        (set @entity.buildings (array/append @entity.buildings { id: (object/get (array/first (array/filter @entity.features (fn ft (and (== @ft.x ?x) (== @ft.y ?y))))) id), type: (object/get (array/first (array/filter @entity.features (fn ft (and (== @ft.x ?x) (== @ft.y ?y))))) type), x: ?x, y: ?y, cost: 25, incomePerTick: 5 }))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-adventure-pack/ui/uipack_rpg_sheet.json", sprite: "panel_beige.png", role: "ui", category: "ui", animations: [], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
