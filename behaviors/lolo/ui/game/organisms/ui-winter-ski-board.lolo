app ui-winter-ski-board "1.0.0"
"WinterSkiBoard — downhill ski run: auto-descend, steer past trees and rocks, weave through slalom gates for score."
orbital WinterSkiBoardOrbital {
  type WinterSkiBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type WinterSkiBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    terrainSprite : Asset
  }
  type WinterSkiBoardHeroPos = {
    x : number!
    y : number!
  }
  type WinterSkiBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
  }
  type WinterSkiBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type WinterSkiBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity WinterSkiBoardItem [runtime] {
    id : string!
    hero : WinterSkiBoardHeroPos = { x: 4, y: 0 }
    lives : number = 3
    score : number = 0
    runs : number = 0
    result : "none" | "victory" | "defeat" = none
    gridWidth : number = 9
    gridHeight : number = 14
    running : boolean = true
    features : [WinterSkiBoardFeaturesItem] = []
    effects : [WinterSkiBoardEffectItem] = []
  }

  trait WinterSkiBoardRender -> @rebindable WinterSkiBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.hero @config.hero)
        (set @entity.lives 3)
        (set @entity.score 0)
        (set @entity.runs 0)
        (set @entity.result "none")
        (set @entity.running true)
        (set @entity.gridWidth 9)
        (set @entity.gridHeight 14)
        (set @entity.features @config.features)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Lives", value: @entity.lives, max: 3, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Distance", value: @entity.hero.y, max: @entity.gridHeight, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,4", role: "ui", category: "ui", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { left: "STEER_LEFT", right: "STEER_RIGHT" }, directionAssets: { left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, keyMap: { ArrowLeft: "STEER_LEFT", KeyA: "STEER_LEFT", ArrowRight: "STEER_RIGHT", KeyD: "STEER_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: [ { type: draw-sprite, position: { x: @entity.hero.x, y: @entity.hero.y }, asset: (object/get (object/get @config.assetManifest units) hero), anchor: "ground", width: 0.5, height: 0.5 } ] }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      STEER_LEFT -> playing when (== @entity.result "none")
        (let ((nx (math/clamp (- @entity.hero.x 1) 0 (- @entity.gridWidth 1))))
          (do
            (set @entity.hero { x: @nx, y: @entity.hero.y })
            (let ((hit (array/find @entity.features (fn f (and (or (== @f.type "tree") (== @f.type "rock")) (and (== @f.x @nx) (== @f.y @entity.hero.y)))))))
          (do
            (set @entity.lives (if (!= @hit null) (math/max 0 (- @entity.lives 1)) @entity.lives))
            (set @entity.effects (if (!= @hit null) (array/append @entity.effects { key: "explosion", x: @nx, y: @entity.hero.y, ttl: 5 }) @entity.effects))
            (set @entity.features (if (!= @hit null) (array/filter @entity.features (fn f (!= @f.id (object/get @hit id)))) @entity.features))))
            (set @entity.result (if (<= @entity.lives 0) "defeat" @entity.result))))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Lives", value: @entity.lives, max: 3, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Distance", value: @entity.hero.y, max: @entity.gridHeight, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,4", role: "ui", category: "ui", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { left: "STEER_LEFT", right: "STEER_RIGHT" }, directionAssets: { left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, keyMap: { ArrowLeft: "STEER_LEFT", KeyA: "STEER_LEFT", ArrowRight: "STEER_RIGHT", KeyD: "STEER_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: [ { type: draw-sprite, position: { x: @entity.hero.x, y: @entity.hero.y }, asset: (object/get (object/get @config.assetManifest units) hero), anchor: "ground", width: 0.5, height: 0.5 } ] }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
        (if (== @entity.result "defeat") (emit GAME_END) true)

      STEER_RIGHT -> playing when (== @entity.result "none")
        (let ((nx (math/clamp (+ @entity.hero.x 1) 0 (- @entity.gridWidth 1))))
          (do
            (set @entity.hero { x: @nx, y: @entity.hero.y })
            (let ((hit (array/find @entity.features (fn f (and (or (== @f.type "tree") (== @f.type "rock")) (and (== @f.x @nx) (== @f.y @entity.hero.y)))))))
          (do
            (set @entity.lives (if (!= @hit null) (math/max 0 (- @entity.lives 1)) @entity.lives))
            (set @entity.effects (if (!= @hit null) (array/append @entity.effects { key: "explosion", x: @nx, y: @entity.hero.y, ttl: 5 }) @entity.effects))
            (set @entity.features (if (!= @hit null) (array/filter @entity.features (fn f (!= @f.id (object/get @hit id)))) @entity.features))))
            (set @entity.result (if (<= @entity.lives 0) "defeat" @entity.result))))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Lives", value: @entity.lives, max: 3, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Distance", value: @entity.hero.y, max: @entity.gridHeight, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,4", role: "ui", category: "ui", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { left: "STEER_LEFT", right: "STEER_RIGHT" }, directionAssets: { left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, keyMap: { ArrowLeft: "STEER_LEFT", KeyA: "STEER_LEFT", ArrowRight: "STEER_RIGHT", KeyD: "STEER_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: [ { type: draw-sprite, position: { x: @entity.hero.x, y: @entity.hero.y }, asset: (object/get (object/get @config.assetManifest units) hero), anchor: "ground", width: 0.5, height: 0.5 } ] }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
        (if (== @entity.result "defeat") (emit GAME_END) true)


      GAME_END -> gameover when (!= @entity.result "none")
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Lives", value: @entity.lives, max: 3, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Distance", value: @entity.hero.y, max: @entity.gridHeight, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,4", role: "ui", category: "ui", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } } ] }
          addons: { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "zoom_reset.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }
          overlay: { type: game-menu, title: (if (== @entity.result "victory") "VICTORY" "DEFEAT"), subtitle: (if (== @entity.result "victory") "Three runs conquered" "Wiped out on the slope"), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, keyMap: { ArrowLeft: "STEER_LEFT", KeyA: "STEER_LEFT", ArrowRight: "STEER_RIGHT", KeyD: "STEER_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: [ { type: draw-sprite, position: { x: @entity.hero.x, y: @entity.hero.y }, asset: (object/get (object/get @config.assetManifest units) hero), anchor: "ground", width: 0.5, height: 0.5 } ] }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.hero @config.hero)
        (set @entity.lives 3)
        (set @entity.score 0)
        (set @entity.runs 0)
        (set @entity.result "none")
        (set @entity.running true)
        (set @entity.gridWidth 9)
        (set @entity.gridHeight 14)
        (set @entity.features @config.features)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Lives", value: @entity.lives, max: 3, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Distance", value: @entity.hero.y, max: @entity.gridHeight, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,4", role: "ui", category: "ui", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { left: "STEER_LEFT", right: "STEER_RIGHT" }, directionAssets: { left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, keyMap: { ArrowLeft: "STEER_LEFT", KeyA: "STEER_LEFT", ArrowRight: "STEER_RIGHT", KeyD: "STEER_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: [ { type: draw-sprite, position: { x: @entity.hero.x, y: @entity.hero.y }, asset: (object/get (object/get @config.assetManifest units) hero), anchor: "ground", width: 0.5, height: 0.5 } ] }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    ticks {
      descentTick every 600ms
        when (and (== @entity.running true) (== @entity.result "none"))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (let ((ny (+ @entity.hero.y 1)))
          (if (>= @ny @entity.gridHeight)
            (do
              (set @entity.score (+ @entity.score 100))
              (set @entity.runs (+ @entity.runs 1))
              (set @entity.result (if (>= @entity.runs 3) "victory" @entity.result))
              (set @entity.hero (if (== @entity.result "victory") @entity.hero { x: 4, y: 0 })))
            (do
              (set @entity.hero { x: @entity.hero.x, y: @ny })
              (let ((hit (array/find @entity.features (fn f (and (or (== @f.type "tree") (== @f.type "rock")) (and (== @f.x @entity.hero.x) (== @f.y @ny)))))))
          (do
            (set @entity.lives (if (!= @hit null) (math/max 0 (- @entity.lives 1)) @entity.lives))
            (set @entity.effects (if (!= @hit null) (array/append @entity.effects { key: "explosion", x: @entity.hero.x, y: @ny, ttl: 5 }) @entity.effects))
            (set @entity.features (if (!= @hit null) (array/filter @entity.features (fn f (!= @f.id (object/get @hit id)))) @entity.features))))
              (let ((redGate (array/find @entity.features (fn f (and (== @f.type "gate_red") (== @f.y @ny)))))
                    (blueGate (array/find @entity.features (fn f (and (== @f.type "gate_blue") (== @f.y @ny))))))
                (set @entity.score (if (and (!= @redGate null) (and (!= @blueGate null) (and (> @entity.hero.x (object/get @redGate x)) (< @entity.hero.x (object/get @blueGate x))))) (+ @entity.score 10) @entity.score)))
              (set @entity.result (if (<= @entity.lives 0) "defeat" @entity.result)))))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Lives", value: @entity.lives, max: 3, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Distance", value: @entity.hero.y, max: @entity.gridHeight, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,4", role: "ui", category: "ui", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-distance", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { left: "STEER_LEFT", right: "STEER_RIGHT" }, directionAssets: { left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, keyMap: { ArrowLeft: "STEER_LEFT", KeyA: "STEER_LEFT", ArrowRight: "STEER_RIGHT", KeyD: "STEER_RIGHT" }, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: [ { type: draw-sprite, position: { x: @entity.hero.x, y: @entity.hero.y }, asset: (object/get (object/get @config.assetManifest units) hero), anchor: "ground", width: 0.5, height: 0.5 } ] }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
        (if (!= @entity.result "none") (emit GAME_END) true)

    }

    emits {
      STEER_LEFT -> external {
        id : string
      }
        @description "Steer the skier one cell left (keyboard keyMap or d-pad)"
        @tier "domain"
      STEER_RIGHT -> external {
        id : string
      }
        @description "Steer the skier one cell right (keyboard keyMap or d-pad)"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Fires when the run ends in defeat or three runs are completed."
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset."
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : WinterSkiBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      tiles : [WinterSkiBoardTilesItem] = [{ id: "t0_0", x: 0, y: 0, terrain: "snow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "4,0", role: "tile", category: "snowFloor", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "snowFloor", thumbnailUrl: "" } }, { id: "t1_0", x: 1, y: 0, terrain: "snow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "2,0", role: "tile", category: "snowVariation", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "snowVariation", thumbnailUrl: "" } }, { id: "t2_0", x: 2, y: 0, terrain: "snow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "4,0", role: "tile", category: "snowFloor", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "snowFloor", thumbnailUrl: "" } }, { id: "t3_0", x: 3, y: 0, terrain: "snow", passable: true, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-winter-ski-board/kenney-tiny-ski/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "2,0", role: "tile", category: "snowVariation", animations: ["static"], style: "pixel", variant: "", dimension: "2d