app ui-space-shmup-board "1.0.0"
"SpaceShmupBoard — sci-fi shmup: dodge enemy lasers, blast descending waves with Space/Fire, clear every wave to win."
orbital SpaceShmupBoardOrbital {
  type SpaceShmupBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type SpaceShmupBoardPlayer = {
    x : number!
    y : number!
    animation : string
    frame : number
  }
  type SpaceShmupBoardEnemiesItem = {
    id : string!
    x : number!
    y : number!
    hp : number!
    animation : string
    frame : number
  }
  type SpaceShmupBoardProjectilesItem = {
    id : string!
    x : number!
    y : number!
    vx : number!
    vy : number!
  }
  type SpaceShmupBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type SpaceShmupBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type SpaceShmupBoardAssetManifest = {
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity SpaceShmupBoardItem [runtime] {
    id : string!
    player : SpaceShmupBoardPlayer
    enemies : [SpaceShmupBoardEnemiesItem]
    projectiles : [SpaceShmupBoardProjectilesItem]
    enemyProjectiles : [SpaceShmupBoardProjectilesItem]
    score : number = 0
    wave : number = 1
    lives : number = 3
    result : "none" | "victory" | "defeat" = none
    tick : number = 0
    nextId : number = 0
    paused : boolean = false
    effects : [SpaceShmupBoardEffectItem] = []
  }

  trait SpaceShmupBoardRender -> @rebindable SpaceShmupBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.player { x: (/ @config.width 2), y: (- @config.height @config.spriteSize), animation: "idle", frame: 0 })
        (set @entity.enemies (array/map (array/range 0 @config.enemiesPerWave) (fn i { id: (str/concat "enemy-" @i), x: (+ @config.spriteSize (* @i (/ @config.width @config.enemiesPerWave))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })))
        (set @entity.projectiles [])
        (set @entity.enemyProjectiles [])
        (set @entity.score 0)
        (set @entity.wave 1)
        (set @entity.lives @config.lives)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.nextId 0)
        (set @entity.paused false)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "star_gold.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Wave", value: @entity.wave, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "ufoRed.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wave", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, max: @config.lives, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "playerLife1_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "bolt_gold.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_pause", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT", Space: "SHOOT" }, children: [
    { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
    { type: draw-sprite-layer, items: (array/map @entity.projectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) playerLaser) })) }
    { type: draw-sprite-layer, items: (array/map @entity.enemyProjectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) enemyLaser) })) }
    { type: draw-sprite-layer, items: (array/concat (list { type: draw-sprite, position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, asset: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation) }) (array/map @entity.enemies (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation) }))) }
    { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) }
  ] } ]
        })

      MOVE_LEFT -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { x: (math/max 0 (- (object/get @entity.player x) @config.moveStep)), animation: "walk" }))

      MOVE_RIGHT -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { x: (math/min @config.width (+ (object/get @entity.player x) @config.moveStep)), animation: "walk" }))

      MOVE_UP -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { y: (math/max @config.playerMinY (- (object/get @entity.player y) @config.moveStep)), animation: "walk" }))

      MOVE_DOWN -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { y: (math/min @config.height (+ (object/get @entity.player y) @config.moveStep)), animation: "walk" }))

      SHOOT -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { animation: "attack" }))
        (set @entity.projectiles (array/concat @entity.projectiles (list { id: (str/concat "proj-" @entity.nextId), x: (object/get @entity.player x), y: (object/get @entity.player y), vx: 0, vy: (- 0 @config.projectileSpeed) })))
        (set @entity.nextId (+ @entity.nextId 1))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "star_gold.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Wave", value: @entity.wave, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "ufoRed.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wave", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, max: @config.lives, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "playerLife1_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "bolt_gold.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_pause", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT", Space: "SHOOT" }, children: [
    { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
    { type: draw-sprite-layer, items: (array/map @entity.projectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) playerLaser) })) }
    { type: draw-sprite-layer, items: (array/map @entity.enemyProjectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) enemyLaser) })) }
    { type: draw-sprite-layer, items: (array/concat (list { type: draw-sprite, position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, asset: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation) }) (array/map @entity.enemies (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation) }))) }
    { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) }
  ] } ]
        })

      PAUSE -> paused
        (set @entity.paused true)
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "star_gold.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Wave", value: @entity.wave, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "ufoRed.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wave", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, max: @config.lives, format: "hearts", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "playerLife1_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" } }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: SHOOT, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/kenney-space-shooter-redux/features/sheet.json", sprite: "bolt_gold.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary }, { type: button, action: PAUSE, label: "Pause", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_pause", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-pause", thumbnailUrl: "" }, variant: secondary } ] }
          overlay: { type: game-menu, title: "PAUSED", subtitle: "Mission on hold", options: [ { id: "resume", label: "Resume", event: "RESUME", variant: "primary" }, { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "secondary" } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "free", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT", Space: "SHOOT" }, children: [
    { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite) })) }
    { type: draw-sprite-layer, items: (array/map @entity.projectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) playerLaser) })) }
    { type: draw-sprite-layer, items: (array/map @entity.enemyProjectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) enemyLaser) })) }
    { type: draw-sprite-layer, items: (array/concat (list { type: draw-sprite, position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, asset: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation) }) (array/map @entity.enemies (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation) }))) }
    { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) }
  ] } ]
        })

      GAME_END -> gameover when (!= @entity.result "none")
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack-sci-fi/ui/uipackSpace_sheet.json", sprite: "metalPanel_blue.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
