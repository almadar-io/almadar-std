app ui-space-shmup-board "1.0.0"
"SpaceShmupBoard — vertical SHMUP field on a flat IsometricCanvas tile grid."
orbital SpaceShmupBoardOrbital {
  type SpaceShmupBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type SpaceShmupBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type SpaceShmupBoardUnitsItem = {
    id : string!
    position : SpaceShmupBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    spriteSheet : asset
    modelUrl : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [SpaceShmupBoardUnitsItemTraitsItem]
    previousPosition : SpaceShmupBoardUnitsItemPreviousPosition
    elevation : number
  }
  type SpaceShmupBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type SpaceShmupBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type SpaceShmupBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type SpaceShmupBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }

  entity SpaceShmupBoardItem [runtime] {
    id : string!
  }

  trait SpaceShmupBoardRender -> @rebindable SpaceShmupBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          assetManifest: @config.assetManifest
          assetBaseUrl: @config.assetBaseUrl
          scale: @config.scale
          showMinimap: @config.showMinimap
          enableCamera: @config.enableCamera
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          type: space-shmup-board
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SpaceShmupBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [SpaceShmupBoardTilesItem] = [{ x: 0, y: 0, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 0, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 0, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 0, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 0, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 0, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 1, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 1, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 1, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 1, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 1, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 1, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 2, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 2, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 2, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 2, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 2, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 2, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 3, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 3, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 3, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 3, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 3, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 3, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 4, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 4, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 4, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 4, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 4, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 4, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 5, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 5, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 5, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 5, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 5, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 5, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 6, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 6, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 6, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 6, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 6, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 6, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 0, y: 7, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 1, y: 7, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 2, y: 7, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 3, y: 7, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 4, y: 7, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }, { x: 5, y: 7, terrain: "space", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/terrain/space.png" }]
        @label "Tiles"
        @description "6×8 flat space-terrain tile grid"
        @tier "presentation"
      units : [SpaceShmupBoardUnitsItem] = [{ id: "enemy1", position: { x: 1, y: 0 }, unitType: "ship", name: "Invader A", team: enemy, health: 1, maxHealth: 1, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png" }, { id: "enemy2", position: { x: 3, y: 0 }, unitType: "ship", name: "Invader B", team: enemy, health: 1, maxHealth: 1, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png" }, { id: "enemy3", position: { x: 0, y: 1 }, unitType: "ship", name: "Invader C", team: enemy, health: 1, maxHealth: 1, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png" }, { id: "enemy4", position: { x: 4, y: 1 }, unitType: "ship", name: "Invader D", team: enemy, health: 1, maxHealth: 1, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/enemy.png" }, { id: "player1", position: { x: 2, y: 7 }, unitType: "ship", name: "Player", team: player, health: 3, maxHealth: 3, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-shmup-board/default/units/ship.png" }]
        @label "Units"
        @description "Player ship (bottom centre) and 4 enemy ships across the top rows"
        @tier "presentation"
      features : [SpaceShmupBoardFeaturesItem] = []
        @label "Features"
        @description "Optional hazards or power-ups on the field"
        @tier "presentation"
      assetManifest : string = ""
        @label "Asset Manifest"
        @description "Asset sprite manifest (same shape as IsometricCanvas.assetManifest)"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prepended to manifest sprite paths"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
      showMinimap : boolean = false
        @label "Show Minimap"
        @description "Show minimap overlay"
        @tier "presentation"
      enableCamera : boolean = true
        @label "Enable Camera"
        @description "Enable camera pan/zoom controls"
        @tier "presentation"
    }
  }

  page "/space-shmup-board" as SpaceShmupBoardPage -> SpaceShmupBoardRender
}
