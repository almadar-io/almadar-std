    { type: draw-sprite-layer, items: (array/concat (list { type: draw-sprite, position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, asset: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation) }) (array/map @entity.enemies (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation) }))) }
    { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) }
  ] } ]
        })

      simulateTick every 100ms
        when (and (== @entity.paused false) (== @entity.result "none"))
        (set @entity.tick (+ @entity.tick 1))
        (set @entity.projectiles (array/map @entity.projectiles (fn p (object/merge @p { y: (+ (object/get @p y) (object/get @p vy)) }))))
        (set @entity.projectiles (array/filter @entity.projectiles (fn p (>= (object/get @p y) 0))))
        (set @entity.enemyProjectiles (array/map @entity.enemyProjectiles (fn p (object/merge @p { y: (+ (object/get @p y) (object/get @p vy)) }))))
        (set @entity.enemyProjectiles (array/filter @entity.enemyProjectiles (fn p (<= (object/get @p y) @config.height))))
        (set @entity.enemyProjectiles (array/concat @entity.enemyProjectiles (array/map (array/filter @entity.enemies (fn e (< (math/random) @config.enemyFireChance))) (fn e { id: (str/concat "eproj-" (str/concat @e.id (str/concat "-" @entity.tick))), x: (object/get @e x), y: (object/get @e y), vx: 0, vy: @config.enemyProjectileSpeed }))))
        (set @entity.enemies (array/map @entity.enemies (fn e (object/merge @e { y: (+ (object/get @e y) @config.enemySpeed), animation: "walk" }))))
        (set @entity.score (+ @entity.score (* @config.scorePerKill (array/len (array/filter @entity.enemies (fn e (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0)))))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemies (fn e (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0))) (fn e { key: "hit", x: (object/get @e x), y: (object/get @e y), ttl: 4 }))))
        (set @entity.enemies (array/map @entity.enemies (fn e (if (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0) (object/merge @e { hp: (- (object/get @e hp) 1), animation: (if (<= (- (object/get @e hp) 1) 0) "death" "hit") }) @e))))
        (set @entity.projectiles (array/filter @entity.projectiles (fn p (== (array/len (array/filter @entity.enemies (fn e (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemies (fn e (<= (object/get @e hp) 0))) (fn e { key: "explosion", x: (object/get @e x), y: (object/get @e y), ttl: 5 }))))
        (set @entity.enemies (array/filter @entity.enemies (fn e (> (object/get @e hp) 0))))
        (set @entity.lives (- @entity.lives (array/len (array/filter @entity.enemyProjectiles (fn p (<= (vec/distance { x: (object/get @entity.player x), y: (object/get @entity.player y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius))))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemyProjectiles (fn p (<= (vec/distance { x: (object/get @entity.player x), y: (object/get @entity.player y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius))) (fn p { key: "explosion", x: (object/get @entity.player x), y: (object/get @entity.player y), ttl: 5 }))))
        (set @entity.enemyProjectiles (array/filter @entity.enemyProjectiles (fn p (> (vec/distance { x: (object/get @entity.player x), y: (object/get @entity.player y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius))))
        (set @entity.lives (- @entity.lives (array/len (array/filter @entity.enemies (fn e (>= (object/get @e y) @config.height))))))
        (set @entity.enemies (array/filter @entity.enemies (fn e (< (object/get @e y) @config.height))))
        (set @entity.result (if (<= @entity.lives 0) "defeat" @entity.result))
        (set @entity.wave (if (and (== (array/len @entity.enemies) 0) (== @entity.result "none")) (+ @entity.wave 1) @entity.wave))
        (set @entity.result (if (and (== (array/len @entity.enemies) 0) (and (== @entity.result "none") (> @entity.wave @config.maxWaves))) "victory" @entity.result))
        (set @entity.enemies (if (and (== (array/len @entity.enemies) 0) (== @entity.result "none")) (array/map (array/range 0 (+ @config.enemiesPerWave (- @entity.wave 1))) (fn i { id: (str/concat "enemy-" (+ (* @entity.wave 100) @i)), x: (+ @config.spriteSize (* @i (/ @config.width (+ @config.enemiesPerWave (- @entity.wave 1))))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })) @entity.enemies))
        (render-ui main {
