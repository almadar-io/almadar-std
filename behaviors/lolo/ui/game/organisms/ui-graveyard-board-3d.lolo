app ui-graveyard-board-3d "1.0.0"
"Graveyard Board 3D — 3D grid-tactics: Keeper vs skeleton, zombie, ghost on a graveyard grid."
orbital GraveyardBoard3DOrbital {
  uses Frame from "std/behaviors/std-tactics-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string
    assetUrl : Asset
    color : string
    elevation : number
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    attackTargets : [ValidMove] = []
    uiPhase : string = "observation"
    turn : number = 0
  }

  trait Authority = Frame.traits.TacticsAuthority -> GameState {
    config {
      running: true
      gridWidth: 20
      gridHeight: 20
      attackDamage: 3
      units: [ { id: "p1", position: { x: 4, y: 18 }, x: 4, y: 18, z: 0, team: "player", health: 12, maxHealth: 12, unitType: "keeper", name: "Keeper", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/units/character-keeper.glb", role: "decoration", category: "character-keeper", animations: ["idle","walk","die","attack-melee-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-keeper", thumbnailUrl: "" } }, { id: "p2", position: { x: 10, y: 18 }, x: 10, y: 18, z: 0, team: "player", health: 12, maxHealth: 12, unitType: "keeper", name: "Warden", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/units/character-keeper.glb", role: "decoration", category: "character-keeper", animations: ["idle","walk","die","attack-melee-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-keeper", thumbnailUrl: "" } }, { id: "p3", position: { x: 16, y: 18 }, x: 16, y: 18, z: 0, team: "player", health: 12, maxHealth: 12, unitType: "keeper", name: "Sentinel", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/units/character-keeper.glb", role: "decoration", category: "character-keeper", animations: ["idle","walk","die","attack-melee-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-keeper", thumbnailUrl: "" } }, { id: "e1", position: { x: 4, y: 1 }, x: 4, y: 1, z: 0, team: "enemy", health: 8, maxHealth: 8, unitType: "skeleton", name: "Skeleton", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/units/character-skeleton.glb", role: "decoration", category: "character-skeleton", animations: ["idle","walk","die","attack-melee-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-skeleton", thumbnailUrl: "" } }, { id: "e2", position: { x: 10, y: 1 }, x: 10, y: 1, z: 0, team: "enemy", health: 10, maxHealth: 10, unitType: "zombie", name: "Zombie", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/units/character-zombie.glb", role: "decoration", category: "character-zombie", animations: ["idle","walk","die","attack-melee-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-zombie", thumbnailUrl: "" } }, { id: "e3", position: { x: 16, y: 1 }, x: 16, y: 1, z: 0, team: "enemy", health: 6, maxHealth: 6, unitType: "ghost", name: "Ghost", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/units/character-ghost.glb", role: "decoration", category: "character-ghost", animations: ["idle","walk","die","attack-melee-right"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "character-ghost", thumbnailUrl: "" } } ]
    }
  }

  trait FxDecay = Frame.traits.FxDecay -> GameState {
    config { running: true }
  }

  trait RoundLogic = Frame.traits.RoundLogic -> GameState {
    config { running: true }
  }

  trait Player = Frame.traits.PlayerIntent -> GameState {
    config {
      gridWidth: 20
      gridHeight: 20
      movementRange: 4
      features: [ { id: "f1", x: 10, y: 10, z: 0, type: "crypt", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/crypt.glb", role: "decoration", category: "crypt", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "crypt", thumbnailUrl: "" } }, { id: "f2", x: 5, y: 8, z: 0, type: "gravestone", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/gravestone-cross.glb", role: "decoration", category: "gravestone-cross", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gravestone-cross", thumbnailUrl: "" } }, { id: "f3", x: 15, y: 8, z: 0, type: "gravestone", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/gravestone-round.glb", role: "decoration", category: "gravestone-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gravestone-round", thumbnailUrl: "" } }, { id: "f4", x: 5, y: 12, z: 0, type: "gravestone", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/gravestone-round.glb", role: "decoration", category: "gravestone-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gravestone-round", thumbnailUrl: "" } }, { id: "f5", x: 15, y: 12, z: 0, type: "gravestone", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/gravestone-cross.glb", role: "decoration", category: "gravestone-cross", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "gravestone-cross", thumbnailUrl: "" } }, { id: "f6", x: 8, y: 6, z: 0, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/pine.glb", role: "decoration", category: "pine", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "pine", thumbnailUrl: "" } }, { id: "f7", x: 12, y: 14, z: 0, type: "tree", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/pine.glb", role: "decoration", category: "pine", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "pine", thumbnailUrl: "" } }, { id: "f8", x: 10, y: 5, z: 0, type: "pumpkin", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/pumpkin-carved.glb", role: "decoration", category: "pumpkin-carved", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "pumpkin-carved", thumbnailUrl: "" } }, { id: "f9", x: 7, y: 10, z: 0, type: "lantern", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/lantern-candle.glb", role: "decoration", category: "lantern-candle", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "lantern-candle", thumbnailUrl: "" } }, { id: "f10", x: 13, y: 10, z: 0, type: "lantern", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-graveyard-board-3d/kenney-graveyard-kit/features/lantern-candle.glb", role: "decoration", category: "lantern-candle", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "lantern-candle", thumbnailUrl: "" } } ]
      assetManifest: { terrains: {}, units: {}, features: {}, effects: {} }
      cameraMode: "isometric"
      scale: 0.45
      unitScale: 1
      bgColor: "#14101f"
    }
  }

  page "/graveyard-board-3d" as GraveyardBoard3DPage -> Authority, FxDecay, RoundLogic, Player
}
