app ui-pirate-board-3d "1.0.0"
"PirateBoard3D — naval 3D tactics board: 3 player ships vs 3 enemy corsair ships across an 18×18 open sea."
;; @capabilities "3D naval fleet tactics, ship-vs-ship combat, open-sea grid movement, multi-ship battle"
orbital PirateBoard3DOrbital {
  uses Frame from "std/behaviors/std-tactics-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string
    assetUrl : Asset
    color : string
    elevation : number
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    attackTargets : [ValidMove] = []
    uiPhase : string = "observation"
    turn : number = 0
  }

  trait Authority = Frame.traits.TacticsAuthority -> GameState {
    config {
      running: true
      gridWidth: 18
      gridHeight: 18
      attackDamage: 4
      units: [ { id: "p1", position: { x: 4, y: 16 }, x: 4, y: 16, z: 0, team: "player", health: 10, maxHealth: 10, unitType: "ship-medium", name: "Player Galleon", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/units/ship-medium.glb", role: "player", category: "ship-medium", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "ship-medium", thumbnailUrl: "" } }, { id: "p2", position: { x: 9, y: 16 }, x: 9, y: 16, z: 0, team: "player", health: 8, maxHealth: 8, unitType: "ship-small", name: "Player Sloop", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/units/ship-small.glb", role: "player", category: "ship-small", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "ship-small", thumbnailUrl: "" } }, { id: "p3", position: { x: 14, y: 16 }, x: 14, y: 16, z: 0, team: "player", health: 9, maxHealth: 9, unitType: "ship-small", name: "Player Corvette", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/units/ship-small.glb", role: "player", category: "ship-small", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "ship-small", thumbnailUrl: "" } }, { id: "e1", position: { x: 4, y: 1 }, x: 4, y: 1, z: 0, team: "enemy", health: 10, maxHealth: 10, unitType: "ship-pirate-medium", name: "Corsair Galleon", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/units/ship-pirate-medium.glb", role: "enemy", category: "ship-pirate-medium", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "ship-pirate-medium", thumbnailUrl: "" } }, { id: "e2", position: { x: 9, y: 1 }, x: 9, y: 1, z: 0, team: "enemy", health: 8, maxHealth: 8, unitType: "ship-pirate-small", name: "Corsair Sloop", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/units/ship-pirate-small.glb", role: "enemy", category: "ship-pirate-small", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "ship-pirate-small", thumbnailUrl: "" } }, { id: "e3", position: { x: 14, y: 1 }, x: 14, y: 1, z: 0, team: "enemy", health: 9, maxHealth: 9, unitType: "ship-pirate-small", name: "Corsair Cutter", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/units/ship-pirate-small.glb", role: "enemy", category: "ship-pirate-small", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "ship-pirate-small", thumbnailUrl: "" } } ]
    }
  }

  trait FxDecay = Frame.traits.FxDecay -> GameState {
    config { running: true }
  }

  trait RoundLogic = Frame.traits.RoundLogic -> GameState {
    config { running: true }
  }

  trait Player = Frame.traits.PlayerIntent -> GameState {
    config {
      gridWidth: 18
      gridHeight: 18
      movementRange: 4
      features: [ { id: "f1", x: 2, y: 6, z: 0, type: "palm", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/terrain/palm-straight.glb", role: "decoration", category: "palm", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "palm-straight", thumbnailUrl: "" } }, { id: "f2", x: 15, y: 11, z: 0, type: "palm", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/terrain/palm-bend.glb", role: "decoration", category: "palm", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "palm-bend", thumbnailUrl: "" } }, { id: "f3", x: 3, y: 9, z: 0, type: "tower", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/tower-watch.glb", role: "decoration", category: "tower", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tower-watch", thumbnailUrl: "" } }, { id: "f4", x: 14, y: 9, z: 0, type: "cannon", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/cannon-mobile.glb", role: "decoration", category: "cannon", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "cannon-mobile", thumbnailUrl: "" } }, { id: "f5", x: 8, y: 5, z: 0, type: "tower", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/tower-watch.glb", role: "decoration", category: "tower", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "tower-watch", thumbnailUrl: "" } }, { id: "f6", x: 9, y: 12, z: 0, type: "cannon", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/cannon-mobile.glb", role: "decoration", category: "cannon", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "cannon-mobile", thumbnailUrl: "" } }, { id: "f7", x: 6, y: 8, z: 0, type: "barrel", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/barrel.glb", role: "decoration", category: "barrel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "barrel", thumbnailUrl: "" } }, { id: "f8", x: 7, y: 8, z: 0, type: "crate", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/crate.glb", role: "decoration", category: "crate", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "crate", thumbnailUrl: "" } }, { id: "f9", x: 11, y: 5, z: 0, type: "barrel", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/barrel.glb", role: "decoration", category: "barrel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "barrel", thumbnailUrl: "" } }, { id: "f10", x: 12, y: 13, z: 0, type: "crate", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-pirate-board-3d/kenney-pirate-kit/features/crate.glb", role: "decoration", category: "crate", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "crate", thumbnailUrl: "" } } ]
      assetManifest: { terrains: {}, units: {}, features: {}, effects: {} }
      cameraMode: "isometric"
      scale: 0.45
      unitScale: 1
      bgColor: "#123a52"
    }
  }

  page "/pirate-board-3d" as PirateBoard3DPage -> Authority, FxDecay, RoundLogic, Player
}
