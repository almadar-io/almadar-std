app ui-market-board-3d "1.0.0"
"MarketBoard3D — a shopkeeper serves customers before their patience runs out; composes the std single-hero market-service frame."
orbital MarketBoard3DOrbital {
  uses Frame from "std/behaviors/std-market-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Customer = {
    id : string!
    position : { x : number!  y : number! }
    patience : number
    maxPatience : number
    unitType : string
    name : string
    team : string
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    type : string!
    assetUrl : Asset
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    movesLeft : number = 0
    customers : [Customer] = []
    served : number = 0
    pending : number = 0
    lost : number = 0
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    phase : string = "observation"
  }

