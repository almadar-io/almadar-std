app ui-space-station-board "1.0.0"
"SpaceStationBoard — UI factory (1:1 with the @almadar/ui space-station-board pattern)."
orbital SpaceStationBoardOrbital {
  type SpaceStationBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type SpaceStationBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type SpaceStationBoardUnitsItem = {
    id : string!
    position : SpaceStationBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    spriteSheet : asset
    modelUrl : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [SpaceStationBoardUnitsItemTraitsItem]
    previousPosition : SpaceStationBoardUnitsItemPreviousPosition
    elevation : number
  }
  type SpaceStationBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type SpaceStationBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type SpaceStationBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type SpaceStationBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }

  entity SpaceStationBoardItem [runtime] {
    id : string!
  }

  trait SpaceStationBoardRender -> @rebindable SpaceStationBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          assetManifest: @config.assetManifest
          assetBaseUrl: @config.assetBaseUrl
          scale: @config.scale
          showMinimap: @config.showMinimap
          enableCamera: @config.enableCamera
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          type: space-station-board
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SpaceStationBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [SpaceStationBoardTilesItem] = [
        { x: 0, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 2, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 3, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 4, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 5, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 6, y: 0, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 0, y: 1, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 1, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 2, y: 1, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 3, y: 1, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 4, y: 1, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 5, y: 1, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 6, y: 1, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 0, y: 2, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 2, terrain: "console", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/console.png" },
        { x: 2, y: 2, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 3, y: 2, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 4, y: 2, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 5, y: 2, terrain: "console", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/console.png" },
        { x: 6, y: 2, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 0, y: 3, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 3, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 2, y: 3, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 3, y: 3, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 4, y: 3, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 5, y: 3, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 6, y: 3, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 0, y: 4, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 4, terrain: "console", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/console.png" },
        { x: 2, y: 4, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 3, y: 4, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 4, y: 4, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 5, y: 4, terrain: "console", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/console.png" },
        { x: 6, y: 4, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 0, y: 5, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 5, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 2, y: 5, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 3, y: 5, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 4, y: 5, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 5, y: 5, terrain: "floor", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/floor.png" },
        { x: 6, y: 5, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 0, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 1, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 2, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 3, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 4, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 5, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" },
        { x: 6, y: 6, terrain: "wall", passable: false, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/terrain/wall.png" }
      ]
        @label "Tiles"
        @description "Isometric grid tiles"
        @tier "presentation"
      units : [SpaceStationBoardUnitsItem] = [
        { id: "u1", position: { x: 2, y: 3 }, unitType: "crew", name: "Commander", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/units/crew.png" },
        { id: "u2", position: { x: 4, y: 3 }, unitType: "crew", name: "Engineer", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/units/crew.png" },
        { id: "u3", position: { x: 3, y: 5 }, unitType: "crew", name: "Technician", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/units/crew.png" }
      ]
        @label "Units"
        @description "Units on the board"
        @tier "presentation"
      features : [SpaceStationBoardFeaturesItem] = [
        { id: "f1", x: 1, y: 2, type: "console", sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/features/console.png" },
        { id: "f2", x: 5, y: 2, type: "console", sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/features/console.png" },
        { id: "f3", x: 1, y: 4, type: "console", sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/features/console.png" },
        { id: "f4", x: 5, y: 4, type: "console", sprite: "https://almadar-kflow-assets.web.app/shared/ui-space-station-board/default/features/console.png" }
      ]
        @label "Features"
        @description "Features (consoles, airlocks, etc.) on the board"
        @tier "presentation"
      assetManifest : string = ""
        @label "Asset Manifest"
        @description "Asset sprite manifest (same shape as IsometricCanvas.assetManifest)"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prepended to manifest sprite paths"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
      showMinimap : boolean = true
        @label "Show Minimap"
        @description "Show minimap overlay"
        @tier "presentation"
      enableCamera : boolean = true
        @label "Enable Camera"
        @description "Enable camera pan/zoom controls"
        @tier "presentation"
    }
  }

  page "/space-station-board" as SpaceStationBoardPage -> SpaceStationBoardRender
}
