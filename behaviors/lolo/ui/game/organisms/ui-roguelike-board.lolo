      enemyAiTick every 1s
        when (and (== @entity.phase "enemy_turn") (== @entity.result "none"))
        (set @entity.enemies (array/map @entity.enemies (fn e (if (> @e.hp 0) (let ((ex @e.x) (ey @e.y) (px (object/get @entity.player x)) (py (object/get @entity.player y))) (let ((adjP (and (== (math/abs (- @ex @px)) 1) (== @ey @py))) (adjQ (and (== @ex @px) (== (math/abs (- @ey @py)) 1)))) (if (or @adjP @adjQ) @e (let ((cnx (math/clamp (+ @ex (math/sign (- @px @ex))) 0 (- @entity.gridWidth 1))) (cny (math/clamp (+ @ey (math/sign (- @py @ey))) 0 (- @entity.gridHeight 1)))) (let ((ntile (array/find @entity.tiles (fn t (and (== (object/get @t x) @cnx) (== (object/get @t y) @cny))))) (occupied (array/find @entity.enemies (fn o (and (!= @o.id @e.id) (and (== @o.x @cnx) (== @o.y @cny))))))) (if (and (and (!= @ntile null) (== (object/get @ntile passable) true)) (and (== @occupied null) (or (!= @cnx @px) (!= @cny @py)))) (object/merge @e { x: @cnx, y: @cny }) @e)))))) @e))))
        (set @entity.playerHp (let ((adjEnemies (array/filter @entity.enemies (fn e (and (> @e.hp 0) (or (and (== (math/abs (- @e.x (object/get @entity.player x))) 1) (== @e.y (object/get @entity.player y))) (and (== @e.x (object/get @entity.player x)) (== (math/abs (- @e.y (object/get @entity.player y))) 1)))))))) (let ((dmg (if (== (array/len @adjEnemies) 0) 0 (array/reduce @adjEnemies (fn acc e (+ acc @e.attack)) 0)))) (math/max 0 (- @entity.playerHp @dmg)))))
        (set @entity.effects (if (> (array/len (array/filter @entity.enemies (fn e (and (> @e.hp 0) (or (and (== (math/abs (- @e.x (object/get @entity.player x))) 1) (== @e.y (object/get @entity.player y))) (and (== @e.x (object/get @entity.player x)) (== (math/abs (- @e.y (object/get @entity.player y))) 1))))))) 0) (array/append @entity.effects { key: "slash", x: (object/get @entity.player x), y: (object/get @entity.player y), ttl: 4 }) @entity.effects))
        (if (<= @entity.playerHp 0) (do (set @entity.result "lost") (emit GAME_END)) true)
        (set @entity.phase (if (== @entity.result "none") "player_turn" "game_over"))
    }

    emits {
      MOVE_UP -> external {
        id : string
      }
        @description "Step north (keyboard keyMap or d-pad directionEvents)"
        @tier "domain"
      MOVE_DOWN -> external {
        id : string
      }
        @description "Step south (keyboard keyMap or d-pad directionEvents)"
        @tier "domain"
      MOVE_LEFT -> external {
        id : string
      }
        @description "Step west (keyboard keyMap or d-pad directionEvents)"
        @tier "domain"
      MOVE_RIGHT -> external {
        id : string
      }
        @description "Step east (keyboard keyMap or d-pad directionEvents)"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets the dungeon to depth 1"
        @tier "domain"
      GAME_END -> external {
        result : string
      }
        @description "Emitted when result transitions to won or lost"
        @tier "domain"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Player clicked a tile (fires selection clear)"
        @tier "interaction"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Player clicked a unit (sets selectedUnitId)"
        @tier "interaction"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : RoguelikeBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      scale : number = 0.25
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      playerMaxHp : number = 10
        @label "Player Max HP"
        @description "Starting max HP for the player"
        @tier "presentation"
      playerAttack : number = 3
        @label "Player Attack"
        @description "Player base damage per hit"
        @tier "presentation"
      player : RoguelikeBoardPlayerPos = { x: 2, y: 2 }
        @label "Player Start"
        @description "Player starting position"
        @tier "presentation"
      stairsX : number = 13
        @label "Stairs X"
        @description "Stairs tile X coordinate"
        @tier "presentation"
      stairsY : number = 9
        @label "Stairs Y"
        @description "Stairs tile Y coordinate"
        @tier "presentation"
