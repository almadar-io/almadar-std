app ui-roguelike-board "1.0.0"
"RoguelikeBoard — step-crawl dungeon: arrows/WASD or d-pad, bump combat, loot and level-ups, descend to depth 5 to win."
orbital RoguelikeBoardOrbital {
  type RoguelikeBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type RoguelikeBoardTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    terrainSprite : Asset
    passable : boolean
    tileType : string
  }
  type RoguelikeBoardPlayerPos = {
    x : number!
    y : number!
  }
  type RoguelikeBoardEnemiesItem = {
    id : string!
    x : number!
    y : number!
    hp : number!
    attack : number!
    animation : string
    frame : number
  }
  type RoguelikeBoardItemsItem = {
    id : string!
    x : number!
    y : number!
    kind : "health_potion" | "sword" | "shield"
  }
  type RoguelikeEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type RoguelikeBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity RoguelikeBoardItem [runtime] {
    id : string!
    tiles : [RoguelikeBoardTilesItem]
    player : RoguelikeBoardPlayerPos = { x: 2, y: 2 }
    playerHp : number = 10
    playerMaxHp : number = 10
    playerAttack : number = 3
    playerAnimation : string = "idle"
    playerFrame : number = 0
    enemies : [RoguelikeBoardEnemiesItem]
    items : [RoguelikeBoardItemsItem]
    depth : number = 1
    result : "none" | "won" | "lost" = none
    phase : string = "player_turn"
    stairsX : number = 13
    stairsY : number = 9
    gridWidth : number = 16
    gridHeight : number = 16
    effects : [RoguelikeEffectItem] = []
    selectedUnitId : string = ""
    validMoves : [RoguelikeBoardPlayerPos] = []
    xp : number = 0
    xpToNext : number = 50
    inventory : [string] = []
    equippedWeapon : string = ""
  }

  trait RoguelikeBoardRender -> @rebindable RoguelikeBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.tiles @config.tiles)
        (set @entity.player @config.player)
        (set @entity.playerHp @config.playerMaxHp)
        (set @entity.playerMaxHp @config.playerMaxHp)
        (set @entity.playerAttack @config.playerAttack)
        (set @entity.playerAnimation "idle")
        (set @entity.playerFrame 0)
        (set @entity.enemies @config.enemies)
        (set @entity.items @config.items)
        (set @entity.depth 1)
        (set @entity.result "none")
        (set @entity.phase "player_turn")
        (set @entity.stairsX @config.stairsX)
        (set @entity.stairsY @config.stairsY)
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.xp 0)
        (set @entity.xpToNext 50)
        (set @entity.inventory [])
        (set @entity.equippedWeapon "")
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, max: @entity.playerMaxHp, format: "bar", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-hp", thumbnailUrl: "" } }, { label: "ATK", value: @entity.playerAttack, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,8", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-attack", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "tower.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-floor", thumbnailUrl: "" } }, { label: "Foes", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "skull.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-foes", thumbnailUrl: "" } }, { label: "XP", value: @entity.xp, max: @entity.xpToNext, format: "bar", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-xp", thumbnailUrl: "" } } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "compass.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }, { type: button, variant: ghost, size: "sm", disabled: true, iconAsset: (if (!= @entity.equippedWeapon "sword") null (object/get (object/get @config.assetManifest features) sword)), icon: "plus" } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" }, directionAssets: { up: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "30,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-up", thumbnailUrl: "" }, down: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "32,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-down", thumbnailUrl: "" }, left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "flat", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.items (fn i { type: draw-sprite, position: { x: (object/get @i x), y: (object/get @i y) }, asset: (if (== (object/get @i kind) "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== (object/get @i kind) "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter (array/append (array/map @entity.enemies (fn e { id: @e.id, x: @e.x, y: @e.y })) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y) }) (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: { x: (object/get @u x), y: (object/get @u y) }, radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/append (array/map @entity.enemies (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, id: (object/get @e id), asset: (if (== (object/get @e id) "e3") (object/get (object/get @config.assetManifest units) boss) (if (== (object/get @e id) "e2") (object/get (object/get @config.assetManifest units) brute) (object/get (object/get @config.assetManifest units) enemy))) })) { type: draw-sprite, position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, id: "player", asset: (object/get (object/get @config.assetManifest units) player) }) }
            { type: draw-shape-layer, items: (array/append (array/map @entity.enemies (fn e { type: draw-shape, shape: "rect", position: { x: (object/get @e x), y: (object/get @e y) }, offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) { type: draw-shape, shape: "rect", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" }) }
            { type: draw-shape-layer, items: (array/append (array/map @entity.enemies (fn e { type: draw-shape, shape: "rect", position: { x: (object/get @e x), y: (object/get @e y) }, offsetY: -0.6, width: (* 0.8 (/ (object/get @e hp) 7)), height: 0.12, fill: "#22c55e" })) { type: draw-shape, shape: "rect", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, offsetY: -0.6, width: (* 0.8 (/ @entity.playerHp @entity.playerMaxHp)), height: 0.12, fill: "#22c55e" }) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @f key)) })) }
          ] } ]
        })

      MOVE_UP -> playing when (and (== @entity.result "none") (== @entity.phase "player_turn"))
        (let ((nx (object/get @entity.player x)) (ny (- (object/get @entity.player y) 1)))
          (do
            (let ((inBounds (and (and (>= @nx 0) (< @nx @entity.gridWidth)) (and (>= @ny 0) (< @ny @entity.gridHeight))))
                  (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny)))))
                  (hitEnemy (array/find @entity.enemies (fn e (and (and (== @e.x @nx) (== @e.y @ny)) (> @e.hp 0)))))
                  (hitItem (array/find @entity.items (fn i (and (== @i.x @nx) (== @i.y @ny))))))
              (let ((walkable (if (== @tile null) false (object/get @tile passable))))
                (if (!= @hitEnemy null)
                  (do
                    (set @entity.enemies (array/map @entity.enemies (fn e (if (== @e.id (object/get @hitEnemy id)) (object/merge @e { hp: (math/max 0 (- @e.hp @entity.playerAttack)) }) @e))))
                    (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 4 }))
                    (if (<= (- (object/get @hitEnemy hp) @entity.playerAttack) 0)
                      (do
                        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 5 }))
                        (set @entity.xp (+ @entity.xp 25)))
                      true))
                  (if (and @inBounds @walkable)
                    (do
                      (if (== @hitItem null) true
                        (do
                          (if (== (object/get @hitItem kind) "health_potion") (set @entity.playerHp (math/min @entity.playerMaxHp (+ @entity.playerHp 5))) true)
                          (if (== (object/get @hitItem kind) "sword") (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.equippedWeapon "sword")) true)
                          (if (== (object/get @hitItem kind) "shield") (do (set @entity.playerMaxHp (+ @entity.playerMaxHp 2)) (set @entity.playerHp (+ @entity.playerHp 2))) true)
                          (set @entity.inventory (array/append @entity.inventory (object/get @hitItem kind)))
                          (set @entity.items (array/filter @entity.items (fn i (!= @i.id (object/get @hitItem id)))))))
                      (set @entity.player { x: @nx, y: @ny }))
                    true))))
            (set @entity.enemies (array/filter @entity.enemies (fn e (> @e.hp 0))))
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
              (do
                (set @entity.depth (+ @entity.depth 1))
                (set @entity.xp (+ @entity.xp 50))
                (if (>= @entity.depth 5)
                  (do (set @entity.result "won") (emit GAME_END))
                  (do
                    (set @entity.player @config.player)
                    (set @entity.enemies (array/map @config.enemies (fn e (object/merge @e { hp: (+ @e.hp (- @entity.depth 1)) }))))
                    (set @entity.items @config.items)
                    (set @entity.effects []))))
              true)
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (set @entity.phase "enemy_turn")))

      MOVE_DOWN -> playing when (and (== @entity.result "none") (== @entity.phase "player_turn"))
        (let ((nx (object/get @entity.player x)) (ny (+ (object/get @entity.player y) 1)))
          (do
            (let ((inBounds (and (and (>= @nx 0) (< @nx @entity.gridWidth)) (and (>= @ny 0) (< @ny @entity.gridHeight))))
                  (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny)))))
                  (hitEnemy (array/find @entity.enemies (fn e (and (and (== @e.x @nx) (== @e.y @ny)) (> @e.hp 0)))))
                  (hitItem (array/find @entity.items (fn i (and (== @i.x @nx) (== @i.y @ny))))))
              (let ((walkable (if (== @tile null) false (object/get @tile passable))))
                (if (!= @hitEnemy null)
                  (do
                    (set @entity.enemies (array/map @entity.enemies (fn e (if (== @e.id (object/get @hitEnemy id)) (object/merge @e { hp: (math/max 0 (- @e.hp @entity.playerAttack)) }) @e))))
                    (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 4 }))
                    (if (<= (- (object/get @hitEnemy hp) @entity.playerAttack) 0)
                      (do
                        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 5 }))
                        (set @entity.xp (+ @entity.xp 25)))
                      true))
                  (if (and @inBounds @walkable)
                    (do
                      (if (== @hitItem null) true
                        (do
                          (if (== (object/get @hitItem kind) "health_potion") (set @entity.playerHp (math/min @entity.playerMaxHp (+ @entity.playerHp 5))) true)
                          (if (== (object/get @hitItem kind) "sword") (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.equippedWeapon "sword")) true)
                          (if (== (object/get @hitItem kind) "shield") (do (set @entity.playerMaxHp (+ @entity.playerMaxHp 2)) (set @entity.playerHp (+ @entity.playerHp 2))) true)
                          (set @entity.inventory (array/append @entity.inventory (object/get @hitItem kind)))
                          (set @entity.items (array/filter @entity.items (fn i (!= @i.id (object/get @hitItem id)))))))
                      (set @entity.player { x: @nx, y: @ny }))
                    true))))
            (set @entity.enemies (array/filter @entity.enemies (fn e (> @e.hp 0))))
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
              (do
                (set @entity.depth (+ @entity.depth 1))
                (set @entity.xp (+ @entity.xp 50))
                (if (>= @entity.depth 5)
                  (do (set @entity.result "won") (emit GAME_END))
                  (do
                    (set @entity.player @config.player)
                    (set @entity.enemies (array/map @config.enemies (fn e (object/merge @e { hp: (+ @e.hp (- @entity.depth 1)) }))))
                    (set @entity.items @config.items)
                    (set @entity.effects []))))
              true)
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (set @entity.phase "enemy_turn")))

      MOVE_LEFT -> playing when (and (== @entity.result "none") (== @entity.phase "player_turn"))
        (let ((nx (- (object/get @entity.player x) 1)) (ny (object/get @entity.player y)))
          (do
            (let ((inBounds (and (and (>= @nx 0) (< @nx @entity.gridWidth)) (and (>= @ny 0) (< @ny @entity.gridHeight))))
                  (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny)))))
                  (hitEnemy (array/find @entity.enemies (fn e (and (and (== @e.x @nx) (== @e.y @ny)) (> @e.hp 0)))))
                  (hitItem (array/find @entity.items (fn i (and (== @i.x @nx) (== @i.y @ny))))))
              (let ((walkable (if (== @tile null) false (object/get @tile passable))))
                (if (!= @hitEnemy null)
                  (do
                    (set @entity.enemies (array/map @entity.enemies (fn e (if (== @e.id (object/get @hitEnemy id)) (object/merge @e { hp: (math/max 0 (- @e.hp @entity.playerAttack)) }) @e))))
                    (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 4 }))
                    (if (<= (- (object/get @hitEnemy hp) @entity.playerAttack) 0)
                      (do
                        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 5 }))
                        (set @entity.xp (+ @entity.xp 25)))
                      true))
                  (if (and @inBounds @walkable)
                    (do
                      (if (== @hitItem null) true
                        (do
                          (if (== (object/get @hitItem kind) "health_potion") (set @entity.playerHp (math/min @entity.playerMaxHp (+ @entity.playerHp 5))) true)
                          (if (== (object/get @hitItem kind) "sword") (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.equippedWeapon "sword")) true)
                          (if (== (object/get @hitItem kind) "shield") (do (set @entity.playerMaxHp (+ @entity.playerMaxHp 2)) (set @entity.playerHp (+ @entity.playerHp 2))) true)
                          (set @entity.inventory (array/append @entity.inventory (object/get @hitItem kind)))
                          (set @entity.items (array/filter @entity.items (fn i (!= @i.id (object/get @hitItem id)))))))
                      (set @entity.player { x: @nx, y: @ny }))
                    true))))
            (set @entity.enemies (array/filter @entity.enemies (fn e (> @e.hp 0))))
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
              (do
                (set @entity.depth (+ @entity.depth 1))
                (set @entity.xp (+ @entity.xp 50))
                (if (>= @entity.depth 5)
                  (do (set @entity.result "won") (emit GAME_END))
                  (do
                    (set @entity.player @config.player)
                    (set @entity.enemies (array/map @config.enemies (fn e (object/merge @e { hp: (+ @e.hp (- @entity.depth 1)) }))))
                    (set @entity.items @config.items)
                    (set @entity.effects []))))
              true)
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (set @entity.phase "enemy_turn")))

      MOVE_RIGHT -> playing when (and (== @entity.result "none") (== @entity.phase "player_turn"))
        (let ((nx (+ (object/get @entity.player x) 1)) (ny (object/get @entity.player y)))
          (do
            (let ((inBounds (and (and (>= @nx 0) (< @nx @entity.gridWidth)) (and (>= @ny 0) (< @ny @entity.gridHeight))))
                  (tile (array/find @entity.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny)))))
                  (hitEnemy (array/find @entity.enemies (fn e (and (and (== @e.x @nx) (== @e.y @ny)) (> @e.hp 0)))))
                  (hitItem (array/find @entity.items (fn i (and (== @i.x @nx) (== @i.y @ny))))))
              (let ((walkable (if (== @tile null) false (object/get @tile passable))))
                (if (!= @hitEnemy null)
                  (do
                    (set @entity.enemies (array/map @entity.enemies (fn e (if (== @e.id (object/get @hitEnemy id)) (object/merge @e { hp: (math/max 0 (- @e.hp @entity.playerAttack)) }) @e))))
                    (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 4 }))
                    (if (<= (- (object/get @hitEnemy hp) @entity.playerAttack) 0)
                      (do
                        (set @entity.effects (array/append @entity.effects { key: "explosion", x: (object/get @hitEnemy x), y: (object/get @hitEnemy y), ttl: 5 }))
                        (set @entity.xp (+ @entity.xp 25)))
                      true))
                  (if (and @inBounds @walkable)
                    (do
                      (if (== @hitItem null) true
                        (do
                          (if (== (object/get @hitItem kind) "health_potion") (set @entity.playerHp (math/min @entity.playerMaxHp (+ @entity.playerHp 5))) true)
                          (if (== (object/get @hitItem kind) "sword") (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.equippedWeapon "sword")) true)
                          (if (== (object/get @hitItem kind) "shield") (do (set @entity.playerMaxHp (+ @entity.playerMaxHp 2)) (set @entity.playerHp (+ @entity.playerHp 2))) true)
                          (set @entity.inventory (array/append @entity.inventory (object/get @hitItem kind)))
                          (set @entity.items (array/filter @entity.items (fn i (!= @i.id (object/get @hitItem id)))))))
                      (set @entity.player { x: @nx, y: @ny }))
                    true))))
            (set @entity.enemies (array/filter @entity.enemies (fn e (> @e.hp 0))))
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (if (and (== (object/get @entity.player x) @entity.stairsX) (== (object/get @entity.player y) @entity.stairsY))
              (do
                (set @entity.depth (+ @entity.depth 1))
                (set @entity.xp (+ @entity.xp 50))
                (if (>= @entity.depth 5)
                  (do (set @entity.result "won") (emit GAME_END))
                  (do
                    (set @entity.player @config.player)
                    (set @entity.enemies (array/map @config.enemies (fn e (object/merge @e { hp: (+ @e.hp (- @entity.depth 1)) }))))
                    (set @entity.items @config.items)
                    (set @entity.effects []))))
              true)
            (if (>= @entity.xp @entity.xpToNext) (do (set @entity.playerAttack (+ @entity.playerAttack 1)) (set @entity.xp (- @entity.xp @entity.xpToNext)) (set @entity.xpToNext (+ @entity.xpToNext 25))) true)
            (set @entity.phase "enemy_turn")))

      TILE_CLICK -> playing
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])

      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (set @entity.validMoves [])

      PLAY_AGAIN -> playing
        (set @entity.tiles @config.tiles)
        (set @entity.player @config.player)
        (set @entity.playerHp @config.playerMaxHp)
        (set @entity.playerMaxHp @config.playerMaxHp)
        (set @entity.playerAttack @config.playerAttack)
        (set @entity.playerAnimation "idle")
        (set @entity.playerFrame 0)
        (set @entity.enemies @config.enemies)
        (set @entity.items @config.items)
        (set @entity.depth 1)
        (set @entity.result "none")
        (set @entity.phase "player_turn")
        (set @entity.stairsX @config.stairsX)
        (set @entity.stairsY @config.stairsY)
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.effects [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.xp 0)
        (set @entity.xpToNext 50)
        (set @entity.inventory [])
        (set @entity.equippedWeapon "")
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: game-hud, stats: [ { label: "HP", value: @entity.playerHp, max: @entity.playerMaxHp, format: "bar", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_heart.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-hp", thumbnailUrl: "" } }, { label: "ATK", value: @entity.playerAttack, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "8,8", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-attack", thumbnailUrl: "" } }, { label: "Floor", value: @entity.depth, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "tower.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-floor", thumbnailUrl: "" } }, { label: "Foes", value: (array/len @entity.enemies), iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "skull.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-foes", thumbnailUrl: "" } }, { label: "XP", value: @entity.xp, max: @entity.xpToNext, format: "bar", iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/pixel_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-xp", thumbnailUrl: "" } } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: PLAY_AGAIN, label: "Restart", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/kenney-cartography-pack/ui/spritesheet_default.json", sprite: "compass.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "icon-restart", thumbnailUrl: "" }, variant: primary }, { type: button, variant: ghost, size: "sm", disabled: true, iconAsset: (if (!= @entity.equippedWeapon "sword") null (object/get (object/get @config.assetManifest features) sword)), icon: "plus" } ] }
          controls: { type: control-grid, kind: "dpad", directionEvents: { up: "MOVE_UP", down: "MOVE_DOWN", left: "MOVE_LEFT", right: "MOVE_RIGHT" }, directionAssets: { up: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "30,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-up", thumbnailUrl: "" }, down: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "32,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-down", thumbnailUrl: "" }, left: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "33,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-left", thumbnailUrl: "" }, right: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-input-prompts-pixel-16/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "31,4", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "key-right", thumbnailUrl: "" } } }
          children: [ { type: canvas, camera: { zoom: @config.scale }, projection: "flat", showMinimap: true, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT" }, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite) })) }
            { type: draw-sprite-layer, items: (array/map @entity.items (fn i { type: draw-sprite, position: { x: (object/get @i x), y: (object/get @i y) }, asset: (if (== (object/get @i kind) "health_potion") (object/get (object/get @config.assetManifest features) health_potion) (if (== (object/get @i kind) "sword") (object/get (object/get @config.assetManifest features) sword) (object/get (object/get @config.assetManifest features) shield))) })) }
            { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) }
            { type: draw-shape-layer, items: (array/map (array/filter (array/append (array/map @entity.enemies (fn e { id: @e.id, x: @e.x, y: @e.y })) { id: "player", x: (object/get @entity.player x), y: (object/get @entity.player y) }) (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: { x: (object/get @u x), y: (object/get @u y) }, radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) }
            { type: draw-sprite-layer, items: (array/append (array/map @entity.enemies (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, id: (object/get @e id), asset: (if (== (object/get @e id) "e3") (object/get (object/get @config.assetManifest units) boss) (if (== (object/get @e id) "e2") (object/get (object/get @config.assetManifest units) brute) (object/get (object/get @config.assetManifest units) enemy))) })) { type: draw-sprite, position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, id: "player", asset: (object/get (object/get @config.assetManifest units) player) }) }
            { type: draw-shape-layer, items: (array/append (array/map @entity.enemies (fn e { type: draw-shape, shape: "rect", position: { x: (object/get @e x), y: (object/get @e y) }, offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" })) { type: draw-shape, shape: "rect", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, offsetY: -0.6, width: 0.8, height: 0.12, fill: "rgba(0,0,0,0.6)" }) }
            { type: draw-shape-layer, items: (array/append (array/map @entity.enemies (fn e { type: draw-shape, shape: "rect", position: { x: (object/get @e x), y: (object/get @e y) }, offsetY: -0.6, width: (* 0.8 (/ (object/get @e hp) 7)), height: 0.12, fill: "#22c55e" })) { type: draw-shape, shape: "rect", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, offsetY: -0.6, width: (* 0.8 (/ @entity.playerHp @entity.playerMaxHp)), height: 0.12, fill: "#22c55e" }) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @f key)) })) }
          ] } ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (render-ui main {
          type: game-shell
          fontFamily: "pixel"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-fantasy-ui-borders/ui/kenney-fantasy-ui-borders.generated.json", sprite: "panel-border-010.png", role: "ui", category: "ui", animations: [], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
