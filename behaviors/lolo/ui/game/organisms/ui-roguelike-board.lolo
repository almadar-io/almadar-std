        @label "Tiles"
        @description "Dungeon tile grid with wall/floor/stairs layout."
        @tier "presentation"
      enemies : [RoguelikeBoardEnemiesItem] = [{ id: "e1", x: 5, y: 2, hp: 5, attack: 2 }, { id: "e2", x: 9, y: 6, hp: 4, attack: 1 }, { id: "e3", x: 3, y: 10, hp: 6, attack: 2 }, { id: "e4", x: 12, y: 8, hp: 5, attack: 3 }]
        @label "Enemies"
        @description "Initial enemy positions, hp, and attack values."
        @tier "presentation"
      items : [RoguelikeBoardItemsItem] = [{ id: "i1", x: 3, y: 3, kind: "health_potion" }, { id: "i2", x: 7, y: 9, kind: "sword" }, { id: "i3", x: 11, y: 5, kind: "shield" }]
        @label "Items"
        @description "Floor items (health_potion / sword / shield)."
        @tier "presentation"
      assetManifest : RoguelikeBoardAssetManifest = { baseUrl: "https://almadar-kflow-assets.web.app/shared", terrains: { floor: "terrains/tiles-iso-medieval/kenney-isometric-blocks/abstractTile_29.png", wall: "terrains/tiles-iso-medieval/kenney-isometric-blocks/abstractTile_29.png", stairs: "terrains/tiles-iso-medieval/kenney-isometric-blocks/abstractTile_29.png", planks: "terrains/tiles-iso-medieval/kenney-isometric-blocks/abstractTile_29.png" }, units: { player: "units/chars-roguelike/kflow/sprite-sheets/forger-sprite-sheet-sw.png", enemy: "units/chars-roguelike/kflow/sprite-sheets/destroyer-sprite-sheet-sw.png" }, features: { health_potion: "terrains/tiles-iso-medieval/kflow/iso/medieval/woodenCrates_N.png", sword: "terrains/tiles-iso-medieval/kflow/iso/medieval/woodenCrates_N.png", shield: "terrains/tiles-iso-medieval/kflow/iso/medieval/woodenCrates_S.png" } }
        @label "Asset Manifest"
        @description "CDN sprite paths for terrain, player, enemies, and items."
        @tier "presentation"
    }
  }

  page "/roguelike-board" as RoguelikeBoardPage -> RoguelikeBoardRender
