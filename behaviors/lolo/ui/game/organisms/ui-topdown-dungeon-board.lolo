app ui-topdown-dungeon-board "1.0.0"
"TopdownDungeonBoard -- key-move dungeon crawl on a Tiny Dungeon grid: bump-attack monsters, reach the chest to win, composes the std dungeon-board-2d frame."
orbital TopdownDungeonBoardOrbital {
  uses Frame from "std/behaviors/std-dungeon-board-2d"

  type Asset = {
    url : asset
    atlas : asset
    sprite : string
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    animation : string
    frame : number
    sprite : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    terrainSprite : Asset
  }
  type Feature = {
    id : string
    x : number!
    y : number!
    type : string!
    sprite : Asset
    done : boolean
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    enemies : [Unit] = []
    tiles : [Tile] = []
    features : [Feature] = []
    fx : [Fx] = []
    movesLeft : number = 0
    score : number = 0
    combatScore : number = 0
    objectivesLeft : number = 0
    hp : number = 5
    maxHp : number = 5
    result : string = "none"
    combatResult : string = "none"
  }

  trait HeroAuthority = Frame.traits.HeroAuthority -> GameState {
    config {
      running: true
      gridWidth: 12
      gridHeight: 9
      moveBudget: 999999
      units: [ { id: "hero", position: { x: 2, y: 1 }, x: 2, y: 1, z: 0, unitType: "hero", name: "Hero", team: "player", health: 5, maxHealth: 5, animation: "idle", frame: 0, sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "0,8", role: "npc", category: "knight", animations: ["idle","walk","attack","hit","death"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "knight", thumbnailUrl: "" } } ]
      tiles: [{ x: 0, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,3", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { x: 1, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,3", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { x: 2, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,3", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { x: 3, y: 0, terrain: "wall", passable: false, terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/tilemap_packed.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-topdown-dungeon-board/kenney-tiny-dungeon/terrain/Tilemap_tilemap_packed.tiles.json", sprite: "1,3", role: "tile", category: "wall", animations: ["static"], style: "pixel", variant: "", dimension: "2d", aspect: "1:1", name: "wall", thumbnailUrl: ""