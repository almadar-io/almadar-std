app ui-fishing-board "1.0.0"
"FishingBoard — game-shell composition with LOLO-driven sprite animation and catch effects."
orbital FishingBoardOrbital {
  type FishingBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type FishingBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type FishingBoardUnitsItem = {
    id : string!
    position : FishingBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    spriteSheet : asset
    modelUrl : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [FishingBoardUnitsItemTraitsItem]
    previousPosition : FishingBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type FishingBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type FishingBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type FishingBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type FishingBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type FishingBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }
  type FishingBoardAssetManifest = {
    baseUrl : asset
    terrains : Map string asset
    units : Map string asset
    features : Map string asset
    effects : Map string asset
  }

  entity FishingBoardItem [runtime] {
    id : string!
    units : [FishingBoardUnitsItem]
    catchCount : number = 0
    score : number = 0
    effects : [FishingBoardEffectItem] = []
  }

  trait FishingBoardRender -> @rebindable FishingBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.catchCount 0)
        (set @entity.score 0)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      TILE_CLICK -> playing
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      UNIT_CLICK -> playing
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      CAST -> playing
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?unitId) (object/merge @u { animation: "cast" }) @u))))
        (if (== ?hitFish true) (set @entity.catchCount (+ @entity.catchCount 1)) null)
        (if (== ?hitFish true) (set @entity.score (+ @entity.score ?points)) null)
        (if (== ?hitFish true) (set @entity.effects (array/append @entity.effects { key: "splash", x: ?x, y: ?y, ttl: 4 })) null)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.units (array/map @entity.units (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount }, { label: "Score", value: @entity.score } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
      CAST -> external {
        unitId : string!
        x : number!
        y : number!
        hitFish : boolean
        points : number
      }
        @description "Emits when a cast action is triggered"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : FishingBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [FishingBoardTilesItem] = [{ x: 0, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 1, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 2, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 3, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 4, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 0, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 1, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 2, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 3, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 4, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png" }, { x: 0, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 1, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 2, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 3, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 4, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 0, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 1, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 2, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 3, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 4, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 0, y: 4, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 1, y: 4, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 2, y: 4, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 3, y: 4, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, { x: 4, y: 4, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }]
        @label "Tiles"
        @description "Flat top-down fishing scene tiles (water + seabed)"
        @tier "presentation"
      units : [FishingBoardUnitsItem] = [{ id: "u1", position: { x: 2, y: 0 }, unitType: "boat", name: "Fishing Boat", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/boat.png", animation: "idle", frame: 0 }, { id: "u2", position: { x: 2, y: 2 }, unitType: "hook", name: "Hook", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/hook.png", animation: "idle", frame: 0 }]
        @label "Units"
        @description "Units on the board (boat, hook)"
        @tier "presentation"
      features : [FishingBoardFeaturesItem] = [{ id: "f1", x: 0, y: 2, type: "seaweed", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png" }, { id: "f2", x: 1, y: 2, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-blue.png" }, { id: "f3", x: 3, y: 2, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-orange.png" }, { id: "f4", x: 4, y: 2, type: "seaweed", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png" }, { id: "f5", x: 0, y: 3, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-green.png" }, { id: "f6", x: 2, y: 3, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-blue.png" }, { id: "f7", x: 4, y: 3, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-orange.png" }, { id: "f8", x: 1, y: 4, type: "seaweed", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png" }, { id: "f9", x: 2, y: 4, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-green.png" }, { id: "f10", x: 3, y: 4, type: "seaweed", sprite: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png" }]
        @label "Features"
        @description "Features on the board (fish spots, seaweed)"
        @tier "presentation"
      assetManifest : FishingBoardAssetManifest = { terrains: { water: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/water.png", seabed: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/terrain/seabed.png" }, units: { boat: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/boat.png", hook: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/units/hook.png" }, features: { fish: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/fish-blue.png", seaweed: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/default/features/seaweed.png" }, effects: { splash: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/spark_06.png" } }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      scale : number = 1
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  page "/fishing-board" as FishingBoardPage -> FishingBoardRender
}
