      biteTick every 500ms
        when (and (== @entity.phase "waiting") (== @entity.result "none"))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.id "hook") (< (object/get (object/get @u position) y) 3)) (object/merge @u { position: { x: 3, y: (+ (object/get (object/get @u position) y) 1) } }) @u))))
        (set @entity.reelWindow (if (< (math/random) @config.biteChance) @config.reelWindowTicks 0))
        (set @entity.phase (if (> @entity.reelWindow 0) "hooked" "waiting"))
        (set @entity.effects (if (== @entity.phase "hooked") (array/append @entity.effects { key: "bite", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id "hook"))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id "hook"))) position) y), ttl: 20 }) @entity.effects))
