app ui-fishing-board "1.0.0"
"FishingBoard — cast/bite/reel fishing loop: hook drops, bites roll on a timer, reel within the window to land fish."
orbital FishingBoardOrbital {
  type FishingBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      atlas : asset
      sprite : string
      role : string
      category : string
      animations : [string]
      style : string
      variant : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type FishingBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type FishingBoardUnitsItem = {
    id : string!
    position : FishingBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    spriteSheet : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [FishingBoardUnitsItemTraitsItem]
    previousPosition : FishingBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type FishingBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type FishingBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type FishingBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type FishingBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type FishingBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type FishingBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity FishingBoardItem [runtime] {
    id : string!
    units : [FishingBoardUnitsItem]
    catchCount : number = 0
    score : number = 0
    phase : string = "idle"
    reelWindow : number = 0
    result : "none" | "won" = none
    effects : [FishingBoardEffectItem] = []
  }

  trait FishingBoardRender -> @rebindable FishingBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.phase "idle")
        (set @entity.reelWindow 0)
        (set @entity.catchCount 0)
        (set @entity.score 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.json", sprite: "fish_orange", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-catch", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CAST, label: "Cast", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_drop.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-cast", thumbnailUrl: "" }, variant: primary }, { type: button, action: REEL, label: "Reel", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "rotate_cw.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-reel", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), anchor: "ground", width: 0.5, height: 0.5 })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: 0.5, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: (* 0.5 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      CAST -> playing when (and (== @entity.phase "idle") (== @entity.result "none"))
        (set @entity.phase "waiting")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id "hook") (object/merge @u { position: { x: 3, y: 2 }, animation: "walk" }) @u))))
        (set @entity.effects (array/append @entity.effects { key: "splash", x: 3, y: 1, ttl: 6 }))
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.json", sprite: "fish_orange", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-catch", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CAST, label: "Cast", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_drop.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-cast", thumbnailUrl: "" }, variant: primary }, { type: button, action: REEL, label: "Reel", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "rotate_cw.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-reel", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), anchor: "ground", width: 0.5, height: 0.5 })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: 0.5, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: (* 0.5 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      REEL -> playing when (== @entity.phase "hooked")
        (set @entity.phase "idle")
        (set @entity.reelWindow 0)
        (set @entity.score (+ @entity.score (let ((roll (math/random))) (if (< @roll 0.5) 10 (if (< @roll 0.8) 20 30)))))
        (set @entity.catchCount (+ @entity.catchCount 1))
        (set @entity.effects (array/append @entity.effects { key: "splash", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id "hook"))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id "hook"))) position) y), ttl: 8 }))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id "hook") (object/merge @u { position: { x: 3, y: 1 }, animation: "idle" }) @u))))
        (set @entity.result (if (>= @entity.catchCount @config.catchTarget) "won" @entity.result))
        (if (!= @entity.result "none") (emit GAME_END) null)
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.json", sprite: "fish_orange", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-catch", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CAST, label: "Cast", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_drop.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-cast", thumbnailUrl: "" }, variant: primary }, { type: button, action: REEL, label: "Reel", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "rotate_cw.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-reel", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), anchor: "ground", width: 0.5, height: 0.5 })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: 0.5, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: (* 0.5 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })

      GAME_END -> gameover when (!= @entity.result "none")
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Catch", value: @entity.catchCount, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-fishing-board/kenney-fish-pack/terrain/spritesheet.json", sprite: "fish_orange", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-catch", thumbnailUrl: "" } }, { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_star.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } } ] } ] }
          addons: { type: stack, direction: vertical, gap: sm, children: [ { type: button, action: CAST, label: "Cast", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-emote-pack/ui/vector_style1.json", sprite: "emote_drop.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-cast", thumbnailUrl: "" }, variant: primary }, { type: button, action: REEL, label: "Reel", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-cursor-pack/ui/kenney-cursor-pack.generated.json", sprite: "rotate_cw.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "icon-reel", thumbnailUrl: "" }, variant: primary } ] }
          overlay: { type: game-menu, title: "VICTORY", subtitle: (str/concat "Full net! Score: " @entity.score), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] }
          children: [ { type: canvas, camera: { zoom: (math/min 1 (/ 5 (+ 1 (math/max (array/max @config.tiles "x") (array/max @config.tiles "y"))))), pos: { x: (/ (+ (array/min @config.tiles "x") (array/max @config.tiles "x")) 2), y: (/ (+ (array/min @config.tiles "y") (array/max @config.tiles "y")) 2) } }, projection: "flat", showMinimap: false, children: [
            { type: draw-shape-layer, items: (array/map @config.tiles (fn t { type: draw-shape, shape: "cell", position: { x: (object/get @t x), y: (object/get @t y) }, fill: "#5c94fc", stroke: "rgba(255,255,255,0.35)", strokeWidth: 1 })) }
            { type: draw-sprite-layer, items: (array/map @config.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t terrainSprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @config.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f sprite), anchor: "center", width: 0.5, height: 0.5 })) }
            { type: draw-sprite-layer, items: (array/map @entity.units (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), anchor: "ground", width: 0.5, height: 0.5 })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: 0.5, height: 0.12, fill: "rgba(0,0,0,0.6)" })) }
            { type: draw-shape-layer, items: (array/map @entity.units (fn u { type: draw-shape, shape: "rect", position: (object/get @u position), anchor: "ground", offsetX: -0.25, offsetY: -0.6, width: (* 0.5 (/ (object/get @u health) (object/get @u maxHealth))), height: 0.12, fill: "#22c55e" })) }
            { type: draw-text-layer, items: (array/map @entity.units (fn u { type: draw-text, text: (object/get @u name), position: (object/get @u position), offsetY: -0.85, color: "#ffffff" })) }
            { type: draw-sprite-layer, items: (array/map @entity.effects (fn e { type: draw-sprite, position: { x: (object/get @e x), y: (object/get @e y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @e key)) })) }
          ] } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.units @config.units)
        (set @entity.phase "idle")
        (set @entity.reelWindow 0)
        (set @entity.catchCount 0)
        (set @entity.score 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          fontFamily: "future"
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/blueSheet.json", sprite: "blue_panel.png", role: "ui", category: "ui", animations: ["static"], style: "vector", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
