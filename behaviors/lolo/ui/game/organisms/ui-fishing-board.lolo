app ui-fishing-board "1.0.0"
"FishingBoard — UI factory (1:1 with the @almadar/ui fishing-board pattern)."
orbital FishingBoardOrbital {
  type FishingBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type FishingBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type FishingBoardUnitsItem = {
    id : string!
    position : FishingBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    spriteSheet : asset
    modelUrl : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [FishingBoardUnitsItemTraitsItem]
    previousPosition : FishingBoardUnitsItemPreviousPosition
    elevation : number
  }
  type FishingBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type FishingBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type FishingBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type FishingBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }

  entity FishingBoardItem [runtime] {
    id : string!
  }

  trait FishingBoardRender -> @rebindable FishingBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          assetManifest: @config.assetManifest
          assetBaseUrl: @config.assetBaseUrl
          scale: @config.scale
          showMinimap: @config.showMinimap
          enableCamera: @config.enableCamera
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          type: fishing-board
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Declarative event: emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Declarative event: emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : FishingBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [FishingBoardTilesItem] = [{ x: 0, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 1, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 2, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 3, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 4, y: 0, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 0, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 1, y: 1, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 2, y: 1, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 3, y: 1, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 4, y: 1, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 0, y: 2, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 1, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 2, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 3, y: 2, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 4, y: 2, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 0, y: 3, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 1, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 2, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 3, y: 3, terrain: "seabed", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 4, y: 3, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 0, y: 4, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 1, y: 4, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 2, y: 4, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 3, y: 4, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { x: 4, y: 4, terrain: "water", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }]
        @label "Tiles"
        @description "Flat top-down fishing scene tiles (water + seabed)"
        @tier "presentation"
      units : [FishingBoardUnitsItem] = [{ id: "u1", position: { x: 2, y: 0 }, unitType: "boat", name: "Fishing Boat", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/units/chars-roguelike/kflow/sprite-sheets/amir-sprite-sheet-se.png" }, { id: "u2", position: { x: 2, y: 4 }, unitType: "hook", name: "Hook", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/units/chars-roguelike/kflow/sprite-sheets/mender-sprite-sheet-se.png" }]
        @label "Units"
        @description "Units on the board (boat, hook)"
        @tier "presentation"
      features : [FishingBoardFeaturesItem] = [{ id: "f1", x: 1, y: 2, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { id: "f2", x: 3, y: 2, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }, { id: "f3", x: 2, y: 3, type: "fish", sprite: "https://almadar-kflow-assets.web.app/shared/terrains/tiles-iso-medieval/kenney-isometric-tiles-base/landscapeTiles_000.png" }]
        @label "Features"
        @description "Features on the board (fish spots)"
        @tier "presentation"
      assetManifest : string = ""
        @label "Asset Manifest"
        @description "Asset sprite manifest (same shape as IsometricCanvas.assetManifest)"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prepended to manifest sprite paths"
        @tier "presentation"
      scale : number = 1
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
      showMinimap : boolean = false
        @label "Show Minimap"
        @description "Show minimap overlay"
        @tier "presentation"
      enableCamera : boolean = true
        @label "Enable Camera"
        @description "Enable camera pan/zoom controls"
        @tier "presentation"
    }
  }

  page "/fishing-board" as FishingBoardPage -> FishingBoardRender
}
