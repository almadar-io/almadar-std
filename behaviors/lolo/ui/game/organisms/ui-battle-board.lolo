      features : [BattleBoardFeaturesItem] = [{ id: "f1", x: 13, y: 1, type: "gold_mine", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/features/gold_mine.png", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" } }, { id: "f2", x: 1, y: 14, type: "portal", sprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/features/portal.png", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }]
        @label "Features"
        @description "Direct feature data — takes priority over entity-derived features."
        @tier "presentation"
      assetManifest : BattleBoardAssetManifest = { terrains: { grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, stone: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, dirt: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/dirt.png", role: "tile", category: "dirt", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "dirt", thumbnailUrl: "" }, planks: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/terrain/planks.png", role: "tile", category: "planks", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "planks", thumbnailUrl: "" } }, units: { worker: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/worker.png", role: "npc", category: "worker", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "worker", thumbnailUrl: "" }, mender: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/mender.png", role: "npc", category: "mender", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "mender", thumbnailUrl: "" }, guardian: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/guardian.png", role: "npc", category: "guardian", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "guardian", thumbnailUrl: "" }, scrapper: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/scrapper.png", role: "npc", category: "scrapper", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "scrapper", thumbnailUrl: "" } }, features: { gold_mine: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/features/gold_mine.png", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" }, portal: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/features/portal.png", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }, effects: { slash: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/slash_03.png", role: "effect", category: "slash", animations: ["static"], style: "", dimension: "2d", aspect: "8:1", name: "slash", thumbnailUrl: "" }, explosion: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/pixelExplosion07.png", role: "effect", category: "explosion", animations: ["static"], style: "", dimension: "2d", aspect: "8:1", name: "explosion", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Direct asset manifest — takes priority over entity-derived manifest."
        @tier "presentation"
      scale : number = 0.25
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      hasActiveEffects : boolean = false
        @label "Has Active Effects"
        @description "hasActiveEffects prop"
        @tier "presentation"
      effectSpriteUrls : [asset] = ["https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/slash_03.png", "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/magic_02.png", "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/spark_06.png", "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/pixelExplosion07.png"]
        @label "Effect Sprite Urls"
        @description "effectSpriteUrls prop"
        @tier "presentation"
    }
  }

  page "/battle-board" as BattleBoardPage -> BattleBoardRender
}
