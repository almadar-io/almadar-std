    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardATTACKTargetSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardATTACKTargetPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardATTACKTargetTraitsItem]
  }
  type BattleBoardATTACKTargetSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardATTACKTargetPosition = {
    x : number!
    y : number!
  }
  type BattleBoardATTACKTargetTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardUNITMOVEUnit = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardUNITMOVEUnitSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardUNITMOVEUnitPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardUNITMOVEUnitTraitsItem]
  }
  type BattleBoardUNITMOVEUnitSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardUNITMOVEUnitPosition = {
    x : number!
    y : number!
  }
  type BattleBoardUNITMOVEUnitTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardUNITMOVETo = {
    x : number!
    y : number!
  }
  type BattleBoardCALCULATEDAMAGEAttacker = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardCALCULATEDAMAGEAttackerSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardCALCULATEDAMAGEAttackerPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardCALCULATEDAMAGEAttackerTraitsItem]
  }
  type BattleBoardCALCULATEDAMAGEAttackerSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardCALCULATEDAMAGEAttackerPosition = {
    x : number!
    y : number!
  }
  type BattleBoardCALCULATEDAMAGEAttackerTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardCALCULATEDAMAGETarget = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardCALCULATEDAMAGETargetSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardCALCULATEDAMAGETargetPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardCALCULATEDAMAGETargetTraitsItem]
  }
  type BattleBoardCALCULATEDAMAGETargetSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardCALCULATEDAMAGETargetPosition = {
    x : number!
    y : number!
  }
  type BattleBoardCALCULATEDAMAGETargetTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }

  entity BattleBoardItem [runtime] {
    id : string!
  }

  trait BattleBoardRender -> @rebindable BattleBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          scale: @config.scale
          unitScale: @config.unitScale
          header: HEADER
          sidebar: SIDEBAR
          actions: ACTIONS
          overlay: OVERLAY
          gameOverOverlay: GAME_OVER_OVERLAY
          onAttack: ATTACK
          onGameEnd: GAME_END
          onUnitMove: UNIT_MOVE
          calculateDamage: CALCULATE_DAMAGE
          onDrawEffects: DRAW_EFFECTS
          hasActiveEffects: @config.hasActiveEffects
          effectSpriteUrls: @config.effectSpriteUrls
          resolveUnitFrame: RESOLVE_UNIT_FRAME
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          endTurnEvent: END_TURN
          cancelEvent: CANCEL
          gameEndEvent: GAME_END
          playAgainEvent: PLAY_AGAIN
          attackEvent: ATTACK
          className: @config.className
          type: battle-board
        })
    }

    emits {
      HEADER -> external {
        ctx : BattleBoardHEADERCtx
      }
        @description "-- Slots --"
        @tier "essential"
      SIDEBAR -> external {
        ctx : BattleBoardSIDEBARCtx
      }
        @description "Sidebar content (combat log, unit roster, etc.)"
        @tier "essential"
      ACTIONS -> external {
        ctx : BattleBoardACTIONSCtx
      }
        @description "Floating action buttons"
        @tier "essential"
      OVERLAY -> external {
        ctx : BattleBoardOVERLAYCtx
      }
        @description "Floating overlays above the canvas (damage popups, tooltips)"
        @tier "essential"
      GAME_OVER_OVERLAY -> external {
        ctx : BattleBoardGAMEOVEROVERLAYCtx
      }
        @description "Game-over screen overlay"
        @tier "essential"
      ATTACK -> external {
        attacker : BattleBoardATTACKAttacker
        target : BattleBoardATTACKTarget
        damage : number
        attackerId : string!
        targetId : string!
      }
        @description "-- Callbacks --"
        @tier "essential"
      GAME_END -> external {
        result : string
      }
        @description "Called when battle ends"
        @tier "essential"
      UNIT_MOVE -> external {
        unit : BattleBoardUNITMOVEUnit
        to : BattleBoardUNITMOVETo
      }
        @description "Called after a unit moves"
        @tier "essential"
      CALCULATE_DAMAGE -> external {
        attacker : BattleBoardCALCULATEDAMAGEAttacker
        target : BattleBoardCALCULATEDAMAGETarget
      }
        @description "Custom combat damage calculator"
        @tier "essential"
      DRAW_EFFECTS -> external {
        ctx : object
        timestamp : number
      }
        @description "-- Canvas pass-through --"
        @tier "essential"
      RESOLVE_UNIT_FRAME -> external {
        unitId : string
      }
        @description "resolveUnitFrame prop"
        @tier "essential"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "-- Declarative event props --"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
      END_TURN -> external {
        id : string
      }
        @description "Emits UI:{endTurnEvent} with {} on end turn"
        @tier "essential"
      CANCEL -> external {
        id : string
      }
        @description "Emits UI:{cancelEvent} with {} on cancel"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "essential"
    }

    config {
      entityProp : BattleBoardEntity
        @label "Entity"
        @description "Entity containing all board data"
        @synonyms "entity"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      hasActiveEffects : boolean = false
        @label "Has Active Effects"
        @description "hasActiveEffects prop"
        @tier "presentation"
      effectSpriteUrls : [string] = []
        @label "Effect Sprite Urls"
        @description "effectSpriteUrls prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/battle-board" as BattleBoardPage -> BattleBoardRender
}
