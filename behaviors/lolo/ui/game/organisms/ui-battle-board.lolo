app ui-battle-board "1.0.0"
"BattleBoard — UI factory (1:1 with the @almadar/ui battle-board pattern)."
orbital BattleBoardOrbital {
  type BattleBoardEntity = {
    id : string!
    tiles : [BattleBoardEntityTilesItem]!
    features : [BattleBoardEntityFeaturesItem]
    boardWidth : number
    boardHeight : number
    assetManifest : BattleBoardEntityAssetManifest
    backgroundImage : string
    units : [BattleBoardEntityUnitsItem]!
    phase : "observation" | "selection" | "movement" | "action" | "enemy_turn" | "game_over"!
    turn : number!
    gameResult : "victory" | "defeat"!
    selectedUnitId : string!
  }
  type BattleBoardEntityTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : string
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
  }
  type BattleBoardEntityFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : string
    assetUrl : string
    color : string
    elevation : number
  }
  type BattleBoardEntityAssetManifest = {
    baseUrl : string!
    terrains : Map string string
    units : Map string string
    features : Map string string
    effects : Map string string
  }
  type BattleBoardEntityUnitsItem = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardEntityUnitsItemSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardEntityUnitsItemPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardEntityUnitsItemTraitsItem]
  }
  type BattleBoardEntityUnitsItemSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardEntityUnitsItemPosition = {
    x : number!
    y : number!
  }
  type BattleBoardEntityUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardATTACKAttacker = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardATTACKAttackerSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardATTACKAttackerPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardATTACKAttackerTraitsItem]
  }
  type BattleBoardATTACKAttackerSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardATTACKAttackerPosition = {
    x : number!
    y : number!
  }
  type BattleBoardATTACKAttackerTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardATTACKTarget = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardATTACKTargetSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardATTACKTargetPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardATTACKTargetTraitsItem]
  }
  type BattleBoardATTACKTargetSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardATTACKTargetPosition = {
    x : number!
    y : number!
  }
  type BattleBoardATTACKTargetTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardUNITMOVEUnit = {
    id : string!
    name : string!
    unitType : string
    heroId : string
    sprite : string
    spriteSheet : BattleBoardUNITMOVEUnitSpriteSheet
    team : "player" | "enemy"!
    position : BattleBoardUNITMOVEUnitPosition!
    health : number!
    maxHealth : number!
    movement : number!
    attack : number!
    defense : number!
    traits : [BattleBoardUNITMOVEUnitTraitsItem]
  }
  type BattleBoardUNITMOVEUnitSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type BattleBoardUNITMOVEUnitPosition = {
    x : number!
    y : number!
  }
  type BattleBoardUNITMOVEUnitTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number
  }
  type BattleBoardUNITMOVETo = {
    x : number!
    y : number!
  }

  entity BattleBoardItem [runtime] {
    id : string!
  }

  trait BattleBoardRender -> @rebindable BattleBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          scale: @config.scale
          unitScale: @config.unitScale
          onAttack: ATTACK
          onGameEnd: GAME_END
          onUnitMove: UNIT_MOVE
          hasActiveEffects: @config.hasActiveEffects
          effectSpriteUrls: @config.effectSpriteUrls
          tileClickEvent: TILE_CLICK
          unitClickEvent: UNIT_CLICK
          endTurnEvent: END_TURN
          cancelEvent: CANCEL
          gameEndEvent: GAME_END
          playAgainEvent: PLAY_AGAIN
          attackEvent: ATTACK
          className: @config.className
          type: battle-board
        })
    }

    emits {
      ATTACK -> external {
        attacker : BattleBoardATTACKAttacker
        target : BattleBoardATTACKTarget
        damage : number
        attackerId : string!
        targetId : string!
      }
        @description "-- Callbacks --"
        @tier "essential"
      GAME_END -> external {
        result : string
      }
        @description "Called when battle ends"
        @tier "essential"
      UNIT_MOVE -> external {
        unit : BattleBoardUNITMOVEUnit
        to : BattleBoardUNITMOVETo
      }
        @description "Called after a unit moves"
        @tier "essential"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "-- Declarative event props --"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
      END_TURN -> external {
        id : string
      }
        @description "Emits UI:{endTurnEvent} with {} on end turn"
        @tier "essential"
      CANCEL -> external {
        id : string
      }
        @description "Emits UI:{cancelEvent} with {} on cancel"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "essential"
    }

    config {
      entityProp : BattleBoardEntity = { id: "", tiles: [], units: [], phase: observation, turn: 0, gameResult: victory, selectedUnitId: "" }
        @label "Entity"
        @description "Entity containing all board data"
        @synonyms "entity"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 1
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      hasActiveEffects : boolean = false
        @label "Has Active Effects"
        @description "hasActiveEffects prop"
        @tier "presentation"
      effectSpriteUrls : [string] = []
        @label "Effect Sprite Urls"
        @description "effectSpriteUrls prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/battle-board" as BattleBoardPage -> BattleBoardRender
}
