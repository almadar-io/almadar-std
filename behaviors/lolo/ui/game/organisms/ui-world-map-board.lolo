app ui-world-map-board "1.0.0"
"WorldMapBoard — game-shell composition with isometric canvas, overworld hero movement, battle encounters, and walk/idle animation ticks."
orbital WorldMapBoardOrbital {
  type WorldMapBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type WorldMapBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : Asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : Asset
  }
  type WorldMapBoardUnitsItem = {
    id : string!
    position : WorldMapBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : Asset
    modelUrl : Asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    movement : number
    traits : [WorldMapBoardUnitsItemTraitsItem]
    previousPosition : WorldMapBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type WorldMapBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type WorldMapBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type WorldMapBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : Asset
    assetUrl : Asset
    color : string
    elevation : number
  }
  type WorldMapBoardAssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity WorldMapBoardItem [runtime] {
    id : string!
    units : [WorldMapBoardUnitsItem]
    tiles : [WorldMapBoardTilesItem]
    features : [WorldMapBoardFeaturesItem]
    selectedHeroId : string = ""
    turn : number = 0
    result : "none" | "win" | "lose" = none
    gridWidth : number = 16
    gridHeight : number = 16
    movementRange : number = 3
    effects : [WorldMapBoardEffectItem] = []
  }

  trait WorldMapBoardRender -> @rebindable WorldMapBoardItem [interaction, instance] {
    initial: playing

    state menu {
      START -> playing
        (set @entity.units (array/map @config.units (fn u (object/merge @u { animation: "idle", frame: 0 }))))
        (set @entity.tiles @config.tiles)
        (set @entity.features @config.features)
        (set @entity.selectedHeroId "")
        (set @entity.turn 0)
        (set @entity.result "none")
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.movementRange 3)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state playing {
      INIT -> playing
        (set @entity.units (array/map @config.units (fn u (object/merge @u { animation: "idle", frame: 0 }))))
        (set @entity.tiles @config.tiles)
        (set @entity.features @config.features)
        (set @entity.selectedHeroId "")
        (set @entity.turn 0)
        (set @entity.result "none")
        (set @entity.gridWidth 16)
        (set @entity.gridHeight 16)
        (set @entity.movementRange 3)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      HERO_SELECT -> playing when (== (object/get (array/find @entity.units (fn u (== @u.id ?heroId))) team) "player")
        (set @entity.selectedHeroId ?heroId)
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      HERO_MOVE -> playing when (and (!= @entity.selectedHeroId "") (and (grid/in-bounds { x: ?toX, y: ?toY } @entity.gridWidth @entity.gridHeight) (and (<= (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id @entity.selectedHeroId))) position) { x: ?toX, y: ?toY }) @entity.movementRange) (and (== (object/get (array/find @entity.tiles (fn t (and (== (object/get @t x) ?toX) (== (object/get @t y) ?toY)))) passable) true) (== (array/len (array/filter @entity.units (fn u (and (== (object/get (object/get @u position) x) ?toX) (== (object/get (object/get @u position) y) ?toY))))) 0)))))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id @entity.selectedHeroId) (object/merge @u { position: { x: ?toX, y: ?toY }, animation: "walk" }) @u))))
        (set @entity.selectedHeroId "")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      BATTLE_ENCOUNTER -> playing when (and (!= @entity.selectedHeroId "") (== (grid/manhattan-distance (object/get (array/find @entity.units (fn u (== @u.id ?attackerId))) position) (object/get (array/find @entity.units (fn u (== @u.id ?defenderId))) position)) 1))
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id ?defenderId) (object/merge @u { health: (math/max 0 (- (object/get @u health) 3)), animation: "hit" }) @u))))
        (set @entity.effects (array/append @entity.effects { key: "slash", x: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?defenderId))) position) x), y: (object/get (object/get (array/find @entity.units (fn u (== @u.id ?defenderId))) position) y), ttl: 4 }))
        (set @entity.selectedHeroId "")
        (set @entity.turn (+ @entity.turn 1))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      FEATURE_ENTER -> playing
        (set @entity.turn (+ @entity.turn 1))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      TILE_CLICK -> playing
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })

      GAME_END -> gameover when (or (== (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> (object/get @u health) 0))))) 0) (== (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> (object/get @u health) 0))))) 0))
        (set @entity.result (if (== (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> (object/get @u health) 0))))) 0) "lose" "win"))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> menu
        (set @entity.units (array/map @config.units (fn u (object/merge @u { animation: "idle", frame: 0 }))))
        (set @entity.tiles @config.tiles)
        (set @entity.features @config.features)
        (set @entity.selectedHeroId "")
        (set @entity.turn 0)
        (set @entity.result "none")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.units (array/map @entity.units (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Region", value: "Overworld" }, { label: "Turn", value: @entity.turn }, { label: "Gold", value: 0 } ] }
          children: [ { type: canvas-2d, tiles: @entity.tiles, units: @entity.units, features: @entity.features, effects: @entity.effects, assetManifest: @config.assetManifest, projection: "isometric", showMinimap: true, scale: @config.scale } ]
        })
    }

    emits {
      HERO_SELECT -> external {
        heroId : string!
      }
        @description "-- Declarative event props --"
        @tier "essential"
      HERO_MOVE -> external {
        heroId : string!
        toX : number!
        toY : number!
      }
        @description "Emits UI:{heroMoveEvent} with { heroId, toX, toY }"
        @tier "essential"
      BATTLE_ENCOUNTER -> external {
        attackerId : string!
        defenderId : string!
      }
        @description "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }"
        @tier "essential"
      FEATURE_ENTER -> external {
        heroId : string!
        feature : string!
        hex : object!
      }
        @description "Emits UI:{featureEnterEvent} with { heroId, feature, hex }"
        @tier "essential"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y }"
        @tier "essential"
      GAME_END -> external {
        result : string
      }
        @description "Called when all enemies or all player heroes are defeated"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : WorldMapBoardError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      tiles : [WorldMapBoardTilesItem] = [{ id: "t0_0", x: 0, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t1_0", x: 1, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t2_0", x: 2, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t3_0", x: 3, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t4_0", x: 4, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t5_0", x: 5, y: 0, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t6_0", x: 6, y: 0, terrain: "grass", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, passable: true }, { id: "t7_0", x: 7, y: 0, terrain: "grass", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, passable: true }, { id: "t8_0", x: 8, y: 0, terrain: "grass", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, passable: true }, { id: "t9_0", x: 9, y: 0, terrain: "grass", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, passable: true }, { id: "t10_0", x: 10, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { id: "t11_0", x: 11, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { id: "t12_0", x: 12, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { id: "t13_0", x: 13, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { id: "t14_0", x: 14, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { id: "t15_0", x: 15, y: 0, terrain: "stone", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" }, passable: false }, { id: "t0_1", x: 0, y: 1, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t1_1", x: 1, y: 1, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passable: false }, { id: "t2_1", x: 2, y: 1, terrain: "forest", terrainSprite: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, passa