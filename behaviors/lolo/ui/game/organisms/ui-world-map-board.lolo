        @description "World features seeded into entity on INIT."
        @tier "presentation"
      assetManifest : WorldMapBoardAssetManifest = { terrains: { grass: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/grass.png", role: "tile", category: "grass", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "grass", thumbnailUrl: "" }, forest: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/forest.png", role: "tile", category: "forest", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "forest", thumbnailUrl: "" }, stone: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/terrain/stone.png", role: "tile", category: "stone", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "stone", thumbnailUrl: "" } }, units: { hero: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/units/hero.png", role: "npc", category: "hero", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "hero", thumbnailUrl: "" }, guard: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/units/guard.png", role: "npc", category: "guard", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "guard", thumbnailUrl: "" } }, features: { gold_mine: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/features/gold_mine.png", role: "decoration", category: "gold_mine", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "gold_mine", thumbnailUrl: "" }, portal: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/features/portal.png", role: "decoration", category: "portal", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "portal", thumbnailUrl: "" } }, effects: { slash: { url: "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/effects/slash_03.png", role: "effect", category: "slash", animations: ["static"], style: "", dimension: "2d", aspect: "8:1", name: "slash", thumbnailUrl: "" } } }
        @label "Asset Manifest"
        @description "Direct asset manifest — takes priority over entity-derived manifest."
        @tier "presentation"
      scale : number = 0.25
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 2.5
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      allowMoveAllHeroes : boolean = false
        @label "Allow Move All Heroes"
        @description "Allow selecting / moving ALL heroes (including enemy). For testing."
        @tier "presentation"
      diamondTopY : number = 374
        @label "Diamond Top Y"
        @description "Y pixel offset to the top diamond vertex of the isometric grid."
        @tier "presentation"
      enableCamera : boolean = true
        @label "Enable Camera"
        @description "Enable pan/zoom camera. Set false for fixed maps where overlay labels need stable positions."
        @tier "presentation"
      effectSpriteUrls : [asset] = ["https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/effects/slash_03.png", "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/effects/magic_02.png", "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/effects/spark_06.png", "https://almadar-kflow-assets.web.app/shared/ui-world-map-board/default/effects/pixelExplosion07.png"]
        @label "Effect Sprite Urls"
        @description "effectSpriteUrls prop"
        @tier "presentation"
    }
  }

  page "/world-map-board" as WorldMapBoardPage -> WorldMapBoardRender
}
