app ui-world-map-board "1.0.0"
"WorldMapBoard — UI factory (1:1 with the @almadar/ui world-map-board pattern)."
orbital WorldMapBoardOrbital {
  type WorldMapBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type WorldMapBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type WorldMapBoardUnitsItem = {
    id : string!
    position : WorldMapBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [WorldMapBoardUnitsItemTraitsItem]
    previousPosition : WorldMapBoardUnitsItemPreviousPosition
    elevation : number
  }
  type WorldMapBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type WorldMapBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }
  type WorldMapBoardAssetManifest = {
    baseUrl : asset
    terrains : Map string asset
    units : Map string asset
    features : Map string asset
  }

  entity WorldMapBoardItem [runtime] {
    id : string!
  }

  trait WorldMapBoardRender -> @rebindable WorldMapBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch WorldMapBoardItem {})
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          entity: @entity
          tiles: @config.tiles
          units: @config.units
          features: @config.features
          assetManifest: @config.assetManifest
          scale: @config.scale
          unitScale: @config.unitScale
          allowMoveAllHeroes: @config.allowMoveAllHeroes
          heroSelectEvent: HERO_SELECT
          heroMoveEvent: HERO_MOVE
          battleEncounterEvent: BATTLE_ENCOUNTER
          featureEnterEvent: FEATURE_ENTER
          tileClickEvent: TILE_CLICK
          onHeroSelect: HERO_SELECT
          onHeroMove: HERO_MOVE
          onBattleEncounter: BATTLE_ENCOUNTER
          onFeatureEnter: FEATURE_ENTER
          diamondTopY: @config.diamondTopY
          enableCamera: @config.enableCamera
          effectSpriteUrls: @config.effectSpriteUrls
          type: world-map-board
        })
    }

    emits {
      HERO_SELECT -> external {
        heroId : string!
      }
        @description "-- Declarative event props --"
        @tier "essential"
      HERO_MOVE -> external {
        heroId : string!
        toX : number!
        toY : number!
      }
        @description "Emits UI:{heroMoveEvent} with { heroId, toX, toY }"
        @tier "essential"
      BATTLE_ENCOUNTER -> external {
        attackerId : string!
        defenderId : string!
      }
        @description "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }"
        @tier "essential"
      FEATURE_ENTER -> external {
        heroId : string!
        feature : string!
        hex : object!
      }
        @description "Emits UI:{featureEnterEvent} with { heroId, feature, hex }"
        @tier "essential"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y }"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : WorldMapBoardError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      tiles : [WorldMapBoardTilesItem] = [{ x: 0, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 1, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 2, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 3, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 4, y: 0, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 0, y: 1, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 1, y: 1, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail.glb" }, { x: 2, y: 1, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb" }, { x: 3, y: 1, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb" }, { x: 4, y: 1, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 0, y: 2, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 1, y: 2, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb" }, { x: 2, y: 2, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail.glb" }, { x: 3, y: 2, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb" }, { x: 4, y: 2, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 0, y: 3, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 1, y: 3, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb" }, { x: 2, y: 3, terrain: "grass", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor.glb" }, { x: 3, y: 3, terrain: "dirt", passable: true, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/floor/template-floor-detail.glb" }, { x: 4, y: 3, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 0, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 1, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 2, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 3, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }, { x: 4, y: 4, terrain: "stone", passable: false, modelUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/rooms/room-small.glb" }]
        @label "Tiles"
        @description "Direct tile data — takes priority over entity-derived tiles."
        @tier "presentation"
      units : [WorldMapBoardUnitsItem] = [{ id: "u1", position: { x: 1, y: 1 }, unitType: "worker", name: "Worker", team: player, health: 10, maxHealth: 10 }, { id: "u2", position: { x: 3, y: 3 }, unitType: "guardian", name: "Guardian", team: enemy, health: 8, maxHealth: 10 }]
        @label "Units"
        @description "Direct unit data — takes priority over entity-derived units."
        @tier "presentation"
      features : [WorldMapBoardFeaturesItem] = [{ id: "f1", x: 2, y: 2, type: "gold_mine", assetUrl: "https://almadar-kflow-assets.web.app/shared/3d/medieval/props/barrels.glb" }, { id: "f2", x: 3, y: 1, type: "portal", assetUrl: "https://almadar-kflow-assets.web.app/shared/3d/dungeon/gates/gate-door.glb" }]
        @label "Features"
        @description "Direct feature data — takes priority over entity-derived features."
        @tier "presentation"
      assetManifest : WorldMapBoardAssetManifest = { terrains: { grass: "isometric-dungeon/Isometric/dirt_E.png", dirt: "isometric-dungeon/Isometric/dirtTiles_E.png", stone: "isometric-dungeon/Isometric/stoneInset_E.png", forest: "isometric-dungeon/Isometric/planks_E.png", castle: "isometric-dungeon/Isometric/stoneTile_E.png" }, units: { worker: "units/worker.png", guardian: "units/guardian.png", scrapper: "units/scrapper.png", mender: "units/mender.png" }, features: { gold_mine: "world-map/gold_mine.png", portal: "world-map/portal_open.png", castle: "castle/resonator_citadel.png" } }
        @label "Asset Manifest"
        @description "Direct asset manifest — takes priority over entity-derived manifest."
        @tier "presentation"
      scale : number = 0.4
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 2.5
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      allowMoveAllHeroes : boolean = false
        @label "Allow Move All Heroes"
        @description "Allow selecting / moving ALL heroes (including enemy). For testing."
        @tier "presentation"
      diamondTopY : number = 0
        @label "Diamond Top Y"
        @description "-- Canvas pass-through --"
        @tier "presentation"
      enableCamera : boolean = false
        @label "Enable Camera"
        @description "Disable pan/zoom camera (default: true). Set false for fixed maps where overlay labels need stable positions."
        @tier "presentation"
      effectSpriteUrls : [asset] = []
        @label "Effect Sprite Urls"
        @description "effectSpriteUrls prop"
        @tier "presentation"
    }
  }

  page "/world-map-board" as WorldMapBoardPage -> WorldMapBoardRender
}
