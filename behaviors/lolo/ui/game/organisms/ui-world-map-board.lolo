app ui-world-map-board "1.0.0"
"WorldMapBoard — UI factory (1:1 with the @almadar/ui world-map-board pattern)."
orbital WorldMapBoardOrbital {
  type WorldMapBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type WorldMapBoardEntity = {
    id : string!
    hexes : [WorldMapBoardEntityHexesItem]!
    heroes : [WorldMapBoardEntityHeroesItem]!
    features : [WorldMapBoardEntityFeaturesItem]
    selectedHeroId : string
    assetManifest : WorldMapBoardEntityAssetManifest
    backgroundImage : string
  }
  type WorldMapBoardEntityHexesItem = {
    x : number!
    y : number!
    terrain : string!
    terrainSprite : string
    feature : string
    featureData : json
    passable : boolean
  }
  type WorldMapBoardEntityHeroesItem = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardEntityHeroesItemPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardEntityHeroesItemSpriteSheet
    level : number
  }
  type WorldMapBoardEntityHeroesItemPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardEntityHeroesItemSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardEntityFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : string
    assetUrl : string
    color : string
    elevation : number
  }
  type WorldMapBoardEntityAssetManifest = {
    baseUrl : string!
    terrains : json
    units : json
    features : json
  }
  type WorldMapBoardISINRANGEFrom = {
    x : number!
    y : number!
  }
  type WorldMapBoardISINRANGETo = {
    x : number!
    y : number!
  }
  type WorldMapBoardHEADERCtx = {
    hoveredTile : WorldMapBoardHEADERCtxHoveredTile!
    hoveredHex : WorldMapBoardHEADERCtxHoveredHex!
    hoveredHero : WorldMapBoardHEADERCtxHoveredHero!
    selectedHero : WorldMapBoardHEADERCtxSelectedHero!
    validMoves : [WorldMapBoardHEADERCtxValidMovesItem]!
    scale : number!
  }
  type WorldMapBoardHEADERCtxHoveredTile = {
    x : number!
    y : number!
  }
  type WorldMapBoardHEADERCtxHoveredHex = {
    x : number!
    y : number!
    terrain : string!
    terrainSprite : string
    feature : string
    featureData : json
    passable : boolean
  }
  type WorldMapBoardHEADERCtxHoveredHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardHEADERCtxHoveredHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardHEADERCtxHoveredHeroSpriteSheet
    level : number
  }
  type WorldMapBoardHEADERCtxHoveredHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardHEADERCtxHoveredHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardHEADERCtxSelectedHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardHEADERCtxSelectedHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardHEADERCtxSelectedHeroSpriteSheet
    level : number
  }
  type WorldMapBoardHEADERCtxSelectedHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardHEADERCtxSelectedHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardHEADERCtxValidMovesItem = {
    x : number!
    y : number!
  }
  type WorldMapBoardSIDEPANELCtx = {
    hoveredTile : WorldMapBoardSIDEPANELCtxHoveredTile!
    hoveredHex : WorldMapBoardSIDEPANELCtxHoveredHex!
    hoveredHero : WorldMapBoardSIDEPANELCtxHoveredHero!
    selectedHero : WorldMapBoardSIDEPANELCtxSelectedHero!
    validMoves : [WorldMapBoardSIDEPANELCtxValidMovesItem]!
    scale : number!
  }
  type WorldMapBoardSIDEPANELCtxHoveredTile = {
    x : number!
    y : number!
  }
  type WorldMapBoardSIDEPANELCtxHoveredHex = {
    x : number!
    y : number!
    terrain : string!
    terrainSprite : string
    feature : string
    featureData : json
    passable : boolean
  }
  type WorldMapBoardSIDEPANELCtxHoveredHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardSIDEPANELCtxHoveredHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardSIDEPANELCtxHoveredHeroSpriteSheet
    level : number
  }
  type WorldMapBoardSIDEPANELCtxHoveredHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardSIDEPANELCtxHoveredHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardSIDEPANELCtxSelectedHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardSIDEPANELCtxSelectedHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardSIDEPANELCtxSelectedHeroSpriteSheet
    level : number
  }
  type WorldMapBoardSIDEPANELCtxSelectedHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardSIDEPANELCtxSelectedHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardSIDEPANELCtxValidMovesItem = {
    x : number!
    y : number!
  }
  type WorldMapBoardOVERLAYCtx = {
    hoveredTile : WorldMapBoardOVERLAYCtxHoveredTile!
    hoveredHex : WorldMapBoardOVERLAYCtxHoveredHex!
    hoveredHero : WorldMapBoardOVERLAYCtxHoveredHero!
    selectedHero : WorldMapBoardOVERLAYCtxSelectedHero!
    validMoves : [WorldMapBoardOVERLAYCtxValidMovesItem]!
    scale : number!
  }
  type WorldMapBoardOVERLAYCtxHoveredTile = {
    x : number!
    y : number!
  }
  type WorldMapBoardOVERLAYCtxHoveredHex = {
    x : number!
    y : number!
    terrain : string!
    terrainSprite : string
    feature : string
    featureData : json
    passable : boolean
  }
  type WorldMapBoardOVERLAYCtxHoveredHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardOVERLAYCtxHoveredHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardOVERLAYCtxHoveredHeroSpriteSheet
    level : number
  }
  type WorldMapBoardOVERLAYCtxHoveredHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardOVERLAYCtxHoveredHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardOVERLAYCtxSelectedHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardOVERLAYCtxSelectedHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardOVERLAYCtxSelectedHeroSpriteSheet
    level : number
  }
  type WorldMapBoardOVERLAYCtxSelectedHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardOVERLAYCtxSelectedHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardOVERLAYCtxValidMovesItem = {
    x : number!
    y : number!
  }
  type WorldMapBoardFOOTERCtx = {
    hoveredTile : WorldMapBoardFOOTERCtxHoveredTile!
    hoveredHex : WorldMapBoardFOOTERCtxHoveredHex!
    hoveredHero : WorldMapBoardFOOTERCtxHoveredHero!
    selectedHero : WorldMapBoardFOOTERCtxSelectedHero!
    validMoves : [WorldMapBoardFOOTERCtxValidMovesItem]!
    scale : number!
  }
  type WorldMapBoardFOOTERCtxHoveredTile = {
    x : number!
    y : number!
  }
  type WorldMapBoardFOOTERCtxHoveredHex = {
    x : number!
    y : number!
    terrain : string!
    terrainSprite : string
    feature : string
    featureData : json
    passable : boolean
  }
  type WorldMapBoardFOOTERCtxHoveredHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardFOOTERCtxHoveredHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardFOOTERCtxHoveredHeroSpriteSheet
    level : number
  }
  type WorldMapBoardFOOTERCtxHoveredHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardFOOTERCtxHoveredHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardFOOTERCtxSelectedHero = {
    id : string!
    name : string!
    owner : string!
    position : WorldMapBoardFOOTERCtxSelectedHeroPosition!
    movement : number!
    sprite : string
    spriteSheet : WorldMapBoardFOOTERCtxSelectedHeroSpriteSheet
    level : number
  }
  type WorldMapBoardFOOTERCtxSelectedHeroPosition = {
    x : number!
    y : number!
  }
  type WorldMapBoardFOOTERCtxSelectedHeroSpriteSheet = {
    se : string!
    sw : string!
    frameWidth : number!
    frameHeight : number!
  }
  type WorldMapBoardFOOTERCtxValidMovesItem = {
    x : number!
    y : number!
  }

  entity WorldMapBoardItem [runtime] {
    id : string!
  }

  trait WorldMapBoardRender -> @rebindable WorldMapBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          entity: @config.entityProp
          scale: @config.scale
          unitScale: @config.unitScale
          allowMoveAllHeroes: @config.allowMoveAllHeroes
          isInRange: IS_IN_RANGE
          heroSelectEvent: HERO_SELECT
          heroMoveEvent: HERO_MOVE
          battleEncounterEvent: BATTLE_ENCOUNTER
          featureEnterEvent: FEATURE_ENTER
          tileClickEvent: TILE_CLICK
          header: HEADER
          sidePanel: SIDE_PANEL
          overlay: OVERLAY
          footer: FOOTER
          onHeroSelect: HERO_SELECT
          onHeroMove: HERO_MOVE
          onBattleEncounter: BATTLE_ENCOUNTER
          onFeatureEnter: FEATURE_ENTER
          diamondTopY: @config.diamondTopY
          enableCamera: @config.enableCamera
          effectSpriteUrls: @config.effectSpriteUrls
          resolveUnitFrame: RESOLVE_UNIT_FRAME
          type: world-map-board
        })
    }

    emits {
      IS_IN_RANGE -> external {
        from : WorldMapBoardISINRANGEFrom
        to : WorldMapBoardISINRANGETo
        range : number
      }
        @description "Custom movement range validator"
        @tier "essential"
      HERO_SELECT -> external {
        heroId : string!
      }
        @description "-- Declarative event props --"
        @tier "essential"
      HERO_MOVE -> external {
        heroId : string!
        toX : number!
        toY : number!
      }
        @description "Emits UI:{heroMoveEvent} with { heroId, toX, toY }"
        @tier "essential"
      BATTLE_ENCOUNTER -> external {
        attackerId : string!
        defenderId : string!
      }
        @description "Emits UI:{battleEncounterEvent} with { attackerId, defenderId }"
        @tier "essential"
      FEATURE_ENTER -> external {
        heroId : string!
        feature : string!
        hex : object!
      }
        @description "Emits UI:{featureEnterEvent} with { heroId, feature, hex }"
        @tier "essential"
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y }"
        @tier "essential"
      HEADER -> external {
        ctx : WorldMapBoardHEADERCtx
      }
        @description "-- Slots --"
        @tier "essential"
      SIDE_PANEL -> external {
        ctx : WorldMapBoardSIDEPANELCtx
      }
        @description "Side panel (hero detail, hero lists, etc.)"
        @tier "essential"
      OVERLAY -> external {
        ctx : WorldMapBoardOVERLAYCtx
      }
        @description "Canvas overlay (tooltips, popups)"
        @tier "essential"
      FOOTER -> external {
        ctx : WorldMapBoardFOOTERCtx
      }
        @description "Footer"
        @tier "essential"
      RESOLVE_UNIT_FRAME -> external {
        unitId : string
      }
        @description "resolveUnitFrame prop"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : WorldMapBoardError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      entityProp : WorldMapBoardEntity
        @label "Entity"
        @description "World map entity data"
        @synonyms "entity"
        @tier "presentation"
      scale : number = 0.4
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      unitScale : number = 2.5
        @label "Unit Scale"
        @description "Unit draw-size multiplier"
        @tier "presentation"
      allowMoveAllHeroes : boolean = false
        @label "Allow Move All Heroes"
        @description "Allow selecting / moving ALL heroes (including enemy). For testing."
        @tier "presentation"
      diamondTopY : number = 0
        @label "Diamond Top Y"
        @description "-- Canvas pass-through --"
        @tier "presentation"
      enableCamera : boolean = false
        @label "Enable Camera"
        @description "Disable pan/zoom camera (default: true). Set false for fixed maps where overlay labels need stable positions."
        @tier "presentation"
      effectSpriteUrls : [string] = []
        @label "Effect Sprite Urls"
        @description "effectSpriteUrls prop"
        @tier "presentation"
    }
  }

  page "/world-map-board" as WorldMapBoardPage -> WorldMapBoardRender
}
