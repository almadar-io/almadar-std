app ui-simulation-canvas "1.0.0"
"SimulationCanvas — UI factory (1:1 with the @almadar/ui simulation-canvas pattern)."
orbital SimulationCanvasOrbital {
  type SimulationCanvasPreset = {
    id : string!
    name : string!
    description : string!
    domain : string!
    gravity : SimulationCanvasPresetGravity
    bodies : [SimulationCanvasPresetBodiesItem]!
    constraints : [SimulationCanvasPresetConstraintsItem]
    backgroundColor : string
    showVelocity : boolean
    parameters : Map string SimulationCanvasPresetParametersValue!
  }
  type SimulationCanvasPresetGravity = {
    x : number!
    y : number!
  }
  type SimulationCanvasPresetBodiesItem = {
    id : string!
    x : number!
    y : number!
    vx : number!
    vy : number!
    mass : number!
    radius : number!
    color : string!
    fixed : boolean!
  }
  type SimulationCanvasPresetConstraintsItem = {
    bodyA : number!
    bodyB : number!
    length : number!
    stiffness : number!
  }
  type SimulationCanvasPresetParametersValue = {
    value : number!
    min : number!
    max : number!
    step : number!
    label : string!
  }

  entity SimulationCanvasItem [runtime] {
    id : string!
  }

  trait SimulationCanvasRender -> @rebindable SimulationCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          preset: @config.preset
          width: @config.width
          height: @config.height
          running: @config.running
          speed: @config.speed
          className: @config.className
          type: simulation-canvas
        })
    }

    config {
      preset : SimulationCanvasPreset = { id: "Id", name: "Name", description: "Description", domain: "Domain", gravity: { x: 1, y: 1 }, bodies: [{ id: "Id", x: 1, y: 1, vx: 1, vy: 1, mass: 1, radius: 1, color: "Color", fixed: false }], constraints: [{ bodyA: 1, bodyB: 1, length: 1, stiffness: 1 }], backgroundColor: "Background Color", showVelocity: false, parameters: {} }
        @label "Preset"
        @description "preset prop"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "height prop"
        @tier "presentation"
      running : boolean = false
        @label "Running"
        @description "running prop"
        @tier "presentation"
      speed : number = 1
        @label "Speed"
        @description "speed prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/simulation-canvas" as SimulationCanvasPage -> SimulationCanvasRender
}
