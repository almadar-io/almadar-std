app ui-simulation-canvas "1.0.0"
"SimulationCanvas — UI factory (1:1 with the @almadar/ui simulation-canvas pattern)."
orbital SimulationCanvasOrbital {
  type SimulationCanvasPreset = {
    id : string!
    name : string!
    description : string!
    domain : string!
    gravity : SimulationCanvasPresetGravity
    bodies : [SimulationCanvasPresetBodiesItem]!
    constraints : [SimulationCanvasPresetConstraintsItem]
    backgroundColor : string
    showVelocity : boolean
    parameters : Map string SimulationCanvasPresetParametersValue!
  }
  type SimulationCanvasPresetGravity = {
    x : number!
    y : number!
  }
  type SimulationCanvasPresetBodiesItem = {
    id : string!
    x : number!
    y : number!
    vx : number!
    vy : number!
    mass : number!
    radius : number!
    color : string!
    fixed : boolean!
  }
  type SimulationCanvasPresetConstraintsItem = {
    bodyA : number!
    bodyB : number!
    length : number!
    stiffness : number!
  }
  type SimulationCanvasPresetParametersValue = {
    value : number!
    min : number!
    max : number!
    step : number!
    label : string!
  }

  entity SimulationCanvasItem [runtime] {
    id : string!
  }

  trait SimulationCanvasRender -> @rebindable SimulationCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          preset: @config.preset
          width: @config.width
          height: @config.height
          running: @config.running
          speed: @config.speed
          className: @config.className
          type: simulation-canvas
        })
    }

    config {
      preset : SimulationCanvasPreset = { id: "demo", name: "Demo Scene", description: "Bouncing bodies with a spring", domain: "mechanics", gravity: { x: 0, y: 9.81 }, bodies: [{ id: "b0", x: 100, y: 80,  vx: 120, vy: 0,   mass: 1, radius: 14, color: "#e94560", fixed: false }, { id: "b1", x: 300, y: 150, vx: -80, vy: 60,  mass: 2, radius: 20, color: "#0f3460", fixed: false }, { id: "b2", x: 480, y: 90,  vx: 50,  vy: 90,  mass: 1, radius: 12, color: "#533483", fixed: false }, { id: "b3", x: 200, y: 300, vx: -40, vy: -70, mass: 3, radius: 22, color: "#16213e", fixed: false }, { id: "b4", x: 400, y: 280, vx: 70,  vy: -50, mass: 1, radius: 16, color: "#e94560", fixed: false }], constraints: [{ bodyA: 1, bodyB: 3, length: 160, stiffness: 0.4 }], backgroundColor: "#1a1a2e", showVelocity: true, parameters: {} }
        @label "Preset"
        @description "preset prop"
        @tier "presentation"
      width : number = 600
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "height prop"
        @tier "presentation"
      running : boolean = true
        @label "Running"
        @description "running prop"
        @tier "presentation"
      speed : number = 1
        @label "Speed"
        @description "speed prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/simulation-canvas" as SimulationCanvasPage -> SimulationCanvasRender
}
