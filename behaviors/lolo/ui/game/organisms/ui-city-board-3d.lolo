  trait FxDecay = Frame.traits.FxDecay -> GameState {
    config { running: true }
  }

  trait RoundGate = Frame.traits.RoundGate -> GameState {
    config { running: true }
  }

  trait Player = Frame.traits.HeroIntent -> GameState {
    config {
      gridWidth: 16
      gridHeight: 16
      movementRange: 1
      scoreLabel: "Deliveries"
      objectiveLabel: "Shops Left"
      cameraMode: "top-down"
      scale: 0.4
      unitScale: 1
      bgColor: "#12161d"
      assetManifest: { terrains: { road: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-roads/terrain/road-straight.glb", role: "tile", category: "road-straight", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "road-straight", thumbnailUrl: "" }, intersection: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-roads/terrain/road-crossroad.glb", role: "tile", category: "road-crossroad", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "road-crossroad", thumbnailUrl: "" }, building: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-commercial/features/building-a.glb", role: "decoration", category: "building-a", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "building-a", thumbnailUrl: "" } }, units: {}, features: {}, effects: {} }
    }
  }

  page "/city-board-3d" as CityBoard3DPage -> HeroAuthority, Collector, FxDecay, RoundGate, Player
