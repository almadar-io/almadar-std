app ui-city-board-3d "1.0.0"
"CityBoard3D — a courier car drives city roads to deliver to every shop within a move budget or the run is lost; composes the std single-hero objective frame."
orbital CityBoard3DOrbital {
  uses Frame from "std/behaviors/std-objective-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    assetUrl : Asset
    color : string
    elevation : number
    done : boolean
  }
  type HudStat = { label : string  value : number }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    movesLeft : number = 0
    features : [Feature] = []
    score : number = 0
    objectivesLeft : number = 0
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    phase : string = "observation"
  }

  trait HeroAuthority = Frame.traits.HeroAuthority -> GameState {
    config {
      running: true
      gridWidth: 16
      gridHeight: 16
      moveBudget: 60
      units: [ { id: "car1", position: { x: 2, y: 2 }, x: 2, y: 2, z: 0, team: "player", health: 1, maxHealth: 1, unitType: "courier", name: "Courier Car", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-car-kit/units/delivery.glb", role: "player", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "delivery", thumbnailUrl: "" } }, { id: "npc-taxi", position: { x: 6, y: 2 }, x: 6, y: 2, z: 0, team: "neutral", health: 1, maxHealth: 1, unitType: "traffic", name: "Taxi", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-car-kit/units/taxi.glb", role: "npc", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "taxi", thumbnailUrl: "" } }, { id: "npc-tram", position: { x: 2, y: 6 }, x: 2, y: 6, z: 0, team: "neutral", health: 1, maxHealth: 1, unitType: "traffic", name: "Tram", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-train-kit/units/train-tram-classic.glb", role: "npc", category: "units", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "train-tram-classic", thumbnailUrl: "" } } ]
      tiles: [ { id: "t-0-0", x: 0, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-1-0", x: 1, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-2-0", x: 2, y: 0, z: 0, terrain: "road", passable: true }, { id: "t-3-0", x: 3, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-4-0", x: 4, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-5-0", x: 5, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-6-0", x: 6, y: 0, z: 0, terrain: "road", passable: true }, { id: "t-7-0", x: 7, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-8-0", x: 8, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-9-0", x: 9, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-10-0", x: 10, y: 0, z: 0, terrain: "road", passable: true }, { id: "t-11-0", x: 11, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-12-0", x: 12, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-13-0", x: 13, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-14-0", x: 14, y: 0, z: 0, terrain: "road", passable: true }, { id: "t-15-0", x: 15, y: 0, z: 0, terrain: "building", passable: false }, { id: "t-0-1", x: 0, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-1-1", x: 1, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-2-1", x: 2, y: 1, z: 0, terrain: "road", passable: true }, { id: "t-3-1", x: 3, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-4-1", x: 4, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-5-1", x: 5, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-6-1", x: 6, y: 1, z: 0, terrain: "road", passable: true }, { id: "t-7-1", x: 7, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-8-1", x: 8, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-9-1", x: 9, y: 1, z: 0, terrain: "building", passable: false }, { id: "t-10-1", x: 10, y: 1, z: 0, terrain: "road", passable: true }, { id: "t-11-1", x: 11, y: 1, z: 0, 