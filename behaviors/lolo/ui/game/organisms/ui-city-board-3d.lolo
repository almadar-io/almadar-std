    config {
      running: true
      targetType: "delivery_target"
      pointsPerTarget: 1
      removeOnReach: false
      reachRadius: 1
      features: [ { id: "f-shop1", x: 1, y: 1, type: "delivery_target", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-commercial/features/detail-awning.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-awning", thumbnailUrl: "" } }, { id: "f-shop2", x: 5, y: 5, type: "delivery_target", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-commercial/features/detail-awning-wide.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-awning-wide", thumbnailUrl: "" } }, { id: "f-shop3", x: 9, y: 3, type: "delivery_target", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-commercial/features/detail-parasol-a.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-parasol-a", thumbnailUrl: "" } }, { id: "f-shop4", x: 13, y: 9, type: "delivery_target", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-commercial/features/detail-awning.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-awning", thumbnailUrl: "" } }, { id: "f-shop5", x: 3, y: 13, type: "delivery_target", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-commercial/features/detail-awning-wide.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "detail-awning-wide", thumbnailUrl: "" } }, { id: "f-sign", x: 10, y: 10, type: "signage", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-roads/features/sign-highway.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "sign-highway", thumbnailUrl: "" } }, { id: "f-chimney", x: 8, y: 8, type: "industrial_detail", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-city-board-3d/kenney-city-kit-industrial/features/chimney-small.glb", role: "decoration", category: "features", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "chimney-small", thumbnailUrl: "" } } ]
    }
