app ui-arcade-board-3d "1.0.0"
"ArcadeBoard3D — 3D arcade-hall board: a kid roams a 5x6 hall and plays machines for tickets; composes the arcade play-for-tickets frame."
;; @capabilities "3D hall exploration, mini-game arcade machines, ticket collection, play-for-tickets loop"
orbital ArcadeBoard3DOrbital {
  uses Frame from "std/behaviors/std-arcade-board-3d"

  type Asset = {
    url : asset
    role : string
    category : string
    animations : [string]
    style : string
    variant : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    modelUrl : Asset
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }
  type ValidMove = { x : number!  z : number! }
  type Machine = {
    id : string!
    x : number!
    y : number!
    type : string!
  }
  type Feature = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    assetUrl : Asset
    color : string
    elevation : number
  }
  type AssetManifest = {
    terrains : Map string Asset
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
  }

  entity GameState [runtime, shared] {
    id : string!
    units : [Unit] = []
    tiles : [Tile] = []
    movesLeft : number = 0
    features : [Feature] = []
    machines : [Machine] = []
    tokens : number = 0
    tickets : number = 0
    lastRoll : number = 0
    playCount : number = 0
    fx : [Fx] = []
    result : string = "none"
    selectedUnitId : string = ""
    validMoves : [ValidMove] = []
    phase : string = "observation"
  }

  trait HeroAuthority = Frame.traits.HeroAuthority -> GameState {
    config {
      running: true
      gridWidth: 5
      gridHeight: 6
      moveBudget: 9999
      units: [ { id: "player1", position: { x: 2, y: 1 }, x: 2, y: 1, z: 0, team: "player", health: 1, maxHealth: 1, unitType: "player-kid", name: "Kid Gamer", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/units/character-gamer.glb", role: "player", category: "character-gamer", animations: ["idle", "walk"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "character-gamer", thumbnailUrl: "" } }, { id: "npc1", position: { x: 2, y: 3 }, x: 2, y: 3, z: 0, team: "neutral", health: 1, maxHealth: 1, unitType: "wander-kid", name: "Wandering Kid", modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/units/character-employee.glb", role: "npc", category: "character-employee", animations: ["idle", "walk"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "character-employee", thumbnailUrl: "" } } ]
      tiles: [ { id: "t00", x: 0, y: 0, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall-corner.glb", role: "tile", category: "wall-corner", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall-corner", thumbnailUrl: "" } }, { id: "t10", x: 1, y: 0, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t20", x: 2, y: 0, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall-window.glb", role: "tile", category: "wall-window", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall-window", thumbnailUrl: "" } }, { id: "t30", x: 3, y: 0, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t40", x: 4, y: 0, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall-corner.glb", role: "tile", category: "wall-corner", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall-corner", thumbnailUrl: "" } }, { id: "t01", x: 0, y: 1, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t11", x: 1, y: 1, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t21", x: 2, y: 1, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t31", x: 3, y: 1, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t41", x: 4, y: 1, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t02", x: 0, y: 2, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t12", x: 1, y: 2, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t22", x: 2, y: 2, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t32", x: 3, y: 2, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t42", x: 4, y: 2, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t03", x: 0, y: 3, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t13", x: 1, y: 3, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t23", x: 2, y: 3, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t33", x: 3, y: 3, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t43", x: 4, y: 3, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t04", x: 0, y: 4, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t14", x: 1, y: 4, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t24", x: 2, y: 4, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t34", x: 3, y: 4, z: 0, terrain: "floor", passable: true, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/floor.glb", role: "tile", category: "floor", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "floor", thumbnailUrl: "" } }, { id: "t44", x: 4, y: 4, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t05", x: 0, y: 5, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall-corner.glb", role: "tile", category: "wall-corner", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall-corner", thumbnailUrl: "" } }, { id: "t15", x: 1, y: 5, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t25", x: 2, y: 5, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall-door-rotate.glb", role: "tile", category: "wall-door-rotate", animations: ["open", "close", "open-and-close"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall-door-rotate", thumbnailUrl: "" } }, { id: "t35", x: 3, y: 5, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall.glb", role: "tile", category: "wall", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall", thumbnailUrl: "" } }, { id: "t45", x: 4, y: 5, z: 0, terrain: "wall", passable: false, modelUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/terrain/wall-corner.glb", role: "tile", category: "wall-corner", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "wall-corner", thumbnailUrl: "" } } ]
    }
  }

  trait PlayEconomy = Frame.traits.PlayEconomy -> GameState {
    config {
      running: true
      startTokens: 14
      minPayout: 0
      maxPayout: 1
      machines: [ { id: "f1", x: 1, y: 1, type: "arcade_machine" }, { id: "f2", x: 3, y: 1, type: "claw_machine" }, { id: "f3", x: 1, y: 2, type: "air_hockey" }, { id: "f4", x: 2, y: 2, type: "prize_wheel" }, { id: "f5", x: 3, y: 2, type: "basketball_game" }, { id: "f6", x: 1, y: 3, type: "pinball" }, { id: "f7", x: 3, y: 3, type: "dance_machine" }, { id: "f8", x: 1, y: 4, type: "gambling_machine" }, { id: "f10", x: 3, y: 4, type: "vending_machine" } ]
    }
  }

  trait FxDecay = Frame.traits.FxDecay -> GameState {
    config { running: true }
  }

  trait RoundGate = Frame.traits.RoundGate -> GameState {
    config { running: true, ticketsToWin: 5 }
  }

  trait Player = Frame.traits.ArcadeIntent -> GameState {
    config {
      gridWidth: 5
      gridHeight: 6
      movementRange: 1
      tokensLabel: "Tokens"
      ticketsLabel: "Tickets"
      goalText: "Win 5 tickets from the arcade machines"
      howText: "Click your kid, then click an adjacent tile to walk; click a machine to play a token"
      cameraMode: "isometric"
      scale: 0.45
      unitScale: 1
      bgColor: "#12161d"
      features: [ { id: "f1", x: 1, y: 1, type: "arcade_machine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/arcade-machine.glb", role: "decoration", category: "arcade-machine", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "arcade-machine", thumbnailUrl: "" } }, { id: "f2", x: 3, y: 1, type: "claw_machine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/claw-machine.glb", role: "decoration", category: "claw-machine", animations: ["animation"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "claw-machine", thumbnailUrl: "" } }, { id: "f3", x: 1, y: 2, type: "air_hockey", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/air-hockey.glb", role: "decoration", category: "air-hockey", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "air-hockey", thumbnailUrl: "" } }, { id: "f4", x: 2, y: 2, type: "prize_wheel", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/prize-wheel.glb", role: "decoration", category: "prize-wheel", animations: ["animation"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "prize-wheel", thumbnailUrl: "" } }, { id: "f5", x: 3, y: 2, type: "basketball_game", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/basketball-game.glb", role: "decoration", category: "basketball-game", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "basketball-game", thumbnailUrl: "" } }, { id: "f6", x: 1, y: 3, type: "pinball", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/pinball.glb", role: "decoration", category: "pinball", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "pinball", thumbnailUrl: "" } }, { id: "f7", x: 3, y: 3, type: "dance_machine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/dance-machine.glb", role: "decoration", category: "dance-machine", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "dance-machine", thumbnailUrl: "" } }, { id: "f8", x: 1, y: 4, type: "gambling_machine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/gambling-machine.glb", role: "decoration", category: "gambling-machine", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "gambling-machine", thumbnailUrl: "" } }, { id: "f9", x: 2, y: 4, type: "prize_counter", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/prizes.glb", role: "decoration", category: "prizes", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "prizes", thumbnailUrl: "" } }, { id: "f10", x: 3, y: 4, type: "vending_machine", assetUrl: { url: "https://almadar-kflow-assets.web.app/shared/ui-arcade-board-3d/kenney-mini-arcade/features/vending-machine.glb", role: "decoration", category: "vending-machine", animations: ["static"], style: "lowpoly-flat", variant: "", dimension: "3d", aspect: "1:1", name: "vending-machine", thumbnailUrl: "" } } ]
      assetManifest: { terrains: {}, units: {}, features: {}, effects: {} }
    }
  }

  page "/arcade-board-3d" as ArcadeBoard3DPage -> HeroAuthority, PlayEconomy, FxDecay, RoundGate, Player
}
