app ui-visual-novel-board "1.0.0"
"VisualNovelBoard — game-shell composition: dialogue-box carries scene background + portrait + branching choices."
orbital VisualNovelBoardOrbital {
  type VisualNovelBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type VisualNovelBoardChoicesItem = {
    label : string!
    nextId : string!
  }
  type VisualNovelBoardNodesItem = {
    id : string!
    speaker : string!
    text : string!
    backgroundKey : string
    portraitKey : string
    choices : [VisualNovelBoardChoicesItem]
  }

  entity VisualNovelBoardItem [runtime] {
    id : string!
    nodes : [VisualNovelBoardNodesItem]
    currentNodeId : string = "start"
    currentNode : VisualNovelBoardNodesItem
  }

  trait VisualNovelBoardRender -> @rebindable VisualNovelBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.nodes @config.nodes)
        (set @entity.currentNodeId @config.startNodeId)
        (set @entity.currentNode (array/first (array/filter @entity.nodes (fn n (== (object/get @n id) @entity.currentNodeId)))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Chapter", value: @entity.currentNodeId } ] }
          children: [
            {
              type: dialogue-box
              backgroundImage: @config.backgroundImage
              portraitUrl: @config.portraitUrl
              portraitScale: @config.portraitScale
              typewriterSpeed: @config.typewriterSpeed
              position: "bottom"
              advanceEvent: ADVANCE
              choiceEvent: CHOOSE
              dialogue: { id: @entity.currentNodeId, speaker: (object/get @entity.currentNode speaker), text: (object/get @entity.currentNode text), portrait: (object/get @entity.currentNode portraitKey), choices: (array/map (object/get @entity.currentNode choices) (fn c { text: (object/get @c label), next: (object/get @c nextId), action: (object/get @c nextId), disabled: false })) }
            }
          ]
        })

      CHOOSE -> playing when (and (!= ?choice null) (!= (object/get ?choice next) ""))
        (set @entity.currentNodeId (object/get ?choice next))
        (set @entity.currentNode (array/first (array/filter @entity.nodes (fn n (== (object/get @n id) @entity.currentNodeId)))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Chapter", value: @entity.currentNodeId } ] }
          children: [
            {
              type: dialogue-box
              backgroundImage: @config.backgroundImage
              portraitUrl: @config.portraitUrl
              portraitScale: @config.portraitScale
              typewriterSpeed: @config.typewriterSpeed
              position: "bottom"
              advanceEvent: ADVANCE
              choiceEvent: CHOOSE
              dialogue: { id: @entity.currentNodeId, speaker: (object/get @entity.currentNode speaker), text: (object/get @entity.currentNode text), portrait: (object/get @entity.currentNode portraitKey), choices: (array/map (object/get @entity.currentNode choices) (fn c { text: (object/get @c label), next: (object/get @c nextId), action: (object/get @c nextId), disabled: false })) }
            }
          ]
        })

      ADVANCE -> playing when (> (array/len (object/get (array/first (array/filter @entity.nodes (fn n (== (object/get @n id) @entity.currentNodeId)))) choices)) 0)
        (set @entity.currentNodeId (object/get (array/nth (object/get (array/first (array/filter @entity.nodes (fn n (== (object/get @n id) @entity.currentNodeId)))) choices) 0) nextId))
        (set @entity.currentNode (array/first (array/filter @entity.nodes (fn n (== (object/get @n id) @entity.currentNodeId)))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Chapter", value: @entity.currentNodeId } ] }
          children: [
            {
              type: dialogue-box
              backgroundImage: @config.backgroundImage
              portraitUrl: @config.portraitUrl
              portraitScale: @config.portraitScale
              typewriterSpeed: @config.typewriterSpeed
              position: "bottom"
              advanceEvent: ADVANCE
              choiceEvent: CHOOSE
              dialogue: { id: @entity.currentNodeId, speaker: (object/get @entity.currentNode speaker), text: (object/get @entity.currentNode text), portrait: (object/get @entity.currentNode portraitKey), choices: (array/map (object/get @entity.currentNode choices) (fn c { text: (object/get @c label), next: (object/get @c nextId), action: (object/get @c nextId), disabled: false })) }
            }
          ]
        })

      RESTART -> playing
        (set @entity.currentNodeId @config.startNodeId)
        (set @entity.currentNode (array/first (array/filter @entity.nodes (fn n (== (object/get @n id) @entity.currentNodeId)))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Chapter", value: @entity.currentNodeId } ] }
          children: [
            {
              type: dialogue-box
              backgroundImage: @config.backgroundImage
              portraitUrl: @config.portraitUrl
              portraitScale: @config.portraitScale
              typewriterSpeed: @config.typewriterSpeed
              position: "bottom"
              advanceEvent: ADVANCE
              choiceEvent: CHOOSE
              dialogue: { id: @entity.currentNodeId, speaker: (object/get @entity.currentNode speaker), text: (object/get @entity.currentNode text), portrait: (object/get @entity.currentNode portraitKey), choices: (array/map (object/get @entity.currentNode choices) (fn c { text: (object/get @c label), next: (object/get @c nextId), action: (object/get @c nextId), disabled: false })) }
            }
          ]
        })
    }

    emits {
      CHOOSE -> external {
        choice : object
      }
        @description "Emits UI:{choiceEvent} with {choice} when the player selects a branching choice"
        @tier "essential"
      ADVANCE -> external {
        id : string
      }
        @description "Emits UI:{advanceEvent} with {} to advance to the first choice's target node"
        @tier "essential"
      RESTART -> external {
        id : string
      }
        @description "Emits UI:{restartEvent} with {} to reset the scene to the start node"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : VisualNovelBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      startNodeId : string = "start"
        @label "Start Node Id"
        @description "Id of the dialogue node shown first / on restart"
        @tier "presentation"
      typewriterSpeed : number = 30
        @label "Typewriter Speed"
        @description "Milliseconds per character of dialogue text reveal (0 = instant)"
        @tier "presentation"
      portraitScale : number = 1
        @label "Portrait Scale"
        @description "Character portrait draw-size multiplier"
        @tier "presentation"
      backgroundImage : asset = "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/corridor.png"
        @label "Background Image"
        @description "Full-frame scene background rendered behind the dialogue box."
        @tier "presentation"
      portraitUrl : asset = "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/portraits/guide.png"
        @label "Portrait Url"
        @description "Large character portrait rendered standing over the scene."
        @tier "presentation"
      nodes : [VisualNovelBoardNodesItem] = [{ id: "start", speaker: "Narrator", text: "The corridor stretches into shadow. A lone sentinel blocks your path.", backgroundKey: "corridor", portraitKey: "guide", choices: [{ label: "Approach the sentinel.", nextId: "meet" }, { label: "Turn back.", nextId: "retreat" }] }, { id: "meet", speaker: "Sentinel", text: "You carry the old marks. Speak your purpose, traveler.", backgroundKey: "forge", portraitKey: "rival", choices: [{ label: "I seek the core.", nextId: "end" }, { label: "I am only passing through.", nextId: "retreat" }] }, { id: "retreat", speaker: "Narrator", text: "You withdraw into the dark. The path will wait for braver feet.", backgroundKey: "corridor", portraitKey: "guide", choices: [{ label: "Begin again.", nextId: "start" }] }, { id: "end", speaker: "Sentinel", text: "Then the way is open. Walk it well.", backgroundKey: "core", portraitKey: "rival", choices: [{ label: "Begin again.", nextId: "start" }] }]
        @label "Nodes"
        @description "Dialogue graph: each node has speaker text, scene/portrait keys, and branching choices."
        @tier "presentation"
    }
  }

  page "/visual-novel-board" as VisualNovelBoardPage -> VisualNovelBoardRender
}
