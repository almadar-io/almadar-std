app ui-brick-sandbox-board-3d "1.0.0"
"BrickSandboxBoard3D — 12x12 LEGO-style build-to-blueprint sandbox; click target cells to place bricks before 3 mistakes."
orbital BrickSandboxBoard3DOrbital {
  type BrickSandboxBoard3DError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type BrickSandboxBoard3DTilesItem = {
    id : string
    x : number!
    y : number!
    terrain : string
    passable : boolean
    modelUrl : Asset
  }
  type BrickSandboxBoard3DBlueprintItem = {
    id : string!
    x : number!
    y : number!
    filled : boolean
    brickModel : Asset
  }
  type BrickSandboxBoard3DFeaturesItem = {
    id : string
    x : number!
    y : number!
    type : string
    assetUrl : Asset
  }
  type BrickSandboxBoard3DFxItem = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity BrickSandboxBoard3DItem [runtime] {
    id : string!
    blueprint : [BrickSandboxBoard3DBlueprintItem]
    features : [BrickSandboxBoard3DFeaturesItem]
    fx : [BrickSandboxBoard3DFxItem] = []
    placed : number = 0
    mistakes : number = 0
    result : "none" | "won" | "lost" = none
    gridWidth : number = 12
    gridHeight : number = 12
    tiles : [BrickSandboxBoard3DTilesItem] = []
  }

  trait BrickSandboxBoard3DRender -> @rebindable BrickSandboxBoard3DItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.gridWidth 12)
        (set @entity.gridHeight 12)
        (set @entity.tiles (array/flatten (array/map (array/range 0 12) (fn gy (array/map (array/range 0 12) (fn gx { id: (str/concat "t-" @gx "-" @gy), x: @gx, y: @gy, terrain: "baseplate", passable: true, modelUrl: @config.baseplateModel }))))))
        (set @entity.blueprint (array/map @config.blueprint (fn b (object/merge @b { filled: false }))))
        (set @entity.placed 0)
        (set @entity.mistakes 0)
        (set @entity.result "none")
        (set @entity.fx [])
        (set @entity.features (array/map @entity.blueprint (fn b (if (== @b.filled true) { id: @b.id, x: @b.x, y: @b.y, type: "brick", assetUrl: @b.brickModel } { id: @b.id, x: @b.x, y: @b.y, type: "marker", assetUrl: @config.markerModel }))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Placed", value: @entity.placed }, { label: "Mistakes", value: @entity.mistakes }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Fill every marked cell with a brick" }, { label: "How", value: "Click a marked cell to drop a brick — 3 mistakes and you're out" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: (if (== @entity.result "won") "BUILD COMPLETE" "OUT OF TRIES"), subtitle: (str/concat "Placed " @entity.placed), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null)
          children: [ { type: canvas, mode: "3d", camera: { mode: "top-down", zoom: @config.scale }, backgroundColor: @config.bgColor, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn fx { type: draw-text, text: (object/get @fx message), position: { x: (object/get @fx x), y: (object/get @fx y), z: (object/get @fx z) }, color: "#ffe066" })) }
          ] } ]
        })

      TILE_CLICK -> playing when (== @entity.result "none")
        (let ((hit (array/find @entity.blueprint (fn b (and (== @b.x ?x) (and (== @b.y ?z) (== @b.filled false)))))))
          (do
            (set @entity.blueprint (if (!= @hit null) (array/map @entity.blueprint (fn b (if (and (== @b.x ?x) (== @b.y ?z)) (object/merge @b { filled: true }) @b))) @entity.blueprint))
            (set @entity.placed (if (!= @hit null) (+ @entity.placed 1) @entity.placed))
            (set @entity.mistakes (if (== @hit null) (+ @entity.mistakes 1) @entity.mistakes))
            (set @entity.result (if (>= @entity.placed (array/len @entity.blueprint)) "won" (if (>= @entity.mistakes 3) "lost" "none")))
            (set @entity.features (array/map @entity.blueprint (fn b (if (== @b.filled true) { id: @b.id, x: @b.x, y: @b.y, type: "brick", assetUrl: @b.brickModel } { id: @b.id, x: @b.x, y: @b.y, type: "marker", assetUrl: @config.markerModel }))))
            (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Placed", value: @entity.placed }, { label: "Mistakes", value: @entity.mistakes }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Fill every marked cell with a brick" }, { label: "How", value: "Click a marked cell to drop a brick — 3 mistakes and you're out" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: (if (== @entity.result "won") "BUILD COMPLETE" "OUT OF TRIES"), subtitle: (str/concat "Placed " @entity.placed), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null)
          children: [ { type: canvas, mode: "3d", camera: { mode: "top-down", zoom: @config.scale }, backgroundColor: @config.bgColor, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn fx { type: draw-text, text: (object/get @fx message), position: { x: (object/get @fx x), y: (object/get @fx y), z: (object/get @fx z) }, color: "#ffe066" })) }
          ] } ]
        })
          )
        )

      PLAY_AGAIN -> playing
        (set @entity.blueprint (array/map @config.blueprint (fn b (object/merge @b { filled: false }))))
        (set @entity.placed 0)
        (set @entity.mistakes 0)
        (set @entity.result "none")
        (set @entity.fx [])
        (set @entity.features (array/map @entity.blueprint (fn b (if (== @b.filled true) { id: @b.id, x: @b.x, y: @b.y, type: "brick", assetUrl: @b.brickModel } { id: @b.id, x: @b.x, y: @b.y, type: "marker", assetUrl: @config.markerModel }))))
        (render-ui main {
          type: game-shell
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Placed", value: @entity.placed }, { label: "Mistakes", value: @entity.mistakes }, { label: "Result", value: @entity.result }, { label: "Goal", value: "Fill every marked cell with a brick" }, { label: "How", value: "Click a marked cell to drop a brick — 3 mistakes and you're out" } ] }, { type: button, action: PLAY_AGAIN, label: "Restart", variant: secondary } ] }
          overlay: (if (!= @entity.result "none") { type: game-menu, title: (if (== @entity.result "won") "BUILD COMPLETE" "OUT OF TRIES"), subtitle: (str/concat "Placed " @entity.placed), options: [ { id: "again", label: "Play Again", event: "PLAY_AGAIN", variant: "primary" } ] } null)
          children: [ { type: canvas, mode: "3d", camera: { mode: "top-down", zoom: @config.scale }, backgroundColor: @config.bgColor, tileClickEvent: TILE_CLICK, children: [
            { type: draw-sprite-layer, items: (array/map @entity.tiles (fn t { type: draw-sprite, position: { x: (object/get @t x), y: (object/get @t y) }, asset: (object/get @t modelUrl) })) }
            { type: draw-sprite-layer, items: (array/map @entity.features (fn f { type: draw-sprite, position: { x: (object/get @f x), y: (object/get @f y) }, asset: (object/get @f assetUrl) })) }
            { type: draw-text-layer, items: (array/map @entity.fx (fn fx { type: draw-text, text: (object/get @fx message), position: { x: (object/get @fx x), y: (object/get @fx y), z: (object/get @fx z) }, color: "#ffe066" })) }
          ] } ]
        })

    }

    emits {
      TILE_CLICK -> external {
        tileId : string
        x : number!
        z : number
      }
        @description "Emits UI:{tileClickEvent} with {tileId,x,z} on grid cell click"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : BrickSandboxBoard3DError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      baseplateModel : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/features/square-hq-plate-1x1.glb", role: "tile", category: "baseplate", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-plate-1x1", thumbnailUrl: "" }
        @label "Baseplate Model"
        @description "Passable baseplate tile, tiled across the 12x12 build plate."
        @tier "presentation"
      blueprint : [BrickSandboxBoard3DBlueprintItem] = [{ id: "bp1", x: 4, y: 3, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp2", x: 5, y: 3, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }, { id: "bp3", x: 6, y: 3, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/bevel-hq-brick-2x2.glb", role: "decoration", category: "brick-bevel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bevel-hq-brick-2x2", thumbnailUrl: "" } }, { id: "bp4", x: 7, y: 3, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp5", x: 4, y: 4, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }, { id: "bp6", x: 5, y: 4, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/bevel-hq-brick-2x2.glb", role: "decoration", category: "brick-bevel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bevel-hq-brick-2x2", thumbnailUrl: "" } }, { id: "bp7", x: 6, y: 4, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp8", x: 7, y: 4, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }, { id: "bp9", x: 4, y: 5, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/bevel-hq-brick-2x2.glb", role: "decoration", category: "brick-bevel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bevel-hq-brick-2x2", thumbnailUrl: "" } }, { id: "bp10", x: 5, y: 5, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp11", x: 6, y: 5, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }, { id: "bp12", x: 7, y: 5, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/bevel-hq-brick-2x2.glb", role: "decoration", category: "brick-bevel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bevel-hq-brick-2x2", thumbnailUrl: "" } }, { id: "bp13", x: 4, y: 6, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp14", x: 5, y: 6, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }, { id: "bp15", x: 6, y: 6, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/bevel-hq-brick-2x2.glb", role: "decoration", category: "brick-bevel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bevel-hq-brick-2x2", thumbnailUrl: "" } }, { id: "bp16", x: 7, y: 6, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp17", x: 4, y: 7, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }, { id: "bp18", x: 5, y: 7, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/bevel-hq-brick-2x2.glb", role: "decoration", category: "brick-bevel", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "bevel-hq-brick-2x2", thumbnailUrl: "" } }, { id: "bp19", x: 6, y: 7, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/square-hq-brick-1x1.glb", role: "decoration", category: "brick-square", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "square-hq-brick-1x1", thumbnailUrl: "" } }, { id: "bp20", x: 7, y: 7, filled: false, brickModel: { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/terrain/round-hq-brick-1x1-round.glb", role: "decoration", category: "brick-round", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-brick-1x1-round", thumbnailUrl: "" } }]
        @label "Blueprint"
        @description "20 target cells forming a 4x5 build blueprint within the 12x12 plate, cycling 3 brick models."
        @tier "presentation"
      markerModel : Asset = { url: "https://almadar-kflow-assets.web.app/shared/ui-brick-sandbox-board-3d/kenney-brick-kit/features/round-hq-plate-1x1-round.glb", role: "decoration", category: "marker", animations: ["static"], style: "lowpoly-flat", dimension: "3d", aspect: "1:1", name: "round-hq-plate-1x1-round", thumbnailUrl: "" }
        @label "Marker Model"
        @description "Subtle stud marker shown on unfilled blueprint cells."
        @tier "presentation"
      scale : number = 0.5
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      bgColor : string = "#FFD966"
        @label "Bg Color"
        @description "Bright playful canvas background color"
        @tier "presentation"
    }
  }

  page "/brick-sandbox-board-3d" as BrickSandboxBoard3DPage -> BrickSandboxBoard3DRender
}
