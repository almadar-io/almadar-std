app ui-sequencer-board "1.0.0"
"SequencerBoard — UI factory (1:1 with the @almadar/ui sequencer-board pattern)."
orbital SequencerBoardOrbital {
  type SequencerBoardEntity = {
    id : string!
    title : string!
    description : string!
    availableActions : [SequencerBoardEntityAvailableActionsItem]!
    maxSlots : number!
    allowDuplicates : boolean
    solutions : [[string]]!
    successMessage : string
    failMessage : string
    hint : string
    path : [SequencerBoardEntityPathItem]
    headerImage : string
    theme : SequencerBoardEntityTheme
  }
  type SequencerBoardEntityAvailableActionsItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : string
    stateMachine : SequencerBoardEntityAvailableActionsItemStateMachine
  }
  type SequencerBoardEntityAvailableActionsItemStateMachine = {
    name : string!
    states : [string]!
    currentState : string!
    transitions : [SequencerBoardEntityAvailableActionsItemStateMachineTransitionsItem]!
    description : string
  }
  type SequencerBoardEntityAvailableActionsItemStateMachineTransitionsItem = {
    from : string!
    to : string!
    event : string!
    guardHint : string
  }
  type SequencerBoardEntityPathItem = {
    x : number!
    y : number!
  }
  type SequencerBoardEntityTheme = {
    background : string
    accentColor : string
  }
  type SequencerBoardCategoryColorsValue = {
    bg : string!
    border : string!
  }

  entity SequencerBoardItem [runtime] {
    id : string!
  }

  trait SequencerBoardRender -> @rebindable SequencerBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          categoryColors: @config.categoryColors
          stepDurationMs: @config.stepDurationMs
          playEvent: PLAY
          completeEvent: COMPLETE
          type: sequencer-board
        })
    }

    emits {
      PLAY -> external {
        sequence : [object]!
      }
        @description "Emits UI:{playEvent} with { sequence: string[] }"
        @tier "essential"
      COMPLETE -> external {
        success : boolean!
        sequence : [object]!
      }
        @description "Emits UI:{completeEvent} with { success: boolean }"
        @tier "essential"
    }

    config {
      entityProp : SequencerBoardEntity
        @label "Entity"
        @description "Puzzle data. Also accepts the canonical `EntityRow` the compiler binds (and arrays); narrowed to `SequencerPuzzleEntity` internally."
        @synonyms "entity"
        @tier "presentation"
      categoryColors : Map string SequencerBoardCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
      stepDurationMs : number = 1000
        @label "Step Duration Ms"
        @description "Playback speed in ms per step"
        @tier "presentation"
    }
  }

  page "/sequencer-board" as SequencerBoardPage -> SequencerBoardRender
}
