app ui-sequencer-board "1.0.0"
"SequencerBoard — UI factory (1:1 with the @almadar/ui sequencer-board pattern)."
orbital SequencerBoardOrbital {
  type SequencerBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type SequencerBoardCategoryColorsValue = {
    bg : string!
    border : string!
  }

  entity SequencerBoardItem [runtime] {
    id : string!
  }

  trait SequencerBoardRender -> @rebindable SequencerBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch SequencerBoardItem {})
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          categoryColors: @config.categoryColors
          stepDurationMs: @config.stepDurationMs
          playEvent: PLAY
          completeEvent: COMPLETE
          type: sequencer-board
        })
    }

    emits {
      PLAY -> external {
        sequence : [object]!
      }
        @description "Emits UI:{playEvent} with { sequence: string[] }"
        @tier "essential"
      COMPLETE -> external {
        success : boolean!
        sequence : [object]!
      }
        @description "Emits UI:{completeEvent} with { success: boolean }"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SequencerBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      categoryColors : Map string SequencerBoardCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
      stepDurationMs : number = 1000
        @label "Step Duration Ms"
        @description "Playback speed in ms per step"
        @tier "presentation"
    }
  }

  page "/sequencer-board" as SequencerBoardPage -> SequencerBoardRender
}
