        @tier "presentation"
      assetManifest : HexStrategyBoardAssetManifest = { terrains: { grass: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/terrain/grass.png", stone: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/terrain/stone.png", dirt: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/terrain/dirt.png", sand: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/terrain/sand.png" }, units: { worker: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/units/worker.png", ranger: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/units/ranger.png", guardian: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/units/guardian.png" }, features: { resource: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/features/resource.png", outpost: "https://almadar-kflow-assets.web.app/shared/ui-hex-strategy-board/default/features/outpost.png" }, effects: { slash: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/slash_03.png", explosion: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/pixelExplosion07.png" } }
        @label "Asset Manifest"
