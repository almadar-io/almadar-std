app ui-trait-slot "1.0.0"
"TraitSlot — UI factory (1:1 with the @almadar/ui trait-slot pattern)."
orbital TraitSlotOrbital {
  type TraitSlotEquippedItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : asset
    stateMachine : json
  }
  type TraitSlotCategoryColorsValue = {
    bg : string!
    border : string!
  }
  type TraitSlotError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type TraitSlotITEMDROPItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : asset
    stateMachine : json
  }
  type TraitSlotDRAGSTARTItem = {
    id : string!
    name : string!
    category : string!
    description : string
    iconEmoji : string
    iconUrl : asset
    stateMachine : json
  }

  entity TraitSlotItem [runtime] {
    id : string!
    slotNumber : number = 0
  }

  trait TraitSlotRender -> @rebindable TraitSlotItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch TraitSlotItem {})
        (set @entity.slotNumber @config.slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          entity: TraitSlotItem
          onItemDrop: ITEM_DROP
          draggable: @config.draggable
          onDragStart: DRAG_START
          feedback: @config.feedback
          onClick: CLICK
          onRemove: REMOVE
          clickEvent: CLICK
          removeEvent: REMOVE
          type: trait-slot
        })
      CLICK -> idle
        (set @entity.slotNumber ?slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          entity: TraitSlotItem
          onItemDrop: ITEM_DROP
          draggable: @config.draggable
          onDragStart: DRAG_START
          feedback: @config.feedback
          onClick: CLICK
          onRemove: REMOVE
          clickEvent: CLICK
          removeEvent: REMOVE
          type: trait-slot
        })
      REMOVE -> idle
        (set @entity.slotNumber ?slotNumber)
        (render-ui main {
          slotNumber: @entity.slotNumber
          equippedItem: @config.equippedItem
          locked: @config.locked
          lockLabel: @config.lockLabel
          selected: @config.selected
          size: @config.size
          showTooltip: @config.showTooltip
          categoryColors: @config.categoryColors
          tooltipFrameUrl: @config.tooltipFrameUrl
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          entity: TraitSlotItem
          onItemDrop: ITEM_DROP
          draggable: @config.draggable
          onDragStart: DRAG_START
          feedback: @config.feedback
          onClick: CLICK
          onRemove: REMOVE
          clickEvent: CLICK
          removeEvent: REMOVE
          type: trait-slot
        })
    }

    emits {
      ITEM_DROP -> external {
        item : TraitSlotITEMDROPItem
      }
        @description "-- Drag and drop --"
        @tier "essential"
      DRAG_START -> external {
        item : TraitSlotDRAGSTARTItem
      }
        @description "Called when drag starts from this slot"
        @tier "essential"
      CLICK -> external {
        slotNumber : number!
      }
        @description "-- Callbacks --"
        @tier "essential"
      REMOVE -> external {
        slotNumber : number!
      }
        @description "Remove handler"
        @tier "essential"
    }

    listens {
      CLICK {
        slotNumber : number!
      }
      REMOVE {
        slotNumber : number!
      }
    }

    config {
      slotNumber : number = 0
        @label "Slot Number"
        @description "Slot index (1-based)"
        @tier "presentation"
      equippedItem : TraitSlotEquippedItem = { id: "Id", name: "Name", category: "Category", description: "Description", iconEmoji: "Icon Emoji", iconUrl: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/guardian.png" }
        @label "Equipped Item"
        @description "Currently equipped item, if any"
        @tier "presentation"
      locked : boolean = false
        @label "Locked"
        @description "Whether slot is locked"
        @tier "presentation"
      lockLabel : string = "Lock Label"
        @label "Lock Label"
        @description "Label shown when locked"
        @tier "presentation"
      selected : boolean = false
        @label "Selected"
        @description "Whether slot is selected"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      showTooltip : boolean = true
        @label "Show Tooltip"
        @description "Show tooltip on hover"
        @tier "presentation"
      categoryColors : Map string TraitSlotCategoryColorsValue = {}
        @label "Category Colors"
        @description "Category → color mapping"
        @tier "presentation"
      tooltipFrameUrl : asset = "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/units/guardian.png"
        @label "Tooltip Frame Url"
        @description "Optional tooltip frame image URL"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : TraitSlotError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      draggable : boolean = false
        @label "Draggable"
        @description "Whether this slot's equipped item is draggable"
        @tier "presentation"
      feedback : "correct" | "wrong" = correct
        @label "Feedback"
        @description "Per-slot correctness feedback after a failed attempt"
        @tier "presentation"
    }
  }

  page "/trait-slot" as TraitSlotPage -> TraitSlotRender
}
