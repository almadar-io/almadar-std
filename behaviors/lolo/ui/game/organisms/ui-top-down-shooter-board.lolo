app ui-top-down-shooter-board "1.0.0"
"TopDownShooterBoard — game-shell composition with LOLO-driven sprite animation and shoot/hit effects."
orbital TopDownShooterBoardOrbital {
  type TopDownShooterBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type Asset = {
      url : asset
      role : string
      category : string
      animations : [string]
      style : string
      dimension : string
      aspect : string
      name : string
      thumbnailUrl : string
    }
  type TopDownShooterBoardPlayer = {
    x : number!
    y : number!
    animation : string
    frame : number
  }
  type TopDownShooterBoardEnemiesItem = {
    id : string!
    x : number!
    y : number!
    hp : number!
    animation : string
    frame : number
  }
  type TopDownShooterBoardProjectilesItem = {
    id : string!
    x : number!
    y : number!
    vx : number!
    vy : number!
  }
  type TopDownShooterBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type TopDownShooterBoardAssetManifest = {
    units : Map string Asset
    features : Map string Asset
    effects : Map string Asset
    background : Asset
  }

  entity TopDownShooterBoardItem [runtime] {
    id : string!
    player : TopDownShooterBoardPlayer
    enemies : [TopDownShooterBoardEnemiesItem]
    projectiles : [TopDownShooterBoardProjectilesItem]
    score : number = 0
    wave : number = 1
    lives : number = 3
    result : "none" | "won" | "lost" = none
    tick : number = 0
    nextId : number = 0
    effects : [TopDownShooterBoardEffectItem] = []
  }

  trait TopDownShooterBoardRender -> @rebindable TopDownShooterBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.player { x: (/ @config.width 2), y: (- @config.height @config.spriteSize), animation: "idle", frame: 0 })
        (set @entity.enemies (array/map (array/range 0 @config.enemiesPerWave) (fn i { id: (str/concat "enemy-" @i), x: (+ @config.spriteSize (* @i (/ @config.width @config.enemiesPerWave))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })))
        (set @entity.projectiles [])
        (set @entity.score 0)
        (set @entity.wave 1)
        (set @entity.lives @config.lives)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.nextId 0)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      MOVE -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { x: (math/max 0 (math/min @config.width (+ (object/get @entity.player x) (* ?dx @config.moveStep)))), y: (math/max 0 (math/min @config.height (+ (object/get @entity.player y) (* ?dy @config.moveStep)))), animation: "walk" }))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      FIRE -> playing when (== @entity.result "none")
        (set @entity.player (object/merge @entity.player { animation: "attack" }))
        (set @entity.projectiles (array/concat @entity.projectiles [{ id: (str/concat "proj-" @entity.nextId), x: (object/get @entity.player x), y: (object/get @entity.player y), vx: 0, vy: (- 0 @config.projectileSpeed) }]))
        (set @entity.nextId (+ @entity.nextId 1))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      GAME_END -> gameover when (or (== @entity.result "won") (== @entity.result "lost"))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.player { x: (/ @config.width 2), y: (- @config.height @config.spriteSize), animation: "idle", frame: 0 })
        (set @entity.enemies (array/map (array/range 0 @config.enemiesPerWave) (fn i { id: (str/concat "enemy-" @i), x: (+ @config.spriteSize (* @i (/ @config.width @config.enemiesPerWave))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })))
        (set @entity.projectiles [])
        (set @entity.score 0)
        (set @entity.wave 1)
        (set @entity.lives @config.lives)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.nextId 0)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.player (object/merge @entity.player { frame: (% (+ (object/get @entity.player frame) 1) 8) }))
        (set @entity.enemies (array/map @entity.enemies (fn e (object/merge @e { frame: (% (+ (object/get @e frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn ef (object/merge @ef { ttl: (- (object/get @ef ttl) 1) }))) (fn ef (> (object/get @ef ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      simulateTick every 100ms
        when (== @entity.result "none")
        (set @entity.tick (+ @entity.tick 1))
        (set @entity.projectiles (array/map @entity.projectiles (fn p (object/merge @p { x: (+ (object/get @p x) (object/get @p vx)), y: (+ (object/get @p y) (object/get @p vy)) }))))
        (set @entity.projectiles (array/filter @entity.projectiles (fn p (and (>= (object/get @p y) 0) (<= (object/get @p y) @config.height)))))
        (set @entity.enemies (array/map @entity.enemies (fn e (object/merge @e { y: (+ (object/get @e y) @config.enemySpeed), animation: "walk" }))))
        (set @entity.score (+ @entity.score (* @config.scorePerKill (array/len (array/filter @entity.enemies (fn e (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0)))))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemies (fn e (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0))) (fn e { key: "spark", x: (object/get @e x), y: (object/get @e y), ttl: 4 }))))
        (set @entity.enemies (array/map @entity.enemies (fn e (if (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0) (object/merge @e { hp: (- (object/get @e hp) 1), animation: (if (<= (- (object/get @e hp) 1) 0) "death" "hit") }) @e))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemies (fn e (<= (object/get @e hp) 0))) (fn e { key: "explosion", x: (object/get @e x), y: (object/get @e y), ttl: 5 }))))
        (set @entity.enemies (array/filter @entity.enemies (fn e (> (object/get @e hp) 0))))
        (set @entity.lives (- @entity.lives (array/len (array/filter @entity.enemies (fn e (>= (object/get @e y) @config.height))))))
        (set @entity.enemies (array/filter @entity.enemies (fn e (< (object/get @e y) @config.height))))
        (set @entity.result (if (<= @entity.lives 0) "lost" @entity.result))
        (set @entity.wave (if (and (== (array/len @entity.enemies) 0) (== @entity.result "none")) (+ @entity.wave 1) @entity.wave))
        (set @entity.result (if (and (== (array/len @entity.enemies) 0) (and (== @entity.result "none") (> @entity.wave @config.maxWaves))) "won" @entity.result))
        (set @entity.enemies (if (and (== (array/len @entity.enemies) 0) (== @entity.result "none")) (array/map (array/range 0 @config.enemiesPerWave) (fn i { id: (str/concat "enemy-" (+ (* @entity.wave 100) @i)), x: (+ @config.spriteSize (* @i (/ @config.width @config.enemiesPerWave))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })) @entity.enemies))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Score", value: @entity.score }, { label: "Wave", value: @entity.wave }, { label: "Lives", value: @entity.lives } ] }
          children: [ { type: isometric-canvas, tiles: [], units: (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))), features: (array/map @entity.projectiles (fn p { id: @p.id, x: (object/get @p x), y: (object/get @p y), type: "projectile", sprite: (object/get (object/get @config.assetManifest features) projectile) })), effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    emits {
      MOVE -> external {
        dx : number!
        dy : number!
      }
        @description "Emits UI:{moveEvent} with {dx,dy} on arrow/WASD key press to move the player"
        @tier "essential"
      FIRE -> external {
        tx : number!
        ty : number!
      }
        @description "Emits UI:{fireEvent} with {tx,ty} on space / arena click to fire a projectile"
        @tier "essential"
      GAME_END -> external {
        result : string!
      }
        @description "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost"
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : TopDownShooterBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      width : number = 640
        @label "Width"
        @description "Arena / canvas width in pixels"
        @tier "presentation"
      height : number = 480
        @label "Height"
        @description "Arena / canvas height in pixels"
        @tier "presentation"
      spriteSize : number = 32
        @label "Sprite Size"
        @description "Pixel draw-size of player/enemy sprites"
        @tier "presentation"
      lives : number = 3
        @label "Starting Lives"
        @description "Lives the player starts with; reaching 0 = defeat"
        @tier "presentation"
      maxWaves : number = 5
        @label "Max Waves"
        @description "Number of waves to clear to win"
        @tier "presentation"
      enemiesPerWave : number = 6
        @label "Enemies Per Wave"
        @description "Enemies spawned at the top of each wave"
        @tier "presentation"
      enemyHp : number = 1
        @label "Enemy HP"
        @description "Hit points each enemy starts with"
        @tier "presentation"
      enemySpeed : number = 6
        @label "Enemy Speed"
        @description "Pixels an enemy advances downward per tick"
        @tier "presentation"
      projectileSpeed : number = 24
        @label "Projectile Speed"
        @description "Pixels a projectile travels per tick"
        @tier "presentation"
      moveStep : number = 16
        @label "Move Step"
        @description "Pixels the player moves per key press"
        @tier "presentation"
      hitRadius : number = 24
        @label "Hit Radius"
        @description "Projectile-to-enemy collision radius in pixels"
        @tier "presentation"
      scorePerKill : number = 10
        @label "Score Per Kill"
        @description "Score awarded for each enemy destroyed"
        @tier "presentation"
      scale : number = 1
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      assetManifest : TopDownShooterBoardAssetManifest = { units: { player: { url: "units/chars-toon/kenney-vendored/toon/platformChar_idle.png", role: "npc", category: "player", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, enemy: { url: "units/chars-toon/kenney-vendored/toon/platformChar_jump.png", role: "npc", category: "enemy", animations: ["idle","walk","attack","hit","death"], style: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" } }, features: { projectile: { url: "features/props-items/kenney-vendored/items/platformPack_item001.png", role: "decoration", category: "projectile", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "projectile", thumbnailUrl: "" }, pickup: { url: "features/props-items/kenney-vendored/items/platformPack_item001.png", role: "decoration", category: "pickup", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "pickup", thumbnailUrl: "" } }, effects: { spark: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/spark_06.png", role: "effect", category: "spark", animations: ["static"], style: "", dimension: "2d", aspect: "8:1", name: "spark", thumbnailUrl: "" }, explosion: { url: "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/pixelExplosion07.png", role: "effect", category: "explosion", animations: ["static"], style: "", dimension: "2d", aspect: "8:1", name: "explosion", thumbnailUrl: "" } }, background: "backgrounds/bg-parallax/trait-wars/scenes/world/streets.png" }
        @label "Asset Manifest"
        @description "Base-url + unit/feature/effect sprite maps + background."
        @tier "presentation"
    }
  }

  page "/top-down-shooter-board" as TopDownShooterBoardPage -> TopDownShooterBoardRender
}
