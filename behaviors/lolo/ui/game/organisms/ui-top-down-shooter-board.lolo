        })
    }

    state gameover {
      PLAY_AGAIN -> playing
        (set @entity.player { x: (/ @config.width 2), y: (- @config.height @config.spriteSize), animation: "idle", frame: 0 })
        (set @entity.enemies (array/map (array/range 0 @config.enemiesPerWave) (fn i { id: (str/concat "enemy-" @i), x: (+ @config.spriteSize (* @i (/ @config.width @config.enemiesPerWave))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })))
        (set @entity.projectiles [])
        (set @entity.selectedUnitId "")
        (set @entity.validMoves [])
        (set @entity.score 0)
        (set @entity.wave 1)
        (set @entity.lives @config.lives)
        (set @entity.result "none")
        (set @entity.tick 0)
        (set @entity.nextId 0)
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_panel.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
