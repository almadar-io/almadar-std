          children: [ { type: canvas, camera: { zoom: @config.scale, pos: { x: (/ @config.width 2), y: (/ @config.height 2) } }, backgroundColor: "#10131c", projection: "free", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT", Space: "FIRE" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [ { type: draw-sprite-layer, items: (array/map @entity.projectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) projectile) })) } { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) } { type: draw-shape-layer, items: (array/map (array/filter (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))) (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) } { type: draw-sprite-layer, items: (array/map (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))) (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), animation: (object/get @u animation), frame: (object/get @u frame), id: (object/get @u id) })) } { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) } ] } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.player (object/merge @entity.player { frame: (% (+ (object/get @entity.player frame) 1) 8) }))
        (set @entity.enemies (array/map @entity.enemies (fn e (object/merge @e { frame: (% (+ (object/get @e frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn ef (object/merge @ef { ttl: (- (object/get @ef ttl) 1) }))) (fn ef (> (object/get @ef ttl) 0))))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_panel.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_panel.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_star", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Wave", value: @entity.wave, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_target", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wave", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_boxCheckmark.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: FIRE, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_fire", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale, pos: { x: (/ @config.width 2), y: (/ @config.height 2) } }, backgroundColor: "#10131c", projection: "free", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT", Space: "FIRE" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [ { type: draw-sprite-layer, items: (array/map @entity.projectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) projectile) })) } { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) } { type: draw-shape-layer, items: (array/map (array/filter (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))) (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) } { type: draw-sprite-layer, items: (array/map (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))) (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), animation: (object/get @u animation), frame: (object/get @u frame), id: (object/get @u id) })) } { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) } ] } ]
        })

      simulateTick every 100ms
        when (== @entity.result "none")
        (set @entity.tick (+ @entity.tick 1))
        (set @entity.projectiles (array/map @entity.projectiles (fn p (object/merge @p { x: (+ (object/get @p x) (object/get @p vx)), y: (+ (object/get @p y) (object/get @p vy)) }))))
        (set @entity.projectiles (array/filter @entity.projectiles (fn p (and (>= (object/get @p y) 0) (<= (object/get @p y) @config.height)))))
        (set @entity.enemies (array/map @entity.enemies (fn e (object/merge @e { y: (+ (object/get @e y) @config.enemySpeed), animation: "walk" }))))
        (set @entity.score (+ @entity.score (* @config.scorePerKill (array/len (array/filter @entity.enemies (fn e (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0)))))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemies (fn e (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0))) (fn e { key: "spark", x: (object/get @e x), y: (object/get @e y), ttl: 4 }))))
        (set @entity.enemies (array/map @entity.enemies (fn e (if (> (array/len (array/filter @entity.projectiles (fn p (<= (vec/distance { x: (object/get @e x), y: (object/get @e y) } { x: (object/get @p x), y: (object/get @p y) }) @config.hitRadius)))) 0) (object/merge @e { hp: (- (object/get @e hp) 1), animation: (if (<= (- (object/get @e hp) 1) 0) "death" "hit") }) @e))))
        (set @entity.effects (array/concat @entity.effects (array/map (array/filter @entity.enemies (fn e (<= (object/get @e hp) 0))) (fn e { key: "explosion", x: (object/get @e x), y: (object/get @e y), ttl: 5 }))))
        (set @entity.enemies (array/filter @entity.enemies (fn e (> (object/get @e hp) 0))))
        (set @entity.lives (- @entity.lives (array/len (array/filter @entity.enemies (fn e (>= (object/get @e y) @config.height))))))
        (set @entity.enemies (array/filter @entity.enemies (fn e (< (object/get @e y) @config.height))))
        (set @entity.result (if (<= @entity.lives 0) "lost" @entity.result))
        (set @entity.wave (if (and (== (array/len @entity.enemies) 0) (== @entity.result "none")) (+ @entity.wave 1) @entity.wave))
        (set @entity.result (if (and (== (array/len @entity.enemies) 0) (and (== @entity.result "none") (> @entity.wave @config.maxWaves))) "won" @entity.result))
        (set @entity.enemies (if (and (== (array/len @entity.enemies) 0) (== @entity.result "none")) (array/map (array/range 0 @config.enemiesPerWave) (fn i { id: (str/concat "enemy-" (+ (* @entity.wave 100) @i)), x: (+ @config.spriteSize (* @i (/ @config.width @config.enemiesPerWave))), y: @config.spriteSize, hp: @config.enemyHp, animation: "idle", frame: 0 })) @entity.enemies))
        (render-ui main {
          type: game-shell
          backgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_panel.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hudBackgroundAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_panel.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "panel-frame", thumbnailUrl: "" }
          hud: { type: stack, direction: horizontal, gap: md, justify: between, children: [ { type: game-hud, stats: [ { label: "Score", value: @entity.score, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_star", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-score", thumbnailUrl: "" } }, { label: "Wave", value: @entity.wave, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_target", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-wave", thumbnailUrl: "" } }, { label: "Lives", value: @entity.lives, iconUrl: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-ui-pack/ui/greySheet.json", sprite: "grey_boxCheckmark.png", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-lives", thumbnailUrl: "" } } ] }, { type: score-display, score: @entity.score, label: "SCORE" }, { type: button, action: FIRE, label: "Fire", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.png", atlas: "https://almadar-kflow-assets.web.app/shared/_shared/kenney-mobile-controls/ui/icons-default.json", sprite: "icon_fire", role: "ui", category: "ui", animations: [], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "icon-fire", thumbnailUrl: "" }, variant: primary } ] }
          children: [ { type: canvas, camera: { zoom: @config.scale, pos: { x: (/ @config.width 2), y: (/ @config.height 2) } }, backgroundColor: "#10131c", projection: "free", showMinimap: false, keyMap: { ArrowUp: "MOVE_UP", KeyW: "MOVE_UP", ArrowDown: "MOVE_DOWN", KeyS: "MOVE_DOWN", ArrowLeft: "MOVE_LEFT", KeyA: "MOVE_LEFT", ArrowRight: "MOVE_RIGHT", KeyD: "MOVE_RIGHT", Space: "FIRE" }, tileClickEvent: TILE_CLICK, unitClickEvent: UNIT_CLICK, children: [ { type: draw-sprite-layer, items: (array/map @entity.projectiles (fn p { type: draw-sprite, position: { x: (object/get @p x), y: (object/get @p y) }, asset: (object/get (object/get @config.assetManifest features) projectile) })) } { type: draw-shape-layer, items: (array/map @entity.validMoves (fn m { type: draw-shape, shape: "cell", position: { x: (object/get @m x), y: (object/get @m y) }, fill: "rgba(74,222,128,0.4)" })) } { type: draw-shape-layer, items: (array/map (array/filter (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))) (fn u (== (object/get @u id) @entity.selectedUnitId))) (fn u { type: draw-shape, shape: "ellipse", position: (object/get @u position), radiusX: 0.5, radiusY: 0.2, stroke: "rgba(0,200,255,0.8)", strokeWidth: 3 })) } { type: draw-sprite-layer, items: (array/map (array/concat [ { id: "player", position: { x: (object/get @entity.player x), y: (object/get @entity.player y) }, sprite: (object/get (object/get @config.assetManifest units) player), animation: (object/get @entity.player animation), frame: (object/get @entity.player frame), team: "player" } ] (array/map @entity.enemies (fn e { id: @e.id, position: { x: (object/get @e x), y: (object/get @e y) }, sprite: (object/get (object/get @config.assetManifest units) enemy), animation: (object/get @e animation), frame: (object/get @e frame), team: "enemy" }))) (fn u { type: draw-sprite, position: (object/get @u position), asset: (object/get @u sprite), animation: (object/get @u animation), frame: (object/get @u frame), id: (object/get @u id) })) } { type: draw-sprite-layer, items: (array/map @entity.effects (fn ef { type: draw-sprite, position: { x: (object/get @ef x), y: (object/get @ef y) }, asset: (object/get (object/get @config.assetManifest effects) (object/get @ef key)) })) } ] } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile/arena click"
        @tier "domain"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "domain"
      MOVE_LEFT -> external {
        id : string
      }
        @description "Move-left intent (keyboard keyMap)"
        @tier "domain"
      MOVE_RIGHT -> external {
        id : string
      }
        @description "Move-right intent (keyboard keyMap)"
        @tier "domain"
      MOVE_UP -> external {
        id : string
      }
        @description "Move-up intent (keyboard keyMap)"
        @tier "domain"
      MOVE_DOWN -> external {
        id : string
      }
        @description "Move-down intent (keyboard keyMap)"
        @tier "domain"
      FIRE -> external {
        id : string
      }
        @description "Fire intent (keyboard Space / Fire button)"
        @tier "domain"
      GAME_END -> external {
        result : string!
      }
        @description "Emits UI:{gameEndEvent} with {result} when the game reaches won or lost"
        @tier "domain"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Emits UI:{playAgainEvent} with {} on play again / reset"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : TopDownShooterBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      width : number = 640
        @label "Width"
        @description "Arena / canvas width in pixels"
        @tier "presentation"
      height : number = 480
        @label "Height"
        @description "Arena / canvas height in pixels"
        @tier "presentation"
      spriteSize : number = 32
        @label "Sprite Size"
        @description "Pixel draw-size of player/enemy sprites"
        @tier "presentation"
      lives : number = 3
        @label "Starting Lives"
        @description "Lives the player starts with; reaching 0 = defeat"
        @tier "presentation"
      maxWaves : number = 5
        @label "Max Waves"
        @description "Number of waves to clear to win"
        @tier "presentation"
      enemiesPerWave : number = 6
        @label "Enemies Per Wave"
        @description "Enemies spawned at the top of each wave"
        @tier "presentation"
      enemyHp : number = 1
        @label "Enemy HP"
        @description "Hit points each enemy starts with"
        @tier "presentation"
      enemySpeed : number = 6
        @label "Enemy Speed"
        @description "Pixels an enemy advances downward per tick"
        @tier "presentation"
      projectileSpeed : number = 24
        @label "Projectile Speed"
        @description "Pixels a projectile travels per tick"
        @tier "presentation"
      moveStep : number = 16
        @label "Move Step"
        @description "Pixels the player moves per key press"
        @tier "presentation"
      hitRadius : number = 24
        @label "Hit Radius"
        @description "Projectile-to-enemy collision radius in pixels"
        @tier "presentation"
      scorePerKill : number = 10
        @label "Score Per Kill"
        @description "Score awarded for each enemy destroyed"
        @tier "presentation"
      scale : number = 1
        @label "Scale"
        @description "Canvas render scale"
        @tier "presentation"
      assetManifest : TopDownShooterBoardAssetManifest = { units: { player: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-toon-characters-pack-1/units/character_maleAdventurer_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-toon-characters-pack-1/units/character_maleAdventurer_sheet.json", sprite: "idle", role: "npc", category: "player", animations: ["idle","walk0","walk1","walk2","walk3","walk4","walk5","walk6","walk7","attack0","attack1","attack2","hurt"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "player", thumbnailUrl: "" }, enemy: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-toon-characters-pack-1/units/character_zombie_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-toon-characters-pack-1/units/character_zombie_sheet.json", sprite: "idle", role: "npc", category: "enemy", animations: ["idle","walk0","walk1","walk2","walk3","walk4","walk5","walk6","walk7","attack0","attack1","attack2","hurt"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "enemy", thumbnailUrl: "" } }, features: { projectile: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-alien-ufo-pack/features/spritesheet_lasers.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-alien-ufo-pack/features/spritesheet_lasers.json", sprite: "laserBlue1.png", role: "decoration", category: "projectile", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "projectile", thumbnailUrl: "" }, pickup: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-generic-items/features/genericItems_spritesheet_colored.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-generic-items/features/genericItems_spritesheet_colored.json", sprite: "genericItem_color_001.png", role: "decoration", category: "pickup", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "pickup", thumbnailUrl: "" } }, effects: { spark: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-simple-space/features/simpleSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-simple-space/features/simpleSpace_sheet.json", sprite: "effect_purple.png", role: "effect", category: "spark", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "spark", thumbnailUrl: "" }, explosion: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-simple-space/features/simpleSpace_sheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-simple-space/features/simpleSpace_sheet.json", sprite: "effect_yellow.png", role: "effect", category: "explosion", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "1:1", name: "explosion", thumbnailUrl: "" } }, background: { url: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-rts-sci-fi/terrain/scifiRTS_spritesheet.png", atlas: "https://almadar-kflow-assets.web.app/shared/ui-top-down-shooter-board/kenney-rts-sci-fi/terrain/scifiRTS_spritesheet.json", sprite: "scifiEnvironment_01.png", role: "background", category: "background", animations: ["static"], style: "sci-fi", variant: "", dimension: "2d", aspect: "16:9", name: "space", thumbnailUrl: "" } }
        @label "Asset Manifest"
        @description "Base-url + unit/feature/effect sprite maps + background."
        @tier "presentation"
    }
  }

  page "/top-down-shooter-board" as TopDownShooterBoardPage -> TopDownShooterBoardRender
}
