app ui-sports-board "1.0.0"
"SportsBoard — game-shell composition with sprite animation and score HUD."
orbital SportsBoardOrbital {
  type SportsBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type SportsBoardTilesItem = {
    id : string
    x : number!
    y : number!
    z : number
    terrain : string
    type : string
    terrainSprite : asset
    passable : boolean
    movementCost : number
    tileType : string
    elevation : number
    modelUrl : asset
  }
  type SportsBoardUnitsItem = {
    id : string!
    position : SportsBoardUnitsItemPosition
    x : number
    y : number
    z : number
    sprite : asset
    spriteSheet : asset
    modelUrl : asset
    unitType : string
    heroId : string
    name : string
    team : "player" | "enemy" | "neutral"
    faction : "player" | "enemy" | "neutral"
    health : number
    maxHealth : number
    traits : [SportsBoardUnitsItemTraitsItem]
    previousPosition : SportsBoardUnitsItemPreviousPosition
    elevation : number
    animation : string
    frame : number
  }
  type SportsBoardEffectItem = {
    key : string!
    x : number!
    y : number!
    ttl : number!
  }
  type SportsBoardUnitsItemPosition = {
    x : number!
    y : number!
  }
  type SportsBoardUnitsItemTraitsItem = {
    name : string!
    currentState : string!
    states : [string]!
    cooldown : number!
  }
  type SportsBoardUnitsItemPreviousPosition = {
    x : number!
    y : number!
  }
  type SportsBoardFeaturesItem = {
    id : string
    x : number!
    y : number!
    z : number
    type : string!
    sprite : asset
    assetUrl : asset
    color : string
    elevation : number
  }
  type SportsBoardAssetManifest = {
    baseUrl : asset
    terrains : Map string asset
    units : Map string asset
    features : Map string asset
    effects : Map string asset
  }

  entity SportsBoardItem [runtime] {
    id : string!
    units : [SportsBoardUnitsItem]
    selectedUnitId : string
    homeScore : number = 0
    awayScore : number = 0
    phase : string = "kickoff"
    effects : [SportsBoardEffectItem] = []
  }

  trait SportsBoardRender -> @rebindable SportsBoardItem [interaction, instance] {
    initial: playing

    state playing {
      INIT -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.homeScore 0)
        (set @entity.awayScore 0)
        (set @entity.phase "kickoff")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      UNIT_CLICK -> playing when (== @entity.selectedUnitId ?unitId)
        (set @entity.selectedUnitId "")
        (set @entity.phase "kickoff")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      UNIT_CLICK -> playing
        (set @entity.selectedUnitId ?unitId)
        (set @entity.phase "selected")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      TILE_CLICK -> playing when (!= @entity.selectedUnitId "")
        (set @entity.units (array/map @entity.units (fn u (if (== @u.id @entity.selectedUnitId) (object/merge @u { position: { x: ?x, y: ?y }, animation: "walk" }) @u))))
        (set @entity.selectedUnitId "")
        (set @entity.phase "kickoff")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      GOAL -> playing
        (set @entity.homeScore (if (== ?team "player") (+ @entity.homeScore 1) @entity.homeScore))
        (set @entity.awayScore (if (== ?team "enemy") (+ @entity.awayScore 1) @entity.awayScore))
        (set @entity.phase "kickoff")
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })

      RESET -> playing
        (set @entity.units @config.units)
        (set @entity.selectedUnitId "")
        (set @entity.homeScore 0)
        (set @entity.awayScore 0)
        (set @entity.phase "kickoff")
        (set @entity.effects [])
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    ticks {
      animTick every 100ms
        (set @entity.units (array/map @entity.units (fn u (object/merge @u { frame: (% (+ (object/get @u frame) 1) 8) }))))
        (set @entity.effects (array/filter (array/map @entity.effects (fn e (object/merge @e { ttl: (- (object/get @e ttl) 1) }))) (fn e (> (object/get @e ttl) 0))))
        (render-ui main {
          type: game-shell
          hud: { type: game-hud, stats: [ { label: "Home", value: @entity.homeScore }, { label: "Away", value: @entity.awayScore } ] }
          children: [ { type: isometric-canvas, tiles: @config.tiles, units: @entity.units, features: @config.features, effects: @entity.effects, assetManifest: @config.assetManifest, tileLayout: "flat", showMinimap: false, scale: @config.scale } ]
        })
    }

    emits {
      TILE_CLICK -> external {
        x : number!
        y : number!
      }
        @description "Emits UI:{tileClickEvent} with { x, y } on tile click"
        @tier "essential"
      UNIT_CLICK -> external {
        unitId : string!
      }
        @description "Emits UI:{unitClickEvent} with { unitId } on unit click"
        @tier "essential"
      GOAL -> external {
        team : string!
      }
        @description "Fired when a goal is scored; team is 'player' or 'enemy'"
        @tier "essential"
      RESET -> external {
        id : string
      }
        @description "Resets the match to initial state"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SportsBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      tiles : [SportsBoardTilesItem] = [{ x: 0, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 1, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 2, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 3, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 4, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 5, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 6, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 7, y: 0, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 0, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 1, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 2, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 3, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 4, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 5, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 6, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 7, y: 1, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 0, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 1, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 2, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 3, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 4, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 5, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 6, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 7, y: 2, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 0, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 1, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 2, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 3, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 4, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 5, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 6, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 7, y: 3, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 0, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 1, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 2, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 3, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 4, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 5, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 6, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, { x: 7, y: 4, terrain: "court", passable: true, terrainSprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }]
        @label "Tiles"
        @description "Court/field terrain tiles"
        @tier "presentation"
      units : [SportsBoardUnitsItem] = [{ id: "g1", position: { x: 1, y: 2 }, unitType: "player", name: "GK Green", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterGreen.png", animation: "idle", frame: 0 }, { id: "g2", position: { x: 2, y: 1 }, unitType: "player", name: "LW Green", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterGreen.png", animation: "idle", frame: 0 }, { id: "g3", position: { x: 3, y: 2 }, unitType: "player", name: "ST Green", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterGreen.png", animation: "idle", frame: 0 }, { id: "g4", position: { x: 2, y: 3 }, unitType: "player", name: "RW Green", team: player, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterGreen.png", animation: "idle", frame: 0 }, { id: "b1", position: { x: 6, y: 2 }, unitType: "player", name: "GK Blue", team: enemy, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterBlue.png", animation: "idle", frame: 0 }, { id: "b2", position: { x: 5, y: 1 }, unitType: "player", name: "DEF Blue", team: enemy, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterBlue.png", animation: "idle", frame: 0 }, { id: "b3", position: { x: 4, y: 2 }, unitType: "player", name: "MID Blue", team: enemy, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterBlue.png", animation: "idle", frame: 0 }, { id: "b4", position: { x: 5, y: 3 }, unitType: "player", name: "DEF Blue", team: enemy, health: 10, maxHealth: 10, sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterBlue.png", animation: "idle", frame: 0 }]
        @label "Units"
        @description "Player units on the board"
        @tier "presentation"
      features : [SportsBoardFeaturesItem] = [{ id: "goal-l1", x: 0, y: 1, type: "goal", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png" }, { id: "goal-l2", x: 0, y: 2, type: "goal", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png" }, { id: "goal-l3", x: 0, y: 3, type: "goal", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png" }, { id: "goal-r1", x: 7, y: 1, type: "goal", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png" }, { id: "goal-r2", x: 7, y: 2, type: "goal", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png" }, { id: "goal-r3", x: 7, y: 3, type: "goal", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png" }, { id: "ball", x: 3, y: 2, type: "ball", sprite: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/ball_soccer.png" }]
        @label "Features"
        @description "Features (goals, markers, etc.) on the board"
        @tier "presentation"
      assetManifest : SportsBoardAssetManifest = { terrains: { court: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/terrain/groundGrass_mown.png" }, units: { characterGreen: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterGreen.png", characterBlue: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/units/characterBlue.png" }, features: { goal: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/goal_net.png", ball: "https://almadar-kflow-assets.web.app/shared/ui-sports-board/default/features/ball_soccer.png" }, effects: {} }
        @label "Asset Manifest"
        @description "Asset sprite manifest"
        @tier "presentation"
      assetBaseUrl : asset = "https://almadar-kflow-assets.web.app/shared/"
        @label "Asset Base Url"
        @description "Base URL prepended to asset paths"
        @tier "presentation"
      scale : number = 0.45
        @label "Scale"
        @description "Render scale"
        @tier "presentation"
    }
  }

  page "/sports-board" as SportsBoardPage -> SportsBoardRender
}
