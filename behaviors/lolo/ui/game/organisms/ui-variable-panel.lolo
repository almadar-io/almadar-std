app ui-variable-panel "1.0.0"
"VariablePanel — UI factory (1:1 with the @almadar/ui variable-panel pattern)."
orbital VariablePanelOrbital {
  entity VariablePanelItem [runtime] {
    id : string!
  }

  trait VariablePanelRender -> @rebindable VariablePanelItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch VariablePanelItem {})
        (render-ui main {
          entityName: @config.entityName
          variables: @entity
          className: @config.className
          type: variable-panel
        })
    }

    config {
      entityName : string = "Entity Name"
        @label "Entity Name"
        @description "Entity name"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/variable-panel" as VariablePanelPage -> VariablePanelRender
}
