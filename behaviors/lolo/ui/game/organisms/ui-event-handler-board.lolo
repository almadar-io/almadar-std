app ui-event-handler-board "1.0.0"
"EventHandlerBoard — UI factory (1:1 with the @almadar/ui event-handler-board pattern)."
orbital EventHandlerBoardOrbital {
  type EventHandlerBoardEntity = {
    id : string!
    title : string!
    description : string!
    objects : [EventHandlerBoardEntityObjectsItem]!
    goalCondition : string!
    goalEvent : string!
    triggerEvents : [string]
    successMessage : string
    failMessage : string
    hint : string
    headerImage : string
    theme : EventHandlerBoardEntityTheme
  }
  type EventHandlerBoardEntityObjectsItem = {
    id : string!
    name : string!
    icon : string!
    states : [string]!
    initialState : string!
    currentState : string!
    availableEvents : [EventHandlerBoardEntityObjectsItemAvailableEventsItem]!
    availableActions : [EventHandlerBoardEntityObjectsItemAvailableActionsItem]!
    rules : [EventHandlerBoardEntityObjectsItemRulesItem]!
    maxRules : number
  }
  type EventHandlerBoardEntityObjectsItemAvailableEventsItem = {
    value : string!
    label : string!
  }
  type EventHandlerBoardEntityObjectsItemAvailableActionsItem = {
    value : string!
    label : string!
  }
  type EventHandlerBoardEntityObjectsItemRulesItem = {
    id : string!
    whenEvent : string!
    thenAction : string!
  }
  type EventHandlerBoardEntityTheme = {
    background : string
    accentColor : string
  }

  entity EventHandlerBoardItem [runtime] {
    id : string!
  }

  trait EventHandlerBoardRender -> @rebindable EventHandlerBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          stepDurationMs: @config.stepDurationMs
          playEvent: PLAY
          completeEvent: COMPLETE
          type: event-handler-board
        })
    }

    emits {
      PLAY -> external {
        id : string
      }
        @description "Emits UI:{playEvent}"
        @tier "essential"
      COMPLETE -> external {
        success : boolean!
      }
        @description "Emits UI:{completeEvent} with { success }"
        @tier "essential"
    }

    config {
      entityProp : EventHandlerBoardEntity
        @label "Entity"
        @description "Puzzle data. The compiler binds the generic `EntityRow`, so the inlet accepts it (and arrays) as union members; the component narrows to its curated `EventHandlerPuzzleEntity` read-shape below (a valid union-narrow) and renders nothing until a puzzle entity is present."
        @synonyms "entity"
        @tier "presentation"
      stepDurationMs : number = 800
        @label "Step Duration Ms"
        @description "Playback speed in ms per event"
        @tier "presentation"
    }
  }

  page "/event-handler-board" as EventHandlerBoardPage -> EventHandlerBoardRender
}
