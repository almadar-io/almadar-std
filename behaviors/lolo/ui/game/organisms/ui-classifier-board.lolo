app ui-classifier-board "1.0.0"
"ClassifierBoard — UI factory (1:1 with the @almadar/ui classifier-board pattern)."
orbital ClassifierBoardOrbital {
  type ClassifierBoardEntity = {
    id : string!
    title : string!
    description : string!
    items : [ClassifierBoardEntityItemsItem]!
    categories : [ClassifierBoardEntityCategoriesItem]!
    successMessage : string
    failMessage : string
    hint : string
    headerImage : string
    theme : ClassifierBoardEntityTheme
  }
  type ClassifierBoardEntityItemsItem = {
    id : string!
    label : string!
    description : string
    correctCategory : string!
    iconUrl : string
  }
  type ClassifierBoardEntityCategoriesItem = {
    id : string!
    label : string!
    color : string
    imageUrl : string
  }
  type ClassifierBoardEntityTheme = {
    background : string
    accentColor : string
  }

  entity ClassifierBoardItem [runtime] {
    id : string!
  }

  trait ClassifierBoardRender -> @rebindable ClassifierBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          completeEvent: COMPLETE
          type: classifier-board
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "essential"
    }

    config {
      entityProp : ClassifierBoardEntity
        @label "Entity"
        @description "entity prop"
        @synonyms "entity"
        @tier "presentation"
    }
  }

  page "/classifier-board" as ClassifierBoardPage -> ClassifierBoardRender
}
