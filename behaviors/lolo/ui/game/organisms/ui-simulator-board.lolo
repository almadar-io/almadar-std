app ui-simulator-board "1.0.0"
"SimulatorBoard — parameter-tuning puzzle: adjust params until output is within tolerance of target."
orbital SimulatorBoardOrbital {
  type SimulatorBoardError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity SimulatorBoardItem [runtime] {
    id : string!
    paramA : number = 0
    paramB : number = 0
    target : number = 10
    tolerance : number = 1
    output : number @intrinsic = derived (+ @entity.paramA (* @entity.paramB 2))
    attempts : number = 0
    result : "none" | "win" = none
  }

  trait SimulatorBoardRender -> @rebindable SimulatorBoardItem [interaction, instance] {
    initial: menu

    state menu {
      INIT -> menu
        (set @entity.paramA 0)
        (set @entity.paramB 0)
        (set @entity.target 10)
        (set @entity.tolerance 1)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })
      START -> playing
        (set @entity.paramA 0)
        (set @entity.paramB 0)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })
    }

    state playing {
      SET_A -> playing when (== @entity.result "none")
        (set @entity.paramA ?value)
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })

      SET_B -> playing when (== @entity.result "none")
        (set @entity.paramB ?value)
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })

      CHECK -> complete when (<= (math/abs (- @entity.output @entity.target)) @entity.tolerance)
        (set @entity.attempts (+ @entity.attempts 1))
        (set @entity.result "win")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })

      CHECK -> playing when (> (math/abs (- @entity.output @entity.target)) @entity.tolerance)
        (set @entity.attempts (+ @entity.attempts 1))
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })
    }

    state complete {
      PLAY_AGAIN -> menu
        (set @entity.paramA 0)
        (set @entity.paramB 0)
        (set @entity.attempts 0)
        (set @entity.result "none")
        (render-ui main {
          entity: @entity
          completeEvent: COMPLETE
          setAEvent: SET_A
          setBEvent: SET_B
          checkEvent: CHECK
          playAgainEvent: PLAY_AGAIN
          type: simulator-board
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "essential"
      SET_A -> external {
        value : number!
      }
        @description "Sets parameter A from { value } during play."
        @tier "essential"
      SET_B -> external {
        value : number!
      }
        @description "Sets parameter B from { value } during play."
        @tier "essential"
      CHECK -> external {
        id : string
      }
        @description "Evaluates output vs target/tolerance; wins or retries."
        @tier "essential"
      PLAY_AGAIN -> external {
        id : string
      }
        @description "Resets the puzzle back to the menu."
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SimulatorBoardError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
    }
  }

  page "/simulator-board" as SimulatorBoardPage -> SimulatorBoardRender
}
