app ui-simulator-board "1.0.0"
"SimulatorBoard — UI factory (1:1 with the @almadar/ui simulator-board pattern)."
orbital SimulatorBoardOrbital {
  type SimulatorBoardEntity = {
    id : string!
    title : string!
    description : string!
    parameters : [SimulatorBoardEntityParametersItem]!
    outputLabel : string!
    outputUnit : string!
    computeExpression : string!
    targetValue : number!
    targetTolerance : number!
    successMessage : string
    failMessage : string
    hint : string
    headerImage : string
    theme : SimulatorBoardEntityTheme
  }
  type SimulatorBoardEntityParametersItem = {
    id : string!
    label : string!
    unit : string!
    min : number!
    max : number!
    step : number!
    initial : number!
    correct : number!
    tolerance : number!
  }
  type SimulatorBoardEntityTheme = {
    background : string
    accentColor : string
  }

  entity SimulatorBoardItem [runtime] {
    id : string!
  }

  trait SimulatorBoardRender -> @rebindable SimulatorBoardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          entity: @config.entityProp
          completeEvent: COMPLETE
          type: simulator-board
        })
    }

    emits {
      COMPLETE -> external {
        success : boolean!
        attempts : number!
      }
        @description "completeEvent prop"
        @tier "essential"
    }

    config {
      entityProp : SimulatorBoardEntity
        @label "Entity"
        @description "The compiler binds the generic `EntityRow`, so the inlet accepts it (and"
        @synonyms "entity"
        @tier "presentation"
    }
  }

  page "/simulator-board" as SimulatorBoardPage -> SimulatorBoardRender
}
