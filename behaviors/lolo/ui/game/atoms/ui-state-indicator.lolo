app ui-state-indicator "1.0.0"
"StateIndicator — UI factory (1:1 with the @almadar/ui state-indicator pattern)."
orbital StateIndicatorOrbital {
  entity StateIndicatorItem [runtime] {
    id : string!
  }

  trait StateIndicatorRender -> @rebindable StateIndicatorItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          state: @config.stateProp
          label: @config.label
          size: @config.size
          animated: @config.animated
          stateStyles: @config.stateStyles
          className: @config.className
          type: state-indicator
        })
    }

    config {
      stateProp : string = ""
        @label "State"
        @description "The current state name"
        @synonyms "state"
        @tier "presentation"
      label : string = ""
        @label "Label"
        @description "Optional label override (defaults to capitalized state name)"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      animated : boolean = true
        @label "Animated"
        @description "Whether to show pulse animation on non-idle states"
        @tier "presentation"
      stateStyles : json
        @label "State Styles"
        @description "Custom state styles to extend/override defaults"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/state-indicator" as StateIndicatorPage -> StateIndicatorRender
}
