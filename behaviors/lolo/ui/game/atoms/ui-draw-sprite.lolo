app ui-draw-sprite "1.0.0"
"DrawSprite — UI factory (1:1 with the @almadar/ui draw-sprite pattern)."
orbital DrawSpriteOrbital {
  type DrawSpritePosition = {
    x : number!
    y : number!
    z : number
  }
  type DrawSpriteAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity DrawSpriteItem [runtime] {
    id : string!
  }

  trait DrawSpriteRender -> @rebindable DrawSpriteItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          position: @config.position
          asset: @config.asset
          anchor: @config.anchor
          width: @config.width
          height: @config.height
          frame: @config.frame
          flipX: @config.flipX
          rotation: @config.rotation
          opacity: @config.opacity
          shadow: @config.shadow
          type: draw-sprite
        })
    }

    config {
      position : DrawSpritePosition = { x: 1, y: 1, z: 1 }
        @label "Position"
        @description "Logical scene position; the projector maps it to pixels / world."
        @tier "presentation"
      asset : DrawSpriteAsset = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "asset", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "asset", thumbnailUrl: "" }
        @label "Asset"
        @description "The image / atlas reference to blit."
        @tier "presentation"
      anchor : json = {}
        @label "Anchor"
        @description "How the sprite aligns to its projected position. Default `'top-left'`."
        @tier "presentation"
      width : number = 0
        @label "Width"
        @description "Draw width in px (2D) / world units (3D); omitted → resolved source width."
        @tier "presentation"
      height : number = 0
        @label "Height"
        @description "Draw height in px (2D) / world units (3D); omitted → resolved source height."
        @tier "presentation"
      frame : json = {}
        @label "Frame"
        @description "Explicit atlas sub-rect override (px); omitted → resolved from `asset.atlas`/`asset.sprite`."
        @tier "presentation"
      flipX : boolean = false
        @label "Flip X"
        @description "Mirror horizontally (facing)."
        @tier "presentation"
      rotation : number = 0
        @label "Rotation"
        @description "Rotation in radians about the sprite's center."
        @tier "presentation"
      opacity : number = 0
        @label "Opacity"
        @description "0..1 opacity."
        @tier "presentation"
      shadow : json = {}
        @label "Shadow"
        @description "Drop shadow (e.g. a team-colored glow)."
        @tier "presentation"
    }
  }

  page "/draw-sprite" as DrawSpritePage -> DrawSpriteRender
}
