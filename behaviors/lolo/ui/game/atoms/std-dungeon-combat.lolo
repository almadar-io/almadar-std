app std-dungeon-combat "1.0.0"
"Headless dungeon combat authority: owns the enemy roster, hero HP, and kill score. Bump-attacks damage enemies; monster ticks chase the hero and deal contact damage."
orbital DungeonCombatOrbital {
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
    name : string
    animation : string
    frame : number
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    passable : boolean
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity DungeonCombatData [runtime, shared] {
    id : string!
    enemies : [Unit] = []
    hp : number = 5
    maxHp : number = 5
    combatScore : number = 0
    combatResult : string = "none"
  }

  trait DungeonCombat -> @rebindable DungeonCombatData [lifecycle] {
    initial: active

    state active {
      INIT -> active
        (set @entity.enemies @config.enemies)
        (set @entity.hp @config.startHp)
        (set @entity.maxHp @config.startHp)
        (set @entity.combatScore 0)
        (set @entity.combatResult "none")

      ATTACK -> active when (and @config.running (> (array/len (array/filter @entity.enemies (fn e (and (== @e.id @payload.targetId) (> @e.health 0))))) 0))
        (let ((target (array/find @entity.enemies (fn e (== @e.id @payload.targetId)))))
          (let ((newHealth (math/max 0 (- (object/get @target health) @config.attackDamage))))
            (do
              (set @entity.enemies (array/map @entity.enemies (fn e (if (== @e.id @payload.targetId) (object/merge @e { health: @newHealth, animation: (if (<= @newHealth 0) "death" "hit") }) e))))
              (if (<= @newHealth 0)
                (do
                  (set @entity.combatScore (+ @entity.combatScore @config.pointsPerKill))
                  (emit BURST { particles: (array/map (array/filter @entity.enemies (fn e (== @e.id @payload.targetId))) (fn t { id: (str/concat "fx-kill-" (object/get t id)), type: "explosion", x: (object/get (object/get t position) x), z: (object/get (object/get t position) y), ttl: 5 })) }))
                true))))

      MONSTER_TICK -> active when @config.running
        (set @entity.enemies (array/map @entity.enemies (fn u
          (if (> @u.health 0)
            (let ((ux (object/get (object/get @u position) x)) (uy (object/get (object/get @u position) y)))
              (let ((dx (math/sign (- @payload.heroX @ux))) (dy (math/sign (- @payload.heroY @uy))) (absDx (math/abs (- @payload.heroX @ux))) (absDy (math/abs (- @payload.heroY @uy))))
                (let ((moveX (and (!= @dx 0) (>= @absDx @absDy))))
                  (let ((nx (if @moveX (+ @ux @dx) @ux)) (ny (if @moveX @uy (+ @uy @dy))))
                    (let ((tile (array/find @config.tiles (fn t (and (== (object/get @t x) @nx) (== (object/get @t y) @ny))))) (occupied (array/find @entity.enemies (fn o (and (!= @o.id @u.id) (and (> @o.health 0) (and (== (object/get (object/get @o position) x) @nx) (== (object/get (object/get @o position) y) @ny))))))))
                      (if (and (grid/in-bounds { x: @nx, y: @ny } @config.gridWidth @config.gridHeight) (and (== (if (== @tile null) false (object/get @tile passable)) true) (== @occupied null)))
                        (object/merge @u { position: { x: @nx, y: @ny }, animation: "walk" })
                        @u))))))
            @u))))
        (set @entity.hp (if (> (array/len (array/filter @entity.enemies (fn u (and (> @u.health 0) (<= (grid/manhattan-distance (object/get @u position) { x: @payload.heroX, y: @payload.heroY }) 1))))) 0) (math/max 0 (- @entity.hp 1)) @entity.hp))
        (if (<= @entity.hp 0) (do (set @entity.combatResult "lost") (emit DEFEATED { id: "board" })) true)

      RESTART -> active
        (set @entity.enemies @config.enemies)
        (set @entity.hp @config.startHp)
        (set @entity.maxHp @config.startHp)
        (set @entity.combatScore 0)
        (set @entity.combatResult "none")
    }

    emits {
      BURST -> external {
        particles : [Fx]
      }
        @description "An enemy died from a bump-attack; a fx-particles listener spawns an explosion"
        @tier "domain"
      DEFEATED -> external {
        id : string
      }
        @description "Hero HP reached zero from monster contact damage"
        @tier "domain"
    }

    listens {
      ATTACK { targetId : string }
      MONSTER_TICK { heroX : number, heroY : number }
      RESTART { id : string }
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true, ATTACK/MONSTER_TICK intents are applied; toggle to freeze combat"
        @tier "domain"
      enemies : [Unit] = []
        @label "Initial Enemies"
        @description "Seed enemy roster"
        @tier "domain"
      startHp : number = 5
        @label "Start HP"
        @description "Hero HP set on INIT/RESTART (also used as maxHp)"
        @tier "domain"
      attackDamage : number = 1
        @label "Attack Damage"
        @description "Damage dealt to an enemy per bump-attack"
        @tier "domain"
      pointsPerKill : number = 50
        @label "Points Per Kill"
        @description "Score awarded when an enemy's health reaches zero"
        @tier "domain"
      tiles : [Tile] = []
        @label "Tiles"
        @description "Grid tiles used for enemy chase passability checks"
        @tier "domain"
      gridWidth : number = 12
        @label "Grid Width"
        @description "Grid column count clamping enemy chase bounds"
        @tier "domain"
      gridHeight : number = 9
        @label "Grid Height"
        @description "Grid row count clamping enemy chase bounds"
        @tier "domain"
    }
  }

  page "/dungeon-combat" as DungeonCombatPage -> DungeonCombat
}
