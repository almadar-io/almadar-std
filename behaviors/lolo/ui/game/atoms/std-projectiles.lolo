app std-projectiles "1.0.0"
"Headless projectile authority: sole writer of projectiles; moves by velocity, decays ttl, culls stragglers each tick."
orbital ProjectilesOrbital {
  type Projectile = {
    id : string!
    x : number!
    y : number!
    vx : number!
    vy : number!
    team : string
    ttl : number
  }

  entity ProjectileState [runtime, shared] {
    id : string!
    projectiles : [Projectile]
  }

  trait Projectiles -> @rebindable ProjectileState [lifecycle] {
    initial: active

    state active {
      INIT -> active
        (set @entity.projectiles @config.projectiles)

      FIRE -> active when @config.running
        (set @entity.projectiles (array/append @entity.projectiles { id: @payload.id, x: @payload.x, y: @payload.y, vx: @payload.vx, vy: @payload.vy, team: @payload.team, ttl: @payload.ttl }))
    }

    ticks {
      advanceTick every 100ms
        when @config.running
        (set @entity.projectiles (array/filter
          (array/map @entity.projectiles (fn p (object/merge @p { x: (+ (object/get @p x) (object/get @p vx)), y: (+ (object/get @p y) (object/get @p vy)), ttl: (if (== (object/get @p ttl) null) null (- (object/get @p ttl) 1)) })))
          (fn p (and (grid/in-bounds { x: (object/get @p x), y: (object/get @p y) } @config.gridWidth @config.gridHeight) (or (== (object/get @p ttl) null) (> (object/get @p ttl) 0))))))
    }

    listens {
      FIRE { id : string, x : number, y : number, vx : number, vy : number, team : string, ttl : number }
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true, FIRE intents are applied and the movement/cull tick advances; toggle to freeze projectiles"
        @tier "domain"
      projectiles : [Projectile] = []
        @label "Initial Projectiles"
        @description "Seed projectiles present before the first FIRE intent; usually empty"
        @tier "domain"
      gridWidth : number = 640
        @label "Bounds Width"
        @description "Arena width in pixels; projectiles outside this bound are culled"
        @tier "domain"
      gridHeight : number = 480
        @label "Bounds Height"
        @description "Arena height in pixels; projectiles outside this bound are culled"
        @tier "domain"
    }
  }

  page "/projectiles" as ProjectilesPage -> Projectiles
}
