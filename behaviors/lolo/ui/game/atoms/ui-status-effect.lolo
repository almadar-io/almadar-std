app ui-status-effect "1.0.0"
"StatusEffect — counts down duration every second; re-renders on each tick."
orbital StatusEffectOrbital {
  entity StatusEffectItem [runtime] {
    id       : string!
    duration : number = 30
  }

  trait StatusEffectRender -> @rebindable StatusEffectItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.duration @config.duration)
        (render-ui main {
          assetUrl: @config.assetUrl
          icon: @config.icon
          label: @config.label
          duration: @entity.duration
          stacks: @config.stacks
          variant: @config.variant
          size: @config.size
          className: @config.className
          type: status-effect
        })
    }

    ticks {
      durationTick every 1s
        when (> @entity.duration 0)
        (set @entity.duration (- @entity.duration 1))
        (render-ui main {
          assetUrl: @config.assetUrl
          icon: @config.icon
          label: @config.label
          duration: @entity.duration
          stacks: @config.stacks
          variant: @config.variant
          size: @config.size
          className: @config.className
          type: status-effect
        })
    }

    config {
      assetUrl : asset = "https://almadar-kflow-assets.web.app/shared/effects/fx-particle/kenney-vendored/particle/flame_01.png"
        @label "Asset Url"
        @description "Sprite image URL — takes precedence over icon when provided"
        @tier "presentation"
      icon : icon = "shield"
        @label "Icon"
        @description "Lucide icon name for the status effect"
        @tier "presentation"
      label : string = "Shield"
        @label "Label"
        @description "Label describing the effect"
        @tier "presentation"
      duration : number = 30
        @label "Duration"
        @description "Remaining duration in seconds"
        @tier "presentation"
      stacks : number = 0
        @label "Stacks"
        @description "Number of stacks"
        @tier "presentation"
      variant : "buff" | "debuff" | "neutral" = buff
        @label "Variant"
        @description "Effect type"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/status-effect" as StatusEffectPage -> StatusEffectRender
}
