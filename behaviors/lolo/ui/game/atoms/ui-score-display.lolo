app ui-score-display "1.0.0"
"ScoreDisplay — UI factory (1:1 with the @almadar/ui score-display pattern)."
orbital ScoreDisplayOrbital {
  type ScoreDisplayAssetUrl = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity ScoreDisplayItem [runtime] {
    id : string!
  }

  trait ScoreDisplayRender -> @rebindable ScoreDisplayItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          assetUrl: @config.assetUrl
          value: @config.value
          score: @config.score
          label: @config.label
          icon: @config.icon
          size: @config.size
          className: @config.className
          locale: @config.locale
          type: score-display
        })
    }

    config {
      assetUrl : ScoreDisplayAssetUrl = { url: "https://almadar-kflow-assets.web.app/shared/characters/archetypes/00_base_model.png", role: "decoration", category: "asset", animations: ["static"], style: "", dimension: "2d", aspect: "1:1", name: "asset", thumbnailUrl: "" }
        @label "Asset Url"
        @description "Sprite asset — takes precedence over icon when provided"
        @tier "presentation"
      value : number = 0
        @label "Value"
        @description "Current score value"
        @tier "presentation"
      score : number = 0
        @label "Score"
        @description "Alias for value — common schema binding name"
        @tier "presentation"
      label : string = "Label"
        @label "Label"
        @description "Label to display before score"
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Icon component or emoji"
        @tier "presentation"
      size : "sm" | "md" | "lg" | "xl" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      locale : string = "en-US"
        @label "Locale"
        @description "Number formatting locale"
        @tier "presentation"
    }
  }

  page "/score-display" as ScoreDisplayPage -> ScoreDisplayRender
}
