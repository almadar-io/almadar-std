app ui-xp-bar "1.0.0"
"XpBar — UI factory (1:1 with the @almadar/ui xp-bar pattern)."
orbital XpBarOrbital {
  entity XpBarItem [runtime] {
    id : string!
  }

  trait XpBarRender -> @rebindable XpBarItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          current: @config.current
          max: @config.max
          level: @config.level
          showLabel: @config.showLabel
          size: @config.size
          animated: @config.animated
          className: @config.className
          type: xp-bar
        })
    }

    config {
      current : number = 350
        @label "Current"
        @description "Current XP value"
        @tier "presentation"
      max : number = 1000
        @label "Max"
        @description "XP needed for next level"
        @tier "presentation"
      level : number = 5
        @label "Level"
        @description "Current level"
        @tier "presentation"
      showLabel : boolean = true
        @label "Show Label"
        @description "Whether to show the XP label"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      animated : boolean = true
        @label "Animated"
        @description "Animate the fill bar"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/xp-bar" as XpBarPage -> XpBarRender
}
