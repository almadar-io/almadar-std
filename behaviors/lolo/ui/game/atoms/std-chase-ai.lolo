app std-chase-ai "1.0.0"
"Headless chase-AI mechanic: enemies damage adjacent targets, else step toward the nearest target respecting tile passability and occupancy."
orbital ChaseAiOrbital {
  type Unit = {
    id : string!
    position : { x : number!  y : number! }
    x : number
    y : number
    z : number
    team : string
    health : number
    maxHealth : number
    unitType : string
  }
  type Tile = {
    id : string
    x : number!
    y : number!
    passable : boolean
  }
  type Fx = {
    id : string!
    type : string!
    x : number!
    z : number
    y : number
    message : string
    ttl : number!
  }

  entity ChaseState [runtime, shared] {
    id : string!
    units : [Unit]
  }

  trait ChaseAi -> @rebindable ChaseState [lifecycle] {
    initial: active

    state active {
      INIT -> active
        (set @entity.units @config.units)
    }

    ticks {
      chaseTick every 1s
        when @config.running
        (emit BURST { particles: (array/map (array/filter @entity.units (fn u (and (and (== @u.team "player") (> @u.health 0)) (> (array/len (array/filter @entity.units (fn e (and (and (== @e.team "enemy") (> @e.health 0)) (== (grid/manhattan-distance (object/get @e position) (object/get @u position)) 1))))) 0)))) (fn u { id: (str/concat "fx-ai-" @u.id), type: "hit", x: (object/get (object/get @u position) x), z: (object/get (object/get @u position) y), message: "-1", ttl: 3 })) })
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "player") (> @u.health 0)) (if (> (array/len (array/filter @entity.units (fn e (and (and (== @e.team "enemy") (> @e.health 0)) (== (grid/manhattan-distance (object/get @e position) (object/get @u position)) 1))))) 0) (object/merge @u { health: (math/max 0 (- @u.health 1)) }) @u) @u))))
        (set @entity.units (array/map @entity.units (fn u (if (and (== @u.team "enemy") (> @u.health 0)) (if (== (array/len (array/filter @entity.units (fn p (and (and (== @p.team "player") (> @p.health 0)) (== (grid/manhattan-distance (object/get @u position) (object/get @p position)) 1))))) 0) (let ((target (array/reduce (array/filter @entity.units (fn p (and (== @p.team "player") (> @p.health 0)))) null (fn nearest p (if (or (== @nearest null) (< (grid/manhattan-distance (object/get @p position) (object/get @u position)) (grid/manhattan-distance (object/get @nearest position) (object/get @u position)))) @p @nearest))))) (if (== @target null) @u (let ((nextX (math/clamp (+ (object/get (object/get @u position) x) (math/sign (- (object/get (object/get @target position) x) (object/get (object/get @u position) x)))) 0 (- @config.gridWidth 1))) (nextY (math/clamp (+ (object/get (object/get @u position) y) (math/sign (- (object/get (object/get @target position) y) (object/get (object/get @u position) y)))) 0 (- @config.gridHeight 1)))) (if (and (grid/in-bounds { x: @nextX, y: @nextY } @config.gridWidth @config.gridHeight) (and (== (object/get (array/find @config.tiles (fn t (and (== (object/get @t x) @nextX) (== (object/get @t y) @nextY)))) passable) true) (== (array/len (array/filter @entity.units (fn o (and (!= @o.id @u.id) (and (> @o.health 0) (and (== (object/get (object/get @o position) x) @nextX) (== (object/get (object/get @o position) y) @nextY))))))) 0))) (object/merge @u { position: { x: @nextX, y: @nextY } }) @u)))) @u) @u))))
        (emit UNITS_CHANGED { playersAlive: (array/len (array/filter @entity.units (fn u (and (== @u.team "player") (> @u.health 0))))), enemiesAlive: (array/len (array/filter @entity.units (fn u (and (== @u.team "enemy") (> @u.health 0))))) })
    }

    emits {
      BURST -> external {
        particles : [Fx]
      }
        @description "Fired each tick a target takes adjacency damage, carrying summarized hit particles"
        @tier "domain"
      UNITS_CHANGED -> external {
        playersAlive : number
        enemiesAlive : number
      }
        @description "Live team survivor counts after this tick's combat; a round-flow listener decides win/lose"
        @tier "domain"
    }

    config {
      running : boolean = true
        @label "Running"
        @description "When true the chase tick runs; toggle to freeze the mechanic"
        @tier "domain"
      units : [Unit] = []
        @label "Initial Units"
        @description "Seed units (players and enemies) present before the first tick"
        @tier "domain"
      tiles : [Tile] = []
        @label "Initial Tiles"
        @description "Seed grid tiles used for passability checks during movement"
        @tier "domain"
      gridWidth : number = 12
        @label "Grid Width"
        @description "Grid column count clamping enemy movement bounds"
        @tier "domain"
      gridHeight : number = 12
        @label "Grid Height"
        @description "Grid row count clamping enemy movement bounds"
        @tier "domain"
    }
  }

  page "/chase-ai" as ChaseAiPage -> ChaseAi
}
