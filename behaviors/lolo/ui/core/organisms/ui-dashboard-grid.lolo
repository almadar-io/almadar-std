app ui-dashboard-grid "1.0.0"
"DashboardGrid — UI factory (1:1 with the @almadar/ui dashboard-grid pattern)."
orbital DashboardGridOrbital {
  type DashboardGridError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type DashboardGridCellsItem = {
    id : string
    content : node
    colSpan : number
    rowSpan : number
  }

  entity DashboardGridItem [runtime] {
    id : string!
  }

  trait DashboardGridRender -> @rebindable DashboardGridItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch DashboardGridItem {})
        (render-ui main {
          entity: @entity
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          columns: @config.columns
          gap: @config.gap
          cells: @config.cells
          type: dashboard-grid
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : DashboardGridError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = ""
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = ""
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      columns : number = 3
        @label "Columns"
        @description "Number of columns"
        @tier "presentation"
      gap : "sm" | "md" | "lg" = md
        @label "Gap"
        @description "Gap between cells"
        @tier "presentation"
      cells : [DashboardGridCellsItem] = []
        @label "Cells"
        @description "Cell definitions"
        @tier "presentation"
    }
  }

  page "/dashboard-grid" as DashboardGridPage -> DashboardGridRender
}
