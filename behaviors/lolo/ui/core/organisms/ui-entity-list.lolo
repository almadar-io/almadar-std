app ui-entity-list "1.0.0"
"EntityList — UI factory (1:1 with the @almadar/ui entity-list pattern)."
orbital EntityListOrbital {
  type EntityListError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type EntityListFieldsItem = {
    key : string
    header : string
    name : string
    label : string
  }

  entity EntityListItem [runtime] {
    id : string!
  }

  trait EntityListRender -> @rebindable EntityListItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch EntityListItem {})
        (render-ui main {
          entity: @entity
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entityType: @config.entityType
          selectable: @config.selectable
          showDividers: @config.showDividers
          variant: @config.variant
          emptyMessage: @config.emptyMessage
          children: [{ content: "Sample content", type: text }]
          fields: @config.fields
          fieldNames: @config.fieldNames
          itemActions: [{ label: "View", event: VIEW }]
          type: entity-list
        })
      VIEW -> idle
        (emit VIEW {})
    }

    emits {
      ITEM_ACTIONS -> external {
        id : string
      }
        @description "Item actions - schema-driven or function-based"
        @tier "essential"
      VIEW -> external {
        id : string
      }
        @description "User opened a record from the list."
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : EntityListError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      entityType : string = "Entity Type"
        @label "Entity Type"
        @description "Entity type name for display"
        @tier "presentation"
      selectable : boolean = false
        @label "Selectable"
        @description "selectable prop"
        @tier "presentation"
      showDividers : boolean = false
        @label "Show Dividers"
        @description "showDividers prop"
        @tier "presentation"
      variant : "default" | "card" = default
        @label "Variant"
        @description "variant prop"
        @tier "presentation"
      emptyMessage : string = "Empty Message"
        @label "Empty Message"
        @description "emptyMessage prop"
        @tier "presentation"
      fields : [EntityListFieldsItem] = [{ key: "Key", header: "Header", name: "Name", label: "Label" }]
        @label "Fields"
        @description "Fields to display - accepts string[] or {key, header}[] for unified interface"
        @tier "presentation"
      fieldNames : [string] = []
        @label "Field Names"
        @description "Alias for fields - backwards compatibility"
        @tier "presentation"
    }
  }

  page "/entity-list" as EntityListPage -> EntityListRender
}
