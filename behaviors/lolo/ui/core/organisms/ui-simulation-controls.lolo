app ui-simulation-controls "1.0.0"
"SimulationControls — UI factory (1:1 with the @almadar/ui simulation-controls pattern)."
orbital SimulationControlsOrbital {
  entity SimulationControlsItem [runtime] {
    id : string!
  }

  trait SimulationControlsRender -> @rebindable SimulationControlsItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          running: @config.running
          speed: @config.speed
          parameters: @config.parameters
          onPlay: PLAY
          onPause: PAUSE
          onStep: STEP
          onReset: RESET
          onSpeedChange: SPEED_CHANGE
          onParameterChange: PARAMETER_CHANGE
          className: @config.className
          type: simulation-controls
        })
    }

    emits {
      PLAY -> external {
        id : string
      }
        @description "onPlay prop"
        @tier "essential"
      PAUSE -> external {
        id : string
      }
        @description "onPause prop"
        @tier "essential"
      STEP -> external {
        id : string
      }
        @description "onStep prop"
        @tier "essential"
      RESET -> external {
        id : string
      }
        @description "onReset prop"
        @tier "essential"
      SPEED_CHANGE -> external {
        speed : number
      }
        @description "onSpeedChange prop"
        @tier "essential"
      PARAMETER_CHANGE -> external {
        name : string
        value : number
      }
        @description "onParameterChange prop"
        @tier "essential"
    }

    config {
      running : boolean = false
        @label "Running"
        @description "running prop"
        @tier "presentation"
      speed : number = 0
        @label "Speed"
        @description "speed prop"
        @tier "presentation"
      parameters : json
        @label "Parameters"
        @description "parameters prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/simulation-controls" as SimulationControlsPage -> SimulationControlsRender
}
