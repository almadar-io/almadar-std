app ui-media-gallery "1.0.0"
"MediaGallery — UI factory (1:1 with the @almadar/ui media-gallery pattern)."
orbital MediaGalleryOrbital {
    type MediaGalleryLoaded = Event { data : [MediaGalleryItem] } "MediaGallery rows finished loading; payload.data holds the collection"
  type MediaGalleryError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type MediaGalleryItemsItem = {
    id : string
    src : asset
    alt : string
    thumbnail : asset
    mediaType : "image" | "video"
    caption : string
    fileSize : string
  }
  type MediaGalleryActionsItem = {
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
  }

  entity MediaGalleryItem [runtime] {
    id : string!
  }

  trait MediaGalleryRender -> @rebindable MediaGalleryItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch MediaGalleryItem { emit: { success: MediaGalleryLoaded } })
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          title: @config.title
          items: @config.items
          columns: @config.columns
          selectable: @config.selectable
          selectedItems: @config.selectedItems
          selectionEvent: @config.selectionEvent
          showUpload: @config.showUpload
          actions: @config.actions
          aspectRatio: @config.aspectRatio
          type: media-gallery
        })
      MediaGalleryLoaded -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @payload.data
          title: @config.title
          items: @config.items
          columns: @config.columns
          selectable: @config.selectable
          selectedItems: @config.selectedItems
          selectionEvent: @config.selectionEvent
          showUpload: @config.showUpload
          actions: @config.actions
          aspectRatio: @config.aspectRatio
          type: media-gallery
        })
    }

    emits {
      SELECTION -> external {
        selection : [object]!
      }
        @description "Event name emitted when selection changes (emitted as UI:{selectionEvent})"
        @tier "essential"
      MediaGalleryLoaded
        @description "MediaGallery rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : MediaGalleryError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      title : string = "Title"
        @label "Title"
        @description "Gallery title"
        @tier "presentation"
      items : [MediaGalleryItemsItem] = [{ id: "Id", src: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", alt: "Alt", thumbnail: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", mediaType: image, caption: "Caption", fileSize: "File Size" }, { id: "Id 2", src: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", alt: "Alt 2", thumbnail: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", mediaType: video, caption: "Caption 2", fileSize: "File Size 2" }]
        @label "Items"
        @description "Media items"
        @tier "presentation"
      columns : number = 3
        @label "Columns"
        @description "Column count"
        @tier "presentation"
      selectable : boolean = false
        @label "Selectable"
        @description "Enable item selection"
        @tier "presentation"
      selectedItems : [string] = []
        @label "Selected Items"
        @description "Selected item IDs"
        @tier "presentation"
      selectionEvent : string = "SELECTION"
        @label "Selection Event"
        @description "Event name emitted when selection changes (emitted as UI:{selectionEvent})"
        @tier "presentation"
      showUpload : boolean = false
        @label "Show Upload"
        @description "Show upload button"
        @tier "presentation"
      actions : [MediaGalleryActionsItem] = [{ label: "Label", navigatesTo: "Navigates To", variant: primary }, { label: "Label 2", navigatesTo: "Navigates To 2", variant: secondary }]
        @label "Actions"
        @description "Actions"
        @tier "presentation"
      aspectRatio : "square" | "landscape" | "portrait" = square
        @label "Aspect Ratio"
        @description "Aspect ratio for thumbnails"
        @tier "presentation"
    }
  }

  page "/media-gallery" as MediaGalleryPage -> MediaGalleryRender
}
