app ui-entity-table "1.0.0"
"EntityTable — UI factory (1:1 with the @almadar/ui entity-table pattern)."
orbital EntityTableOrbital {
    type EntityTableLoaded = Event { data : [EntityTableItem] } "EntityTable rows finished loading; payload.data holds the collection"
  type EntityTableError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type EntityTableFieldsItem = {
    key : string!
    header : string!
    name : string
    label : string
    width : string
    sortable : boolean
  }
  type EntityTableColumnsItem = {
    key : string!
    header : string!
    name : string
    label : string
    width : string
    sortable : boolean
  }
  type EntityTableItemActionsItem = {
    label : string!
    event : string
    navigatesTo : string
    action : string
    placement : "row" | "bulk"
    icon : icon
    variant : "default" | "primary" | "secondary" | "ghost" | "danger"
  }
  type EntityTableEmptyAction = {
    label : string!
    event : string
  }
  type EntityTableRowActionsItem = {
    label : string!
    icon : icon
    variant : "default" | "danger"
    event : string
  }
  type EntityTableBulkActionsItem = {
    label : string!
    icon : icon
    variant : "default" | "danger"
  }

  entity EntityTableItem [runtime] {
    id : string!
  }

  trait EntityTableRender -> @rebindable EntityTableItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch EntityTableItem { emit: { success: EntityTableLoaded } })
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          fields: @config.fields
          columns: @config.columns
          emptyIcon: @config.emptyIcon
          emptyTitle: @config.emptyTitle
          emptyDescription: @config.emptyDescription
          emptyAction: @config.emptyAction
          selectable: @config.selectable
          searchable: @config.searchable
          searchPlaceholder: @config.searchPlaceholder
          rowActions: @config.rowActions
          bulkActions: @config.bulkActions
          headerActions: @config.headerActions
          showTotal: @config.showTotal
          look: @config.look
          itemActions: [{ label: "View", event: VIEW }]
          type: entity-table
        })
      EntityTableLoaded -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @payload.data
          fields: @config.fields
          columns: @config.columns
          emptyIcon: @config.emptyIcon
          emptyTitle: @config.emptyTitle
          emptyDescription: @config.emptyDescription
          emptyAction: @config.emptyAction
          selectable: @config.selectable
          searchable: @config.searchable
          searchPlaceholder: @config.searchPlaceholder
          rowActions: @config.rowActions
          bulkActions: @config.bulkActions
          headerActions: @config.headerActions
          showTotal: @config.showTotal
          look: @config.look
          itemActions: [{ label: "View", event: VIEW }]
          type: entity-table
        })
      VIEW -> idle
        (emit VIEW {})
    }

    emits {
      VIEW -> external {
        id : string
      }
        @description "User opened a record from the list."
        @tier "essential"
      EntityTableLoaded
        @description "EntityTable rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : EntityTableError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      fields : [EntityTableFieldsItem] = [{ key: "Key", header: "Header", name: "Name", label: "Label", width: "Width", sortable: false }, { key: "Key 2", header: "Header 2", name: "Name 2", label: "Label 2", width: "Width 2", sortable: true }]
        @label "Fields"
        @description "Fields to display - accepts string[] or Column[] for unified interface. Alias for columns"
        @tier "presentation"
      columns : [EntityTableColumnsItem] = [{ key: "Key", header: "Header", name: "Name", label: "Label", width: "Width", sortable: false }, { key: "Key 2", header: "Header 2", name: "Name 2", label: "Label 2", width: "Width 2", sortable: true }]
        @label "Columns"
        @description "Columns can be Column objects or simple string field names"
        @tier "presentation"
      itemActions : [EntityTableItemActionsItem] = [{ label: "Label", navigatesTo: "Navigates To", action: "Action", placement: row, icon: "circle", variant: default }, { label: "Label 2", navigatesTo: "Navigates To 2", action: "Action 2", placement: bulk, icon: "circle", variant: primary }]
        @label "Item Actions"
        @description "Item actions from generated code - maps to rowActions"
        @tier "presentation"
      emptyIcon : icon
        @label "Empty Icon"
        @description "emptyIcon prop"
        @tier "presentation"
      emptyTitle : string = "Empty Title"
        @label "Empty Title"
        @description "emptyTitle prop"
        @tier "presentation"
      emptyDescription : string = "Empty Description"
        @label "Empty Description"
        @description "emptyDescription prop"
        @tier "presentation"
      emptyAction : EntityTableEmptyAction = { label: "Label" }
        @label "Empty Action"
        @description "emptyAction prop"
        @tier "presentation"
      selectable : boolean = false
        @label "Selectable"
        @description "Selection"
        @tier "presentation"
      searchable : boolean = false
        @label "Searchable"
        @description "Search"
        @tier "presentation"
      searchPlaceholder : string = "Search Placeholder"
        @label "Search Placeholder"
        @description "searchPlaceholder prop"
        @tier "presentation"
      rowActions : [EntityTableRowActionsItem] = []
        @label "Row Actions"
        @description "Row actions"
        @tier "presentation"
      bulkActions : [EntityTableBulkActionsItem] = []
        @label "Bulk Actions"
        @description "Bulk actions"
        @tier "presentation"
      headerActions : node
        @label "Header Actions"
        @description "Header actions"
        @tier "presentation"
      showTotal : boolean = true
        @label "Show Total"
        @description "Show total count in pagination"
        @tier "presentation"
      look : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Look"
        @description "Layer 2 visual treatment — orthogonal to the semantic variant."
        @tier "presentation"
    }
  }

  page "/entity-table" as EntityTablePage -> EntityTableRender
}
