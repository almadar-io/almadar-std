app ui-transition-arrow "1.0.0"
"TransitionArrow — UI factory (1:1 with the @almadar/ui transition-arrow pattern)."
orbital TransitionArrowOrbital {
  type TransitionArrowFrom = {
    x : number!
    y : number!
  }
  type TransitionArrowTo = {
    x : number!
    y : number!
  }

  entity TransitionArrowItem [runtime] {
    id : string!
  }

  trait TransitionArrowRender -> @rebindable TransitionArrowItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          from: @config.fromProp
          to: @config.toProp
          eventLabel: @config.eventLabel
          guardHint: @config.guardHint
          isActive: @config.isActive
          onClick: CLICK
          className: @config.className
          type: transition-arrow
        })
    }

    emits {
      CLICK -> external {
        id : string
      }
        @description "Click handler"
        @tier "essential"
    }

    config {
      fromProp : TransitionArrowFrom = { x: 0, y: 0 }
        @label "From"
        @description "Start position (center of from-node)"
        @synonyms "from"
        @tier "presentation"
      toProp : TransitionArrowTo = { x: 0, y: 0 }
        @label "To"
        @description "End position (center of to-node)"
        @synonyms "to"
        @tier "presentation"
      eventLabel : string = ""
        @label "Event Label"
        @description "Event label shown on the arrow"
        @tier "presentation"
      guardHint : string = ""
        @label "Guard Hint"
        @description "Guard hint shown below event"
        @tier "presentation"
      isActive : boolean = false
        @label "Is Active"
        @description "Whether this transition is currently active"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes for the SVG group"
        @tier "presentation"
    }
  }

  page "/transition-arrow" as TransitionArrowPage -> TransitionArrowRender
}
