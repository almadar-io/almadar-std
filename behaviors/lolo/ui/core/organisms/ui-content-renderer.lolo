app ui-content-renderer "1.0.0"
"ContentRenderer — UI factory (1:1 with the @almadar/ui content-renderer pattern)."
orbital ContentRendererOrbital {
  entity ContentRendererItem [runtime] {
    id : string!
  }

  trait ContentRendererRender -> @rebindable ContentRendererItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ContentRendererItem {})
        (render-ui main {
          entity: @entity
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          content: @config.content
          segments: @config.segments
          direction: @config.direction
          type: content-renderer
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : json
        @label "Error"
        @description "Error state"
        @tier "presentation"
      sortBy : string = ""
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : string = ""
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = ""
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [json] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      content : string = ""
        @label "Content"
        @description "Raw content string — auto-parsed into segments"
        @tier "presentation"
      segments : [json] = []
        @label "Segments"
        @description "Pre-parsed segments (overrides content)"
        @tier "presentation"
      direction : "rtl" | "ltr" = rtl
        @label "Direction"
        @description "Text direction for markdown"
        @tier "presentation"
    }
  }

  page "/content-renderer" as ContentRendererPage -> ContentRendererRender
}
