app ui-detail-panel "1.0.0"
"DetailPanel — UI factory (1:1 with the @almadar/ui detail-panel pattern)."
orbital DetailPanelOrbital {
  type DetailPanelError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type DetailPanelStatus = {
    label : string!
    variant : "default" | "success" | "warning" | "danger" | "info"
  }
  type DetailPanelSectionsItem = {
    title : string!
    fields : [DetailPanelSectionsItemFieldsItem]!
  }
  type DetailPanelSectionsItemFieldsItem = {
    label : string!
    value : node!
    icon : icon
    copyable : boolean
  }
  type DetailPanelActionsItem = {
    label : string!
    icon : icon
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost" | "danger"
  }
  type DetailPanelFieldsItem = {
    key : string
    header : string
    name : string
    label : string
  }

  entity DetailPanelItem [runtime] {
    id : string!
  }

  trait DetailPanelRender -> @rebindable DetailPanelItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch DetailPanelItem {})
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          title: @config.title
          subtitle: @config.subtitle
          status: @config.status
          avatar: @config.avatar
          sections: @config.sections
          actions: @config.actions
          footer: @config.footer
          slideOver: @config.slideOver
          fields: @config.fields
          fieldNames: @config.fieldNames
          initialData: @config.initialData
          mode: @config.mode
          position: @config.position
          width: @config.width
          displayFields: @config.displayFields
          showActions: @config.showActions
          type: detail-panel
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : DetailPanelError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      title : string = "Title"
        @label "Title"
        @description "title prop"
        @tier "presentation"
      subtitle : string = "Subtitle"
        @label "Subtitle"
        @description "subtitle prop"
        @tier "presentation"
      status : DetailPanelStatus
        @label "Status"
        @description "status prop"
        @tier "presentation"
      avatar : node
        @label "Avatar"
        @description "avatar prop"
        @tier "presentation"
      sections : [DetailPanelSectionsItem] = [{ title: "Title", fields: [{ label: "Label", value: "Value", icon: "circle", copyable: false }] }]
        @label "Sections"
        @description "sections prop"
        @tier "presentation"
      actions : [DetailPanelActionsItem] = [{ label: "Label", icon: "circle", navigatesTo: "Navigates To", variant: primary }]
        @label "Actions"
        @description "Unified actions array - first action with variant='primary' is the main action"
        @tier "presentation"
      footer : node
        @label "Footer"
        @description "footer prop"
        @tier "presentation"
      slideOver : boolean = false
        @label "Slide Over"
        @description "slideOver prop"
        @tier "presentation"
      fields : [DetailPanelFieldsItem] = [{ key: "Key", header: "Header", name: "Name", label: "Label" }]
        @label "Fields"
        @description "Fields to display - accepts string[], {key, header}[], or DetailField[]"
        @tier "presentation"
      fieldNames : [string] = []
        @label "Field Names"
        @description "Alias for fields - backwards compatibility"
        @tier "presentation"
      initialData : json
        @label "Initial Data"
        @description "Initial data for edit mode (passed by compiler)"
        @tier "presentation"
      mode : string = "Mode"
        @label "Mode"
        @description "Display mode (passed by compiler)"
        @tier "presentation"
      position : "left" | "right" = left
        @label "Position"
        @description "Panel position (for drawer/sidebar placement)"
        @tier "presentation"
      width : string = "Width"
        @label "Width"
        @description "Panel width (CSS value, e.g., '400px', '50%')"
        @tier "presentation"
      displayFields : [string] = []
        @label "Display Fields"
        @description "Display fields (alias for fields)"
        @tier "presentation"
      showActions : boolean = false
        @label "Show Actions"
        @description "Show actions flag"
        @tier "presentation"
    }
  }

  page "/detail-panel" as DetailPanelPage -> DetailPanelRender
}
