app ui-svg-node "1.0.0"
"SvgNode — UI factory (1:1 with the @almadar/ui svg-node pattern)."
orbital SvgNodeOrbital {
  entity SvgNodeItem [runtime] {
    id : string!
  }

  trait SvgNodeRender -> @rebindable SvgNodeItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          x: @config.x
          y: @config.y
          r: @config.r
          variant: @config.variant
          color: @config.color
          opacity: @config.opacity
          className: @config.className
          label: @config.label
          asRoot: @config.asRoot
          width: @config.width
          height: @config.height
          type: svg-node
        })
    }

    config {
      x : number = 50
        @label "X"
        @description "x prop"
        @tier "presentation"
      y : number = 50
        @label "Y"
        @description "y prop"
        @tier "presentation"
      r : number = 6
        @label "R"
        @description "r prop"
        @tier "presentation"
      variant : "filled" | "stroked" | "pulse" = filled
        @label "Variant"
        @description "variant prop"
        @tier "presentation"
      color : string = "var(--color-primary)"
        @label "Color"
        @description "color prop"
        @tier "presentation"
      opacity : number = 1
        @label "Opacity"
        @description "opacity prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
      label : string = ""
        @label "Label"
        @description "label prop"
        @tier "presentation"
      asRoot : boolean = true
        @label "As Root"
        @description "When true (default), wraps in a standalone <svg> so the shape is visible without a parent SVG context."
        @tier "presentation"
      width : number = 100
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 100
        @label "Height"
        @description "height prop"
        @tier "presentation"
    }
  }

  page "/svg-node" as SvgNodePage -> SvgNodeRender
}
