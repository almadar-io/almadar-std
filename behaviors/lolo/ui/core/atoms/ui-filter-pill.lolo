app ui-filter-pill "1.0.0"
"FilterPill — UI factory (1:1 with the @almadar/ui filter-pill pattern)."
orbital FilterPillOrbital {
  entity FilterPillItem [runtime] {
    id : string!
    label : string = "Label"
  }

  trait FilterPillRender -> @rebindable FilterPillItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.label @config.label)
        (render-ui main {
          className: @config.className
          variant: @config.variant
          size: @config.size
          label: @entity.label
          icon: @config.icon
          onRemove: @config.onRemove
          removable: @config.removable
          onClick: @config.onClick
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          type: filter-pill
        })
      REMOVE -> idle
        (set @entity.label ?label)
        (render-ui main {
          className: @config.className
          variant: @config.variant
          size: @config.size
          label: @entity.label
          icon: @config.icon
          onRemove: @config.onRemove
          removable: @config.removable
          onClick: @config.onClick
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          type: filter-pill
        })
      CLICK -> idle
        (set @entity.label ?label)
        (render-ui main {
          className: @config.className
          variant: @config.variant
          size: @config.size
          label: @entity.label
          icon: @config.icon
          onRemove: @config.onRemove
          removable: @config.removable
          onClick: @config.onClick
          clickEvent: @config.clickEvent
          removeEvent: @config.removeEvent
          type: filter-pill
        })
    }

    emits {
      REMOVE -> external {
        label : string!
      }
        @description "Called when the user clicks the remove (×) button"
        @tier "essential"
      CLICK -> external {
        label : string!
      }
        @description "Click handler for the body of the pill (filter toggle)"
        @tier "essential"
    }

    listens {
      REMOVE {
        label : string!
      }
      CLICK {
        label : string!
      }
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes applied to the root element."
        @tier "presentation"
      variant : "default" | "primary" | "secondary" | "success" | "warning" | "danger" | "info" | "neutral" = default
        @label "Variant"
        @description "variant prop"
        @tier "presentation"
      size : "sm" | "md" | "lg" = sm
        @label "Size"
        @description "size prop"
        @tier "presentation"
      label : string = "Label"
        @label "Label"
        @description "Pill label text (alternative to children for schema-driven rendering)."
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Lucide icon component or canonical kebab-case icon name string"
        @tier "presentation"
      onRemove : string = "REMOVE"
        @label "On Remove"
        @description "Called when the user clicks the remove (×) button"
        @tier "presentation"
      removable : boolean = true
        @label "Removable"
        @description "Disable the remove button (renders without × control)"
        @tier "presentation"
      onClick : string = "CLICK"
        @label "On Click"
        @description "Click handler for the body of the pill (filter toggle)"
        @tier "presentation"
      clickEvent : string = "CLICK"
        @label "Click Event"
        @description "Event name dispatched via event bus when the pill body is clicked. Payload: { label }"
        @tier "presentation"
      removeEvent : string = "REMOVE"
        @label "Remove Event"
        @description "Event name dispatched via event bus when the remove (×) button is clicked. Payload: { label }"
        @tier "presentation"
    }
  }

  page "/filter-pill" as FilterPillPage -> FilterPillRender
}
