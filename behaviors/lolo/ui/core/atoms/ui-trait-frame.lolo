app ui-trait-frame "1.0.0"
"TraitFrame — UI factory (1:1 with the @almadar/ui trait-frame pattern)."
orbital TraitFrameOrbital {
  entity TraitFrameItem [runtime] {
    id : string!
  }

  trait TraitFrameRender -> @rebindable TraitFrameItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          traitName: @config.traitName
          fallback: [{ content: "Fallback", type: typography }]
          type: trait-frame
        })
    }

    config {
      traitName : string = "Trait Name"
        @label "Trait Name"
        @description "Name of the trait whose current frame to embed. Must match a trait declared in the current orbital. Compiler validates that the name exists at build time (see `ORB_BINDING_TRAIT_UNKNOWN`)."
        @tier "presentation"
    }
  }

  page "/trait-frame" as TraitFramePage -> TraitFrameRender
}
