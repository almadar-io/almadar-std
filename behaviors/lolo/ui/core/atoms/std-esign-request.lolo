app std-esign-request "1.1.0"
"std-esign-request — specialized e-signature request tracker: send a document out for signing and track its status (draft/sent/viewed/signed/declined/expired). Just the request list + send/revoke; signature capture is std-signature-capture's job."
orbital ESignRequestOrbital {
    type ESignRequestLoaded = Event { data : [ESignRequest] }

    type ESignRequestLoadFailed = Event { error : string, code : string }

  entity ESignRequest [persistent: esignrequests] {
    id : string!
    documentId : string! @description "Unique identifier for the associated document." @synonyms "document reference, file ID"
    documentName : string @description "The name of the document being requested for signature." @synonyms "filename, document title, file name" = ""
    recipientName : string! @description "The name of the recipient for the e-signature request." @synonyms "recipient, name, user"
    recipientEmail : string! @description "The email address of the recipient." @synonyms "email, address, contact"
    status : "draft" | "sent" | "viewed" | "signed" | "declined" | "expired" @description "The current stage of the request lifecycle." @synonyms "state, condition, phase" = draft
    sentAt : string @description "Timestamp indicating when the request was sent." @synonyms "sent date, send time, dispatched at" = ""
    signedAt : string @description "Timestamp indicating when the request was signed." @synonyms "signed date, signature date, completion date" = ""
    expiresAt : string @description "The date and time when the request is no longer valid." @synonyms "expiration, expiry, due date" = ""
    notes : string @description "Free-text comments or additional information." @synonyms "comment, remark, description, details" = ""
  }

  uses Typography from "std/behaviors/ui-typography"
  uses DataGrid from "std/behaviors/ui-data-grid"
  uses Alert from "std/behaviors/ui-alert"

  trait TitleHeading = Typography.traits.TypographyRender -> ESignRequest {
    config {
      content: @config.title
      variant: h3
    }
  }

  trait RequestDataGrid = DataGrid.traits.DataGridRender -> ESignRequest {
    config {
      entity: ?data
      fields: [{
        label: Document
        name: documentName
        variant: h4
      }, {
        label: Recipient
        name: recipientName
        variant: body
      }, {
        label: Email
        name: recipientEmail
        variant: caption
      }, {
        label: Status
        name: status
        variant: badge
      }, {
        label: Sent
        name: sentAt
        variant: caption
      }]
      look: @config.tableLook
    }
  }

  trait ErrorAlert = Alert.traits.AlertRender -> ESignRequest {
    config {
      message: "Failed to load signature requests"
      title: "Failed to load signature requests"
      variant: error
    }
  }

  trait ESignRequestSigning -> ESignRequest [interaction, collection] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch ESignRequest {
          emit: { failure: ESignRequestLoadFailed, success: ESignRequestLoaded }
        })
        (render-ui main { size: md, type: spinner })
      ESignRequestLoaded -> browsing
        (render-ui main {
          children: [@trait.TitleHeading, @trait.RequestDataGrid]
          direction: vertical
          gap: md
          type: stack
        })
      ESignRequestLoadFailed -> error
        (render-ui main {
          children: [@trait.ErrorAlert]
          type: box
        })
    }

    state browsing {
      SEND_REQUEST -> browsing
        (set @entity.id ?id)
        (notify "Signature request sent" success)
      REVOKE_REQUEST -> browsing
        (set @entity.id ?id)
        (notify "Signature request revoked" info)
    }

    state error {
      INIT -> loading
        (fetch ESignRequest {
          emit: { failure: ESignRequestLoadFailed, success: ESignRequestLoaded }
        })
        (render-ui main { size: md, type: spinner })
    }

    emits {
      SEND_REQUEST {
        id : string!
      }
        @description "Signals a request has been sent for signature."
        @synonyms "dispatch, submit, transmit"
        @tier "domain"
      REVOKE_REQUEST {
        id : string!
      }
        @description "Indicates a signature request has been cancelled."
        @synonyms "cancel, void, retract"
        @tier "presentation"
      ESignRequestLoaded {
        data : [ESignRequest]
      }
        @description "Signals that the request list has been successfully populated."
        @synonyms "loaded, refreshed, populated, initialized"
        @tier "domain"
      ESignRequestLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load e-signature request data."
        @synonyms "error, failure, load error"
        @tier "internal"
    }

    listens {
      SEND_REQUEST {
        id : string!
      }
        @description "A request has been sent for signature."
        @synonyms "submitted, dispatched, transmitted"
        @tier "domain"
      REVOKE_REQUEST {
        id : string!
      }
        @description "A request is cancelled or withdrawn."
        @synonyms "cancel, withdraw, void, remove"
        @tier "presentation"
      ESignRequestLoaded {
        data : [ESignRequest]
      }
        @description "Indicates the request list has been populated."
        @synonyms "loaded, refreshed, initialized"
        @tier "domain"
      ESignRequestLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load e-signature requests."
        @synonyms "error, failure, problem, issue"
        @tier "internal"
    }

    config {
      title : string = "Signature Requests"
        @label "Section title"
        @description "Heading shown above the signature-request list"
        @tier "presentation"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
    }
  }

  page "/esign" as ESignRequestPage -> ESignRequestSigning
}