app std-export "3.0.0"
"std-export — a dropdown format menu (CSV/XLSX/PDF defaults; caller can override via config.formats). Emits EXPORT_REQUESTED { itemId, label } on the bus — itemId is the picked format id; host or sibling orbital generates the file. tileId is a static per-instance config value, not echoed in the click payload."
orbital ExportOrbital {
    uses Button from "std/behaviors/ui-button"
    uses Menu from "std/behaviors/ui-menu"

    type FormatOption = { id : string!, format : string!, label : string!, event : string }

  entity ExportPanel [runtime] {
    id : string!
  }

  trait Button1 = Button.traits.ButtonRender -> ExportPanel {
    config {
      action: OPEN_EXPORT
      icon: download
      label: @config.buttonLabel
      size: sm
      variant: ghost
    }
  }

  trait Menu1 = Menu.traits.MenuRender -> ExportPanel {
    config {
      items: @config.formats
      position: bottom-start
      trigger: [@trait.Button1]
    }
  }

  trait ExportMenu -> ExportPanel [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main { children: [@trait.Menu1], type: box })
      OPEN_EXPORT -> idle
      EXPORT_REQUESTED -> idle
    }

    emits {
      EXPORT_REQUESTED -> external {
        itemId : string!
        label : string!
      }
        @description "Requests export of data in the picked format. itemId is the format id (matches the FormatOption.id/format of the picked entry)."
        @synonyms "export, save, download, generate"
        @tier "domain"
    }

    listens {
      EXPORT_REQUESTED {
        itemId : string!
        label : string!
      }
        @description "A request to export data in a specific format. itemId is the picked format id."
        @synonyms "export, generate, save, download"
        @tier "domain"
    }

    config {
      tileId : string = ""
        @label "Tile id"
        @description "Identifier of the dashboard tile being exported"
        @synonyms "internal identifier — host orbital wires this; users rarely set it directly"
        @tier "internal"
      event : string = EXPORT_REQUESTED
        @label "Export event"
        @description "Event emitted when the user picks a format. Each entry in formats[] carries its own literal event field (no per-item templating in .lolo) — overriding this alone does not retarget the click; also set formats[].event to match."
        @synonyms "bus event name. internal wiring; users rarely target directly"
        @tier "internal"
      formats : [FormatOption] = [{
        event: EXPORT_REQUESTED
        format: csv
        id: csv
        label: CSV
      }, {
        event: EXPORT_REQUESTED
        format: xlsx
        id: xlsx
        label: XLSX
      }, {
        event: EXPORT_REQUESTED
        format: pdf
        id: pdf
        label: PDF
      }]
        @label "Available formats"
        @description "Export formats shown to the user in the popover"
        @synonyms "list of export format entries (csv / xlsx / pdf / png / json). user phrases: 'only CSV' -> keep only csv entry; 'add JSON' -> append json entry; 'no PNG' -> remove png; 'allow X and Y' -> set the array to those two"
        @tier "presentation"
      buttonLabel : string = Export
        @label "Button label"
        @description "Text shown on the toolbar button that opens the export popover"
        @synonyms "the text on the export trigger button. user phrases: 'rename export button to X' / 'set the button label to X' / 'call the button X' / 'change export button text to X' -> X (e.g. 'Download CSV', 'Download', 'Export Data')"
        @tier "presentation"
    }
  }

  page "/exports/menu" as ExportMenuPage -> ExportMenu, Button1, Menu1
}