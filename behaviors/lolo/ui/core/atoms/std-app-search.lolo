app std-app-search "1.0.0"
"std-app-search — reusable global search: wraps a host content view and, on a SEARCH trigger, fetches the linked entity filtered by @config.searchField and renders the matching results, then CLEAR_SEARCH returns to the host view. Rebind to any entity; point @config.idleContent at the normal view and wire a trigger (e.g. AppLayout SEARCH) into SEARCH."
type AppSearchFieldSpec = { event : string, label : string, variant : string, icon : string, href : string, payload : string, disabled : boolean, confirm : string, hidden : boolean, format : string }
type AppSearchActionSpec = { label : string!, event : string!, variant : string, icon : string, href : string, payload : string, disabled : boolean, confirm : string, hidden : boolean }
orbital AppSearchOrbital {
  type AppSearchLoaded = Event { data : [AppSearchTarget] } "Filtered search results loaded"
  type AppSearchFailed = Event { error : string } "Search fetch failed"

  entity AppSearchTarget [runtime] {
    id : string!
    name : string @description "The primary human-readable label matched by search." @synonyms "title, label, productName"
    searchTerm : string @intrinsic @description "The current search query the user submitted." @synonyms "query, term, q" = ""
  }

  trait AppSearch -> @rebindable AppSearchTarget [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch AppSearchTarget {})
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          children: [@config.idleContent]
        })
      APP_SEARCH -> searching
        (set @entity.searchTerm ?value)
        (fetch AppSearchTarget {
          filter: (or ["=", ?value, ""] (str/includes (object/get @entity @config.searchField) ?value))
          emit: { success: AppSearchLoaded, failure: AppSearchFailed }
        })
        (render-ui main {
          type: stack
          align: center
          direction: vertical
          gap: md
          className: "py-12"
          children: [{ type: spinner }, {
            type: typography
            variant: caption
            color: muted
            content: "Searching…"
          }]
        })
    }

    state searching {
      APP_SEARCH -> searching
        (set @entity.searchTerm ?value)
        (fetch AppSearchTarget {
          filter: (or ["=", ?value, ""] (str/includes (object/get @entity @config.searchField) ?value))
          emit: { success: AppSearchLoaded, failure: AppSearchFailed }
        })
        (render-ui main {
          type: stack
          align: center
          direction: vertical
          gap: md
          className: "py-12"
          children: [{ type: spinner }, {
            type: typography
            variant: caption
            color: muted
            content: "Searching…"
          }]
        })
      AppSearchLoaded -> results
        (render-ui main {
          type: stack
          direction: vertical
          gap: lg
          className: "max-w-6xl mx-auto w-full p-4"
          children: [{
            type: stack
            direction: horizontal
            gap: sm
            justify: between
            align: center
            children: [{ type: icon, name: search }, {
              type: typography
              variant: h2
              content: @config.resultsTitle
            }, {
              type: button
              variant: ghost
              icon: x
              label: "Clear search"
              action: CLEAR_SEARCH
            }]
          }, {
            type: typography
            variant: caption
            color: muted
            content: "Matching “@entity.searchTerm”"
          }, { type: divider }, {
            type: data-grid
            entity: @payload.data
            fields: @config.resultFields
            itemActions: @config.resultActions
          }]
        })
      AppSearchFailed -> idle
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          children: [{
            type: alert
            variant: error
            message: ?error
          }, @config.idleContent]
        })
    }

    state results {
      APP_SEARCH -> searching
        (set @entity.searchTerm ?value)
        (fetch AppSearchTarget {
          filter: (or ["=", ?value, ""] (str/includes (object/get @entity @config.searchField) ?value))
          emit: { success: AppSearchLoaded, failure: AppSearchFailed }
        })
        (render-ui main {
          type: stack
          align: center
          direction: vertical
          gap: md
          className: "py-12"
          children: [{ type: spinner }, {
            type: typography
            variant: caption
            color: muted
            content: "Searching…"
          }]
        })
      CLEAR_SEARCH -> idle
        (set @entity.searchTerm "")
        (render-ui main {
          type: stack
          direction: vertical
          gap: md
          children: [@config.idleContent]
        })
    }

    emits {
      AppSearchLoaded
      AppSearchFailed
    }

    listens {
      APP_SEARCH {
        value : string
      }
        @description "A search query was submitted (e.g. from the AppLayout top-bar search)."
        @synonyms "query, find, lookup"
        @tier "domain"
      AppSearchFailed {
        error : string
      }
    }

    config {
      idleContent : trait
        @label "Idle content"
        @description "The normal content view (e.g. the data ledger/browse trait) shown when no search is active."
        @tier "presentation"
      searchField : string = name
        @label "Search field"
        @description "Entity field matched against the query (case-insensitive substring)."
        @tier "presentation"
      resultsTitle : string = "Search results"
        @label "Results title"
        @description "Heading shown above the search-results grid."
        @tier "presentation"
      resultFields : [AppSearchFieldSpec] = [{
        label: Name
        name: name
        variant: h4
      }]
        @label "Result columns"
        @description "Columns shown in the search-results grid; maps entity fields to display cells."
        @tier "presentation"
      resultActions : [AppSearchActionSpec] = []
        @label "Result row actions"
        @description "Optional per-row actions on a result, e.g. { label: \"View Details\", event: \"VIEW\" }."
        @tier "presentation"
    }
  }

  page "/app-search" as AppSearchPage -> AppSearch
}
