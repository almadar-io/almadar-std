app ui-text-highlight "1.0.0"
"TextHighlight — UI factory (1:1 with the @almadar/ui text-highlight pattern)."
orbital TextHighlightOrbital {
  entity TextHighlightItem [runtime] {
    id : string!
  }

  trait TextHighlightRender -> @rebindable TextHighlightItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          highlightType: @config.highlightType
          isActive: @config.isActive
          onClick: @config.onClick
          onMouseEnter: @config.onMouseEnter
          onMouseLeave: @config.onMouseLeave
          annotationId: @config.annotationId
          className: @config.className
          children: @config.children
          action: @config.action
          hoverEvent: @config.hoverEvent
          type: text-highlight
        })
    }

    emits {
      @config.onClick -> external {
        id : string
      }
        @description "Callback when highlight is clicked"
        @tier "essential"
      @config.onMouseEnter -> external {
        id : string
      }
        @description "Callback when highlight is hovered"
        @tier "essential"
      @config.onMouseLeave -> external {
        id : string
      }
        @description "Callback when hover ends"
        @tier "essential"
      @config.action -> external {
        id : string
      }
        @description "Declarative event name — emits UI:{action} via eventBus on click"
        @tier "essential"
      @config.hoverEvent -> external {
        id : string
      }
        @description "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }"
        @tier "essential"
    }

    config {
      highlightType : "question" | "note" = question
        @label "Highlight Type"
        @description "Type of highlight (determines color)"
        @tier "presentation"
      isActive : boolean = false
        @label "Is Active"
        @description "Whether the highlight is currently active/focused"
        @tier "presentation"
      onClick : string = "CLICK"
        @label "On Click"
        @description "Callback when highlight is clicked"
        @tier "presentation"
      onMouseEnter : string = "MOUSE_ENTER"
        @label "On Mouse Enter"
        @description "Callback when highlight is hovered"
        @tier "presentation"
      onMouseLeave : string = "MOUSE_LEAVE"
        @label "On Mouse Leave"
        @description "Callback when hover ends"
        @tier "presentation"
      annotationId : string
        @label "Annotation Id"
        @description "Unique ID for the annotation"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      children : node
        @label "Children"
        @description "Highlighted text content"
        @tier "presentation"
      action : string = "ACTION"
        @label "Action"
        @description "Declarative event name — emits UI:{action} via eventBus on click"
        @tier "presentation"
      hoverEvent : string = "HOVER"
        @label "Hover Event"
        @description "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }"
        @tier "presentation"
    }
  }

  page "/text-highlight" as TextHighlightPage -> TextHighlightRender
}
