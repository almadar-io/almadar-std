app ui-vstack "1.0.0"
"Vstack — UI factory (1:1 with the @almadar/ui vstack pattern)."
orbital VstackOrbital {
  entity VstackItem [runtime] {
    id : string!
  }

  trait VstackRender -> @rebindable VstackItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: vstack
        })
    }
  }

  page "/vstack" as VstackPage -> VstackRender
}
