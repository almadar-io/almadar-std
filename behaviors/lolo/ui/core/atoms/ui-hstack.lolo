app ui-hstack "1.0.0"
"Hstack — UI factory (1:1 with the @almadar/ui hstack pattern)."
orbital HstackOrbital {
  entity HstackItem [runtime] {
    id : string!
  }

  trait HstackRender -> @rebindable HstackItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          gap: @config.gap
          align: @config.align
          justify: @config.justify
          wrap: @config.wrap
          reverse: @config.reverse
          flex: @config.flex
          className: @config.className
          style: @config.style
          children: @config.children
          role: @config.role
          tabIndex: @config.tabIndex
          action: @config.action
          actionPayload: @config.actionPayload
          responsive: @config.responsive
          type: hstack
        })
    }

    emits {
      @config.action -> external {
        id : string
      }
        @description "Declarative event name — emits UI:{action} via eventBus on click"
        @tier "essential"
    }

    config {
      gap : "none" | "xs" | "sm" | "md" | "lg" | "xl" | "2xl" = md
        @label "Gap"
        @description "Gap between children"
        @tier "presentation"
      align : "start" | "center" | "end" | "stretch" | "baseline" = stretch
        @label "Align"
        @description "Align items on the cross axis"
        @tier "presentation"
      justify : "start" | "center" | "end" | "between" | "around" | "evenly" = start
        @label "Justify"
        @description "Justify items on the main axis"
        @tier "presentation"
      wrap : boolean = false
        @label "Wrap"
        @description "Allow items to wrap"
        @tier "presentation"
      reverse : boolean = false
        @label "Reverse"
        @description "Reverse the order of children"
        @tier "presentation"
      flex : boolean = false
        @label "Flex"
        @description "Fill available space (flex: 1)"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Custom class name"
        @tier "presentation"
      style : json = {}
        @label "Style"
        @description "Inline styles"
        @tier "presentation"
      children : node = [{ content: "Sample content", type: typography }]
        @label "Children"
        @description "Children elements"
        @tier "presentation"
      role : string = "Role"
        @label "Role"
        @description "Role for accessibility"
        @tier "presentation"
      tabIndex : number = 0
        @label "Tab Index"
        @description "Tab index for focus management"
        @tier "presentation"
      action : string = "ACTION"
        @label "Action"
        @description "Declarative event name — emits UI:{action} via eventBus on click"
        @tier "presentation"
      actionPayload : json = {}
        @label "Action Payload"
        @description "Payload to include with the action event"
        @tier "presentation"
      responsive : boolean = false
        @label "Responsive"
        @description "When true, horizontal stacks flip to vertical below the md breakpoint (768px)"
        @tier "presentation"
    }
  }

  page "/hstack" as HstackPage -> HstackRender
}
