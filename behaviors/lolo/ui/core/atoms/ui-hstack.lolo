app ui-hstack "1.0.0"
"Hstack — UI factory (1:1 with the @almadar/ui hstack pattern)."
orbital HstackOrbital {
  entity HstackItem [runtime] {
    id : string!
  }

  trait HstackRender -> @rebindable HstackItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          type: hstack
        })
    }
  }

  page "/hstack" as HstackPage -> HstackRender
}
