app ui-button "1.0.0"
"Button — UI factory (1:1 with the @almadar/ui button pattern)."
orbital ButtonOrbital {
  type ButtonIconAsset = {
    url : asset!
    role : string
    category : string
    animations : [string]
    style : string
    dimension : string
    aspect : string
    name : string
    thumbnailUrl : string
  }

  entity ButtonItem [runtime] {
    id : string!
  }

  trait ButtonRender -> @rebindable ButtonItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          variant: @config.variant
          size: @config.size
          isLoading: @config.isLoading
          leftIcon: @config.leftIcon
          rightIcon: @config.rightIcon
          icon: @config.icon
          iconRight: @config.iconRight
          iconAsset: @config.iconAsset
          action: ACTION
          actionPayload: @config.actionPayload
          label: @config.label
          disabled: @config.disabled
          type: button
        })
    }

    emits {
      ACTION -> external {
        id : string
      }
        @description "Declarative event name — emits UI:{action} via eventBus on click"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes applied to the root element."
        @tier "presentation"
      variant : "primary" | "secondary" | "ghost" | "danger" | "success" | "warning" | "default" = primary
        @label "Variant"
        @description "variant prop"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "size prop"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "isLoading prop"
        @tier "presentation"
      leftIcon : icon
        @label "Left Icon"
        @description "Left icon: a Lucide component or a canonical icon name string (e.g. 'plus', 'trash')."
        @tier "presentation"
      rightIcon : icon
        @label "Right Icon"
        @description "Right icon: a Lucide component or a canonical icon name string."
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Alias for leftIcon"
        @tier "presentation"
      iconRight : icon
        @label "Icon Right"
        @description "Alias for rightIcon"
        @tier "presentation"
      iconAsset : ButtonIconAsset = { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "iconAsset", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "iconAsset", thumbnailUrl: "" }
        @label "Icon Asset"
        @description "Asset image rendered as the leading icon; takes precedence over icon/leftIcon when provided."
        @tier "presentation"
      actionPayload : json = {}
        @label "Action Payload"
        @description "Payload to include with the action event"
        @tier "presentation"
      label : string = "Label"
        @label "Label"
        @description "Button label text (alternative to children for schema-driven rendering)"
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "Disable the button (greys out, blocks click events)"
        @tier "presentation"
    }
  }

  page "/button" as ButtonPage -> ButtonRender
}
