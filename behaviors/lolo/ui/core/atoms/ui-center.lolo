app ui-center "1.0.0"
"Center — UI factory (1:1 with the @almadar/ui center pattern)."
orbital CenterOrbital {
  entity CenterItem [runtime] {
    id : string!
  }

  trait CenterRender -> @rebindable CenterItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          inline: @config.inline
          horizontal: @config.horizontal
          vertical: @config.vertical
          minHeight: @config.minHeight
          fullHeight: @config.fullHeight
          fullWidth: @config.fullWidth
          className: @config.className
          style: @config.style
          children: @config.children
          as: @config.asProp
          type: center
        })
    }

    config {
      inline : boolean = false
        @label "Inline"
        @description "Center inline (width fits content) vs block (full width)"
        @tier "presentation"
      horizontal : boolean = true
        @label "Horizontal"
        @description "Center only horizontally"
        @tier "presentation"
      vertical : boolean = true
        @label "Vertical"
        @description "Center only vertically"
        @tier "presentation"
      minHeight : string = ""
        @label "Min Height"
        @description "Minimum height (useful for vertical centering)"
        @tier "presentation"
      fullHeight : boolean = false
        @label "Full Height"
        @description "Fill available height"
        @tier "presentation"
      fullWidth : boolean = false
        @label "Full Width"
        @description "Fill available width"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Custom class name"
        @tier "presentation"
      style : json
        @label "Style"
        @description "Inline styles"
        @tier "presentation"
      children : node
        @label "Children"
        @description "Children elements"
        @tier "presentation"
      asProp : json
        @label "As"
        @description "HTML element to render as"
        @synonyms "as"
        @tier "presentation"
    }
  }

  page "/center" as CenterPage -> CenterRender
}
