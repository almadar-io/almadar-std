app ui-day-cell "1.0.0"
"DayCell — UI factory (1:1 with the @almadar/ui day-cell pattern)."
orbital DayCellOrbital {
  entity DayCellItem [runtime] {
    id : string!
  }

  trait DayCellRender -> @rebindable DayCellItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          date: @config.date
          isToday: @config.isToday
          onClick: @config.onClick
          className: @config.className
          type: day-cell
        })
    }

    emits {
      @config.onClick -> external {
        date : date
      }
        @description "Called when the day is clicked"
        @tier "essential"
    }

    config {
      date : date = "2024-01-01"
        @label "Date"
        @description "The date this cell represents. Optional at the dynamic render edge: an unbound `@config.date` arrives as `undefined`, so the cell falls back to today."
        @tier "presentation"
      isToday : boolean = false
        @label "Is Today"
        @description "Whether this date is today"
        @tier "presentation"
      onClick : string = "CLICK"
        @label "On Click"
        @description "Called when the day is clicked"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/day-cell" as DayCellPage -> DayCellRender
}
