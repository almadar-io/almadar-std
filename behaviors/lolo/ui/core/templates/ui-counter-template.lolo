app ui-counter-template "1.0.0"
"CounterTemplate — UI factory (1:1 with the @almadar/ui counter-template pattern)."
orbital CounterTemplateOrbital {
  entity CounterTemplateItem [runtime] {
    id : string!
  }

  trait CounterTemplateRender -> @rebindable CounterTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch CounterTemplateItem {})
        (render-ui main {
          entity: @entity
          className: @config.className
          onIncrement: INCREMENT
          onDecrement: DECREMENT
          onReset: RESET
          title: @config.title
          showReset: @config.showReset
          size: @config.size
          variant: @config.variant
          type: counter-template
        })
    }

    emits {
      INCREMENT -> external {
        id : string
      }
        @description "Called when increment is clicked"
        @tier "essential"
      DECREMENT -> external {
        id : string
      }
        @description "Called when decrement is clicked"
        @tier "essential"
      RESET -> external {
        id : string
      }
        @description "Called when reset is clicked"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      title : string = Counter
        @label "Title"
        @description "Title displayed above the counter"
        @tier "presentation"
      showReset : boolean = true
        @label "Show Reset"
        @description "Show reset button"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Counter display size"
        @tier "presentation"
      variant : "minimal" | "standard" | "full" = minimal
        @label "Variant"
        @description "Template variant"
        @tier "presentation"
    }
  }

  page "/counter-template" as CounterTemplatePage -> CounterTemplateRender
}
