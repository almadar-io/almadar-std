app ui-counter-template "1.0.0"
"CounterTemplate — UI factory (1:1 with the @almadar/ui counter-template pattern)."
orbital CounterTemplateOrbital {
    type CounterTemplateLoaded = Event { data : [CounterTemplateItem] } "CounterTemplate rows finished loading; payload.data holds the collection"

  entity CounterTemplateItem [runtime] {
    id : string!
    count : number = 1
    decrementDisabled : boolean = false
    incrementDisabled : boolean = false
    decrementLabel : string = "Decrement Label"
    incrementLabel : string = "Increment Label"
    rangeText : string = "Range Text"
  }

  trait CounterTemplateRender -> @rebindable CounterTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch CounterTemplateItem { emit: { success: CounterTemplateLoaded } })
        (render-ui main {
          entity: @entity
          className: @config.className
          onIncrement: INCREMENT
          onDecrement: DECREMENT
          onReset: RESET
          title: @config.title
          showReset: @config.showReset
          size: @config.size
          variant: @config.variant
          type: counter-template
        })
      CounterTemplateLoaded -> idle
        (render-ui main {
          entity: @payload.data
          className: @config.className
          onIncrement: INCREMENT
          onDecrement: DECREMENT
          onReset: RESET
          title: @config.title
          showReset: @config.showReset
          size: @config.size
          variant: @config.variant
          type: counter-template
        })
    }

    emits {
      INCREMENT -> external {
        id : string
      }
        @description "Called when increment is clicked"
        @tier "domain"
      DECREMENT -> external {
        id : string
      }
        @description "Called when decrement is clicked"
        @tier "domain"
      RESET -> external {
        id : string
      }
        @description "Called when reset is clicked"
        @tier "domain"
      CounterTemplateLoaded
        @description "CounterTemplate rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "domain"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      title : string = Counter
        @label "Title"
        @description "Title displayed above the counter"
        @tier "presentation"
      showReset : boolean = true
        @label "Show Reset"
        @description "Show reset button"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Counter display size"
        @tier "presentation"
      variant : "minimal" | "standard" | "full" = minimal
        @label "Variant"
        @description "Template variant"
        @tier "presentation"
    }
  }

  page "/counter-template" as CounterTemplatePage -> CounterTemplateRender
}
