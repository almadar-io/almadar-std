app ui-pagination "1.0.0"
"Pagination — UI factory (1:1 with the @almadar/ui pagination pattern)."
orbital PaginationOrbital {
  entity PaginationItem [runtime] {
    id : string!
    pageSize : number = 0
  }

  trait PaginationRender -> @rebindable PaginationItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.pageSize @config.pageSize)
        (render-ui main {
          currentPage: @config.currentPage
          totalPages: @config.totalPages
          onPageChange: @config.onPageChange
          showPageSize: @config.showPageSize
          pageSizeOptions: @config.pageSizeOptions
          pageSize: @entity.pageSize
          onPageSizeChange: @config.onPageSizeChange
          showJumpToPage: @config.showJumpToPage
          showTotal: @config.showTotal
          totalItems: @config.totalItems
          maxVisiblePages: @config.maxVisiblePages
          className: @config.className
          pageChangeEvent: @config.pageChangeEvent
          pageSizeChangeEvent: @config.pageSizeChangeEvent
          type: pagination
        })
      PAGE_SIZE_CHANGE -> idle
        (set @entity.pageSize ?pageSize)
        (render-ui main {
          currentPage: @config.currentPage
          totalPages: @config.totalPages
          onPageChange: @config.onPageChange
          showPageSize: @config.showPageSize
          pageSizeOptions: @config.pageSizeOptions
          pageSize: @entity.pageSize
          onPageSizeChange: @config.onPageSizeChange
          showJumpToPage: @config.showJumpToPage
          showTotal: @config.showTotal
          totalItems: @config.totalItems
          maxVisiblePages: @config.maxVisiblePages
          className: @config.className
          pageChangeEvent: @config.pageChangeEvent
          pageSizeChangeEvent: @config.pageSizeChangeEvent
          type: pagination
        })
    }

    emits {
      @config.onPageChange -> external {
        page : number
      }
        @description "Callback when page changes (optional - can be a no-op if not interactive)"
        @tier "essential"
      @config.onPageSizeChange -> external {
        size : number
        pageSize : number!
      }
        @description "Callback when page size changes"
        @tier "essential"
    }

    listens {
      PAGE_SIZE_CHANGE {
        size : number
        pageSize : number!
      }
    }

    config {
      currentPage : number = 1
        @label "Current Page"
        @description "Current page (1-indexed)"
        @tier "presentation"
      totalPages : number = 1
        @label "Total Pages"
        @description "Total number of pages"
        @tier "presentation"
      onPageChange : string = "PAGE_CHANGE"
        @label "On Page Change"
        @description "Callback when page changes (optional - can be a no-op if not interactive)"
        @tier "presentation"
      showPageSize : boolean = false
        @label "Show Page Size"
        @description "Show page size selector"
        @tier "presentation"
      pageSizeOptions : [number] = []
        @label "Page Size Options"
        @description "Page size options"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Current page size"
        @tier "presentation"
      onPageSizeChange : string = "PAGE_SIZE_CHANGE"
        @label "On Page Size Change"
        @description "Callback when page size changes"
        @tier "presentation"
      showJumpToPage : boolean = false
        @label "Show Jump To Page"
        @description "Show jump to page input"
        @tier "presentation"
      showTotal : boolean = false
        @label "Show Total"
        @description "Show total count"
        @tier "presentation"
      totalItems : number = 0
        @label "Total Items"
        @description "Total items count"
        @tier "presentation"
      maxVisiblePages : number = 7
        @label "Max Visible Pages"
        @description "Maximum number of page buttons to show"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      pageChangeEvent : string = "PAGE_CHANGE"
        @label "Page Change Event"
        @description "Declarative page change event — emits UI:{pageChangeEvent} with { page }"
        @tier "presentation"
      pageSizeChangeEvent : string = "PAGE_SIZE_CHANGE"
        @label "Page Size Change Event"
        @description "Declarative page size change event — emits UI:{pageSizeChangeEvent} with { pageSize }"
        @tier "presentation"
    }
  }

  page "/pagination" as PaginationPage -> PaginationRender
}
