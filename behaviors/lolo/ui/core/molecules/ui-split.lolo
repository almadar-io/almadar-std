app ui-split "1.0.0"
"Split — UI factory (1:1 with the @almadar/ui split pattern)."
orbital SplitOrbital {
  type SplitError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity SplitItem [runtime] {
    id : string!
  }

  trait SplitRender -> @rebindable SplitItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch SplitItem {})
        (render-ui main {
          ratio: @config.ratio
          gap: @config.gap
          reverse: @config.reverse
          stackOnMobile: @config.stackOnMobile
          stackBreakpoint: @config.stackBreakpoint
          align: @config.align
          className: @config.className
          leftClassName: @config.leftClassName
          rightClassName: @config.rightClassName
          children: [{ content: "Panel A", type: text }, { content: "Panel B", type: text }]
          isLoading: @config.isLoading
          error: @config.error
          entity: SplitItem
          type: split
        })
    }

    config {
      ratio : "1:1" | "1:2" | "2:1" | "1:3" | "3:1" | "1:4" | "4:1" | "2:3" | "3:2" = "1:1"
        @label "Ratio"
        @description "Size ratio between left and right panels"
        @tier "presentation"
      gap : "none" | "sm" | "md" | "lg" | "xl" = md
        @label "Gap"
        @description "Gap between panels"
        @tier "presentation"
      reverse : boolean = false
        @label "Reverse"
        @description "Reverse the order (right first)"
        @tier "presentation"
      stackOnMobile : boolean = true
        @label "Stack On Mobile"
        @description "Stack vertically on mobile"
        @tier "presentation"
      stackBreakpoint : "sm" | "md" | "lg" | "xl" = md
        @label "Stack Breakpoint"
        @description "Breakpoint to switch from stacked to side-by-side"
        @tier "presentation"
      align : "start" | "center" | "end" | "stretch" = stretch
        @label "Align"
        @description "Align items vertically"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Custom class name"
        @tier "presentation"
      leftClassName : string = "Left Class Name"
        @label "Left Class Name"
        @description "Left/first panel class name"
        @tier "presentation"
      rightClassName : string = "Right Class Name"
        @label "Right Class Name"
        @description "Right/second panel class name"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SplitError
        @label "Error"
        @description "Error state"
        @tier "presentation"
    }
  }

  page "/split" as SplitPage -> SplitRender
}
