app ui-wizard-navigation "1.0.0"
"WizardNavigation — UI factory (1:1 with the @almadar/ui wizard-navigation pattern)."
orbital WizardNavigationOrbital {
  entity WizardNavigationItem [runtime] {
    id : string!
    currentStep : number = 1
    totalSteps : number = 1
  }

  trait WizardNavigationRender -> @rebindable WizardNavigationItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.currentStep @config.currentStep)
        (set @entity.totalSteps @config.totalSteps)
        (render-ui main {
          currentStep: @entity.currentStep
          totalSteps: @entity.totalSteps
          isValid: @config.isValid
          showBack: @config.showBack
          showNext: @config.showNext
          showComplete: @config.showComplete
          backLabel: @config.backLabel
          nextLabel: @config.nextLabel
          completeLabel: @config.completeLabel
          onBack: @config.onBack
          onNext: @config.onNext
          onComplete: @config.onComplete
          onBackClick: @config.onBackClick
          onNextClick: @config.onNextClick
          onCompleteClick: @config.onCompleteClick
          compact: @config.compact
          className: @config.className
          type: wizard-navigation
        })
      BACK -> idle
        (set @entity.currentStep ?currentStep)
        (set @entity.totalSteps ?totalSteps)
        (render-ui main {
          currentStep: @entity.currentStep
          totalSteps: @entity.totalSteps
          isValid: @config.isValid
          showBack: @config.showBack
          showNext: @config.showNext
          showComplete: @config.showComplete
          backLabel: @config.backLabel
          nextLabel: @config.nextLabel
          completeLabel: @config.completeLabel
          onBack: @config.onBack
          onNext: @config.onNext
          onComplete: @config.onComplete
          onBackClick: @config.onBackClick
          onNextClick: @config.onNextClick
          onCompleteClick: @config.onCompleteClick
          compact: @config.compact
          className: @config.className
          type: wizard-navigation
        })
      NEXT -> idle
        (set @entity.currentStep ?currentStep)
        (set @entity.totalSteps ?totalSteps)
        (render-ui main {
          currentStep: @entity.currentStep
          totalSteps: @entity.totalSteps
          isValid: @config.isValid
          showBack: @config.showBack
          showNext: @config.showNext
          showComplete: @config.showComplete
          backLabel: @config.backLabel
          nextLabel: @config.nextLabel
          completeLabel: @config.completeLabel
          onBack: @config.onBack
          onNext: @config.onNext
          onComplete: @config.onComplete
          onBackClick: @config.onBackClick
          onNextClick: @config.onNextClick
          onCompleteClick: @config.onCompleteClick
          compact: @config.compact
          className: @config.className
          type: wizard-navigation
        })
      COMPLETE -> idle
        (set @entity.currentStep ?currentStep)
        (set @entity.totalSteps ?totalSteps)
        (render-ui main {
          currentStep: @entity.currentStep
          totalSteps: @entity.totalSteps
          isValid: @config.isValid
          showBack: @config.showBack
          showNext: @config.showNext
          showComplete: @config.showComplete
          backLabel: @config.backLabel
          nextLabel: @config.nextLabel
          completeLabel: @config.completeLabel
          onBack: @config.onBack
          onNext: @config.onNext
          onComplete: @config.onComplete
          onBackClick: @config.onBackClick
          onNextClick: @config.onNextClick
          onCompleteClick: @config.onCompleteClick
          compact: @config.compact
          className: @config.className
          type: wizard-navigation
        })
    }

    emits {
      @config.onBack -> external {
        currentStep : number!
        totalSteps : number!
      }
        @description "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }"
        @tier "essential"
      @config.onNext -> external {
        currentStep : number!
        totalSteps : number!
      }
        @description "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }"
        @tier "essential"
      @config.onComplete -> external {
        currentStep : number!
        totalSteps : number!
      }
        @description "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }"
        @tier "essential"
      @config.onBackClick -> external {
        id : string
      }
        @description "Direct callback for Back (alternative to event)"
        @tier "essential"
      @config.onNextClick -> external {
        id : string
      }
        @description "Direct callback for Next (alternative to event)"
        @tier "essential"
      @config.onCompleteClick -> external {
        id : string
      }
        @description "Direct callback for Complete (alternative to event)"
        @tier "essential"
    }

    listens {
      BACK {
        currentStep : number!
        totalSteps : number!
      }
      NEXT {
        currentStep : number!
        totalSteps : number!
      }
      COMPLETE {
        currentStep : number!
        totalSteps : number!
      }
    }

    config {
      currentStep : number = 1
        @label "Current Step"
        @description "Current step index (0-based)"
        @tier "presentation"
      totalSteps : number = 1
        @label "Total Steps"
        @description "Total number of steps"
        @tier "presentation"
      isValid : boolean = true
        @label "Is Valid"
        @description "Whether the current step is valid (enables Next/Complete)"
        @tier "presentation"
      showBack : boolean = true
        @label "Show Back"
        @description "Show the Back button"
        @tier "presentation"
      showNext : boolean = true
        @label "Show Next"
        @description "Show the Next button"
        @tier "presentation"
      showComplete : boolean = true
        @label "Show Complete"
        @description "Show the Complete button (on last step)"
        @tier "presentation"
      backLabel : string = "Back Label"
        @label "Back Label"
        @description "Custom label for Back button"
        @tier "presentation"
      nextLabel : string = "Next Label"
        @label "Next Label"
        @description "Custom label for Next button"
        @tier "presentation"
      completeLabel : string = "Complete Label"
        @label "Complete Label"
        @description "Custom label for Complete button"
        @tier "presentation"
      onBack : string = "BACK"
        @label "On Back"
        @description "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }"
        @tier "presentation"
      onNext : string = "NEXT"
        @label "On Next"
        @description "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }"
        @tier "presentation"
      onComplete : string = "COMPLETE"
        @label "On Complete"
        @description "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }"
        @tier "presentation"
      onBackClick : string = "BACK_CLICK"
        @label "On Back Click"
        @description "Direct callback for Back (alternative to event)"
        @tier "presentation"
      onNextClick : string = "NEXT_CLICK"
        @label "On Next Click"
        @description "Direct callback for Next (alternative to event)"
        @tier "presentation"
      onCompleteClick : string = "COMPLETE_CLICK"
        @label "On Complete Click"
        @description "Direct callback for Complete (alternative to event)"
        @tier "presentation"
      compact : boolean = false
        @label "Compact"
        @description "Compact mode (smaller padding)"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/wizard-navigation" as WizardNavigationPage -> WizardNavigationRender
}
