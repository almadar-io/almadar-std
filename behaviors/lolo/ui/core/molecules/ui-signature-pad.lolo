app ui-signature-pad "1.0.0"
"SignaturePad — a draw-to-sign canvas that captures a handwritten signature or initials."
;; @capabilities "e-signature capture, sign-here field, consent signature, initial-here field, wet-signature substitute"
orbital SignaturePadOrbital {
  type SignaturePadError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity SignaturePadItem [runtime] {
    id : string!
  }

  trait SignaturePadRender -> @rebindable SignaturePadItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          label: @config.label
          helperText: @config.helperText
          strokeColor: @config.strokeColor
          strokeWidth: @config.strokeWidth
          height: @config.height
          readOnly: @config.readOnly
          value: @config.value
          onChange: @config.onChange
          signEvent: @config.signEvent
          clearEvent: @config.clearEvent
          isLoading: @config.isLoading
          error: @config.error
          className: @config.className
          type: signature-pad
        })
    }

    emits {
      @config.onChange -> external {
        dataUrl : string
      }
        @description "Callback when signature changes"
        @tier "essential"
      @config.signEvent -> external {
        signature : string!
      }
        @description "Event to emit on sign"
        @tier "essential"
      @config.clearEvent -> external {
        id : string
      }
        @description "Event to emit on clear"
        @tier "essential"
    }

    config {
      label : string
        @label "Label"
        @description "Label above the pad"
        @tier "presentation"
      helperText : string
        @label "Helper Text"
        @description "Helper text"
        @tier "presentation"
      strokeColor : string
        @label "Stroke Color"
        @description "Stroke color"
        @tier "presentation"
      strokeWidth : number = 2
        @label "Stroke Width"
        @description "Stroke width"
        @tier "presentation"
      height : number = 200
        @label "Height"
        @description "Pad height"
        @tier "presentation"
      readOnly : boolean = false
        @label "Read Only"
        @description "Whether the pad is read-only"
        @tier "presentation"
      value : string
        @label "Value"
        @description "Existing signature image URL"
        @tier "presentation"
      onChange : string = "CHANGE"
        @label "On Change"
        @description "Callback when signature changes"
        @tier "presentation"
      signEvent : string = "SIGN"
        @label "Sign Event"
        @description "Event to emit on sign"
        @tier "presentation"
      clearEvent : string = "CLEAR"
        @label "Clear Event"
        @description "Event to emit on clear"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : SignaturePadError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/signature-pad" as SignaturePadPage -> SignaturePadRender
}
