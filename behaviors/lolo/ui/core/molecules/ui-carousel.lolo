app ui-carousel "1.0.0"
"Carousel — UI factory (1:1 with the @almadar/ui carousel pattern)."
orbital CarouselOrbital {
  entity CarouselItem [runtime] {
    id : string!
  }

  trait CarouselRender -> @rebindable CarouselItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          autoPlay: @config.autoPlay
          autoPlayInterval: @config.autoPlayInterval
          showDots: @config.showDots
          showArrows: @config.showArrows
          loop: @config.loop
          slideChangeEvent: SLIDE_CHANGE
          slideChangePayload: @config.slideChangePayload
          className: @config.className
          type: carousel
        })
    }

    emits {
      SLIDE_CHANGE -> external {
        index : number!
      }
        @description "Declarative event name for slide change"
        @tier "essential"
    }

    config {
      items : [json] = []
        @label "Items"
        @description "Array of items to display as slides"
        @tier "presentation"
      autoPlay : boolean = false
        @label "Auto Play"
        @description "Enable auto-play rotation"
        @tier "presentation"
      autoPlayInterval : number = 5000
        @label "Auto Play Interval"
        @description "Auto-play interval in milliseconds (default: 5000)"
        @tier "presentation"
      showDots : boolean = true
        @label "Show Dots"
        @description "Show dot indicators"
        @tier "presentation"
      showArrows : boolean = true
        @label "Show Arrows"
        @description "Show prev/next arrow buttons"
        @tier "presentation"
      loop : boolean = false
        @label "Loop"
        @description "Enable infinite loop"
        @tier "presentation"
      slideChangePayload : json
        @label "Slide Change Payload"
        @description "Payload to include with the slide change event"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/carousel" as CarouselPage -> CarouselRender
}
