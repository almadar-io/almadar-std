app ui-date-range-selector "1.0.0"
"DateRangeSelector — UI factory (1:1 with the @almadar/ui date-range-selector pattern)."
orbital DateRangeSelectorOrbital {
  type DateRangeSelectorOptionsItem = {
    label : string!
    value : string!
  }

  entity DateRangeSelectorItem [runtime] {
    id : string!
  }

  trait DateRangeSelectorRender -> @rebindable DateRangeSelectorItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          options: @config.options
          selected: @config.selected
          onSelect: SELECT
          className: @config.className
          type: date-range-selector
        })
    }

    emits {
      SELECT -> external {
        value : string
      }
        @description "Callback when a range is selected"
        @tier "essential"
    }

    config {
      options : [DateRangeSelectorOptionsItem] = [{ label: "Label", value: "Value" }]
        @label "Options"
        @description "Available range options"
        @tier "presentation"
      selected : string = month
        @label "Selected"
        @description "Currently selected value"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/date-range-selector" as DateRangeSelectorPage -> DateRangeSelectorRender
}
