app ui-code-block "1.0.0"
"CodeBlock — UI factory (1:1 with the @almadar/ui code-block pattern)."
orbital CodeBlockOrbital {
  type CodeBlockDiffItem = {
    type : "added" | "removed" | "unchanged" | "context"!
    beforeLineNumber : number
    afterLineNumber : number
    content : string!
  }
  type CodeBlockFilesItem = {
    label : string!
    code : string!
    language : "text" | "json" | "javascript" | "js" | "typescript" | "ts" | "jsx" | "tsx" | "css" | "markdown" | "md" | "bash" | "shell" | "sh" | "yaml" | "yml" | "rust" | "python" | "py" | "sql" | "diff" | "toml" | "go" | "graphql" | "html" | "xml" | "clojure" | "clj" | "edn" | "haskell" | "hs" | "lisp" | "scheme" | "scala" | "elixir" | "ex" | "exs" | "erlang" | "erl" | "elm" | "fsharp" | "fs" | "fsx" | "ocaml" | "ml" | "java" | "c" | "cpp" | "c++" | "cc" | "cxx" | "hpp" | "h" | "csharp" | "cs" | "objectivec" | "objc" | "php" | "ruby" | "rb" | "swift" | "kotlin" | "kt" | "lua" | "r" | "dart" | "julia" | "fortran" | "f90" | "f95" | "perl" | "pl" | "powershell" | "ps1" | "makefile" | "make" | "nginx" | "ini" | "orb" | "lolo"
  }
  type CodeBlockActionsItem = {
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
  }
  type CodeBlockError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity CodeBlockItem [runtime] {
    id : string!
    code : string
  }

  trait CodeBlockRender -> @rebindable CodeBlockItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.code @config.code)
        (render-ui main {
          code: @entity.code
          language: @config.language
          showCopyButton: @config.showCopyButton
          showLanguageBadge: @config.showLanguageBadge
          maxHeight: @config.maxHeight
          foldable: @config.foldable
          className: @config.className
          editable: @config.editable
          onChange: @config.onChange
          title: @config.title
          mode: @config.mode
          diff: @config.diff
          oldValue: @config.oldValue
          newValue: @config.newValue
          showLineNumbers: @config.showLineNumbers
          wordWrap: @config.wordWrap
          files: @config.files
          actions: @config.actions
          isLoading: @config.isLoading
          error: @config.error
          showCopy: @config.showCopy
          type: code-block
        })
      CHANGE -> idle
        (set @entity.code ?code)
        (render-ui main {
          code: @entity.code
          language: @config.language
          showCopyButton: @config.showCopyButton
          showLanguageBadge: @config.showLanguageBadge
          maxHeight: @config.maxHeight
          foldable: @config.foldable
          className: @config.className
          editable: @config.editable
          onChange: @config.onChange
          title: @config.title
          mode: @config.mode
          diff: @config.diff
          oldValue: @config.oldValue
          newValue: @config.newValue
          showLineNumbers: @config.showLineNumbers
          wordWrap: @config.wordWrap
          files: @config.files
          actions: @config.actions
          isLoading: @config.isLoading
          error: @config.error
          showCopy: @config.showCopy
          type: code-block
        })
    }

    emits {
      @config.onChange -> external {
        code : string
      }
        @description "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not."
        @tier "essential"
    }

    listens {
      CHANGE {
        code : string
      }
    }

    config {
      code : string
        @label "Code"
        @description "The code content to display"
        @tier "presentation"
      language : string = text
        @label "Language"
        @description "Programming language for syntax highlighting (any Prism id; loaded on demand if not pre-registered)"
        @tier "presentation"
      showCopyButton : boolean = true
        @label "Show Copy Button"
        @description "Show the copy button"
        @tier "presentation"
      showLanguageBadge : boolean = true
        @label "Show Language Badge"
        @description "Show the language badge"
        @tier "presentation"
      maxHeight : string = "60vh"
        @label "Max Height"
        @description "Maximum height before scrolling"
        @tier "presentation"
      foldable : boolean
        @label "Foldable"
        @description "Enable brace-based code folding of multi-line `{}`/`[]` blocks (default: true)."
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      editable : boolean = false
        @label "Editable"
        @description "When true, render an editable surface that composes a transparent `Textarea` over a Prism-highlighted overlay. The overlay re-tokenizes on each keystroke (driven from a local mirror of the textarea value), so users see syntax-highlighted code while still being able to type. Folding is skipped in editable mode. History: GAP-51 first-cut shipped plain (no-highlighting) editable text; GAP-77 (2026-04-12) added the Prism overlay layer. Default: false (existing read-only behavior unchanged)."
        @tier "presentation"
      onChange : string = "CHANGE"
        @label "On Change"
        @description "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not."
        @tier "presentation"
      title : string
        @label "Title"
        @description "── Viewer props (absorbed from CodeViewer / DocCodeBlock) ────────────────"
        @tier "presentation"
      mode : "code" | "diff" = code
        @label "Mode"
        @description "Diff or plain-code display mode"
        @tier "presentation"
      diff : [CodeBlockDiffItem] = []
        @label "Diff"
        @description "Pre-computed diff lines"
        @tier "presentation"
      oldValue : string
        @label "Old Value"
        @description "Old source text — generates diff when combined with newValue"
        @tier "presentation"
      newValue : string
        @label "New Value"
        @description "New source text — generates diff when combined with oldValue"
        @tier "presentation"
      showLineNumbers : boolean = false
        @label "Show Line Numbers"
        @description "Show line numbers in code / diff mode"
        @tier "presentation"
      wordWrap : boolean = false
        @label "Word Wrap"
        @description "Enable word-wrap in code / diff mode"
        @tier "presentation"
      files : [CodeBlockFilesItem] = []
        @label "Files"
        @description "Multiple files shown as tabs"
        @tier "presentation"
      actions : [CodeBlockActionsItem] = []
        @label "Actions"
        @description "Action badges in the toolbar"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : CodeBlockError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      showCopy : boolean
        @label "Show Copy"
        @description "Show copy button (viewer alias for showCopyButton)"
        @tier "presentation"
    }
  }

  page "/code-block" as CodeBlockPage -> CodeBlockRender
}
