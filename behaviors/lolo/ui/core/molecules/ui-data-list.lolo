app ui-data-list "1.0.0"
"DataList — UI factory (1:1 with the @almadar/ui data-list pattern)."
orbital DataListOrbital {
    type DataListLoaded = Event { data : [DataListItem] } "DataList rows finished loading; payload.data holds the collection"
  type DataListFieldsItem = {
    name : string!
    label : string
    icon : icon
    variant : "h3" | "h4" | "body" | "caption" | "badge" | "small" | "progress"
    format : "date" | "currency" | "number" | "boolean" | "percent"
  }
  type DataListColumnsItem = {
    name : string!
    label : string
    icon : icon
    variant : "h3" | "h4" | "body" | "caption" | "badge" | "small" | "progress"
    format : "date" | "currency" | "number" | "boolean" | "percent"
  }
  type DataListItemActionsItem = {
    label : string!
    event : string!
    icon : icon
    variant : "primary" | "secondary" | "ghost" | "danger"
  }
  type DataListError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type DataListSwipeLeftActionsItem = {
    label : string!
    icon : icon
    variant : "primary" | "secondary" | "danger" | "ghost"
  }
  type DataListSwipeRightActionsItem = {
    label : string!
    icon : icon
    variant : "primary" | "secondary" | "danger" | "ghost"
  }

  entity DataListItem [runtime] {
    id : string!
  }

  trait DataListRender -> @rebindable DataListItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch DataListItem { emit: { success: DataListLoaded } })
        (render-ui main {
          dragGroup: @config.dragGroup
          accepts: @config.accepts
          sortable: @config.sortable
          dropEvent: @config.dropEvent
          reorderEvent: REORDER
          positionEvent: @config.positionEvent
          dndItemIdField: @config.dndItemIdField
          dndRoot: @config.dndRoot
          entity: @entity
          fields: @config.fields
          columns: @config.columns
          maxInlineActions: @config.maxInlineActions
          itemClickEvent: ITEM_CLICK
          gap: @config.gap
          variant: @config.variant
          groupBy: @config.groupBy
          senderField: @config.senderField
          currentUser: @config.currentUser
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          reorderable: @config.reorderable
          swipeLeftEvent: SWIPE_LEFT
          swipeLeftActions: @config.swipeLeftActions
          swipeRightEvent: SWIPE_RIGHT
          swipeRightActions: @config.swipeRightActions
          longPressEvent: LONG_PRESS
          infiniteScroll: @config.infiniteScroll
          loadMoreEvent: LOAD_MORE
          hasMore: @config.hasMore
          pageSize: @config.pageSize
          look: @config.look
          itemActions: [{ label: "View", event: VIEW }]
          type: data-list
        })
      DataListLoaded -> idle
        (render-ui main {
          dragGroup: @config.dragGroup
          accepts: @config.accepts
          sortable: @config.sortable
          dropEvent: @config.dropEvent
          reorderEvent: REORDER
          positionEvent: @config.positionEvent
          dndItemIdField: @config.dndItemIdField
          dndRoot: @config.dndRoot
          entity: @payload.data
          fields: @config.fields
          columns: @config.columns
          maxInlineActions: @config.maxInlineActions
          itemClickEvent: ITEM_CLICK
          gap: @config.gap
          variant: @config.variant
          groupBy: @config.groupBy
          senderField: @config.senderField
          currentUser: @config.currentUser
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          reorderable: @config.reorderable
          swipeLeftEvent: SWIPE_LEFT
          swipeLeftActions: @config.swipeLeftActions
          swipeRightEvent: SWIPE_RIGHT
          swipeRightActions: @config.swipeRightActions
          longPressEvent: LONG_PRESS
          infiniteScroll: @config.infiniteScroll
          loadMoreEvent: LOAD_MORE
          hasMore: @config.hasMore
          pageSize: @config.pageSize
          look: @config.look
          itemActions: [{ label: "View", event: VIEW }]
          type: data-list
        })
      VIEW -> idle
        (emit VIEW {})
    }

    emits {
      REORDER -> external {
        id : string
      }
        @description "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }"
        @tier "essential"
      ITEM_CLICK -> external {
        id : string
      }
        @description "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win)."
        @tier "essential"
      SWIPE_LEFT -> external {
        id : string
      }
        @description "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }"
        @tier "essential"
      SWIPE_RIGHT -> external {
        id : string
      }
        @description "Event emitted on right swipe: UI:{swipeRightEvent} with { row }"
        @tier "essential"
      LONG_PRESS -> external {
        id : string
      }
        @description "Event emitted on long press: UI:{longPressEvent} with { row }"
        @tier "essential"
      LOAD_MORE -> external {
        id : string
      }
        @description "Event emitted when more items needed: UI:{loadMoreEvent}"
        @tier "essential"
      VIEW -> external {
        id : string
      }
        @description "User opened a record from the list."
        @tier "essential"
      DataListLoaded
        @description "DataList rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      dragGroup : string = "Drag Group"
        @label "Drag Group"
        @description "When set, items in this container are draggable and announce this group as their source"
        @tier "presentation"
      accepts : string = "Accepts"
        @label "Accepts"
        @description "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)"
        @tier "presentation"
      sortable : boolean = false
        @label "Sortable"
        @description "Enable in-container reorder; items can be dragged to new positions among siblings"
        @tier "presentation"
      dropEvent : string = "Drop Event"
        @label "Drop Event"
        @description "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }"
        @tier "presentation"
      positionEvent : string = "Position Event"
        @label "Position Event"
        @description "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }"
        @tier "presentation"
      dndItemIdField : string = "Dnd Item Id Field"
        @label "Dnd Item Id Field"
        @description "Row field used as the @dnd-kit draggable id (default 'id')"
        @tier "presentation"
      dndRoot : boolean = false
        @label "Dnd Root"
        @description "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable."
        @tier "presentation"
      fields : [DataListFieldsItem] = [{ name: "Name", label: "Label", icon: "circle", variant: h3, format: date }, { name: "Name 2", label: "Label 2", icon: "circle", variant: h4, format: currency }]
        @label "Fields"
        @description "Field definitions for rendering each row. The pattern contract in `@almadar/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either."
        @tier "presentation"
      columns : [DataListColumnsItem] = [{ name: "Name", label: "Label", icon: "circle", variant: h3, format: date }, { name: "Name 2", label: "Label 2", icon: "circle", variant: h4, format: currency }]
        @label "Columns"
        @description "Alias for `fields` — the compiler emits `columns` for field defs."
        @tier "presentation"
      itemActions : [DataListItemActionsItem] = []
        @label "Item Actions"
        @description "Per-item action buttons"
        @tier "presentation"
      maxInlineActions : number = 0
        @label "Max Inline Actions"
        @description "Max inline action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline."
        @tier "presentation"
      gap : "none" | "sm" | "md" | "lg" = none
        @label "Gap"
        @description "Gap between rows"
        @tier "presentation"
      variant : "default" | "card" | "compact" | "message" = default
        @label "Variant"
        @description "Visual variant"
        @tier "presentation"
      groupBy : string = "Group By"
        @label "Group By"
        @description "Group items by a field value (renders section headers between groups)"
        @tier "presentation"
      senderField : string = "Sender Field"
        @label "Sender Field"
        @description "Field name identifying the sender (used with variant: 'message')"
        @tier "presentation"
      currentUser : string = "Current User"
        @label "Current User"
        @description "Current user identifier; messages matching this value align right (used with variant: 'message')"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : DataListError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      reorderable : boolean = false
        @label "Reorderable"
        @description "Enable drag-to-reorder with grip handles"
        @tier "presentation"
      swipeLeftActions : [DataListSwipeLeftActionsItem] = [{ label: "Label", icon: "circle", variant: primary }, { label: "Label 2", icon: "circle", variant: secondary }]
        @label "Swipe Left Actions"
        @description "Actions revealed on left swipe"
        @tier "presentation"
      swipeRightActions : [DataListSwipeRightActionsItem] = [{ label: "Label", icon: "circle", variant: primary }, { label: "Label 2", icon: "circle", variant: secondary }]
        @label "Swipe Right Actions"
        @description "Actions revealed on right swipe"
        @tier "presentation"
      infiniteScroll : boolean = false
        @label "Infinite Scroll"
        @description "Enable infinite scroll loading"
        @tier "presentation"
      hasMore : boolean = false
        @label "Has More"
        @description "Whether more items are available for infinite scroll"
        @tier "presentation"
      pageSize : number = 5
        @label "Page Size"
        @description "Max items to show before 'Show More' button. Defaults to 5. Set to 0 to disable."
        @tier "presentation"
      look : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Look"
        @description "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors."
        @tier "presentation"
    }
  }

  page "/data-list" as DataListPage -> DataListRender
}
