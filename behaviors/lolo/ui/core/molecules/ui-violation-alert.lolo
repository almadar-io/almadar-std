app ui-violation-alert "1.0.0"
"ViolationAlert — UI factory (1:1 with the @almadar/ui violation-alert pattern)."
orbital ViolationAlertOrbital {
  type ViolationAlertViolation = {
    id : string!
    law : string!
    article : string!
    message : string!
    actionType : "measure" | "admin" | "penalty"!
    adminAction : string
    penaltyAction : string
    fieldId : string
    tabId : string
  }

  entity ViolationAlertItem [runtime] {
    id : string!
  }

  trait ViolationAlertRender -> @rebindable ViolationAlertItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          violation: @config.violation
          severity: @config.severity
          dismissible: @config.dismissible
          onDismiss: @config.onDismiss
          onNavigateToField: @config.onNavigateToField
          compact: @config.compact
          className: @config.className
          message: @config.message
          type: violation-alert
        })
    }

    emits {
      @config.onDismiss -> external {
        id : string
      }
        @description "Dismiss handler"
        @tier "essential"
      @config.onNavigateToField -> external {
        fieldId : string
      }
        @description "Navigate to the field that caused violation"
        @tier "essential"
    }

    config {
      violation : ViolationAlertViolation = { id: "Id", law: "Law", article: "Article", message: "Message", actionType: measure, adminAction: "Admin Action", penaltyAction: "Penalty Action", fieldId: "Field Id", tabId: "Tab Id" }
        @label "Violation"
        @description "Violation data"
        @tier "presentation"
      severity : "warning" | "error" = warning
        @label "Severity"
        @description "Visual severity (derived from actionType if not specified)"
        @tier "presentation"
      dismissible : boolean = false
        @label "Dismissible"
        @description "Dismissible alert"
        @tier "presentation"
      onDismiss : string = "DISMISS"
        @label "On Dismiss"
        @description "Dismiss handler"
        @tier "presentation"
      onNavigateToField : string = "NAVIGATE_TO_FIELD"
        @label "On Navigate To Field"
        @description "Navigate to the field that caused violation"
        @tier "presentation"
      compact : boolean = false
        @label "Compact"
        @description "Compact display mode"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      message : string = ""
        @label "Message"
        @description "Fallback message from playground render-ui"
        @tier "presentation"
    }
  }

  page "/violation-alert" as ViolationAlertPage -> ViolationAlertRender
}
