app ui-page-header "1.0.0"
"PageHeader — UI factory (1:1 with the @almadar/ui page-header pattern)."
orbital PageHeaderOrbital {
  type PageHeaderBreadcrumbsItem = {
    label : string!
    href : string
  }
  type PageHeaderStatus = {
    label : string!
    variant : "default" | "success" | "warning" | "danger" | "info"
  }
  type PageHeaderActionsItem = {
    label : string!
    navigatesTo : string
    event : string
    variant : "primary" | "secondary" | "ghost" | "danger"
    icon : icon
    loading : boolean
    disabled : boolean
  }
  type PageHeaderError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type PageHeaderTabsItem = {
    label : string!
    value : string!
    count : number
  }

  entity PageHeaderItem [runtime] {
    id : string!
  }

  trait PageHeaderRender -> @rebindable PageHeaderItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          title: @config.title
          subtitle: @config.subtitle
          showBack: @config.showBack
          backEvent: @config.backEvent
          breadcrumbs: @config.breadcrumbs
          status: @config.status
          actions: @config.actions
          isLoading: @config.isLoading
          error: @config.error
          tabs: @config.tabs
          activeTab: @config.activeTab
          onTabChange: @config.onTabChange
          children: @config.children
          className: @config.className
          type: page-header
        })
    }

    emits {
      @config.backEvent -> external {
        id : string
      }
        @description "Event to emit when back is clicked (default: BACK)"
        @tier "essential"
      @config.onTabChange -> external {
        value : string
      }
        @description "onTabChange prop"
        @tier "essential"
    }

    config {
      title : string = ""
        @label "Title"
        @description "Page title - accepts string or number from generated code accessing dynamic entity data"
        @tier "presentation"
      subtitle : string = ""
        @label "Subtitle"
        @description "Optional subtitle/description"
        @tier "presentation"
      showBack : boolean = false
        @label "Show Back"
        @description "Show back button"
        @tier "presentation"
      backEvent : string = "BACK"
        @label "Back Event"
        @description "Event to emit when back is clicked (default: BACK)"
        @tier "presentation"
      breadcrumbs : [PageHeaderBreadcrumbsItem] = [{ label: "Label", href: "Href" }, { label: "Label 2", href: "Href 2" }]
        @label "Breadcrumbs"
        @description "Breadcrumbs"
        @tier "presentation"
      status : PageHeaderStatus
        @label "Status"
        @description "Status badge"
        @tier "presentation"
      actions : [PageHeaderActionsItem] = [{ label: "Label", navigatesTo: "Navigates To", variant: primary, icon: "circle", loading: false, disabled: false }, { label: "Label 2", navigatesTo: "Navigates To 2", variant: secondary, icon: "circle", loading: true, disabled: true }]
        @label "Actions"
        @description "Actions array - first action with variant='primary' (or first action) is the main action"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : PageHeaderError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      tabs : [PageHeaderTabsItem] = [{ label: "Label", value: "Value", count: 1 }, { label: "Label 2", value: "Value 2", count: 2 }]
        @label "Tabs"
        @description "Tabs for sub-navigation"
        @tier "presentation"
      activeTab : string = ""
        @label "Active Tab"
        @description "activeTab prop"
        @tier "presentation"
      onTabChange : string = "TAB_CHANGE"
        @label "On Tab Change"
        @description "onTabChange prop"
        @tier "presentation"
      children : node
        @label "Children"
        @description "Custom content in the header"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/page-header" as PageHeaderPage -> PageHeaderRender
}
