app ui-search-input "1.0.0"
"SearchInput — UI factory (1:1 with the @almadar/ui search-input pattern)."
orbital SearchInputOrbital {
  entity SearchInputItem [runtime] {
    id : string!
    value : string = ""
  }

  trait SearchInputRender -> @rebindable SearchInputItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch SearchInputItem {})
        (set @entity.value @config.value)
        (render-ui main {
          value: @entity.value
          onSearch: @config.onSearch
          debounceMs: @config.debounceMs
          isLoading: @config.isLoading
          placeholder: @config.placeholder
          clearable: @config.clearable
          className: @config.className
          event: @config.event
          entity: SearchInputItem
          query: @config.query
          type: search-input
        })
      SEARCH -> idle
        (set @entity.value ?value)
        (render-ui main {
          value: @entity.value
          onSearch: @config.onSearch
          debounceMs: @config.debounceMs
          isLoading: @config.isLoading
          placeholder: @config.placeholder
          clearable: @config.clearable
          className: @config.className
          event: @config.event
          entity: SearchInputItem
          query: @config.query
          type: search-input
        })
    }

    emits {
      @config.onSearch -> external {
        value : string
      }
        @description "Callback when search value changes"
        @tier "essential"
    }

    listens {
      SEARCH {
        value : string
      }
    }

    config {
      value : string = ""
        @label "Value"
        @description "Search value (controlled mode)"
        @tier "presentation"
      onSearch : string = "SEARCH"
        @label "On Search"
        @description "Callback when search value changes"
        @tier "presentation"
      debounceMs : number = 300
        @label "Debounce Ms"
        @description "Debounce delay in milliseconds"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Show loading state"
        @tier "presentation"
      placeholder : string = ""
        @label "Placeholder"
        @description "Placeholder text"
        @tier "presentation"
      clearable : boolean = true
        @label "Clearable"
        @description "Show clear button"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      event : string = ""
        @label "Event"
        @description "Event name to dispatch on search (schema metadata, wired by trait) This is metadata used by the trait generator, not by the component."
        @tier "presentation"
      query : string = ""
        @label "Query"
        @description "Query singleton binding for state management. When provided, syncs search state with the query singleton. Example: '@TaskQuery'"
        @tier "presentation"
    }
  }

  page "/search-input" as SearchInputPage -> SearchInputRender
}
