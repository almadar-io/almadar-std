app ui-branching-logic-builder "1.0.0"
"BranchingLogicBuilder — UI factory (1:1 with the @almadar/ui branching-logic-builder pattern)."
orbital BranchingLogicBuilderOrbital {
  type BranchingLogicBuilderQuestionsItem = {
    id : string!
    label : string!
    optionValues : [string]
  }
  type BranchingLogicBuilderRulesItem = {
    id : string!
    sourceQuestionId : string!
    operator : "equals" | "not-equals" | "contains" | "in"!
    value : [string]!
    targetQuestionId : json!
  }

  entity BranchingLogicBuilderItem [runtime] {
    id : string!
  }

  trait BranchingLogicBuilderRender -> @rebindable BranchingLogicBuilderItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          questions: @config.questions
          rules: @config.rules
          onRulesChange: RULES_CHANGE
          rulesChangeEvent: RULES_CHANGE
          readOnly: @config.readOnly
          className: @config.className
          type: branching-logic-builder
        })
    }

    emits {
      RULES_CHANGE -> external {
        rules : [object]
      }
        @description "onRulesChange prop"
        @tier "domain"
    }

    config {
      questions : [BranchingLogicBuilderQuestionsItem] = [{ id: "Id", label: "Label", optionValues: ["Item", "Item 2"] }, { id: "Id 2", label: "Label 2", optionValues: ["Item", "Item 2"] }]
        @label "Questions"
        @description "questions prop"
        @tier "presentation"
      rules : [BranchingLogicBuilderRulesItem] = [{ id: "Id", sourceQuestionId: "Source Question Id", operator: equals, value: ["Item", "Item 2"], targetQuestionId: "Target Question Id" }, { id: "Id 2", sourceQuestionId: "Source Question Id 2", operator: "not-equals", value: ["Item", "Item 2"], targetQuestionId: "Target Question Id 2" }]
        @label "Rules"
        @description "Rules. Accepts either a typed array (direct consumers) or the runtime payload shape from a render-ui binding (`@payload.data`). Narrowed to `[]` internally when the value isn't an array."
        @tier "presentation"
      readOnly : boolean = false
        @label "Read Only"
        @description "readOnly prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/branching-logic-builder" as BranchingLogicBuilderPage -> BranchingLogicBuilderRender
}
