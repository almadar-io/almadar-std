app ui-doc-toc "1.0.0"
"DocToc — UI factory (1:1 with the @almadar/ui doc-toc pattern)."
orbital DocTocOrbital {
  type DocTocItemsItem = {
    id : string!
    label : string!
    level : number!
  }

  entity DocTocItem [runtime] {
    id : string!
  }

  trait DocTocRender -> @rebindable DocTocItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          activeId: @config.activeId
          className: @config.className
          type: doc-toc
        })
    }

    config {
      items : [DocTocItemsItem] = [{ id: "Id", label: "Label", level: 1 }, { id: "Id 2", label: "Label 2", level: 2 }]
        @label "Items"
        @description "Table of contents items"
        @tier "presentation"
      activeId : string
        @label "Active Id"
        @description "Currently active section id"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/doc-toc" as DocTocPage -> DocTocRender
}
