app ui-reply-tree "1.0.0"
"ReplyTree — UI factory (1:1 with the @almadar/ui reply-tree pattern)."
orbital ReplyTreeOrbital {
    type ReplyTreeLoaded = Event { data : [ReplyTreeItem] } "ReplyTree rows finished loading; payload.data holds the collection"

  entity ReplyTreeItem [runtime] {
    id : string!
    authorName : string = "Author Name"
    content : string = "Content"
    authorAvatarUrl : string = "Author Avatar Url"
    postedAt : string = "Posted At"
    voteCount : number = 1
    userVote : "up" | "down" | "none" = up
    collapsed : boolean = false
    replies : json = {}
  }

  trait ReplyTreeRender -> @rebindable ReplyTreeItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ReplyTreeItem { emit: { success: ReplyTreeLoaded } })
        (render-ui main {
          nodes: @entity
          maxDepth: @config.maxDepth
          onVote: @config.onVote
          onReply: @config.onReply
          onFlag: @config.onFlag
          onContinueThread: @config.onContinueThread
          voteEvent: @config.voteEvent
          replyEvent: @config.replyEvent
          flagEvent: @config.flagEvent
          continueThreadEvent: @config.continueThreadEvent
          showActions: @config.showActions
          className: @config.className
          type: reply-tree
        })
      ReplyTreeLoaded -> idle
        (render-ui main {
          nodes: @payload.data
          maxDepth: @config.maxDepth
          onVote: @config.onVote
          onReply: @config.onReply
          onFlag: @config.onFlag
          onContinueThread: @config.onContinueThread
          voteEvent: @config.voteEvent
          replyEvent: @config.replyEvent
          flagEvent: @config.flagEvent
          continueThreadEvent: @config.continueThreadEvent
          showActions: @config.showActions
          className: @config.className
          type: reply-tree
        })
    }

    emits {
      @config.onVote -> external {
        nodeId : string
        vote : string
      }
        @description "onVote prop"
        @tier "essential"
      @config.onReply -> external {
        parentNodeId : string
        content : string!
      }
        @description "onReply prop"
        @tier "essential"
      @config.onFlag -> external {
        nodeId : string
      }
        @description "onFlag prop"
        @tier "essential"
      @config.onContinueThread -> external {
        nodeId : string
      }
        @description "onContinueThread prop"
        @tier "essential"
      ReplyTreeLoaded
        @description "ReplyTree rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      maxDepth : number = 6
        @label "Max Depth"
        @description "maxDepth prop"
        @tier "presentation"
      onVote : string = "VOTE"
        @label "On Vote"
        @description "onVote prop"
        @tier "presentation"
      onReply : string = "REPLY"
        @label "On Reply"
        @description "onReply prop"
        @tier "presentation"
      onFlag : string = "FLAG"
        @label "On Flag"
        @description "onFlag prop"
        @tier "presentation"
      onContinueThread : string = "CONTINUE_THREAD"
        @label "On Continue Thread"
        @description "onContinueThread prop"
        @tier "presentation"
      voteEvent : string = "VOTE"
        @label "Vote Event"
        @description "voteEvent prop"
        @tier "presentation"
      replyEvent : string = "REPLY"
        @label "Reply Event"
        @description "replyEvent prop"
        @tier "presentation"
      flagEvent : string = "FLAG"
        @label "Flag Event"
        @description "flagEvent prop"
        @tier "presentation"
      continueThreadEvent : string = "CONTINUE_THREAD"
        @label "Continue Thread Event"
        @description "continueThreadEvent prop"
        @tier "presentation"
      showActions : boolean = true
        @label "Show Actions"
        @description "showActions prop"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/reply-tree" as ReplyTreePage -> ReplyTreeRender
}
