app ui-quiz-block "1.0.0"
"QuizBlock — a single quiz question with answer choices and submit/reveal feedback."
;; @capabilities "multiple-choice quiz, test question, exam item, assessment question, knowledge check, trivia question"
orbital QuizBlockOrbital {
  entity QuizBlockItem [runtime] {
    id : string!
  }

  trait QuizBlockRender -> @rebindable QuizBlockItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          question: @config.question
          answer: @config.answer
          className: @config.className
          type: quiz-block
        })
    }

    config {
      question : string = ""
        @label "Question"
        @description "The quiz question"
        @tier "presentation"
      answer : string = ""
        @label "Answer"
        @description "The quiz answer (revealed on toggle)"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/quiz-block" as QuizBlockPage -> QuizBlockRender
}
