app ui-stat-display "1.0.0"
"StatDisplay — UI factory (1:1 with the @almadar/ui stat-display pattern)."
orbital StatDisplayOrbital {
  type StatDisplayError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity StatDisplayItem [runtime] {
    id : string!
  }

  trait StatDisplayRender -> @rebindable StatDisplayItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          label: @config.label
          value: @config.value
          max: @config.max
          target: @config.target
          trend: @config.trend
          trendPolarity: @config.trendPolarity
          trendFormat: @config.trendFormat
          sparklineData: @config.sparklineData
          clickEvent: @config.clickEvent
          prefix: @config.prefix
          suffix: @config.suffix
          icon: @config.icon
          iconBg: @config.iconBg
          iconColor: @config.iconColor
          format: @config.format
          size: @config.size
          variant: @config.variant
          compact: @config.compact
          look: @config.look
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          type: stat-display
        })
    }

    config {
      label : string = ""
        @label "Label"
        @description "Display label (e.g., 'Total', 'Remaining')"
        @tier "presentation"
      value : string = ""
        @label "Value"
        @description "Primary value (number or formatted string)"
        @tier "presentation"
      max : number = 0
        @label "Max"
        @description "Optional denominator. >0 renders 'value / max'; 0 or omitted hides the divider."
        @tier "presentation"
      target : number = 0
        @label "Target"
        @description "Optional progress target. >0 renders a progress bar at value/target."
        @tier "presentation"
      trend : number = 0
        @label "Trend"
        @description "Signed delta vs previous period. >0 renders ↑ green, <0 renders ↓ red, 0 hides. Polarity reversal via `trendPolarity`."
        @tier "presentation"
      trendPolarity : "higher-is-better" | "lower-is-better" = "higher-is-better"
        @label "Trend Polarity"
        @description "Controls whether `trend > 0` is 'good' (default) or 'bad'. `lower-is-better` inverts the color logic."
        @tier "presentation"
      trendFormat : "absolute" | "percent" = absolute
        @label "Trend Format"
        @description "When `'percent'`, renders trend with a `%` suffix (e.g. `↓ 3.3%`); default is `'absolute'`."
        @tier "presentation"
      sparklineData : [number] = []
        @label "Sparkline Data"
        @description "Optional inline sparkline data appended to the trend row. Length < 2 renders nothing."
        @tier "presentation"
      clickEvent : string = ""
        @label "Click Event"
        @description "Event name emitted as `UI:{clickEvent}` with `{ metricLabel }` when the card is clicked."
        @tier "presentation"
      prefix : string = ""
        @label "Prefix"
        @description "Prefix prepended to the formatted value (e.g. '≈ ')."
        @tier "presentation"
      suffix : string = ""
        @label "Suffix"
        @description "Suffix appended to the formatted value (e.g. ' /mo', ' ms')."
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Lucide icon name or component"
        @tier "presentation"
      iconBg : string = "bg-muted"
        @label "Icon Bg"
        @description "Icon background color class"
        @tier "presentation"
      iconColor : string = "text-foreground"
        @label "Icon Color"
        @description "Icon color class"
        @tier "presentation"
      format : string = ""
        @label "Format"
        @description "Display format: 'number', 'currency', 'percent'"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      variant : "default" | "primary" | "success" | "warning" | "error" | "info" = default
        @label "Variant"
        @description "Color variant"
        @tier "presentation"
      compact : boolean = false
        @label "Compact"
        @description "Compact mode (inline, no card wrapper)"
        @tier "presentation"
      look : "elevated" | "flat" | "progress-backed" | "gauge" | "sparkline" = elevated
        @label "Look"
        @description "Layer 2 visual treatment."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : StatDisplayError
        @label "Error"
        @description "Error state"
        @tier "presentation"
    }
  }

  page "/stat-display" as StatDisplayPage -> StatDisplayRender
}
