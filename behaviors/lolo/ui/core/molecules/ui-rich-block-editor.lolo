app ui-rich-block-editor "1.0.0"
"RichBlockEditor — UI factory (1:1 with the @almadar/ui rich-block-editor pattern)."
orbital RichBlockEditorOrbital {
    type RichBlockEditorLoaded = Event { data : [RichBlockEditorItem] } "RichBlockEditor rows finished loading; payload.data holds the collection"

  entity RichBlockEditorItem [runtime] {
    id : string!
  }

  trait RichBlockEditorRender -> @rebindable RichBlockEditorItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch RichBlockEditorItem { emit: { success: RichBlockEditorLoaded } })
        (render-ui main {
          initialBlocks: @entity
          onChange: @config.onChange
          changeEvent: @config.changeEvent
          readOnly: @config.readOnly
          placeholder: @config.placeholder
          enableBlocks: @config.enableBlocks
          showToolbar: @config.showToolbar
          className: @config.className
          type: rich-block-editor
        })
      RichBlockEditorLoaded -> idle
        (render-ui main {
          initialBlocks: @payload.data
          onChange: @config.onChange
          changeEvent: @config.changeEvent
          readOnly: @config.readOnly
          placeholder: @config.placeholder
          enableBlocks: @config.enableBlocks
          showToolbar: @config.showToolbar
          className: @config.className
          type: rich-block-editor
        })
    }

    emits {
      CHANGE -> external {
        blocks : [object]
      }
        @description "onChange prop"
        @tier "essential"
      RichBlockEditorLoaded
        @description "RichBlockEditor rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      onChange : string = "CHANGE"
        @label "On Change"
        @description "onChange prop"
        @tier "presentation"
      changeEvent : string = "CHANGE"
        @label "Change Event"
        @description "changeEvent prop"
        @tier "presentation"
      readOnly : boolean = false
        @label "Read Only"
        @description "readOnly prop"
        @tier "presentation"
      placeholder : string = "Placeholder"
        @label "Placeholder"
        @description "placeholder prop"
        @tier "presentation"
      enableBlocks : boolean = true
        @label "Enable Blocks"
        @description "Opt-in to the Notion-style block authoring chrome (insert toolbar, per-row +/menu gutter, turn-into menu). Off by default: the editor renders as a plain rich text surface that edits block content inline without any add-block affordances."
        @tier "presentation"
      showToolbar : boolean = true
        @label "Show Toolbar"
        @description "showToolbar prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/rich-block-editor" as RichBlockEditorPage -> RichBlockEditorRender
}
