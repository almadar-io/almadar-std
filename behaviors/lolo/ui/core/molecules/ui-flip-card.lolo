app ui-flip-card "1.0.0"
"FlipCard — UI factory (1:1 with the @almadar/ui flip-card pattern)."
orbital FlipCardOrbital {
  entity FlipCardItem [runtime] {
    id : string!
  }

  trait FlipCardRender -> @rebindable FlipCardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          front: @config.front
          back: @config.back
          flipped: @config.flipped
          onFlip: FLIP
          className: @config.className
          height: @config.height
          type: flip-card
        })
    }

    emits {
      FLIP -> external {
        id : string
      }
        @description "Callback when the card is clicked to flip"
        @tier "essential"
    }

    config {
      front : node
        @label "Front"
        @description "Content rendered on the front face"
        @tier "presentation"
      back : node
        @label "Back"
        @description "Content rendered on the back face"
        @tier "presentation"
      flipped : boolean = false
        @label "Flipped"
        @description "Controlled flip state"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Optional className for the outer container"
        @tier "presentation"
      height : string = "h-64"
        @label "Height"
        @description "Card height as a Tailwind class (default: 'h-64')"
        @tier "presentation"
    }
  }

  page "/flip-card" as FlipCardPage -> FlipCardRender
}
