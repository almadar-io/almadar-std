app ui-flip-card "1.0.0"
"FlipCard — flip card that reveals a hidden back face on tap or click, toggling between a front and back content slot. — UI factory (1:1 with the @almadar/ui flip-card pattern)."
;; @capabilities "flashcard, study deck, spaced-repetition review card, memorization drill, quiz reveal card, question/answer card, before/after reveal, term-and-definition card"
orbital FlipCardOrbital {
  entity FlipCardItem [runtime] {
    id : string!
  }

  trait FlipCardRender -> @rebindable FlipCardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          front: @config.front
          back: @config.back
          flipped: @config.flipped
          onFlip: @config.onFlip
          className: @config.className
          height: @config.height
          type: flip-card
        })
    }

    emits {
      @config.onFlip -> external {
        id : string
      }
        @description "Callback when the card is clicked to flip"
        @tier "essential"
    }

    config {
      front : node = []
        @label "Front"
        @description "Content rendered on the front face"
        @tier "presentation"
      back : node = []
        @label "Back"
        @description "Content rendered on the back face"
        @tier "presentation"
      flipped : boolean = false
        @label "Flipped"
        @description "Controlled flip state"
        @tier "presentation"
      onFlip : string = "FLIP"
        @label "On Flip"
        @description "Callback when the card is clicked to flip"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Optional className for the outer container"
        @tier "presentation"
      height : string = "h-64"
        @label "Height"
        @description "Card height as a Tailwind class (default: 'h-64')"
        @tier "presentation"
    }
  }

  page "/flip-card" as FlipCardPage -> FlipCardRender
}
