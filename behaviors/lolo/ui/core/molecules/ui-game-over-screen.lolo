app ui-game-over-screen "1.0.0"
"GameOverScreen — UI factory (1:1 with the @almadar/ui game-over-screen pattern)."
orbital GameOverScreenOrbital {
  type GameOverScreenStatsItem = {
    label : string!
    value : string
    bind : string
    format : "number" | "time" | "text"
    icon : node
  }
  type GameOverScreenActionsItem = {
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
  }
  type GameOverScreenMenuItemsItem = {
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
  }
  type GameOverScreenACTIONAction = {
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
  }

  entity GameOverScreenItem [runtime] {
    id : string!
  }

  trait GameOverScreenRender -> @rebindable GameOverScreenItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          title: @config.title
          message: @config.message
          stats: @config.stats
          actions: @config.actions
          menuItems: @config.menuItems
          onAction: ACTION
          variant: @config.variant
          highScore: @config.highScore
          currentScore: @config.currentScore
          className: @config.className
          type: game-over-screen
        })
    }

    emits {
      ACTION -> external {
        action : GameOverScreenACTIONAction
      }
        @description "Called when an action is selected (legacy callback, prefer event bus)"
        @tier "essential"
    }

    config {
      title : string = "Title"
        @label "Title"
        @description "Screen title (e.g., 'Game Over', 'Victory!')"
        @tier "presentation"
      message : string = ""
        @label "Message"
        @description "Optional message"
        @tier "presentation"
      stats : [GameOverScreenStatsItem] = []
        @label "Stats"
        @description "Stats to display"
        @tier "presentation"
      actions : [GameOverScreenActionsItem] = []
        @label "Actions"
        @description "Action buttons"
        @tier "presentation"
      menuItems : [GameOverScreenMenuItemsItem] = []
        @label "Menu Items"
        @description "Alias for actions (schema compatibility)"
        @tier "presentation"
      variant : "victory" | "defeat" | "neutral" = neutral
        @label "Variant"
        @description "Victory or defeat variant"
        @tier "presentation"
      highScore : string = ""
        @label "High Score"
        @description "High score (optional, shows 'NEW HIGH SCORE!' if exceeded)"
        @tier "presentation"
      currentScore : string = ""
        @label "Current Score"
        @description "Current score for high score comparison (accepts string for schema bindings)"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/game-over-screen" as GameOverScreenPage -> GameOverScreenRender
}
