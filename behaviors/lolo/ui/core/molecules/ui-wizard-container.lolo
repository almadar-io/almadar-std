app ui-wizard-container "1.0.0"
"WizardContainer — UI factory (1:1 with the @almadar/ui wizard-container pattern)."
orbital WizardContainerOrbital {
  type WizardContainerStepsItem = {
    id : string
    tabId : string
    title : string
    name : string
    description : string
    content : node
    optional : boolean
    sections : [WizardContainerStepsItemSectionsItem]
    globalVariablesRequired : [string]
    globalVariablesSet : [string]
    localVariables : [string]
    entityMapping : WizardContainerStepsItemEntityMapping
    validationRules : [WizardContainerStepsItemValidationRulesItem]
    lawReferences : [WizardContainerStepsItemLawReferencesItem]
    phase : string
    contextMenu : [string]
  }
  type WizardContainerStepsItemSectionsItem = {
    id : string!
    title : string
    description : string
    fields : [WizardContainerStepsItemSectionsItemFieldsItem]
    subsections : [json]
    condition : [json]
    repeatable : boolean
    minItems : number
    addButtonLabel : string
    hiddenCalculations : [WizardContainerStepsItemSectionsItemHiddenCalculationsItem]
    dataSource : json
    readOnly : boolean
  }
  type WizardContainerStepsItemSectionsItemFieldsItem = {
    id : string!
    type : string!
    label : string
    required : boolean
    repeatable : boolean
    options : [WizardContainerStepsItemSectionsItemFieldsItemOptionsItem]
    defaultValue : json
    condition : [json]
    placeholder : string
    entityField : string
    minLength : number
    maxLength : number
    dataSource : json
    displayFields : [string]
    searchConfig : json
    hiddenCalculations : [WizardContainerStepsItemSectionsItemFieldsItemHiddenCalculationsItem]
    signatureConfig : json
    displayTemplate : json
    lawReference : json
    contextMenu : [string]
    calculated : json
    readOnly : boolean
    minDate : json
    stats : [WizardContainerStepsItemSectionsItemFieldsItemStatsItem]
    items : [WizardContainerStepsItemSectionsItemFieldsItemItemsItem]
  }
  type WizardContainerStepsItemSectionsItemFieldsItemOptionsItem = {
    value : string!
    label : string!
    isDefault : boolean
  }
  type WizardContainerStepsItemSectionsItemFieldsItemHiddenCalculationsItem = {
    variable : string!
    expression : string!
    scope : string
  }
  type WizardContainerStepsItemSectionsItemFieldsItemStatsItem = {
    label : string!
    value : json!
    icon : string
  }
  type WizardContainerStepsItemSectionsItemFieldsItemItemsItem = {
    id : string!
    label : string!
    autoCheck : json
  }
  type WizardContainerStepsItemSectionsItemHiddenCalculationsItem = {
    variable : string!
    expression : string!
    scope : string
  }
  type WizardContainerStepsItemEntityMapping = {
    entity : string!
    mode : "search_or_create" | "create_multiple" | "select_one" | "update"!
    parentField : string
    idField : string
  }
  type WizardContainerStepsItemValidationRulesItem = {
    condition : [json]!
    message : string!
  }
  type WizardContainerStepsItemLawReferencesItem = {
    law : string!
    article : string!
    description : string
  }
  type WizardContainerError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity WizardContainerItem [runtime] {
    id : string!
  }

  trait WizardContainerRender -> @rebindable WizardContainerItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          steps: @config.steps
          currentStep: @config.currentStep
          onStepChange: @config.onStepChange
          onComplete: @config.onComplete
          showProgress: @config.showProgress
          allowBack: @config.allowBack
          compact: @config.compact
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          nextEvent: @config.nextEvent
          backEvent: @config.backEvent
          completeEvent: @config.completeEvent
          type: wizard-container
        })
    }

    emits {
      @config.onStepChange -> external {
        stepIndex : number
      }
        @description "Callback when step changes"
        @tier "essential"
      @config.onComplete -> external {
        id : string
      }
        @description "Callback when wizard is completed"
        @tier "essential"
      @config.nextEvent -> external {
        id : string
      }
        @description "Emits UI:{nextEvent} when advancing to next step"
        @tier "essential"
      @config.backEvent -> external {
        id : string
      }
        @description "Emits UI:{backEvent} when going to previous step"
        @tier "essential"
    }

    config {
      steps : [WizardContainerStepsItem] = [{ id: "Id", tabId: "Tab Id", title: "Title", name: "Name", description: "Description", content: "Content", optional: false, sections: [{ id: "Id", title: "Title", description: "Description", fields: [{ id: "Id", type: "Type", label: "Label", required: false, repeatable: false, options: [], condition: [], placeholder: "Placeholder", entityField: "Entity Field", minLength: 1, maxLength: 1, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: false, stats: [], items: [] }, { id: "Id 2", type: "Type 2", label: "Label 2", required: true, repeatable: true, options: [], condition: [], placeholder: "Placeholder 2", entityField: "Entity Field 2", minLength: 2, maxLength: 2, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: true, stats: [], items: [] }], subsections: [], condition: [], repeatable: false, minItems: 1, addButtonLabel: "Add Button Label", hiddenCalculations: [{ variable: "Variable", expression: "Expression", scope: "Scope" }, { variable: "Variable 2", expression: "Expression 2", scope: "Scope 2" }], readOnly: false }, { id: "Id 2", title: "Title 2", description: "Description 2", fields: [{ id: "Id", type: "Type", label: "Label", required: false, repeatable: false, options: [], condition: [], placeholder: "Placeholder", entityField: "Entity Field", minLength: 1, maxLength: 1, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: false, stats: [], items: [] }, { id: "Id 2", type: "Type 2", label: "Label 2", required: true, repeatable: true, options: [], condition: [], placeholder: "Placeholder 2", entityField: "Entity Field 2", minLength: 2, maxLength: 2, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: true, stats: [], items: [] }], subsections: [], condition: [], repeatable: true, minItems: 2, addButtonLabel: "Add Button Label 2", hiddenCalculations: [{ variable: "Variable", expression: "Expression", scope: "Scope" }, { variable: "Variable 2", expression: "Expression 2", scope: "Scope 2" }], readOnly: true }], globalVariablesRequired: ["Item", "Item 2"], globalVariablesSet: ["Item", "Item 2"], localVariables: ["Item", "Item 2"], entityMapping: { entity: "Entity", mode: "search_or_create", parentField: "Parent Field", idField: "Id Field" }, validationRules: [{ condition: [], message: "Message" }, { condition: [], message: "Message 2" }], lawReferences: [{ law: "Law", article: "Article", description: "Description" }, { law: "Law 2", article: "Article 2", description: "Description 2" }], phase: "Phase", contextMenu: ["Item", "Item 2"] }, { id: "Id 2", tabId: "Tab Id 2", title: "Title 2", name: "Name 2", description: "Description 2", content: "Content 2", optional: true, sections: [{ id: "Id", title: "Title", description: "Description", fields: [{ id: "Id", type: "Type", label: "Label", required: false, repeatable: false, options: [], condition: [], placeholder: "Placeholder", entityField: "Entity Field", minLength: 1, maxLength: 1, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: false, stats: [], items: [] }, { id: "Id 2", type: "Type 2", label: "Label 2", required: true, repeatable: true, options: [], condition: [], placeholder: "Placeholder 2", entityField: "Entity Field 2", minLength: 2, maxLength: 2, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: true, stats: [], items: [] }], subsections: [], condition: [], repeatable: false, minItems: 1, addButtonLabel: "Add Button Label", hiddenCalculations: [{ variable: "Variable", expression: "Expression", scope: "Scope" }, { variable: "Variable 2", expression: "Expression 2", scope: "Scope 2" }], readOnly: false }, { id: "Id 2", title: "Title 2", description: "Description 2", fields: [{ id: "Id", type: "Type", label: "Label", required: false, repeatable: false, options: [], condition: [], placeholder: "Placeholder", entityField: "Entity Field", minLength: 1, maxLength: 1, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: false, stats: [], items: [] }, { id: "Id 2", type: "Type 2", label: "Label 2", required: true, repeatable: true, options: [], condition: [], placeholder: "Placeholder 2", entityField: "Entity Field 2", minLength: 2, maxLength: 2, displayFields: [], hiddenCalculations: [], contextMenu: [], readOnly: true, stats: [], items: [] }], subsections: [], condition: [], repeatable: true, minItems: 2, addButtonLabel: "Add Button Label 2", hiddenCalculations: [{ variable: "Variable", expression: "Expression", scope: "Scope" }, { variable: "Variable 2", expression: "Expression 2", scope: "Scope 2" }], readOnly: true }], globalVariablesRequired: ["Item", "Item 2"], globalVariablesSet: ["Item", "Item 2"], localVariables: ["Item", "Item 2"], entityMapping: { entity: "Entity 2", mode: "create_multiple", parentField: "Parent Field 2", idField: "Id Field 2" }, validationRules: [{ condition: [], message: "Message" }, { condition: [], message: "Message 2" }], lawReferences: [{ law: "Law", article: "Article", description: "Description" }, { law: "Law 2", article: "Article 2", description: "Description 2" }], phase: "Phase 2", contextMenu: ["Item", "Item 2"] }]
        @label "Steps"
        @description "Wizard steps"
        @tier "presentation"
      currentStep : string = ""
        @label "Current Step"
        @description "Current step index (controlled) - accepts number or string for generated code compatibility"
        @tier "presentation"
      onStepChange : string = "STEP_CHANGE"
        @label "On Step Change"
        @description "Callback when step changes"
        @tier "presentation"
      onComplete : string = "COMPLETE"
        @label "On Complete"
        @description "Callback when wizard is completed"
        @tier "presentation"
      showProgress : boolean = true
        @label "Show Progress"
        @description "Show progress indicator"
        @tier "presentation"
      allowBack : boolean = true
        @label "Allow Back"
        @description "Allow navigation to previous steps"
        @tier "presentation"
      compact : boolean = false
        @label "Compact"
        @description "Modal mode (compact header, no padding)"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : WizardContainerError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      nextEvent : string = "NEXT"
        @label "Next Event"
        @description "Emits UI:{nextEvent} when advancing to next step"
        @tier "presentation"
      backEvent : string = "BACK"
        @label "Back Event"
        @description "Emits UI:{backEvent} when going to previous step"
        @tier "presentation"
      completeEvent : string = "COMPLETE"
        @label "Complete Event"
        @description "Emits UI:{completeEvent} when wizard completes"
        @tier "presentation"
    }
  }

  page "/wizard-container" as WizardContainerPage -> WizardContainerRender
}
