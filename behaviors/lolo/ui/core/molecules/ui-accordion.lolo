app ui-accordion "1.0.0"
"Accordion — UI factory (1:1 with the @almadar/ui accordion pattern)."
orbital AccordionOrbital {
  type AccordionItemsItem = {
    id : string
    header : node
    title : node
    content : node!
    disabled : boolean
    defaultOpen : boolean
  }

  entity AccordionItem [runtime] {
    id : string!
  }

  trait AccordionRender -> @rebindable AccordionItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          multiple: @config.multiple
          defaultOpenItems: @config.defaultOpenItems
          defaultOpen: @config.defaultOpen
          openItems: @config.openItems
          onItemToggle: @config.onItemToggle
          className: @config.className
          toggleEvent: @config.toggleEvent
          type: accordion
        })
    }

    emits {
      @config.onItemToggle -> external {
        itemId : string
        isOpen : boolean
      }
        @description "Callback when item opens/closes"
        @tier "essential"
      @config.toggleEvent -> external {
        itemId : string!
        isOpen : boolean!
      }
        @description "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }"
        @tier "essential"
    }

    config {
      items : [AccordionItemsItem] = [{ id: "Id", header: "Header", title: "Title", content: "Content", disabled: false, defaultOpen: false }, { id: "Id 2", header: "Header 2", title: "Title 2", content: "Content 2", disabled: true, defaultOpen: true }]
        @label "Items"
        @description "Accordion items"
        @tier "presentation"
      multiple : boolean = false
        @label "Multiple"
        @description "Allow multiple items open at once"
        @tier "presentation"
      defaultOpenItems : [string] = []
        @label "Default Open Items"
        @description "Default open items (IDs)"
        @tier "presentation"
      defaultOpen : [number] = []
        @label "Default Open"
        @description "Default open items by index (pattern compatibility)"
        @tier "presentation"
      openItems : [string] = []
        @label "Open Items"
        @description "Controlled open items (IDs)"
        @tier "presentation"
      onItemToggle : string = "ITEM_TOGGLE"
        @label "On Item Toggle"
        @description "Callback when item opens/closes"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      toggleEvent : string = "TOGGLE"
        @label "Toggle Event"
        @description "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }"
        @tier "presentation"
    }
  }

  page "/accordion" as AccordionPage -> AccordionRender
}
