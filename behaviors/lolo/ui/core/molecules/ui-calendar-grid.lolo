app ui-calendar-grid "1.0.0"
"CalendarGrid — UI factory (1:1 with the @almadar/ui calendar-grid pattern)."
orbital CalendarGridOrbital {
  type CalendarGridEVENTCLICKEvent = {
    id : string!
    title : string!
    startTime : date!
    endTime : date
    color : string
  }

  entity CalendarGridItem [runtime] {
    id : string!
    title : string = ""
    startTime : date
    endTime : date
    color : string = ""
  }

  trait CalendarGridRender -> @rebindable CalendarGridItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch CalendarGridItem {})
        (render-ui main {
          weekStart: @config.weekStart
          timeSlots: @config.timeSlots
          events: @entity
          onSlotClick: SLOT_CLICK
          onDayClick: DAY_CLICK
          onEventClick: EVENT_CLICK
          className: @config.className
          longPressEvent: LONG_PRESS
          longPressPayload: @config.longPressPayload
          swipeLeftEvent: SWIPE_LEFT
          swipeRightEvent: SWIPE_RIGHT
          dayWindow: @config.dayWindow
          type: calendar-grid
        })
    }

    emits {
      SLOT_CLICK -> external {
        day : date
        time : string
      }
        @description "Called when a time slot is clicked"
        @tier "essential"
      DAY_CLICK -> external {
        day : date
      }
        @description "Called when a day header is clicked"
        @tier "essential"
      EVENT_CLICK -> external {
        event : CalendarGridEVENTCLICKEvent
      }
        @description "Called when an event is clicked"
        @tier "essential"
      LONG_PRESS -> external {
        date : string!
        time : string
      }
        @description "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }"
        @tier "essential"
      SWIPE_LEFT -> external {
        id : string
      }
        @description "Event emitted on swipe left (next week): UI:{swipeLeftEvent}"
        @tier "essential"
      SWIPE_RIGHT -> external {
        id : string
      }
        @description "Event emitted on swipe right (prev week): UI:{swipeRightEvent}"
        @tier "essential"
    }

    config {
      weekStart : date
        @label "Week Start"
        @description "Start of the week (defaults to current week's Monday)"
        @tier "presentation"
      timeSlots : [string] = []
        @label "Time Slots"
        @description "Time slot labels (defaults to 09:00-17:00)"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      longPressPayload : json
        @label "Long Press Payload"
        @description "Additional payload for long-press events"
        @tier "presentation"
      dayWindow : "auto"
        @label "Day Window"
        @description "Override the viewport-driven day window. `'auto'` (default) tracks `window.innerWidth` — 1 day on mobile, 3 on tablet, 7 on laptop+. Pass an explicit number to force a fixed window (useful for print layouts or screenshot tests)."
        @tier "presentation"
    }
  }

  page "/calendar-grid" as CalendarGridPage -> CalendarGridRender
}
