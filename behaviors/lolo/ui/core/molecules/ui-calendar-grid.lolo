app ui-calendar-grid "1.0.0"
"CalendarGrid — UI factory (1:1 with the @almadar/ui calendar-grid pattern)."
orbital CalendarGridOrbital {
    type CalendarGridLoaded = Event { data : [CalendarGridItem] } "CalendarGrid rows finished loading; payload.data holds the collection"

  entity CalendarGridItem [runtime] {
    id : string!
    title : string = "Title"
    startTime : string = "Start Time"
    endTime : string = "End Time"
    color : string = "Color"
  }

  trait CalendarGridRender -> @rebindable CalendarGridItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch CalendarGridItem { emit: { success: CalendarGridLoaded } })
        (render-ui main {
          weekStart: @config.weekStart
          timeSlots: @config.timeSlots
          events: @entity
          onSlotClick: @config.onSlotClick
          onDayClick: @config.onDayClick
          onEventClick: @config.onEventClick
          className: @config.className
          longPressEvent: @config.longPressEvent
          longPressPayload: @config.longPressPayload
          swipeLeftEvent: @config.swipeLeftEvent
          swipeRightEvent: @config.swipeRightEvent
          dayWindow: @config.dayWindow
          type: calendar-grid
        })
      CalendarGridLoaded -> idle
        (render-ui main {
          weekStart: @config.weekStart
          timeSlots: @config.timeSlots
          events: @payload.data
          onSlotClick: @config.onSlotClick
          onDayClick: @config.onDayClick
          onEventClick: @config.onEventClick
          className: @config.className
          longPressEvent: @config.longPressEvent
          longPressPayload: @config.longPressPayload
          swipeLeftEvent: @config.swipeLeftEvent
          swipeRightEvent: @config.swipeRightEvent
          dayWindow: @config.dayWindow
          type: calendar-grid
        })
    }

    emits {
      SLOT_CLICK -> external {
        day : date
        time : string
      }
        @description "Called when a time slot is clicked"
        @tier "essential"
      DAY_CLICK -> external {
        day : date
      }
        @description "Called when a day header is clicked"
        @tier "essential"
      EVENT_CLICK -> external {
        event : object
      }
        @description "Called when an event is clicked"
        @tier "essential"
      LONG_PRESS -> external {
        date : string!
        time : string
      }
        @description "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }"
        @tier "essential"
      SWIPE_LEFT -> external {
        id : string
      }
        @description "Event emitted on swipe left (next week): UI:{swipeLeftEvent}"
        @tier "essential"
      SWIPE_RIGHT -> external {
        id : string
      }
        @description "Event emitted on swipe right (prev week): UI:{swipeRightEvent}"
        @tier "essential"
      CalendarGridLoaded
        @description "CalendarGrid rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      weekStart : date = "2024-01-01"
        @label "Week Start"
        @description "Start of the week (defaults to current week's Monday)"
        @tier "presentation"
      timeSlots : [string] = []
        @label "Time Slots"
        @description "Time slot labels (defaults to 09:00-17:00)"
        @tier "presentation"
      onSlotClick : string = "SLOT_CLICK"
        @label "On Slot Click"
        @description "Called when a time slot is clicked"
        @tier "presentation"
      onDayClick : string = "DAY_CLICK"
        @label "On Day Click"
        @description "Called when a day header is clicked"
        @tier "presentation"
      onEventClick : string = "EVENT_CLICK"
        @label "On Event Click"
        @description "Called when an event is clicked"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      longPressEvent : string = "LONG_PRESS"
        @label "Long Press Event"
        @description "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }"
        @tier "presentation"
      longPressPayload : json = {}
        @label "Long Press Payload"
        @description "Additional payload for long-press events"
        @tier "presentation"
      swipeLeftEvent : string = "SWIPE_LEFT"
        @label "Swipe Left Event"
        @description "Event emitted on swipe left (next week): UI:{swipeLeftEvent}"
        @tier "presentation"
      swipeRightEvent : string = "SWIPE_RIGHT"
        @label "Swipe Right Event"
        @description "Event emitted on swipe right (prev week): UI:{swipeRightEvent}"
        @tier "presentation"
      dayWindow : "auto"
        @label "Day Window"
        @description "Override the viewport-driven day window. `'auto'` (default) tracks `window.innerWidth` — 1 day on mobile, 3 on tablet, 7 on laptop+. Pass an explicit number to force a fixed window (useful for print layouts or screenshot tests)."
        @tier "presentation"
    }
  }

  page "/calendar-grid" as CalendarGridPage -> CalendarGridRender
}
