app ui-unit-command-bar "1.0.0"
"UnitCommandBar — UI factory (1:1 with the @almadar/ui unit-command-bar pattern)."
orbital UnitCommandBarOrbital {
  type UnitCommandBarCommandsItem = {
    label : string!
    icon : node
    event : string
    disabled : boolean
    hotkey : string
  }

  entity UnitCommandBarItem [runtime] {
    id : string!
  }

  trait UnitCommandBarRender -> @rebindable UnitCommandBarItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          commands: @config.commands
          selectedUnitId: @config.selectedUnitId
          className: @config.className
          type: unit-command-bar
        })
    }

    config {
      commands : [UnitCommandBarCommandsItem] = []
        @label "Commands"
        @description "Available commands"
        @tier "presentation"
      selectedUnitId : string = ""
        @label "Selected Unit Id"
        @description "ID of the currently selected unit"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/unit-command-bar" as UnitCommandBarPage -> UnitCommandBarRender
}
