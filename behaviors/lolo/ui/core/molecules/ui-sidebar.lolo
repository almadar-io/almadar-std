app ui-sidebar "1.0.0"
"Sidebar — UI factory (1:1 with the @almadar/ui sidebar pattern)."
orbital SidebarOrbital {
  type SidebarError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type SidebarItemsItem = {
    id : string!
    label : string!
    icon : icon
    badge : string
    href : string
    active : boolean
    isActive : boolean
    subItems : [json]
  }

  entity SidebarItem [runtime] {
    id : string!
    collapsed : boolean
  }

  trait SidebarRender -> @rebindable SidebarItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.collapsed @config.collapsed)
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          logo: @config.logo
          logoSrc: @config.logoSrc
          brandName: @config.brandName
          items: @config.items
          userSection: @config.userSection
          footerContent: @config.footerContent
          collapsed: @entity.collapsed
          defaultCollapsed: @config.defaultCollapsed
          collapseChangeEvent: @config.collapseChangeEvent
          hideCollapseButton: @config.hideCollapseButton
          showCloseButton: @config.showCloseButton
          closeEvent: @config.closeEvent
          logoClickEvent: @config.logoClickEvent
          type: sidebar
        })
      COLLAPSE_CHANGE -> idle
        (set @entity.collapsed ?collapsed)
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          logo: @config.logo
          logoSrc: @config.logoSrc
          brandName: @config.brandName
          items: @config.items
          userSection: @config.userSection
          footerContent: @config.footerContent
          collapsed: @entity.collapsed
          defaultCollapsed: @config.defaultCollapsed
          collapseChangeEvent: @config.collapseChangeEvent
          hideCollapseButton: @config.hideCollapseButton
          showCloseButton: @config.showCloseButton
          closeEvent: @config.closeEvent
          logoClickEvent: @config.logoClickEvent
          type: sidebar
        })
    }

    emits {
      @config.collapseChangeEvent -> external {
        collapsed : boolean!
      }
        @description "Event emitted when collapse state changes, payload: { collapsed: boolean }"
        @tier "essential"
      @config.closeEvent -> external {
        id : string
      }
        @description "Event emitted when close button is clicked"
        @tier "essential"
      @config.logoClickEvent -> external {
        id : string
      }
        @description "Event emitted when logo/brand is clicked"
        @tier "essential"
    }

    listens {
      COLLAPSE_CHANGE {
        collapsed : boolean!
      }
    }

    config {
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : SidebarError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      logo : node
        @label "Logo"
        @description "Logo/Brand content - can be a ReactNode or logo config"
        @tier "presentation"
      logoSrc : asset = "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
        @label "Logo Src"
        @description "Logo image source"
        @tier "presentation"
      brandName : string = KFlow
        @label "Brand Name"
        @description "Brand/App name"
        @tier "presentation"
      items : [SidebarItemsItem] = [{ id: "Id", label: "Label", icon: "circle", badge: "Badge", href: "Href", active: false, isActive: false, subItems: [] }, { id: "Id 2", label: "Label 2", icon: "circle", badge: "Badge 2", href: "Href 2", active: true, isActive: true, subItems: [] }]
        @label "Items"
        @description "Navigation items"
        @tier "presentation"
      userSection : node
        @label "User Section"
        @description "User section content"
        @tier "presentation"
      footerContent : node
        @label "Footer Content"
        @description "Footer content (e.g., theme toggle)"
        @tier "presentation"
      collapsed : boolean
        @label "Collapsed"
        @description "Collapsed state (controlled)"
        @tier "presentation"
      defaultCollapsed : boolean = false
        @label "Default Collapsed"
        @description "Default collapsed state"
        @tier "presentation"
      collapseChangeEvent : string = "COLLAPSE_CHANGE"
        @label "Collapse Change Event"
        @description "Event emitted when collapse state changes, payload: { collapsed: boolean }"
        @tier "presentation"
      hideCollapseButton : boolean = false
        @label "Hide Collapse Button"
        @description "Hide the collapse/expand button"
        @tier "presentation"
      showCloseButton : boolean = false
        @label "Show Close Button"
        @description "Show a close button (for mobile)"
        @tier "presentation"
      closeEvent : string = "CLOSE"
        @label "Close Event"
        @description "Event emitted when close button is clicked"
        @tier "presentation"
      logoClickEvent : string = "LOGO_CLICK"
        @label "Logo Click Event"
        @description "Event emitted when logo/brand is clicked"
        @tier "presentation"
    }
  }

  page "/sidebar" as SidebarPage -> SidebarRender
}
