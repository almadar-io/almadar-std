app ui-reflection-block "1.0.0"
"ReflectionBlock — UI factory (1:1 with the @almadar/ui reflection-block pattern)."
orbital ReflectionBlockOrbital {
  entity ReflectionBlockItem [runtime] {
    id : string!
  }

  trait ReflectionBlockRender -> @rebindable ReflectionBlockItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          prompt: @config.prompt
          index: @config.index
          savedNote: @config.savedNote
          saveEvent: @config.saveEvent
          className: @config.className
          type: reflection-block
        })
    }

    config {
      prompt : string = "Prompt"
        @label "Prompt"
        @description "The reflection prompt"
        @tier "presentation"
      index : number = 1
        @label "Index"
        @description "Zero-based index of this block (used in the emitted event payload)"
        @tier "presentation"
      savedNote : string = "Saved Note"
        @label "Saved Note"
        @description "Pre-filled note from saved state"
        @tier "presentation"
      saveEvent : string = "SAVE_REFLECTION"
        @label "Save Event"
        @description "Event name emitted on save (as `UI:<saveEvent>`). Defaults to 'SAVE_REFLECTION'."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/reflection-block" as ReflectionBlockPage -> ReflectionBlockRender
}
