app ui-navigation "1.0.0"
"Navigation — UI factory (1:1 with the @almadar/ui navigation pattern)."
orbital NavigationOrbital {
  type NavigationItemsItem = {
    id : string!
    label : string!
    icon : icon
    badge : string
    href : string
    isActive : boolean
    disabled : boolean
    subMenu : [json]
  }
  type NavigationError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity NavigationItem [runtime] {
    id : string!
  }

  trait NavigationRender -> @rebindable NavigationItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          orientation: @config.orientation
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          type: navigation
        })
    }

    config {
      items : [NavigationItemsItem] = [{ id: "Id", label: "Label", icon: "circle", badge: "Badge", href: "Href", isActive: false, disabled: false, subMenu: [] }, { id: "Id 2", label: "Label 2", icon: "circle", badge: "Badge 2", href: "Href 2", isActive: true, disabled: true, subMenu: [] }]
        @label "Items"
        @description "Navigation items"
        @tier "presentation"
      orientation : "horizontal" | "vertical" = horizontal
        @label "Orientation"
        @description "Navigation orientation"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : NavigationError
        @label "Error"
        @description "Error state"
        @tier "presentation"
    }
  }

  page "/navigation" as NavigationPage -> NavigationRender
}
