app ui-sortable-list "1.0.0"
"SortableList — UI factory (1:1 with the @almadar/ui sortable-list pattern)."
orbital SortableListOrbital {
    type SortableListLoaded = Event { data : [SortableListItem] } "SortableList rows finished loading; payload.data holds the collection"

  entity SortableListItem [runtime] {
    id : string!
  }

  trait SortableListRender -> @rebindable SortableListItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch SortableListItem { emit: { success: SortableListLoaded } })
        (render-ui main {
          items: @entity
          renderItem: (fn item { content: @item.id, type: typography })
          reorderEvent: @config.reorderEvent
          reorderPayload: @config.reorderPayload
          dragHandlePosition: @config.dragHandlePosition
          className: @config.className
          type: sortable-list
        })
      SortableListLoaded -> idle
        (render-ui main {
          items: @payload.data
          renderItem: (fn item { content: @item.id, type: typography })
          reorderEvent: @config.reorderEvent
          reorderPayload: @config.reorderPayload
          dragHandlePosition: @config.dragHandlePosition
          className: @config.className
          type: sortable-list
        })
    }

    emits {
      @config.reorderEvent -> external {
        id : string
      }
        @description "reorderEvent prop"
        @tier "essential"
      SortableListLoaded
        @description "SortableList rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      reorderEvent : string = "REORDER"
        @label "Reorder Event"
        @description "reorderEvent prop"
        @tier "presentation"
      reorderPayload : json = {}
        @label "Reorder Payload"
        @description "reorderPayload prop"
        @tier "presentation"
      dragHandlePosition : "left" | "right" = left
        @label "Drag Handle Position"
        @description "dragHandlePosition prop"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/sortable-list" as SortableListPage -> SortableListRender
}
