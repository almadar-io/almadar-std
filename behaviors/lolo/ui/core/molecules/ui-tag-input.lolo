app ui-tag-input "1.0.0"
"TagInput — UI factory (1:1 with the @almadar/ui tag-input pattern)."
orbital TagInputOrbital {
  entity TagInputItem [runtime] {
    id : string!
  }

  trait TagInputRender -> @rebindable TagInputItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          value: @config.value
          onChange: @config.onChange
          placeholder: @config.placeholder
          disabled: @config.disabled
          variant: @config.variant
          unique: @config.unique
          helperText: @config.helperText
          className: @config.className
          addEvent: @config.addEvent
          removeEvent: @config.removeEvent
          type: tag-input
        })
    }

    emits {
      @config.onChange -> external {
        next : [object]
      }
        @description "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below."
        @tier "essential"
      @config.addEvent -> external {
        id : string
      }
        @description "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`."
        @tier "essential"
      @config.removeEvent -> external {
        id : string
      }
        @description "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`."
        @tier "essential"
    }

    config {
      value : [string] = ["Item", "Item 2"]
        @label "Value"
        @description "Current list of tags."
        @tier "presentation"
      onChange : string = "CHANGE"
        @label "On Change"
        @description "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below."
        @tier "presentation"
      placeholder : string = "Placeholder"
        @label "Placeholder"
        @description "Placeholder for the entry input. Default: `'Type and press Enter…'`."
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "Disable add + remove interactions."
        @tier "presentation"
      variant : "default" | "primary" | "secondary" | "success" | "warning" | "danger" | "error" | "info" | "neutral" = default
        @label "Variant"
        @description "Variant applied to each chip Badge. Default: `'default'`."
        @tier "presentation"
      unique : boolean = true
        @label "Unique"
        @description "Suppress duplicate entries. Default: `true`."
        @tier "presentation"
      helperText : string = "Helper Text"
        @label "Helper Text"
        @description "Helper text rendered under the input."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes applied to the outer container."
        @tier "presentation"
      addEvent : string = "ADD"
        @label "Add Event"
        @description "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`."
        @tier "presentation"
      removeEvent : string = "REMOVE"
        @label "Remove Event"
        @description "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`."
        @tier "presentation"
    }
  }

  page "/tag-input" as TagInputPage -> TagInputRender
}
