app ui-positioned-canvas "1.0.0"
"PositionedCanvas — UI factory (1:1 with the @almadar/ui positioned-canvas pattern)."
orbital PositionedCanvasOrbital {
    type PositionedCanvasLoaded = Event { data : [PositionedCanvasItem] } "PositionedCanvas rows finished loading; payload.data holds the collection"

  entity PositionedCanvasItem [runtime] {
    id : string!
    label : string = "Label"
    x : number = 1
    y : number = 1
    capacity : number = 1
    partySize : number = 1
    serverName : string = "Server Name"
    status : "empty" | "seated" | "ordered" | "awaiting-bill" | "cleaning" = empty
    shape : "round" | "rectangle" | "square" = round
  }

  trait PositionedCanvasRender -> @rebindable PositionedCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch PositionedCanvasItem { emit: { success: PositionedCanvasLoaded } })
        (render-ui main {
          items: @entity
          width: @config.width
          height: @config.height
          selectedId: @config.selectedId
          editable: @config.editable
          onSelect: SELECT
          onMove: MOVE
          selectEvent: SELECT
          moveEvent: MOVE
          className: @config.className
          type: positioned-canvas
        })
      PositionedCanvasLoaded -> idle
        (render-ui main {
          items: @payload.data
          width: @config.width
          height: @config.height
          selectedId: @config.selectedId
          editable: @config.editable
          onSelect: SELECT
          onMove: MOVE
          selectEvent: SELECT
          moveEvent: MOVE
          className: @config.className
          type: positioned-canvas
        })
    }

    emits {
      SELECT -> external {
        id : string
      }
        @description "onSelect prop"
        @tier "domain"
      MOVE -> external {
        id : string
        x : number
        y : number
      }
        @description "onMove prop"
        @tier "domain"
      PositionedCanvasLoaded
        @description "PositionedCanvas rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "domain"
    }

    config {
      width : number = 800
        @label "Width"
        @description "width prop"
        @tier "presentation"
      height : number = 600
        @label "Height"
        @description "height prop"
        @tier "presentation"
      selectedId : string = ""
        @label "Selected Id"
        @description "selectedId prop"
        @tier "presentation"
      editable : boolean = false
        @label "Editable"
        @description "editable prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/positioned-canvas" as PositionedCanvasPage -> PositionedCanvasRender
}
