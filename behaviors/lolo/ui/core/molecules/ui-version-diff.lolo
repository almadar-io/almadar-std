app ui-version-diff "1.0.0"
"VersionDiff — UI factory (1:1 with the @almadar/ui version-diff pattern)."
orbital VersionDiffOrbital {
  type VersionDiffRevisionsItem = {
    id : string!
    label : string!
    author : string
    timestamp : string
    content : string!
  }

  entity VersionDiffItem [runtime] {
    id : string!
  }

  trait VersionDiffRender -> @rebindable VersionDiffItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          revisions: @config.revisions
          beforeId: @config.beforeId
          afterId: @config.afterId
          view: @config.view
          onSelectBefore: @config.onSelectBefore
          onSelectAfter: @config.onSelectAfter
          onRevert: @config.onRevert
          selectBeforeEvent: @config.selectBeforeEvent
          selectAfterEvent: @config.selectAfterEvent
          revertEvent: @config.revertEvent
          language: @config.language
          className: @config.className
          type: version-diff
        })
    }

    emits {
      SELECT_BEFORE -> external {
        id : string
      }
        @description "Called when the user picks a different 'before' revision."
        @tier "essential"
      SELECT_AFTER -> external {
        id : string
      }
        @description "Called when the user picks a different 'after' revision."
        @tier "essential"
      REVERT -> external {
        id : string
      }
        @description "Called when the user clicks the revert button (passes the 'before' id)."
        @tier "essential"
    }

    config {
      revisions : [VersionDiffRevisionsItem] = [{ id: "Id", label: "Label", author: "Author", timestamp: "Timestamp", content: "Content" }, { id: "Id 2", label: "Label 2", author: "Author 2", timestamp: "Timestamp 2", content: "Content 2" }]
        @label "Revisions"
        @description "All available revisions (at least 2). Accepts either a typed array (direct consumers) or the runtime payload shape from a render-ui binding (`@payload.revisions`). Narrowed to `[]` internally when the value isn't an array."
        @tier "presentation"
      beforeId : string = "Before Id"
        @label "Before Id"
        @description "Currently selected 'before' revision id."
        @tier "presentation"
      afterId : string = "After Id"
        @label "After Id"
        @description "Currently selected 'after' revision id."
        @tier "presentation"
      view : "side-by-side" | "inline" = "side-by-side"
        @label "View"
        @description "Display mode."
        @tier "presentation"
      onSelectBefore : string = "SELECT_BEFORE"
        @label "On Select Before"
        @description "Called when the user picks a different 'before' revision."
        @tier "presentation"
      onSelectAfter : string = "SELECT_AFTER"
        @label "On Select After"
        @description "Called when the user picks a different 'after' revision."
        @tier "presentation"
      onRevert : string = "REVERT"
        @label "On Revert"
        @description "Called when the user clicks the revert button (passes the 'before' id)."
        @tier "presentation"
      selectBeforeEvent : string = "SELECT_BEFORE"
        @label "Select Before Event"
        @description "Event name dispatched via event bus when the 'before' revision changes. Payload: { id }."
        @tier "presentation"
      selectAfterEvent : string = "SELECT_AFTER"
        @label "Select After Event"
        @description "Event name dispatched via event bus when the 'after' revision changes. Payload: { id }."
        @tier "presentation"
      revertEvent : string = "REVERT"
        @label "Revert Event"
        @description "Event name dispatched via event bus when the user clicks revert. Payload: { id }."
        @tier "presentation"
      language : string = "Language"
        @label "Language"
        @description "Language label (informational)."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes."
        @tier "presentation"
    }
  }

  page "/version-diff" as VersionDiffPage -> VersionDiffRender
}
