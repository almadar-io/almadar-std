app ui-header "1.0.0"
"Header — UI factory (1:1 with the @almadar/ui header pattern)."
orbital HeaderOrbital {
  type HeaderNavigationItemsItem = {
    label : string!
    href : string
    icon : icon
    badge : string
    active : boolean
  }
  type HeaderUserAvatar = {
    src : asset
    alt : string
    initials : string
  }
  type HeaderError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity HeaderItem [runtime] {
    id : string!
  }

  trait HeaderRender -> @rebindable HeaderItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          logo: @config.logo
          logoSrc: @config.logoSrc
          brandName: @config.brandName
          navigationItems: @config.navigationItems
          showMenuToggle: @config.showMenuToggle
          isMenuOpen: @config.isMenuOpen
          onMenuToggle: @config.onMenuToggle
          showSearch: @config.showSearch
          searchPlaceholder: @config.searchPlaceholder
          onSearch: @config.onSearch
          userAvatar: @config.userAvatar
          userName: @config.userName
          onUserClick: @config.onUserClick
          actions: @config.actions
          sticky: @config.sticky
          variant: @config.variant
          look: @config.look
          onLogoClick: @config.onLogoClick
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          type: header
        })
    }

    emits {
      @config.onMenuToggle -> external {
        id : string
      }
        @description "Menu toggle callback"
        @tier "essential"
      @config.onSearch -> external {
        value : string
      }
        @description "Search callback"
        @tier "essential"
      @config.onUserClick -> external {
        id : string
      }
        @description "Callback when user avatar is clicked"
        @tier "essential"
      @config.onLogoClick -> external {
        id : string
      }
        @description "Callback when logo/brand is clicked"
        @tier "essential"
    }

    config {
      logo : node
        @label "Logo"
        @description "Logo/Brand content"
        @tier "presentation"
      logoSrc : asset = "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
        @label "Logo Src"
        @description "Logo image source"
        @tier "presentation"
      brandName : string = KFlow
        @label "Brand Name"
        @description "Brand/App name"
        @tier "presentation"
      navigationItems : [HeaderNavigationItemsItem] = []
        @label "Navigation Items"
        @description "Navigation items (for desktop header variant)"
        @tier "presentation"
      showMenuToggle : boolean = true
        @label "Show Menu Toggle"
        @description "Show menu toggle button"
        @tier "presentation"
      isMenuOpen : boolean = false
        @label "Is Menu Open"
        @description "Is menu open (for toggle icon)"
        @tier "presentation"
      onMenuToggle : string = "MENU_TOGGLE"
        @label "On Menu Toggle"
        @description "Menu toggle callback"
        @tier "presentation"
      showSearch : boolean = false
        @label "Show Search"
        @description "Show search input"
        @tier "presentation"
      searchPlaceholder : string
        @label "Search Placeholder"
        @description "Search placeholder"
        @tier "presentation"
      onSearch : string = "SEARCH"
        @label "On Search"
        @description "Search callback"
        @tier "presentation"
      userAvatar : HeaderUserAvatar
        @label "User Avatar"
        @description "User avatar configuration"
        @tier "presentation"
      userName : string
        @label "User Name"
        @description "User name (display name or email)"
        @tier "presentation"
      onUserClick : string = "USER_CLICK"
        @label "On User Click"
        @description "Callback when user avatar is clicked"
        @tier "presentation"
      actions : node
        @label "Actions"
        @description "Action buttons (right side)"
        @tier "presentation"
      sticky : boolean = true
        @label "Sticky"
        @description "Sticky header"
        @tier "presentation"
      variant : "mobile" | "desktop" = mobile
        @label "Variant"
        @description "Variant - mobile shows menu toggle, desktop shows full nav"
        @tier "presentation"
      look : "hero" | "compact-bar" | "breadcrumb" | "contextual" | "editorial-banner" = "compact-bar"
        @label "Look"
        @description "Layer 2 visual treatment — orthogonal to the structural variant (which currently flips mobile vs desktop)."
        @tier "presentation"
      onLogoClick : string = "LOGO_CLICK"
        @label "On Logo Click"
        @description "Callback when logo/brand is clicked"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean
        @label "Is Loading"
        @description "Loading state indicator (closed circuit)"
        @tier "presentation"
      error : HeaderError
        @label "Error"
        @description "Error state (closed circuit)"
        @tier "presentation"
    }
  }

  page "/header" as HeaderPage -> HeaderRender
}
