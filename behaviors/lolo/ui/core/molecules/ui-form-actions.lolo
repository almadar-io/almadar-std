app ui-form-actions "1.0.0"
"FormActions — UI factory (1:1 with the @almadar/ui form-actions pattern)."
orbital FormActionsOrbital {
  type FormActionsError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity FormActionsItem [runtime] {
    id : string!
  }

  trait FormActionsRender -> @rebindable FormActionsItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          children: @config.children
          sticky: @config.sticky
          align: @config.align
          type: form-actions
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : FormActionsError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = ""
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = ""
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      children : node
        @label "Children"
        @description "children prop"
        @tier "presentation"
      sticky : boolean = false
        @label "Sticky"
        @description "Sticky at bottom"
        @tier "presentation"
      align : "left" | "right" | "between" | "center" = right
        @label "Align"
        @description "Alignment"
        @tier "presentation"
    }
  }

  page "/form-actions" as FormActionsPage -> FormActionsRender
}
