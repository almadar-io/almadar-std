app ui-vote-stack "1.0.0"
"VoteStack — UI factory (1:1 with the @almadar/ui vote-stack pattern)."
orbital VoteStackOrbital {
  entity VoteStackItem [runtime] {
    id : string!
  }

  trait VoteStackRender -> @rebindable VoteStackItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          count: @config.count
          userVote: @config.userVote
          onVote: @config.onVote
          voteEvent: @config.voteEvent
          disabled: @config.disabled
          size: @config.size
          variant: @config.variant
          className: @config.className
          label: @config.label
          type: vote-stack
        })
    }

    emits {
      @config.onVote -> external {
        next : string
      }
        @description "Toggle handler. Clicking the same arrow clears (emits null)."
        @tier "essential"
    }

    config {
      count : number = 1
        @label "Count"
        @description "Current tally"
        @tier "presentation"
      userVote : "up" | "down" | "none" = up
        @label "User Vote"
        @description "Current user's vote (null = no vote cast)"
        @tier "presentation"
      onVote : string = "VOTE"
        @label "On Vote"
        @description "Toggle handler. Clicking the same arrow clears (emits null)."
        @tier "presentation"
      voteEvent : string = "VOTE"
        @label "Vote Event"
        @description "Event name dispatched on the bus when a vote is cast. Payload: { next: VoteValue }."
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "Disabled state"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      variant : "vertical" | "horizontal" = vertical
        @label "Variant"
        @description "Layout orientation. `vertical` = forum/Q&A column; `horizontal` = compact row."
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      label : string = ""
        @label "Label"
        @description "Accessible label for the group"
        @tier "presentation"
    }
  }

  page "/vote-stack" as VoteStackPage -> VoteStackRender
}
