app ui-input-group "1.0.0"
"InputGroup — UI factory (1:1 with the @almadar/ui input-group pattern)."
orbital InputGroupOrbital {
  type InputGroupOptionsItem = {
    value : string!
    label : string!
  }

  entity InputGroupItem [runtime] {
    id : string!
  }

  trait InputGroupRender -> @rebindable InputGroupItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          className: @config.className
          placeholder: @config.placeholder
          value: @config.value
          disabled: @config.disabled
          action: @config.action
          inputType: @config.inputType
          label: @config.label
          helperText: @config.helperText
          error: @config.error
          leftIcon: @config.leftIcon
          rightIcon: @config.rightIcon
          clearable: @config.clearable
          onClear: @config.onClear
          options: @config.options
          rows: @config.rows
          onChange: @config.onChange
          leftAddon: @config.leftAddon
          rightAddon: @config.rightAddon
          type: input-group
        })
    }

    emits {
      @config.action -> external {
        id : string
      }
        @description "Declarative event name for trait dispatch"
        @tier "essential"
      @config.onClear -> external {
        id : string
      }
        @description "Callback or declarative event key when clear button is clicked"
        @tier "essential"
      @config.onChange -> external {
        id : string
      }
        @description "onChange handler or declarative event key for trait dispatch"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      placeholder : string = ""
        @label "Placeholder"
        @description "Placeholder text"
        @tier "presentation"
      value : string = ""
        @label "Value"
        @description "Current value"
        @tier "presentation"
      disabled : boolean = false
        @label "Disabled"
        @description "Whether input is disabled"
        @tier "presentation"
      action : string = "ACTION"
        @label "Action"
        @description "Declarative event name for trait dispatch"
        @tier "presentation"
      inputType : "text" | "email" | "password" | "number" | "tel" | "url" | "search" | "date" | "datetime-local" | "time" | "checkbox" | "select" | "textarea" = text
        @label "Input Type"
        @description "Input type - supports 'select' and 'textarea' in addition to standard types"
        @tier "presentation"
      label : string = ""
        @label "Label"
        @description "label prop"
        @tier "presentation"
      helperText : string = ""
        @label "Helper Text"
        @description "helperText prop"
        @tier "presentation"
      error : string = ""
        @label "Error"
        @description "error prop"
        @tier "presentation"
      leftIcon : icon
        @label "Left Icon"
        @description "leftIcon prop"
        @tier "presentation"
      rightIcon : icon
        @label "Right Icon"
        @description "rightIcon prop"
        @tier "presentation"
      clearable : boolean = false
        @label "Clearable"
        @description "Show clear button when input has value"
        @tier "presentation"
      onClear : string = "CLEAR"
        @label "On Clear"
        @description "Callback or declarative event key when clear button is clicked"
        @tier "presentation"
      options : [InputGroupOptionsItem] = [{ value: "Value", label: "Label" }, { value: "Value 2", label: "Label 2" }]
        @label "Options"
        @description "Options for select type"
        @tier "presentation"
      rows : number = 0
        @label "Rows"
        @description "Rows for textarea type"
        @tier "presentation"
      onChange : string = "CHANGE"
        @label "On Change"
        @description "onChange handler or declarative event key for trait dispatch"
        @tier "presentation"
      leftAddon : node
        @label "Left Addon"
        @description "Left addon (icon, button, or text)"
        @tier "presentation"
      rightAddon : node
        @label "Right Addon"
        @description "Right addon (icon, button, or text)"
        @tier "presentation"
    }
  }

  page "/input-group" as InputGroupPage -> InputGroupRender
}
