app ui-tabs "1.0.0"
"Tabs — UI factory (1:1 with the @almadar/ui tabs pattern)."
orbital TabsOrbital {
  type TabsItemsItem = {
    id : string
    value : string
    label : string!
    content : node
    icon : icon
    iconAsset : TabsItemsItemIconAsset
    badge : string
    disabled : boolean
    event : string
    active : boolean
  }
  type TabsItemsItemIconAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }
  type TabsTabsItem = {
    id : string
    value : string
    label : string!
    content : node
    icon : icon
    iconAsset : TabsTabsItemIconAsset
    badge : string
    disabled : boolean
    event : string
    active : boolean
  }
  type TabsTabsItemIconAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity TabsItem [runtime] {
    id : string!
  }

  trait TabsRender -> @rebindable TabsItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          tabs: @config.tabs
          defaultActiveTab: @config.defaultActiveTab
          activeTab: @config.activeTab
          onTabChange: TAB_CHANGE
          tabChangeEvent: TAB_CHANGE
          variant: @config.variant
          orientation: @config.orientation
          className: @config.className
          type: tabs
        })
    }

    emits {
      TAB_CHANGE -> external {
        tabId : string
      }
        @description "Callback when tab changes"
        @tier "essential"
    }

    config {
      items : [TabsItemsItem] = [{ id: "Id", value: "Value", label: "Label", content: "Content", icon: "circle", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "iconAsset", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "iconAsset", thumbnailUrl: "" }, badge: "Badge", disabled: false, active: false }, { id: "Id 2", value: "Value 2", label: "Label 2", content: "Content 2", icon: "circle", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "iconAsset", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "iconAsset", thumbnailUrl: "" }, badge: "Badge 2", disabled: true, active: true }]
        @label "Items"
        @description "Tab items"
        @tier "presentation"
      tabs : [TabsTabsItem] = [{ id: "Id", value: "Value", label: "Label", content: "Content", icon: "circle", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "iconAsset", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "iconAsset", thumbnailUrl: "" }, badge: "Badge", disabled: false, active: false }, { id: "Id 2", value: "Value 2", label: "Label 2", content: "Content 2", icon: "circle", iconAsset: { url: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", role: "npc", category: "iconAsset", animations: ["idle", "walk", "attack", "hit", "death"], style: "", dimension: "2d", aspect: "1:1", name: "iconAsset", thumbnailUrl: "" }, badge: "Badge 2", disabled: true, active: true }]
        @label "Tabs"
        @description "Tab items (alias for items - used by generated code)"
        @tier "presentation"
      defaultActiveTab : string = "Default Active Tab"
        @label "Default Active Tab"
        @description "Default active tab ID"
        @tier "presentation"
      activeTab : string = "Active Tab"
        @label "Active Tab"
        @description "Controlled active tab ID"
        @tier "presentation"
      variant : "default" | "pills" | "underline" = default
        @label "Variant"
        @description "Tab variant"
        @tier "presentation"
      orientation : "horizontal" | "vertical" = horizontal
        @label "Orientation"
        @description "Tab orientation"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/tabs" as TabsPage -> TabsRender
}
