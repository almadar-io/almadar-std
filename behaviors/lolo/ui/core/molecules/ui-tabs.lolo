app ui-tabs "1.0.0"
"Tabs — UI factory (1:1 with the @almadar/ui tabs pattern)."
orbital TabsOrbital {
  type TabsItemsItem = {
    id : string
    value : string
    label : string!
    content : node
    icon : icon
    iconAsset : TabsItemsItemIconAsset
    badge : string
    disabled : boolean
    event : string
    active : boolean
  }
  type TabsItemsItemIconAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }
  type TabsTabsItem = {
    id : string
    value : string
    label : string!
    content : node
    icon : icon
    iconAsset : TabsTabsItemIconAsset
    badge : string
    disabled : boolean
    event : string
    active : boolean
  }
  type TabsTabsItemIconAsset = {
    url : asset!
    role : "player" | "enemy" | "npc" | "item" | "tile" | "projectile" | "effect" | "ui" | "decoration" | "vehicle"
    category : string
    animations : [string]
    style : "pixel" | "vector" | "hd" | "1-bit" | "isometric"
    dimension : "2d" | "3d"
    aspect : "1:1" | "16:9" | "5:7" | "8:1"
    name : string
    thumbnailUrl : string
  }

  entity TabsItem [runtime] {
    id : string!
  }

  trait TabsRender -> @rebindable TabsItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          tabs: @config.tabs
          defaultActiveTab: @config.defaultActiveTab
          activeTab: @config.activeTab
          onTabChange: @config.onTabChange
          tabChangeEvent: @config.tabChangeEvent
          variant: @config.variant
          orientation: @config.orientation
          className: @config.className
          type: tabs
        })
    }

    emits {
      @config.onTabChange -> external {
        tabId : string
      }
        @description "Callback when tab changes"
        @tier "essential"
    }

    config {
      items : [TabsItemsItem] = []
        @label "Items"
        @description "Tab items"
        @tier "presentation"
      tabs : [TabsTabsItem] = []
        @label "Tabs"
        @description "Tab items (alias for items - used by generated code)"
        @tier "presentation"
      defaultActiveTab : string
        @label "Default Active Tab"
        @description "Default active tab ID"
        @tier "presentation"
      activeTab : string
        @label "Active Tab"
        @description "Controlled active tab ID"
        @tier "presentation"
      onTabChange : string = "TAB_CHANGE"
        @label "On Tab Change"
        @description "Callback when tab changes"
        @tier "presentation"
      tabChangeEvent : string = "TAB_CHANGE"
        @label "Tab Change Event"
        @description "Declarative tab change event — emits UI:{tabChangeEvent} with { tabId }"
        @tier "presentation"
      variant : "default" | "pills" | "underline" = default
        @label "Variant"
        @description "Tab variant"
        @tier "presentation"
      orientation : "horizontal" | "vertical" = horizontal
        @label "Orientation"
        @description "Tab orientation"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/tabs" as TabsPage -> TabsRender
}
