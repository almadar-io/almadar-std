app ui-form-section-header "1.0.0"
"FormSectionHeader — UI factory (1:1 with the @almadar/ui form-section-header pattern)."
orbital FormSectionHeaderOrbital {
  entity FormSectionHeaderItem [runtime] {
    id : string!
  }

  trait FormSectionHeaderRender -> @rebindable FormSectionHeaderItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          title: @config.title
          subtitle: @config.subtitle
          isCollapsed: @config.isCollapsed
          onToggle: @config.onToggle
          badge: @config.badge
          badgeVariant: @config.badgeVariant
          icon: @config.icon
          hasErrors: @config.hasErrors
          isComplete: @config.isComplete
          className: @config.className
          type: form-section-header
        })
    }

    emits {
      @config.onToggle -> external {
        id : string
      }
        @description "Toggle collapse handler (makes header clickable)"
        @tier "essential"
    }

    config {
      title : string = "Title"
        @label "Title"
        @description "Section title"
        @tier "presentation"
      subtitle : string = "Subtitle"
        @label "Subtitle"
        @description "Section subtitle"
        @tier "presentation"
      isCollapsed : boolean = false
        @label "Is Collapsed"
        @description "Whether section is collapsed"
        @tier "presentation"
      onToggle : string = "TOGGLE"
        @label "On Toggle"
        @description "Toggle collapse handler (makes header clickable)"
        @tier "presentation"
      badge : string = "Badge"
        @label "Badge"
        @description "Badge text (e.g., '3 fields', 'Required', 'Complete')"
        @tier "presentation"
      badgeVariant : "default" | "primary" | "success" | "warning" | "danger" = default
        @label "Badge Variant"
        @description "Badge variant"
        @tier "presentation"
      icon : icon = "circle"
        @label "Icon"
        @description "Lucide icon name or component to show before title"
        @tier "presentation"
      hasErrors : boolean = false
        @label "Has Errors"
        @description "Whether section has validation errors"
        @tier "presentation"
      isComplete : boolean = false
        @label "Is Complete"
        @description "Whether section is complete"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/form-section-header" as FormSectionHeaderPage -> FormSectionHeaderRender
}
