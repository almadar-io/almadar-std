app ui-data-grid "1.0.0"
"DataGrid — UI factory (1:1 with the @almadar/ui data-grid pattern)."
orbital DataGridOrbital {
    type DataGridLoaded = Event { data : [DataGridItem] } "DataGrid rows finished loading; payload.data holds the collection"
  type DataGridFieldsItem = {
    name : string!
    label : string
    icon : icon
    variant : "h3" | "h4" | "body" | "caption" | "badge" | "small" | "progress"
    format : "date" | "currency" | "number" | "boolean" | "percent"
    colorMap : Map string string
  }
  type DataGridColumnsItem = {
    name : string!
    label : string
    icon : icon
    variant : "h3" | "h4" | "body" | "caption" | "badge" | "small" | "progress"
    format : "date" | "currency" | "number" | "boolean" | "percent"
    colorMap : Map string string
  }
  type DataGridItemActionsItem = {
    label : string!
    event : string!
    icon : icon
    variant : "primary" | "secondary" | "ghost" | "danger"
  }
  type DataGridError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity DataGridItem [runtime] {
    id : string!
  }

  trait DataGridRender -> @rebindable DataGridItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch DataGridItem { emit: { success: DataGridLoaded } })
        (render-ui main {
          dragGroup: @config.dragGroup
          accepts: @config.accepts
          sortable: @config.sortable
          dropEvent: @config.dropEvent
          reorderEvent: @config.reorderEvent
          positionEvent: @config.positionEvent
          dndItemIdField: @config.dndItemIdField
          dndRoot: @config.dndRoot
          entity: @entity
          fields: @config.fields
          columns: @config.columns
          itemActions: @config.itemActions
          maxInlineActions: @config.maxInlineActions
          scrollX: @config.scrollX
          cols: @config.cols
          gap: @config.gap
          minCardWidth: @config.minCardWidth
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          imageField: @config.imageField
          selectable: @config.selectable
          selectionEvent: @config.selectionEvent
          infiniteScroll: @config.infiniteScroll
          loadMoreEvent: @config.loadMoreEvent
          hasMore: @config.hasMore
          pageSize: @config.pageSize
          look: @config.look
          type: data-grid
        })
      DataGridLoaded -> idle
        (render-ui main {
          dragGroup: @config.dragGroup
          accepts: @config.accepts
          sortable: @config.sortable
          dropEvent: @config.dropEvent
          reorderEvent: @config.reorderEvent
          positionEvent: @config.positionEvent
          dndItemIdField: @config.dndItemIdField
          dndRoot: @config.dndRoot
          entity: @payload.data
          fields: @config.fields
          columns: @config.columns
          itemActions: @config.itemActions
          maxInlineActions: @config.maxInlineActions
          scrollX: @config.scrollX
          cols: @config.cols
          gap: @config.gap
          minCardWidth: @config.minCardWidth
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          imageField: @config.imageField
          selectable: @config.selectable
          selectionEvent: @config.selectionEvent
          infiniteScroll: @config.infiniteScroll
          loadMoreEvent: @config.loadMoreEvent
          hasMore: @config.hasMore
          pageSize: @config.pageSize
          look: @config.look
          type: data-grid
        })
      VIEW -> idle
        (emit VIEW {})
    }

    emits {
      @config.selectionEvent -> external {
        id : string
      }
        @description "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })"
        @tier "essential"
      @config.loadMoreEvent -> external {
        id : string
      }
        @description "Event emitted when more items needed: UI:{loadMoreEvent}"
        @tier "essential"
      VIEW -> external {
        id : string
      }
        @description "User opened a record from the list."
        @tier "essential"
      DataGridLoaded
        @description "DataGrid rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      dragGroup : string
        @label "Drag Group"
        @description "When set, items in this container are draggable and announce this group as their source"
        @tier "presentation"
      accepts : string
        @label "Accepts"
        @description "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)"
        @tier "presentation"
      sortable : boolean
        @label "Sortable"
        @description "Enable in-container reorder; items can be dragged to new positions among siblings"
        @tier "presentation"
      dropEvent : string
        @label "Drop Event"
        @description "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }"
        @tier "presentation"
      reorderEvent : string
        @label "Reorder Event"
        @description "Bus event fired on in-container reorder. Payload: { id, oldIndex, newIndex }"
        @tier "presentation"
      positionEvent : string
        @label "Position Event"
        @description "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }"
        @tier "presentation"
      dndItemIdField : string
        @label "Dnd Item Id Field"
        @description "Row field used as the @dnd-kit draggable id (default 'id')"
        @tier "presentation"
      dndRoot : boolean
        @label "Dnd Root"
        @description "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable."
        @tier "presentation"
      fields : [DataGridFieldsItem] = []
        @label "Fields"
        @description "Field definitions for rendering each card. The pattern contract in `@almadar/core/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either."
        @tier "presentation"
      columns : [DataGridColumnsItem] = []
        @label "Columns"
        @description "Alias for `fields` — the compiler emits `columns` for field defs."
        @tier "presentation"
      itemActions : json = []
        @tier "presentation"
      maxInlineActions : number
        @label "Max Inline Actions"
        @description "Max inline primary action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline."
        @tier "presentation"
      scrollX : boolean = false
        @label "Scroll X"
        @description "Lay items in a single horizontally-scrolling row (kanban columns) sized to `minCardWidth` instead of a wrapping grid."
        @tier "presentation"
      cols : number = 1
        @label "Cols"
        @description "Number of columns (uses auto-fit if omitted)"
        @tier "presentation"
      gap : "none" | "sm" | "md" | "lg" | "xl" = md
        @label "Gap"
        @description "Gap between cards"
        @tier "presentation"
      minCardWidth : number = 280
        @label "Min Card Width"
        @description "Minimum card width in pixels (used when cols is not set, default 280)"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : DataGridError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      imageField : string
        @label "Image Field"
        @description "Entity field name containing an image URL for card thumbnails"
        @tier "presentation"
      selectable : boolean = false
        @label "Selectable"
        @description "Enable multi-select with checkboxes"
        @tier "presentation"
      selectionEvent : string = "SELECTION"
        @label "Selection Event"
        @description "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })"
        @tier "presentation"
      infiniteScroll : boolean
        @label "Infinite Scroll"
        @description "Enable infinite scroll loading"
        @tier "presentation"
      loadMoreEvent : string = "LOAD_MORE"
        @label "Load More Event"
        @description "Event emitted when more items needed: UI:{loadMoreEvent}"
        @tier "presentation"
      hasMore : boolean
        @label "Has More"
        @description "Whether more items are available for infinite scroll"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Max items to show before 'Show More' button. Defaults to 0 (disabled)."
        @tier "presentation"
      look : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Look"
        @description "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors."
        @tier "presentation"
    }
  }

  page "/data-grid" as DataGridPage -> DataGridRender
}
