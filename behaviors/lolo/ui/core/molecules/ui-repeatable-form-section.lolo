app ui-repeatable-form-section "1.0.0"
"RepeatableFormSection — a form section that repeats a fixed group of fields, letting the user add or remove entries. — UI factory (1:1 with the @almadar/ui repeatable-form-section pattern)."
;; @capabilities "dynamic line items, repeatable field group, add/remove entry rows, multi-entry form block"
orbital RepeatableFormSectionOrbital {
  type RepeatableFormSectionItemsItem = {
    id : string!
    addedInState : string
    addedAt : string
  }

  entity RepeatableFormSectionItem [runtime] {
    id : string!
  }

  trait RepeatableFormSectionRender -> @rebindable RepeatableFormSectionItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          sectionType: @config.sectionType
          title: @config.title
          items: @config.items
          renderItem: (fn item { content: @item.id, type: typography })
          minItems: @config.minItems
          maxItems: @config.maxItems
          allowReorder: @config.allowReorder
          addLabel: @config.addLabel
          emptyMessage: @config.emptyMessage
          readOnly: @config.readOnly
          className: @config.className
          onAdd: @config.onAdd
          onRemove: @config.onRemove
          onReorder: @config.onReorder
          trackAddedInState: @config.trackAddedInState
          currentState: @config.currentState
          showAuditInfo: @config.showAuditInfo
          type: repeatable-form-section
        })
    }

    emits {
      @config.onAdd -> external {
        id : string
      }
        @description "Add handler"
        @tier "essential"
      @config.onRemove -> external {
        itemId : string
        index : number
      }
        @description "Remove handler"
        @tier "essential"
      @config.onReorder -> external {
        fromIndex : number
        toIndex : number
      }
        @description "Reorder handler"
        @tier "essential"
    }

    config {
      sectionType : string = ""
        @label "Section Type"
        @description "Section type identifier"
        @tier "presentation"
      title : string = ""
        @label "Title"
        @description "Section title"
        @tier "presentation"
      items : [RepeatableFormSectionItemsItem] = [{ id: "Id", addedInState: "Added In State", addedAt: "Added At" }, { id: "Id 2", addedInState: "Added In State 2", addedAt: "Added At 2" }]
        @label "Items"
        @description "Items in the section"
        @tier "presentation"
      minItems : number = 0
        @label "Min Items"
        @description "Minimum items required"
        @tier "presentation"
      maxItems : number
        @label "Max Items"
        @description "Maximum items allowed"
        @tier "presentation"
      allowReorder : boolean = false
        @label "Allow Reorder"
        @description "Allow reordering"
        @tier "presentation"
      addLabel : string
        @label "Add Label"
        @description "Add button label"
        @tier "presentation"
      emptyMessage : string
        @label "Empty Message"
        @description "Empty state message"
        @tier "presentation"
      readOnly : boolean = false
        @label "Read Only"
        @description "Read-only mode"
        @tier "presentation"
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      onAdd : string = "ADD"
        @label "On Add"
        @description "Add handler"
        @tier "presentation"
      onRemove : string = "REMOVE"
        @label "On Remove"
        @description "Remove handler"
        @tier "presentation"
      onReorder : string = "REORDER"
        @label "On Reorder"
        @description "Reorder handler"
        @tier "presentation"
      trackAddedInState : boolean = false
        @label "Track Added In State"
        @description "Inspection-specific enhancements"
        @tier "presentation"
      currentState : string
        @label "Current State"
        @description "Current inspection state (used when trackAddedInState is true)"
        @tier "presentation"
      showAuditInfo : boolean = false
        @label "Show Audit Info"
        @description "Show audit metadata (addedInState, addedAt)"
        @tier "presentation"
    }
  }

  page "/repeatable-form-section" as RepeatableFormSectionPage -> RepeatableFormSectionRender
}
