app ui-graph-canvas "1.0.0"
"GraphCanvas — UI factory (1:1 with the @almadar/ui graph-canvas pattern)."
orbital GraphCanvasOrbital {
  type GraphCanvasNodesItem = {
    id : string!
    label : string
    group : string
    color : string
    size : number
    x : number
    y : number
  }
  type GraphCanvasEdgesItem = {
    source : string!
    target : string!
    label : string
    weight : number
    color : string
  }
  type GraphCanvasActionsItem = {
    label : string!
    event : string
    navigatesTo : string
    variant : "primary" | "secondary" | "ghost"
  }
  type GraphCanvasError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type GraphCanvasNODECLICKNode = {
    id : string!
    label : string
    group : string
    color : string
    size : number
    x : number
    y : number
  }
  type GraphCanvasNODEDOUBLECLICKNode = {
    id : string!
    label : string
    group : string
    color : string
    size : number
    x : number
    y : number
  }

  entity GraphCanvasItem [runtime] {
    id : string!
  }

  trait GraphCanvasRender -> @rebindable GraphCanvasItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          title: @config.title
          nodes: @config.nodes
          edges: @config.edges
          height: @config.height
          showLabels: @config.showLabels
          interactive: @config.interactive
          draggable: @config.draggable
          actions: @config.actions
          onNodeClick: @config.onNodeClick
          onNodeDoubleClick: @config.onNodeDoubleClick
          nodeClickEvent: @config.nodeClickEvent
          selectedNodeId: @config.selectedNodeId
          repulsion: @config.repulsion
          linkDistance: @config.linkDistance
          nodeSpacing: @config.nodeSpacing
          linkOpacity: @config.linkOpacity
          layout: @config.layout
          isLoading: @config.isLoading
          error: @config.error
          className: @config.className
          type: graph-canvas
        })
    }

    emits {
      @config.onNodeClick -> external {
        node : GraphCanvasNODECLICKNode
        id : string!
      }
        @description "On node click"
        @tier "essential"
      @config.onNodeDoubleClick -> external {
        node : GraphCanvasNODEDOUBLECLICKNode
      }
        @description "On node double-click (e.g. to drill in)"
        @tier "essential"
    }

    config {
      title : string = "Title"
        @label "Title"
        @description "Graph title"
        @tier "presentation"
      nodes : [GraphCanvasNodesItem] = [{ id: "Id", label: "Label", group: "Group", color: "Color", size: 1, x: 1, y: 1 }, { id: "Id 2", label: "Label 2", group: "Group 2", color: "Color 2", size: 2, x: 2, y: 2 }]
        @label "Nodes"
        @description "Graph nodes"
        @tier "presentation"
      edges : [GraphCanvasEdgesItem] = [{ source: "Source", target: "Target", label: "Label", weight: 1, color: "Color" }, { source: "Source 2", target: "Target 2", label: "Label 2", weight: 2, color: "Color 2" }]
        @label "Edges"
        @description "Graph edges"
        @tier "presentation"
      height : number = 400
        @label "Height"
        @description "Canvas height"
        @tier "presentation"
      showLabels : boolean = true
        @label "Show Labels"
        @description "Show node labels"
        @tier "presentation"
      interactive : boolean = true
        @label "Interactive"
        @description "Enable zoom/pan"
        @tier "presentation"
      draggable : boolean = true
        @label "Draggable"
        @description "Enable node dragging"
        @tier "presentation"
      actions : [GraphCanvasActionsItem] = [{ label: "Label", navigatesTo: "Navigates To", variant: primary }, { label: "Label 2", navigatesTo: "Navigates To 2", variant: secondary }]
        @label "Actions"
        @description "Actions"
        @tier "presentation"
      onNodeClick : string = "NODE_CLICK"
        @label "On Node Click"
        @description "On node click"
        @tier "presentation"
      onNodeDoubleClick : string = "NODE_DOUBLE_CLICK"
        @label "On Node Double Click"
        @description "On node double-click (e.g. to drill in)"
        @tier "presentation"
      nodeClickEvent : string = "NODE_CLICK"
        @label "Node Click Event"
        @description "Node click event"
        @tier "presentation"
      selectedNodeId : string = "Selected Node Id"
        @label "Selected Node Id"
        @description "Currently selected node id (rendered emphasized)"
        @tier "presentation"
      repulsion : number = 800
        @label "Repulsion"
        @description "Force-sim repulsion strength between nodes (larger ⇒ more spread out)"
        @tier "presentation"
      linkDistance : number = 100
        @label "Link Distance"
        @description "Force-sim target edge length (larger ⇒ more spread out)"
        @tier "presentation"
      nodeSpacing : number = 28
        @label "Node Spacing"
        @description "Minimum empty gap (px) enforced between node edges so nodes never overlap."
        @tier "presentation"
      linkOpacity : number = 0.18
        @label "Link Opacity"
        @description "Base opacity for links when nothing is hovered (kept faint so dense graphs stay readable; incident links brighten on hover)."
        @tier "presentation"
      layout : "force" | "circular" | "grid" = force
        @label "Layout"
        @description "Layout algorithm"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state"
        @tier "presentation"
      error : GraphCanvasError
        @label "Error"
        @description "Error state"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/graph-canvas" as GraphCanvasPage -> GraphCanvasRender
}
