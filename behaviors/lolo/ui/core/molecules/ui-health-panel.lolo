app ui-health-panel "1.0.0"
"HealthPanel — UI factory (1:1 with the @almadar/ui health-panel pattern)."
orbital HealthPanelOrbital {
  entity HealthPanelItem [runtime] {
    id : string!
  }

  trait HealthPanelRender -> @rebindable HealthPanelItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          current: @config.current
          max: @config.max
          shield: @config.shield
          label: @config.label
          effects: @config.effects
          showNumbers: @config.showNumbers
          size: @config.size
          className: @config.className
          type: health-panel
        })
    }

    config {
      current : number = 0
        @label "Current"
        @description "Current health value"
        @tier "presentation"
      max : number = 0
        @label "Max"
        @description "Maximum health value"
        @tier "presentation"
      shield : number = 0
        @label "Shield"
        @description "Shield/armor points"
        @tier "presentation"
      label : string = ""
        @label "Label"
        @description "Label shown above the bar"
        @tier "presentation"
      effects : [json] = []
        @label "Effects"
        @description "Active status effects displayed as small badges"
        @tier "presentation"
      showNumbers : boolean = true
        @label "Show Numbers"
        @description "Whether to display numeric HP values"
        @tier "presentation"
      size : "sm" | "md" | "lg" = md
        @label "Size"
        @description "Size variant"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
    }
  }

  page "/health-panel" as HealthPanelPage -> HealthPanelRender
}
