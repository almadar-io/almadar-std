app ui-inventory-panel "1.0.0"
"InventoryPanel — UI factory (1:1 with the @almadar/ui inventory-panel pattern)."
orbital InventoryPanelOrbital {
  entity InventoryPanelItem [runtime] {
    id : string!
  }

  trait InventoryPanelRender -> @rebindable InventoryPanelItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          items: @config.items
          slots: @config.slots
          columns: @config.columns
          selectedSlot: @config.selectedSlot
          onSelectSlot: SELECT_SLOT
          onUseItem: USE_ITEM
          onDropItem: DROP_ITEM
          selectSlotEvent: SELECT_SLOT
          useItemEvent: USE_ITEM
          dropItemEvent: DROP_ITEM
          showTooltips: @config.showTooltips
          className: @config.className
          slotSize: @config.slotSize
          type: inventory-panel
        })
    }

    emits {
      SELECT_SLOT -> external {
        index : number
      }
        @description "Called when a slot is selected"
        @tier "essential"
      USE_ITEM -> external {
        item : object
      }
        @description "Called when an item is used (double-click or Enter)"
        @tier "essential"
      DROP_ITEM -> external {
        item : object
      }
        @description "Called when an item is dropped"
        @tier "essential"
    }

    config {
      items : [json] = []
        @label "Items"
        @description "Array of items in inventory"
        @tier "presentation"
      slots : number = 0
        @label "Slots"
        @description "Total number of slots"
        @tier "presentation"
      columns : number = 0
        @label "Columns"
        @description "Number of columns in grid"
        @tier "presentation"
      selectedSlot : number = 0
        @label "Selected Slot"
        @description "Currently selected slot index"
        @tier "presentation"
      showTooltips : boolean = true
        @label "Show Tooltips"
        @description "Show item tooltips on hover"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Optional className"
        @tier "presentation"
      slotSize : number = 48
        @label "Slot Size"
        @description "Slot size in pixels"
        @tier "presentation"
    }
  }

  page "/inventory-panel" as InventoryPanelPage -> InventoryPanelRender
}
