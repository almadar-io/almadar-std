app ui-module-card "1.0.0"
"ModuleCard — UI factory (1:1 with the @almadar/ui module-card pattern)."
orbital ModuleCardOrbital {
  type ModuleCardData = {
    orbitalName : string!
    entityName : string!
    persistence : string!
    fields : [ModuleCardDataFieldsItem]!
    traits : [ModuleCardDataTraitsItem]!
    pages : [ModuleCardDataPagesItem]!
    traitDetails : Map string ModuleCardDataTraitDetailsValue!
    externalLinks : [ModuleCardDataExternalLinksItem]!
  }
  type ModuleCardDataFieldsItem = {
    name : string!
    type : string!
    required : boolean!
    hasDefault : boolean!
  }
  type ModuleCardDataTraitsItem = {
    name : string!
    stateCount : number!
    eventCount : number!
    transitionCount : number!
    emits : [string]!
    listens : [string]!
  }
  type ModuleCardDataPagesItem = {
    name : string!
    route : string!
  }
  type ModuleCardDataTraitDetailsValue = {
    name : string!
    linkedEntity : string!
    states : [ModuleCardDataTraitDetailsValueStatesItem]!
    transitions : [ModuleCardDataTraitDetailsValueTransitionsItem]!
    emittedEvents : [string]!
    listenedEvents : [string]!
  }
  type ModuleCardDataTraitDetailsValueStatesItem = {
    name : string!
    isInitial : boolean
    isTerminal : boolean
  }
  type ModuleCardDataTraitDetailsValueTransitionsItem = {
    from : string!
    to : string!
    event : string!
    guard : json
    effects : [ModuleCardDataTraitDetailsValueTransitionsItemEffectsItem]!
    index : number!
  }
  type ModuleCardDataTraitDetailsValueTransitionsItemEffectsItem = {
    type : string!
    args : [json]!
  }
  type ModuleCardDataExternalLinksItem = {
    targetOrbital : string!
    eventName : string!
    direction : "out" | "in"!
    traitName : string!
  }

  entity ModuleCardItem [runtime] {
    id : string!
  }

  trait ModuleCardRender -> @rebindable ModuleCardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          data: @config.data
          type: module-card
        })
    }

    config {
      data : ModuleCardData = { orbitalName: "Orbital Name", entityName: "Entity Name", persistence: "Persistence", fields: [{ name: "Name", type: "Type", required: false, hasDefault: false }], traits: [{ name: "Name", stateCount: 1, eventCount: 1, transitionCount: 1, emits: ["Item"], listens: ["Item"] }], pages: [{ name: "Name", route: "Route" }], traitDetails: {}, externalLinks: [{ targetOrbital: "Target Orbital", eventName: "Event Name", direction: out, traitName: "Trait Name" }] }
        @label "Data"
        @description "data prop"
        @tier "presentation"
    }
  }

  page "/module-card" as ModuleCardPage -> ModuleCardRender
}
