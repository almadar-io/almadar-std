app ui-module-card "1.0.0"
"ModuleCard — a card summarizing one course module or lesson with progress and entry point."
;; @capabilities "course module card, lesson card, curriculum unit card, learning-path step card"
orbital ModuleCardOrbital {
  entity ModuleCardItem [runtime] {
    id : string!
  }

  trait ModuleCardRender -> @rebindable ModuleCardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          data: @config.data
          type: module-card
        })
    }

    config {
      data : json = {}
        @label "Data"
        @description "data prop"
        @tier "presentation"
    }
  }

  page "/module-card" as ModuleCardPage -> ModuleCardRender
}
