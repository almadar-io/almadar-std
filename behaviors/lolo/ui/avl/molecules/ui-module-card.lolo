app ui-module-card "1.0.0"
"ModuleCard — UI factory (1:1 with the @almadar/ui module-card pattern)."
orbital ModuleCardOrbital {
  type ModuleCardData = {
    orbitalName : string!
    entityName : string!
    persistence : string!
    fields : [ModuleCardDataFieldsItem]!
    traits : [ModuleCardDataTraitsItem]!
    pages : [ModuleCardDataPagesItem]!
    traitDetails : json!
    externalLinks : [ModuleCardDataExternalLinksItem]!
  }
  type ModuleCardDataFieldsItem = {
    name : string!
    type : string!
    required : boolean!
    hasDefault : boolean!
  }
  type ModuleCardDataTraitsItem = {
    name : string!
    stateCount : number!
    eventCount : number!
    transitionCount : number!
    emits : [string]!
    listens : [string]!
  }
  type ModuleCardDataPagesItem = {
    name : string!
    route : string!
  }
  type ModuleCardDataExternalLinksItem = {
    targetOrbital : string!
    eventName : string!
    direction : string!
    traitName : string!
  }

  entity ModuleCardItem [runtime] {
    id : string!
  }

  trait ModuleCardRender -> @rebindable ModuleCardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          data: @config.data
          type: module-card
        })
    }

    config {
      data : ModuleCardData = { orbitalName: "Orbital Name", entityName: "Entity Name", persistence: "Persistence", fields: [{ name: "Name", type: "Type", required: false, hasDefault: false }, { name: "Name 2", type: "Type 2", required: true, hasDefault: true }], traits: [{ name: "Name", stateCount: 1, eventCount: 1, transitionCount: 1, emits: ["Item", "Item 2"], listens: ["Item", "Item 2"] }, { name: "Name 2", stateCount: 2, eventCount: 2, transitionCount: 2, emits: ["Item", "Item 2"], listens: ["Item", "Item 2"] }], pages: [{ name: "Name", route: "Route" }, { name: "Name 2", route: "Route 2" }], traitDetails: {}, externalLinks: [{ targetOrbital: "Target Orbital", eventName: "Event Name", direction: "Direction", traitName: "Trait Name" }, { targetOrbital: "Target Orbital 2", eventName: "Event Name 2", direction: "Direction 2", traitName: "Trait Name 2" }] }
        @label "Data"
        @description "data prop"
        @tier "presentation"
    }
  }

  page "/module-card" as ModuleCardPage -> ModuleCardRender
}
