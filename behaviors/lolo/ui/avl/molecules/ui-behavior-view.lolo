app ui-behavior-view "1.0.0"
"BehaviorView — UI factory (1:1 with the @almadar/ui behavior-view pattern)."
orbital BehaviorViewOrbital {
  type BehaviorViewData = {
    orbitalName : string!
    entityName : string!
    persistence : string!
    fields : [BehaviorViewDataFieldsItem]!
    traits : [BehaviorViewDataTraitsItem]!
    pages : [BehaviorViewDataPagesItem]!
    traitDetails : Map string BehaviorViewDataTraitDetailsValue!
    externalLinks : [BehaviorViewDataExternalLinksItem]!
  }
  type BehaviorViewDataFieldsItem = {
    name : string!
    type : string!
    required : boolean!
    hasDefault : boolean!
  }
  type BehaviorViewDataTraitsItem = {
    name : string!
    stateCount : number!
    eventCount : number!
    transitionCount : number!
    emits : [string]!
    listens : [string]!
  }
  type BehaviorViewDataPagesItem = {
    name : string!
    route : string!
  }
  type BehaviorViewDataTraitDetailsValue = {
    name : string!
    linkedEntity : string!
    states : [BehaviorViewDataTraitDetailsValueStatesItem]!
    transitions : [BehaviorViewDataTraitDetailsValueTransitionsItem]!
    emittedEvents : [string]!
    listenedEvents : [string]!
  }
  type BehaviorViewDataTraitDetailsValueStatesItem = {
    name : string!
    isInitial : boolean
    isTerminal : boolean
  }
  type BehaviorViewDataTraitDetailsValueTransitionsItem = {
    from : string!
    to : string!
    event : string!
    guard : json
    effects : [BehaviorViewDataTraitDetailsValueTransitionsItemEffectsItem]!
    index : number!
  }
  type BehaviorViewDataTraitDetailsValueTransitionsItemEffectsItem = {
    type : string!
    args : [json]!
  }
  type BehaviorViewDataExternalLinksItem = {
    targetOrbital : string!
    eventName : string!
    direction : "out" | "in"!
    traitName : string!
  }

  entity BehaviorViewItem [runtime] {
    id : string!
  }

  trait BehaviorViewRender -> @rebindable BehaviorViewItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          data: @config.data
          type: behavior-view
        })
    }

    config {
      data : BehaviorViewData = { orbitalName: "", entityName: "", persistence: "", fields: [], traits: [], pages: [], traitDetails: {}, externalLinks: [] }
        @label "Data"
        @description "data prop"
        @tier "presentation"
    }
  }

  page "/behavior-view" as BehaviorViewPage -> BehaviorViewRender
}
