app ui-behavior-view "1.0.0"
"BehaviorView — UI factory (1:1 with the @almadar/ui behavior-view pattern)."
orbital BehaviorViewOrbital {
  type BehaviorViewData = {
    orbitalName : string!
    entityName : string!
    persistence : string!
    fields : [BehaviorViewDataFieldsItem]!
    traits : [BehaviorViewDataTraitsItem]!
    pages : [BehaviorViewDataPagesItem]!
    traitDetails : json!
    externalLinks : [BehaviorViewDataExternalLinksItem]!
  }
  type BehaviorViewDataFieldsItem = {
    name : string!
    type : string!
    required : boolean!
    hasDefault : boolean!
  }
  type BehaviorViewDataTraitsItem = {
    name : string!
    stateCount : number!
    eventCount : number!
    transitionCount : number!
    emits : [string]!
    listens : [string]!
  }
  type BehaviorViewDataPagesItem = {
    name : string!
    route : string!
  }
  type BehaviorViewDataExternalLinksItem = {
    targetOrbital : string!
    eventName : string!
    direction : string!
    traitName : string!
  }

  entity BehaviorViewItem [runtime] {
    id : string!
  }

  trait BehaviorViewRender -> @rebindable BehaviorViewItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          data: @config.data
          type: behavior-view
        })
    }

    config {
      data : BehaviorViewData = { orbitalName: "Orbital Name", entityName: "Entity Name", persistence: "Persistence", fields: [{ name: "Name", type: "Type", required: false, hasDefault: false }, { name: "Name 2", type: "Type 2", required: true, hasDefault: true }], traits: [{ name: "Name", stateCount: 1, eventCount: 1, transitionCount: 1, emits: ["Item", "Item 2"], listens: ["Item", "Item 2"] }, { name: "Name 2", stateCount: 2, eventCount: 2, transitionCount: 2, emits: ["Item", "Item 2"], listens: ["Item", "Item 2"] }], pages: [{ name: "Name", route: "Route" }, { name: "Name 2", route: "Route 2" }], traitDetails: {}, externalLinks: [{ targetOrbital: "Target Orbital", eventName: "Event Name", direction: "Direction", traitName: "Trait Name" }, { targetOrbital: "Target Orbital 2", eventName: "Event Name 2", direction: "Direction 2", traitName: "Trait Name 2" }] }
        @label "Data"
        @description "data prop"
        @tier "presentation"
    }
  }

  page "/behavior-view" as BehaviorViewPage -> BehaviorViewRender
}
