app std-marketing-steps "1.0.0"
"Step flow atom for marketing pages. Renders numbered steps horizontally or vertically. Pick for how-it-works sections and onboarding explainers."
;; Config-driven step flow using the `step-flow-organism` marketing pattern.
;; Steps are declared as an array of { number, title, description, icon } objects.
;; The atom renders immediately on INIT with no fetch required.
type StepCard = { id : string!, number : number, title : string!, description : string!, icon : string }
orbital StepItemOrbital {
  uses StepFlowOrganism from "std/behaviors/ui-step-flow-organism"

  entity StepSectionItem [runtime] {
    id : string!
    steps : [StepCard] @description "An ordered list of individual step components." @synonyms "items, sequence, stages" = []
  }

  trait StepSectionItemSteps = StepFlowOrganism.traits.StepFlowOrganismRender -> StepSectionItem {
    config {
      orientation: @config.orientation
      steps : [StepCard] = [{
        description: "Describe your app in natural language."
        icon: pen-tool
        id: "1"
        number: 1
        title: Design
      }, {
        description: "Almadar generates the full stack automatically."
        icon: hammer
        id: "2"
        number: 2
        title: Build
      }, {
        description: "Deploy to production with one click."
        icon: rocket
        id: "3"
        number: 3
        title: Ship
      }]
        @label "Steps"
        @description "Array of step items"
        @tier "presentation"
      orientation : string = horizontal
        @label "Orientation"
        @description "horizontal or vertical"
        @tier "presentation"
    }
  }

  page "/steps" as StepSectionItemStepsPage -> StepSectionItemSteps
}