app ui-pricing-organism "1.0.0"
"PricingOrganism — UI factory (1:1 with the @almadar/ui pricing-organism pattern)."
orbital PricingOrganismOrbital {
    type PricingOrganismLoaded = Event { data : [PricingOrganismItem] } "PricingOrganism rows finished loading; payload.data holds the collection"
  type PricingOrganismError = {
    message : string!
    name : string
    code : string
    stack : string
  }

  entity PricingOrganismItem [runtime] {
    id : string!
    name : string = "Name"
    price : string = "Price"
    description : string = "Description"
    features : [string] = ["Item", "Item 2"]
    actionLabel : string = "Action Label"
    actionHref : string = "Action Href"
    highlighted : boolean = false
    badge : string = "Badge"
  }

  trait PricingOrganismRender -> @rebindable PricingOrganismItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch PricingOrganismItem { emit: { success: PricingOrganismLoaded } })
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          heading: @config.heading
          subtitle: @config.subtitle
          type: pricing-organism
        })
      PricingOrganismLoaded -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @payload.data
          heading: @config.heading
          subtitle: @config.subtitle
          type: pricing-organism
        })
    }

    emits {
      PricingOrganismLoaded
        @description "PricingOrganism rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : PricingOrganismError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      heading : string
        @label "Heading"
        @description "heading prop"
        @tier "presentation"
      subtitle : string
        @label "Subtitle"
        @description "subtitle prop"
        @tier "presentation"
    }
  }

  page "/pricing-organism" as PricingOrganismPage -> PricingOrganismRender
}
