app ui-hero-organism "1.0.0"
"HeroOrganism — UI factory (1:1 with the @almadar/ui hero-organism pattern)."
orbital HeroOrganismOrbital {
    type HeroOrganismLoaded = Event { data : [HeroOrganismItem] } "HeroOrganism rows finished loading; payload.data holds the collection"
  type HeroOrganismError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type HeroOrganismPrimaryAction = {
    label : string
    href : string
  }
  type HeroOrganismSecondaryAction = {
    label : string
    href : string
  }
  type HeroOrganismImage = {
    src : asset
    alt : string
  }

  entity HeroOrganismItem [runtime] {
    id : string!
    title : string = "Title"
    tag : string = "Tag"
    titleAccent : string = "Title Accent"
    subtitle : string = "Subtitle"
    primaryAction : HeroOrganismPrimaryAction = { label: "Label", href: "Href" }
    secondaryAction : HeroOrganismSecondaryAction = { label: "Label", href: "Href" }
    installCommand : string = "Install Command"
    image : HeroOrganismImage = { src: "https://almadar-kflow-assets.web.app/shared/ui-visual-novel-board/default/backgrounds/chamber.png", alt: "Alt" }
    imagePosition : "below" | "right" | "background" = below
    background : "dark" | "gradient" | "subtle" = dark
  }

  trait HeroOrganismRender -> @rebindable HeroOrganismItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch HeroOrganismItem { emit: { success: HeroOrganismLoaded } })
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          children: [{ content: "Sample content", type: typography }]
          type: hero-organism
        })
      HeroOrganismLoaded -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @payload.data
          children: [{ content: "Sample content", type: typography }]
          type: hero-organism
        })
    }

    emits {
      HeroOrganismLoaded
        @description "HeroOrganism rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : HeroOrganismError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string = "Sort By"
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string = "Search Value"
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number = 0
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number = 0
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number = 0
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
    }
  }

  page "/hero-organism" as HeroOrganismPage -> HeroOrganismRender
}
