app ui-showcase-organism "1.0.0"
"ShowcaseOrganism — UI factory (1:1 with the @almadar/ui showcase-organism pattern)."
orbital ShowcaseOrganismOrbital {
    type ShowcaseOrganismLoaded = Event { data : [ShowcaseOrganismItem] } "ShowcaseOrganism rows finished loading; payload.data holds the collection"
  type ShowcaseOrganismError = {
    message : string!
    name : string
    code : string
    stack : string
  }
  type ShowcaseOrganismImage = {
    src : asset
    alt : string
  }

  entity ShowcaseOrganismItem [runtime] {
    id : string!
    title : string = "Title"
    description : string = "Description"
    image : ShowcaseOrganismImage = { src: "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png", alt: "Alt" }
    href : string = "Href"
    badge : string = "Badge"
    accentColor : string = "Accent Color"
  }

  trait ShowcaseOrganismRender -> @rebindable ShowcaseOrganismItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ShowcaseOrganismItem { emit: { success: ShowcaseOrganismLoaded } })
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @entity
          columns: @config.columns
          heading: @config.heading
          subtitle: @config.subtitle
          type: showcase-organism
        })
      ShowcaseOrganismLoaded -> idle
        (render-ui main {
          className: @config.className
          isLoading: @config.isLoading
          error: @config.error
          sortBy: @config.sortBy
          sortDirection: @config.sortDirection
          searchValue: @config.searchValue
          page: @config.pageProp
          pageSize: @config.pageSize
          totalCount: @config.totalCount
          activeFilters: @config.activeFilters
          selectedIds: @config.selectedIds
          entity: @payload.data
          columns: @config.columns
          heading: @config.heading
          subtitle: @config.subtitle
          type: showcase-organism
        })
    }

    emits {
      ShowcaseOrganismLoaded
        @description "ShowcaseOrganism rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string
        @label "Class Name"
        @description "Additional CSS classes"
        @tier "presentation"
      isLoading : boolean = false
        @label "Is Loading"
        @description "Loading state indicator"
        @tier "presentation"
      error : ShowcaseOrganismError
        @label "Error"
        @description "Error state (UiError)"
        @tier "presentation"
      sortBy : string
        @label "Sort By"
        @description "Current sort field"
        @tier "presentation"
      sortDirection : "asc" | "desc" = asc
        @label "Sort Direction"
        @description "Current sort direction"
        @tier "presentation"
      searchValue : string
        @label "Search Value"
        @description "Current search query value"
        @tier "presentation"
      pageProp : number
        @label "Page"
        @description "Current page number"
        @synonyms "page"
        @tier "presentation"
      pageSize : number
        @label "Page Size"
        @description "Number of items per page"
        @tier "presentation"
      totalCount : number
        @label "Total Count"
        @description "Total number of items"
        @tier "presentation"
      activeFilters : json = {}
        @label "Active Filters"
        @description "Active filters"
        @tier "presentation"
      selectedIds : [string] = []
        @label "Selected Ids"
        @description "Currently selected item IDs"
        @tier "presentation"
      columns : number = 3
        @label "Columns"
        @description "columns prop"
        @tier "presentation"
      heading : string
        @label "Heading"
        @description "heading prop"
        @tier "presentation"
      subtitle : string
        @label "Subtitle"
        @description "subtitle prop"
        @tier "presentation"
    }
  }

  page "/showcase-organism" as ShowcaseOrganismPage -> ShowcaseOrganismRender
}
