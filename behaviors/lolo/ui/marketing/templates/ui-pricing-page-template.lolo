app ui-pricing-page-template "1.0.0"
"PricingPageTemplate — UI factory (1:1 with the @almadar/ui pricing-page-template pattern)."
orbital PricingPageTemplateOrbital {
  entity PricingPageTemplateItem [runtime] {
    id : string!
  }

  trait PricingPageTemplateRender -> @rebindable PricingPageTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch PricingPageTemplateItem {})
        (render-ui main {
          entity: @entity
          className: @config.className
          type: pricing-page-template
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
    }
  }

  page "/pricing-page-template" as PricingPageTemplatePage -> PricingPageTemplateRender
}
