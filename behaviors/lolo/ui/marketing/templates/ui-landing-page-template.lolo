app ui-landing-page-template "1.0.0"
"LandingPageTemplate — UI factory (1:1 with the @almadar/ui landing-page-template pattern)."
orbital LandingPageTemplateOrbital {
    type LandingPageTemplateLoaded = Event { data : [LandingPageTemplateItem] } "LandingPageTemplate rows finished loading; payload.data holds the collection"
  type LandingPageTemplateHero = {
    id : string
    tag : string
    title : string!
    titleAccent : string
    subtitle : string!
    primaryAction : LandingPageTemplateHeroPrimaryAction
    secondaryAction : LandingPageTemplateHeroSecondaryAction
    installCommand : string
    image : LandingPageTemplateHeroImage
    imagePosition : "below" | "right" | "background"
    background : "dark" | "gradient" | "subtle"
  }
  type LandingPageTemplateHeroPrimaryAction = {
    label : string!
    href : string!
  }
  type LandingPageTemplateHeroSecondaryAction = {
    label : string!
    href : string!
  }
  type LandingPageTemplateHeroImage = {
    src : json!
    alt : string!
  }
  type LandingPageTemplateFeaturesItem = {
    id : string
    icon : icon
    title : string!
    description : string!
    href : string
  }
  type LandingPageTemplateStatsItem = {
    id : string
    value : string!
    label : string!
  }
  type LandingPageTemplateStepsItem = {
    id : string
    title : string!
    description : string!
    icon : icon
  }
  type LandingPageTemplateShowcaseItem = {
    id : string!
    title : string!
    description : string
    image : LandingPageTemplateShowcaseItemImage!
    href : string
    badge : string
  }
  type LandingPageTemplateShowcaseItemImage = {
    src : json!
    alt : string!
  }
  type LandingPageTemplateCtaPrimaryAction = {
    label : string!
    href : string!
  }
  type LandingPageTemplateCtaSecondaryAction = {
    label : string!
    href : string!
  }

  entity LandingPageTemplateItem [runtime] {
    id : string!
    hero : LandingPageTemplateHero = { id: "Id", tag: "Tag", title: "Title", titleAccent: "Title Accent", subtitle: "Subtitle", primaryAction: { label: "Label", href: "Href" }, secondaryAction: { label: "Label", href: "Href" }, installCommand: "Install Command", image: { src: {}, alt: "Alt" }, imagePosition: below, background: dark }
    features : [LandingPageTemplateFeaturesItem] = [{ id: "Id", icon: "circle", title: "Title", description: "Description", href: "Href" }, { id: "Id 2", icon: "circle", title: "Title 2", description: "Description 2", href: "Href 2" }]
    stats : [LandingPageTemplateStatsItem] = [{ id: "Id", value: "Value", label: "Label" }, { id: "Id 2", value: "Value 2", label: "Label 2" }]
    steps : [LandingPageTemplateStepsItem] = [{ id: "Id", title: "Title", description: "Description", icon: "circle" }, { id: "Id 2", title: "Title 2", description: "Description 2", icon: "circle" }]
    showcase : [LandingPageTemplateShowcaseItem] = [{ id: "Id", title: "Title", description: "Description", image: { src: {}, alt: "Alt" }, href: "Href", badge: "Badge" }, { id: "Id 2", title: "Title 2", description: "Description 2", image: { src: {}, alt: "Alt" }, href: "Href 2", badge: "Badge 2" }]
    ctaTitle : string = "Cta Title"
    ctaSubtitle : string = "Cta Subtitle"
    ctaPrimaryAction : LandingPageTemplateCtaPrimaryAction = { label: "Label", href: "Href" }
    ctaSecondaryAction : LandingPageTemplateCtaSecondaryAction = { label: "Label", href: "Href" }
    communityGithub : string = "Community Github"
    communityDiscord : string = "Community Discord"
  }

  trait LandingPageTemplateRender -> @rebindable LandingPageTemplateItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch LandingPageTemplateItem { emit: { success: LandingPageTemplateLoaded } })
        (render-ui main {
          entity: @entity
          className: @config.className
          variant: @config.variant
          featureColumns: @config.featureColumns
          type: landing-page-template
        })
      LandingPageTemplateLoaded -> idle
        (render-ui main {
          entity: @payload.data
          className: @config.className
          variant: @config.variant
          featureColumns: @config.featureColumns
          type: landing-page-template
        })
    }

    emits {
      LandingPageTemplateLoaded
        @description "LandingPageTemplate rows finished loading; payload.data holds the collection."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "External styling override"
        @tier "presentation"
      variant : "product" | "service" | "platform" = product
        @label "Variant"
        @description "variant prop"
        @tier "presentation"
      featureColumns : number = 3
        @label "Feature Columns"
        @description "featureColumns prop"
        @tier "presentation"
    }
  }

  page "/landing-page-template" as LandingPageTemplatePage -> LandingPageTemplateRender
}
