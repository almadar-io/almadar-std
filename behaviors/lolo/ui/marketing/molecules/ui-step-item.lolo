app ui-step-item "1.0.0"
"StepItem — UI factory (1:1 with the @almadar/ui step-item pattern)."
orbital StepItemOrbital {
  entity StepItemItem [runtime] {
    id : string!
  }

  trait StepItemRender -> @rebindable StepItemItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          number: @config.number
          title: @config.title
          description: @config.description
          icon: @config.icon
          type: step-item
        })
    }

    config {
      number : number = 0
        @label "Number"
        @description "number prop"
        @tier "presentation"
      title : string = ""
        @label "Title"
        @description "title prop"
        @tier "presentation"
      description : string = ""
        @label "Description"
        @description "description prop"
        @tier "presentation"
      icon : string = "circle"
        @label "Icon"
        @description "icon prop"
        @tier "presentation"
    }
  }

  page "/step-item" as StepItemPage -> StepItemRender
}
