app ui-tag-cloud "1.0.0"
"TagCloud — UI factory (1:1 with the @almadar/ui tag-cloud pattern)."
orbital TagCloudOrbital {
  type TagCloudTagsItem = {
    label : string!
    href : string
    variant : string
  }

  entity TagCloudItem [runtime] {
    id : string!
  }

  trait TagCloudRender -> @rebindable TagCloudItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          tags: @config.tags
          variant: @config.variant
          className: @config.className
          type: tag-cloud
        })
    }

    config {
      tags : [TagCloudTagsItem] = [{ label: "Label" }]
        @label "Tags"
        @description "tags prop"
        @tier "presentation"
      variant : "default" | "primary" | "accent" = default
        @label "Variant"
        @description "variant prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/tag-cloud" as TagCloudPage -> TagCloudRender
}
