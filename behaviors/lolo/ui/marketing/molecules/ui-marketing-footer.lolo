app ui-marketing-footer "1.0.0"
"MarketingFooter — UI factory (1:1 with the @almadar/ui marketing-footer pattern)."
orbital MarketingFooterOrbital {
  type MarketingFooterColumnsItem = {
    title : string!
    items : [MarketingFooterColumnsItemItemsItem]!
  }
  type MarketingFooterColumnsItemItemsItem = {
    label : string!
    href : string!
  }
  type MarketingFooterLogo = {
    src : asset!
    alt : string!
    href : string
  }

  entity MarketingFooterItem [runtime] {
    id : string!
  }

  trait MarketingFooterRender -> @rebindable MarketingFooterItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          columns: @config.columns
          copyright: @config.copyright
          logo: @config.logo
          className: @config.className
          type: marketing-footer
        })
    }

    config {
      columns : [MarketingFooterColumnsItem] = [{ title: "Title", items: [{ label: "Label", href: "Href" }, { label: "Label 2", href: "Href 2" }] }, { title: "Title 2", items: [{ label: "Label", href: "Href" }, { label: "Label 2", href: "Href 2" }] }]
        @label "Columns"
        @description "columns prop"
        @tier "presentation"
      copyright : string = "Copyright"
        @label "Copyright"
        @description "copyright prop"
        @tier "presentation"
      logo : MarketingFooterLogo = { src: "https://almadar-kflow-assets.web.app/shared/units/chars-toon/trait-wars/citizens/archetypes/00_base_model.png", alt: "Alt", href: "Href" }
        @label "Logo"
        @description "logo prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/marketing-footer" as MarketingFooterPage -> MarketingFooterRender
}
