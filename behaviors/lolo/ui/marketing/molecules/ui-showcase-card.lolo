app ui-showcase-card "1.0.0"
"ShowcaseCard — UI factory (1:1 with the @almadar/ui showcase-card pattern)."
orbital ShowcaseCardOrbital {
  type ShowcaseCardImage = {
    src : json!
    alt : string!
  }

  entity ShowcaseCardItem [runtime] {
    id : string!
  }

  trait ShowcaseCardRender -> @rebindable ShowcaseCardItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          title: @config.title
          description: @config.description
          image: @config.image
          href: @config.href
          badge: @config.badge
          accentColor: @config.accentColor
          className: @config.className
          type: showcase-card
        })
    }

    config {
      title : string = "Title"
        @label "Title"
        @description "title prop"
        @tier "presentation"
      description : string = "Description"
        @label "Description"
        @description "description prop"
        @tier "presentation"
      image : ShowcaseCardImage = { src: {}, alt: "Alt" }
        @label "Image"
        @description "image prop"
        @tier "presentation"
      href : string = "Href"
        @label "Href"
        @description "href prop"
        @tier "presentation"
      badge : string = "Badge"
        @label "Badge"
        @description "badge prop"
        @tier "presentation"
      accentColor : string = "Accent Color"
        @label "Accent Color"
        @description "accentColor prop"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/showcase-card" as ShowcaseCardPage -> ShowcaseCardRender
}
