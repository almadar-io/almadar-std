app ui-hero-section "1.0.0"
"HeroSection — UI factory (1:1 with the @almadar/ui hero-section pattern)."
orbital HeroSectionOrbital {
  type HeroSectionPrimaryAction = {
    label : string!
    href : string!
  }
  type HeroSectionSecondaryAction = {
    label : string!
    href : string!
  }
  type HeroSectionImage = {
    src : json!
    alt : string!
  }

  entity HeroSectionItem [runtime] {
    id : string!
  }

  trait HeroSectionRender -> @rebindable HeroSectionItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          tag: @config.tag
          tagVariant: @config.tagVariant
          title: @config.title
          titleAccent: @config.titleAccent
          subtitle: @config.subtitle
          primaryAction: @config.primaryAction
          secondaryAction: @config.secondaryAction
          installCommand: @config.installCommand
          image: @config.image
          imagePosition: @config.imagePosition
          background: @config.background
          align: @config.align
          backgroundElement: @config.backgroundElement
          children: [{ content: "Sample content", type: typography }]
          className: @config.className
          type: hero-section
        })
    }

    config {
      tag : string = "Tag"
        @label "Tag"
        @description "tag prop"
        @tier "presentation"
      tagVariant : "primary" | "secondary" | "accent" = primary
        @label "Tag Variant"
        @description "tagVariant prop"
        @tier "presentation"
      title : string = "Title"
        @label "Title"
        @description "title prop"
        @tier "presentation"
      titleAccent : string = "Title Accent"
        @label "Title Accent"
        @description "titleAccent prop"
        @tier "presentation"
      subtitle : string = "Subtitle"
        @label "Subtitle"
        @description "subtitle prop"
        @tier "presentation"
      primaryAction : HeroSectionPrimaryAction = { label: "Label", href: "Href" }
        @label "Primary Action"
        @description "primaryAction prop"
        @tier "presentation"
      secondaryAction : HeroSectionSecondaryAction = { label: "Label", href: "Href" }
        @label "Secondary Action"
        @description "secondaryAction prop"
        @tier "presentation"
      installCommand : string = "Install Command"
        @label "Install Command"
        @description "installCommand prop"
        @tier "presentation"
      image : HeroSectionImage = { src: {}, alt: "Alt" }
        @label "Image"
        @description "image prop"
        @tier "presentation"
      imagePosition : "below" | "right" | "background" = below
        @label "Image Position"
        @description "imagePosition prop"
        @tier "presentation"
      background : "dark" | "gradient" | "subtle" = subtle
        @label "Background"
        @description "background prop"
        @tier "presentation"
      align : "center" | "left" = center
        @label "Align"
        @description "align prop"
        @tier "presentation"
      backgroundElement : node
        @label "Background Element"
        @description "Background element (SVG animation, etc.) rendered behind hero content"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "className prop"
        @tier "presentation"
    }
  }

  page "/hero-section" as HeroSectionPage -> HeroSectionRender
}
