app ui-install-box "1.0.0"
"InstallBox — UI factory (1:1 with the @almadar/ui install-box pattern)."
orbital InstallBoxOrbital {
  entity InstallBoxItem [runtime] {
    id : string!
  }

  trait InstallBoxRender -> @rebindable InstallBoxItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          command: @config.command
          label: @config.label
          className: @config.className
          type: install-box
        })
    }

    config {
      command : string = "Command"
        @label "Command"
        @description "The command to display and copy"
        @tier "presentation"
      label : string = ""
        @label "Label"
        @description "Optional label above the command"
        @tier "presentation"
      className : string = ""
        @label "Class Name"
        @description "Additional class names"
        @tier "presentation"
    }
  }

  page "/install-box" as InstallBoxPage -> InstallBoxRender
}
