app ui-pull-quote "1.0.0"
"PullQuote — UI factory (1:1 with the @almadar/ui pull-quote pattern)."
orbital PullQuoteOrbital {
  entity PullQuoteItem [runtime] {
    id : string!
  }

  trait PullQuoteRender -> @rebindable PullQuoteItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          children: "Sample content"
          className: @config.className
          type: pull-quote
        })
    }

    config {
      className : string = ""
        @label "Class Name"
        @description "Additional class names"
        @tier "presentation"
    }
  }

  page "/pull-quote" as PullQuotePage -> PullQuoteRender
}
