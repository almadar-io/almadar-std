app std-healthcare "1.0.0"
"std-healthcare as a Function"

orbital PatientOrbital {
  entity Patient [persistent: patients] {
    id : string!
    firstName : string!
    lastName : string!
    dateOfBirth : datetime!
    phone : string
    insuranceId : string
    status : "active" | "inactive" | "discharged" = "active"
    pendingId : string = ""
  }

  type PatientLoaded     = Event { data : [Patient] }                  "Fired when Patient finishes loading"
  type PatientLoadFailed = Event { error : string, code : string } "Fired when Patient fails to load"
  type PatientSaved = Event { id : string }
  type PatientSaveFailed = Event { error : string, code : string }
  type PatientUpdated = Event { id : string }
  type PatientUpdateFailed = Event { error : string, code : string }
  type PatientDeleted = Event { id : string }
  type PatientDeleteFailed = Event { error : string, code : string }
  type AppointmentSaved = Event { id : string }
  type AppointmentSaveFailed = Event { error : string, code : string }
  type AppointmentUpdated = Event { id : string }
  type AppointmentUpdateFailed = Event { error : string, code : string }
  type AppointmentDeleted = Event { id : string }
  type AppointmentDeleteFailed = Event { error : string, code : string }
  type IntakeFormSaved = Event { id : string }
  type IntakeFormSaveFailed = Event { error : string, code : string }
  type PrescriptionSaved = Event { id : string }
  type PrescriptionSaveFailed = Event { error : string, code : string }
  trait PatientBrowse -> Patient [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Patient { emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      PatientLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "HealthcareApp", navItems: [{ label: "Patients", href: "/patients", icon: "heart" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Intake", href: "/intake", icon: "layout-list" }, { label: "Prescriptions", href: "/prescriptions", icon: "pill" }, { label: "Dashboard", href: "/dashboard", icon: "layout-dashboard" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "Patients", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Patient", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 1, children: [{ type: "stat-display", label: "Total Patients", value: "@entity", icon: "users" }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], columns: [{ name: "firstName", variant: "h3", icon: "user" }, { name: "lastName", variant: "h3" }, { name: "status", variant: "badge" }, { name: "dateOfBirth", label: "Date of Birth", variant: "body", format: "date" }, { name: "phone", variant: "caption" }, { name: "insuranceId", label: "Insurance ID", variant: "caption" }], variant: "card", gap: "sm" }] }] })
      PatientLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load patient" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
      PatientCreate PATIENT_CREATED -> INIT
      PatientEdit PATIENT_UPDATED -> INIT
      PatientDelete PATIENT_DELETED -> INIT
      * INTAKE_COMPLETE -> INIT
      VIEW { id : string!, row : object }
      EDIT { id : string!, row : object }
      DELETE { id : string!, row : object }
          PatientLoadFailed { error : string, code : string }
    
      PatientSaveFailed { error : string, code : string }
      PatientUpdateFailed { error : string, code : string }
      PatientDeleteFailed { error : string, code : string }
      AppointmentSaveFailed { error : string, code : string }
      AppointmentUpdateFailed { error : string, code : string }
      AppointmentDeleteFailed { error : string, code : string }
      IntakeFormSaveFailed { error : string, code : string }
      PrescriptionSaveFailed { error : string, code : string }
    }
    emits: [PatientLoaded, PatientLoadFailed, PatientSaved, PatientSaveFailed, PatientUpdated, PatientUpdateFailed, PatientDeleted, PatientDeleteFailed, AppointmentSaved, AppointmentSaveFailed, AppointmentUpdated, AppointmentUpdateFailed, AppointmentDeleted, AppointmentDeleteFailed, IntakeFormSaved, IntakeFormSaveFailed, PrescriptionSaved, PrescriptionSaveFailed]
  }
  trait PatientCreate -> Patient [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Patient)
      CREATE -> open
        (fetch Patient { emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Patient", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["firstName", "lastName", "dateOfBirth", "phone", "insuranceId", "status"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Patient @payload.data { emit: { success: "PatientSaved", failure: "PatientSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit PATIENT_CREATED)
    }
    emits {
      PATIENT_CREATED external { id: string }
    }
    listens {
      SAVE { data : object! }
          PatientLoadFailed { error : string, code : string }
    }
    emits: [PatientLoadFailed, PatientLoaded, PatientSaveFailed, PatientSaved]
  }
  trait PatientEdit -> Patient [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Patient)
      EDIT -> open
        (fetch Patient {id: "@payload.id" , emit: { success: "PatientLoaded", failure: "PatientLoadFailed" }, emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Patient", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "Patient", mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["firstName", "lastName", "dateOfBirth", "phone", "insuranceId", "status"], entityId: "@entity.id" }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Patient @payload.data { emit: { success: "PatientUpdated", failure: "PatientUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit PATIENT_UPDATED)
    }
    emits {
      PATIENT_UPDATED external { id: string }
    }
    listens {
      EDIT { id : string! }
      SAVE { data : object! }
          PatientLoadFailed { error : string, code : string }
    }
    emits: [PatientLoadFailed, PatientLoaded, PatientUpdateFailed, PatientUpdated]
  }
  trait PatientView -> Patient [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Patient)
      VIEW -> open
        (fetch Patient {id: "@payload.id" , emit: { success: "PatientLoaded", failure: "PatientLoadFailed" }, emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.firstName" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "First Name" }, { type: "typography", variant: "body", content: "@entity.firstName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Last Name" }, { type: "typography", variant: "body", content: "@entity.lastName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Date Of Birth" }, { type: "typography", variant: "body", content: "@entity.dateOfBirth" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Insurance ID" }, { type: "typography", variant: "body", content: "@entity.insuranceId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          PatientLoadFailed { error : string, code : string }
    }
    emits: [PatientLoaded, PatientLoadFailed]
  }
  trait PatientDelete -> Patient [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (ref Patient)
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Patient {id: "@payload.id" , emit: { success: "PatientLoaded", failure: "PatientLoadFailed" }, emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Patient", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Patient @entity.pendingId { emit: { success: "PatientDeleted", failure: "PatientDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref Patient)
        (emit PATIENT_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref Patient)
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref Patient)
    }
    emits {
      PATIENT_DELETED external { id: string }
    }
    listens {
      DELETE { id : string! }
          PatientLoadFailed { error : string, code : string }
    }
    emits: [PatientDeleteFailed, PatientDeleted, PatientLoadFailed, PatientLoaded]
  }
  page "/patients" as PatientsPage -> PatientBrowse, PatientCreate, PatientEdit, PatientView, PatientDelete
}
orbital AppointmentOrbital {
  entity Appointment [persistent: appointments] {
    id : string!
    patientName : string!
    doctorName : string!
    date : datetime!
    time : string!
    reason : string
    status : "active" | "inactive" | "discharged" = "active"
    pendingId : string = ""
  }

  type AppointmentLoaded     = Event { data : [Appointment] }                  "Fired when Appointment finishes loading"
  type AppointmentLoadFailed = Event { error : string, code : string } "Fired when Appointment fails to load"
  type AppointmentDeleteFailed = Event { error : string, code : string }
  type AppointmentDeleted = Event { id : string }
  type AppointmentSaveFailed = Event { error : string, code : string }
  type AppointmentSaved = Event { id : string }
  type AppointmentUpdateFailed = Event { error : string, code : string }
  type AppointmentUpdated = Event { id : string }
  trait AppointmentBrowse -> Appointment [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      AppointmentLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "HealthcareApp", navItems: [{ label: "Patients", href: "/patients", icon: "heart" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Intake", href: "/intake", icon: "layout-list" }, { label: "Prescriptions", href: "/prescriptions", icon: "pill" }, { label: "Dashboard", href: "/dashboard", icon: "layout-dashboard" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "Appointments", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Appointment", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], columns: [{ name: "patientName", label: "Patient", variant: "h3", icon: "calendar" }, { name: "status", variant: "badge" }, { name: "doctorName", label: "Doctor", variant: "body" }, { name: "date", variant: "body", format: "date" }, { name: "time", variant: "caption" }, { name: "reason", variant: "caption" }], variant: "card", gap: "sm" }] }] })
      AppointmentLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load appointment" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      PRESCRIBE external { id: string }
    }
    listens {
      AppointmentCreate APPOINTMENT_CREATED -> INIT
      AppointmentEdit APPOINTMENT_UPDATED -> INIT
      AppointmentDelete APPOINTMENT_DELETED -> INIT
          AppointmentLoadFailed { error : string, code : string }
    }
    emits: [AppointmentLoaded, AppointmentLoadFailed]
  }
  trait AppointmentCreate -> Appointment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Appointment)
      CREATE -> open
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Appointment", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["patientName", "doctorName", "date", "time", "reason", "status"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Appointment @payload.data { emit: { success: "AppointmentSaved", failure: "AppointmentSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit APPOINTMENT_CREATED)
    }
    emits {
      APPOINTMENT_CREATED
    }
    emits: [AppointmentLoadFailed, AppointmentLoaded, AppointmentSaveFailed, AppointmentSaved]
    listens {
      AppointmentLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait AppointmentEdit -> Appointment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Appointment)
      EDIT -> open
        (fetch Appointment {id: "@payload.id" , emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" }, emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Appointment", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "Appointment", mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["patientName", "doctorName", "date", "time", "reason", "status"], entityId: "@entity.id" }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Appointment @payload.data { emit: { success: "AppointmentUpdated", failure: "AppointmentUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit APPOINTMENT_UPDATED)
    }
    emits {
      APPOINTMENT_UPDATED
    }
    emits: [AppointmentLoadFailed, AppointmentLoaded, AppointmentUpdateFailed, AppointmentUpdated]
    listens {
      AppointmentLoadFailed { error : string, code : string }
      EDIT { id : string }
      SAVE { data : string }
    }
  }
  trait AppointmentView -> Appointment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Appointment)
      VIEW -> open
        (fetch Appointment {id: "@payload.id" , emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" }, emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.patientName" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Patient Name" }, { type: "typography", variant: "body", content: "@entity.patientName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Doctor Name" }, { type: "typography", variant: "body", content: "@entity.doctorName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Date" }, { type: "typography", variant: "body", content: "@entity.date" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Time" }, { type: "typography", variant: "body", content: "@entity.time" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Reason" }, { type: "typography", variant: "body", content: "@entity.reason" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits: [AppointmentLoaded, AppointmentLoadFailed]
    listens {
      AppointmentLoadFailed { error : string, code : string }
      VIEW { id : string }
    }
  }
  trait AppointmentDelete -> Appointment [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (ref Appointment)
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Appointment {id: "@payload.id" , emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" }, emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Appointment", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Appointment @entity.pendingId { emit: { success: "AppointmentDeleted", failure: "AppointmentDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref Appointment)
        (emit APPOINTMENT_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref Appointment)
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref Appointment)
    }
    emits {
      APPOINTMENT_DELETED
    }
    emits: [AppointmentDeleteFailed, AppointmentDeleted, AppointmentLoadFailed, AppointmentLoaded]
    listens {
      AppointmentLoadFailed { error : string, code : string }
      DELETE { id : string }
    }
  }
  page "/appointments" -> AppointmentBrowse, AppointmentCreate, AppointmentEdit, AppointmentView, AppointmentDelete
}
orbital IntakeFormOrbital {
  entity IntakeForm [runtime] {
    id : string!
    firstName : string!
    lastName : string!
    dateOfBirth : datetime!
    allergies : string
    medications : string
    emergencyContact : string
    insuranceProvider : string
    insuranceId : string
  }

  type IntakeFormLoaded     = Event { data : [IntakeForm] }                  "Fired when IntakeForm finishes loading"
  type IntakeFormLoadFailed = Event { error : string, code : string } "Fired when IntakeForm fails to load"
  type IntakeFormSaveFailed = Event { error : string, code : string }
  type IntakeFormSaved = Event { id : string }
  trait IntakeFormWizard -> IntakeForm [interaction, collection] {
    initial: step1
    state step1 {
      INIT -> step1
        (fetch IntakeForm { emit: { success: "IntakeFormLoaded", failure: "IntakeFormLoadFailed" } })
