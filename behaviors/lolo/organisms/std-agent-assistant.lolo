      SELECT_TAB -> idle
        (fetch Assistant)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle", size: "lg" }, { type: "typography", content: "Assistant", variant: "h2" }] }, { type: "divider" }, { type: "tabs", tabs: [{ label: "Chat", value: "chat" }, { label: "Memory", value: "memory" }, { label: "Settings", value: "settings" }], defaultActiveTab: "chat", activeTab: "@payload.tab", onTabChange: "SELECT_TAB" }, { type: "divider" }, { type: "data-grid", entity: "Assistant", emptyIcon: "inbox", emptyTitle: "No assistants yet", emptyDescription: "Add assistants to see them here.", className: "transition-shadow hover:shadow-md cursor-pointer", renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", variant: "h4", content: "@item.messages" }, { type: "typography", variant: "caption", color: "muted", content: "@item.chat" }] }] }] }] })
    }
  }
  page "/assistant/nav" -> AssistantTabs
}
orbital MemorySidebarOrbital {
  entity MemorySidebar [runtime] {
    id : string!
    content : string
    query : string
    strength : number
  }
  trait MemoryDrawer -> MemorySidebar [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch MemorySidebar)
      OPEN -> open
        (fetch MemorySidebar)
        (render-ui drawer { type: "stack", direction: "vertical", gap: "none", children: [{ type: "drawer", title: "Memory Recall", isOpen: true, children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "typography", variant: "caption", content: "Content" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "content"] }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "typography", variant: "caption", content: "Query" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "query"] }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "typography", variant: "caption", content: "Strength" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "strength"] }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Close", event: "CLOSE", variant: "ghost" }] }] }] }, { type: "side-panel", title: "Memory Recall", isOpen: true, position: "right", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "typography", variant: "caption", content: "Content" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "content"] }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "typography", variant: "caption", content: "Query" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "query"] }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "typography", variant: "caption", content: "Strength" }, { type: "typography", variant: "body", content: ["object/get", ["array/first", "@entity"], "strength"] }] }] }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui drawer null)
        (fetch MemorySidebar)
    }
  }
  page "/assistant/sidebar" -> MemoryDrawer
}