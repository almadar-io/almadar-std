    }
  }
  trait AssistantContextNotification -> AssistantContext [interaction] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AssistantContext)
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "layers", size: "lg" }, { type: "typography", content: "Context Window Alert", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "layers", size: "lg" }, { type: "typography", content: "Context Window Alert", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] }] })
      HIDE -> hidden
        (set @entity.message "")
    }
  }
  trait AssistantContextAgent -> AssistantContext [interaction] {
    initial: normal
    state normal {
      INIT -> normal
        (fetch AssistantContext)
        (agent/token-count)
        (agent/context-usage)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "empty-state", icon: "layers", title: "Context Window", description: "Context Window is ready" }] })
      UPDATE_TOKENS -> normal
        ? (< (/ @entity.tokenCount @entity.maxTokens) 0.85)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE)
      UPDATE_TOKENS -> approaching_limit
        ? (and (>= (/ @entity.tokenCount @entity.maxTokens) 0.85) (< (/ @entity.tokenCount @entity.maxTokens) 1))
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE)
        (emit SHOW)
    }
    state approaching_limit {
      UPDATE_TOKENS -> at_limit
        ? (>= (/ @entity.tokenCount @entity.maxTokens) 1)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage 100)
        (set @entity.current @entity.tokenCount)
        (emit UPDATE)
        (emit SHOW)
      COMPACT -> normal
        (agent/compact)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.lastCompactedAt @now)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE)
      UPDATE_TOKENS -> approaching_limit
        ? (and (>= (/ @entity.tokenCount @entity.maxTokens) 0.85) (< (/ @entity.tokenCount @entity.maxTokens) 1))
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE)
    }
    state at_limit {
      COMPACT -> normal
        (agent/compact)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.lastCompactedAt @now)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE)
    }
    emits {
      SHOW internal { tokenCount: number, usage: number }
      UPDATE internal { current: number, max: number }
    }
  }
  page "/context" -> AssistantContextMonitor
}
orbital ProviderConfigOrbital {
  entity ProviderConfig [runtime] {
    id : string!
    currentProvider : string
    currentModel : string
    fallbackProvider : string
    requestCount : number
    message : string
    notificationType : string
  }
  trait ProviderManager -> ProviderConfig [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (ref ProviderConfig)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", event: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SWITCH -> open
        (fetch ProviderConfig)
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "repeat", size: "md" }, { type: "typography", content: "Switch Provider", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Current:" }, { type: "badge", label: "@entity.currentProvider" }, { type: "badge", label: "@entity.currentModel" }] }, { type: "form-section", entity: "ProviderConfig", mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["currentProvider", "currentModel"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref ProviderConfig)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", event: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist update ProviderConfig @payload.data)
        (render-ui modal null)
        (emit SWITCHED)
        (ref ProviderConfig)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", event: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      SAVE
      SWITCHED
      PROVIDER_CHANGED internal { provider: string }
      PROVIDER_CHANGED external { provider: string }
    }
  }
  trait ProviderConfigNotification -> ProviderConfig [interaction] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch ProviderConfig)
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "server", size: "lg" }, { type: "typography", content: "Provider Status", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "server", size: "lg" }, { type: "typography", content: "Provider Status", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] }] })
      HIDE -> hidden
        (set @entity.message "")
    }
  }
  trait ProviderConfigAgent -> ProviderConfig [interaction] {
    initial: idle
    state idle {
      INIT -> active
        (fetch ProviderConfig)
        (agent/provider)
        (agent/model)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "empty-state", icon: "repeat", title: "Provider", description: "Provider is ready" }] })
      DO_SWITCH -> switching
        (agent/switch-provider @payload.data.currentProvider @payload.data.currentModel)
        (set @entity.currentProvider @payload.data.currentProvider)
        (set @entity.currentModel @payload.data.currentModel)
    }
    state active {
      DO_SWITCH -> switching
        (agent/switch-provider @payload.data.currentProvider @payload.data.currentModel)
        (set @entity.currentProvider @payload.data.currentProvider)
        (set @entity.currentModel @payload.data.currentModel)
      SWITCHED -> switching
        (agent/switch-provider @entity.currentProvider @entity.currentModel)
      SWITCH_AUTO -> switching
        (agent/switch-provider @entity.fallbackProvider)
        (set @entity.currentProvider @entity.fallbackProvider)
    }
    state switching {
      INIT -> active
        (agent/provider)
        (agent/model)
        (set @entity.requestCount (+ @entity.requestCount 1))
        (emit SHOW)
    }
    emits {
      SHOW internal { provider: string, model: string }
    }
    listens {
      * SWITCHED -> SWITCHED
    }
  }
  page "/settings" -> ProviderManager
}
orbital AssistantNavOrbital {
  entity AssistantNav [runtime] {
    id : string!
    messages : string
    currentMessage : string
    response : string
    memoryCount : number
    contextUsage : number
    provider : string
    sessionId : string
    status : string
    error : string
