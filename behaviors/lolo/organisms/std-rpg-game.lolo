app std-rpg-game "1.0.0"
"std-rpg-game as a Function"

orbital BattleStateOrbital {
  entity BattleState [runtime] {
    id : string!
    turn : number = 0
    score : number = 0
    phase : string = "setup"
    outcome : string
  }

  type BattleStateLoaded     = Event BattleState                  "Fired when BattleState finishes loading"
  type BattleStateLoadFailed = Event { message : string } "Fired when BattleState fails to load"
  type RpgItemSaved = Event { id : string }
  type RpgItemSaveFailed = Event { error : string, code : string }
  type RpgItemUpdated = Event { id : string }
  type RpgItemUpdateFailed = Event { error : string, code : string }
  type RpgItemDeleted = Event { id : string }
  type RpgItemDeleteFailed = Event { error : string, code : string }
  type MissionUpdated = Event { id : string }
  type MissionUpdateFailed = Event { error : string, code : string }
  trait BattleStateBattleFlow -> BattleState [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (fetch BattleState { emit: { success: "BattleStateLoaded", failure: "BattleStateLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-menu", title: "Battle Arena", subtitle: "Turn-Based Strategy", menuItems: [{ label: "Start Battle", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      NAVIGATE -> menu
    }
    state playing {
      END_TURN -> playing
        (set @entity.turn (+ @entity.turn 1))
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      PAUSE -> paused
        (render-ui modal { type: "game-menu", title: "Paused", menuItems: [{ label: "Resume", event: "RESUME", variant: "primary" }, { label: "Quit", event: "RESTART", variant: "ghost" }] })
      GAME_OVER -> gameover
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-over-screen", title: "Battle Over", stats: [{ label: "Turns", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }], menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }, { label: "Main Menu", event: "RESTART", variant: "secondary" }] }] })
    }
    state paused {
      NAVIGATE -> paused
      RESUME -> playing
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      CLOSE -> playing
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-hud", stats: [{ label: "Turn", value: "@entity.turn" }, { label: "Score", value: "@entity.score" }] }] })
      RESTART -> menu
        (render-ui modal null)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-menu", title: "Battle Arena", subtitle: "Turn-Based Strategy", menuItems: [{ label: "Start Battle", event: "START", variant: "primary" }] }] })
    }
    state gameover {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "game-menu", title: "Battle Arena", subtitle: "Turn-Based Strategy", menuItems: [{ label: "Start Battle", event: "START", variant: "primary" }] }] })
    }
    emits {
      LOOT_DROPPED external { itemId: string }
    }
    listens {
      * ENCOUNTER_STARTED -> START
          BattleStateLoadFailed { message : string }
    
      RpgItemSaveFailed { error : string, code : string }
      RpgItemUpdateFailed { error : string, code : string }
      RpgItemDeleteFailed { error : string, code : string }
      MissionUpdateFailed { error : string, code : string }
    }
    emits: [BattleStateLoaded, BattleStateLoadFailed, RpgItemSaved, RpgItemSaveFailed, RpgItemUpdated, RpgItemUpdateFailed, RpgItemDeleted, RpgItemDeleteFailed, MissionUpdated, MissionUpdateFailed]
  }
  trait BattleStateCombatLog -> BattleState [interaction, collection] {
    state idle {
      INIT -> idle
        (fetch BattleState { emit: { success: "BattleStateLoaded", failure: "BattleStateLoadFailed" } })
      LOG_EVENT -> idle
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "combat-log", events: "@BattleState", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" }] })
      CLEAR -> idle
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "combat-log", events: "@BattleState", maxVisible: 10, autoScroll: true, showTimestamps: true, title: "Combat Log" }] })
    }
    listens {
      LOG_EVENT { data : object! }
          BattleStateLoadFailed { message : string }
    }
    emits: [BattleStateLoaded, BattleStateLoadFailed]
  }
  page "/battle" as BattlePage -> BattleStateBattleFlow, BattleStateCombatLog
}
orbital WorldZoneOrbital {
  entity WorldZone [runtime] {
    id : string!
    name : string!
    description : string
    level : number
    explored : boolean
  }

  type WorldZoneLoaded     = Event WorldZone                  "Fired when WorldZone finishes loading"
  type WorldZoneLoadFailed = Event { message : string } "Fired when WorldZone fails to load"
  trait WorldZoneNavigation -> WorldZone [interaction, collection] {
    initial: exploring
    state exploring {
      INIT -> exploring
        (fetch WorldZone { emit: { success: "WorldZoneLoaded", failure: "WorldZoneLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "map" }, { type: "typography", content: "World Map", variant: "h2" }] }, { type: "status-dot", status: "online", pulse: false, label: "Exploring" }] }, { type: "divider" }, { type: "map-view", markers: [], height: "200px", zoom: 10 }, { type: "data-grid", entity: "WorldZone", fields: [], itemActions: [{ label: "Travel", event: "TRAVEL" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", variant: "h4", content: "@item.name" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.level" }] }] }] }] })
      TRAVEL -> transitioning
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "loader" }, { type: "typography", content: "Traveling...", variant: "h2" }] }, { type: "divider" }, { type: "typography", content: "Traveling to the destination worldzones map.", variant: "body" }] }] })
    }
    state transitioning {
      ARRIVE -> entered
        (fetch WorldZone { emit: { success: "WorldZoneLoaded", failure: "WorldZoneLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "map" }, { type: "typography", content: "WorldZones Map", variant: "h2" }] }, { type: "status-dot", status: "online", label: "Entered" }] }, { type: "divider" }, { type: "data-grid", entity: "WorldZone", fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", variant: "h4", content: "@item.name" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.level" }] }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back to Map", action: "BACK", variant: "ghost", icon: "arrow-left" }] }] }] })
    }
    state entered {
      BACK -> exploring
        (fetch WorldZone { emit: { success: "WorldZoneLoaded", failure: "WorldZoneLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "map" }, { type: "typography", content: "World Map", variant: "h2" }] }, { type: "status-dot", status: "online", pulse: false, label: "Exploring" }] }, { type: "divider" }, { type: "map-view", markers: [], height: "200px", zoom: 10 }, { type: "data-grid", entity: "WorldZone", fields: [], itemActions: [{ label: "Travel", event: "TRAVEL" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", variant: "h4", content: "@item.name" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.level" }] }] }] }] })
    }
    emits {
      ENCOUNTER_STARTED external { zoneId: string }
      QUEST_ACCEPTED external { questId: string }
    }
    emits: [WorldZoneLoaded, WorldZoneLoadFailed]
    listens {
      WorldZoneLoadFailed { message : string }
    }
  }
  page "/world" -> WorldZoneNavigation
}
orbital RpgItemOrbital {
  entity RpgItem [persistent: rpgitems] {
    id : string!
    name : string!
    type : string!
    quantity : number
    rarity : string
    pendingId : string
  }

  type RpgItemLoaded     = Event RpgItem                  "Fired when RpgItem finishes loading"
  type RpgItemLoadFailed = Event { message : string } "Fired when RpgItem fails to load"
  trait RpgItemBrowse -> RpgItem [interaction, collection] {
    state browsing {
      INIT -> browsing
        (ref RpgItem)
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "briefcase" }, { type: "typography", content: "Inventory", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Add RpgItem", action: "ADD_ITEM", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: "RpgItem", fields: [], itemActions: [{ label: "Use", event: "USE_ITEM", variant: "ghost" }, { label: "Drop", event: "DROP", variant: "danger" }], columns: [{ name: "name", label: "Name", variant: "h4", icon: "briefcase" }, { name: "type", label: "Type", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "quantity", label: "Quantity", variant: "caption" }] }] }] })
    }
    listens {
      RpgItemAdd ITEM_ADDED -> INIT
      RpgItemUse ITEM_USED -> INIT
      RpgItemDrop CONFIRM_DROP -> INIT
      * LOOT_DROPPED -> INIT
          RpgItemLoadFailed { message : string }
    }
    emits: [RpgItemLoaded, RpgItemLoadFailed]
  }
  trait RpgItemAdd -> RpgItem [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref RpgItem)
      ADD_ITEM -> open
        (fetch RpgItem { emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Add RpgItem", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "RpgItem", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "type", "quantity", "rarity"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create RpgItem @payload.data { emit: { success: "RpgItemSaved", failure: "RpgItemSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ITEM_ADDED)
    }
    emits {
      ITEM_ADDED
    }
    emits: [RpgItemLoaded, RpgItemLoadFailed]
    listens {
      RpgItemLoadFailed { message : string }
      SAVE { data : string }
    }
  }
  trait RpgItemUse -> RpgItem [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref RpgItem)
      USE_ITEM -> open
        (fetch RpgItem {id: "@payload.id" , emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" }, emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "zap" }, { type: "typography", content: "Use RpgItem", variant: "h3" }] }, { type: "divider" }, { type: "typography", content: "@entity.name", variant: "body" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Cancel", action: "CLOSE", variant: "ghost" }, { type: "button", label: "Confirm Use", action: "SAVE", variant: "primary", icon: "check" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update RpgItem @payload.data { emit: { success: "RpgItemUpdated", failure: "RpgItemUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ITEM_USED)
    }
    emits {
      ITEM_USED
    }
    emits: [RpgItemLoaded, RpgItemLoadFailed]
    listens {
      RpgItemLoadFailed { message : string }
      USE_ITEM { id : string }
      SAVE { data : string }
    }
  }
  trait RpgItemDrop -> RpgItem [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (ref RpgItem)
      DROP -> confirming
        (set @entity.pendingId @payload.id)
        (fetch RpgItem {id: "@payload.id" , emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" }, emit: { success: "RpgItemLoaded", failure: "RpgItemLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Drop RpgItem", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Are you sure you want to drop this rpgitem?" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Drop", action: "CONFIRM_DROP", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DROP -> idle
        (persist delete RpgItem @entity.pendingId { emit: { success: "RpgItemDeleted", failure: "RpgItemDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref RpgItem)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref RpgItem)
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (ref RpgItem)
    }
    emits {
      CONFIRM_DROP
    }
    emits: [RpgItemLoaded, RpgItemLoadFailed]
    listens {
      RpgItemLoadFailed { message : string }
      DROP { id : string }
    }
  }
  page "/inventory" -> RpgItemBrowse, RpgItemAdd, RpgItemUse, RpgItemDrop
}
orbital MissionOrbital {
  entity Mission [runtime] {
    id : string!
    title : string!
    description : string
    status : string
    reward : string
  }

  type MissionLoaded     = Event Mission                  "Fired when Mission finishes loading"
  type MissionLoadFailed = Event { message : string } "Fired when Mission fails to load"
  trait MissionTracking -> Mission [interaction, collection] {
    initial: available
    state available {
      INIT -> available
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }] }, { type: "divider" }, { type: "data-list", entity: "Mission", fields: [], groupBy: "status", itemActions: [{ label: "Accept", event: "ACCEPT" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
      ACCEPT -> active
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }, { type: "badge", label: "Active" }] }, { type: "divider" }, { type: "progress-bar", value: 50, showPercentage: true }, { type: "data-grid", entity: "Mission", fields: [], itemActions: [{ label: "Progress", event: "PROGRESS" }, { label: "Complete", event: "COMPLETE" }, { label: "Fail", event: "FAIL", variant: "danger" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
    }
    state active {
      INIT -> active
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }, { type: "badge", label: "Active" }] }, { type: "divider" }, { type: "progress-bar", value: 50, showPercentage: true }, { type: "data-grid", entity: "Mission", fields: [], itemActions: [{ label: "Progress", event: "PROGRESS" }, { label: "Complete", event: "COMPLETE" }, { label: "Fail", event: "FAIL", variant: "danger" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
      PROGRESS -> progressing
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "trending-up" }, { type: "typography", content: "Update Progress", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "Mission", mode: "edit", submitEvent: "SAVE", cancelEvent: "CANCEL", fields: ["title", "description", "status", "reward"] }] })
      COMPLETE -> complete
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Quest Complete", variant: "h2" }, { type: "alert", variant: "success", message: "Congratulations! The quest has been completed." }, { type: "button", label: "View Quests", action: "RESET", variant: "primary", icon: "arrow-left" }] }] })
      FAIL -> failed
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle" }, { type: "typography", content: "Quest Failed", variant: "h2" }, { type: "alert", variant: "error", message: "The quest was not completed. You can try again." }, { type: "button", label: "View Quests", action: "RESET", variant: "primary", icon: "arrow-left" }] }] })
    }
    state progressing {
      SAVE -> active
        (persist update Mission @payload.data { emit: { success: "MissionUpdated", failure: "MissionUpdateFailed" } })
        (render-ui modal null)
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }, { type: "badge", label: "Active" }] }, { type: "divider" }, { type: "progress-bar", value: 50, showPercentage: true }, { type: "data-grid", entity: "Mission", fields: [], itemActions: [{ label: "Progress", event: "PROGRESS" }, { label: "Complete", event: "COMPLETE" }, { label: "Fail", event: "FAIL", variant: "danger" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
      CANCEL -> active
        (render-ui modal null)
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }, { type: "badge", label: "Active" }] }, { type: "divider" }, { type: "progress-bar", value: 50, showPercentage: true }, { type: "data-grid", entity: "Mission", fields: [], itemActions: [{ label: "Progress", event: "PROGRESS" }, { label: "Complete", event: "COMPLETE" }, { label: "Fail", event: "FAIL", variant: "danger" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
      CLOSE -> active
        (render-ui modal null)
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }, { type: "badge", label: "Active" }] }, { type: "divider" }, { type: "progress-bar", value: 50, showPercentage: true }, { type: "data-grid", entity: "Mission", fields: [], itemActions: [{ label: "Progress", event: "PROGRESS" }, { label: "Complete", event: "COMPLETE" }, { label: "Fail", event: "FAIL", variant: "danger" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
    }
    state complete {
      RESET -> available
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }] }, { type: "divider" }, { type: "data-list", entity: "Mission", fields: [], groupBy: "status", itemActions: [{ label: "Accept", event: "ACCEPT" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
    }
    state failed {
      RESET -> available
        (fetch Mission { emit: { success: "MissionLoaded", failure: "MissionLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "RPG Game", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "flag" }, { type: "typography", content: "Missions Board", variant: "h2" }] }] }, { type: "divider" }, { type: "data-list", entity: "Mission", fields: [], groupBy: "status", itemActions: [{ label: "Accept", event: "ACCEPT" }], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "flag" }, { type: "typography", variant: "h4", content: "@item.title" }] }, { type: "badge", label: "@item.description" }] }, { type: "typography", variant: "caption", content: "@item.status" }] }] }] }] })
    }
    listens {
      * QUEST_ACCEPTED -> INIT
          MissionLoadFailed { message : string }
          SAVE { data : string }
    }
    emits: [MissionLoaded, MissionLoadFailed]
  }
  page "/quests" -> MissionTracking
}