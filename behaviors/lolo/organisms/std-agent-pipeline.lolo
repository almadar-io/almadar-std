;; app std-agent-pipeline

orbital PipelinePlanOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"
  uses Drawer from "std/behaviors/std-drawer"

  entity PipelinePlan [runtime] {
    id : string!
    task : string
    category : string
    steps : string
    confidence : number
    status : string
    relevantMemories : string
    memoryCount : number
    error : string
    input : string
    prompt : string
    response : string
    provider : string
    model : string
    content : string
    scope : string
    strength : number
    pinned : boolean
    action : string
    detail : string
    timestamp : string
    duration : number
    icon : string
  }
  trait PipelinePlanner -> PipelinePlan [interaction] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map", size: "lg" }, { type: "typography", content: "Task Planner", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to plan", variant: "body" }, { type: "form-section", entity: "PipelinePlan", mode: "edit", submitEvent: "PLAN", fields: ["task"] }] }] }] }] })
      PLAN -> classifying
        (set @entity.status classifying)
        (agent/generate (str/concat "Classify this task into exactly one category.\n" "Categories: " "data, transform, validate, deploy, test" "\n" "Task: " @entity.task "\n" "Return only the category name."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "tag", size: "lg" }, { type: "typography", content: "Classifying task...", variant: "h3" }, { type: "spinner", size: "lg" }, { type: "typography", content: "@entity.task", variant: "caption" }] }] })
    }
    state classifying {
      CLASSIFIED -> recalling
        (set @entity.category @payload.category)
        (set @entity.status recalling)
        (agent/recall (str/concat @entity.category " " @entity.task) 5)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "brain", size: "lg" }, { type: "typography", content: "Recalling relevant experience...", variant: "h3" }, { type: "spinner", size: "lg" }, { type: "badge", label: ["str/concat", "Category: ", "@entity.category"] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle", size: "lg" }, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", event: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state recalling {
      MEMORIES_LOADED -> planning
        (set @entity.relevantMemories @payload.memories)
        (set @entity.memoryCount @payload.count)
        (set @entity.status planning)
        (agent/generate (str/concat "Task: " @entity.task "\n" "Category: " @entity.category "\n" "Relevant experience:\n" @entity.relevantMemories "\n\n" "Generate a numbered step-by-step execution plan. " "Include a confidence score (0-100) for how likely this plan will succeed."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu", size: "lg" }, { type: "typography", content: "Generating plan...", variant: "h3" }, { type: "spinner", size: "lg" }, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: ["str/concat", "Category: ", "@entity.category"] }, { type: "badge", label: ["str/concat", ["str/concat", "@entity.memoryCount"], " memories loaded"] }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle", size: "lg" }, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", event: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state planning {
      PLAN_GENERATED -> ready
        (set @entity.steps @payload.steps)
        (set @entity.confidence @payload.confidence)
        (set @entity.status ready)
        (agent/memorize (str/concat "Plan for " @entity.category " task: " @entity.task) pattern-affinity)
        (emit PLAN_READY)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle", size: "lg" }, { type: "typography", content: "Plan Ready", variant: "h2" }] }, { type: "button", label: "New Plan", event: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", columns: 3, children: [{ type: "stat-display", label: "Category", value: "@entity.category", icon: "tag" }, { type: "stat-display", label: "Confidence", value: ["str/concat", ["str/concat", "@entity.confidence"], "%"], icon: "target" }, { type: "stat-display", label: "Memories Used", value: "@entity.memoryCount", icon: "brain" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Task", variant: "caption" }, { type: "typography", content: "@entity.task", variant: "body" }, { type: "divider" }, { type: "typography", content: "Execution Plan", variant: "caption" }, { type: "typography", content: "@entity.steps", variant: "body" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Relevant Memories", variant: "caption" }, { type: "typography", content: "@entity.relevantMemories", variant: "body" }] }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle", size: "lg" }, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", event: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state ready {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.category "")
        (set @entity.steps "")
        (set @entity.confidence 0)
        (set @entity.relevantMemories "")
        (set @entity.memoryCount 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map", size: "lg" }, { type: "typography", content: "Task Planner", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to plan", variant: "body" }, { type: "form-section", entity: "PipelinePlan", mode: "edit", submitEvent: "PLAN", fields: ["task"] }] }] }] }] })
    }
    emits {
      PLAN_READY external { plan: string, category: string }
      PIPELINE_PLANNED internal
      PIPELINE_PLANNED external { steps: string }
    }
    listens {
      * PLAN_READY -> INIT
    }
  }
  trait PlannerTaskInput -> PipelinePlan [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (ref PipelinePlan)
      NEW_TASK -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "icon", name: "map", size: "md" }, { type: "typography", content: "Describe the task to plan", variant: "h3" }, { type: "divider" }, { type: "form-section", entity: "PipelinePlan", mode: "edit", submitEvent: "PLAN", cancelEvent: "CLOSE", fields: ["task"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
      PLAN -> closed
        (render-ui modal null)
    }
    emits {
      PLAN
    }
  }
  trait PlannerClassifierFlow -> PipelinePlan [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag", size: "lg" }, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", event: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      CLASSIFY -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag", size: "md" }, { type: "typography", content: "PipelinePlan", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "typography", variant: "caption", content: "Categories:" }, { type: "badge", label: "data", variant: "secondary" }, { type: "badge", label: "transform", variant: "secondary" }, { type: "badge", label: "validate", variant: "secondary" }, { type: "badge", label: "deploy", variant: "secondary" }, { type: "badge", label: "test", variant: "secondary" }] }, { type: "form-section", entity: "PipelinePlan", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["input"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag", size: "lg" }, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", event: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create PipelinePlan @payload.data)
        (render-ui modal null)
        (emit CLASSIFIED)
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag", size: "lg" }, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", event: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      SAVE internal
      CLASSIFIED internal
    }
  }
  trait PlannerCompletionFlow -> PipelinePlan [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", event: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles", size: "md" }, { type: "typography", content: "PipelinePlan", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", entity: "PipelinePlan", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", event: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create PipelinePlan @payload.data)
        (render-ui modal null)
        (emit GENERATED)
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", event: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      SAVE internal
      GENERATED internal
    }
  }
  trait PlannerMemoryLifecycle -> PipelinePlan [interaction] {
    state browsing {
      INIT -> browsing
        (ref PipelinePlan)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain", size: "lg" }, { type: "typography", content: "PipelinePlan Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", event: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", event: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", event: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: "PipelinePlan", emptyIcon: "inbox", emptyTitle: "No memories yet", emptyDescription: "Create your first memory to get started.", itemActions: [{ label: "Pin", event: "PIN", variant: "ghost", size: "sm" }, { label: "Reinforce", event: "REINFORCE", variant: "ghost", size: "sm" }, { label: "Forget", event: "FORGET", variant: "danger", size: "sm" }], columns: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "strength", label: "Strength", variant: "caption" }] }] }] })
    }
  }
  page "/pipeline" -> PipelinePlanner
}
orbital PipelineExecOrbital {
  entity PipelineExec [runtime] {
    id : string!
    task : string
    plan : string
    iterations : number
    maxIterations : number
    status : string
    result : string
    currentTool : string
    lastToolResult : string
    error : string
    currentStep : number
    totalSteps : number
    steps : string
    toolName : string
    args : string
    prompt : string
    response : string
    provider : string
    model : string
    tokenCount : number
    maxTokens : number
    usage : number
    current : number
    max : number
    threshold : number
    lastCompactedAt : string
    action : string
    detail : string
    timestamp : string
    duration : number
  }
  trait PipelineExecutor -> PipelineExec [interaction] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: "PipelineExec", mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] }] })
      EXECUTE -> planning
        (set @entity.status planning)
        (set @entity.iterations 0)
        (agent/generate (str/concat "Task: " @entity.task "\n\nAvailable tools: " (str/join (agent/tools) ", ") "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "brain", size: "lg" }, { type: "typography", content: "Planning execution...", variant: "h3" }, { type: "spinner", size: "lg" }, { type: "typography", content: "@entity.task", variant: "caption" }] }] })
    }
    state planning {
      PLAN_GENERATED -> executing
        (set @entity.plan @payload.plan)
        (set @entity.currentTool @payload.toolName)
        (set @entity.iterations (+ @entity.iterations 1))
        (agent/invoke @payload.toolName @payload.toolArgs)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "tool", size: "lg" }, { type: "typography", content: "Executing Tool", variant: "h2" }] }, { type: "badge", label: ["str/concat", "Iteration ", ["str/concat", "@entity.iterations"], "/", ["str/concat", "@entity.maxIterations"]] }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Current Tool", variant: "caption" }, { type: "typography", content: "@entity.currentTool", variant: "h4" }, { type: "spinner", size: "md" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Plan", variant: "caption" }, { type: "typography", content: "@entity.plan", variant: "body" }] }] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle", size: "lg" }, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", event: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state executing {
      TOOL_RESULT -> checking
        (set @entity.lastToolResult @payload.output)
        (agent/generate (str/concat "Task: " @entity.task "\nPlan: " @entity.plan "\nTool output: " @payload.output "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "eye", size: "lg" }, { type: "typography", content: "Checking result...", variant: "h3" }, { type: "spinner", size: "lg" }, { type: "badge", label: ["str/concat", "Iteration ", ["str/concat", "@entity.iterations"]] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle", size: "lg" }, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", event: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state checking {
      CHECK_PASSED -> completed
        (set @entity.result @payload.result)
        (set @entity.status completed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle", size: "lg" }, { type: "typography", content: "Loop Complete", variant: "h2" }] }, { type: "button", label: "New Task", event: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Status", value: "@entity.status", icon: "check" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Task", variant: "caption" }, { type: "typography", content: "@entity.task", variant: "body" }, { type: "divider" }, { type: "typography", content: "Result", variant: "caption" }, { type: "typography", content: "@entity.result", variant: "body" }] }] }] }] })
      CHECK_NEEDS_MORE -> executing
        (set @entity.currentTool @payload.toolName)
        (set @entity.iterations (+ @entity.iterations 1))
        (if (>= (agent/context-usage) 0.8) (agent/compact hybrid) (log "Context below compact threshold"))
        (agent/invoke @payload.toolName @payload.toolArgs)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "tool", size: "lg" }, { type: "typography", content: "Executing Tool", variant: "h2" }] }, { type: "badge", label: ["str/concat", "Iteration ", ["str/concat", "@entity.iterations"], "/", ["str/concat", "@entity.maxIterations"]] }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Current Tool", variant: "caption" }, { type: "typography", content: "@entity.currentTool", variant: "h4" }, { type: "spinner", size: "md" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Plan", variant: "caption" }, { type: "typography", content: "@entity.plan", variant: "body" }] }] }] }] })
      MAX_ITERATIONS -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle", size: "lg" }, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", event: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: "PipelineExec", mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: "PipelineExec", mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] }] })
    }
    emits {
      STEP_COMPLETE internal { step: number }
      PIPELINE_FINISHED internal
      STEP_COMPLETE external { step: number }
      PIPELINE_FINISHED external { result: string }
    }
    listens {
      * PIPELINE_PLANNED -> EXECUTE
    }
  }
  trait ToolLoopStepProgress -> PipelineExec [interaction] {
    initial: idle
