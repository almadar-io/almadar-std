app std-field-service "1.0.0"
"Field service: jobs in, assign technicians, optimize routes, check in on-site, and capture a signature on completion. Pick for plumbing/HVAC/dispatch apps."

orbital WorkOrderOrbital {
  uses AppShell    from "std/behaviors/std-app-layout"
  uses Modal       from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses WO          from "std/behaviors/std-work-order"
  uses Dispatch    from "std/behaviors/std-technician-dispatch"
  uses RouteOpt    from "std/behaviors/std-route-optimize"
  uses Search      from "std/behaviors/std-search"
  uses Filter      from "std/behaviors/std-filter"
  uses Browse      from "std/behaviors/std-browse"
  uses Stats       from "std/behaviors/std-stats"

  entity WorkOrderRow [persistent: workorders] {
    id : string!
    customerName : string!
    serviceType : string!
    address : string!
    priority : "low" | "normal" | "high" | "urgent" = "normal"
    status : "created" | "assigned" | "en-route" | "on-site" | "completed" | "cancelled" = "created"
    assignedTo : string = ""
    scheduledAt : string = ""
    etaMinutes : number = 0
    notes : string = ""
    createdAt : string = ""
    pendingId : string = ""
  }

  trait WorkOrderAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.WorkOrderCatalog",
      appName: "Field Service",
      navItems: [{ label: "Work Orders", href: "/workorders", icon: "clipboard-list" }, { label: "Technicians", href: "/technicians", icon: "hard-hat" }, { label: "Check In", href: "/jobs/checkin", icon: "map-pin" }],
      searchEvent: "WORK_ORDER_SEARCH",
      notifications: [],
      notificationClickEvent: "WORK_ORDER_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: WORK_ORDER_SEARCH
      NOTIFY_CLICK: WORK_ORDER_NOTIFICATIONS_OPEN
    }
  }

  trait WorkOrderCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "clipboard-list" },
              { type: "typography", content: "Work Orders", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Work Order", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.WorkOrderSearch",
            "@trait.WorkOrderFilter"
          ]},
          "@trait.WorkOrderStats",
          { type: "divider" },
          "@trait.WorkOrderBrowseList",
          { type: "divider" },
          { type: "typography", content: "Dispatch", variant: "h3" },
          "@trait.WorkOrderDispatch",
          { type: "divider" },
          { type: "typography", content: "Routes", variant: "h3" },
          "@trait.WorkOrderRoutes"
        ]})
      WORK_ORDER_SEARCH -> composing
      WORK_ORDER_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to work orders", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      WorkOrderAppLayout.WORK_ORDER_SEARCH -> WORK_ORDER_SEARCH
      WorkOrderAppLayout.WORK_ORDER_NOTIFICATIONS_OPEN -> WORK_ORDER_NOTIFICATIONS_OPEN
      WORK_ORDER_SEARCH { value : string }
      WORK_ORDER_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait WorkOrderSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search work orders…",
      event: "WORK_ORDER_SEARCH"
    }
  }

  trait WorkOrderFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "priority", label: "Priority", filterType: "select", options: ["low", "normal", "high", "urgent"] },
        { field: "status",   label: "Status",   filterType: "select", options: ["created", "assigned", "en-route", "on-site", "completed", "cancelled"] }
      ],
      event: "WORK_ORDER_FILTER"
    }
  }

  trait WorkOrderStats = Stats.traits.StatsItemStats {
    config: {
      title: "Work Orders",
      metrics: [
        { aggregation: "count", label: "Total",      icon: "clipboard-list", variant: "primary", format: "number" },
        { aggregation: "count", label: "Open",       icon: "circle",         variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "created"]] },
        { aggregation: "count", label: "On Site",    icon: "map-pin",        variant: "info",    format: "number", filter: ["fn", "row", ["=", "@row.status", "on-site"]] },
        { aggregation: "count", label: "Completed",  icon: "check-circle",   variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "completed"]] }
      ]
    }
    listens {
      WorkOrderBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait WorkOrderBrowseList = Browse.traits.BrowseItemBrowse -> WorkOrderRow {
    config: {
      fields: [
        { name: "customerName", variant: "h4",      icon: "user" },
        { name: "serviceType",  variant: "body" },
        { name: "address",      variant: "caption" },
        { name: "priority",     variant: "badge" },
        { name: "status",       variant: "badge" },
        { name: "assignedTo",   variant: "caption" },
        { name: "etaMinutes",   variant: "caption" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      WorkOrderSearch.SEARCH                  -> REFETCH_QUERY
      WorkOrderFilter.FILTER                  -> REFETCH_FILTER
      WorkOrderPersistor.WORK_ORDER_CREATED   -> INIT
      WorkOrderPersistor.WORK_ORDER_UPDATED   -> INIT
      WorkOrderPersistor.WORK_ORDER_DELETED   -> INIT
    }
  }

  trait WorkOrderDispatch = Dispatch.traits.TechnicianDispatch -> WorkOrderRow {
    config: {
      title: "Available Technicians"
    }
  }

  trait WorkOrderRoutes = RouteOpt.traits.RouteOptimize {
    config: {
      title: "Technician Routes"
    }
  }

  trait WorkOrderCreate = Modal.traits.ModalRecordModal -> WorkOrderRow {
    config: {
      icon: "plus-circle",
      title: "New Work Order",
      mode: "create",
      fields: ["customerName", "serviceType", "address", "priority", "status", "assignedTo", "scheduledAt", "etaMinutes", "notes"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      WorkOrderCatalog.CREATE -> CREATE
      CREATE { id : string, row : WorkOrderRow }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait WorkOrderEdit = Modal.traits.ModalRecordModal -> WorkOrderRow {
    config: {
      icon: "edit",
      title: "Edit Work Order",
      mode: "edit",
      fields: ["customerName", "serviceType", "address", "priority", "status", "assignedTo", "scheduledAt", "etaMinutes", "notes"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      WorkOrderBrowseList.EDIT -> EDIT
      EDIT { id : string, row : WorkOrderRow }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait WorkOrderView = Modal.traits.ModalRecordModal -> WorkOrderRow {
    config: {
      icon: "eye",
      title: "View Work Order",
      mode: "edit",
      fields: ["customerName", "serviceType", "address", "priority", "status", "assignedTo", "scheduledAt", "etaMinutes", "notes"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      WorkOrderBrowseList.VIEW -> VIEW
      VIEW { id : string, row : WorkOrderRow }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait WorkOrderDelete = Confirmation.traits.ConfirmActionConfirmation -> WorkOrderRow {
    config: {
      icon: "alert-triangle",
      title: "Delete Work Order",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      WorkOrderBrowseList.DELETE -> DELETE
      DELETE { id : string, row : WorkOrderRow }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait WorkOrderPersistor -> WorkOrderRow [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create WorkOrderRow @payload.data { emit: { success: "WORK_ORDER_CREATED" } })
      DO_UPDATE -> idle
        (persist update WorkOrderRow @payload.data { emit: { success: "WORK_ORDER_UPDATED" } })
      DO_DELETE -> idle
        (persist delete WorkOrderRow @payload.id { emit: { success: "WORK_ORDER_DELETED" } })
    }
    emits {
      WORK_ORDER_CREATED -> external { id : string }
      WORK_ORDER_UPDATED -> external { id : string }
      WORK_ORDER_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      WorkOrderCreate.SAVE          -> DO_CREATE
      WorkOrderEdit.SAVE            -> DO_UPDATE
      WorkOrderDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/workorders" as WorkOrdersPage -> WorkOrderAppLayout, WorkOrderCatalog, WorkOrderSearch, WorkOrderFilter, WorkOrderStats, WorkOrderBrowseList, WorkOrderDispatch, WorkOrderRoutes, WorkOrderCreate, WorkOrderEdit, WorkOrderView, WorkOrderDelete, WorkOrderPersistor
}

orbital TechnicianOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Modal    from "std/behaviors/std-modal"
  uses Dispatch from "std/behaviors/std-technician-dispatch"
  uses Checkin  from "std/behaviors/std-checkin"
  uses Browse   from "std/behaviors/std-browse"

  entity TechnicianRow [persistent: technicians] {
    id : string!
    name : string!
    phone : string = ""
    skills : [string] = []
    available : boolean = true
    currentOrderId : string = ""
    lat : number = 0
    lng : number = 0
    lastSeenAt : string = ""
    pendingId : string = ""
  }

  trait TechnicianAppLayout = AppShell.traits.AppLayout -> TechnicianRow {
    config: {
      contentTrait: "@trait.TechnicianCatalog",
      appName: "Field Service",
      navItems: [{ label: "Work Orders", href: "/workorders", icon: "clipboard-list" }, { label: "Technicians", href: "/technicians", icon: "hard-hat" }, { label: "Check In", href: "/jobs/checkin", icon: "map-pin" }],
      searchEvent: "TECHNICIAN_SEARCH",
      notifications: [],
      notificationClickEvent: "TECHNICIAN_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: TECHNICIAN_SEARCH
      NOTIFY_CLICK: TECHNICIAN_NOTIFICATIONS_OPEN
    }
  }

  trait TechnicianCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "hard-hat" },
              { type: "typography", content: "Technicians", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Add Technician", action: "CREATE", variant: "primary", icon: "user-plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.TechnicianBrowseList",
          { type: "divider" },
          { type: "typography", content: "Dispatch Board", variant: "h3" },
          "@trait.TechnicianDispatchBoard",
          { type: "divider" },
          { type: "typography", content: "Field Check-In", variant: "h3" },
          "@trait.TechnicianFieldCheckin"
        ]})
      TECHNICIAN_SEARCH -> composing
      TECHNICIAN_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to technicians", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      TechnicianAppLayout.TECHNICIAN_SEARCH -> TECHNICIAN_SEARCH
      TechnicianAppLayout.TECHNICIAN_NOTIFICATIONS_OPEN -> TECHNICIAN_NOTIFICATIONS_OPEN
      TECHNICIAN_SEARCH { value : string }
      TECHNICIAN_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait TechnicianBrowseList = Browse.traits.BrowseItemBrowse -> TechnicianRow {
    config: {
      fields: [
        { name: "name",           variant: "h4",      icon: "hard-hat" },
        { name: "phone",          variant: "caption" },
        { name: "skills",         variant: "caption" },
        { name: "available",      variant: "badge" },
        { name: "currentOrderId", variant: "caption" },
        { name: "lastSeenAt",     variant: "caption" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      TechnicianPersistor.TECHNICIAN_CREATED -> INIT
      TechnicianPersistor.TECHNICIAN_UPDATED -> INIT
      TechnicianPersistor.TECHNICIAN_DELETED -> INIT
    }
  }

  trait TechnicianDispatchBoard = Dispatch.traits.TechnicianDispatch {
    config: {
      title: "Dispatch Board"
    }
  }

  trait TechnicianFieldCheckin = Checkin.traits.CheckinScan -> TechnicianRow {
    config: {
      mode: "geo",
      title: "Technician Check-In"
    }
  }

  trait TechnicianCreate = Modal.traits.ModalRecordModal -> TechnicianRow {
    config: {
      icon: "user-plus",
      title: "Add Technician",
      mode: "create",
      fields: ["name", "phone", "skills", "available", "currentOrderId", "lat", "lng"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      TechnicianCatalog.CREATE -> CREATE
      CREATE { id : string, row : TechnicianRow }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TechnicianEdit = Modal.traits.ModalRecordModal -> TechnicianRow {
    config: {
      icon: "edit",
      title: "Edit Technician",
      mode: "edit",
      fields: ["name", "phone", "skills", "available", "currentOrderId", "lat", "lng"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      TechnicianBrowseList.EDIT -> EDIT
      EDIT { id : string, row : TechnicianRow }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TechnicianView = Modal.traits.ModalRecordModal -> TechnicianRow {
    config: {
      icon: "eye",
      title: "View Technician",
      mode: "edit",
      fields: ["name", "phone", "skills", "available", "currentOrderId", "lat", "lng", "lastSeenAt"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      TechnicianBrowseList.VIEW -> VIEW
      VIEW { id : string, row : TechnicianRow }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TechnicianPersistor -> TechnicianRow [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create TechnicianRow @payload.data { emit: { success: "TECHNICIAN_CREATED" } })
      DO_UPDATE -> idle
        (persist update TechnicianRow @payload.data { emit: { success: "TECHNICIAN_UPDATED" } })
      DO_DELETE -> idle
        (persist delete TechnicianRow @payload.id { emit: { success: "TECHNICIAN_DELETED" } })
    }
    emits {
      TECHNICIAN_CREATED -> external { id : string }
      TECHNICIAN_UPDATED -> external { id : string }
      TECHNICIAN_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      TechnicianCreate.SAVE -> DO_CREATE
      TechnicianEdit.SAVE   -> DO_UPDATE
    }
  }

  page "/technicians" as TechniciansPage -> TechnicianAppLayout, TechnicianCatalog, TechnicianBrowseList, TechnicianDispatchBoard, TechnicianFieldCheckin, TechnicianCreate, TechnicianEdit, TechnicianView, TechnicianPersistor
}

orbital JobCheckinOrbital {
  uses AppShell  from "std/behaviors/std-app-layout"
  uses Checkin   from "std/behaviors/std-checkin"
  uses Signature from "std/behaviors/std-signature-capture"

  entity JobCheckinRow [runtime] {
    id : string!
  }

  type JobCheckinRowLoaded     = Event { data : [JobCheckinRow] }
  type JobCheckinRowLoadFailed = Event { error : string, code : string }

  trait JobCheckinAppLayout = AppShell.traits.AppLayout -> JobCheckinRow {
    config: {
      contentTrait: "@trait.JobCheckinComposer",
      appName: "Field Service",
      navItems: [{ label: "Work Orders", href: "/workorders", icon: "clipboard-list" }, { label: "Technicians", href: "/technicians", icon: "hard-hat" }, { label: "Check In", href: "/jobs/checkin", icon: "map-pin" }],
      searchEvent: "JOB_CHECKIN_SEARCH",
      notifications: [],
      notificationClickEvent: "JOB_CHECKIN_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: JOB_CHECKIN_SEARCH
      NOTIFY_CLICK: JOB_CHECKIN_NOTIFICATIONS_OPEN
    }
  }

  trait JobCheckinComposer [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-3xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "icon", name: "map-pin" },
            { type: "typography", content: "Job Check-In", variant: "h2" }
          ]},
          { type: "typography", variant: "caption", color: "muted", content: "Verify your arrival, complete the job, and capture the customer's signature." },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "1. Arrival check-in" },
          "@trait.JobArrivalCheckin",
          { type: "divider" },
          { type: "typography", variant: "h3", content: "2. Customer signature" },
          "@trait.JobCompletionSignature"
        ]})
    }
  }

  trait JobArrivalCheckin = Checkin.traits.CheckinScan {
    config: {
      mode: "geo",
      title: "Confirm arrival on site"
    }
  }

  trait JobCompletionSignature = Signature.traits.SignatureCapture {
    config: {
      title: "Customer signature",
      instructions: "Customer signs to confirm the job is complete."
    }
  }

  page "/jobs/checkin" as JobCheckinPage -> JobCheckinAppLayout, JobCheckinComposer, JobArrivalCheckin, JobCompletionSignature
}
