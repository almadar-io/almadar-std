app std-project-manager "2.0.0"
"Project manager: tasks with stats/graphs/calendar, sprints with planning, and burndown metrics. Pick for agile/scrum-style PM tools."

orbital TaskOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Search       from "std/behaviors/std-search"
  uses Filter       from "std/behaviors/std-filter"
  uses Stats        from "std/behaviors/std-stats"
  uses Graphs       from "std/behaviors/std-graphs"
  uses Calendar     from "std/behaviors/std-calendar"
  uses Selection    from "std/behaviors/std-selection"
  uses Browse       from "std/behaviors/std-browse"

  entity Task [persistent: tasks] {
    id : string!
    title : string!
    description : string = ""
    assignee : string = ""
    priority : "low" | "medium" | "high" | "critical" = "medium"
    status : "todo" | "in-progress" | "review" | "done" = "todo"
    sprint : string = ""
    storyPoints : number = 0
    dueDate : string = ""
    pendingId : string = ""
  }

  trait TaskAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.TaskCatalog",
      appName: "ProjectManagerApp",
      navItems: [{ label: "Tasks", href: "/tasks", icon: "list-todo" }, { label: "Sprints", href: "/sprints", icon: "zap" }, { label: "Burndown", href: "/burndown", icon: "trending-down" }],
      searchEvent: "TASK_SEARCH",
      notifications: [],
      notificationClickEvent: "TASK_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: TASK_SEARCH
      NOTIFY_CLICK: TASK_NOTIFICATIONS_OPEN
    }
  }

  trait TaskCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "list-todo" },
              { type: "typography", content: "Tasks", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Task", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.TaskSearch",
            "@trait.TaskFilter"
          ]},
          "@trait.TaskStats",
          "@trait.TaskGraphs",
          "@trait.TaskCalendar",
          { type: "divider" },
          "@trait.TaskBrowseList"
        ]})
      TASK_SEARCH -> composing
      TASK_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to tasks", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      TaskAppLayout.TASK_SEARCH -> TASK_SEARCH
      TaskAppLayout.TASK_NOTIFICATIONS_OPEN -> TASK_NOTIFICATIONS_OPEN
      TASK_SEARCH { value : string }
      TASK_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait TaskSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search tasks…",
      event: "TASK_SEARCH"
    }
  }

  trait TaskFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "status",   label: "Status",   filterType: "select", options: ["todo", "in-progress", "review", "done"] },
        { field: "assignee", label: "Assignee", filterType: "text" },
        { field: "priority", label: "Priority", filterType: "select", options: ["low", "medium", "high", "critical"] },
        { field: "sprint",   label: "Sprint",   filterType: "text" }
      ],
      event: "TASK_FILTER"
    }
  }

  trait TaskStats = Stats.traits.StatsItemStats {
    config: {
      title: "Tasks",
      metrics: [
        { aggregation: "count", label: "Total",       icon: "list-todo",    variant: "primary", format: "number" },
        { aggregation: "count", label: "Todo",        icon: "circle",       variant: "muted",   format: "number", filter: ["fn", "row", ["=", "@row.status", "todo"]] },
        { aggregation: "count", label: "In Progress", icon: "loader",       variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "in-progress"]] },
        { aggregation: "count", label: "Done",        icon: "check-circle", variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "done"]] },
        { aggregation: "count", label: "Critical",    icon: "alert-octagon", variant: "danger",  format: "number", filter: ["fn", "row", ["=", "@row.priority", "critical"]] }
      ]
    }
    listens {
      TaskBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait TaskGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Tasks by Status",
      subtitle: "Workload distribution across status buckets",
      chartType: "bar",
      categoryField: "status",
      aggregation: "count",
      height: 240,
      showLegend: false
    }
    listens {
      TaskBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait TaskCalendar = Calendar.traits.CalendarEventCalendar -> Task {
    config: {
      dateField:  "dueDate",
      titleField: "title",
      colorField: "priority"
    }
  }

  trait TaskBrowseList = Browse.traits.BrowseItemBrowse -> Task {
    config: {
      fields: [
        { name: "title",    variant: "h3",      icon: "list-todo" },
        { name: "status",   variant: "badge" },
        { name: "assignee", variant: "body" },
        { name: "priority", variant: "badge" },
        { name: "dueDate",  label: "Due",       variant: "caption", format: "date" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      TaskSearch.SEARCH               -> REFETCH_QUERY
      TaskFilter.FILTER               -> REFETCH_FILTER
      TaskPersistor.TASK_CREATED      -> INIT
      TaskPersistor.TASK_UPDATED      -> INIT
      TaskPersistor.TASK_DELETED      -> INIT
    }
  }

  trait TaskCreate = Modal.traits.ModalRecordModal -> Task {
    config: {
      icon: "plus-circle",
      title: "New Task",
      mode: "create",
      fields: ["title", "description", "assignee", "priority", "status", "sprint", "storyPoints", "dueDate"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      TaskCatalog.CREATE -> CREATE
      CREATE { id : string, row : Task }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TaskEdit = Modal.traits.ModalRecordModal -> Task {
    config: {
      icon: "edit",
      title: "Edit Task",
      mode: "edit",
      fields: ["title", "description", "assignee", "priority", "status", "sprint", "storyPoints", "dueDate"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      TaskBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Task }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TaskView = Modal.traits.ModalRecordModal -> Task {
    config: {
      icon: "eye",
      title: "View Task",
      mode: "edit",
      fields: ["title", "description", "assignee", "priority", "status", "sprint", "storyPoints", "dueDate"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      TaskBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Task }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TaskDelete = Confirmation.traits.ConfirmActionConfirmation -> Task {
    config: {
      icon: "alert-triangle",
      title: "Delete Task",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      TaskBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Task }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait TaskPersistor -> Task [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Task @payload.data { emit: { success: "TASK_CREATED" } })
      DO_UPDATE -> idle
        (persist update Task @payload.data { emit: { success: "TASK_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Task @payload.id { emit: { success: "TASK_DELETED" } })
    }
    emits {
      TASK_CREATED -> external { id : string }
      TASK_UPDATED -> external { id : string }
      TASK_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      TaskCreate.SAVE          -> DO_CREATE
      TaskEdit.SAVE            -> DO_UPDATE
      TaskDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/tasks" as TasksPage -> TaskAppLayout, TaskCatalog, TaskSearch, TaskFilter, TaskStats, TaskGraphs, TaskCalendar, TaskBrowseList, TaskCreate, TaskEdit, TaskView, TaskDelete, TaskPersistor
}

orbital SprintOrbital {
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Browse       from "std/behaviors/std-browse"

  entity Sprint [persistent: sprints] {
    id : string!
    name : string!
    startDate : string!
    endDate : string!
    goal : string = ""
    status : "planning" | "active" | "completed" = "planning"
    taskCount : number = 0
    pendingId : string = ""
  }

  trait SprintCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "zap" },
              { type: "typography", content: "Sprints", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Sprint", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.SprintBrowseList"
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  trait SprintBrowseList = Browse.traits.BrowseItemBrowse -> Sprint {
    config: {
      fields: [
        { name: "name",      variant: "h3",      icon: "zap" },
        { name: "status",    variant: "badge" },
        { name: "goal",      variant: "body" },
        { name: "startDate", label: "Start",     variant: "caption", format: "date" },
        { name: "endDate",   label: "End",       variant: "caption", format: "date" },
        { name: "taskCount", label: "Tasks",     variant: "body",    format: "number" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      SprintPersistor.SPRINT_CREATED -> INIT
      SprintPersistor.SPRINT_UPDATED -> INIT
      SprintPersistor.SPRINT_DELETED -> INIT
    }
  }

  trait SprintCreate = Modal.traits.ModalRecordModal -> Sprint {
    config: {
      icon: "plus-circle",
      title: "New Sprint",
      mode: "create",
      fields: ["name", "startDate", "endDate", "goal", "status", "taskCount"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      SprintCatalog.CREATE -> CREATE
      CREATE { id : string, row : Sprint }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait SprintEdit = Modal.traits.ModalRecordModal -> Sprint {
    config: {
      icon: "edit",
      title: "Edit Sprint",
      mode: "edit",
      fields: ["name", "startDate", "endDate", "goal", "status", "taskCount"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      SprintBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Sprint }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait SprintView = Modal.traits.ModalRecordModal -> Sprint {
    config: {
      icon: "eye",
      title: "View Sprint",
      mode: "edit",
      fields: ["name", "startDate", "endDate", "goal", "status", "taskCount"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      SprintBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Sprint }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait SprintDelete = Confirmation.traits.ConfirmActionConfirmation -> Sprint {
    config: {
      icon: "alert-triangle",
      title: "Delete Sprint",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      SprintBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Sprint }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait SprintPersistor -> Sprint [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Sprint @payload.data { emit: { success: "SPRINT_CREATED" } })
      DO_UPDATE -> idle
        (persist update Sprint @payload.data { emit: { success: "SPRINT_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Sprint @payload.id { emit: { success: "SPRINT_DELETED" } })
    }
    emits {
      SPRINT_CREATED -> external { id : string }
      SPRINT_UPDATED -> external { id : string }
      SPRINT_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      SprintCreate.SAVE           -> DO_CREATE
      SprintEdit.SAVE             -> DO_UPDATE
      SprintDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/sprints" -> SprintCatalog, SprintBrowseList, SprintCreate, SprintEdit, SprintView, SprintDelete, SprintPersistor
}

orbital BurndownOrbital {
  entity Burndown [singleton] {
    id : string!
    totalPoints : number = 0
    completedPoints : number = 0
    remainingPoints : number = 0
    velocity : number = 0
    daysRemaining : number = 0
  }

  type BurndownLoaded     = Event { data : [Burndown] }                  "Fired when Burndown finishes loading"
  type BurndownLoadFailed = Event { error : string, code : string }      "Fired when Burndown fails to load"

  ;; Cross-orbital @trait.X references aren't supported (std-cms gap), so the
  ;; burndown view aggregates locally with an inline line-chart instead of
  ;; embedding TaskStats + TaskGraphs from TaskOrbital.
  trait BurndownDisplay -> Burndown [interaction, instance] {
    initial: loading
    state loading {
      INIT -> displaying
        (set @entity.totalPoints 0)
        (set @entity.completedPoints 0)
        (set @entity.remainingPoints 0)
        (set @entity.velocity 0)
        (set @entity.daysRemaining 0)
        (fetch Burndown { emit: { success: "BurndownLoaded", failure: "BurndownLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-6xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "icon", name: "trending-down" },
            { type: "typography", content: "Burndown", variant: "h2" }
          ]},
          { type: "divider" },
          { type: "simple-grid", cols: 5, children: [
            { type: "stat-display", label: "Total Points",     value: "@entity.totalPoints",     icon: "target" },
            { type: "stat-display", label: "Completed",        value: "@entity.completedPoints", icon: "check-circle" },
            { type: "stat-display", label: "Remaining",        value: "@entity.remainingPoints", icon: "circle" },
            { type: "stat-display", label: "Velocity",         value: "@entity.velocity",        icon: "zap" },
            { type: "stat-display", label: "Days Remaining",   value: "@entity.daysRemaining",   icon: "calendar" }
          ]},
          { type: "divider" },
          { type: "line-chart", data: [
            { date: "Day 1",  value: 100 },
            { date: "Day 2",  value: 92 },
            { date: "Day 3",  value: 85 },
            { date: "Day 4",  value: 70 },
            { date: "Day 5",  value: 60 },
            { date: "Day 6",  value: 45 },
            { date: "Day 7",  value: 30 },
            { date: "Day 8",  value: 15 }
          ]},
          { type: "chart-legend", items: [
            { label: "Remaining points", color: "primary" },
            { label: "Ideal burndown",   color: "muted" }
          ]},
          { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [
            { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }
          ]}
        ]})
    }
    state displaying {
      REFRESH -> displaying
        (fetch Burndown { emit: { success: "BurndownLoaded", failure: "BurndownLoadFailed" } })
      BurndownLoaded -> displaying
    }
    emits {
      BurndownLoaded
      BurndownLoadFailed
    }
    listens {
      SprintOrbital.SprintPersistor.SPRINT_UPDATED -> REFRESH
      BurndownLoadFailed { error : string, code : string }
    }
  }

  page "/burndown" -> BurndownDisplay
}
